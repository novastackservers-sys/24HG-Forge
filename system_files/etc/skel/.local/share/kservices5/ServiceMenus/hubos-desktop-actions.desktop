[Desktop Entry]
Type=Service
ServiceTypes=KonqPopupMenu/Plugin
MimeType=application/octet-stream;inode/directory;
Actions=openHub;quickConnect;performance;serverStatus;screenshot;

[Desktop Action openHub]
Name=Open 24HG Hub
Icon=hubos-logo
Exec=/usr/bin/hubos-hub

[Desktop Action quickConnect]
Name=Quick Connect to Server
Icon=network-connect
Exec=konsole -e hubos-server-status --once

[Desktop Action performance]
Name=Toggle Gaming Mode
Icon=speedometer
Exec=/usr/bin/hubos-performance gaming

[Desktop Action serverStatus]
Name=Server Status
Icon=network-server
Exec=konsole -e hubos-server-status --once

[Desktop Action screenshot]
Name=Take Screenshot
Icon=camera-photo
Exec=/usr/bin/hubos-screenshot full
