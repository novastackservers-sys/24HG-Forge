[Desktop Entry]
Version=1.0
Type=Application
Name=24HG Forge Tools
Comment=Gaming tools and diagnostics
Exec=konsole -e bash -c 'echo "=== 24HG Forge Gaming Tools ==="; echo ""; echo "  forge-performance  - Switch performance profile"; echo "  forge-server-status - Live server status"; echo "  forge-proton-fix   - Fix game launch issues"; echo "  forge-benchmark    - System benchmark"; echo "  forge-diag         - Full diagnostics"; echo "  forge-achievements - Your achievements"; echo "  forge-game-timer   - Playtime stats"; echo "  forge-tips         - Gaming tips"; echo ""; echo "Type any command to get started."; echo ""; exec bash'
Icon=utilities-terminal
Terminal=false
Categories=System;
