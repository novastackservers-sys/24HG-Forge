<?xml version="1.0" encoding="utf-8"?>
<zone target="DROP">
  <short>24HG Gaming</short>
  <description>
    24HG gaming-optimized firewall zone. Allows Steam, Source engine,
    Rust, Sunshine remote play, WireGuard VPN, and LAN gaming traffic.
    All other inbound connections are dropped and logged. SSH is rate-limited
    to 5 connections per minute to prevent brute-force attacks.
  </description>

  <!-- ================================================================== -->
  <!-- Services                                                           -->
  <!-- ================================================================== -->

  <!-- SSH (rate-limited via rich rules below) -->
  <service name="ssh"/>

  <!-- DHCPv6 client (needed for network autoconfiguration) -->
  <service name="dhcpv6-client"/>

  <!-- ================================================================== -->
  <!-- Steam Client (TCP + UDP 27015-27050)                               -->
  <!-- Covers: Steam client, game servers, Steam Remote Play,             -->
  <!-- Steam Voice Chat, Steam matchmaking                                -->
  <!-- ================================================================== -->
  <port protocol="tcp" port="27015-27050"/>
  <port protocol="udp" port="27015-27050"/>

  <!-- ================================================================== -->
  <!-- Source Engine (UDP 27000-27030)                                     -->
  <!-- Covers: Source engine game traffic, HLTV, client ports             -->
  <!-- ================================================================== -->
  <port protocol="udp" port="27000-27030"/>

  <!-- ================================================================== -->
  <!-- Rust (TCP + UDP 28015-28016)                                       -->
  <!-- 28015: Game port                                                   -->
  <!-- 28016: RCON port                                                   -->
  <!-- ================================================================== -->
  <port protocol="tcp" port="28015-28016"/>
  <port protocol="udp" port="28015-28016"/>

  <!-- ================================================================== -->
  <!-- Sunshine Remote Play                                               -->
  <!-- TCP 47984-47990: Control, HTTPS, HTTP                              -->
  <!-- TCP 48010: RTSP                                                    -->
  <!-- UDP 47998-48000: Video, control, audio streams                     -->
  <!-- ================================================================== -->
  <port protocol="tcp" port="47984-47990"/>
  <port protocol="tcp" port="48010"/>
  <port protocol="udp" port="47998-48000"/>

  <!-- ================================================================== -->
  <!-- WireGuard VPN (UDP 51820)                                          -->
  <!-- ================================================================== -->
  <port protocol="udp" port="51820"/>

  <!-- ================================================================== -->
  <!-- mDNS (UDP 5353)                                                    -->
  <!-- Required for: Avahi, local service discovery, Chromecast           -->
  <!-- ================================================================== -->
  <port protocol="udp" port="5353"/>

  <!-- ================================================================== -->
  <!-- LAN Discovery (UDP 24240)                                          -->
  <!-- Used by various games for local network game discovery             -->
  <!-- ================================================================== -->
  <port protocol="udp" port="24240"/>

  <!-- ================================================================== -->
  <!-- Voice Chat (UDP 24250-24251)                                       -->
  <!-- 24HG voice chat / LAN party communication                        -->
  <!-- ================================================================== -->
  <port protocol="udp" port="24250-24251"/>

  <!-- ================================================================== -->
  <!-- Rich Rules                                                         -->
  <!-- ================================================================== -->

  <!-- Rate-limit SSH: max 5 new connections per minute (IPv4) -->
  <rule family="ipv4">
    <source address="0.0.0.0/0"/>
    <service name="ssh"/>
    <accept>
      <limit value="5/m"/>
    </accept>
  </rule>

  <!-- Rate-limit SSH: max 5 new connections per minute (IPv6) -->
  <rule family="ipv6">
    <source address="::/0"/>
    <service name="ssh"/>
    <accept>
      <limit value="5/m"/>
    </accept>
  </rule>

  <!-- Log dropped packets (rate-limited to 10/min to prevent log spam) -->
  <rule>
    <log prefix="24HG-DROP: " level="info">
      <limit value="10/m"/>
    </log>
    <drop/>
  </rule>

</zone>
