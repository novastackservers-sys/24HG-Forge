# Caddyfile for os.24hgaming.com
# ISO files are served directly from /iso/ directory

os.24hgaming.com {
    root * /srv/landing-page
    file_server

    # Allow large file downloads (ISOs)
    handle /iso/* {
        file_server {
            precompressed gzip
        }
        header Content-Disposition "attachment"
    }

    # Clean URLs (optional)
    try_files {path} {path}.html
}
