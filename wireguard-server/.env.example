# 24HG Discovery VPN — Environment Variables
# Copy to .env and fill in values before running setup.sh

# Public hostname for the WireGuard endpoint (included in client configs)
WG_SERVER_URL=vpn.24hgaming.com

# Hub API URL for validating user auth tokens
HUB_VALIDATE_URL=https://hub.24hgaming.com/api/auth/validate

# Timezone for the WireGuard container
TZ=Europe/Berlin
