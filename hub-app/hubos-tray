            unread = hub_state.get("unread_notifications", 0)
            unread_dms = hub_state.get("unread_dms", 0)
            online_friends = hub_state.get("online_friends", 0)

            hub_label = f"Hub: {username}"
            badges = []
            if unread > 0:
                badges.append(f"{unread} notif")
            if unread_dms > 0:
                badges.append(f"{unread_dms} DMs")
            if online_friends > 0:
                badges.append(f"{online_friends} friends online")
            if badges:
                hub_label += f" — {', '.join(badges)}"

            hub_info = Gtk.MenuItem(label=hub_label)
            hub_info.set_sensitive(False)
            menu.append(hub_info)
