        ach_item.connect("activate", lambda w: subprocess.Popen(["konsole", "-e", "hubos-achievements", "list"]))
        personal_menu.append(ach_item)

        wp_item = Gtk.MenuItem(label="Wallpaper")
        wp_menu = Gtk.Menu()
        for action, desc in [("random", "Random Wallpaper"), ("rotate", "Time-Based Rotation"), ("list", "Browse Wallpapers")]:
            wi = Gtk.MenuItem(label=desc)
            wi.connect("activate", lambda w, a=action: subprocess.Popen(["/usr/bin/hubos-wallpaper", a]))
            wp_menu.append(wi)
        wp_item.set_submenu(wp_menu)
        personal_menu.append(wp_item)

        snd_item = Gtk.MenuItem(label="Sounds")
        snd_menu = Gtk.Menu()
        for action, desc in [("enable", "Enable HubOS Sounds"), ("disable", "Use Default Sounds"), ("test", "Test All Sounds")]:
            si = Gtk.MenuItem(label=desc)
            si.connect("activate", lambda w, a=action: subprocess.Popen(["konsole", "-e", "hubos-sounds", a]))
            snd_menu.append(si)
        snd_item.set_submenu(snd_menu)
        personal_menu.append(snd_item)

        notif_item = Gtk.MenuItem(label="Notification Style")
        notif_menu = Gtk.Menu()
        for action, desc in [("gaming", "Gaming (Compact, Top-Right)"), ("desktop", "Desktop (Default)"), ("minimal", "Minimal (Quiet)")]:
            ni = Gtk.MenuItem(label=desc)
            ni.connect("activate", lambda w, a=action: subprocess.Popen(["/usr/bin/hubos-notify-style", a]))
            notif_menu.append(ni)
        notif_item.set_submenu(notif_menu)
        personal_menu.append(notif_item)

        personal_item.set_submenu(personal_menu)
        menu.append(personal_item)

        discord = Gtk.MenuItem(label="Discord")
        discord.connect("activate", open_discord)
        menu.append(discord)

        menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", Gtk.main_quit)
        menu.append(quit_item)

        menu.show_all()
        self.menu = menu

    def refresh_menu(self):
        """Periodically rebuild the menu to update player counts."""
        self.build_menu()
        if self.indicator:
            self.indicator.set_menu(self.menu)
        return True  # Keep the timer running

    def setup_indicator(self):
        if AppIndicator3:
            self.indicator = AppIndicator3.Indicator.new(
                "hubos-tray",
                ICON_NAME,
                AppIndicator3.IndicatorCategory.APPLICATION_STATUS
            )
            self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.indicator.set_title("24HG Hub")
            self.indicator.set_menu(self.menu)
        else:
            self.status_icon = Gtk.StatusIcon.new_from_icon_name(ICON_NAME)
            self.status_icon.set_title("24HG Hub")
            self.status_icon.set_tooltip_text("24 Hour Gaming — Right-click for servers")
            self.status_icon.connect("popup-menu",
                                     lambda i, b, t: self.menu.popup(None, None, None, None, b, t))
            self.status_icon.connect("activate", open_hub)


def main():
    tray = HubOSTray()
    Gtk.main()


if __name__ == "__main__":
    main()
