#!/bin/bash
# HubOS Hub Launcher — Branded Chromium kiosk pointing at hub.24hgaming.com
# Upgradeable to Tauri native app in the future

HUB_URL="https://hub.24hgaming.com"
APP_NAME="24HG Hub"
USER_DATA_DIR="${HOME}/.config/hubos-hub"

# Ensure data directory exists
mkdir -p "${USER_DATA_DIR}"

# Detect if running in Gamescope session
IN_GAMESCOPE=false
if [ -n "${GAMESCOPE_WAYLAND_DISPLAY}" ] || [ "${XDG_CURRENT_DESKTOP}" = "gamescope" ]; then
    IN_GAMESCOPE=true
fi

# Build Chromium flags
CHROME_FLAGS=(
    "--app=${HUB_URL}"
    "--user-data-dir=${USER_DATA_DIR}"
    "--class=hubos-hub"
    "--no-first-run"
    "--no-default-browser-check"
    "--disable-translate"
    "--disable-sync"
    "--enable-features=UseOzonePlatform,WebRTCPipeWireCapturer"
    "--enable-gpu-rasterization"
    "--enable-zero-copy"
    "--force-dark-mode"
)

# In Gamescope mode, go fullscreen and optimize for gamepad
if [ "${IN_GAMESCOPE}" = true ]; then
    CHROME_FLAGS+=(
        "--start-fullscreen"
        "--kiosk"
        "--ozone-platform=wayland"
    )
else
    CHROME_FLAGS+=(
        "--start-maximized"
        "--ozone-platform-hint=auto"
    )
fi

# Launch Chromium
exec chromium-browser "${CHROME_FLAGS[@]}" "$@" 2>/dev/null
