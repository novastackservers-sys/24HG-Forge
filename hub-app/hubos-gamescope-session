#!/bin/bash
# HubOS Gamescope Session — Console-like experience
# Launches Gamescope compositor with the 24HG Hub app

# ── Resolution detection (Wayland-first, X11 fallback, sysfs last) ──
detect_resolution() {
    local res=""

    # Try wlr-randr (Wayland)
    if command -v wlr-randr &>/dev/null; then
        res=$(wlr-randr 2>/dev/null | grep -oP '\d+x\d+' | head -1)
    fi

    # Fallback: swaymsg (sway/wlroots)
    if [ -z "$res" ] && command -v swaymsg &>/dev/null; then
        res=$(swaymsg -t get_outputs 2>/dev/null | grep -oP '"current_mode".*?"width":\s*\K\d+' | head -1)
        if [ -n "$res" ]; then
            local h=$(swaymsg -t get_outputs 2>/dev/null | grep -oP '"current_mode".*?"height":\s*\K\d+' | head -1)
            res="${res}x${h}"
        fi
    fi

    # Fallback: xdpyinfo (X11)
    if [ -z "$res" ] && command -v xdpyinfo &>/dev/null; then
        res=$(xdpyinfo 2>/dev/null | grep dimensions | awk '{print $2}')
    fi

    # Fallback: DRM sysfs (works even without display server)
    if [ -z "$res" ]; then
        for mode_file in /sys/class/drm/card*-*/modes; do
            if [ -f "$mode_file" ]; then
                res=$(head -1 "$mode_file" 2>/dev/null)
                [ -n "$res" ] && break
            fi
        done
    fi

    echo "${res:-1920x1080}"
}

RESOLUTION=$(detect_resolution)
WIDTH="${RESOLUTION%x*}"
HEIGHT="${RESOLUTION#*x}"

# Validate dimensions
[[ "$WIDTH" =~ ^[0-9]+$ ]] || WIDTH=1920
[[ "$HEIGHT" =~ ^[0-9]+$ ]] || HEIGHT=1080

# Gamescope flags
GAMESCOPE_FLAGS=(
    -W "${WIDTH}"
    -H "${HEIGHT}"
    -w "${WIDTH}"
    -h "${HEIGHT}"
    --adaptive-sync
    --force-grab-cursor
    --expose-wayland
    --steam
)

# MangoHud config for performance overlay (toggle with F12)
export MANGOHUD=1
export MANGOHUD_CONFIG="position=top-left,fps,gpu_stats,cpu_stats,ram,vram,frame_timing,toggle_hud=F12"

# Gaming environment
export SDL_VIDEO_MINIMIZE_ON_FOCUS_LOSS=0
export DXVK_FRAME_RATE=0

# Launch Gamescope with Hub app
exec gamescope "${GAMESCOPE_FLAGS[@]}" -- /usr/bin/hubos-hub
