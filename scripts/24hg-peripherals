#!/usr/bin/env bash
# 24hg-peripherals — Gaming peripheral manager for 24HG
# Replaces Razer Synapse / iCUE / Logitech G Hub on Linux.
# Uses libratbag/ratbagctl for mice, openrgb for RGB, xdotool/ydotool for macros.
# Profiles stored in ~/.config/24hg/peripherals/
set -euo pipefail

CONFIG_DIR="${HOME}/.config/24hg/peripherals"
PROFILES_DIR="${CONFIG_DIR}/profiles"
MACROS_DIR="${CONFIG_DIR}/macros"
ASSIGNMENTS="${CONFIG_DIR}/.assignments"
DAEMON_PID="${XDG_RUNTIME_DIR:-/tmp}/24hg-peripherals-daemon.pid"
VERSION="1.0.0"

mkdir -p "$PROFILES_DIR" "$MACROS_DIR"
touch "$ASSIGNMENTS"

RED='\033[0;31m'; GRN='\033[0;32m'; YEL='\033[1;33m'
CYN='\033[0;36m'; MAG='\033[0;35m'; BLD='\033[1m'; DIM='\033[2m'; RST='\033[0m'
info() { echo -e "${GRN}[24hg-periph]${RST} $*"; }
warn() { echo -e "${YEL}[24hg-periph]${RST} $*"; }
die()  { echo -e "${RED}[24hg-periph]${RST} $*" >&2; exit 1; }

# ── Dependency checks ───────────────────────────────────────────────
has_ratbag() { command -v ratbagctl &>/dev/null; }
has_openrgb() { command -v openrgb &>/dev/null; }
has_xdotool() { command -v xdotool &>/dev/null; }
has_ydotool() { command -v ydotool &>/dev/null; }

need_ratbag() { has_ratbag || die "ratbagctl not found. Install libratbag: sudo dnf install libratbag ratbagd"; }
need_openrgb() { has_openrgb || die "openrgb not found. Install: flatpak install org.openrgb.OpenRGB"; }

macro_tool() {
    if has_ydotool; then echo ydotool
    elif has_xdotool; then echo xdotool
    else die "No macro tool found. Install ydotool (Wayland) or xdotool (X11)."
    fi
}

# ── Device detection ────────────────────────────────────────────────
list_ratbag_devices() {
    has_ratbag || return 0
    ratbagctl list 2>/dev/null || true
}

list_openrgb_devices() {
    has_openrgb || return 0
    openrgb --noautoconnect -l 2>/dev/null | grep -E "^[0-9]+:" || true
}

list_hid_devices() {
    local typ="$1"
    for dev in /sys/class/hidraw/hidraw*; do
        [[ -d "$dev" ]] || continue
        local name uevent
        name=$(cat "$dev/device/../../product" 2>/dev/null || cat "$dev/device/../product" 2>/dev/null || echo "Unknown")
        uevent=$(cat "$dev/device/uevent" 2>/dev/null || true)
        case "$typ" in
            mouse)    echo "$uevent" | grep -qi "mouse\|gaming.*mouse" && echo "$name ($dev)" || true ;;
            keyboard) echo "$uevent" | grep -qi "keyboard\|kbd" && echo "$name ($dev)" || true ;;
            headset)  echo "$uevent" | grep -qi "headset\|audio\|headphone" && echo "$name ($dev)" || true ;;
            *)        echo "$name ($dev)" ;;
        esac
    done 2>/dev/null || true
}

list_input_devices() {
    if [[ -r /proc/bus/input/devices ]]; then
        local current_name="" current_handlers=""
        while IFS= read -r line; do
            case "$line" in
                N:*) current_name="${line#*Name=\"}"; current_name="${current_name%\"}" ;;
                H:*) current_handlers="$line" ;;
                "")
                    if [[ -n "$current_name" ]]; then
                        local dtype="unknown"
                        [[ "$current_handlers" == *mouse* ]] && dtype="mouse"
                        [[ "$current_handlers" == *kbd* ]] && dtype="keyboard"
                        [[ "$current_name" == *[Hh]eadset* || "$current_name" == *[Hh]eadphone* ]] && dtype="headset"
                        echo "$dtype|$current_name"
                    fi
                    current_name="" current_handlers=""
                    ;;
            esac
        done < /proc/bus/input/devices
    fi
}

cmd_list() {
    echo -e "${BLD}=== 24HG Peripheral Manager ===${RST}\n"

    echo -e "${CYN}--- ratbagctl devices (mice) ---${RST}"
    if has_ratbag; then
        local rb_list
        rb_list=$(list_ratbag_devices)
        if [[ -n "$rb_list" ]]; then
            echo "$rb_list" | while IFS= read -r line; do
                echo -e "  ${GRN}*${RST} $line"
            done
        else
            echo -e "  ${DIM}No ratbagctl devices found${RST}"
        fi
    else
        echo -e "  ${DIM}ratbagctl not installed${RST}"
    fi

    echo -e "\n${CYN}--- OpenRGB devices (RGB) ---${RST}"
    if has_openrgb; then
        local rgb_list
        rgb_list=$(list_openrgb_devices)
        if [[ -n "$rgb_list" ]]; then
            echo "$rgb_list" | while IFS= read -r line; do
                echo -e "  ${MAG}*${RST} $line"
            done
        else
            echo -e "  ${DIM}No OpenRGB devices found${RST}"
        fi
    else
        echo -e "  ${DIM}openrgb not installed${RST}"
    fi

    echo -e "\n${CYN}--- Input devices ---${RST}"
    local found=0
    list_input_devices | sort -t'|' -k1,1 | while IFS='|' read -r dtype dname; do
        local icon="?"
        case "$dtype" in
            mouse)    icon="${GRN}M${RST}" ;;
            keyboard) icon="${CYN}K${RST}" ;;
            headset)  icon="${MAG}H${RST}" ;;
        esac
        echo -e "  [${icon}] ${dname} ${DIM}(${dtype})${RST}"
        found=1
    done
    [[ $found -eq 0 ]] && echo -e "  ${DIM}No input devices detected${RST}"
}

# ── Mouse configuration (ratbagctl) ─────────────────────────────────
pick_mouse() {
    need_ratbag
    local mice
    mice=$(ratbagctl list 2>/dev/null | head -1 | cut -d: -f1)
    [[ -n "$mice" ]] || die "No ratbagctl-compatible mouse found."
    echo "$mice"
}

cmd_mouse() {
    local sub="${1:-}"; shift || true
    case "$sub" in
        dpi)
            local mouse val
            mouse=$(pick_mouse)
            val="${1:-}"
            if [[ -z "$val" ]]; then
                info "Current DPI for ${BLD}$mouse${RST}:"
                ratbagctl "$mouse" dpi get 2>/dev/null || warn "Could not read DPI"
                echo ""
                info "Available DPI values:"
                ratbagctl "$mouse" dpi list 2>/dev/null || true
            else
                [[ "$val" =~ ^[0-9]+$ ]] || die "DPI must be a number (e.g. 800, 1600, 3200)"
                info "Setting DPI to ${BLD}$val${RST} on $mouse..."
                ratbagctl "$mouse" dpi set "$val" 2>/dev/null || die "Failed to set DPI"
                info "DPI set to $val"
            fi
            ;;
        rate)
            local mouse val
            mouse=$(pick_mouse)
            val="${1:-}"
            if [[ -z "$val" ]]; then
                info "Current polling rate for ${BLD}$mouse${RST}:"
                ratbagctl "$mouse" rate get 2>/dev/null || warn "Could not read rate"
            else
                [[ "$val" =~ ^[0-9]+$ ]] || die "Polling rate must be a number in Hz (e.g. 125, 250, 500, 1000)"
                info "Setting polling rate to ${BLD}${val}Hz${RST}..."
                ratbagctl "$mouse" rate set "$val" 2>/dev/null || die "Failed to set polling rate"
                info "Polling rate set to ${val}Hz"
            fi
            ;;
        buttons)
            local mouse
            mouse=$(pick_mouse)
            local action="${1:-}" btn="${2:-}" mapping="${3:-}"
            if [[ "$action" == "set" && -n "$btn" && -n "$mapping" ]]; then
                info "Mapping button $btn to '$mapping' on $mouse..."
                ratbagctl "$mouse" button "$btn" action set "$mapping" 2>/dev/null \
                    || die "Failed to map button $btn"
                info "Button $btn mapped."
            else
                info "Button mapping for ${BLD}$mouse${RST}:"
                local count
                count=$(ratbagctl "$mouse" button count 2>/dev/null || echo 0)
                for ((i=0; i<count; i++)); do
                    local act
                    act=$(ratbagctl "$mouse" button "$i" action get 2>/dev/null || echo "unknown")
                    echo -e "  Button $i: $act"
                done
                echo ""
                info "To remap: 24hg-peripherals mouse buttons set <button#> <action>"
                info "Actions: button(N), special(N), macro(...), key(KEY)"
            fi
            ;;
        ""|help)
            echo -e "${BLD}Mouse configuration (via ratbagctl):${RST}"
            echo "  24hg-peripherals mouse dpi [VALUE]       Get/set DPI"
            echo "  24hg-peripherals mouse rate [HZ]         Get/set polling rate"
            echo "  24hg-peripherals mouse buttons [set N A] List/remap buttons"
            ;;
        *) die "Unknown mouse subcommand '$sub'. Try: dpi, rate, buttons" ;;
    esac
}

# ── RGB control (openrgb) ──────────────────────────────────────────
parse_color() {
    local c="${1:-}"
    case "${c,,}" in
        red)     echo "FF0000" ;;
        green)   echo "00FF00" ;;
        blue)    echo "0000FF" ;;
        white)   echo "FFFFFF" ;;
        purple)  echo "8B00FF" ;;
        cyan)    echo "00FFFF" ;;
        orange)  echo "FF8C00" ;;
        pink)    echo "FF69B4" ;;
        yellow)  echo "FFFF00" ;;
        off)     echo "000000" ;;
        *)
            if [[ "$c" =~ ^[0-9A-Fa-f]{6}$ ]]; then
                echo "${c^^}"
            else
                die "Invalid color '$c'. Use a name (red/green/blue/...) or hex (FF00AA)"
            fi
            ;;
    esac
}

cmd_rgb() {
    need_openrgb
    local sub="${1:-}"; shift || true
    case "$sub" in
        color)
            local color="${1:-}"
            [[ -n "$color" ]] || die "Usage: 24hg-peripherals rgb color <COLOR> [device#]"
            local hex dev
            hex=$(parse_color "$color")
            dev="${2:-all}"
            if [[ "$dev" == "all" ]]; then
                info "Setting all RGB devices to #${hex}..."
                openrgb --noautoconnect -m static -c "$hex" 2>/dev/null \
                    || die "Failed to set color"
            else
                info "Setting device $dev to #${hex}..."
                openrgb --noautoconnect -d "$dev" -m static -c "$hex" 2>/dev/null \
                    || die "Failed to set color on device $dev"
            fi
            info "Color applied."
            ;;
        effect)
            local effect="${1:-}"
            [[ -n "$effect" ]] || die "Usage: 24hg-peripherals rgb effect <static|breathing|rainbow|wave> [color] [device#]"
            local color="${2:-FF0000}" dev="${3:-all}" hex
            hex=$(parse_color "$color")
            local mode
            case "${effect,,}" in
                static)    mode="static" ;;
                breathing) mode="breathing" ;;
                rainbow)   mode="rainbow wave" ;;
                wave)      mode="spectrum cycle" ;;
                *)         die "Unknown effect '$effect'. Use: static, breathing, rainbow, wave" ;;
            esac
            if [[ "$dev" == "all" ]]; then
                info "Applying effect '${mode}' with color #${hex} to all devices..."
                openrgb --noautoconnect -m "$mode" -c "$hex" 2>/dev/null || true
            else
                info "Applying effect '${mode}' to device $dev..."
                openrgb --noautoconnect -d "$dev" -m "$mode" -c "$hex" 2>/dev/null || true
            fi
            info "Effect applied."
            ;;
        off)
            info "Turning off all RGB lighting..."
            openrgb --noautoconnect -m static -c 000000 2>/dev/null || true
            info "RGB off."
            ;;
        ""|help)
            echo -e "${BLD}RGB lighting control (via OpenRGB):${RST}"
            echo "  24hg-peripherals rgb color <COLOR> [dev#]           Set solid color"
            echo "  24hg-peripherals rgb effect <EFFECT> [color] [dev#] Set effect"
            echo "  24hg-peripherals rgb off                            Turn off all RGB"
            echo ""
            echo "Colors: red, green, blue, white, purple, cyan, orange, pink, yellow, off, or hex (FF00AA)"
            echo "Effects: static, breathing, rainbow, wave"
            ;;
        *) die "Unknown rgb subcommand '$sub'. Try: color, effect, off" ;;
    esac
}

# ── Keyboard macros ─────────────────────────────────────────────────
macro_file() { echo "${MACROS_DIR}/${1}.macro"; }

cmd_macro() {
    local sub="${1:-}"; shift || true
    case "$sub" in
        record)
            local name="${1:-}"
            [[ -n "$name" ]] || die "Usage: 24hg-peripherals macro record <name>"
            [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Macro name must be alphanumeric/dash/underscore"
            local mf tool
            mf=$(macro_file "$name")
            tool=$(macro_tool)
            info "Recording macro '${BLD}$name${RST}' using $tool..."
            info "Press keys/mouse buttons. Press ${BLD}Ctrl+C${RST} to stop recording."
            echo "# Macro: $name" > "$mf"
            echo "# Recorded: $(date -Iseconds)" >> "$mf"
            echo "# Tool: $tool" >> "$mf"
            echo "---" >> "$mf"
            if [[ "$tool" == "xdotool" ]]; then
                trap 'info "Recording stopped."; exit 0' INT
                xdotool keydown --clearmodifiers --delay 0 2>/dev/null || true
                # Capture via xinput or xev fallback
                if command -v xinput &>/dev/null; then
                    xinput test-xi2 --root 2>/dev/null | while IFS= read -r line; do
                        echo "$line" >> "$mf"
                    done
                else
                    warn "xinput not available, using timeout-based recording."
                    info "Type your macro sequence and press Enter when done:"
                    read -r sequence
                    echo "type $sequence" >> "$mf"
                fi
            elif [[ "$tool" == "ydotool" ]]; then
                if command -v ydotool &>/dev/null; then
                    info "Type your macro sequence and press Enter when done:"
                    read -r sequence
                    echo "type $sequence" >> "$mf"
                fi
            fi
            info "Macro '${name}' saved to $mf"
            ;;
        play)
            local name="${1:-}" count="${2:-1}"
            [[ -n "$name" ]] || die "Usage: 24hg-peripherals macro play <name> [repeat_count]"
            local mf
            mf=$(macro_file "$name")
            [[ -f "$mf" ]] || die "Macro '$name' not found."
            local tool
            tool=$(macro_tool)
            info "Playing macro '${BLD}$name${RST}' ($count times)..."
            local started=0
            for ((r=0; r<count; r++)); do
                while IFS= read -r line; do
                    [[ "$line" == "#"* || "$line" == "---" ]] && continue
                    local cmd args
                    cmd="${line%% *}"
                    args="${line#* }"
                    case "$cmd" in
                        type)
                            if [[ "$tool" == "xdotool" ]]; then
                                xdotool type --delay 50 "$args" 2>/dev/null || true
                            else
                                ydotool type "$args" 2>/dev/null || true
                            fi
                            ;;
                        key)
                            if [[ "$tool" == "xdotool" ]]; then
                                xdotool key "$args" 2>/dev/null || true
                            else
                                ydotool key "$args" 2>/dev/null || true
                            fi
                            ;;
                        sleep)
                            sleep "$args" 2>/dev/null || true
                            ;;
                        click)
                            if [[ "$tool" == "xdotool" ]]; then
                                xdotool click "$args" 2>/dev/null || true
                            else
                                ydotool click "$args" 2>/dev/null || true
                            fi
                            ;;
                        *)
                            # Raw xinput/ydotool event replay
                            $tool "$line" 2>/dev/null || true
                            ;;
                    esac
                done < "$mf"
                [[ $count -gt 1 ]] && sleep 0.1
            done
            info "Macro playback complete."
            ;;
        list)
            echo -e "${BLD}Saved macros:${RST}"
            local found=0
            for mf in "$MACROS_DIR"/*.macro; do
                [[ -f "$mf" ]] || continue
                found=1
                local mname recorded tool_used
                mname=$(basename "$mf" .macro)
                recorded=$(grep "^# Recorded:" "$mf" 2>/dev/null | cut -d' ' -f3- || echo "unknown")
                tool_used=$(grep "^# Tool:" "$mf" 2>/dev/null | cut -d' ' -f3- || echo "unknown")
                local lines
                lines=$(grep -cv "^#\|^---\|^$" "$mf" 2>/dev/null || echo 0)
                echo -e "  ${GRN}*${RST} ${BLD}$mname${RST} — $lines actions, recorded $recorded ($tool_used)"
            done
            [[ $found -eq 0 ]] && echo -e "  ${DIM}No macros saved.${RST}"
            ;;
        delete)
            local name="${1:-}"
            [[ -n "$name" ]] || die "Usage: 24hg-peripherals macro delete <name>"
            local mf
            mf=$(macro_file "$name")
            [[ -f "$mf" ]] || die "Macro '$name' not found."
            rm -f "$mf"
            info "Macro '$name' deleted."
            ;;
        ""|help)
            echo -e "${BLD}Keyboard macro management:${RST}"
            echo "  24hg-peripherals macro record <name>          Record a new macro"
            echo "  24hg-peripherals macro play <name> [count]    Play a macro"
            echo "  24hg-peripherals macro list                   List saved macros"
            echo "  24hg-peripherals macro delete <name>          Delete a macro"
            ;;
        *) die "Unknown macro subcommand '$sub'. Try: record, play, list, delete" ;;
    esac
}

# ── Profiles ────────────────────────────────────────────────────────
profile_path() { echo "${PROFILES_DIR}/${1}.periph"; }

cmd_profile() {
    local sub="${1:-}"; shift || true
    case "$sub" in
        save)
            local name="${1:-}"
            [[ -n "$name" ]] || die "Usage: 24hg-peripherals profile save <name>"
            [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Profile name must be alphanumeric/dash/underscore"
            local pf
            pf=$(profile_path "$name")
            info "Saving peripheral profile '${BLD}$name${RST}'..."
            {
                echo "# Peripheral profile: $name"
                echo "# Created: $(date -Iseconds)"
                echo ""
                # Mouse settings
                if has_ratbag; then
                    local mouse
                    mouse=$(ratbagctl list 2>/dev/null | head -1 | cut -d: -f1 || true)
                    if [[ -n "$mouse" ]]; then
                        echo "mouse_device=$mouse"
                        echo "mouse_dpi=$(ratbagctl "$mouse" dpi get 2>/dev/null || echo '')"
                        echo "mouse_rate=$(ratbagctl "$mouse" rate get 2>/dev/null || echo '')"
                    fi
                fi
                # RGB settings — store last-used color if we cached it
                if [[ -f "${CONFIG_DIR}/.last_rgb" ]]; then
                    cat "${CONFIG_DIR}/.last_rgb"
                else
                    echo "rgb_mode=static"
                    echo "rgb_color=FFFFFF"
                fi
                # Associated macros
                echo "macros=$(ls "$MACROS_DIR"/*.macro 2>/dev/null | xargs -I{} basename {} .macro | tr '\n' ',' || echo '')"
            } > "$pf"
            info "Profile '${name}' saved to $pf"
            ;;
        load)
            local name="${1:-}"
            [[ -n "$name" ]] || die "Usage: 24hg-peripherals profile load <name>"
            local pf
            pf=$(profile_path "$name")
            [[ -f "$pf" ]] || die "Profile '$name' not found."
            info "Loading peripheral profile '${BLD}$name${RST}'..."
            local val
            # Apply mouse DPI
            val=$(grep "^mouse_dpi=" "$pf" 2>/dev/null | cut -d= -f2-)
            if [[ -n "$val" ]] && has_ratbag; then
                local mouse
                mouse=$(grep "^mouse_device=" "$pf" | cut -d= -f2-)
                [[ -n "$mouse" ]] || mouse=$(pick_mouse 2>/dev/null || true)
                if [[ -n "$mouse" ]]; then
                    ratbagctl "$mouse" dpi set "$val" 2>/dev/null && info "DPI set to $val" || warn "Could not set DPI"
                fi
            fi
            # Apply mouse rate
            val=$(grep "^mouse_rate=" "$pf" 2>/dev/null | cut -d= -f2-)
            if [[ -n "$val" ]] && has_ratbag; then
                local mouse
                mouse=$(grep "^mouse_device=" "$pf" | cut -d= -f2-)
                [[ -n "$mouse" ]] || mouse=$(pick_mouse 2>/dev/null || true)
                if [[ -n "$mouse" ]]; then
                    ratbagctl "$mouse" rate set "$val" 2>/dev/null && info "Polling rate set to ${val}Hz" || warn "Could not set rate"
                fi
            fi
            # Apply RGB
            local rgb_mode rgb_color
            rgb_mode=$(grep "^rgb_mode=" "$pf" 2>/dev/null | cut -d= -f2- || echo "")
            rgb_color=$(grep "^rgb_color=" "$pf" 2>/dev/null | cut -d= -f2- || echo "")
            if [[ -n "$rgb_mode" && -n "$rgb_color" ]] && has_openrgb; then
                openrgb --noautoconnect -m "$rgb_mode" -c "$rgb_color" 2>/dev/null \
                    && info "RGB set to $rgb_mode #$rgb_color" || warn "Could not apply RGB"
            fi
            info "Profile '${name}' loaded."
            ;;
        list)
            echo -e "${BLD}Peripheral profiles:${RST}"
            local found=0
            for pf in "$PROFILES_DIR"/*.periph; do
                [[ -f "$pf" ]] || continue
                found=1
                local pname created dpi rgb_c
                pname=$(basename "$pf" .periph)
                created=$(grep "^# Created:" "$pf" 2>/dev/null | cut -d' ' -f3- || echo "unknown")
                dpi=$(grep "^mouse_dpi=" "$pf" 2>/dev/null | cut -d= -f2- || echo "n/a")
                rgb_c=$(grep "^rgb_color=" "$pf" 2>/dev/null | cut -d= -f2- || echo "n/a")
                # Check if assigned to any game
                local games
                games=$(grep "=${pname}$" "$ASSIGNMENTS" 2>/dev/null | cut -d= -f1 | tr '\n' ', ' || true)
                games="${games%,}"
                local extra=""
                [[ -n "$games" ]] && extra=" ${DIM}[games: $games]${RST}"
                echo -e "  ${GRN}*${RST} ${BLD}$pname${RST} — DPI:$dpi RGB:#$rgb_c ${DIM}($created)${RST}$extra"
            done
            [[ $found -eq 0 ]] && echo -e "  ${DIM}No profiles saved.${RST}"
            ;;
        assign)
            local game="${1:-}" pname="${2:-}"
            [[ -n "$game" && -n "$pname" ]] || die "Usage: 24hg-peripherals profile assign <game> <profile>"
            local pf
            pf=$(profile_path "$pname")
            [[ -f "$pf" ]] || die "Profile '$pname' not found."
            # Remove existing assignment for this game, then add new one
            sed -i "/^${game}=/d" "$ASSIGNMENTS" 2>/dev/null || true
            echo "${game}=${pname}" >> "$ASSIGNMENTS"
            info "Game '${BLD}$game${RST}' assigned to peripheral profile '${BLD}$pname${RST}'."
            ;;
        ""|help)
            echo -e "${BLD}Peripheral profile management:${RST}"
            echo "  24hg-peripherals profile save <name>             Save current settings"
            echo "  24hg-peripherals profile load <name>             Apply a profile"
            echo "  24hg-peripherals profile list                    List all profiles"
            echo "  24hg-peripherals profile assign <game> <profile> Auto-apply for a game"
            ;;
        *) die "Unknown profile subcommand '$sub'. Try: save, load, list, assign" ;;
    esac
}

# ── Battery ─────────────────────────────────────────────────────────
cmd_battery() {
    echo -e "${BLD}Wireless device battery levels:${RST}"
    local found=0

    # UPower (most reliable for wireless peripherals)
    if command -v upower &>/dev/null; then
        while IFS= read -r dev; do
            [[ -n "$dev" ]] || continue
            local native model pct state icon
            native=$(upower -i "$dev" 2>/dev/null || true)
            model=$(echo "$native" | grep "model:" | sed 's/.*model:\s*//')
            pct=$(echo "$native" | grep "percentage:" | sed 's/.*percentage:\s*//')
            state=$(echo "$native" | grep "state:" | sed 's/.*state:\s*//')
            [[ -n "$pct" ]] || continue
            # Color code by level
            local num="${pct%\%}"
            if [[ "$num" =~ ^[0-9]+$ ]]; then
                if (( num > 60 )); then icon="${GRN}"
                elif (( num > 20 )); then icon="${YEL}"
                else icon="${RED}"
                fi
            else
                icon="${DIM}"
            fi
            echo -e "  ${icon}*${RST} ${BLD}${model:-$dev}${RST}: ${icon}${pct}${RST} ${DIM}(${state:-unknown})${RST}"
            found=1
        done < <(upower -e 2>/dev/null | grep -iE "mouse|keyboard|headset|gaming|razer|logitech|corsair|steelseries" || true)
    fi

    # sysfs power_supply fallback
    for ps in /sys/class/power_supply/*; do
        [[ -d "$ps" ]] || continue
        local pstype
        pstype=$(cat "$ps/type" 2>/dev/null || echo "")
        [[ "$pstype" == "Battery" ]] || continue
        local scope
        scope=$(cat "$ps/scope" 2>/dev/null || echo "")
        [[ "$scope" == "Device" ]] || continue
        local cap name status
        cap=$(cat "$ps/capacity" 2>/dev/null || echo "?")
        name=$(cat "$ps/model_name" 2>/dev/null || basename "$ps")
        status=$(cat "$ps/status" 2>/dev/null || echo "unknown")
        local icon="${DIM}"
        if [[ "$cap" =~ ^[0-9]+$ ]]; then
            if (( cap > 60 )); then icon="${GRN}"
            elif (( cap > 20 )); then icon="${YEL}"
            else icon="${RED}"
            fi
        fi
        echo -e "  ${icon}*${RST} ${BLD}$name${RST}: ${icon}${cap}%${RST} ${DIM}($status)${RST}"
        found=1
    done

    [[ $found -eq 0 ]] && echo -e "  ${DIM}No wireless devices with battery info found.${RST}"
}

# ── Status overview ─────────────────────────────────────────────────
cmd_status() {
    echo -e "${BLD}=== 24HG Peripheral Status ===${RST}\n"

    # Tool availability
    echo -e "${CYN}Tools:${RST}"
    local tool_status
    for tool in ratbagctl openrgb xdotool ydotool upower; do
        if command -v "$tool" &>/dev/null; then
            tool_status="${GRN}installed${RST}"
        else
            tool_status="${DIM}not found${RST}"
        fi
        printf "  %-12s %b\n" "$tool" "$tool_status"
    done

    echo ""
    cmd_list
    echo ""
    cmd_battery

    # Active profiles
    echo -e "\n${CYN}Profile assignments:${RST}"
    if [[ -s "$ASSIGNMENTS" ]]; then
        while IFS='=' read -r game prof; do
            [[ -n "$game" && "$game" != "#"* ]] || continue
            echo -e "  ${BLD}$game${RST} -> $prof"
        done < "$ASSIGNMENTS"
    else
        echo -e "  ${DIM}No game-to-profile assignments.${RST}"
    fi

    # Daemon status
    echo -e "\n${CYN}Daemon:${RST}"
    if [[ -f "$DAEMON_PID" ]] && kill -0 "$(cat "$DAEMON_PID")" 2>/dev/null; then
        echo -e "  ${GRN}Running${RST} (PID $(cat "$DAEMON_PID"))"
    else
        echo -e "  ${DIM}Not running${RST}"
    fi
}

# ── Daemon: auto-switch profiles on game launch ────────────────────
cmd_daemon() {
    local action="${1:-start}"
    case "$action" in
        start)
            if [[ -f "$DAEMON_PID" ]] && kill -0 "$(cat "$DAEMON_PID")" 2>/dev/null; then
                die "Daemon already running (PID $(cat "$DAEMON_PID")). Use '24hg-peripherals daemon stop' first."
            fi
            info "Starting peripheral auto-switch daemon..."
            _daemon_loop &
            local pid=$!
            echo "$pid" > "$DAEMON_PID"
            disown "$pid" 2>/dev/null || true
            info "Daemon started (PID $pid). Monitoring game launches."
            info "Assigned games will auto-switch peripheral profiles."
            ;;
        stop)
            if [[ -f "$DAEMON_PID" ]]; then
                local pid
                pid=$(cat "$DAEMON_PID")
                if kill -0 "$pid" 2>/dev/null; then
                    kill "$pid" 2>/dev/null || true
                    info "Daemon stopped (PID $pid)."
                else
                    info "Daemon was not running."
                fi
                rm -f "$DAEMON_PID"
            else
                info "No daemon PID file found."
            fi
            ;;
        status)
            if [[ -f "$DAEMON_PID" ]] && kill -0 "$(cat "$DAEMON_PID")" 2>/dev/null; then
                info "Daemon running (PID $(cat "$DAEMON_PID"))."
            else
                info "Daemon not running."
            fi
            ;;
        *)
            echo "Usage: 24hg-peripherals daemon [start|stop|status]"
            ;;
    esac
}

_daemon_loop() {
    local last_game=""
    local default_profile=""
    [[ -f "$(profile_path default)" ]] && default_profile="default"

    while true; do
        local current_game=""
        # Check for Steam game via SteamAppId in running processes
        for pid_dir in /proc/[0-9]*/environ; do
            [[ -r "$pid_dir" ]] || continue
            local appid
            appid=$(tr '\0' '\n' < "$pid_dir" 2>/dev/null | grep "^SteamAppId=" | head -1 | cut -d= -f2- || true)
            if [[ -n "$appid" && "$appid" != "0" ]]; then
                current_game="steam_$appid"
                break
            fi
        done

        # Check for game name via gamemoded processes
        if [[ -z "$current_game" ]] && command -v gamemoded &>/dev/null; then
            local gm_clients
            gm_clients=$(gamemoded -s 2>/dev/null | grep -oP 'pid \K[0-9]+' || true)
            for gmpid in $gm_clients; do
                local comm
                comm=$(cat "/proc/$gmpid/comm" 2>/dev/null || true)
                if [[ -n "$comm" ]]; then
                    current_game="$comm"
                    break
                fi
            done
        fi

        # Apply profile if game changed
        if [[ "$current_game" != "$last_game" ]]; then
            if [[ -n "$current_game" ]]; then
                local assigned
                assigned=$(grep "^${current_game}=" "$ASSIGNMENTS" 2>/dev/null | head -1 | cut -d= -f2- || true)
                if [[ -n "$assigned" && -f "$(profile_path "$assigned")" ]]; then
                    cmd_profile load "$assigned" 2>/dev/null || true
                fi
            elif [[ -n "$last_game" && -n "$default_profile" ]]; then
                # Game exited, restore default
                cmd_profile load "$default_profile" 2>/dev/null || true
            fi
            last_game="$current_game"
        fi

        sleep 5
    done
}

# ── Help ────────────────────────────────────────────────────────────
cmd_help() {
    cat <<EOF
${BLD}24hg-peripherals${RST} v${VERSION} — Gaming peripheral manager for 24HG

${BLD}USAGE:${RST}
  24hg-peripherals <command> [subcommand] [args...]

${BLD}COMMANDS:${RST}
  list                          List all detected gaming devices
  mouse [dpi|rate|buttons]      Configure mouse (DPI, polling rate, buttons)
  rgb [color|effect|off]        Control RGB lighting
  macro [record|play|list|del]  Keyboard macro management
  profile [save|load|list|assign]  Manage per-game peripheral profiles
  battery                       Show wireless device battery levels
  status                        Full device status overview
  daemon [start|stop|status]    Auto-switch profiles on game launch
  help                          Show this help

${BLD}EXAMPLES:${RST}
  24hg-peripherals mouse dpi 1600          Set mouse to 1600 DPI
  24hg-peripherals mouse rate 1000         Set 1000Hz polling rate
  24hg-peripherals rgb color red           Set all RGB to red
  24hg-peripherals rgb effect breathing cyan  Breathing cyan effect
  24hg-peripherals rgb off                 Kill all RGB
  24hg-peripherals macro record burst      Record a macro named "burst"
  24hg-peripherals macro play burst 5      Play "burst" macro 5 times
  24hg-peripherals profile save fps        Save current settings as "fps"
  24hg-peripherals profile assign cs2 fps  Auto-apply "fps" for CS2
  24hg-peripherals daemon start            Start auto-switch daemon

${BLD}BACKENDS:${RST}
  Mice:     ratbagctl (libratbag)  — DPI, polling rate, button mapping
  RGB:      openrgb               — Colors, effects for all RGB devices
  Macros:   ydotool / xdotool     — Key/mouse macro recording and playback
  Battery:  upower / sysfs        — Wireless peripheral battery levels

${BLD}PROFILES:${RST}
  Stored in ~/.config/24hg/peripherals/profiles/
  Assign profiles to games, then run the daemon to auto-switch.
  Works with 24hg-perf-profiles for complete per-game optimization.

EOF
}

# ── Main dispatch ───────────────────────────────────────────────────
main() {
    local cmd="${1:-help}"; shift || true
    case "$cmd" in
        list)               cmd_list "$@" ;;
        mouse)              cmd_mouse "$@" ;;
        rgb)                cmd_rgb "$@" ;;
        macro)              cmd_macro "$@" ;;
        profile)            cmd_profile "$@" ;;
        battery)            cmd_battery "$@" ;;
        status)             cmd_status "$@" ;;
        daemon)             cmd_daemon "$@" ;;
        help|--help|-h)     cmd_help ;;
        version|--version)  echo "24hg-peripherals v${VERSION}" ;;
        *)                  die "Unknown command '$cmd'. Run '24hg-peripherals help' for usage." ;;
    esac
}

main "$@"
