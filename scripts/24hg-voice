#!/bin/bash
set -euo pipefail
# 24HG Voice — Push-to-talk voice chat for the 24HG community
# Uses LiveKit WebRTC for low-latency voice communication between members.
#
# Usage: 24hg-voice <command> [args]
#   join [room]       Join a voice room (default: 24hg-lobby)
#   leave             Leave the current voice room
#   mute              Mute your microphone
#   unmute            Unmute your microphone
#   ptt-bind [key]    Set push-to-talk key (default: F10)
#   status            Show current voice status
#   rooms             List active voice rooms
#   volume <0-100>    Set input volume / gain
#   test-mic          Test microphone with VU meter
#   help              Show this help

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Paths ───────────────────────────────────────────────────────────────────
CONFIG_DIR="${HOME}/.config/24hg"
CONFIG_FILE="${CONFIG_DIR}/voice.conf"
TOKEN_FILE="${CONFIG_DIR}/hub-token"
STATE_DIR="/tmp/24hg-voice"
PID_FILE="${STATE_DIR}/voice.pid"
PTT_PID_FILE="${STATE_DIR}/ptt.pid"
ROOM_STATE_FILE="${STATE_DIR}/room"
PARTICIPANTS_FILE="${STATE_DIR}/participants"
AUDIO_PID_FILE="${STATE_DIR}/audio.pid"
OVERLAY_STATE_FILE="/tmp/24hg-voice-status"
LOG_TAG="24hg-voice"

# ── Defaults ────────────────────────────────────────────────────────────────
LIVEKIT_SERVER="wss://voice.24hgaming.com"
HUB_API_URL="https://hub.24hgaming.com"
DEFAULT_ROOM="24hg-lobby"
PTT_KEY="F10"
PTT_MODE="hold"
INPUT_VOLUME=80
NOISE_SUPPRESS="auto"
AUTO_JOIN_GAME_ROOM="yes"
GAME_POLL_INTERVAL=15

# ── Helpers ─────────────────────────────────────────────────────────────────
log_info()  { logger -t "$LOG_TAG" "$*"; echo -e "${CYAN}[VOICE]${RESET} $*"; }
log_ok()    { logger -t "$LOG_TAG" "$*"; echo -e "${GREEN}[   OK]${RESET} $*"; }
log_warn()  { logger -t "$LOG_TAG" "WARN: $*"; echo -e "${YELLOW}[ WARN]${RESET} $*"; }
log_err()   { logger -t "$LOG_TAG" "ERROR: $*"; echo -e "${RED}[  ERR]${RESET} $*" >&2; }

die() {
    log_err "$*"
    exit 1
}

ensure_dirs() {
    mkdir -p "$CONFIG_DIR" "$STATE_DIR"
}

# ── Configuration ───────────────────────────────────────────────────────────

ensure_config() {
    ensure_dirs
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" <<'CONF'
# 24HG Voice Configuration
# LiveKit server URL
LIVEKIT_SERVER=wss://voice.24hgaming.com
# Hub API base URL
HUB_API_URL=https://hub.24hgaming.com
# Default room to join
DEFAULT_ROOM=24hg-lobby
# Push-to-talk key (evdev key name, e.g. F10, CAPSLOCK, RIGHTALT)
PTT_KEY=F10
# PTT mode: "hold" = talk while held, "toggle" = press to toggle mute
PTT_MODE=hold
# Input volume (0-100)
INPUT_VOLUME=80
# Noise suppression: auto, on, off
NOISE_SUPPRESS=auto
# Auto-join game-specific room when a game is detected
AUTO_JOIN_GAME_ROOM=yes
# How often to check for running games (seconds)
GAME_POLL_INTERVAL=15
CONF
        log_info "Created default config at ${CONFIG_FILE}"
    fi
}

load_config() {
    ensure_config
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
}

save_config() {
    ensure_config
    cat > "$CONFIG_FILE" <<CONF
# 24HG Voice Configuration
LIVEKIT_SERVER=${LIVEKIT_SERVER}
HUB_API_URL=${HUB_API_URL}
DEFAULT_ROOM=${DEFAULT_ROOM}
PTT_KEY=${PTT_KEY}
PTT_MODE=${PTT_MODE}
INPUT_VOLUME=${INPUT_VOLUME}
NOISE_SUPPRESS=${NOISE_SUPPRESS}
AUTO_JOIN_GAME_ROOM=${AUTO_JOIN_GAME_ROOM}
GAME_POLL_INTERVAL=${GAME_POLL_INTERVAL}
CONF
}

# ── Dependency Checks ───────────────────────────────────────────────────────

check_deps() {
    local missing=()

    # Primary audio transport — livekit-cli or gstreamer with livekit plugin
    if ! command -v livekit-cli &>/dev/null; then
        if ! gst-inspect-1.0 livekitwebrtcsink &>/dev/null 2>&1; then
            missing+=("livekit-cli or gst-plugins-livekit")
        fi
    fi

    # Audio plumbing
    if ! command -v pactl &>/dev/null; then
        missing+=("pulseaudio-utils (pactl)")
    fi

    # Network requests
    if ! command -v curl &>/dev/null; then
        missing+=("curl")
    fi

    # JSON parsing
    if ! command -v jq &>/dev/null; then
        missing+=("jq")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        log_err "Missing dependencies:"
        for dep in "${missing[@]}"; do
            echo -e "  ${RED}-${RESET} ${dep}"
        done
        echo ""
        echo -e "${DIM}Install with:${RESET}"
        echo -e "  ${WHITE}sudo dnf install pulseaudio-utils curl jq${RESET}"
        echo -e "  ${DIM}For LiveKit CLI: https://docs.livekit.io/home/cli/cli-setup/${RESET}"
        exit 1
    fi
}

has_livekit_cli() {
    command -v livekit-cli &>/dev/null
}

has_gst_livekit() {
    gst-inspect-1.0 livekitwebrtcsink &>/dev/null 2>&1
}

has_evtest() {
    command -v evtest &>/dev/null
}

has_xinput() {
    command -v xinput &>/dev/null
}

# ── Hub API Authentication ──────────────────────────────────────────────────

get_hub_token() {
    if [[ ! -f "$TOKEN_FILE" ]]; then
        die "Hub token not found at ${TOKEN_FILE}. Run '24hg-hub login' first."
    fi
    cat "$TOKEN_FILE"
}

hub_api() {
    local method="$1"
    local endpoint="$2"
    shift 2
    local token
    token=$(get_hub_token)

    local response
    response=$(curl -s -w "\n%{http_code}" -X "$method" \
        "${HUB_API_URL}${endpoint}" \
        -H "Authorization: Bearer ${token}" \
        -H "Content-Type: application/json" \
        "$@" 2>/dev/null) || die "Failed to reach Hub API at ${HUB_API_URL}"

    local http_code body
    http_code=$(echo "$response" | tail -1)
    body=$(echo "$response" | sed '$d')

    if [[ "$http_code" -ge 400 ]]; then
        local msg
        msg=$(echo "$body" | jq -r '.message // .error // "Unknown error"' 2>/dev/null || echo "$body")
        if [[ "$http_code" == "401" ]]; then
            die "Authentication failed. Run '24hg-hub login' to refresh your token."
        fi
        die "Hub API error (${http_code}): ${msg}"
    fi

    echo "$body"
}

# ── LiveKit Token ───────────────────────────────────────────────────────────

request_room_token() {
    local room="$1"
    local response

    response=$(hub_api POST "/api/24hg/voice/token" \
        -d "{\"room\": \"${room}\"}") || exit 1

    local lk_token
    lk_token=$(echo "$response" | jq -r '.token // empty' 2>/dev/null)

    if [[ -z "$lk_token" ]]; then
        die "Failed to get LiveKit token from Hub API. Response: ${response}"
    fi

    echo "$lk_token"
}

# ── Audio Device Management ─────────────────────────────────────────────────

get_default_source() {
    pactl get-default-source 2>/dev/null || echo "unknown"
}

get_default_source_desc() {
    local src
    src=$(get_default_source)
    pactl list sources 2>/dev/null | grep -A1 "Name: ${src}" | grep "Description:" | sed 's/.*Description: //' || echo "$src"
}

set_input_volume() {
    local vol="$1"
    if [[ "$vol" -lt 0 || "$vol" -gt 100 ]]; then
        die "Volume must be between 0 and 100"
    fi
    local src
    src=$(get_default_source)
    pactl set-source-volume "$src" "${vol}%" 2>/dev/null || {
        log_warn "Failed to set volume via pactl, trying wpctl..."
        wpctl set-volume "@DEFAULT_AUDIO_SOURCE@" "$(echo "scale=2; $vol / 100" | bc)" 2>/dev/null || \
            die "Failed to set input volume"
    }
    INPUT_VOLUME="$vol"
    save_config
    log_ok "Input volume set to ${vol}%"
}

get_input_volume() {
    pactl get-source-volume "$(get_default_source)" 2>/dev/null | \
        grep -oP '\d+%' | head -1 | tr -d '%' || echo "$INPUT_VOLUME"
}

mute_mic() {
    pactl set-source-mute "$(get_default_source)" 1 2>/dev/null || \
        wpctl set-mute "@DEFAULT_AUDIO_SOURCE@" 1 2>/dev/null || \
        log_warn "Failed to mute microphone"
}

unmute_mic() {
    pactl set-source-mute "$(get_default_source)" 0 2>/dev/null || \
        wpctl set-mute "@DEFAULT_AUDIO_SOURCE@" 0 2>/dev/null || \
        log_warn "Failed to unmute microphone"
}

is_mic_muted() {
    local muted
    muted=$(pactl get-source-mute "$(get_default_source)" 2>/dev/null | grep -o "yes\|no" || echo "unknown")
    [[ "$muted" == "yes" ]]
}

check_noise_suppression() {
    if [[ "$NOISE_SUPPRESS" == "off" ]]; then
        return
    fi

    # Check if noise-suppression-for-voice (RNNoise) LADSPA plugin is installed
    if [[ -f "/usr/lib64/ladspa/librnnoise_ladspa.so" ]] || \
       [[ -f "/usr/lib/ladspa/librnnoise_ladspa.so" ]]; then
        if [[ "$NOISE_SUPPRESS" == "auto" || "$NOISE_SUPPRESS" == "on" ]]; then
            local already
            already=$(pactl list modules short 2>/dev/null | grep -c "ladspa-sink.*rnnoise" || echo 0)
            if [[ "$already" -eq 0 ]]; then
                log_info "RNNoise detected. Noise suppression available."
            fi
        fi
    else
        if [[ "$NOISE_SUPPRESS" != "off" ]]; then
            echo -e "${DIM}  Tip: Install noise-suppression-for-voice for cleaner audio:${RESET}"
            echo -e "${DIM}    sudo dnf install noise-suppression-for-voice${RESET}"
        fi
    fi
}

# ── VU Meter ────────────────────────────────────────────────────────────────

test_mic() {
    log_info "Testing microphone: $(get_default_source_desc)"
    echo -e "${DIM}  Press Ctrl+C to stop${RESET}"
    echo ""

    local src
    src=$(get_default_source)

    # Use pactl subscribe + parec for VU meter
    if command -v parec &>/dev/null; then
        echo -e "${BLUE}  Mic Level:${RESET}"
        parec --channels=1 --rate=8000 --format=s16le -d "$src" 2>/dev/null | \
        while IFS= read -r -n 128 chunk; do
            # Calculate RMS from raw PCM bytes (rough approximation)
            local level
            level=$(echo "$chunk" | od -An -td2 -N 128 2>/dev/null | \
                    awk '{for(i=1;i<=NF;i++){s+=($i>0?$i:-$i);n++}} END{if(n>0)printf "%d",s/n/327; else print 0}' 2>/dev/null || echo "0")

            # Clamp to 0-50 for bar width
            [[ "$level" -gt 50 ]] && level=50

            local bar=""
            local color="$GREEN"
            [[ "$level" -gt 30 ]] && color="$YELLOW"
            [[ "$level" -gt 45 ]] && color="$RED"

            for ((i=0; i<level; i++)); do bar+="█"; done
            for ((i=level; i<50; i++)); do bar+="░"; done

            printf "\r  ${color}%s${RESET} %3d%%" "$bar" "$((level * 2))"
        done
    else
        log_warn "parec not available. Install pulseaudio-utils for mic testing."
        echo -e "${DIM}  Alternatively, check your audio levels in pavucontrol.${RESET}"
    fi
}

# ── Game Detection ──────────────────────────────────────────────────────────

detect_current_game() {
    local game=""

    # Check Steam games
    local steam_pid
    steam_pid=$(pgrep -f "steamapps/common" 2>/dev/null | head -1 || true)
    if [[ -n "$steam_pid" ]]; then
        local cmdline
        cmdline=$(tr '\0' ' ' < "/proc/$steam_pid/cmdline" 2>/dev/null || true)
        if [[ "$cmdline" =~ steamapps/common/([^/]+)/ ]]; then
            game="${BASH_REMATCH[1]}"
        fi
    fi

    # Check common game processes
    if [[ -z "$game" ]]; then
        local -a known_games=(
            "cs2:cs2"
            "hl2_linux:source-game"
            "dota2:dota2"
            "factorio:factorio"
            "valheim:valheim"
            "rust:rust"
            "minecraft-launcher:minecraft"
            "java.*minecraft:minecraft"
            "GarrysMod:gmod"
        )
        for entry in "${known_games[@]}"; do
            local pattern="${entry%%:*}"
            local name="${entry#*:}"
            if pgrep -f "$pattern" &>/dev/null; then
                game="$name"
                break
            fi
        done
    fi

    echo "$game"
}

game_room_name() {
    local game="$1"
    # Normalize game name to room name (lowercase, hyphens)
    echo "game-${game}" | tr '[:upper:]' '[:lower:]' | tr ' _' '--' | tr -cd 'a-z0-9-'
}

# ── Push-to-Talk ────────────────────────────────────────────────────────────

find_keyboard_device() {
    # Find the first keyboard event device
    local dev
    for dev in /dev/input/event*; do
        if [[ -r "$dev" ]] 2>/dev/null; then
            local name
            name=$(cat "/sys/class/input/$(basename "$dev")/device/name" 2>/dev/null || true)
            # Look for keyboard-like device names
            if echo "$name" | grep -iqE "keyboard|kbd"; then
                echo "$dev"
                return
            fi
        fi
    done

    # Fallback: scan capabilities
    for dev in /dev/input/event*; do
        if [[ -r "$dev" ]] 2>/dev/null; then
            # Check if device has KEY capability and common keyboard keys
            local caps
            caps=$(cat "/sys/class/input/$(basename "$dev")/device/capabilities/key" 2>/dev/null || true)
            if [[ -n "$caps" ]] && [[ "$caps" != "0" ]]; then
                # Heuristic: keyboards have many key bits set
                local bits
                bits=$(echo "$caps" | tr ' ' '\n' | grep -v '^0$' | wc -l)
                if [[ "$bits" -ge 3 ]]; then
                    echo "$dev"
                    return
                fi
            fi
        fi
    done

    echo ""
}

# Map key names to evdev key codes
key_name_to_code() {
    local name="${1^^}"  # uppercase
    case "$name" in
        F1)  echo 59 ;;
        F2)  echo 60 ;;
        F3)  echo 61 ;;
        F4)  echo 62 ;;
        F5)  echo 63 ;;
        F6)  echo 64 ;;
        F7)  echo 65 ;;
        F8)  echo 66 ;;
        F9)  echo 67 ;;
        F10) echo 68 ;;
        F11) echo 87 ;;
        F12) echo 88 ;;
        CAPSLOCK|CAPS)   echo 58 ;;
        SCROLLLOCK)      echo 70 ;;
        RIGHTALT|RALT)   echo 100 ;;
        RIGHTCTRL|RCTRL) echo 97 ;;
        PAUSE)           echo 119 ;;
        INSERT)          echo 110 ;;
        HOME)            echo 102 ;;
        PAGEUP)          echo 104 ;;
        PAGEDOWN)        echo 109 ;;
        END)             echo 107 ;;
        DELETE)          echo 111 ;;
        NUMLOCK)         echo 69 ;;
        LEFTMETA|SUPER)  echo 125 ;;
        *)
            log_warn "Unknown key name: ${name}. Using F10."
            echo 68
            ;;
    esac
}

start_ptt_monitor() {
    local key_code
    key_code=$(key_name_to_code "$PTT_KEY")

    stop_ptt_monitor

    log_info "Starting PTT monitor (key: ${PTT_KEY}, code: ${key_code}, mode: ${PTT_MODE})"

    if has_evtest; then
        start_ptt_evtest "$key_code" &
        local pid=$!
        echo "$pid" > "$PTT_PID_FILE"
        log_info "PTT monitor started (PID ${pid}, evtest)"
    elif has_xinput; then
        start_ptt_xinput &
        local pid=$!
        echo "$pid" > "$PTT_PID_FILE"
        log_info "PTT monitor started (PID ${pid}, xinput)"
    else
        log_warn "No input monitor available (need evtest or xinput)."
        echo -e "${DIM}  Install evtest: sudo dnf install evtest${RESET}"
        echo -e "${DIM}  Push-to-talk will not work without an input monitor.${RESET}"
        return 1
    fi
}

start_ptt_evtest() {
    local key_code="$1"
    local kbd_dev
    kbd_dev=$(find_keyboard_device)

    if [[ -z "$kbd_dev" ]]; then
        log_err "No keyboard device found for PTT."
        return 1
    fi

    log_info "Monitoring ${kbd_dev} for key code ${key_code}"

    # In hold mode: press=unmute, release=mute
    # In toggle mode: press toggles mute state
    evtest "$kbd_dev" 2>/dev/null | while IFS= read -r line; do
        # evtest output: "Event: time ..., type 1 (EV_KEY), code <N> (KEY_*), value <V>"
        # value: 0=release, 1=press, 2=repeat
        if [[ "$line" =~ code\ ${key_code}\ .*value\ ([012]) ]]; then
            local val="${BASH_REMATCH[1]}"

            if [[ "$PTT_MODE" == "hold" ]]; then
                if [[ "$val" == "1" ]]; then
                    unmute_mic
                    update_overlay_status "talking"
                elif [[ "$val" == "0" ]]; then
                    mute_mic
                    update_overlay_status "muted"
                fi
            elif [[ "$PTT_MODE" == "toggle" ]]; then
                if [[ "$val" == "1" ]]; then
                    if is_mic_muted; then
                        unmute_mic
                        update_overlay_status "talking"
                        notify-send -a "24HG Voice" -i "audio-input-microphone" \
                            "Mic Unmuted" "Push-to-talk active" 2>/dev/null || true
                    else
                        mute_mic
                        update_overlay_status "muted"
                        notify-send -a "24HG Voice" -i "audio-input-microphone-muted" \
                            "Mic Muted" "" 2>/dev/null || true
                    fi
                fi
            fi
        fi
    done
}

start_ptt_xinput() {
    # Fallback: use xinput test-xi2 to watch for key events
    local key_code
    key_code=$(key_name_to_code "$PTT_KEY")

    xinput test-xi2 --root 2>/dev/null | while IFS= read -r line; do
        # xinput outputs key events with detail field
        if [[ "$line" =~ detail:\ +${key_code} ]]; then
            read -r next_line
            if [[ "$next_line" =~ RawKeyPress ]]; then
                if [[ "$PTT_MODE" == "hold" ]]; then
                    unmute_mic
                    update_overlay_status "talking"
                else
                    if is_mic_muted; then
                        unmute_mic
                        update_overlay_status "talking"
                    else
                        mute_mic
                        update_overlay_status "muted"
                    fi
                fi
            elif [[ "$next_line" =~ RawKeyRelease ]]; then
                if [[ "$PTT_MODE" == "hold" ]]; then
                    mute_mic
                    update_overlay_status "muted"
                fi
            fi
        fi
    done
}

stop_ptt_monitor() {
    if [[ -f "$PTT_PID_FILE" ]]; then
        local pid
        pid=$(cat "$PTT_PID_FILE" 2>/dev/null || true)
        if [[ -n "$pid" ]]; then
            kill "$pid" 2>/dev/null || true
            # Also kill child processes (evtest/xinput)
            pkill -P "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
        fi
        rm -f "$PTT_PID_FILE"
    fi
}

# ── LiveKit Audio Session ───────────────────────────────────────────────────

start_audio_session() {
    local room="$1"
    local lk_token="$2"

    stop_audio_session

    if has_livekit_cli; then
        start_audio_livekit_cli "$room" "$lk_token"
    elif has_gst_livekit; then
        start_audio_gstreamer "$room" "$lk_token"
    else
        die "No audio backend available. Install livekit-cli or gstreamer LiveKit plugin."
    fi
}

start_audio_livekit_cli() {
    local room="$1"
    local lk_token="$2"

    log_info "Starting audio session via livekit-cli..."

    livekit-cli join-room \
        --url "$LIVEKIT_SERVER" \
        --token "$lk_token" \
        --publish-audio \
        --subscribe-audio \
        > "${STATE_DIR}/livekit.log" 2>&1 &

    local pid=$!
    echo "$pid" > "$AUDIO_PID_FILE"

    # Give it a moment to connect
    sleep 2

    if kill -0 "$pid" 2>/dev/null; then
        log_ok "Audio session started (PID ${pid})"
    else
        local err
        err=$(tail -5 "${STATE_DIR}/livekit.log" 2>/dev/null || echo "unknown error")
        die "Audio session failed to start: ${err}"
    fi
}

start_audio_gstreamer() {
    local room="$1"
    local lk_token="$2"

    log_info "Starting audio session via GStreamer LiveKit plugin..."

    local src
    src=$(get_default_source)

    # GStreamer pipeline: capture mic -> LiveKit room, LiveKit room -> speakers
    gst-launch-1.0 -e \
        pulsesrc device="$src" ! \
        audioconvert ! \
        audioresample ! \
        audio/x-raw,rate=48000,channels=1 ! \
        opusenc bitrate=64000 ! \
        livekitwebrtcsink \
            signaller::ws-url="$LIVEKIT_SERVER" \
            signaller::auth-token="$lk_token" \
        livekitwebrtcsrc \
            signaller::ws-url="$LIVEKIT_SERVER" \
            signaller::auth-token="$lk_token" ! \
        autoaudiosink \
        > "${STATE_DIR}/gstreamer.log" 2>&1 &

    local pid=$!
    echo "$pid" > "$AUDIO_PID_FILE"

    sleep 2

    if kill -0 "$pid" 2>/dev/null; then
        log_ok "Audio session started (PID ${pid}, GStreamer)"
    else
        local err
        err=$(tail -5 "${STATE_DIR}/gstreamer.log" 2>/dev/null || echo "unknown error")
        die "GStreamer pipeline failed: ${err}"
    fi
}

stop_audio_session() {
    if [[ -f "$AUDIO_PID_FILE" ]]; then
        local pid
        pid=$(cat "$AUDIO_PID_FILE" 2>/dev/null || true)
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
            pkill -P "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            log_info "Audio session stopped"
        fi
        rm -f "$AUDIO_PID_FILE"
    fi
}

is_audio_running() {
    if [[ -f "$AUDIO_PID_FILE" ]]; then
        local pid
        pid=$(cat "$AUDIO_PID_FILE" 2>/dev/null || true)
        [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
    else
        return 1
    fi
}

# ── Overlay Integration ─────────────────────────────────────────────────────

update_overlay_status() {
    local status="$1"
    local room=""
    local participants=""

    if [[ -f "$ROOM_STATE_FILE" ]]; then
        room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || true)
    fi
    if [[ -f "$PARTICIPANTS_FILE" ]]; then
        participants=$(cat "$PARTICIPANTS_FILE" 2>/dev/null || true)
    fi

    # Write status file that 24hg-overlay can read
    cat > "$OVERLAY_STATE_FILE" <<OVERLAY
VOICE_STATUS=${status}
VOICE_ROOM=${room}
VOICE_PARTICIPANTS=${participants}
VOICE_MIC_MUTED=$(is_mic_muted && echo "yes" || echo "no")
VOICE_PTT_KEY=${PTT_KEY}
VOICE_TIMESTAMP=$(date +%s)
OVERLAY
}

clear_overlay_status() {
    rm -f "$OVERLAY_STATE_FILE"
}

# ── LAN Party Integration ──────────────────────────────────────────────────

notify_lan_party() {
    local action="$1"
    local room="$2"

    # Send a UDP notification to the LAN party listener if running
    local lan_port=24240
    local user
    user=$(whoami)
    local payload
    payload=$(printf '{"type":"voice-%s","from":"%s","room":"%s","timestamp":%d}' \
        "$action" "$user" "$room" "$(date +%s)")

    # Broadcast on LAN (best-effort, don't fail if nobody's listening)
    if command -v socat &>/dev/null; then
        local my_ip
        my_ip=$(ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1)
        local broadcast
        broadcast=$(ip -o addr show 2>/dev/null | grep "$my_ip" | awk '{print $6}' | \
                    python3 -c "import ipaddress,sys; n=ipaddress.ip_network(sys.stdin.read().strip(),strict=False); print(n.broadcast_address)" 2>/dev/null || echo "255.255.255.255")

        echo "$payload" | socat - UDP-SENDTO:"${broadcast}:${lan_port},broadcast" 2>/dev/null || true
    fi
}

# ── Game Room Auto-Join ─────────────────────────────────────────────────────

start_game_watcher() {
    if [[ "$AUTO_JOIN_GAME_ROOM" != "yes" ]]; then
        return
    fi

    (
        local last_game=""
        while true; do
            sleep "$GAME_POLL_INTERVAL"

            # Only act if we're connected
            if ! is_audio_running; then
                continue
            fi

            local current_game
            current_game=$(detect_current_game)

            if [[ -n "$current_game" && "$current_game" != "$last_game" ]]; then
                local game_room
                game_room=$(game_room_name "$current_game")
                local current_room
                current_room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || true)

                if [[ "$game_room" != "$current_room" ]]; then
                    log_info "Game detected: ${current_game}. Switching to room: ${game_room}"
                    # Re-join in the game room
                    do_leave_quiet
                    do_join "$game_room"
                fi
                last_game="$current_game"
            elif [[ -z "$current_game" && -n "$last_game" ]]; then
                # Game closed — return to default room
                local current_room
                current_room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || true)
                if [[ "$current_room" != "$DEFAULT_ROOM" ]]; then
                    log_info "Game closed. Returning to ${DEFAULT_ROOM}"
                    do_leave_quiet
                    do_join "$DEFAULT_ROOM"
                fi
                last_game=""
            fi
        done
    ) &
    local watcher_pid=$!
    echo "$watcher_pid" > "${STATE_DIR}/watcher.pid"
}

stop_game_watcher() {
    if [[ -f "${STATE_DIR}/watcher.pid" ]]; then
        local pid
        pid=$(cat "${STATE_DIR}/watcher.pid" 2>/dev/null || true)
        if [[ -n "$pid" ]]; then
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
        fi
        rm -f "${STATE_DIR}/watcher.pid"
    fi
}

# ── Room Commands ───────────────────────────────────────────────────────────

do_join() {
    local room="${1:-$DEFAULT_ROOM}"

    check_deps

    # Check if already in a room
    if is_audio_running; then
        local current_room
        current_room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || true)
        if [[ "$current_room" == "$room" ]]; then
            log_warn "Already in room: ${room}"
            return
        fi
        log_info "Leaving current room: ${current_room}"
        do_leave_quiet
    fi

    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BLUE}  24HG Voice${RESET}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""

    log_info "Joining room: ${WHITE}${room}${RESET}"

    # Get LiveKit token from Hub API
    log_info "Authenticating with Hub..."
    local lk_token
    lk_token=$(request_room_token "$room") || exit 1
    log_ok "Token received"

    # Set initial volume
    set_input_volume "$INPUT_VOLUME" 2>/dev/null || true

    # Start muted (PTT will unmute)
    mute_mic

    # Start audio session
    start_audio_session "$room" "$lk_token"

    # Save room state
    echo "$room" > "$ROOM_STATE_FILE"
    echo "$$" > "$PID_FILE"

    # Start PTT monitor
    start_ptt_monitor || true

    # Start game watcher for auto room switching
    start_game_watcher

    # Update overlay
    update_overlay_status "connected"

    # Notify LAN party
    notify_lan_party "join" "$room"

    # Check for noise suppression
    check_noise_suppression

    echo ""
    echo -e "${GREEN}  Connected to room:${RESET} ${WHITE}${room}${RESET}"
    echo -e "${CYAN}  Push-to-talk key:${RESET}  ${WHITE}${PTT_KEY}${RESET} (${PTT_MODE} mode)"
    echo -e "${CYAN}  Input volume:${RESET}      ${WHITE}${INPUT_VOLUME}%${RESET}"
    echo -e "${CYAN}  Mic status:${RESET}        ${YELLOW}Muted${RESET} (press ${WHITE}${PTT_KEY}${RESET} to talk)"
    echo ""
    echo -e "${DIM}  Use '24hg-voice leave' to disconnect${RESET}"
    echo -e "${DIM}  Use '24hg-voice status' to see room info${RESET}"
    echo ""
}

do_leave_quiet() {
    # Leave without printing banners (used for room switches)
    stop_ptt_monitor
    stop_audio_session
    stop_game_watcher

    local room
    room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || true)

    rm -f "$ROOM_STATE_FILE" "$PARTICIPANTS_FILE" "$PID_FILE"
    clear_overlay_status

    if [[ -n "$room" ]]; then
        notify_lan_party "leave" "$room"
    fi
}

do_leave() {
    if ! is_audio_running; then
        log_warn "Not currently in a voice room."
        return
    fi

    local room
    room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || echo "unknown")

    do_leave_quiet

    unmute_mic 2>/dev/null || true

    echo ""
    log_ok "Left room: ${WHITE}${room}${RESET}"
    echo ""
}

do_mute() {
    if ! is_audio_running; then
        die "Not in a voice room. Join one first with '24hg-voice join'"
    fi

    mute_mic
    update_overlay_status "muted"
    log_ok "Microphone muted"
    notify-send -a "24HG Voice" -i "audio-input-microphone-muted" "Mic Muted" "" 2>/dev/null || true
}

do_unmute() {
    if ! is_audio_running; then
        die "Not in a voice room. Join one first with '24hg-voice join'"
    fi

    unmute_mic
    update_overlay_status "talking"
    log_ok "Microphone unmuted"
    notify-send -a "24HG Voice" -i "audio-input-microphone" "Mic Unmuted" "" 2>/dev/null || true
}

do_ptt_bind() {
    local new_key="${1:-}"

    if [[ -z "$new_key" ]]; then
        echo -e "${BLUE}  Current PTT key:${RESET} ${WHITE}${PTT_KEY}${RESET} (${PTT_MODE} mode)"
        echo ""
        echo -e "${CYAN}  Available keys:${RESET}"
        echo -e "    F1-F12, CAPSLOCK, SCROLLLOCK, RIGHTALT, RIGHTCTRL,"
        echo -e "    PAUSE, INSERT, HOME, END, PAGEUP, PAGEDOWN,"
        echo -e "    DELETE, NUMLOCK, LEFTMETA"
        echo ""
        echo -e "${CYAN}  Modes:${RESET}"
        echo -e "    hold   — talk while key is held down"
        echo -e "    toggle — press to toggle mute on/off"
        echo ""
        echo -e "${DIM}  Usage: 24hg-voice ptt-bind <key> [hold|toggle]${RESET}"
        return
    fi

    local mode="${2:-$PTT_MODE}"
    if [[ "$mode" != "hold" && "$mode" != "toggle" ]]; then
        die "Invalid PTT mode: ${mode}. Use 'hold' or 'toggle'."
    fi

    # Validate key
    local key_upper="${new_key^^}"
    local code
    code=$(key_name_to_code "$key_upper")

    PTT_KEY="$key_upper"
    PTT_MODE="$mode"
    save_config

    log_ok "PTT key set to ${WHITE}${PTT_KEY}${RESET} (${PTT_MODE} mode)"

    # Restart PTT monitor if currently in a room
    if is_audio_running; then
        log_info "Restarting PTT monitor with new key..."
        start_ptt_monitor || true
    fi
}

# ── Status & Room List ──────────────────────────────────────────────────────

do_status() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BLUE}  24HG Voice — Status${RESET}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""

    # Connection status
    if is_audio_running; then
        local room
        room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || echo "unknown")
        echo -e "  ${GREEN}●${RESET} ${WHITE}Connected${RESET}"
        echo -e "    Room:           ${WHITE}${room}${RESET}"
    else
        echo -e "  ${RED}●${RESET} ${DIM}Disconnected${RESET}"
        echo ""
        echo -e "  ${DIM}Join a room: 24hg-voice join [room]${RESET}"
        echo ""
        # Still show configuration
        echo -e "  ${CYAN}Configuration:${RESET}"
        echo -e "    Server:         ${DIM}${LIVEKIT_SERVER}${RESET}"
        echo -e "    Default room:   ${DIM}${DEFAULT_ROOM}${RESET}"
        echo -e "    PTT key:        ${DIM}${PTT_KEY} (${PTT_MODE})${RESET}"
        echo -e "    Auto game room: ${DIM}${AUTO_JOIN_GAME_ROOM}${RESET}"
        echo ""
        return
    fi

    # Mic status
    if is_mic_muted; then
        echo -e "    Mic:            ${YELLOW}Muted${RESET}"
    else
        echo -e "    Mic:            ${GREEN}Unmuted${RESET} (talking)"
    fi

    # Volume
    local vol
    vol=$(get_input_volume)
    echo -e "    Volume:         ${WHITE}${vol}%${RESET}"

    # PTT
    echo -e "    PTT key:        ${WHITE}${PTT_KEY}${RESET} (${PTT_MODE} mode)"
    if [[ -f "$PTT_PID_FILE" ]]; then
        local ptt_pid
        ptt_pid=$(cat "$PTT_PID_FILE" 2>/dev/null || true)
        if kill -0 "$ptt_pid" 2>/dev/null; then
            echo -e "    PTT monitor:    ${GREEN}Active${RESET}"
        else
            echo -e "    PTT monitor:    ${RED}Dead${RESET} (restart with '24hg-voice join')"
        fi
    else
        echo -e "    PTT monitor:    ${DIM}Not running${RESET}"
    fi

    # Audio device
    echo -e "    Input device:   ${DIM}$(get_default_source_desc)${RESET}"

    # Server
    echo -e "    Server:         ${DIM}${LIVEKIT_SERVER}${RESET}"

    # Latency estimate from livekit log
    if [[ -f "${STATE_DIR}/livekit.log" ]]; then
        local rtt
        rtt=$(grep -oP 'rtt[=:]\s*\K[\d.]+ms' "${STATE_DIR}/livekit.log" 2>/dev/null | tail -1 || true)
        if [[ -n "$rtt" ]]; then
            echo -e "    Latency:        ${DIM}${rtt}${RESET}"
        fi
    fi

    # Participants
    echo ""
    echo -e "  ${CYAN}Participants:${RESET}"
    if [[ -f "$PARTICIPANTS_FILE" ]] && [[ -s "$PARTICIPANTS_FILE" ]]; then
        while IFS= read -r participant; do
            echo -e "    ${WHITE}●${RESET} ${participant}"
        done < "$PARTICIPANTS_FILE"
    else
        echo -e "    ${DIM}Participant list requires Hub API polling${RESET}"
    fi

    # Game detection
    local game
    game=$(detect_current_game)
    if [[ -n "$game" ]]; then
        echo ""
        echo -e "  ${CYAN}Game detected:${RESET} ${GREEN}${game}${RESET}"
        if [[ "$AUTO_JOIN_GAME_ROOM" == "yes" ]]; then
            echo -e "    ${DIM}Auto game-room switching is enabled${RESET}"
        fi
    fi

    echo ""
}

do_rooms() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BLUE}  24HG Voice — Active Rooms${RESET}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""

    check_deps

    log_info "Fetching room list from Hub API..."

    local response
    response=$(hub_api GET "/api/24hg/voice/rooms") || exit 1

    local room_count
    room_count=$(echo "$response" | jq -r '.rooms | length' 2>/dev/null || echo "0")

    if [[ "$room_count" -eq 0 ]]; then
        echo -e "  ${DIM}No active voice rooms.${RESET}"
        echo -e "  ${DIM}Create one: 24hg-voice join <room-name>${RESET}"
        echo ""
        return
    fi

    # Print table
    printf "  ${BOLD}${WHITE}%-25s %-12s %-8s${RESET}\n" "ROOM" "PARTICIPANTS" "STATUS"
    printf "  ${DIM}%-25s %-12s %-8s${RESET}\n" \
        "─────────────────────────" "────────────" "────────"

    local current_room=""
    if [[ -f "$ROOM_STATE_FILE" ]]; then
        current_room=$(cat "$ROOM_STATE_FILE" 2>/dev/null || true)
    fi

    echo "$response" | jq -r '.rooms[] | "\(.name)\t\(.num_participants)\t\(.status // "active")"' 2>/dev/null | \
    while IFS=$'\t' read -r name participants status; do
        local marker="  "
        local name_color="${WHITE}"

        if [[ "$name" == "$current_room" ]]; then
            marker="${GREEN}> ${RESET}"
            name_color="${GREEN}"
        fi

        local part_color="$DIM"
        if [[ "$participants" -gt 0 ]]; then
            part_color="$CYAN"
        fi

        printf "${marker}${name_color}%-25s${RESET} ${part_color}%-12s${RESET} ${DIM}%-8s${RESET}\n" \
            "$name" "${participants} users" "$status"
    done

    echo ""
    echo -e "  ${DIM}Join with: 24hg-voice join <room-name>${RESET}"
    echo ""
}

do_volume() {
    local vol="${1:-}"

    if [[ -z "$vol" ]]; then
        local current
        current=$(get_input_volume)
        echo -e "${CYAN}  Current input volume:${RESET} ${WHITE}${current}%${RESET}"
        echo -e "${DIM}  Usage: 24hg-voice volume <0-100>${RESET}"
        return
    fi

    # Validate
    if ! [[ "$vol" =~ ^[0-9]+$ ]]; then
        die "Volume must be a number between 0 and 100"
    fi

    if [[ "$vol" -lt 0 || "$vol" -gt 100 ]]; then
        die "Volume must be between 0 and 100"
    fi

    set_input_volume "$vol"
}

# ── Cleanup ─────────────────────────────────────────────────────────────────

cleanup() {
    stop_ptt_monitor
    stop_audio_session
    stop_game_watcher
    clear_overlay_status
    rm -f "$PID_FILE"
}

trap cleanup EXIT INT TERM

# ── Help ────────────────────────────────────────────────────────────────────

show_help() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BLUE}  24HG Voice${RESET} — Push-to-talk community voice chat"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""
    echo -e "  ${WHITE}USAGE${RESET}"
    echo -e "    24hg-voice <command> [arguments]"
    echo ""
    echo -e "  ${WHITE}COMMANDS${RESET}"
    echo -e "    ${GREEN}join${RESET} [room]          Join a voice room (default: ${DEFAULT_ROOM})"
    echo -e "    ${GREEN}leave${RESET}                Leave the current voice room"
    echo -e "    ${GREEN}mute${RESET}                 Mute your microphone"
    echo -e "    ${GREEN}unmute${RESET}               Unmute your microphone"
    echo -e "    ${GREEN}ptt-bind${RESET} [key] [mode]  Set push-to-talk key and mode"
    echo -e "    ${GREEN}status${RESET}               Show current voice status"
    echo -e "    ${GREEN}rooms${RESET}                List active voice rooms"
    echo -e "    ${GREEN}volume${RESET} <0-100>       Set input volume / mic gain"
    echo -e "    ${GREEN}test-mic${RESET}             Test microphone with VU meter"
    echo -e "    ${GREEN}help${RESET}                 Show this help message"
    echo ""
    echo -e "  ${WHITE}PUSH-TO-TALK${RESET}"
    echo -e "    Default key: ${WHITE}F10${RESET}"
    echo -e "    Modes:"
    echo -e "      ${CYAN}hold${RESET}   — Talk while the key is held (default)"
    echo -e "      ${CYAN}toggle${RESET} — Press once to unmute, press again to mute"
    echo ""
    echo -e "  ${WHITE}GAME AUTO-ROOMS${RESET}"
    echo -e "    When a game is detected (via Steam/Lutris/Heroic), 24HG Voice"
    echo -e "    automatically joins a game-specific room (e.g. ${CYAN}game-cs2${RESET})."
    echo -e "    When the game exits, you return to ${CYAN}${DEFAULT_ROOM}${RESET}."
    echo -e "    Disable with: ${DIM}AUTO_JOIN_GAME_ROOM=no${RESET} in ${DIM}~/.config/24hg/voice.conf${RESET}"
    echo ""
    echo -e "  ${WHITE}CONFIGURATION${RESET}"
    echo -e "    Config file:  ${DIM}~/.config/24hg/voice.conf${RESET}"
    echo -e "    Hub token:    ${DIM}~/.config/24hg/hub-token${RESET}"
    echo ""
    echo -e "  ${WHITE}DEPENDENCIES${RESET}"
    echo -e "    Required:  livekit-cli ${DIM}or${RESET} gst-plugins-livekit, pactl, curl, jq"
    echo -e "    Optional:  evtest ${DIM}(PTT)${RESET}, noise-suppression-for-voice ${DIM}(RNNoise)${RESET}"
    echo ""
    echo -e "  ${WHITE}EXAMPLES${RESET}"
    echo -e "    ${DIM}24hg-voice join${RESET}                  # Join the lobby"
    echo -e "    ${DIM}24hg-voice join game-cs2${RESET}         # Join a CS2 voice room"
    echo -e "    ${DIM}24hg-voice ptt-bind CAPSLOCK hold${RESET}  # Use CapsLock for PTT"
    echo -e "    ${DIM}24hg-voice volume 75${RESET}             # Set mic to 75%"
    echo -e "    ${DIM}24hg-voice test-mic${RESET}              # Test mic with VU meter"
    echo ""
    echo -e "  ${DIM}Part of 24HG — https://24hgaming.com${RESET}"
    echo ""
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    ensure_dirs
    load_config

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        join)
            do_join "${1:-$DEFAULT_ROOM}"
            ;;
        leave|disconnect|quit)
            do_leave
            ;;
        mute)
            do_mute
            ;;
        unmute)
            do_unmute
            ;;
        ptt-bind|ptt|bind)
            do_ptt_bind "${1:-}" "${2:-}"
            ;;
        status|info)
            do_status
            ;;
        rooms|list)
            do_rooms
            ;;
        volume|vol)
            do_volume "${1:-}"
            ;;
        test-mic|mic-test|test)
            test_mic
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_err "Unknown command: ${cmd}"
            echo ""
            echo -e "  ${DIM}Run '24hg-voice help' for usage information.${RESET}"
            exit 1
            ;;
    esac
}

main "$@"
