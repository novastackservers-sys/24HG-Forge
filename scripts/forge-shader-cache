#!/bin/bash
# 24HG Forge Shader Cache Manager
# Manages shader caches to eliminate first-launch stuttering.
# Supports Steam (Flatpak and native), DXVK, Mesa, NVIDIA, and AMD caches.
#
# Usage: forge-shader-cache [status|clean|size|prebuild|export|import|optimize]

set -euo pipefail

# Steam paths (Flatpak and native)
STEAM_FLATPAK="$HOME/.var/app/com.valvesoftware.Steam/.local/share/Steam"
STEAM_NATIVE="$HOME/.local/share/Steam"

# Cache locations
MESA_CACHE="${MESA_SHADER_CACHE_DIR:-$HOME/.cache/mesa_shader_cache}"
NVIDIA_CACHE="$HOME/.cache/nvidia/GLCache"
AMD_CACHE="$HOME/.cache/AMD/GLCache"

ACTION="${1:-help}"

# ─── Helpers ────────────────────────────────────────────────────────────────

get_steam_dir() {
    if [ -d "$STEAM_FLATPAK" ]; then
        echo "$STEAM_FLATPAK"
    elif [ -d "$STEAM_NATIVE" ]; then
        echo "$STEAM_NATIVE"
    else
        echo ""
    fi
}

get_all_steam_dirs() {
    local dirs=()
    [ -d "$STEAM_FLATPAK" ] && dirs+=("$STEAM_FLATPAK")
    [ -d "$STEAM_NATIVE" ] && dirs+=("$STEAM_NATIVE")
    echo "${dirs[@]}"
}

# Discover all Steam library paths from libraryfolders.vdf
get_library_paths() {
    local steam_dirs
    steam_dirs=$(get_all_steam_dirs)
    local libs=()

    for steam_dir in $steam_dirs; do
        local vdf="$steam_dir/steamapps/libraryfolders.vdf"
        if [ -f "$vdf" ]; then
            # Parse "path" entries from libraryfolders.vdf
            while IFS= read -r line; do
                local path
                path=$(echo "$line" | sed -n 's/.*"path"[[:space:]]*"\([^"]*\)".*/\1/p')
                if [ -n "$path" ] && [ -d "$path/steamapps" ]; then
                    libs+=("$path")
                fi
            done < "$vdf"
        fi
        # Always include the Steam dir itself
        if [ -d "$steam_dir/steamapps" ]; then
            libs+=("$steam_dir")
        fi
    done

    # Deduplicate
    printf '%s\n' "${libs[@]}" | sort -u
}

# Map an AppID to a game name using appmanifest files
get_game_name() {
    local appid="$1"
    local libs
    libs=$(get_library_paths)

    while IFS= read -r lib; do
        local manifest="$lib/steamapps/appmanifest_${appid}.acf"
        if [ -f "$manifest" ]; then
            local name
            name=$(sed -n 's/.*"name"[[:space:]]*"\([^"]*\)".*/\1/p' "$manifest" | head -1)
            if [ -n "$name" ]; then
                echo "$name"
                return
            fi
        fi
    done <<< "$libs"

    echo "Unknown (AppID $appid)"
}

# Get the Steam shader cache dir for an appid
get_steam_shader_cache() {
    local appid="$1"
    local steam_dir
    steam_dir=$(get_steam_dir)
    [ -z "$steam_dir" ] && return
    echo "$steam_dir/steamapps/shadercache/$appid"
}

# Get the compatdata (Wine prefix) dir for an appid
get_compat_dir() {
    local appid="$1"
    local libs
    libs=$(get_library_paths)

    while IFS= read -r lib; do
        local pfx="$lib/steamapps/compatdata/$appid"
        if [ -d "$pfx" ]; then
            echo "$pfx"
            return
        fi
    done <<< "$libs"
}

# Find DXVK state cache files for an appid
find_dxvk_caches() {
    local appid="$1"
    local compat_dir
    compat_dir=$(get_compat_dir "$appid")
    [ -z "$compat_dir" ] && return

    find "$compat_dir" -name "*.dxvk-cache" -type f 2>/dev/null
}

# Human-readable size
human_size() {
    local bytes="$1"
    if [ "$bytes" -ge 1073741824 ]; then
        echo "$(awk "BEGIN {printf \"%.2f\", $bytes/1073741824}")G"
    elif [ "$bytes" -ge 1048576 ]; then
        echo "$(awk "BEGIN {printf \"%.1f\", $bytes/1048576}")M"
    elif [ "$bytes" -ge 1024 ]; then
        echo "$(awk "BEGIN {printf \"%.0f\", $bytes/1024}")K"
    else
        echo "${bytes}B"
    fi
}

# Get directory size in bytes (0 if missing)
dir_size_bytes() {
    local path="$1"
    if [ -d "$path" ]; then
        du -sb "$path" 2>/dev/null | awk '{print $1}'
    else
        echo 0
    fi
}

# ─── Commands ───────────────────────────────────────────────────────────────

cmd_status() {
    echo "=== 24HG Forge Shader Cache Status ==="
    echo ""

    local steam_dir
    steam_dir=$(get_steam_dir)
    if [ -z "$steam_dir" ]; then
        echo "Steam installation not found."
        return 1
    fi

    local shader_root="$steam_dir/steamapps/shadercache"

    # Total size
    echo "Cache Locations:"
    printf "  %-40s %s\n" "Steam shader cache" "$(if [ -d "$shader_root" ]; then du -sh "$shader_root" 2>/dev/null | awk '{print $1}'; else echo "N/A"; fi)"
    printf "  %-40s %s\n" "Mesa shader cache ($MESA_CACHE)" "$(if [ -d "$MESA_CACHE" ]; then du -sh "$MESA_CACHE" 2>/dev/null | awk '{print $1}'; else echo "N/A"; fi)"
    printf "  %-40s %s\n" "NVIDIA GL cache" "$(if [ -d "$NVIDIA_CACHE" ]; then du -sh "$NVIDIA_CACHE" 2>/dev/null | awk '{print $1}'; else echo "N/A"; fi)"
    printf "  %-40s %s\n" "AMD shader cache" "$(if [ -d "$AMD_CACHE" ]; then du -sh "$AMD_CACHE" 2>/dev/null | awk '{print $1}'; else echo "N/A"; fi)"
    echo ""

    # Per-game breakdown (top 10 by size)
    if [ -d "$shader_root" ]; then
        echo "Top 10 Games by Shader Cache Size:"
        echo "──────────────────────────────────────────────────────────────"

        local tmpfile
        tmpfile=$(mktemp)

        for dir in "$shader_root"/*/; do
            [ -d "$dir" ] || continue
            local appid
            appid=$(basename "$dir")
            # Skip non-numeric dirs
            [[ "$appid" =~ ^[0-9]+$ ]] || continue
            local sz
            sz=$(du -sb "$dir" 2>/dev/null | awk '{print $1}')
            [ -z "$sz" ] && sz=0
            echo "$sz $appid" >> "$tmpfile"
        done

        sort -rn "$tmpfile" | head -10 | while read -r sz appid; do
            local name
            name=$(get_game_name "$appid")
            printf "  %-45s %8s  (AppID %s)\n" "$name" "$(human_size "$sz")" "$appid"
        done

        rm -f "$tmpfile"
        echo ""
    fi

    # DXVK state cache files
    echo "DXVK State Cache Files:"
    echo "──────────────────────────────────────────────────────────────"
    local dxvk_count=0
    local libs
    libs=$(get_library_paths)

    while IFS= read -r lib; do
        local compat_root="$lib/steamapps/compatdata"
        [ -d "$compat_root" ] || continue
        while IFS= read -r cache_file; do
            [ -z "$cache_file" ] && continue
            local fsize
            fsize=$(du -sh "$cache_file" 2>/dev/null | awk '{print $1}')
            # Try to extract appid from path
            local fappid
            fappid=$(echo "$cache_file" | sed -n 's|.*/compatdata/\([0-9]*\)/.*|\1|p')
            local fname=""
            [ -n "$fappid" ] && fname=$(get_game_name "$fappid")
            if [ -n "$fname" ]; then
                printf "  %-40s %6s  %s\n" "$fname" "$fsize" "$(basename "$cache_file")"
            else
                printf "  %s (%s)\n" "$cache_file" "$fsize"
            fi
            dxvk_count=$((dxvk_count + 1))
        done < <(find "$compat_root" -name "*.dxvk-cache" -type f 2>/dev/null)
    done <<< "$libs"

    if [ "$dxvk_count" -eq 0 ]; then
        echo "  No DXVK state cache files found."
    fi
    echo ""
    echo "Found $dxvk_count DXVK state cache file(s) total."
}

cmd_size() {
    echo "=== 24HG Forge Shader Cache Disk Usage ==="
    echo ""

    local total=0

    local steam_dir
    steam_dir=$(get_steam_dir)
    local shader_root=""
    [ -n "$steam_dir" ] && shader_root="$steam_dir/steamapps/shadercache"

    local locations=(
        "Steam shader cache:${shader_root}"
        "Mesa shader cache:${MESA_CACHE}"
        "NVIDIA GL cache:${NVIDIA_CACHE}"
        "AMD shader cache:${AMD_CACHE}"
    )

    printf "  %-40s %10s\n" "Location" "Size"
    echo "  ──────────────────────────────────────────────────────"

    for entry in "${locations[@]}"; do
        local label="${entry%%:*}"
        local path="${entry#*:}"
        local sz=0
        if [ -n "$path" ] && [ -d "$path" ]; then
            sz=$(dir_size_bytes "$path")
        fi
        total=$((total + sz))
        printf "  %-40s %10s\n" "$label" "$(human_size "$sz")"
    done

    echo "  ──────────────────────────────────────────────────────"
    printf "  %-40s %10s\n" "TOTAL" "$(human_size "$total")"
    echo ""
}

cmd_clean() {
    local target="${2:-}"
    if [ -z "$target" ]; then
        echo "Usage: forge-shader-cache clean <appid|all>"
        return 1
    fi

    local steam_dir
    steam_dir=$(get_steam_dir)

    local paths_to_clean=()
    local total_bytes=0

    if [ "$target" = "all" ]; then
        echo "=== Clean ALL Shader Caches ==="
        echo ""

        # Steam shader cache
        if [ -n "$steam_dir" ] && [ -d "$steam_dir/steamapps/shadercache" ]; then
            paths_to_clean+=("$steam_dir/steamapps/shadercache")
        fi

        # Mesa
        [ -d "$MESA_CACHE" ] && paths_to_clean+=("$MESA_CACHE")

        # NVIDIA
        [ -d "$NVIDIA_CACHE" ] && paths_to_clean+=("$NVIDIA_CACHE")

        # AMD
        [ -d "$AMD_CACHE" ] && paths_to_clean+=("$AMD_CACHE")

        # All DXVK state caches
        local libs
        libs=$(get_library_paths)
        while IFS= read -r lib; do
            local compat_root="$lib/steamapps/compatdata"
            [ -d "$compat_root" ] || continue
            while IFS= read -r cache_file; do
                [ -z "$cache_file" ] && continue
                paths_to_clean+=("$cache_file")
            done < <(find "$compat_root" -name "*.dxvk-cache" -type f 2>/dev/null)
        done <<< "$libs"
    else
        # Specific appid
        if ! [[ "$target" =~ ^[0-9]+$ ]]; then
            echo "Error: AppID must be numeric."
            return 1
        fi

        local name
        name=$(get_game_name "$target")
        echo "=== Clean Shader Cache for $name (AppID $target) ==="
        echo ""

        # Steam shader cache for this app
        local sc
        sc=$(get_steam_shader_cache "$target")
        [ -n "$sc" ] && [ -d "$sc" ] && paths_to_clean+=("$sc")

        # DXVK state caches
        while IFS= read -r cache_file; do
            [ -z "$cache_file" ] && continue
            paths_to_clean+=("$cache_file")
        done < <(find_dxvk_caches "$target")
    fi

    if [ ${#paths_to_clean[@]} -eq 0 ]; then
        echo "No shader cache data found to clean."
        return 0
    fi

    echo "Files/directories to be removed:"
    for p in "${paths_to_clean[@]}"; do
        local sz
        if [ -d "$p" ]; then
            sz=$(du -sh "$p" 2>/dev/null | awk '{print $1}')
        elif [ -f "$p" ]; then
            sz=$(du -sh "$p" 2>/dev/null | awk '{print $1}')
        else
            sz="0"
        fi
        local bytes
        if [ -d "$p" ]; then
            bytes=$(dir_size_bytes "$p")
        elif [ -f "$p" ]; then
            bytes=$(du -sb "$p" 2>/dev/null | awk '{print $1}')
            bytes=${bytes:-0}
        else
            bytes=0
        fi
        total_bytes=$((total_bytes + bytes))
        echo "  $p ($sz)"
    done

    echo ""
    echo "Total space to free: $(human_size "$total_bytes")"
    echo ""
    read -rp "Proceed with deletion? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        return 0
    fi

    for p in "${paths_to_clean[@]}"; do
        if [ -d "$p" ]; then
            rm -rf "$p"
            echo "  Removed directory: $p"
        elif [ -f "$p" ]; then
            rm -f "$p"
            echo "  Removed file: $p"
        fi
    done

    echo ""
    echo "Shader cache cleaned. Freed $(human_size "$total_bytes")."

    # Desktop notification
    if command -v notify-send &>/dev/null; then
        notify-send "24HG Forge Shader Cache" "Cleaned $(human_size "$total_bytes") of shader cache data." -i dialog-information
    fi
}

cmd_prebuild() {
    local appid="${2:-}"
    if [ -z "$appid" ] || ! [[ "$appid" =~ ^[0-9]+$ ]]; then
        echo "Usage: forge-shader-cache prebuild <appid>"
        return 1
    fi

    local name
    name=$(get_game_name "$appid")
    echo "=== Pre-build Shader Cache for $name (AppID $appid) ==="
    echo ""

    local steam_dir
    steam_dir=$(get_steam_dir)
    if [ -z "$steam_dir" ]; then
        echo "Error: Steam installation not found."
        return 1
    fi

    # Method 1: Touch the shader manifest to trigger Steam's shader pre-caching
    local shader_manifest="$steam_dir/steamapps/shadercache/$appid/shadercache.manifest"
    if [ -f "$shader_manifest" ]; then
        echo "Triggering Steam shader pre-cache by updating manifest timestamp..."
        touch "$shader_manifest"
        echo "  Updated: $shader_manifest"
        echo "  Steam should re-validate and download pre-compiled shaders on next launch."
        echo ""
    fi

    # Method 2: Launch game briefly with DXVK async compilation enabled
    echo "Launching game with shader compilation optimizations..."
    echo "  DXVK_ASYNC=1 (async shader compilation, reduces stuttering)"
    echo "  VKD3D_CONFIG=dxr11 (DX12 raytracing shader support)"
    echo "  DXVK_STATE_CACHE=1 (state cache enabled)"
    echo ""
    echo "The game will start. Play through menus and a brief session to populate caches."
    echo "Close the game when ready."
    echo ""

    read -rp "Launch now? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        return 0
    fi

    # Determine if Flatpak or native Steam
    if [ -d "$STEAM_FLATPAK" ] && [ "$steam_dir" = "$STEAM_FLATPAK" ]; then
        DXVK_ASYNC=1 VKD3D_CONFIG=dxr11 DXVK_STATE_CACHE=1 \
            flatpak run com.valvesoftware.Steam "steam://run/$appid" 2>/dev/null &
    else
        DXVK_ASYNC=1 VKD3D_CONFIG=dxr11 DXVK_STATE_CACHE=1 \
            steam "steam://run/$appid" 2>/dev/null &
    fi

    echo "Game launched (PID $!). Close it when shader compilation is done."

    if command -v notify-send &>/dev/null; then
        notify-send "24HG Forge Shader Cache" "Pre-building shaders for $name. Close the game when ready." -i dialog-information
    fi
}

cmd_export() {
    local appid="${2:-}"
    if [ -z "$appid" ] || ! [[ "$appid" =~ ^[0-9]+$ ]]; then
        echo "Usage: forge-shader-cache export <appid>"
        return 1
    fi

    local name
    name=$(get_game_name "$appid")
    echo "=== Export Shader Cache for $name (AppID $appid) ==="
    echo ""

    local files_to_export=()

    # Collect DXVK state caches
    while IFS= read -r cache_file; do
        [ -z "$cache_file" ] && continue
        files_to_export+=("$cache_file")
    done < <(find_dxvk_caches "$appid")

    # Also include the Steam shader cache directory if present
    local sc
    sc=$(get_steam_shader_cache "$appid")
    if [ -n "$sc" ] && [ -d "$sc" ]; then
        while IFS= read -r f; do
            [ -z "$f" ] && continue
            files_to_export+=("$f")
        done < <(find "$sc" -type f 2>/dev/null)
    fi

    if [ ${#files_to_export[@]} -eq 0 ]; then
        echo "No shader cache files found for AppID $appid."
        return 1
    fi

    local export_dir="$HOME/.local/share/forge/shader-exports"
    mkdir -p "$export_dir"
    local tarball="$export_dir/shader-cache_${appid}_$(date +%Y%m%d_%H%M%S).tar.gz"

    echo "Packaging ${#files_to_export[@]} file(s)..."

    # Create a manifest with metadata
    local manifest
    manifest=$(mktemp)
    {
        echo "# 24HG Forge Shader Cache Export"
        echo "appid=$appid"
        echo "name=$name"
        echo "date=$(date -Iseconds)"
        echo "hostname=$(hostname)"
        echo "gpu=$(lspci 2>/dev/null | grep -i 'vga\|3d' | head -1 | sed 's/.*: //' || echo 'unknown')"
    } > "$manifest"

    # Build tar with relative paths
    tar czf "$tarball" \
        --transform='s|.*/||' \
        -C "$(dirname "$manifest")" "$(basename "$manifest")" \
        "${files_to_export[@]}" 2>/dev/null

    rm -f "$manifest"

    local tarsize
    tarsize=$(du -sh "$tarball" | awk '{print $1}')

    echo "Exported to: $tarball ($tarsize)"
    echo ""
    echo "Share this file with other 24HG Forge users. They can import it with:"
    echo "  forge-shader-cache import $tarball"

    if command -v notify-send &>/dev/null; then
        notify-send "24HG Forge Shader Cache" "Exported shader cache for $name ($tarsize)" -i dialog-information
    fi
}

cmd_import() {
    local file="${2:-}"
    if [ -z "$file" ] || [ ! -f "$file" ]; then
        echo "Usage: forge-shader-cache import <file>"
        [ -n "$file" ] && echo "Error: File not found: $file"
        return 1
    fi

    echo "=== Import Shader Cache ==="
    echo ""
    echo "Archive: $file"
    echo "Contents:"
    tar tzf "$file" | head -20
    echo ""

    # Extract to temp dir for inspection
    local tmpdir
    tmpdir=$(mktemp -d)
    tar xzf "$file" -C "$tmpdir"

    # Read manifest if present
    local appid=""
    local name=""
    if [ -f "$tmpdir/manifest" ] || ls "$tmpdir"/*.manifest &>/dev/null 2>&1; then
        local mf
        mf=$(find "$tmpdir" -name "manifest" -o -name "*.manifest" | head -1)
        if [ -n "$mf" ] && [ -f "$mf" ]; then
            appid=$(sed -n 's/^appid=//p' "$mf")
            name=$(sed -n 's/^name=//p' "$mf")
        fi
    fi

    if [ -n "$name" ]; then
        echo "Game: $name (AppID $appid)"
    fi

    # Find DXVK cache files in the extracted archive
    local dxvk_files=()
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        dxvk_files+=("$f")
    done < <(find "$tmpdir" -name "*.dxvk-cache" -type f 2>/dev/null)

    if [ ${#dxvk_files[@]} -eq 0 ]; then
        echo "No DXVK state cache files found in archive."
        rm -rf "$tmpdir"
        return 1
    fi

    echo "Found ${#dxvk_files[@]} DXVK state cache file(s) to import."
    echo ""

    # Find the target compatdata directory
    local compat_dir=""
    if [ -n "$appid" ]; then
        compat_dir=$(get_compat_dir "$appid")
    fi

    if [ -z "$compat_dir" ]; then
        echo "Warning: Could not find Wine prefix for AppID $appid."
        echo "The game may need to be launched at least once first."
        echo ""
        read -rp "Specify a target directory (or press Enter to abort): " compat_dir
        if [ -z "$compat_dir" ]; then
            rm -rf "$tmpdir"
            echo "Aborted."
            return 0
        fi
    fi

    read -rp "Import DXVK caches into $compat_dir? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        rm -rf "$tmpdir"
        echo "Aborted."
        return 0
    fi

    # Merge: if a .dxvk-cache already exists at destination, we need to merge entries.
    # DXVK cache files are append-only binary, so we can try to find existing files
    # and merge by keeping the larger one (which has more entries), or simply replace.
    local imported=0
    for src in "${dxvk_files[@]}"; do
        local basename_f
        basename_f=$(basename "$src")
        # Find existing cache file with same name in the prefix
        local existing
        existing=$(find "$compat_dir" -name "$basename_f" -type f 2>/dev/null | head -1)

        if [ -n "$existing" ]; then
            local src_size existing_size
            src_size=$(stat -c%s "$src" 2>/dev/null || echo 0)
            existing_size=$(stat -c%s "$existing" 2>/dev/null || echo 0)

            if [ "$src_size" -gt "$existing_size" ]; then
                # Backup existing, replace with larger import
                cp "$existing" "${existing}.bak"
                cp "$src" "$existing"
                echo "  Merged (replaced): $basename_f ($(human_size "$src_size") > $(human_size "$existing_size"))"
            else
                echo "  Skipped: $basename_f (existing is larger or equal)"
            fi
        else
            # No existing file, find the pfx directory and place it there
            local pfx_dir="$compat_dir/pfx"
            if [ -d "$pfx_dir" ]; then
                cp "$src" "$pfx_dir/$basename_f"
                echo "  Imported: $basename_f -> $pfx_dir/"
            else
                cp "$src" "$compat_dir/$basename_f"
                echo "  Imported: $basename_f -> $compat_dir/"
            fi
        fi
        imported=$((imported + 1))
    done

    rm -rf "$tmpdir"

    echo ""
    echo "Import complete. $imported file(s) processed."

    if command -v notify-send &>/dev/null; then
        notify-send "24HG Forge Shader Cache" "Imported $imported shader cache file(s)." -i dialog-information
    fi
}

cmd_optimize() {
    echo "=== 24HG Forge Shader Cache Optimization ==="
    echo ""

    local env_dir="$HOME/.config/environment.d"
    local env_file="$env_dir/forge-shader-cache.conf"

    mkdir -p "$env_dir"

    # Build environment config
    cat > "$env_file" << 'ENVEOF'
# 24HG Forge Shader Cache Optimization
# Written by forge-shader-cache optimize

# Mesa: 10GB shader cache limit (default is 1GB)
MESA_SHADER_CACHE_MAX_SIZE=10G

# DXVK: Enable state cache for faster shader recompilation
DXVK_STATE_CACHE=1

# DXVK: Use async shader compilation to reduce stuttering
DXVK_ASYNC=1

# Radeon: Enable shader cache
RADV_PERFTEST=gpl

# NVIDIA: Threaded optimizations
__GL_THREADED_OPTIMIZATIONS=1
ENVEOF

    echo "Written environment config to: $env_file"
    echo ""
    echo "Settings applied:"
    echo "  MESA_SHADER_CACHE_MAX_SIZE=10G  (10GB Mesa shader cache limit)"
    echo "  DXVK_STATE_CACHE=1              (DXVK state cache enabled)"
    echo "  DXVK_ASYNC=1                    (async shader compilation)"
    echo "  RADV_PERFTEST=gpl               (RADV graphics pipeline library)"
    echo "  __GL_THREADED_OPTIMIZATIONS=1   (NVIDIA threaded optimizations)"
    echo ""

    # Also apply to current session
    export MESA_SHADER_CACHE_MAX_SIZE=10G
    export DXVK_STATE_CACHE=1
    export DXVK_ASYNC=1
    export RADV_PERFTEST=gpl
    export __GL_THREADED_OPTIMIZATIONS=1

    echo "Settings are active for this session and will persist after reboot."
    echo ""

    # Create Mesa cache dir if it doesn't exist
    if [ ! -d "$MESA_CACHE" ]; then
        mkdir -p "$MESA_CACHE"
        echo "Created Mesa shader cache directory: $MESA_CACHE"
    fi

    # Show current cache sizes
    echo ""
    cmd_size

    if command -v notify-send &>/dev/null; then
        notify-send "24HG Forge Shader Cache" "Shader cache optimized. Settings will persist after reboot." -i dialog-information
    fi
}

cmd_help() {
    cat << 'EOF'
24HG Forge Shader Cache Manager
Manage shader caches to eliminate first-launch stuttering.

Usage:
  forge-shader-cache <command> [arguments]

Commands:
  status             Show shader cache status, per-game breakdown, DXVK files
  clean <appid|all>  Clear shader cache for a game or all games
  size               Show total shader cache disk usage by location
  prebuild <appid>   Force shader pre-compilation for a game
  export <appid>     Package shader cache as a tarball for sharing
  import <file>      Import a shared shader cache tarball
  optimize           Apply optimal shader cache settings system-wide
  help               Show this help message

Examples:
  forge-shader-cache status
  forge-shader-cache clean 252490        # Clean Rust shader cache
  forge-shader-cache clean all           # Clean all shader caches
  forge-shader-cache prebuild 252490     # Pre-build shaders for Rust
  forge-shader-cache export 252490       # Export Rust shader cache
  forge-shader-cache import shader-cache_252490_20260316.tar.gz
  forge-shader-cache optimize            # Apply optimal settings

Cache Locations Managed:
  - Steam shader cache    (~/.var/app/.../shadercache/ or ~/.local/share/Steam/...)
  - DXVK state cache      (*.dxvk-cache in Wine prefixes)
  - Mesa shader cache      (~/.cache/mesa_shader_cache/ or $MESA_SHADER_CACHE_DIR)
  - NVIDIA GL cache       (~/.cache/nvidia/GLCache/)
  - AMD shader cache      (~/.cache/AMD/GLCache/)

Supports both Flatpak and native Steam installations.
EOF
}

# ─── Main ───────────────────────────────────────────────────────────────────

case "$ACTION" in
    status)     cmd_status ;;
    clean)      cmd_clean "$@" ;;
    size)       cmd_size ;;
    prebuild)   cmd_prebuild "$@" ;;
    export)     cmd_export "$@" ;;
    import)     cmd_import "$@" ;;
    optimize)   cmd_optimize ;;
    help|--help|-h)  cmd_help ;;
    *)
        echo "Unknown command: $ACTION"
        echo ""
        cmd_help
        exit 1
        ;;
esac
