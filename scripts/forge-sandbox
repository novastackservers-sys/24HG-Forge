#!/usr/bin/env bash
# ============================================================================
# forge-sandbox — 24HG Forge Safe Gaming Sandbox
# Privacy-first game isolation using bubblewrap (bwrap) or firejail
# Games run in contained environments that cannot access personal files
# unless explicitly allowed.
# ============================================================================
set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
readonly VERSION="1.0.0"
readonly SCRIPT_NAME="forge-sandbox"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge/sandbox"
readonly PROFILES_DIR="${CONFIG_DIR}/profiles"
readonly RULES_DIR="${CONFIG_DIR}/rules"
readonly LOG_DIR="${CONFIG_DIR}/logs"
readonly GLOBAL_CONF="${CONFIG_DIR}/sandbox.conf"
readonly STEAM_DIR="${HOME}/.local/share/Steam"
readonly HEROIC_DIR="${HOME}/.config/heroic"
readonly LUTRIS_DIR="${HOME}/.local/share/lutris"

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly DIM='\033[2m'
readonly NC='\033[0m'

# Devices
readonly WEBCAM_DEVICES=(/dev/video*)
readonly MIC_DEVICE="/dev/snd"

# ---------------------------------------------------------------------------
# Initialization
# ---------------------------------------------------------------------------
init_dirs() {
    mkdir -p "$PROFILES_DIR" "$RULES_DIR" "$LOG_DIR"
    if [[ ! -f "$GLOBAL_CONF" ]]; then
        cat > "$GLOBAL_CONF" <<'CONF'
# forge-sandbox global configuration
# Backend: bwrap (default) or firejail
SANDBOX_BACKEND=bwrap
# Default network access: allow | block
DEFAULT_NETWORK=allow
# Default webcam access: allow | block
DEFAULT_WEBCAM=block
# Default microphone access: allow | block
DEFAULT_MIC=block
# Audit logging: true | false
AUDIT_LOGGING=true
# Max log size in lines per game
MAX_LOG_LINES=5000
CONF
    fi
    source "$GLOBAL_CONF"
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
log_msg()  { echo -e "${GREEN}[sandbox]${NC} $*"; }
warn_msg() { echo -e "${YELLOW}[sandbox]${NC} $*"; }
err_msg()  { echo -e "${RED}[sandbox]${NC} $*" >&2; }
die()      { err_msg "$@"; exit 1; }

check_backend() {
    local backend="${SANDBOX_BACKEND:-bwrap}"
    case "$backend" in
        bwrap)
            command -v bwrap &>/dev/null || die "bubblewrap (bwrap) not found. Install with: sudo dnf install bubblewrap"
            ;;
        firejail)
            command -v firejail &>/dev/null || die "firejail not found. Install with: sudo dnf install firejail"
            ;;
        *) die "Unknown backend: $backend (use bwrap or firejail)" ;;
    esac
}

game_id_from_name() {
    # Normalize game name to a safe filesystem identifier
    echo "$1" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | sed 's/^-//;s/-$//'
}

timestamp() { date '+%Y-%m-%d %H:%M:%S'; }

audit_log() {
    local game="$1" action="$2" detail="${3:-}"
    [[ "${AUDIT_LOGGING:-true}" != "true" ]] && return
    local logfile="${LOG_DIR}/${game}.log"
    echo "[$(timestamp)] ${action}: ${detail}" >> "$logfile"
    # Trim if too large
    local max="${MAX_LOG_LINES:-5000}"
    if [[ -f "$logfile" ]] && (( $(wc -l < "$logfile") > max )); then
        tail -n "$max" "$logfile" > "${logfile}.tmp" && mv "${logfile}.tmp" "$logfile"
    fi
}

# ---------------------------------------------------------------------------
# Rules Management
# ---------------------------------------------------------------------------
get_rules_file() {
    local game="$1"
    echo "${RULES_DIR}/${game}.rules"
}

load_rules() {
    local game="$1"
    local rules_file
    rules_file="$(get_rules_file "$game")"
    if [[ -f "$rules_file" ]]; then
        source "$rules_file"
    else
        # Defaults from global config
        GAME_NETWORK="${DEFAULT_NETWORK:-allow}"
        GAME_WEBCAM="${DEFAULT_WEBCAM:-block}"
        GAME_MIC="${DEFAULT_MIC:-block}"
        GAME_EXTRA_PATHS=()
    fi
}

save_rules() {
    local game="$1"
    local rules_file
    rules_file="$(get_rules_file "$game")"
    cat > "$rules_file" <<RULES
# Sandbox rules for: ${game}
# Generated by forge-sandbox on $(timestamp)
GAME_NETWORK="${GAME_NETWORK:-allow}"
GAME_WEBCAM="${GAME_WEBCAM:-block}"
GAME_MIC="${GAME_MIC:-block}"
GAME_EXTRA_PATHS=(${GAME_EXTRA_PATHS[*]+"${GAME_EXTRA_PATHS[*]}"})
RULES
    log_msg "Rules saved for ${BOLD}${game}${NC}"
}

# ---------------------------------------------------------------------------
# Profile Management
# ---------------------------------------------------------------------------
get_profile_file() {
    local game="$1"
    echo "${PROFILES_DIR}/${game}.profile"
}

create_default_profile() {
    local game="$1" install_dir="$2" save_dir="${3:-}"
    local profile_file
    profile_file="$(get_profile_file "$game")"
    cat > "$profile_file" <<PROFILE
# Sandbox profile for: ${game}
# Created: $(timestamp)
GAME_NAME="${game}"
INSTALL_DIR="${install_dir}"
SAVE_DIR="${save_dir}"
LAUNCH_CMD=""
PROFILE
    log_msg "Profile created: ${BOLD}${profile_file}${NC}"
}

load_profile() {
    local game="$1"
    local profile_file
    profile_file="$(get_profile_file "$game")"
    [[ -f "$profile_file" ]] || return 1
    source "$profile_file"
    return 0
}

# Pre-built Steam profile
create_steam_profile() {
    local appid="$1"
    local game_id="steam-${appid}"
    local install_dir="${STEAM_DIR}/steamapps/common"
    local save_dir="${STEAM_DIR}/steamapps/compatdata/${appid}"
    local profile_file
    profile_file="$(get_profile_file "$game_id")"
    cat > "$profile_file" <<PROFILE
# Steam sandbox profile for AppID: ${appid}
# Created: $(timestamp)
GAME_NAME="steam-${appid}"
INSTALL_DIR="${install_dir}"
SAVE_DIR="${save_dir}"
COMPAT_DIR="${STEAM_DIR}/steamapps/compatdata/${appid}"
SHADER_CACHE="${STEAM_DIR}/steamapps/shadercache/${appid}"
LAUNCH_CMD="steam steam://rungameid/${appid}"
PROFILE
    log_msg "Steam profile created for AppID ${BOLD}${appid}${NC}"
}

# Pre-built Heroic profile
create_heroic_profile() {
    local game="$1"
    local game_id="heroic-$(game_id_from_name "$game")"
    local profile_file
    profile_file="$(get_profile_file "$game_id")"
    cat > "$profile_file" <<PROFILE
# Heroic sandbox profile for: ${game}
# Created: $(timestamp)
GAME_NAME="${game_id}"
INSTALL_DIR="${HOME}/Games/Heroic/${game}"
SAVE_DIR="${HEROIC_DIR}/store"
LAUNCH_CMD=""
PROFILE
    log_msg "Heroic profile created for ${BOLD}${game}${NC}"
}

# Pre-built Lutris profile
create_lutris_profile() {
    local game="$1"
    local game_id="lutris-$(game_id_from_name "$game")"
    local profile_file
    profile_file="$(get_profile_file "$game_id")"
    cat > "$profile_file" <<PROFILE
# Lutris sandbox profile for: ${game}
# Created: $(timestamp)
GAME_NAME="${game_id}"
INSTALL_DIR="${HOME}/Games/${game}"
SAVE_DIR="${LUTRIS_DIR}/runners"
LAUNCH_CMD=""
PROFILE
    log_msg "Lutris profile created for ${BOLD}${game}${NC}"
}

# ---------------------------------------------------------------------------
# Sandbox Execution — bwrap
# ---------------------------------------------------------------------------
build_bwrap_args() {
    local game="$1"
    shift
    load_rules "$game"

    local args=()

    # Base filesystem: read-only bind the system
    args+=(--ro-bind /usr /usr)
    args+=(--ro-bind /etc /etc)
    args+=(--ro-bind /lib /lib)
    [[ -d /lib64 ]] && args+=(--ro-bind /lib64 /lib64)
    args+=(--ro-bind /bin /bin)
    args+=(--ro-bind /sbin /sbin)
    args+=(--proc /proc)
    args+=(--dev /dev)
    args+=(--tmpfs /tmp)

    # XDG runtime for Wayland/PulseAudio sockets
    local xdg_run="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    if [[ -d "$xdg_run" ]]; then
        args+=(--bind "$xdg_run" "$xdg_run")
    fi

    # GPU access
    [[ -d /dev/dri ]] && args+=(--dev-bind /dev/dri /dev/dri)
    [[ -e /dev/nvidia0 ]] && args+=(--dev-bind /dev/nvidia0 /dev/nvidia0)
    [[ -e /dev/nvidiactl ]] && args+=(--dev-bind /dev/nvidiactl /dev/nvidiactl)
    [[ -e /dev/nvidia-modeset ]] && args+=(--dev-bind /dev/nvidia-modeset /dev/nvidia-modeset)
    [[ -e /dev/nvidia-uvm ]] && args+=(--dev-bind /dev/nvidia-uvm /dev/nvidia-uvm)

    # Webcam access
    if [[ "${GAME_WEBCAM}" == "allow" ]]; then
        for dev in "${WEBCAM_DEVICES[@]}"; do
            [[ -e "$dev" ]] && args+=(--dev-bind "$dev" "$dev")
        done
        audit_log "$game" "DEVICE_ALLOW" "webcam"
    else
        audit_log "$game" "DEVICE_BLOCK" "webcam"
    fi

    # Microphone access
    if [[ "${GAME_MIC}" == "allow" ]]; then
        [[ -d "$MIC_DEVICE" ]] && args+=(--dev-bind "$MIC_DEVICE" "$MIC_DEVICE")
        audit_log "$game" "DEVICE_ALLOW" "microphone"
    else
        audit_log "$game" "DEVICE_BLOCK" "microphone"
    fi

    # Network control
    if [[ "${GAME_NETWORK}" == "block" ]]; then
        args+=(--unshare-net)
        audit_log "$game" "NETWORK" "blocked"
    else
        audit_log "$game" "NETWORK" "allowed"
    fi

    # Game install directory (read-write)
    if [[ -n "${INSTALL_DIR:-}" && -d "${INSTALL_DIR}" ]]; then
        args+=(--bind "$INSTALL_DIR" "$INSTALL_DIR")
        audit_log "$game" "PATH_BIND" "$INSTALL_DIR (rw)"
    fi

    # Game save directory (read-write)
    if [[ -n "${SAVE_DIR:-}" && -d "${SAVE_DIR}" ]]; then
        args+=(--bind "$SAVE_DIR" "$SAVE_DIR")
        audit_log "$game" "PATH_BIND" "$SAVE_DIR (rw)"
    fi

    # Compat/shader dirs for Steam
    if [[ -n "${COMPAT_DIR:-}" && -d "${COMPAT_DIR}" ]]; then
        args+=(--bind "$COMPAT_DIR" "$COMPAT_DIR")
    fi
    if [[ -n "${SHADER_CACHE:-}" && -d "${SHADER_CACHE}" ]]; then
        args+=(--bind "$SHADER_CACHE" "$SHADER_CACHE")
    fi

    # Extra allowed paths from rules
    for extra in "${GAME_EXTRA_PATHS[@]+"${GAME_EXTRA_PATHS[@]}"}"; do
        [[ -z "$extra" ]] && continue
        if [[ -e "$extra" ]]; then
            args+=(--bind "$extra" "$extra")
            audit_log "$game" "PATH_BIND" "$extra (extra)"
        else
            warn_msg "Extra path not found: $extra"
        fi
    done

    # Essential runtime paths for gaming
    local steam_runtime="${STEAM_DIR}/ubuntu12_32"
    [[ -d "$steam_runtime" ]] && args+=(--ro-bind "$steam_runtime" "$steam_runtime")

    # Isolate home — give a tmpfs home with only what's needed
    args+=(--tmpfs "$HOME")
    # Bind back specific dirs the game actually needs
    [[ -d "${HOME}/.local/share/vulkan" ]] && args+=(--ro-bind "${HOME}/.local/share/vulkan" "${HOME}/.local/share/vulkan")
    [[ -d "${HOME}/.nv" ]] && args+=(--bind "${HOME}/.nv" "${HOME}/.nv")

    # New PID namespace for isolation
    args+=(--unshare-pid --die-with-parent)

    # Set environment
    args+=(--setenv HOME "$HOME")
    args+=(--setenv XDG_RUNTIME_DIR "$xdg_run")

    echo "${args[@]}"
}

run_bwrap() {
    local game="$1"
    shift
    local bwrap_args
    bwrap_args="$(build_bwrap_args "$game")"

    audit_log "$game" "LAUNCH" "bwrap: $*"
    log_msg "Launching in sandbox (bwrap): ${BOLD}$*${NC}"

    # shellcheck disable=SC2086
    exec bwrap $bwrap_args -- "$@"
}

# ---------------------------------------------------------------------------
# Sandbox Execution — firejail
# ---------------------------------------------------------------------------
build_firejail_args() {
    local game="$1"
    load_rules "$game"

    local args=()
    args+=(--private)
    args+=(--noroot)

    # Whitelist game directories
    if [[ -n "${INSTALL_DIR:-}" ]]; then
        args+=(--whitelist="$INSTALL_DIR")
    fi
    if [[ -n "${SAVE_DIR:-}" ]]; then
        args+=(--whitelist="$SAVE_DIR")
    fi
    for extra in "${GAME_EXTRA_PATHS[@]+"${GAME_EXTRA_PATHS[@]}"}"; do
        [[ -n "$extra" ]] && args+=(--whitelist="$extra")
    done

    # Device control
    if [[ "${GAME_WEBCAM}" == "block" ]]; then
        args+=(--no-webcam)
    fi

    # Network control
    if [[ "${GAME_NETWORK}" == "block" ]]; then
        args+=(--net=none)
    fi

    # GPU access
    args+=(--ignore=novideo)

    echo "${args[@]}"
}

run_firejail() {
    local game="$1"
    shift
    local fj_args
    fj_args="$(build_firejail_args "$game")"

    audit_log "$game" "LAUNCH" "firejail: $*"
    log_msg "Launching in sandbox (firejail): ${BOLD}$*${NC}"

    # shellcheck disable=SC2086
    exec firejail $fj_args -- "$@"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_status() {
    echo -e "${BOLD}${CYAN}=== Forge Sandbox Status ===${NC}"
    echo -e "${DIM}Version ${VERSION}${NC}"
    echo ""

    # Backend
    local backend="${SANDBOX_BACKEND:-bwrap}"
    local backend_ok=false
    if command -v "$backend" &>/dev/null; then
        backend_ok=true
    fi
    echo -e "  Backend:    ${BOLD}${backend}${NC} $(${backend_ok} && echo -e "${GREEN}(installed)${NC}" || echo -e "${RED}(not found)${NC}")"
    echo -e "  Network:    Default ${BOLD}${DEFAULT_NETWORK:-allow}${NC}"
    echo -e "  Webcam:     Default ${BOLD}${DEFAULT_WEBCAM:-block}${NC}"
    echo -e "  Microphone: Default ${BOLD}${DEFAULT_MIC:-block}${NC}"
    echo -e "  Audit log:  ${BOLD}${AUDIT_LOGGING:-true}${NC}"
    echo ""

    # Profiles
    local profile_count=0
    if [[ -d "$PROFILES_DIR" ]]; then
        profile_count=$(find "$PROFILES_DIR" -name '*.profile' 2>/dev/null | wc -l)
    fi
    echo -e "  Profiles:   ${BOLD}${profile_count}${NC} configured"

    # Rules
    local rules_count=0
    if [[ -d "$RULES_DIR" ]]; then
        rules_count=$(find "$RULES_DIR" -name '*.rules' 2>/dev/null | wc -l)
    fi
    echo -e "  Rules:      ${BOLD}${rules_count}${NC} custom rule sets"
    echo ""

    # List profiles
    if (( profile_count > 0 )); then
        echo -e "  ${BOLD}Game Profiles:${NC}"
        for pf in "$PROFILES_DIR"/*.profile; do
            [[ -f "$pf" ]] || continue
            local name
            name="$(basename "$pf" .profile)"
            local net="allow" cam="block" mic="block"
            if [[ -f "${RULES_DIR}/${name}.rules" ]]; then
                source "${RULES_DIR}/${name}.rules"
                net="${GAME_NETWORK:-allow}"
                cam="${GAME_WEBCAM:-block}"
                mic="${GAME_MIC:-block}"
            fi
            local net_icon cam_icon mic_icon
            [[ "$net" == "allow" ]] && net_icon="${GREEN}net${NC}" || net_icon="${RED}net${NC}"
            [[ "$cam" == "allow" ]] && cam_icon="${GREEN}cam${NC}" || cam_icon="${RED}cam${NC}"
            [[ "$mic" == "allow" ]] && mic_icon="${GREEN}mic${NC}" || mic_icon="${RED}mic${NC}"
            echo -e "    ${BLUE}${name}${NC}  [${net_icon} | ${cam_icon} | ${mic_icon}]"
        done
    fi
}

cmd_run() {
    [[ $# -lt 1 ]] && die "Usage: $SCRIPT_NAME run <command> [args...]"
    check_backend

    local cmd_name
    cmd_name="$(game_id_from_name "$(basename "$1")")"
    load_rules "$cmd_name"

    # Load profile if exists, otherwise use sensible defaults
    INSTALL_DIR="" SAVE_DIR="" COMPAT_DIR="" SHADER_CACHE=""
    load_profile "$cmd_name" 2>/dev/null || true

    local backend="${SANDBOX_BACKEND:-bwrap}"
    if [[ "$backend" == "bwrap" ]]; then
        run_bwrap "$cmd_name" "$@"
    else
        run_firejail "$cmd_name" "$@"
    fi
}

cmd_steam() {
    [[ $# -lt 1 ]] && die "Usage: $SCRIPT_NAME steam <appid>"
    check_backend

    local appid="$1"
    local game_id="steam-${appid}"

    # Create profile if it doesn't exist
    if ! load_profile "$game_id" 2>/dev/null; then
        create_steam_profile "$appid"
        load_profile "$game_id"
    fi

    load_rules "$game_id"

    # Ensure directories exist
    mkdir -p "${SAVE_DIR:-/dev/null}" 2>/dev/null || true

    local backend="${SANDBOX_BACKEND:-bwrap}"
    audit_log "$game_id" "STEAM_LAUNCH" "AppID ${appid}"

    if [[ "$backend" == "bwrap" ]]; then
        run_bwrap "$game_id" steam "steam://rungameid/${appid}"
    else
        run_firejail "$game_id" steam "steam://rungameid/${appid}"
    fi
}

cmd_allow() {
    [[ $# -lt 2 ]] && die "Usage: $SCRIPT_NAME allow <game> <path>"

    local game
    game="$(game_id_from_name "$1")"
    local target_path="$2"

    # Resolve to absolute path
    target_path="$(realpath -m "$target_path")"

    # Safety check — never allow binding all of home
    if [[ "$target_path" == "$HOME" || "$target_path" == "/" ]]; then
        die "Refusing to allow access to ${target_path} — too broad. Specify a subdirectory."
    fi

    load_rules "$game"
    GAME_EXTRA_PATHS+=("$target_path")
    save_rules "$game"
    audit_log "$game" "RULE_ALLOW" "path: $target_path"
    log_msg "Allowed ${BOLD}${game}${NC} to access: ${target_path}"
}

cmd_block() {
    [[ $# -lt 2 ]] && die "Usage: $SCRIPT_NAME block <game> <device>"

    local game
    game="$(game_id_from_name "$1")"
    local device="$2"

    load_rules "$game"
    case "$device" in
        webcam|cam|camera)
            GAME_WEBCAM="block"
            log_msg "Blocked webcam for ${BOLD}${game}${NC}"
            ;;
        mic|microphone|audio-in)
            GAME_MIC="block"
            log_msg "Blocked microphone for ${BOLD}${game}${NC}"
            ;;
        network|net)
            GAME_NETWORK="block"
            log_msg "Blocked network for ${BOLD}${game}${NC}"
            ;;
        *)
            die "Unknown device: $device (use: webcam, mic, network)"
            ;;
    esac
    save_rules "$game"
    audit_log "$game" "RULE_BLOCK" "device: $device"
}

cmd_rules() {
    local game="${1:-}"

    if [[ -z "$game" ]]; then
        # Show all rules
        echo -e "${BOLD}${CYAN}=== Sandbox Rules ===${NC}"
        echo ""
        if [[ -d "$RULES_DIR" ]] && compgen -G "${RULES_DIR}/*.rules" >/dev/null; then
            for rf in "$RULES_DIR"/*.rules; do
                local name
                name="$(basename "$rf" .rules)"
                echo -e "  ${BOLD}${BLUE}${name}${NC}"
                source "$rf"
                echo -e "    Network:  ${GAME_NETWORK:-allow}"
                echo -e "    Webcam:   ${GAME_WEBCAM:-block}"
                echo -e "    Mic:      ${GAME_MIC:-block}"
                if [[ ${#GAME_EXTRA_PATHS[@]} -gt 0 ]] 2>/dev/null; then
                    echo -e "    Extra paths:"
                    for p in "${GAME_EXTRA_PATHS[@]}"; do
                        echo -e "      - ${p}"
                    done
                fi
                echo ""
            done
        else
            echo -e "  ${DIM}No custom rules configured. Using global defaults.${NC}"
        fi
    else
        game="$(game_id_from_name "$game")"
        local rules_file
        rules_file="$(get_rules_file "$game")"
        if [[ -f "$rules_file" ]]; then
            echo -e "${BOLD}${CYAN}Rules for: ${game}${NC}"
            echo ""
            source "$rules_file"
            echo -e "  Network:    ${GAME_NETWORK:-allow}"
            echo -e "  Webcam:     ${GAME_WEBCAM:-block}"
            echo -e "  Microphone: ${GAME_MIC:-block}"
            if [[ ${#GAME_EXTRA_PATHS[@]} -gt 0 ]] 2>/dev/null; then
                echo -e "  Extra allowed paths:"
                for p in "${GAME_EXTRA_PATHS[@]}"; do
                    echo -e "    - ${p}"
                done
            fi
        else
            echo -e "${DIM}No custom rules for '${game}'. Global defaults apply.${NC}"
            echo -e "  Network:    ${DEFAULT_NETWORK:-allow}"
            echo -e "  Webcam:     ${DEFAULT_WEBCAM:-block}"
            echo -e "  Microphone: ${DEFAULT_MIC:-block}"
        fi
    fi
}

cmd_log() {
    local game="${1:-}"

    if [[ -z "$game" ]]; then
        echo -e "${BOLD}${CYAN}=== Sandbox Audit Logs ===${NC}"
        echo ""
        if [[ -d "$LOG_DIR" ]] && compgen -G "${LOG_DIR}/*.log" >/dev/null; then
            for lf in "$LOG_DIR"/*.log; do
                local name
                name="$(basename "$lf" .log)"
                local lines
                lines="$(wc -l < "$lf")"
                local last
                last="$(tail -1 "$lf" 2>/dev/null || echo "empty")"
                echo -e "  ${BLUE}${name}${NC} (${lines} entries)"
                echo -e "    Last: ${DIM}${last}${NC}"
            done
        else
            echo -e "  ${DIM}No audit logs yet. Run a game in sandbox to generate logs.${NC}"
        fi
    else
        game="$(game_id_from_name "$game")"
        local logfile="${LOG_DIR}/${game}.log"
        if [[ -f "$logfile" ]]; then
            echo -e "${BOLD}${CYAN}Audit log for: ${game}${NC}"
            echo ""
            tail -50 "$logfile"
        else
            echo -e "${DIM}No audit log for '${game}'.${NC}"
        fi
    fi
}

cmd_profile() {
    [[ $# -lt 1 ]] && die "Usage: $SCRIPT_NAME profile <game> [create|edit|delete]"

    local game
    game="$(game_id_from_name "$1")"
    local action="${2:-show}"
    local profile_file
    profile_file="$(get_profile_file "$game")"

    case "$action" in
        create)
            if [[ -f "$profile_file" ]]; then
                warn_msg "Profile already exists for '${game}'. Use 'edit' to modify."
                return 1
            fi
            echo -e "${BOLD}Creating profile for: ${game}${NC}"
            read -rp "Install directory: " install_dir
            read -rp "Save directory (optional): " save_dir
            create_default_profile "$game" "$install_dir" "$save_dir"

            # Also create default rules
            load_rules "$game"
            save_rules "$game"
            ;;
        edit)
            if [[ ! -f "$profile_file" ]]; then
                die "No profile for '${game}'. Use 'create' first."
            fi
            local editor="${EDITOR:-nano}"
            "$editor" "$profile_file"
            log_msg "Profile updated for ${BOLD}${game}${NC}"
            audit_log "$game" "PROFILE_EDIT" "manual edit"
            ;;
        delete)
            if [[ ! -f "$profile_file" ]]; then
                die "No profile for '${game}'."
            fi
            read -rp "Delete profile and rules for '${game}'? [y/N] " confirm
            if [[ "$confirm" =~ ^[Yy] ]]; then
                rm -f "$profile_file"
                rm -f "$(get_rules_file "$game")"
                log_msg "Deleted profile and rules for ${BOLD}${game}${NC}"
                audit_log "$game" "PROFILE_DELETE" "removed"
            fi
            ;;
        show|*)
            if [[ -f "$profile_file" ]]; then
                echo -e "${BOLD}${CYAN}Profile: ${game}${NC}"
                echo ""
                cat "$profile_file"
            else
                echo -e "${DIM}No profile for '${game}'.${NC}"
                echo ""
                echo "Create one with: $SCRIPT_NAME profile ${game} create"
                echo "Or use a launcher shortcut:"
                echo "  $SCRIPT_NAME steam <appid>"
            fi
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
${BOLD}forge-sandbox${NC} v${VERSION} — Safe Gaming Sandbox for 24HG Forge

${BOLD}USAGE:${NC}
    $SCRIPT_NAME <command> [options]

${BOLD}COMMANDS:${NC}
    status                  Show sandbox status and rules
    run <command>           Run a command in sandbox
    steam <appid>           Launch a Steam game in sandbox
    allow <game> <path>     Allow a game to access a specific path
    block <game> <device>   Block device access (webcam, mic, network)
    rules [game]            Show sandbox rules (all or per game)
    log [game]              Show access audit log
    profile <game> [action] Manage game profiles (create|edit|delete)

${BOLD}EXAMPLES:${NC}
    $SCRIPT_NAME steam 730                   # Launch CS2 sandboxed
    $SCRIPT_NAME run ./my-game               # Run any executable sandboxed
    $SCRIPT_NAME allow steam-730 ~/Music     # Let CS2 access music folder
    $SCRIPT_NAME block steam-730 webcam      # Block webcam for CS2
    $SCRIPT_NAME rules steam-730             # View CS2 sandbox rules
    $SCRIPT_NAME log steam-730               # View CS2 access log
    $SCRIPT_NAME profile mygame create       # Create a custom game profile

${BOLD}CONFIG:${NC}
    Profiles:  ${PROFILES_DIR}/
    Rules:     ${RULES_DIR}/
    Logs:      ${LOG_DIR}/
    Config:    ${GLOBAL_CONF}

${BOLD}BACKENDS:${NC}
    bwrap     (default) Bubblewrap — lightweight, namespace-based
    firejail  Feature-rich, SUID-based sandboxing

EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    init_dirs

    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        status)             cmd_status "$@" ;;
        run)                cmd_run "$@" ;;
        steam)              cmd_steam "$@" ;;
        allow)              cmd_allow "$@" ;;
        block)              cmd_block "$@" ;;
        rules)              cmd_rules "$@" ;;
        log)                cmd_log "$@" ;;
        profile)            cmd_profile "$@" ;;
        help|--help|-h)     usage ;;
        version|--version)  echo "forge-sandbox v${VERSION}" ;;
        *)                  err_msg "Unknown command: $cmd"; usage; exit 1 ;;
    esac
}

main "$@"
