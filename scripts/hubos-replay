#!/bin/bash
# HubOS Replay — Instant replay recording (like NVIDIA ShadowPlay)
# Uses gpu-screen-recorder for zero-overhead hardware-accelerated recording.
# Saves the last N minutes when you press the hotkey.
#
# Usage: hubos-replay [start|stop|save|status|config]

set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hubos"
CONFIG_FILE="$CONFIG_DIR/replay.conf"
CLIPS_DIR="${HOME}/Videos/HubOS Clips"
STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/hubos-replay"
PID_FILE="$STATE_DIR/replay.pid"

# Defaults
REPLAY_DURATION=120  # seconds (2 minutes)
REPLAY_QUALITY="very_high"  # ultra, very_high, high, medium
REPLAY_FPS=60
REPLAY_CODEC="auto"  # auto = NVENC on NVIDIA, VAAPI on AMD/Intel

mkdir -p "$CONFIG_DIR" "$STATE_DIR"

# Load config if exists
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
fi

detect_gpu_encoder() {
    if command -v nvidia-smi &>/dev/null && nvidia-smi -L &>/dev/null; then
        echo "h264_nvenc"
    elif [ -d /sys/class/drm/card0/device ] && grep -qi amd /sys/class/drm/card0/device/vendor 2>/dev/null; then
        echo "h264_vaapi"
    else
        echo "h264_vaapi"  # Intel / generic
    fi
}

check_gpu_screen_recorder() {
    if ! command -v gpu-screen-recorder &>/dev/null; then
        echo "gpu-screen-recorder is not installed."
        echo ""
        echo "Install it with:"
        echo "  flatpak install flathub com.dec05eba.gpu_screen_recorder"
        echo ""
        echo "Or if using rpm-ostree:"
        echo "  rpm-ostree install gpu-screen-recorder"
        return 1
    fi
    return 0
}

start_replay() {
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "Replay buffer already running (PID: $(cat "$PID_FILE"))"
        return 0
    fi

    check_gpu_screen_recorder || exit 1
    mkdir -p "$CLIPS_DIR"

    local ENCODER
    if [ "$REPLAY_CODEC" = "auto" ]; then
        ENCODER=$(detect_gpu_encoder)
    else
        ENCODER="$REPLAY_CODEC"
    fi

    echo "Starting HubOS Replay Buffer..."
    echo "  Duration: ${REPLAY_DURATION}s | Quality: $REPLAY_QUALITY | FPS: $REPLAY_FPS"
    echo "  Encoder: $ENCODER"
    echo "  Clips: $CLIPS_DIR"

    # Detect display server
    local WINDOW_ARG
    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        WINDOW_ARG="screen"  # Capture entire screen on Wayland
    else
        WINDOW_ARG="screen"
    fi

    # Start gpu-screen-recorder in replay mode
    gpu-screen-recorder \
        -w "$WINDOW_ARG" \
        -c mp4 \
        -q "$REPLAY_QUALITY" \
        -f "$REPLAY_FPS" \
        -r "$REPLAY_DURATION" \
        -o "$CLIPS_DIR" \
        -k "$ENCODER" \
        &>/dev/null &

    local PID=$!
    echo "$PID" > "$PID_FILE"
    sleep 1

    if kill -0 "$PID" 2>/dev/null; then
        echo "Replay buffer ACTIVE (PID: $PID)"
        echo "Send SIGUSR1 to save: kill -USR1 $PID"
        notify-send -a "24HG" -i "hubos-logo" "Replay Buffer Active" \
            "Last ${REPLAY_DURATION}s recording. Press Save to clip." 2>/dev/null || true
    else
        echo "Failed to start gpu-screen-recorder"
        rm -f "$PID_FILE"
        exit 1
    fi
}

stop_replay() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Replay buffer not running"
        return 0
    fi

    local PID
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        kill "$PID"
        echo "Replay buffer stopped"
        notify-send -a "24HG" -i "hubos-logo" "Replay Buffer Stopped" 2>/dev/null || true
    fi
    rm -f "$PID_FILE"
}

save_replay() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Replay buffer not running. Start it first: hubos-replay start"
        exit 1
    fi

    local PID
    PID=$(cat "$PID_FILE")
    if ! kill -0 "$PID" 2>/dev/null; then
        echo "Replay process died. Restart with: hubos-replay start"
        rm -f "$PID_FILE"
        exit 1
    fi

    # gpu-screen-recorder saves replay on SIGUSR1
    kill -USR1 "$PID"

    # Find the most recently created clip
    sleep 1
    local LATEST
    LATEST=$(find "$CLIPS_DIR" -maxdepth 1 -name "*.mp4" -newer "$PID_FILE" -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)

    if [ -n "$LATEST" ]; then
        local SIZE
        SIZE=$(du -h "$LATEST" | cut -f1)
        echo "Clip saved: $LATEST ($SIZE)"
        notify-send -a "24HG" -i "hubos-logo" "Replay Saved!" \
            "$(basename "$LATEST") ($SIZE)" 2>/dev/null || true
    else
        echo "Replay save signal sent"
        notify-send -a "24HG" -i "hubos-logo" "Replay Saved!" \
            "Clip saved to $CLIPS_DIR" 2>/dev/null || true
    fi
}

show_status() {
    echo "=== HubOS Replay Buffer ==="
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "Status: ACTIVE (PID: $(cat "$PID_FILE"))"
    else
        echo "Status: Inactive"
    fi
    echo "Duration: ${REPLAY_DURATION}s"
    echo "Quality: $REPLAY_QUALITY"
    echo "FPS: $REPLAY_FPS"
    echo "Clips directory: $CLIPS_DIR"

    if [ -d "$CLIPS_DIR" ]; then
        local COUNT SIZE
        COUNT=$(find "$CLIPS_DIR" -name "*.mp4" 2>/dev/null | wc -l)
        SIZE=$(du -sh "$CLIPS_DIR" 2>/dev/null | cut -f1)
        echo "Saved clips: $COUNT ($SIZE)"
    fi

    echo ""
    echo "GPU encoder: $(detect_gpu_encoder)"
}

write_config() {
    cat > "$CONFIG_FILE" << EOF
# HubOS Replay Buffer Configuration
REPLAY_DURATION=$REPLAY_DURATION     # Seconds to keep in buffer (default: 120)
REPLAY_QUALITY=$REPLAY_QUALITY       # ultra, very_high, high, medium
REPLAY_FPS=$REPLAY_FPS               # Recording FPS (default: 60)
REPLAY_CODEC=$REPLAY_CODEC           # auto, h264_nvenc, h264_vaapi, hevc_nvenc
EOF
    echo "Config written to $CONFIG_FILE"
}

case "${1:-status}" in
    start)  start_replay ;;
    stop)   stop_replay ;;
    save)   save_replay ;;
    status) show_status ;;
    config) write_config ;;
    *)
        echo "HubOS Replay — Instant replay recording"
        echo "Usage: hubos-replay [start|stop|save|status|config]"
        echo ""
        echo "  start   — Start replay buffer (records last ${REPLAY_DURATION}s)"
        echo "  stop    — Stop replay buffer"
        echo "  save    — Save current replay to ~/Videos/HubOS Clips/"
        echo "  status  — Show current state"
        echo "  config  — Write default config file"
        exit 1
        ;;
esac
