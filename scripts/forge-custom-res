#!/usr/bin/env bash
# forge-custom-res — Custom resolution creator for 24HG Forge Linux
# Create custom resolutions, stretched modes, high refresh rates, and super-resolution modes.
set -euo pipefail

APP_NAME="forge-custom-res"
CONFIG_DIR="${HOME}/.config/forge/custom-res"
MODES_FILE="${CONFIG_DIR}/custom-modes.conf"
GAMES_FILE="${CONFIG_DIR}/game-prefs.conf"
DEFAULTS_FILE="${CONFIG_DIR}/defaults.conf"
REVERT_TIMEOUT=15

# Stretched resolution presets (4:3 on 16:9 panels)
STRETCHED_PRESETS=(
    "1024x768"
    "1280x960"
    "1280x1024"
    "1440x1080"
    "1600x1200"
    "1920x1440"
)

# Super-resolution presets
SUPER_PRESETS_1080=(
    "2560x1440"
    "3200x1800"
    "3840x2160"
)
SUPER_PRESETS_1440=(
    "3840x2160"
    "5120x2880"
)

# High refresh rate options
HIGH_REFRESH_RATES=(144 165 240 360)

# --- Helpers ---

init_config() {
    mkdir -p "$CONFIG_DIR"
    touch "$MODES_FILE" "$GAMES_FILE" "$DEFAULTS_FILE"
}

detect_session() {
    if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]]; then
        echo "wayland"
    elif [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        echo "wayland"
    else
        echo "x11"
    fi
}

require_cmd() {
    local cmd="$1"
    if ! command -v "$cmd" &>/dev/null; then
        echo "Error: '$cmd' is not installed." >&2
        return 1
    fi
}

get_primary_display() {
    local session
    session="$(detect_session)"
    if [[ "$session" == "wayland" ]]; then
        if command -v kscreen-doctor &>/dev/null; then
            kscreen-doctor -o 2>/dev/null | grep -oP 'Output: \d+ \K\S+' | head -1
        else
            echo "unknown"
        fi
    else
        xrandr --query 2>/dev/null | grep ' connected primary' | awk '{print $1}'
    fi
}

get_all_displays() {
    local session
    session="$(detect_session)"
    if [[ "$session" == "wayland" ]]; then
        if command -v kscreen-doctor &>/dev/null; then
            kscreen-doctor -o 2>/dev/null | grep -oP 'Output: \d+ \K\S+' || true
        fi
    else
        xrandr --query 2>/dev/null | grep ' connected' | awk '{print $1}'
    fi
}

parse_resolution() {
    local input="$1"
    local width height hz
    if [[ "$input" =~ ^([0-9]+)x([0-9]+)(@([0-9]+))?$ ]]; then
        width="${BASH_REMATCH[1]}"
        height="${BASH_REMATCH[2]}"
        hz="${BASH_REMATCH[4]:-60}"
        echo "$width $height $hz"
    else
        echo "Error: Invalid resolution format '$input'. Use WxH or WxH@Hz." >&2
        return 1
    fi
}

generate_modeline() {
    local width="$1" height="$2" hz="$3"
    local modeline
    if command -v cvt &>/dev/null; then
        modeline="$(cvt "$width" "$height" "$hz" 2>/dev/null | grep -i modeline | sed 's/^[Mm]odeline //')"
    elif command -v gtf &>/dev/null; then
        modeline="$(gtf "$width" "$height" "$hz" 2>/dev/null | grep -i modeline | sed 's/^[Mm]odeline //')"
    else
        echo "Error: Neither cvt nor gtf found. Cannot generate modeline." >&2
        return 1
    fi
    echo "$modeline"
}

save_custom_mode() {
    local mode_name="$1" width="$2" height="$3" hz="$4"
    if ! grep -qF "$mode_name" "$MODES_FILE" 2>/dev/null; then
        echo "${mode_name}|${width}|${height}|${hz}" >> "$MODES_FILE"
    fi
}

remove_custom_mode() {
    local mode_name="$1"
    if [[ -f "$MODES_FILE" ]]; then
        local tmp
        tmp="$(mktemp)"
        grep -vF "$mode_name" "$MODES_FILE" > "$tmp" || true
        mv "$tmp" "$MODES_FILE"
    fi
}

save_default() {
    local display="$1"
    local session
    session="$(detect_session)"
    if [[ "$session" == "x11" ]]; then
        local current
        current="$(xrandr --query 2>/dev/null | grep -A1 "^${display} " | tail -1 | awk '{print $1}')"
        echo "${display}|${current}" > "$DEFAULTS_FILE"
    fi
}

# --- Commands ---

cmd_list() {
    local session
    session="$(detect_session)"
    echo "=== Display Information ==="
    echo "Session type: $session"
    echo ""

    if [[ "$session" == "wayland" ]]; then
        if command -v kscreen-doctor &>/dev/null; then
            echo "--- Displays (kscreen-doctor) ---"
            kscreen-doctor -o 2>/dev/null || echo "  (kscreen-doctor not available)"
        else
            echo "kscreen-doctor not found. Install kscreen for Wayland support."
        fi
        # Fall back to xrandr under XWayland if available
        if command -v xrandr &>/dev/null; then
            echo ""
            echo "--- XWayland modes (xrandr) ---"
            xrandr --query 2>/dev/null || true
        fi
    else
        require_cmd xrandr
        echo "--- Displays (xrandr) ---"
        xrandr --query 2>/dev/null
    fi

    echo ""
    if [[ -s "$MODES_FILE" ]]; then
        echo "=== Custom Modes (saved) ==="
        while IFS='|' read -r name w h hz; do
            echo "  ${w}x${h}@${hz}Hz  (mode: $name)"
        done < "$MODES_FILE"
    else
        echo "No custom modes saved."
    fi

    if [[ -s "$GAMES_FILE" ]]; then
        echo ""
        echo "=== Per-Game Preferences ==="
        while IFS='|' read -r appid res; do
            echo "  AppID $appid -> $res"
        done < "$GAMES_FILE"
    fi
}

cmd_add() {
    local input="$1"
    local parsed width height hz
    parsed="$(parse_resolution "$input")" || return 1
    read -r width height hz <<< "$parsed"

    local session
    session="$(detect_session)"

    echo "Creating custom resolution: ${width}x${height}@${hz}Hz"

    if [[ "$session" == "wayland" ]]; then
        echo "Note: Custom mode creation on Wayland is limited."
        echo "Wayland compositors typically handle modes differently."
        if command -v kscreen-doctor &>/dev/null; then
            echo "Use 'kscreen-doctor output.<display>.mode.<WxH>@<Hz>' to set modes."
        fi
        # Generate modeline for reference
        local modeline
        modeline="$(generate_modeline "$width" "$height" "$hz")" || return 1
        local mode_name="${width}x${height}_${hz}.00"
        echo "Generated modeline (for reference): $modeline"
        save_custom_mode "$mode_name" "$width" "$height" "$hz"
        echo "Saved to custom modes list."
        return 0
    fi

    require_cmd xrandr

    local modeline mode_name mode_params
    modeline="$(generate_modeline "$width" "$height" "$hz")" || return 1
    mode_name="$(echo "$modeline" | awk '{print $1}' | tr -d '"')"
    mode_params="$(echo "$modeline" | sed 's/^"[^"]*" //' | sed 's/^[^ ]* //')"

    # Check if mode already exists
    if xrandr --query 2>/dev/null | grep -qF "$mode_name"; then
        echo "Mode '$mode_name' already exists."
    else
        echo "Adding new mode: $mode_name"
        xrandr --newmode $modeline 2>/dev/null || {
            echo "Error: Failed to create mode. You may need root privileges." >&2
            return 1
        }
    fi

    # Add mode to all connected displays
    local displays
    displays="$(get_all_displays)"
    for display in $displays; do
        if ! xrandr --query 2>/dev/null | grep -A100 "^${display}" | grep -B100 "^[^ ]" | grep -qF "$mode_name"; then
            xrandr --addmode "$display" "$mode_name" 2>/dev/null && \
                echo "Added '$mode_name' to display '$display'" || \
                echo "Warning: Could not add mode to '$display'"
        fi
    done

    save_custom_mode "$mode_name" "$width" "$height" "$hz"
    echo "Custom resolution ${width}x${height}@${hz}Hz created and saved."
}

cmd_remove() {
    local input="$1"
    local parsed width height hz
    parsed="$(parse_resolution "${input}@60")" || {
        parsed="$(parse_resolution "$input")" || return 1
    }
    read -r width height hz <<< "$parsed"

    local session
    session="$(detect_session)"

    # Find matching mode names
    local pattern="${width}x${height}"
    echo "Removing custom resolution: $pattern"

    if [[ "$session" == "x11" ]] && command -v xrandr &>/dev/null; then
        local displays
        displays="$(get_all_displays)"
        # Remove from all displays
        local modes
        modes="$(xrandr --query 2>/dev/null | grep -oP "${width}x${height}_\S+" | sort -u || true)"
        for mode in $modes; do
            for display in $displays; do
                xrandr --delmode "$display" "$mode" 2>/dev/null || true
            done
            xrandr --rmmode "$mode" 2>/dev/null && echo "Removed mode: $mode" || true
        done
    fi

    # Remove from saved config
    if [[ -f "$MODES_FILE" ]]; then
        local tmp
        tmp="$(mktemp)"
        grep -v "^.*|${width}|${height}|" "$MODES_FILE" > "$tmp" 2>/dev/null || true
        mv "$tmp" "$MODES_FILE"
        echo "Removed from saved modes."
    fi
}

cmd_stretched() {
    echo "=== Stretched Resolution Presets ==="
    echo "Common 4:3 resolutions for competitive gaming on 16:9 panels:"
    echo ""
    local i=1
    for preset in "${STRETCHED_PRESETS[@]}"; do
        echo "  $i) $preset"
        ((i++))
    done
    echo ""
    echo "  a) Add all presets"
    echo "  q) Cancel"
    echo ""
    read -rp "Select preset to add (1-${#STRETCHED_PRESETS[@]}, a, or q): " choice

    case "$choice" in
        q|Q) echo "Cancelled."; return 0 ;;
        a|A)
            for preset in "${STRETCHED_PRESETS[@]}"; do
                cmd_add "$preset" || true
                echo ""
            done
            ;;
        [1-9]*)
            local idx=$((choice - 1))
            if [[ $idx -ge 0 && $idx -lt ${#STRETCHED_PRESETS[@]} ]]; then
                cmd_add "${STRETCHED_PRESETS[$idx]}"
            else
                echo "Invalid selection."
                return 1
            fi
            ;;
        *)
            echo "Invalid selection."
            return 1
            ;;
    esac
}

cmd_super() {
    echo "=== Super-Resolution Modes ==="
    echo "Higher-than-native resolutions for downsampled screenshots/quality."
    echo ""

    local primary
    primary="$(get_primary_display)"
    local native=""
    if [[ -n "$primary" ]] && command -v xrandr &>/dev/null; then
        native="$(xrandr --query 2>/dev/null | grep -A1 "^${primary}" | tail -1 | awk '{print $1}' | cut -d'+' -f1)"
    fi

    local presets=()
    if [[ "$native" == *"1920"* ]]; then
        echo "Detected ~1080p panel. Super-resolution presets:"
        presets=("${SUPER_PRESETS_1080[@]}")
    elif [[ "$native" == *"2560"* ]]; then
        echo "Detected ~1440p panel. Super-resolution presets:"
        presets=("${SUPER_PRESETS_1440[@]}")
    else
        echo "Using 1080p super-resolution presets (default):"
        presets=("${SUPER_PRESETS_1080[@]}")
    fi

    echo ""
    local i=1
    for preset in "${presets[@]}"; do
        echo "  $i) $preset"
        ((i++))
    done
    echo ""
    echo "  a) Add all"
    echo "  q) Cancel"
    echo ""
    read -rp "Select (1-${#presets[@]}, a, or q): " choice

    case "$choice" in
        q|Q) echo "Cancelled."; return 0 ;;
        a|A)
            for preset in "${presets[@]}"; do
                cmd_add "$preset" || true
                echo ""
            done
            ;;
        [1-9]*)
            local idx=$((choice - 1))
            if [[ $idx -ge 0 && $idx -lt ${#presets[@]} ]]; then
                cmd_add "${presets[$idx]}"
            else
                echo "Invalid selection."
                return 1
            fi
            ;;
        *)
            echo "Invalid selection."
            return 1
            ;;
    esac
}

cmd_apply() {
    local input="$1"
    local display="${2:-}"
    local parsed width height hz
    parsed="$(parse_resolution "$input")" || return 1
    read -r width height hz <<< "$parsed"

    local session
    session="$(detect_session)"

    if [[ -z "$display" ]]; then
        display="$(get_primary_display)"
        if [[ -z "$display" || "$display" == "unknown" ]]; then
            echo "Error: Could not detect primary display. Specify it explicitly." >&2
            return 1
        fi
    fi

    echo "Applying ${width}x${height}@${hz}Hz to '$display'..."

    if [[ "$session" == "wayland" ]]; then
        if command -v kscreen-doctor &>/dev/null; then
            # kscreen-doctor uses output index; try matching by name
            local output_id
            output_id="$(kscreen-doctor -o 2>/dev/null | grep "$display" | grep -oP 'Output: \K\d+' | head -1)"
            if [[ -n "$output_id" ]]; then
                kscreen-doctor output."$output_id".mode."${width}x${height}@${hz}" 2>/dev/null && \
                    echo "Applied via kscreen-doctor." || \
                    echo "Error: Failed to apply mode via kscreen-doctor." >&2
            else
                echo "Error: Could not find display '$display' in kscreen-doctor output." >&2
                return 1
            fi
        else
            echo "Error: kscreen-doctor required for Wayland mode changes." >&2
            return 1
        fi
    else
        require_cmd xrandr
        local mode_name="${width}x${height}_${hz}.00"
        # Try exact mode name first, fall back to WxH
        if xrandr --query 2>/dev/null | grep -qF "$mode_name"; then
            xrandr --output "$display" --mode "$mode_name" 2>/dev/null && \
                echo "Applied mode '$mode_name' to '$display'." || {
                echo "Error: Failed to apply mode." >&2
                return 1
            }
        else
            xrandr --output "$display" --mode "${width}x${height}" --rate "$hz" 2>/dev/null && \
                echo "Applied ${width}x${height}@${hz}Hz to '$display'." || {
                echo "Error: Mode not available. Add it first with 'forge-custom-res add ${width}x${height}@${hz}'." >&2
                return 1
            }
        fi
    fi
}

cmd_test() {
    local input="$1"
    local display
    display="$(get_primary_display)"

    if [[ -z "$display" || "$display" == "unknown" ]]; then
        echo "Error: Could not detect primary display." >&2
        return 1
    fi

    # Save current resolution for revert
    local session
    session="$(detect_session)"
    local current_mode=""

    if [[ "$session" == "x11" ]] && command -v xrandr &>/dev/null; then
        current_mode="$(xrandr --query 2>/dev/null | grep -A1 "^${display}" | grep '\*' | awk '{print $1}')"
    fi

    if [[ -z "$current_mode" ]]; then
        echo "Warning: Could not determine current mode for revert."
        read -rp "Continue anyway? (y/N): " confirm
        [[ "$confirm" =~ ^[yY]$ ]] || return 0
    fi

    echo "=== Safe Mode Test ==="
    echo "Applying resolution for ${REVERT_TIMEOUT} seconds..."
    echo "If the screen goes blank, wait for auto-revert."
    echo ""

    cmd_apply "$input" "$display" || return 1

    echo ""
    echo "Resolution applied. Reverting in ${REVERT_TIMEOUT} seconds unless confirmed."
    echo ""

    local confirmed=false
    local remaining=$REVERT_TIMEOUT

    # Background revert timer
    (
        sleep "$REVERT_TIMEOUT"
        # If still running, revert
        if [[ "$session" == "x11" ]] && [[ -n "$current_mode" ]]; then
            xrandr --output "$display" --mode "$current_mode" 2>/dev/null
        fi
    ) &
    local timer_pid=$!

    read -rt "$REVERT_TIMEOUT" -rp "Does this look correct? (y/N, auto-revert in ${REVERT_TIMEOUT}s): " answer && {
        if [[ "$answer" =~ ^[yY]$ ]]; then
            confirmed=true
            kill "$timer_pid" 2>/dev/null || true
            wait "$timer_pid" 2>/dev/null || true
            echo "Resolution confirmed and kept."
        fi
    } || true

    if [[ "$confirmed" == false ]]; then
        kill "$timer_pid" 2>/dev/null || true
        wait "$timer_pid" 2>/dev/null || true
        if [[ "$session" == "x11" ]] && [[ -n "$current_mode" ]]; then
            xrandr --output "$display" --mode "$current_mode" 2>/dev/null
            echo "Reverted to previous resolution: $current_mode"
        else
            echo "Auto-revert: previous mode restored (or attempted)."
        fi
    fi
}

cmd_game() {
    local appid="$1"
    local resolution="$2"

    # Validate resolution format
    parse_resolution "$resolution" >/dev/null || return 1

    echo "Setting resolution preference for AppID $appid: $resolution"

    # Remove existing entry for this appid
    if [[ -f "$GAMES_FILE" ]]; then
        local tmp
        tmp="$(mktemp)"
        grep -v "^${appid}|" "$GAMES_FILE" > "$tmp" 2>/dev/null || true
        mv "$tmp" "$GAMES_FILE"
    fi

    echo "${appid}|${resolution}" >> "$GAMES_FILE"
    echo "Saved. Resolution will be applied when launching AppID $appid via Forge."
    echo ""
    echo "To apply now:  forge-custom-res apply $resolution"
    echo "To add mode:   forge-custom-res add $resolution"
}

cmd_reset() {
    local display
    display="$(get_primary_display)"
    local session
    session="$(detect_session)"

    echo "Resetting to default resolution..."

    if [[ "$session" == "x11" ]] && command -v xrandr &>/dev/null; then
        if [[ -n "$display" && "$display" != "unknown" ]]; then
            xrandr --output "$display" --auto 2>/dev/null && \
                echo "Reset '$display' to auto-detected default." || \
                echo "Error: Failed to reset display." >&2
        else
            xrandr --auto 2>/dev/null && \
                echo "Reset all displays to defaults." || \
                echo "Error: Failed to reset displays." >&2
        fi
    elif [[ "$session" == "wayland" ]]; then
        if command -v kscreen-doctor &>/dev/null; then
            echo "On Wayland, use System Settings > Display to reset resolution."
            echo "Or run: kscreen-doctor output.<id>.mode.auto"
        fi
    fi

    # Clean up custom xrandr modes
    if [[ "$session" == "x11" ]] && [[ -s "$MODES_FILE" ]]; then
        read -rp "Also remove all custom modes? (y/N): " confirm
        if [[ "$confirm" =~ ^[yY]$ ]]; then
            local displays
            displays="$(get_all_displays)"
            while IFS='|' read -r name w h hz; do
                for d in $displays; do
                    xrandr --delmode "$d" "$name" 2>/dev/null || true
                done
                xrandr --rmmode "$name" 2>/dev/null || true
                echo "Removed mode: $name"
            done < "$MODES_FILE"
            : > "$MODES_FILE"
            echo "All custom modes removed."
        fi
    fi
}

cmd_help() {
    cat <<'USAGE'
forge-custom-res — Custom resolution creator for 24HG Forge Linux

Usage:
  forge-custom-res <command> [options]

Commands:
  list                        Show all displays and available modes
  add <WxH[@Hz]>              Add a custom resolution (default 60Hz)
  remove <WxH>                Remove a custom resolution
  stretched                   Show/apply stretched resolution presets
  super                       Add super-resolution modes (DSR)
  apply <WxH[@Hz]> [display]  Apply a resolution to a display
  test <WxH[@Hz]>             Test resolution with 15s auto-revert
  game <appid> <WxH[@Hz]>     Set per-game resolution preference
  reset                       Reset to default resolution

Examples:
  forge-custom-res list
  forge-custom-res add 1440x1080
  forge-custom-res add 1920x1080@144
  forge-custom-res apply 1280x960 HDMI-1
  forge-custom-res test 2560x1440@165
  forge-custom-res game 730 1280x960
  forge-custom-res stretched

Config: ~/.config/forge/custom-res/
USAGE
}

# --- Main ---

main() {
    init_config

    local command="${1:-help}"
    shift || true

    case "$command" in
        list|ls|info)
            cmd_list
            ;;
        add|new|create)
            if [[ $# -lt 1 ]]; then
                echo "Usage: forge-custom-res add <WxH[@Hz]>" >&2
                return 1
            fi
            cmd_add "$1"
            ;;
        remove|rm|del|delete)
            if [[ $# -lt 1 ]]; then
                echo "Usage: forge-custom-res remove <WxH>" >&2
                return 1
            fi
            cmd_remove "$1"
            ;;
        stretched|stretch|43)
            cmd_stretched
            ;;
        super|dsr|superres)
            cmd_super
            ;;
        apply|set|use)
            if [[ $# -lt 1 ]]; then
                echo "Usage: forge-custom-res apply <WxH[@Hz]> [display]" >&2
                return 1
            fi
            cmd_apply "$1" "${2:-}"
            ;;
        test|try|safe)
            if [[ $# -lt 1 ]]; then
                echo "Usage: forge-custom-res test <WxH[@Hz]>" >&2
                return 1
            fi
            cmd_test "$1"
            ;;
        game|appid)
            if [[ $# -lt 2 ]]; then
                echo "Usage: forge-custom-res game <appid> <WxH[@Hz]>" >&2
                return 1
            fi
            cmd_game "$1" "$2"
            ;;
        reset|default|revert)
            cmd_reset
            ;;
        help|-h|--help)
            cmd_help
            ;;
        *)
            echo "Unknown command: $command" >&2
            echo "Run 'forge-custom-res help' for usage." >&2
            return 1
            ;;
    esac
}

main "$@"
