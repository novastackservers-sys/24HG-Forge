#!/bin/bash
set -euo pipefail
# 24HG Game Clip вЂ” Capture, save, and share gameplay clips

# в”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# в”Ђв”Ђ Paths & defaults в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CLIP_DIR="$HOME/Videos/24HG Clips"
CONFIG_DIR="$HOME/.config/24hg"
CONFIG_FILE="$CONFIG_DIR/clip.conf"
HUB_TOKEN_FILE="$CONFIG_DIR/hub-token"
PID_FILE="/tmp/24hg-replay-buffer.pid"
REPLAY_SOCKET="/tmp/24hg-replay-buffer.sock"
REPLAY_FILE="/tmp/24hg-replay-buffer.mp4"
RECORDING_PID_FILE="/tmp/24hg-recording.pid"
RECORDING_FILE=""
LOG_TAG="24hg-clip"
HUB_UPLOAD_URL="https://hub.24hgaming.com/api/clips/upload"

# в”Ђв”Ђ Config defaults в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
REPLAY_DURATION=60
QUALITY="high"
AUDIO="yes"
KEYBIND_HINT="F9"

# в”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
log() { logger -t "$LOG_TAG" "$*"; }

info()    { echo -e "${BLUE}${BOLD}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}${BOLD}[  OK]${RESET}  $*"; }
warn()    { echo -e "${YELLOW}${BOLD}[WARN]${RESET}  $*"; }
error()   { echo -e "${RED}${BOLD}[ ERR]${RESET}  $*" >&2; }

die() {
    error "$*"
    log "ERROR: $*"
    exit 1
}

banner() {
    echo -e "${MAGENTA}${BOLD}"
    echo "  в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—"
    echo "  в•‘       рџЋ®  24HG Game Clip  рџЋ¬        в•‘"
    echo "  в•‘          24 Hour Gaming              в•‘"
    echo "  в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ"
    echo -e "${RESET}"
}

# в”Ђв”Ђ Load config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
        log "Loaded config from $CONFIG_FILE"
    else
        # Create default config
        mkdir -p "$CONFIG_DIR"
        cat > "$CONFIG_FILE" <<'CONF'
# 24HG Clip Configuration
# Replay buffer length in seconds
REPLAY_DURATION=60

# Video quality: high, medium, low
# high   = 20 Mbps (1080p60) / 35 Mbps (1440p60)
# medium = 12 Mbps (1080p60) / 20 Mbps (1440p60)
# low    =  6 Mbps (1080p60) / 10 Mbps (1440p60)
QUALITY=high

# Capture game audio (yes/no)
AUDIO=yes

# Keybind hint (display only вЂ” actual keybind is set in KDE Shortcuts)
KEYBIND_HINT=F9
CONF
        log "Created default config at $CONFIG_FILE"
    fi
}

# в”Ђв”Ђ Quality в†’ bitrate mapping в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
get_bitrate() {
    local res_height
    res_height=$(xdpyinfo 2>/dev/null | awk '/dimensions/{print $2}' | cut -d'x' -f2 || echo "1080")
    [[ -z "$res_height" ]] && res_height=1080

    case "${QUALITY,,}" in
        high)
            if (( res_height > 1080 )); then echo "35000000"; else echo "20000000"; fi
            ;;
        medium)
            if (( res_height > 1080 )); then echo "20000000"; else echo "12000000"; fi
            ;;
        low)
            if (( res_height > 1080 )); then echo "10000000"; else echo "6000000"; fi
            ;;
        *)
            echo "20000000"
            ;;
    esac
}

# в”Ђв”Ђ Detect GPU encoder в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
detect_gpu() {
    if lspci 2>/dev/null | grep -qi "nvidia"; then
        echo "nvidia"
    elif lspci 2>/dev/null | grep -qi "amd.*radeon\|advanced micro"; then
        echo "amd"
    elif lspci 2>/dev/null | grep -qi "intel.*graphics\|intel.*uhd\|intel.*iris"; then
        echo "intel"
    else
        echo "unknown"
    fi
}

# в”Ђв”Ђ Detect display server в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
detect_display() {
    if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        echo "wayland"
    elif [[ -n "${DISPLAY:-}" ]]; then
        echo "x11"
    else
        echo "headless"
    fi
}

# в”Ђв”Ђ Choose recorder backend в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Priority: gpu-screen-recorder > wl-screenrec (wayland) > ffmpeg
choose_recorder() {
    if command -v gpu-screen-recorder &>/dev/null; then
        echo "gpu-screen-recorder"
    elif [[ "$(detect_display)" == "wayland" ]] && command -v wl-screenrec &>/dev/null; then
        echo "wl-screenrec"
    elif command -v ffmpeg &>/dev/null; then
        echo "ffmpeg"
    else
        echo "none"
    fi
}

# в”Ђв”Ђ Build audio flags в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
get_audio_args() {
    local recorder="$1"
    if [[ "${AUDIO,,}" != "yes" ]]; then
        return
    fi

    # Find default audio sink monitor
    local audio_source
    audio_source=$(pactl get-default-sink 2>/dev/null || echo "")
    if [[ -n "$audio_source" ]]; then
        audio_source="${audio_source}.monitor"
    else
        # Fallback: try pipewire
        audio_source=$(pw-cli ls Node 2>/dev/null | grep -m1 'alsa_output' | awk '{print $2}' || echo "")
    fi

    case "$recorder" in
        gpu-screen-recorder)
            [[ -n "$audio_source" ]] && echo "-a $audio_source"
            ;;
        wl-screenrec)
            [[ -n "$audio_source" ]] && echo "--audio --audio-device $audio_source"
            ;;
        ffmpeg)
            [[ -n "$audio_source" ]] && echo "-f pulse -i $audio_source"
            ;;
    esac
}

# в”Ђв”Ђ Ensure clip directory в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ensure_clip_dir() {
    mkdir -p "$CLIP_DIR"
}

# в”Ђв”Ђ Generate clip filename в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
clip_filename() {
    local ts
    ts=$(date +"%Y-%m-%d_%H-%M-%S")
    echo "Clip_${ts}.mp4"
}

# в”Ђв”Ђ Desktop notification в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
notify() {
    local title="$1"
    local body="${2:-}"
    local icon="${3:-24hg-logo}"

    if command -v notify-send &>/dev/null; then
        notify-send -a "24HG Clip" -i "$icon" "$title" "$body" 2>/dev/null || true
    fi
}

# Generate thumbnail for notification
generate_thumbnail() {
    local clip="$1"
    local thumb="/tmp/24hg-clip-thumb.jpg"
    if command -v ffmpeg &>/dev/null; then
        ffmpeg -y -i "$clip" -ss 00:00:01 -vframes 1 -vf "scale=320:-1" "$thumb" 2>/dev/null && echo "$thumb"
    fi
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
#  COMMANDS
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

# в”Ђв”Ђ daemon: Start replay buffer in background в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cmd_daemon() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        warn "Replay buffer already running (PID $(cat "$PID_FILE"))"
        return 0
    fi

    local recorder
    recorder=$(choose_recorder)
    [[ "$recorder" == "none" ]] && die "No screen recorder found. Install gpu-screen-recorder, wl-screenrec, or ffmpeg."

    local gpu display bitrate
    gpu=$(detect_gpu)
    display=$(detect_display)
    bitrate=$(get_bitrate)

    info "Starting replay buffer..."
    echo -e "  ${DIM}Recorder:${RESET}  ${CYAN}$recorder${RESET}"
    echo -e "  ${DIM}GPU:${RESET}       ${CYAN}$gpu${RESET}"
    echo -e "  ${DIM}Display:${RESET}   ${CYAN}$display${RESET}"
    echo -e "  ${DIM}Buffer:${RESET}    ${CYAN}${REPLAY_DURATION}s${RESET}"
    echo -e "  ${DIM}Quality:${RESET}   ${CYAN}$QUALITY${RESET}"
    echo -e "  ${DIM}Audio:${RESET}     ${CYAN}$AUDIO${RESET}"
    echo ""

    local audio_args
    audio_args=$(get_audio_args "$recorder")

    case "$recorder" in
        gpu-screen-recorder)
            local encoder_flag=""
            case "$gpu" in
                nvidia) encoder_flag="-encoder gpu" ;;
                amd)    encoder_flag="-encoder gpu" ;;
                intel)  encoder_flag="-encoder gpu" ;;
                *)      encoder_flag="-encoder cpu" ;;
            esac

            # gpu-screen-recorder supports replay mode natively
            # shellcheck disable=SC2086
            gpu-screen-recorder -w screen \
                $encoder_flag \
                -q "$bitrate" \
                -r "$REPLAY_DURATION" \
                -f 60 \
                $audio_args \
                -o "$REPLAY_FILE" &
            local pid=$!
            echo "$pid" > "$PID_FILE"
            ;;

        wl-screenrec)
            # wl-screenrec doesn't have a replay mode; run continuous and trim on capture
            # shellcheck disable=SC2086
            wl-screenrec \
                --bitrate "$(( bitrate / 1000 ))k" \
                --fps 60 \
                $audio_args \
                -f "$REPLAY_FILE" &
            local pid=$!
            echo "$pid" > "$PID_FILE"
            ;;

        ffmpeg)
            local input_args
            if [[ "$display" == "wayland" ]]; then
                # pipewire screen capture for wayland
                input_args="-f pipewire -i default"
            else
                input_args="-f x11grab -framerate 60 -video_size $(xdpyinfo 2>/dev/null | awk '/dimensions/{print $2}' || echo '1920x1080') -i ${DISPLAY:-:0}"
            fi

            local encoder_args
            case "$gpu" in
                nvidia) encoder_args="-c:v h264_nvenc -preset p4 -b:v $bitrate" ;;
                amd)    encoder_args="-c:v h264_amf -quality balanced -b:v $bitrate" ;;
                intel)  encoder_args="-c:v h264_vaapi -b:v $bitrate" ;;
                *)      encoder_args="-c:v libx264 -preset ultrafast -b:v $bitrate" ;;
            esac

            # Record continuously; we'll trim on capture
            # shellcheck disable=SC2086
            ffmpeg -y $input_args \
                $audio_args \
                $encoder_args \
                -f mp4 \
                "$REPLAY_FILE" </dev/null &>/dev/null &
            local pid=$!
            echo "$pid" > "$PID_FILE"
            ;;
    esac

    disown "$pid" 2>/dev/null || true
    log "Replay buffer started: recorder=$recorder gpu=$gpu pid=$pid buffer=${REPLAY_DURATION}s"
    success "Replay buffer active (PID $pid)"
    echo -e "  ${DIM}Hint: Press ${BOLD}${KEYBIND_HINT}${RESET}${DIM} to save a clip (configure in KDE Shortcuts)${RESET}"

    notify "Replay Buffer Active" "Recording last ${REPLAY_DURATION}s вЂ” Press $KEYBIND_HINT to clip"
}

# в”Ђв”Ђ capture: Save last N seconds from replay buffer в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cmd_capture() {
    local duration="${1:-30}"
    ensure_clip_dir

    local recorder
    recorder=$(choose_recorder)
    local filename
    filename=$(clip_filename)
    local output="$CLIP_DIR/$filename"

    # Check if replay buffer is running
    if [[ ! -f "$PID_FILE" ]] || ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        warn "Replay buffer not running. Starting it first..."
        cmd_daemon
        die "Replay buffer just started. Wait a few seconds then try capture again."
    fi

    info "Capturing last ${CYAN}${duration}s${RESET} of gameplay..."

    case "$recorder" in
        gpu-screen-recorder)
            # gpu-screen-recorder: send SIGUSR1 to save replay
            local pid
            pid=$(cat "$PID_FILE")
            kill -SIGUSR1 "$pid" 2>/dev/null || die "Failed to signal replay buffer"
            # Wait briefly for file to be written
            sleep 2

            if [[ -f "$REPLAY_FILE" ]]; then
                cp "$REPLAY_FILE" "$output"
            else
                die "Replay file not found after signal"
            fi
            ;;

        wl-screenrec|ffmpeg)
            # For continuous recorders, trim last N seconds from the replay file
            if [[ ! -f "$REPLAY_FILE" ]]; then
                die "Replay file not found. Is the buffer running?"
            fi

            # Get file duration and trim
            local file_duration
            file_duration=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$REPLAY_FILE" 2>/dev/null || echo "0")

            if command -v ffmpeg &>/dev/null; then
                local start_time
                start_time=$(echo "$file_duration - $duration" | bc 2>/dev/null || echo "0")
                if (( $(echo "$start_time < 0" | bc 2>/dev/null || echo "1") )); then
                    start_time="0"
                fi

                ffmpeg -y -sseof "-${duration}" -i "$REPLAY_FILE" \
                    -c copy -avoid_negative_ts make_zero \
                    "$output" 2>/dev/null || die "Failed to trim clip"
            else
                cp "$REPLAY_FILE" "$output"
            fi
            ;;

        none)
            die "No screen recorder available"
            ;;
    esac

    if [[ -f "$output" ]]; then
        local size
        size=$(du -h "$output" | cut -f1)
        log "Clip captured: $output ($size, ${duration}s)"

        success "Clip saved!"
        echo -e "  ${DIM}File:${RESET}     ${CYAN}$output${RESET}"
        echo -e "  ${DIM}Size:${RESET}     ${CYAN}$size${RESET}"
        echo -e "  ${DIM}Duration:${RESET} ${CYAN}${duration}s${RESET}"
        echo ""

        # Notification with thumbnail
        local thumb
        thumb=$(generate_thumbnail "$output" || echo "")
        local icon="${thumb:-24hg-logo}"
        notify "Clip Saved!" "$filename ($size)" "$icon"
    else
        die "Clip capture failed вЂ” output file not created"
    fi
}

# в”Ђв”Ђ start: Begin unlimited recording в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cmd_start() {
    if [[ -f "$RECORDING_PID_FILE" ]] && kill -0 "$(cat "$RECORDING_PID_FILE")" 2>/dev/null; then
        warn "Already recording (PID $(cat "$RECORDING_PID_FILE"))"
        return 0
    fi

    ensure_clip_dir
    local recorder
    recorder=$(choose_recorder)
    [[ "$recorder" == "none" ]] && die "No screen recorder found."

    local filename
    filename=$(clip_filename)
    RECORDING_FILE="$CLIP_DIR/$filename"

    local gpu display bitrate audio_args
    gpu=$(detect_gpu)
    display=$(detect_display)
    bitrate=$(get_bitrate)
    audio_args=$(get_audio_args "$recorder")

    info "Starting recording..."

    case "$recorder" in
        gpu-screen-recorder)
            local encoder_flag=""
            case "$gpu" in
                nvidia|amd|intel) encoder_flag="-encoder gpu" ;;
                *)                encoder_flag="-encoder cpu" ;;
            esac

            # shellcheck disable=SC2086
            gpu-screen-recorder -w screen \
                $encoder_flag \
                -q "$bitrate" \
                -f 60 \
                $audio_args \
                -o "$RECORDING_FILE" &
            ;;

        wl-screenrec)
            # shellcheck disable=SC2086
            wl-screenrec \
                --bitrate "$(( bitrate / 1000 ))k" \
                --fps 60 \
                $audio_args \
                -f "$RECORDING_FILE" &
            ;;

        ffmpeg)
            local input_args
            if [[ "$display" == "wayland" ]]; then
                input_args="-f pipewire -i default"
            else
                input_args="-f x11grab -framerate 60 -video_size $(xdpyinfo 2>/dev/null | awk '/dimensions/{print $2}' || echo '1920x1080') -i ${DISPLAY:-:0}"
            fi

            local encoder_args
            case "$gpu" in
                nvidia) encoder_args="-c:v h264_nvenc -preset p4 -b:v $bitrate" ;;
                amd)    encoder_args="-c:v h264_amf -quality balanced -b:v $bitrate" ;;
                intel)  encoder_args="-c:v h264_vaapi -b:v $bitrate" ;;
                *)      encoder_args="-c:v libx264 -preset ultrafast -b:v $bitrate" ;;
            esac

            # shellcheck disable=SC2086
            ffmpeg -y $input_args \
                $audio_args \
                $encoder_args \
                "$RECORDING_FILE" </dev/null &>/dev/null &
            ;;
    esac

    local pid=$!
    echo "$pid" > "$RECORDING_PID_FILE"
    # Store the filename so stop can find it
    echo "$RECORDING_FILE" > "/tmp/24hg-recording-file.txt"
    disown "$pid" 2>/dev/null || true

    log "Recording started: $RECORDING_FILE (PID $pid)"
    success "Recording started (PID $pid)"
    echo -e "  ${DIM}Output:${RESET} ${CYAN}$RECORDING_FILE${RESET}"
    echo -e "  ${DIM}Run ${BOLD}24hg-clip stop${RESET}${DIM} to finish${RESET}"

    notify "Recording Started" "Saving to $filename"
}

# в”Ђв”Ђ stop: Stop unlimited recording в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cmd_stop() {
    if [[ ! -f "$RECORDING_PID_FILE" ]]; then
        die "No active recording found"
    fi

    local pid
    pid=$(cat "$RECORDING_PID_FILE")

    if ! kill -0 "$pid" 2>/dev/null; then
        rm -f "$RECORDING_PID_FILE" "/tmp/24hg-recording-file.txt"
        die "Recording process ($pid) is no longer running"
    fi

    # Graceful stop
    kill -SIGINT "$pid" 2>/dev/null || kill -SIGTERM "$pid" 2>/dev/null || true
    sleep 1

    # Force kill if still alive
    if kill -0 "$pid" 2>/dev/null; then
        kill -SIGKILL "$pid" 2>/dev/null || true
    fi

    rm -f "$RECORDING_PID_FILE"

    local rec_file=""
    if [[ -f "/tmp/24hg-recording-file.txt" ]]; then
        rec_file=$(cat "/tmp/24hg-recording-file.txt")
        rm -f "/tmp/24hg-recording-file.txt"
    fi

    if [[ -n "$rec_file" && -f "$rec_file" ]]; then
        local size
        size=$(du -h "$rec_file" | cut -f1)
        log "Recording stopped: $rec_file ($size)"
        success "Recording saved!"
        echo -e "  ${DIM}File:${RESET} ${CYAN}$rec_file${RESET}"
        echo -e "  ${DIM}Size:${RESET} ${CYAN}$size${RESET}"

        local thumb
        thumb=$(generate_thumbnail "$rec_file" || echo "")
        notify "Recording Saved" "$(basename "$rec_file") ($size)" "${thumb:-24hg-logo}"
    else
        warn "Recording stopped but output file not found"
        log "Recording stopped, output file missing"
    fi
}

# в”Ђв”Ђ share: Upload clip to Hub в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cmd_share() {
    local clip_file="${1:-}"

    # If no file specified, use the most recent clip
    if [[ -z "$clip_file" ]]; then
        ensure_clip_dir
        clip_file=$(ls -t "$CLIP_DIR"/*.mp4 2>/dev/null | head -1 || true)
        [[ -z "$clip_file" ]] && die "No clips found. Capture one first!"
    fi

    [[ -f "$clip_file" ]] || die "File not found: $clip_file"

    # Check for auth token
    if [[ ! -f "$HUB_TOKEN_FILE" ]]; then
        die "Hub token not found at $HUB_TOKEN_FILE\n  Run ${BOLD}24hg hub login${RESET} to authenticate."
    fi

    local token
    token=$(cat "$HUB_TOKEN_FILE")
    local filename
    filename=$(basename "$clip_file")
    local size
    size=$(du -h "$clip_file" | cut -f1)

    info "Uploading ${CYAN}$filename${RESET} (${size}) to 24HG Hub..."

    local response http_code
    response=$(curl -s -w "\n%{http_code}" \
        -X POST "$HUB_UPLOAD_URL" \
        -H "Authorization: Bearer $token" \
        -F "clip=@$clip_file" \
        -F "filename=$filename" \
        2>/dev/null) || die "Upload failed вЂ” network error"

    http_code=$(echo "$response" | tail -1)
    local body
    body=$(echo "$response" | head -n -1)

    if [[ "$http_code" == "200" || "$http_code" == "201" ]]; then
        local share_url
        share_url=$(echo "$body" | jq -r '.url // .share_url // .link // empty' 2>/dev/null || echo "")

        if [[ -z "$share_url" ]]; then
            share_url=$(echo "$body" | grep -oP 'https?://[^\s"]+' | head -1 || echo "$HUB_UPLOAD_URL")
        fi

        log "Clip shared: $filename -> $share_url"
        success "Clip uploaded!"
        echo -e "  ${DIM}Link:${RESET} ${CYAN}${BOLD}$share_url${RESET}"
        echo ""

        # Copy to clipboard if possible
        if command -v wl-copy &>/dev/null; then
            echo -n "$share_url" | wl-copy 2>/dev/null && echo -e "  ${DIM}(Link copied to clipboard)${RESET}"
        elif command -v xclip &>/dev/null; then
            echo -n "$share_url" | xclip -selection clipboard 2>/dev/null && echo -e "  ${DIM}(Link copied to clipboard)${RESET}"
        fi

        notify "Clip Shared!" "$share_url"
    else
        log "Upload failed: HTTP $http_code"
        die "Upload failed (HTTP $http_code): $body"
    fi
}

# в”Ђв”Ђ list: Show saved clips в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cmd_list() {
    ensure_clip_dir

    local clips
    clips=$(ls -lt "$CLIP_DIR"/*.mp4 2>/dev/null || true)

    if [[ -z "$clips" ]]; then
        info "No saved clips yet."
        echo -e "  ${DIM}Run ${BOLD}24hg-clip capture${RESET}${DIM} or ${BOLD}24hg-clip start${RESET}${DIM} to create one.${RESET}"
        return 0
    fi

    local count
    count=$(ls "$CLIP_DIR"/*.mp4 2>/dev/null | wc -l)
    local total_size
    total_size=$(du -sh "$CLIP_DIR" 2>/dev/null | cut -f1)

    echo -e "${BOLD}${MAGENTA}  Saved Clips${RESET} ${DIM}($count clips, $total_size total)${RESET}"
    echo -e "  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
    echo ""

    local i=1
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        local name size mod_date duration_str
        name=$(basename "$file")
        size=$(du -h "$file" | cut -f1)
        mod_date=$(date -r "$file" "+%Y-%m-%d %H:%M" 2>/dev/null || echo "unknown")

        # Try to get duration
        duration_str=""
        if command -v ffprobe &>/dev/null; then
            local dur
            dur=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$file" 2>/dev/null || echo "")
            if [[ -n "$dur" ]]; then
                local secs
                secs=$(printf "%.0f" "$dur" 2>/dev/null || echo "0")
                duration_str="${secs}s"
            fi
        fi

        printf "  ${CYAN}%2d.${RESET} %-40s ${DIM}%6s  %s  %s${RESET}\n" \
            "$i" "$name" "$size" "$mod_date" "$duration_str"
        (( i++ ))
    done < <(ls -t "$CLIP_DIR"/*.mp4 2>/dev/null)

    echo ""
    echo -e "  ${DIM}Clip directory: $CLIP_DIR${RESET}"
}

# в”Ђв”Ђ status: Show replay buffer status в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cmd_status() {
    banner

    local recorder
    recorder=$(choose_recorder)
    local gpu
    gpu=$(detect_gpu)
    local display
    display=$(detect_display)

    echo -e "  ${BOLD}System${RESET}"
    echo -e "  ${DIM}GPU:${RESET}       ${CYAN}$gpu${RESET}"
    echo -e "  ${DIM}Display:${RESET}   ${CYAN}$display${RESET}"
    echo -e "  ${DIM}Recorder:${RESET}  ${CYAN}$recorder${RESET}"
    echo ""

    echo -e "  ${BOLD}Configuration${RESET}"
    echo -e "  ${DIM}Buffer:${RESET}    ${CYAN}${REPLAY_DURATION}s${RESET}"
    echo -e "  ${DIM}Quality:${RESET}   ${CYAN}$QUALITY${RESET}"
    echo -e "  ${DIM}Audio:${RESET}     ${CYAN}$AUDIO${RESET}"
    echo -e "  ${DIM}Keybind:${RESET}   ${CYAN}$KEYBIND_HINT${RESET}"
    echo ""

    echo -e "  ${BOLD}Replay Buffer${RESET}"
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        local pid
        pid=$(cat "$PID_FILE")
        local uptime_str
        uptime_str=$(ps -o etime= -p "$pid" 2>/dev/null | xargs || echo "unknown")
        echo -e "  ${DIM}Status:${RESET}    ${GREEN}${BOLD}ACTIVE${RESET}"
        echo -e "  ${DIM}PID:${RESET}       ${CYAN}$pid${RESET}"
        echo -e "  ${DIM}Uptime:${RESET}    ${CYAN}$uptime_str${RESET}"
    else
        echo -e "  ${DIM}Status:${RESET}    ${RED}${BOLD}INACTIVE${RESET}"
        echo -e "  ${DIM}Start with:${RESET} ${BOLD}24hg-clip --daemon${RESET}"
    fi
    echo ""

    echo -e "  ${BOLD}Recording${RESET}"
    if [[ -f "$RECORDING_PID_FILE" ]] && kill -0 "$(cat "$RECORDING_PID_FILE")" 2>/dev/null; then
        local rec_pid
        rec_pid=$(cat "$RECORDING_PID_FILE")
        local rec_file=""
        [[ -f "/tmp/24hg-recording-file.txt" ]] && rec_file=$(cat "/tmp/24hg-recording-file.txt")
        echo -e "  ${DIM}Status:${RESET}    ${RED}${BOLD}RECORDING${RESET}"
        echo -e "  ${DIM}PID:${RESET}       ${CYAN}$rec_pid${RESET}"
        [[ -n "$rec_file" ]] && echo -e "  ${DIM}File:${RESET}     ${CYAN}$rec_file${RESET}"
    else
        echo -e "  ${DIM}Status:${RESET}    ${DIM}Not recording${RESET}"
    fi
    echo ""

    # Clip count
    ensure_clip_dir
    local count=0
    count=$(ls "$CLIP_DIR"/*.mp4 2>/dev/null | wc -l || echo "0")
    echo -e "  ${BOLD}Clips${RESET}"
    echo -e "  ${DIM}Saved:${RESET}     ${CYAN}$count clips${RESET}"
    echo -e "  ${DIM}Location:${RESET}  ${CYAN}$CLIP_DIR${RESET}"
    echo ""
}

# в”Ђв”Ђ usage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
usage() {
    banner
    echo -e "  ${BOLD}Usage:${RESET} 24hg-clip <command> [args]"
    echo ""
    echo -e "  ${BOLD}Commands:${RESET}"
    echo -e "    ${CYAN}capture${RESET} [duration]   Save last N seconds (default: 30)"
    echo -e "    ${CYAN}start${RESET}                Start unlimited recording"
    echo -e "    ${CYAN}stop${RESET}                 Stop recording"
    echo -e "    ${CYAN}share${RESET} [file]          Upload clip to 24HG Hub"
    echo -e "    ${CYAN}list${RESET}                 List saved clips"
    echo -e "    ${CYAN}status${RESET}               Show replay buffer status"
    echo ""
    echo -e "  ${BOLD}Flags:${RESET}"
    echo -e "    ${CYAN}--daemon${RESET}             Start replay buffer in background"
    echo ""
    echo -e "  ${BOLD}Examples:${RESET}"
    echo -e "    ${DIM}24hg-clip --daemon${RESET}          # Start replay buffer"
    echo -e "    ${DIM}24hg-clip capture${RESET}           # Save last 30 seconds"
    echo -e "    ${DIM}24hg-clip capture 60${RESET}        # Save last 60 seconds"
    echo -e "    ${DIM}24hg-clip start${RESET}             # Start recording"
    echo -e "    ${DIM}24hg-clip stop${RESET}              # Stop and save"
    echo -e "    ${DIM}24hg-clip share${RESET}             # Upload latest clip"
    echo ""
    echo -e "  ${DIM}Config: $CONFIG_FILE${RESET}"
    echo -e "  ${DIM}Clips:  $CLIP_DIR${RESET}"
    echo ""
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
#  MAIN
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

load_config

# Handle --daemon flag anywhere in args
for arg in "$@"; do
    if [[ "$arg" == "--daemon" ]]; then
        cmd_daemon
        exit 0
    fi
done

cmd="${1:-}"
shift || true

case "$cmd" in
    capture)  cmd_capture "$@" ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    share)    cmd_share "$@" ;;
    list)     cmd_list ;;
    status)   cmd_status ;;
    help|-h|--help)
              usage ;;
    "")       usage ;;
    *)        error "Unknown command: $cmd"
              echo ""
              usage
              exit 1 ;;
esac
