#!/bin/bash
set -euo pipefail
# 24HG Forge Rescue — Fix common gaming issues and recover your system

# ── Colors & Symbols ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
CHECK="${GREEN}[✓]${RESET}"
CROSS="${RED}[✗]${RESET}"
WARN="${YELLOW}[!]${RESET}"
INFO="${BLUE}[i]${RESET}"
ARROW="${CYAN}→${RESET}"

# ── Globals ───────────────────────────────────────────────────────────────────
AUTO_FIX=false
ISSUES_FOUND=0
ISSUES_FIXED=0
NEEDS_REBOOT=0
WARNINGS=0
LOG_TAG="forge-rescue"

# ── Helpers ───────────────────────────────────────────────────────────────────
log() { logger -t "$LOG_TAG" "$*"; }

header() {
    echo ""
    echo -e "${BOLD}${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BOLD}${MAGENTA}  $1${RESET}"
    echo -e "${BOLD}${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""
}

section() {
    echo ""
    echo -e "${BOLD}${CYAN}── $1 ──${RESET}"
}

ok()   { echo -e "  ${CHECK} $1"; }
fail() { echo -e "  ${CROSS} $1"; ISSUES_FOUND=$((ISSUES_FOUND + 1)); }
warn() { echo -e "  ${WARN} $1"; WARNINGS=$((WARNINGS + 1)); }
info() { echo -e "  ${INFO} $1"; }

progress() {
    echo -ne "  ${DIM}$1...${RESET} "
}

progress_done() {
    echo -e "${GREEN}done${RESET}"
}

progress_fail() {
    echo -e "${RED}failed${RESET}"
}

confirm() {
    local msg="$1"
    if $AUTO_FIX; then
        echo -e "  ${ARROW} ${msg} ${DIM}(auto-confirmed)${RESET}"
        return 0
    fi
    echo -ne "  ${ARROW} ${msg} ${BOLD}[y/N]${RESET} "
    read -r reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

needs_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}This operation requires root. Re-running with sudo...${RESET}"
        exec sudo "$0" "$@"
    fi
}

banner() {
    echo -e "${BOLD}${MAGENTA}"
    echo "  ╔═══════════════════════════════════════════╗"
    echo "  ║        24HG Forge Rescue Toolkit          ║"
    echo "  ║   Fix gaming issues & recover your system ║"
    echo "  ╚═══════════════════════════════════════════╝"
    echo -e "${RESET}"
}

# ── Health Check Functions ────────────────────────────────────────────────────

check_gpu_driver() {
    section "GPU Driver"
    local gpu_info
    gpu_info=$(lspci 2>/dev/null | grep -i 'vga\|3d\|display' || true)

    if echo "$gpu_info" | grep -qi nvidia; then
        info "NVIDIA GPU detected"
        if command -v nvidia-smi &>/dev/null; then
            if nvidia-smi &>/dev/null; then
                local driver_ver
                driver_ver=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1)
                ok "NVIDIA driver loaded (v${driver_ver:-unknown})"
            else
                fail "NVIDIA driver installed but not working"
            fi
        else
            fail "NVIDIA GPU found but driver not installed"
        fi
    elif echo "$gpu_info" | grep -qi amd; then
        info "AMD GPU detected"
        if lspci -k 2>/dev/null | grep -A2 -i vga | grep -qi amdgpu; then
            ok "AMDGPU driver loaded"
        else
            fail "AMD GPU found but amdgpu driver not loaded"
        fi
    elif echo "$gpu_info" | grep -qi intel; then
        info "Intel GPU detected"
        if lspci -k 2>/dev/null | grep -A2 -i vga | grep -qi i915; then
            ok "Intel i915 driver loaded"
        else
            warn "Intel GPU detected but i915 not confirmed"
        fi
    else
        warn "Could not identify GPU vendor"
    fi
}

check_vulkan() {
    section "Vulkan"
    if command -v vulkaninfo &>/dev/null; then
        if vulkaninfo --summary &>/dev/null 2>&1; then
            local vk_gpu
            vk_gpu=$(vulkaninfo --summary 2>/dev/null | grep -i "GPU name" | head -1 | sed 's/.*= *//' || echo "unknown")
            ok "Vulkan working: ${vk_gpu}"
        else
            fail "Vulkan installed but not functional"
        fi
    else
        fail "vulkaninfo not found — Vulkan SDK may be missing"
    fi
}

check_opengl() {
    section "OpenGL"
    if command -v glxinfo &>/dev/null; then
        local renderer
        renderer=$(glxinfo 2>/dev/null | grep "OpenGL renderer" | sed 's/.*: //' || true)
        if [[ -n "$renderer" ]]; then
            ok "OpenGL renderer: ${renderer}"
        else
            fail "OpenGL not rendering (no display or driver issue)"
        fi
    else
        warn "glxinfo not available — install mesa-demos"
    fi
}

check_audio() {
    section "Audio"
    if command -v pactl &>/dev/null; then
        if pactl info &>/dev/null 2>&1; then
            local server
            server=$(pactl info 2>/dev/null | grep "Server Name" | sed 's/.*: //' || echo "unknown")
            ok "Audio server running: ${server}"
            local sink
            sink=$(pactl get-default-sink 2>/dev/null || echo "")
            if [[ -n "$sink" ]]; then
                ok "Default audio output: ${sink}"
            else
                warn "No default audio sink configured"
            fi
        else
            fail "PulseAudio/PipeWire not responding"
        fi
    else
        fail "pactl not found — audio stack may be broken"
    fi

    if systemctl --user is-active pipewire &>/dev/null 2>&1; then
        ok "PipeWire service active"
    else
        warn "PipeWire service not running"
    fi

    if systemctl --user is-active wireplumber &>/dev/null 2>&1; then
        ok "WirePlumber session manager active"
    else
        warn "WirePlumber not running"
    fi
}

check_network() {
    section "Network"
    if ping -c1 -W3 hub.24hgaming.com &>/dev/null 2>&1; then
        ok "Network connectivity: hub.24hgaming.com reachable"
    else
        if ping -c1 -W3 1.1.1.1 &>/dev/null 2>&1; then
            warn "Internet works but hub.24hgaming.com unreachable"
        else
            fail "No network connectivity"
        fi
    fi

    if command -v dig &>/dev/null; then
        if dig +short hub.24hgaming.com &>/dev/null 2>&1; then
            local ip
            ip=$(dig +short hub.24hgaming.com 2>/dev/null | head -1)
            if [[ -n "$ip" ]]; then
                ok "DNS resolution working (hub.24hgaming.com -> ${ip})"
            else
                warn "DNS query returned empty result"
            fi
        else
            fail "DNS resolution failed"
        fi
    elif command -v nslookup &>/dev/null; then
        if nslookup hub.24hgaming.com &>/dev/null 2>&1; then
            ok "DNS resolution working"
        else
            fail "DNS resolution failed"
        fi
    else
        warn "No DNS tools available (dig/nslookup)"
    fi
}

check_steam() {
    section "Steam"
    if command -v steam &>/dev/null || flatpak list 2>/dev/null | grep -qi steam; then
        ok "Steam installed"
        if pgrep -x steam &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
            ok "Steam is running"
        else
            info "Steam is not currently running"
        fi
    else
        fail "Steam not found (native or Flatpak)"
    fi
}

check_flatpak() {
    section "Flatpak"
    if command -v flatpak &>/dev/null; then
        ok "Flatpak available"
        local count
        count=$(flatpak list 2>/dev/null | wc -l || echo "0")
        info "${count} Flatpak apps installed"
        if flatpak repair --user --dry-run &>/dev/null 2>&1; then
            ok "Flatpak user installation healthy"
        else
            warn "Flatpak user installation may need repair"
        fi
    else
        warn "Flatpak not available"
    fi
}

check_disk_space() {
    section "Disk Space"
    local avail_kb
    avail_kb=$(df --output=avail / 2>/dev/null | tail -1 | tr -d ' ')
    if [[ -n "$avail_kb" ]]; then
        local avail_gb=$((avail_kb / 1048576))
        if [[ $avail_gb -lt 5 ]]; then
            fail "Root filesystem critically low: ${avail_gb}GB free"
        elif [[ $avail_gb -lt 10 ]]; then
            warn "Root filesystem low: ${avail_gb}GB free (recommend >10GB)"
        else
            ok "Root filesystem: ${avail_gb}GB free"
        fi
    fi

    # Check /home separately if different mount
    local home_avail_kb
    home_avail_kb=$(df --output=avail "$HOME" 2>/dev/null | tail -1 | tr -d ' ')
    if [[ -n "$home_avail_kb" && "$home_avail_kb" != "$avail_kb" ]]; then
        local home_gb=$((home_avail_kb / 1048576))
        if [[ $home_gb -lt 10 ]]; then
            warn "Home partition low: ${home_gb}GB free"
        else
            ok "Home partition: ${home_gb}GB free"
        fi
    fi
}

check_swap() {
    section "Swap"
    local swap_total
    swap_total=$(grep -i swaptotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo "0")
    if [[ "$swap_total" -gt 0 ]]; then
        local swap_gb=$((swap_total / 1048576))
        ok "Swap configured: ${swap_gb}GB"
        if [[ -f /sys/fs/cgroup/memory.swap.max ]] || swapon --show 2>/dev/null | grep -q zram; then
            ok "ZRAM swap detected"
        fi
    else
        warn "No swap configured — may cause issues with low memory"
    fi
}

check_gamemode() {
    section "GameMode"
    if command -v gamemoded &>/dev/null; then
        ok "GameMode available"
        if command -v gamemoderun &>/dev/null; then
            ok "gamemoderun launcher available"
        fi
    else
        warn "GameMode not installed — performance optimizations unavailable"
    fi
}

check_mangohud() {
    section "MangoHud"
    if command -v mangohud &>/dev/null; then
        ok "MangoHud available"
        if [[ -f "$HOME/.config/MangoHud/MangoHud.conf" ]]; then
            ok "MangoHud config found"
        else
            info "No MangoHud config — using defaults"
        fi
    else
        warn "MangoHud not installed"
    fi
}

check_proton() {
    section "Proton Versions"
    local steam_dir="$HOME/.steam/steam"
    [[ -d "$steam_dir" ]] || steam_dir="$HOME/.local/share/Steam"
    local compat_dir="$steam_dir/compatibilitytools.d"
    local proton_dir="$steam_dir/steamapps/common"

    local count=0
    if [[ -d "$proton_dir" ]]; then
        count=$(find "$proton_dir" -maxdepth 1 -name "Proton*" -type d 2>/dev/null | wc -l || echo "0")
    fi
    local custom=0
    if [[ -d "$compat_dir" ]]; then
        custom=$(find "$compat_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l || echo "0")
    fi

    if [[ $((count + custom)) -gt 0 ]]; then
        ok "${count} official Proton version(s), ${custom} custom (GE/TKG)"
    else
        warn "No Proton versions found"
    fi
}

check_system_updates() {
    section "System Updates"
    if command -v rpm-ostree &>/dev/null; then
        local status
        status=$(rpm-ostree status 2>/dev/null || true)
        if echo "$status" | grep -q "●"; then
            local current
            current=$(echo "$status" | grep "●" | head -1 | xargs)
            ok "Current deployment: ${current:0:70}"
        fi
        local pending
        pending=$(echo "$status" | grep -c "^  " || echo "0")
        if [[ "$pending" -gt 2 ]]; then
            info "Pending updates available"
        else
            ok "System up to date"
        fi
    else
        info "Not an rpm-ostree system — skipping update check"
    fi
}

# ── Full Scan ─────────────────────────────────────────────────────────────────

cmd_scan() {
    banner
    header "System Health Scan"
    log "Starting health scan"

    check_gpu_driver
    check_vulkan
    check_opengl
    check_audio
    check_network
    check_steam
    check_flatpak
    check_disk_space
    check_swap
    check_gamemode
    check_mangohud
    check_proton
    check_system_updates

    echo ""
    echo -e "${BOLD}${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BOLD}  Scan Results${RESET}"
    echo -e "${BOLD}${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    if [[ $ISSUES_FOUND -eq 0 && $WARNINGS -eq 0 ]]; then
        echo -e "  ${CHECK} ${GREEN}All checks passed — system is healthy!${RESET}"
    else
        [[ $ISSUES_FOUND -gt 0 ]] && echo -e "  ${CROSS} ${RED}${ISSUES_FOUND} issue(s) detected${RESET}"
        [[ $WARNINGS -gt 0 ]]     && echo -e "  ${WARN} ${YELLOW}${WARNINGS} warning(s)${RESET}"
        echo ""
        echo -e "  Run ${BOLD}forge-rescue fix${RESET} to resolve issues interactively"
        echo -e "  Run ${BOLD}forge-rescue fix --auto${RESET} to auto-fix safe issues"
    fi
    echo ""
    log "Scan complete: ${ISSUES_FOUND} issues, ${WARNINGS} warnings"
}

# ── Fix: GPU ──────────────────────────────────────────────────────────────────

cmd_gpu() {
    banner
    header "GPU Driver Fix"
    log "Starting GPU fix"

    local gpu_info
    gpu_info=$(lspci 2>/dev/null | grep -i 'vga\|3d\|display' || true)

    if echo "$gpu_info" | grep -qi nvidia; then
        fix_gpu_nvidia
    elif echo "$gpu_info" | grep -qi amd; then
        fix_gpu_amd
    else
        info "No NVIDIA or AMD GPU detected — nothing to fix"
        info "GPU info: ${gpu_info:-none}"
    fi
    print_summary
}

fix_gpu_nvidia() {
    section "NVIDIA GPU Diagnostics"

    # Check driver
    if ! command -v nvidia-smi &>/dev/null || ! nvidia-smi &>/dev/null; then
        fail "NVIDIA driver not working"
        info "Problem: The NVIDIA proprietary driver is not loaded or not installed."
        info "Fix: Will install akmod-nvidia via rpm-ostree and rebuild initramfs."

        if confirm "Install/reinstall NVIDIA driver via rpm-ostree?"; then
            progress "Installing akmod-nvidia"
            if rpm-ostree install akmod-nvidia xorg-x11-drv-nvidia-cuda &>/dev/null 2>&1; then
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                NEEDS_REBOOT=$((NEEDS_REBOOT + 1))
                warn "Reboot required for driver to load"
            else
                progress_fail
                warn "rpm-ostree install failed — may already be layered or conflict exists"
            fi
            log "Attempted NVIDIA driver install"
        fi
    else
        ok "NVIDIA driver is loaded"
    fi

    # Check nouveau blacklist
    if lsmod 2>/dev/null | grep -q nouveau; then
        fail "nouveau driver is loaded (conflicts with NVIDIA)"
        info "Fix: Blacklist nouveau in kernel arguments."
        if confirm "Add nouveau.modeset=0 to kernel args?"; then
            progress "Blacklisting nouveau"
            if rpm-ostree kargs --append=nouveau.modeset=0 &>/dev/null 2>&1; then
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                NEEDS_REBOOT=$((NEEDS_REBOOT + 1))
            else
                progress_fail
            fi
            log "Blacklisted nouveau"
        fi
    else
        ok "nouveau is not loaded"
    fi

    # Check nvidia-drm.modeset
    if ! grep -q "nvidia-drm.modeset=1" /proc/cmdline 2>/dev/null; then
        warn "nvidia-drm.modeset=1 not in kernel cmdline"
        info "Fix: This is needed for Wayland and proper DRM support."
        if confirm "Add nvidia-drm.modeset=1 to kernel args?"; then
            progress "Setting nvidia-drm.modeset=1"
            if rpm-ostree kargs --append=nvidia-drm.modeset=1 &>/dev/null 2>&1; then
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                NEEDS_REBOOT=$((NEEDS_REBOOT + 1))
            else
                progress_fail
            fi
            log "Added nvidia-drm.modeset=1"
        fi
    else
        ok "nvidia-drm.modeset=1 is set"
    fi

    # Check Wayland env vars
    section "NVIDIA Wayland Compatibility"
    local env_file="$HOME/.config/environment.d/nvidia-wayland.conf"
    local needs_env=false

    if [[ "$XDG_SESSION_TYPE" == "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        info "Wayland session detected"
        if [[ ! -f "$env_file" ]]; then
            needs_env=true
            warn "NVIDIA Wayland environment variables not configured"
            info "Fix: Set GBM_BACKEND and __GLX_VENDOR_LIBRARY_NAME for proper Wayland support."
            if confirm "Create NVIDIA Wayland environment config?"; then
                progress "Writing environment config"
                mkdir -p "$(dirname "$env_file")"
                cat > "$env_file" <<'ENVEOF'
GBM_BACKEND=nvidia-drm
__GLX_VENDOR_LIBRARY_NAME=nvidia
WLR_NO_HARDWARE_CURSORS=1
ENVEOF
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                info "Log out and back in for changes to take effect"
                log "Created NVIDIA Wayland env config"
            fi
        else
            ok "NVIDIA Wayland environment configured"
        fi
    fi

    # Rebuild initramfs if fixes were applied
    if [[ $NEEDS_REBOOT -gt 0 ]]; then
        section "Finalizing"
        info "Driver changes applied. Rebuilding initramfs on next boot."
        if confirm "Trigger initramfs rebuild?"; then
            progress "Scheduling initramfs rebuild"
            if rpm-ostree initramfs --enable &>/dev/null 2>&1; then
                progress_done
            else
                progress_fail
                info "initramfs rebuild may happen automatically on reboot"
            fi
        fi
    fi
}

fix_gpu_amd() {
    section "AMD GPU Diagnostics"

    # Check AMDGPU driver
    if ! lsmod 2>/dev/null | grep -q amdgpu; then
        fail "amdgpu kernel module not loaded"
        info "Fix: The amdgpu driver should load automatically. Checking firmware..."
        if confirm "Attempt to load amdgpu module?"; then
            progress "Loading amdgpu"
            if sudo modprobe amdgpu &>/dev/null 2>&1; then
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            else
                progress_fail
                warn "Could not load amdgpu — check dmesg for firmware errors"
            fi
            log "Attempted to load amdgpu"
        fi
    else
        ok "amdgpu driver loaded"
    fi

    # Check Vulkan driver (RADV vs AMDVLK)
    if command -v vulkaninfo &>/dev/null; then
        local vk_driver
        vk_driver=$(vulkaninfo --summary 2>/dev/null | grep -i "driverName" | head -1 || true)
        if echo "$vk_driver" | grep -qi radv; then
            ok "Using RADV (Mesa) Vulkan driver (recommended)"
        elif echo "$vk_driver" | grep -qi amdvlk; then
            warn "Using AMDVLK — RADV is generally better for gaming"
            info "Fix: Set AMD_VULKAN_ICD=RADV to prefer RADV."
            if confirm "Set RADV as default Vulkan driver?"; then
                local amd_env="$HOME/.config/environment.d/amd-vulkan.conf"
                mkdir -p "$(dirname "$amd_env")"
                echo "AMD_VULKAN_ICD=RADV" > "$amd_env"
                ok "RADV set as default — log out and back in"
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                log "Set RADV as default Vulkan driver"
            fi
        fi
    fi

    # Check firmware
    if dmesg 2>/dev/null | grep -qi "amdgpu.*firmware"; then
        local fw_errors
        fw_errors=$(dmesg 2>/dev/null | grep -i "amdgpu.*firmware.*fail\|amdgpu.*firmware.*missing" || true)
        if [[ -n "$fw_errors" ]]; then
            fail "AMD GPU firmware errors detected"
            info "Error: ${fw_errors}"
            info "Fix: Update linux-firmware package"
            if confirm "Update firmware via rpm-ostree?"; then
                progress "Updating linux-firmware"
                if rpm-ostree upgrade &>/dev/null 2>&1; then
                    progress_done
                    ISSUES_FIXED=$((ISSUES_FIXED + 1))
                    NEEDS_REBOOT=$((NEEDS_REBOOT + 1))
                else
                    progress_fail
                fi
                log "Attempted firmware update"
            fi
        fi
    fi

    # Reset power profile
    section "Power Profile"
    if [[ -f /sys/class/drm/card0/device/power_dpm_force_performance_level ]]; then
        local current_profile
        current_profile=$(cat /sys/class/drm/card0/device/power_dpm_force_performance_level 2>/dev/null || echo "unknown")
        info "Current GPU power profile: ${current_profile}"
        if [[ "$current_profile" != "auto" ]]; then
            if confirm "Reset GPU power profile to 'auto'?"; then
                echo "auto" | sudo tee /sys/class/drm/card0/device/power_dpm_force_performance_level &>/dev/null
                ok "Power profile reset to auto"
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                log "Reset AMD GPU power profile to auto"
            fi
        else
            ok "Power profile is set to auto"
        fi
    fi
}

# ── Fix: Proton ───────────────────────────────────────────────────────────────

cmd_proton() {
    banner
    header "Proton/Wine Prefix Fix"
    log "Starting Proton fix"

    local steam_dir="$HOME/.steam/steam"
    [[ -d "$steam_dir" ]] || steam_dir="$HOME/.local/share/Steam"

    if [[ ! -d "$steam_dir" ]]; then
        fail "Steam directory not found"
        print_summary
        return
    fi

    local compat_dir="$steam_dir/steamapps/compatdata"
    local shader_dir="$steam_dir/steamapps/shadercache"

    section "Broken Prefix Detection"
    if [[ -d "$compat_dir" ]]; then
        local broken=0
        while IFS= read -r prefix_dir; do
            local appid
            appid=$(basename "$prefix_dir")
            local pfx="$prefix_dir/pfx"
            if [[ -d "$prefix_dir" && ! -f "$pfx/system.reg" ]]; then
                warn "Broken prefix for AppID ${appid} (missing system.reg)"
                broken=$((broken + 1))
                if confirm "Delete broken prefix for AppID ${appid}? (Steam will recreate it)"; then
                    progress "Removing prefix ${appid}"
                    rm -rf "$prefix_dir"
                    progress_done
                    ISSUES_FIXED=$((ISSUES_FIXED + 1))
                    log "Deleted broken prefix for AppID $appid"
                fi
            fi
        done < <(find "$compat_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null)

        if [[ $broken -eq 0 ]]; then
            ok "No broken prefixes found"
        fi
    else
        info "No compatdata directory found"
    fi

    section "Shader Cache"
    if [[ -d "$shader_dir" ]]; then
        local cache_size
        cache_size=$(du -sh "$shader_dir" 2>/dev/null | cut -f1)
        info "Shader cache size: ${cache_size}"
        if confirm "Clear shader cache? (Steam will rebuild it, may reduce stutter)"; then
            progress "Clearing shader cache"
            rm -rf "${shader_dir:?}"/*
            progress_done
            ISSUES_FIXED=$((ISSUES_FIXED + 1))
            log "Cleared shader cache"
        fi
    fi

    section "Proton Versions"
    local proton_common="$steam_dir/steamapps/common"
    if [[ -d "$proton_common" ]]; then
        local versions
        versions=$(find "$proton_common" -maxdepth 1 -name "Proton*" -type d 2>/dev/null || true)
        if [[ -n "$versions" ]]; then
            echo "$versions" | while read -r v; do
                info "  $(basename "$v")"
            done
        else
            warn "No official Proton versions installed"
            info "Install Proton from Steam: Library -> Tools -> search 'Proton'"
        fi
    fi

    local custom_dir="$steam_dir/compatibilitytools.d"
    if [[ -d "$custom_dir" ]]; then
        local custom_versions
        custom_versions=$(find "$custom_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null || true)
        if [[ -n "$custom_versions" ]]; then
            echo "$custom_versions" | while read -r v; do
                info "  $(basename "$v") (custom)"
            done
        fi
    fi

    section "Proton Config Reset"
    local proton_cfg="$steam_dir/config/config.vdf"
    if [[ -f "$proton_cfg" ]]; then
        info "Steam config found at ${proton_cfg}"
        if confirm "Reset per-game Proton compatibility settings? (non-destructive backup first)"; then
            local backup="${proton_cfg}.backup.$(date +%s)"
            cp "$proton_cfg" "$backup"
            ok "Config backed up to ${backup}"
            info "To fully reset, delete compat_tool_mapping entries in Steam Settings"
            ISSUES_FIXED=$((ISSUES_FIXED + 1))
            log "Backed up Steam config"
        fi
    fi

    print_summary
}

# ── Fix: Audio ────────────────────────────────────────────────────────────────

cmd_audio() {
    banner
    header "Audio Fix"
    log "Starting audio fix"

    section "Audio Service Status"

    # Check PipeWire
    local pw_active=false
    if systemctl --user is-active pipewire &>/dev/null 2>&1; then
        ok "PipeWire is running"
        pw_active=true
    else
        fail "PipeWire is not running"
        info "Problem: PipeWire audio server is not active."
        info "Fix: Restart PipeWire and related services."
        if confirm "Restart PipeWire stack?"; then
            progress "Restarting PipeWire"
            systemctl --user restart pipewire pipewire-pulse wireplumber 2>/dev/null || true
            sleep 2
            if systemctl --user is-active pipewire &>/dev/null 2>&1; then
                progress_done
                ok "PipeWire restarted successfully"
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            else
                progress_fail
                fail "PipeWire failed to restart"
            fi
            log "Restarted PipeWire"
        fi
    fi

    # Check PipeWire-Pulse
    if systemctl --user is-active pipewire-pulse &>/dev/null 2>&1; then
        ok "PipeWire-Pulse bridge running"
    else
        warn "PipeWire-Pulse bridge not running"
        if confirm "Start pipewire-pulse?"; then
            systemctl --user restart pipewire-pulse 2>/dev/null || true
            sleep 1
            if systemctl --user is-active pipewire-pulse &>/dev/null 2>&1; then
                ok "PipeWire-Pulse started"
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            else
                fail "Could not start PipeWire-Pulse"
            fi
            log "Restarted pipewire-pulse"
        fi
    fi

    # Check WirePlumber
    if systemctl --user is-active wireplumber &>/dev/null 2>&1; then
        ok "WirePlumber session manager running"
    else
        warn "WirePlumber not running"
        if confirm "Start WirePlumber?"; then
            systemctl --user restart wireplumber 2>/dev/null || true
            sleep 1
            if systemctl --user is-active wireplumber &>/dev/null 2>&1; then
                ok "WirePlumber started"
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            else
                fail "Could not start WirePlumber"
            fi
            log "Restarted WirePlumber"
        fi
    fi

    # Check output device
    section "Audio Devices"
    if command -v pactl &>/dev/null && pactl info &>/dev/null 2>&1; then
        local sinks
        sinks=$(pactl list short sinks 2>/dev/null || true)
        if [[ -n "$sinks" ]]; then
            echo "$sinks" | while read -r line; do
                info "  Sink: $(echo "$line" | awk '{print $2}')"
            done
        else
            fail "No audio output devices found"
        fi
    fi

    # Check ALSA
    section "ALSA"
    if command -v aplay &>/dev/null; then
        local cards
        cards=$(aplay -l 2>/dev/null | grep "^card" || true)
        if [[ -n "$cards" ]]; then
            ok "ALSA devices found"
        else
            warn "No ALSA playback devices detected"
        fi
    else
        info "aplay not available"
    fi

    # Reset PipeWire config option
    section "Configuration Reset"
    local pw_config_dir="$HOME/.config/pipewire"
    if [[ -d "$pw_config_dir" ]]; then
        info "Custom PipeWire config found at ${pw_config_dir}"
        if confirm "Reset PipeWire config to defaults? (backup will be created)"; then
            local backup="${pw_config_dir}.backup.$(date +%s)"
            mv "$pw_config_dir" "$backup"
            ok "PipeWire config backed up to ${backup}"
            info "Restart PipeWire or reboot to apply defaults"
            if confirm "Restart PipeWire now?"; then
                systemctl --user restart pipewire pipewire-pulse wireplumber 2>/dev/null || true
                sleep 2
                ok "PipeWire restarted with default config"
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            fi
            log "Reset PipeWire config"
        fi
    else
        ok "Using default PipeWire configuration"
    fi

    print_summary
}

# ── Fix: Network ──────────────────────────────────────────────────────────────

cmd_network() {
    banner
    header "Network Fix"
    log "Starting network fix"

    section "Connectivity Test"
    if ping -c1 -W3 1.1.1.1 &>/dev/null 2>&1; then
        ok "Internet connectivity: OK"
    else
        fail "No internet connectivity"
        info "Problem: Cannot reach external servers."
        info "Fix: Restart NetworkManager to re-establish connection."
        if confirm "Restart NetworkManager?"; then
            progress "Restarting NetworkManager"
            if sudo systemctl restart NetworkManager &>/dev/null 2>&1; then
                sleep 3
                progress_done
                if ping -c1 -W3 1.1.1.1 &>/dev/null 2>&1; then
                    ok "Connectivity restored"
                    ISSUES_FIXED=$((ISSUES_FIXED + 1))
                else
                    fail "Still no connectivity after restart"
                fi
            else
                progress_fail
            fi
            log "Restarted NetworkManager"
        fi
    fi

    section "DNS Resolution"
    if command -v dig &>/dev/null; then
        if ! dig +short +time=3 google.com &>/dev/null 2>&1 || [[ -z "$(dig +short +time=3 google.com 2>/dev/null)" ]]; then
            fail "DNS resolution failing"
            info "Fix: Flush DNS cache and reset resolv.conf."
            if confirm "Flush DNS cache?"; then
                progress "Flushing DNS cache"
                sudo resolvectl flush-caches &>/dev/null 2>&1 || \
                sudo systemd-resolve --flush-caches &>/dev/null 2>&1 || true
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                log "Flushed DNS cache"
            fi
        else
            ok "DNS resolution working"
        fi
    fi

    section "Firewall"
    if command -v firewall-cmd &>/dev/null; then
        local zone
        zone=$(firewall-cmd --get-default-zone 2>/dev/null || echo "unknown")
        info "Default firewall zone: ${zone}"
        if [[ "$zone" == "drop" || "$zone" == "block" ]]; then
            warn "Firewall zone '${zone}' may be blocking traffic"
            if confirm "Reset firewall to 'public' zone?"; then
                sudo firewall-cmd --set-default-zone=public &>/dev/null 2>&1
                sudo firewall-cmd --reload &>/dev/null 2>&1
                ok "Firewall reset to public zone"
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
                log "Reset firewall zone to public"
            fi
        else
            ok "Firewall zone looks appropriate"
        fi
    fi

    section "VPN Check"
    local vpn_active=false
    if ip link show 2>/dev/null | grep -qiE "tun|wg|nordlynx|proton|mullvad"; then
        warn "VPN interface detected — may affect game connectivity"
        vpn_active=true
        local vpn_ifaces
        vpn_ifaces=$(ip link show 2>/dev/null | grep -iE "tun|wg|nordlynx|proton|mullvad" | awk -F: '{print $2}' | xargs)
        info "VPN interfaces: ${vpn_ifaces}"
        info "If experiencing connection issues, try disabling VPN for the game"
    fi
    if ! $vpn_active; then
        ok "No VPN interference detected"
    fi

    section "Game Ports"
    info "Common game ports should be open (outbound): 27015-27050 (Steam), 443 (HTTPS)"
    if command -v ss &>/dev/null; then
        local steam_conns
        steam_conns=$(ss -tn 2>/dev/null | grep -c ":2701[0-9]" || echo "0")
        info "Active Steam connections: ${steam_conns}"
    fi

    print_summary
}

# ── Fix: Flatpak ──────────────────────────────────────────────────────────────

cmd_flatpak() {
    banner
    header "Flatpak Fix"
    log "Starting Flatpak fix"

    if ! command -v flatpak &>/dev/null; then
        fail "Flatpak is not installed"
        print_summary
        return
    fi

    section "Flatpak Health"

    # Repair user installation
    info "Checking user installation integrity..."
    if ! flatpak repair --user --dry-run &>/dev/null 2>&1; then
        fail "Flatpak user installation has issues"
        info "Fix: Run flatpak repair to fix broken references."
        if confirm "Run flatpak repair --user?"; then
            progress "Repairing user installation"
            if flatpak repair --user &>/dev/null 2>&1; then
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            else
                progress_fail
            fi
            log "Repaired Flatpak user installation"
        fi
    else
        ok "User installation healthy"
    fi

    # Repair system installation
    info "Checking system installation integrity..."
    if ! flatpak repair --dry-run &>/dev/null 2>&1; then
        fail "Flatpak system installation has issues"
        if confirm "Run flatpak repair (system)?"; then
            progress "Repairing system installation"
            if sudo flatpak repair &>/dev/null 2>&1; then
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            else
                progress_fail
            fi
            log "Repaired Flatpak system installation"
        fi
    else
        ok "System installation healthy"
    fi

    # Check for broken apps
    section "Installed Applications"
    local apps
    apps=$(flatpak list --app --columns=application,name 2>/dev/null || true)
    if [[ -n "$apps" ]]; then
        local count
        count=$(echo "$apps" | wc -l)
        info "${count} Flatpak apps installed"

        # Try running each app's info to detect broken ones
        while IFS=$'\t' read -r appid appname; do
            if ! flatpak info "$appid" &>/dev/null 2>&1; then
                fail "Broken app: ${appid} (${appname})"
                if confirm "Reinstall ${appname}?"; then
                    progress "Reinstalling ${appid}"
                    flatpak uninstall -y "$appid" &>/dev/null 2>&1 || true
                    if flatpak install -y flathub "$appid" &>/dev/null 2>&1; then
                        progress_done
                        ISSUES_FIXED=$((ISSUES_FIXED + 1))
                    else
                        progress_fail
                        warn "Could not reinstall — check Flathub availability"
                    fi
                    log "Reinstalled Flatpak app $appid"
                fi
            fi
        done <<< "$apps"
    fi

    # Permissions reset
    section "Permissions"
    info "If a Flatpak app is misbehaving, resetting its permissions may help."
    if confirm "Reset all Flatpak permission overrides?"; then
        progress "Resetting overrides"
        flatpak override --user --reset &>/dev/null 2>&1 || true
        progress_done
        ISSUES_FIXED=$((ISSUES_FIXED + 1))
        info "Per-app overrides cleared — apps will use default permissions"
        log "Reset Flatpak permission overrides"
    fi

    # Update
    section "Updates"
    if confirm "Update all Flatpak apps?"; then
        progress "Updating Flatpak apps"
        if flatpak update -y &>/dev/null 2>&1; then
            progress_done
            ok "All Flatpak apps updated"
        else
            progress_fail
            warn "Some updates may have failed"
        fi
        log "Updated Flatpak apps"
    fi

    print_summary
}

# ── Fix: Steam ────────────────────────────────────────────────────────────────

cmd_steam() {
    banner
    header "Steam Fix"
    log "Starting Steam fix"

    section "Steam Process"
    local steam_pids
    steam_pids=$(pgrep -f "steam" 2>/dev/null || true)
    if [[ -n "$steam_pids" ]]; then
        info "Steam processes running"
        if confirm "Kill all Steam processes? (recommended for troubleshooting)"; then
            progress "Killing Steam processes"
            pkill -9 -f "steam" &>/dev/null 2>&1 || true
            sleep 2
            if ! pgrep -f "steam" &>/dev/null; then
                progress_done
                ISSUES_FIXED=$((ISSUES_FIXED + 1))
            else
                progress_fail
                warn "Some Steam processes persist"
            fi
            log "Killed Steam processes"
        fi
    else
        info "Steam is not running"
    fi

    local steam_dir="$HOME/.steam/steam"
    [[ -d "$steam_dir" ]] || steam_dir="$HOME/.local/share/Steam"

    if [[ ! -d "$steam_dir" ]]; then
        fail "Steam directory not found at expected locations"
        info "Try launching Steam once to initialize, or install via Flatpak"
        print_summary
        return
    fi

    # Clear download cache
    section "Download Cache"
    local dl_cache="$steam_dir/depotcache"
    if [[ -d "$dl_cache" ]]; then
        local cache_size
        cache_size=$(du -sh "$dl_cache" 2>/dev/null | cut -f1)
        info "Download cache size: ${cache_size}"
        if confirm "Clear Steam download cache?"; then
            progress "Clearing download cache"
            rm -rf "${dl_cache:?}"/*
            progress_done
            ISSUES_FIXED=$((ISSUES_FIXED + 1))
            log "Cleared Steam download cache"
        fi
    fi

    # Verify library folders
    section "Library Folders"
    local lib_config="$steam_dir/steamapps/libraryfolders.vdf"
    if [[ -f "$lib_config" ]]; then
        ok "Library config found"
        local folders
        folders=$(grep '"path"' "$lib_config" 2>/dev/null | sed 's/.*"\(.*\)"/\1/' || true)
        while read -r folder; do
            [[ -z "$folder" ]] && continue
            if [[ -d "$folder" ]]; then
                ok "Library: ${folder}"
            else
                fail "Library path missing: ${folder}"
            fi
        done <<< "$folders"
    else
        warn "Library config not found"
    fi

    # Fix missing libraries
    section "Steam Runtime"
    local runtime_dir="$steam_dir/ubuntu12_32/steam-runtime"
    if [[ -d "$runtime_dir" ]]; then
        ok "Steam runtime present"
    else
        warn "Steam runtime not found"
        info "Fix: Run steam --reset to bootstrap"
        if confirm "Run steam --reset to fix runtime? (Steam will restart)"; then
            progress "Resetting Steam"
            steam --reset &>/dev/null 2>&1 &
            disown
            progress_done
            info "Steam is resetting — wait for it to finish launching"
            ISSUES_FIXED=$((ISSUES_FIXED + 1))
            log "Ran steam --reset"
        fi
    fi

    # Fix package cache / appcache
    section "App Cache"
    local app_cache="$steam_dir/appcache"
    if [[ -d "$app_cache" ]]; then
        local ac_size
        ac_size=$(du -sh "$app_cache" 2>/dev/null | cut -f1)
        info "App cache size: ${ac_size}"
        if confirm "Clear Steam app cache? (fixes metadata issues)"; then
            progress "Clearing app cache"
            rm -rf "${app_cache:?}"/*
            progress_done
            ISSUES_FIXED=$((ISSUES_FIXED + 1))
            log "Cleared Steam app cache"
        fi
    fi

    # HTML cache (common cause of Steam browser issues)
    section "HTML/Browser Cache"
    local html_cache="$steam_dir/config/htmlcache"
    if [[ -d "$html_cache" ]]; then
        if confirm "Clear Steam browser cache?"; then
            progress "Clearing browser cache"
            rm -rf "${html_cache:?}"/*
            progress_done
            ISSUES_FIXED=$((ISSUES_FIXED + 1))
            log "Cleared Steam HTML cache"
        fi
    fi

    print_summary
}

# ── Fix: Rollback ─────────────────────────────────────────────────────────────

cmd_rollback() {
    banner
    header "System Rollback"
    log "Starting rollback"

    if ! command -v rpm-ostree &>/dev/null; then
        fail "This is not an rpm-ostree system — rollback not available"
        print_summary
        return
    fi

    section "Current Deployments"
    rpm-ostree status 2>/dev/null || true

    echo ""
    local deploy_count
    deploy_count=$(rpm-ostree status 2>/dev/null | grep -c "^  " || echo "0")

    if [[ "$deploy_count" -lt 2 ]]; then
        warn "Only one deployment available — nothing to roll back to"
        print_summary
        return
    fi

    info "Rolling back will boot into the previous system deployment."
    info "Your files and data are NOT affected — only the OS layer changes."
    echo ""

    if confirm "Rollback to previous deployment?"; then
        progress "Initiating rollback"
        if rpm-ostree rollback &>/dev/null 2>&1; then
            progress_done
            ok "Rollback staged successfully"
            ISSUES_FIXED=$((ISSUES_FIXED + 1))
            NEEDS_REBOOT=$((NEEDS_REBOOT + 1))
            warn "Reboot required to complete rollback"
            if confirm "Reboot now?"; then
                log "Rebooting for rollback"
                sudo systemctl reboot
            fi
        else
            progress_fail
            fail "Rollback failed"
        fi
        log "Performed system rollback"
    fi

    print_summary
}

# ── Fix: Reset Desktop ───────────────────────────────────────────────────────

cmd_reset_desktop() {
    banner
    header "Reset KDE Plasma Desktop"
    log "Starting desktop reset"

    section "KDE Plasma Configuration"
    warn "This will reset your KDE desktop to 24HG defaults."
    info "Your files, apps, and games will NOT be affected."
    info "Only desktop layout, theme, and panel settings will be reset."
    echo ""

    local kde_config_dirs=(
        "$HOME/.config/plasma-org.kde.plasma.desktop-appletsrc"
        "$HOME/.config/plasmarc"
        "$HOME/.config/plasmashellrc"
        "$HOME/.config/kwinrc"
        "$HOME/.config/kdeglobals"
        "$HOME/.config/kscreenlockerrc"
        "$HOME/.config/kcminputrc"
        "$HOME/.config/kglobalshortcutsrc"
    )

    if confirm "Reset KDE Plasma desktop to 24HG defaults?"; then
        local backup_dir="$HOME/.config/kde-backup-$(date +%s)"
        mkdir -p "$backup_dir"
        progress "Backing up current config"
        for cfg in "${kde_config_dirs[@]}"; do
            if [[ -f "$cfg" ]]; then
                cp "$cfg" "$backup_dir/" 2>/dev/null || true
            fi
        done
        progress_done
        ok "Backup saved to ${backup_dir}"

        progress "Removing current KDE config"
        for cfg in "${kde_config_dirs[@]}"; do
            rm -f "$cfg" 2>/dev/null || true
        done
        progress_done

        # Copy defaults from /etc/skel if available
        progress "Applying 24HG defaults"
        if [[ -d /etc/skel/.config ]]; then
            for cfg in "${kde_config_dirs[@]}"; do
                local basename
                basename=$(basename "$cfg")
                if [[ -f "/etc/skel/.config/$basename" ]]; then
                    cp "/etc/skel/.config/$basename" "$cfg" 2>/dev/null || true
                fi
            done
            progress_done
            ok "24HG defaults applied from /etc/skel"
        else
            progress_done
            info "No /etc/skel defaults found — KDE will use built-in defaults"
        fi

        ISSUES_FIXED=$((ISSUES_FIXED + 1))

        if confirm "Restart Plasma shell now?"; then
            progress "Restarting Plasma"
            kquitapp5 plasmashell &>/dev/null 2>&1 || killall plasmashell &>/dev/null 2>&1 || true
            sleep 2
            kstart5 plasmashell &>/dev/null 2>&1 &
            disown
            sleep 3
            if pgrep -x plasmashell &>/dev/null; then
                progress_done
                ok "Plasma shell restarted"
            else
                progress_fail
                warn "Plasma may need a log-out/log-in to fully reset"
            fi
            log "Restarted Plasma shell"
        fi
    fi

    print_summary
}

# ── Logs ──────────────────────────────────────────────────────────────────────

cmd_logs() {
    banner
    header "Recent Gaming Error Logs"
    log "Viewing logs"

    section "System Errors (last 50 lines)"
    journalctl -p err -n 50 --no-pager 2>/dev/null || info "Could not read system journal"

    section "GPU/Graphics Errors"
    journalctl -b --no-pager 2>/dev/null | grep -iE "nvidia|amdgpu|gpu|vulkan|drm|mesa" | tail -30 || info "No GPU errors found"

    section "Steam Errors"
    local steam_log="$HOME/.steam/steam/logs/stderr.txt"
    if [[ -f "$steam_log" ]]; then
        tail -30 "$steam_log"
    else
        info "No Steam error log found"
    fi

    section "PipeWire/Audio Errors"
    journalctl --user -u pipewire -u pipewire-pulse -u wireplumber -p err -n 20 --no-pager 2>/dev/null || info "No audio errors found"

    section "Forge Rescue History"
    journalctl -t forge-rescue -n 20 --no-pager 2>/dev/null || info "No forge-rescue log entries"

    echo ""
}

# ── Interactive Fix Wizard ────────────────────────────────────────────────────

cmd_fix() {
    banner
    header "Interactive Fix Wizard"
    log "Starting fix wizard (auto=$AUTO_FIX)"

    # Run scan first (silently count issues)
    info "Scanning for issues..."
    echo ""

    # GPU
    local gpu_ok=true
    if ! (command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null) && \
       lspci 2>/dev/null | grep -qi nvidia; then
        gpu_ok=false
    fi
    if lspci 2>/dev/null | grep -qi amd && ! lsmod 2>/dev/null | grep -q amdgpu; then
        gpu_ok=false
    fi

    # Vulkan
    local vulkan_ok=true
    if ! (command -v vulkaninfo &>/dev/null && vulkaninfo --summary &>/dev/null 2>&1); then
        vulkan_ok=false
    fi

    # Audio
    local audio_ok=true
    if ! systemctl --user is-active pipewire &>/dev/null 2>&1; then
        audio_ok=false
    fi

    # Network
    local net_ok=true
    if ! ping -c1 -W3 1.1.1.1 &>/dev/null 2>&1; then
        net_ok=false
    fi

    # Steam
    local steam_ok=true
    if ! (command -v steam &>/dev/null || flatpak list 2>/dev/null | grep -qi steam); then
        steam_ok=false
    fi

    # Flatpak
    local flatpak_ok=true
    if command -v flatpak &>/dev/null && ! flatpak repair --user --dry-run &>/dev/null 2>&1; then
        flatpak_ok=false
    fi

    # Disk
    local disk_ok=true
    local avail_kb
    avail_kb=$(df --output=avail / 2>/dev/null | tail -1 | tr -d ' ')
    if [[ -n "$avail_kb" ]] && [[ $((avail_kb / 1048576)) -lt 10 ]]; then
        disk_ok=false
    fi

    # Report and fix
    local any_issue=false

    if ! $gpu_ok; then
        any_issue=true
        fail "GPU driver issue detected"
        if confirm "Run GPU fix?"; then
            cmd_gpu
        fi
    else
        ok "GPU: healthy"
    fi

    if ! $vulkan_ok; then
        any_issue=true
        fail "Vulkan not working"
        warn "Install Vulkan drivers for your GPU (mesa-vulkan-drivers or nvidia)"
    else
        ok "Vulkan: working"
    fi

    if ! $audio_ok; then
        any_issue=true
        fail "Audio issue detected"
        if confirm "Run audio fix?"; then
            cmd_audio
        fi
    else
        ok "Audio: healthy"
    fi

    if ! $net_ok; then
        any_issue=true
        fail "Network issue detected"
        if confirm "Run network fix?"; then
            cmd_network
        fi
    else
        ok "Network: connected"
    fi

    if ! $steam_ok; then
        any_issue=true
        warn "Steam not found"
    else
        ok "Steam: installed"
    fi

    if ! $flatpak_ok; then
        any_issue=true
        fail "Flatpak issue detected"
        if confirm "Run Flatpak fix?"; then
            cmd_flatpak
        fi
    else
        ok "Flatpak: healthy"
    fi

    if ! $disk_ok; then
        any_issue=true
        warn "Low disk space on root filesystem"
        info "Free up space by clearing caches or removing unused apps"
    else
        ok "Disk space: sufficient"
    fi

    if ! $any_issue; then
        echo ""
        ok "${GREEN}No issues detected — your system is healthy!${RESET}"
    fi

    print_summary
}

# ── Summary ───────────────────────────────────────────────────────────────────

print_summary() {
    echo ""
    echo -e "${BOLD}${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${BOLD}  Summary${RESET}"
    echo -e "${BOLD}${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

    local parts=()
    if [[ $ISSUES_FIXED -gt 0 ]]; then
        parts+=("${GREEN}Fixed ${ISSUES_FIXED} issue(s)${RESET}")
    fi
    if [[ $NEEDS_REBOOT -gt 0 ]]; then
        parts+=("${YELLOW}${NEEDS_REBOOT} require(s) reboot${RESET}")
    fi
    if [[ $WARNINGS -gt 0 ]]; then
        parts+=("${YELLOW}${WARNINGS} warning(s)${RESET}")
    fi
    if [[ $ISSUES_FOUND -gt 0 ]]; then
        local unfixed=$((ISSUES_FOUND - ISSUES_FIXED))
        if [[ $unfixed -gt 0 ]]; then
            parts+=("${RED}${unfixed} unresolved issue(s)${RESET}")
        fi
    fi

    if [[ ${#parts[@]} -eq 0 ]]; then
        echo -e "  ${CHECK} ${GREEN}No issues found — system is healthy!${RESET}"
    else
        local IFS=", "
        echo -e "  ${parts[*]}"
    fi

    if [[ $NEEDS_REBOOT -gt 0 ]]; then
        echo ""
        echo -e "  ${WARN} ${BOLD}Reboot recommended:${RESET} sudo systemctl reboot"
    fi

    echo ""
    log "Summary: fixed=$ISSUES_FIXED, reboot=$NEEDS_REBOOT, warnings=$WARNINGS, issues=$ISSUES_FOUND"
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    banner
    echo -e "${BOLD}Usage:${RESET} forge-rescue <command> [options]"
    echo ""
    echo -e "${BOLD}Commands:${RESET}"
    echo -e "  ${CYAN}scan${RESET}            Scan for common issues and show health report"
    echo -e "  ${CYAN}fix${RESET}             Interactive wizard to fix detected issues"
    echo -e "  ${CYAN}fix --auto${RESET}      Auto-fix all safe issues without prompting"
    echo -e "  ${CYAN}gpu${RESET}             Fix GPU/driver issues (NVIDIA or AMD)"
    echo -e "  ${CYAN}proton${RESET}          Fix Proton/Wine prefix issues"
    echo -e "  ${CYAN}audio${RESET}           Fix audio issues (PipeWire/PulseAudio)"
    echo -e "  ${CYAN}network${RESET}         Fix network/connectivity issues"
    echo -e "  ${CYAN}flatpak${RESET}         Fix Flatpak issues (permissions, broken installs)"
    echo -e "  ${CYAN}steam${RESET}           Fix Steam issues (bootstrap, library, downloads)"
    echo -e "  ${CYAN}rollback${RESET}        Rollback to previous system version (rpm-ostree)"
    echo -e "  ${CYAN}reset-desktop${RESET}   Reset KDE Plasma config to 24HG defaults"
    echo -e "  ${CYAN}logs${RESET}            Show recent error logs relevant to gaming"
    echo ""
    echo -e "${DIM}Part of the 24HG Forge toolkit — https://24hgaming.com${RESET}"
    echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-}"
    shift || true

    # Check for --auto flag
    for arg in "$@"; do
        if [[ "$arg" == "--auto" ]]; then
            AUTO_FIX=true
        fi
    done

    case "$cmd" in
        scan)           cmd_scan ;;
        fix)            cmd_fix ;;
        gpu)            cmd_gpu ;;
        proton)         cmd_proton ;;
        audio)          cmd_audio ;;
        network)        cmd_network ;;
        flatpak)        cmd_flatpak ;;
        steam)          cmd_steam ;;
        rollback)       cmd_rollback ;;
        reset-desktop)  cmd_reset_desktop ;;
        logs)           cmd_logs ;;
        -h|--help|help) usage ;;
        "")             usage ;;
        *)
            echo -e "${CROSS} Unknown command: ${cmd}"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
