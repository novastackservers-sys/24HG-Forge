#!/bin/bash
# 24HG Game Ready — Auto-Optimizer
# Detects newly installed Steam games and applies optimal settings automatically.
# Monitors Steam library folders, applies Proton tweaks, launch args, shader
# pre-caching, controller configs, and per-game performance profiles.
#
# State stored in ~/.config/24hg/game-ready/
#
# Usage: 24hg-game-ready <command> [options]
# Commands: scan, watch, status, optimize <appid>, reset <appid>, help

set -euo pipefail

# ─── Constants ───────────────────────────────────────────────────────────────

STATE_DIR="${HOME}/.config/24hg/game-ready"
OPTIMIZED_DIR="${STATE_DIR}/optimized"
CACHE_DIR="${STATE_DIR}/cache"
LOG_FILE="${STATE_DIR}/game-ready.log"
PROTONDB_CACHE="${CACHE_DIR}/protondb"
WATCH_PID_FILE="${STATE_DIR}/watch.pid"

STEAM_PATHS=(
    "${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam"
    "${HOME}/.local/share/Steam"
    "${HOME}/.steam/steam"
)

PROTONDB_API="https://www.protondb.com/api/v1/reports/summaries"

# ─── Helpers ─────────────────────────────────────────────────────────────────

_log()  { echo "[game-ready] $*"; echo "$(date +%FT%T) $*" >> "$LOG_FILE" 2>/dev/null; }
_err()  { echo "[game-ready] ERROR: $*" >&2; }
_die()  { _err "$@"; exit 1; }
_warn() { echo "[game-ready] WARN: $*" >&2; }

_notify() {
    local title="$1" body="$2" icon="${3:-input-gaming}"
    if command -v notify-send &>/dev/null && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]; then
        notify-send -i "$icon" "$title" "$body" 2>/dev/null || true
    fi
    _log "$title — $body"
}

_ensure_dirs() {
    mkdir -p "$OPTIMIZED_DIR" "$CACHE_DIR" "$PROTONDB_CACHE"
}

# ─── GPU Detection ───────────────────────────────────────────────────────────

_detect_gpu() {
    local gpu="Unknown GPU"
    if command -v lspci &>/dev/null; then
        gpu=$(lspci | grep -iE 'VGA|3D' | head -1 | sed 's/.*: //' | cut -c1-60)
    elif [ -f /sys/class/drm/card0/device/vendor ]; then
        local vendor
        vendor=$(cat /sys/class/drm/card0/device/vendor 2>/dev/null)
        case "$vendor" in
            0x10de) gpu="NVIDIA GPU" ;;
            0x1002) gpu="AMD GPU" ;;
            0x8086) gpu="Intel GPU" ;;
        esac
    fi
    echo "$gpu"
}

_gpu_vendor() {
    local gpu
    gpu=$(_detect_gpu)
    if echo "$gpu" | grep -qi nvidia; then echo "nvidia"
    elif echo "$gpu" | grep -qi amd; then echo "amd"
    elif echo "$gpu" | grep -qi intel; then echo "intel"
    else echo "unknown"
    fi
}

# ─── Steam Discovery ────────────────────────────────────────────────────────

_find_steam_root() {
    for p in "${STEAM_PATHS[@]}"; do
        [ -d "$p" ] && echo "$p" && return 0
    done
    return 1
}

_get_library_folders() {
    local steam_root
    steam_root=$(_find_steam_root) || return 1
    local vdf="${steam_root}/steamapps/libraryfolders.vdf"
    local folders=("${steam_root}/steamapps")

    if [ -f "$vdf" ]; then
        while IFS= read -r line; do
            local path
            path=$(echo "$line" | grep -oP '"path"\s+"\K[^"]+' 2>/dev/null || true)
            if [ -n "$path" ] && [ -d "${path}/steamapps" ]; then
                folders+=("${path}/steamapps")
            fi
        done < "$vdf"
    fi

    printf '%s\n' "${folders[@]}" | sort -u
}

# ─── ACF Parser ──────────────────────────────────────────────────────────────

_parse_acf() {
    local acf_file="$1" key="$2"
    grep -oP "\"${key}\"\s+\"\\K[^\"]+" "$acf_file" 2>/dev/null | head -1
}

_get_game_info() {
    local acf_file="$1"
    local appid name installdir
    appid=$(_parse_acf "$acf_file" "appid")
    name=$(_parse_acf "$acf_file" "name")
    installdir=$(_parse_acf "$acf_file" "installdir")
    echo "${appid}|${name}|${installdir}"
}

# ─── Game Database ───────────────────────────────────────────────────────────
# Format: APPID|PROTON_HINT|LAUNCH_ARGS|PERF_PROFILE|NOTES
# PROTON_HINT: "ge" = Proton-GE recommended, "native" = native Linux, "stock" = default
# PERF_PROFILE: "high" "balanced" "low" for GPU demand

declare -A GAME_DB
_init_game_db() {
    # Rust
    GAME_DB[252490]="ge|-window-mode exclusive -gc.buffer 2048 -gc.budget 64 -fps.limit 0|high|Rust"
    # CS2
    GAME_DB[730]="native|-novid -high -threads 4 -nojoy +fps_max 0|balanced|Counter-Strike 2"
    # Apex Legends
    GAME_DB[1172470]="ge|-novid -eac_launcher_settings SettingsLinux.json +fps_max 0|high|Apex Legends"
    # Dota 2
    GAME_DB[570]="native|-novid -high -map dota -nojoy +fps_max 0|balanced|Dota 2"
    # Elden Ring
    GAME_DB[1245620]="ge|MANGOHUD=1|high|Elden Ring"
    # Cyberpunk 2077
    GAME_DB[1091500]="ge|--launcher-skip MANGOHUD=1|high|Cyberpunk 2077"
    # Baldur's Gate 3
    GAME_DB[1086940]="ge|MANGOHUD=1 --skip-launcher|high|Baldur's Gate 3"
    # Hogwarts Legacy
    GAME_DB[990080]="ge|-dx12 MANGOHUD=1|high|Hogwarts Legacy"
    # Palworld
    GAME_DB[1623730]="ge|-useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS MANGOHUD=1|high|Palworld"
    # Lethal Company
    GAME_DB[1966720]="ge|MANGOHUD=1|balanced|Lethal Company"
    # Helldivers 2
    GAME_DB[553850]="ge|--skip-launcher MANGOHUD=1|high|Helldivers 2"
    # Forza Horizon 5
    GAME_DB[1551360]="ge|MANGOHUD=1|high|Forza Horizon 5"
    # GTA V
    GAME_DB[271590]="ge|-ignorepipelinecache MANGOHUD=1|high|Grand Theft Auto V"
    # Starfield
    GAME_DB[1716740]="ge|MANGOHUD=1|high|Starfield"
    # Red Dead Redemption 2
    GAME_DB[1174180]="ge|-ignorepipelinecache MANGOHUD=1|high|Red Dead Redemption 2"
    # The Witcher 3
    GAME_DB[292030]="ge|MANGOHUD=1|balanced|The Witcher 3: Wild Hunt"
    # Valheim
    GAME_DB[892970]="ge|-window-mode exclusive -screen-fullscreen MANGOHUD=1|balanced|Valheim"
    # Deep Rock Galactic
    GAME_DB[548430]="ge|MANGOHUD=1|balanced|Deep Rock Galactic"
    # No Man's Sky
    GAME_DB[275850]="ge|MANGOHUD=1|high|No Man's Sky"
    # ARK: Survival Evolved
    GAME_DB[346110]="ge|-useallavailablecores -sm4 -d3d10 MANGOHUD=1|high|ARK: Survival Evolved"
    # Monster Hunter: World
    GAME_DB[582010]="ge|MANGOHUD=1|high|Monster Hunter: World"
    # Destiny 2 (currently unsupported on Linux, but entry for reference)
    GAME_DB[1085660]="ge||high|Destiny 2"
    # Terraria
    GAME_DB[105600]="native||low|Terraria"
    # Stardew Valley
    GAME_DB[413150]="native||low|Stardew Valley"
    # Satisfactory
    GAME_DB[526870]="ge|-useperfthreads -NoAsyncLoadingThread MANGOHUD=1|balanced|Satisfactory"
}

# ─── ProtonDB Integration ───────────────────────────────────────────────────

_protondb_fetch() {
    local appid="$1"
    local cache_file="${PROTONDB_CACHE}/${appid}.json"

    # Use cache if less than 7 days old
    if [ -f "$cache_file" ]; then
        local age
        age=$(( $(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || echo 0) ))
        if [ "$age" -lt 604800 ]; then
            cat "$cache_file"
            return 0
        fi
    fi

    if command -v curl &>/dev/null; then
        local data
        data=$(curl -sf --max-time 10 "${PROTONDB_API}/${appid}.json" 2>/dev/null || echo "")
        if [ -n "$data" ]; then
            echo "$data" > "$cache_file"
            echo "$data"
            return 0
        fi
    fi

    [ -f "$cache_file" ] && cat "$cache_file" && return 0
    return 1
}

_protondb_tier() {
    local appid="$1"
    local data
    data=$(_protondb_fetch "$appid" 2>/dev/null) || { echo "unknown"; return; }

    if command -v jq &>/dev/null; then
        jq -r '.tier // "unknown"' <<< "$data" 2>/dev/null || echo "unknown"
    else
        echo "$data" | grep -oP '"tier"\s*:\s*"\K[^"]+' 2>/dev/null || echo "unknown"
    fi
}

# ─── Proton Version Selection ───────────────────────────────────────────────

_select_proton() {
    local appid="$1" hint="${2:-stock}"
    local steam_root
    steam_root=$(_find_steam_root) || return 1

    case "$hint" in
        native)
            _log "  Proton: native Linux build, no Proton needed"
            return 0
            ;;
        ge)
            # Look for Proton-GE
            local ge_dir
            for d in "${steam_root}/compatibilitytools.d" "/var/lib/24hg/proton-ge"; do
                if [ -d "$d" ]; then
                    ge_dir=$(find "$d" -maxdepth 1 -name 'GE-Proton*' -type d 2>/dev/null | sort -V | tail -1)
                    [ -n "$ge_dir" ] && break
                fi
            done
            if [ -n "${ge_dir:-}" ]; then
                _log "  Proton: using $(basename "$ge_dir")"
                echo "$(basename "$ge_dir")"
                return 0
            fi
            _log "  Proton: GE recommended but not found, using default"
            ;;
        *)
            _log "  Proton: using Steam default"
            ;;
    esac
    echo "default"
}

# ─── Launch Options ──────────────────────────────────────────────────────────

_build_launch_opts() {
    local appid="$1" base_args="${2:-}"
    local vendor
    vendor=$(_gpu_vendor)
    local env_vars=""
    local args=""

    # Separate env vars from args in base_args
    for token in $base_args; do
        if [[ "$token" == *=* ]] && [[ "$token" != -* ]]; then
            env_vars+="${token} "
        else
            args+="${token} "
        fi
    done

    # GPU-specific tweaks
    case "$vendor" in
        nvidia)
            env_vars+="__GL_SHADER_DISK_CACHE=1 __GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1 "
            env_vars+="__GL_THREADED_OPTIMIZATIONS=1 "
            ;;
        amd)
            env_vars+="RADV_PERFTEST=gpl,nggc "
            env_vars+="mesa_glthread=true "
            ;;
        intel)
            env_vars+="mesa_glthread=true "
            ;;
    esac

    # Common good defaults
    env_vars+="DXVK_ASYNC=1 "
    env_vars+="STAGING_SHARED_MEMORY=1 "

    local result="${env_vars}%command% ${args}"
    echo "$result" | sed 's/  */ /g; s/ $//'
}

# ─── Shader Pre-Cache ────────────────────────────────────────────────────────

_trigger_shader_precache() {
    local appid="$1"
    local steam_root
    steam_root=$(_find_steam_root) || return 1

    # Check if shader pre-caching is available
    local shader_dir="${steam_root}/shadercache/${appid}"
    if [ -d "$shader_dir" ]; then
        _log "  Shaders: cache exists ($(du -sh "$shader_dir" 2>/dev/null | cut -f1))"
    else
        _log "  Shaders: no pre-cache yet, will build on first launch"
    fi

    # Link to 24hg-shader-cache if available
    if command -v 24hg-shader-cache &>/dev/null; then
        _log "  Shaders: 24hg-shader-cache available for management"
    fi
}

# ─── Controller Mappings ─────────────────────────────────────────────────────

_apply_controller_config() {
    local appid="$1" game_name="$2"
    local steam_root
    steam_root=$(_find_steam_root) || return 1

    local controller_dir="${steam_root}/steamapps/workshop/content/241100"
    if [ -d "$controller_dir" ]; then
        local configs
        configs=$(find "$controller_dir" -name "*.vdf" 2>/dev/null | wc -l)
        if [ "$configs" -gt 0 ]; then
            _log "  Controller: $configs community configs available"
            return 0
        fi
    fi
    _log "  Controller: using default Steam Input configuration"
}

# ─── Performance Profile ─────────────────────────────────────────────────────

_apply_perf_profile() {
    local appid="$1" profile="${2:-balanced}"

    # Link to 24hg-game-profiles if it exists
    if command -v 24hg-game-profiles &>/dev/null; then
        local profile_file="${HOME}/.config/24hg/game-profiles/${appid}.json"
        if [ ! -f "$profile_file" ]; then
            _log "  Profile: creating $profile profile via 24hg-game-profiles"
            24hg-game-profiles create --appid "$appid" --profile "$profile" 2>/dev/null || true
        else
            _log "  Profile: existing 24hg-game-profiles config found"
        fi
        return 0
    fi

    # Standalone profile management
    local perf_file="${OPTIMIZED_DIR}/${appid}.profile"
    case "$profile" in
        high)
            cat > "$perf_file" <<-PROF
perf_profile=performance
gpu_power=high
cpu_governor=performance
mangohud_preset=fps-only
PROF
            ;;
        balanced)
            cat > "$perf_file" <<-PROF
perf_profile=balanced
gpu_power=auto
cpu_governor=schedutil
mangohud_preset=default
PROF
            ;;
        low)
            cat > "$perf_file" <<-PROF
perf_profile=powersave
gpu_power=low
cpu_governor=powersave
mangohud_preset=minimal
PROF
            ;;
    esac
    _log "  Profile: set to $profile"
}

# ─── Core: Optimize a Game ───────────────────────────────────────────────────

_optimize_game() {
    local appid="$1" name="${2:-}" installdir="${3:-}" force="${4:-false}"

    local state_file="${OPTIMIZED_DIR}/${appid}.state"

    # Skip if already optimized (unless forced)
    if [ -f "$state_file" ] && [ "$force" != "true" ]; then
        _log "Skipping $name ($appid) — already optimized"
        return 0
    fi

    _log "Optimizing: $name ($appid)"

    local proton_hint="stock" launch_args="" perf_profile="balanced" db_name=""

    # Check built-in database
    if [ -n "${GAME_DB[$appid]:-}" ]; then
        IFS='|' read -r proton_hint launch_args perf_profile db_name <<< "${GAME_DB[$appid]}"
        _log "  Database: matched as ${db_name:-$name}"
    else
        # Unknown game — check ProtonDB for guidance
        local tier
        tier=$(_protondb_tier "$appid")
        _log "  ProtonDB: rated '$tier'"
        case "$tier" in
            platinum|gold) proton_hint="stock" ;;
            silver|bronze) proton_hint="ge" ;;
            *) proton_hint="ge" ;;
        esac
    fi

    # Select Proton version
    local proton_ver
    proton_ver=$(_select_proton "$appid" "$proton_hint")

    # Build launch options
    local launch_opts
    launch_opts=$(_build_launch_opts "$appid" "$launch_args")
    _log "  Launch opts: $launch_opts"

    # Shader pre-cache check
    _trigger_shader_precache "$appid"

    # Controller config
    _apply_controller_config "$appid" "$name"

    # Performance profile
    _apply_perf_profile "$appid" "$perf_profile"

    # Save state
    cat > "$state_file" <<-STATE
appid=${appid}
name=${name}
installdir=${installdir}
proton=${proton_ver:-default}
launch_opts=${launch_opts}
perf_profile=${perf_profile}
optimized_at=$(date +%FT%T)
version=1
STATE

    # Desktop notification
    local gpu
    gpu=$(_detect_gpu)
    _notify "Game Ready: ${name}" "Optimized for your ${gpu}" "input-gaming"

    _log "  Done: $name is game-ready"
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_scan() {
    _ensure_dirs
    _init_game_db
    _log "Scanning all installed Steam games..."

    local count=0 optimized=0 skipped=0

    while IFS= read -r lib_folder; do
        for acf in "${lib_folder}"/appmanifest_*.acf; do
            [ -f "$acf" ] || continue
            local info
            info=$(_get_game_info "$acf")
            IFS='|' read -r appid name installdir <<< "$info"

            [ -z "$appid" ] && continue
            # Skip Steamworks common redistributables, Proton, tools
            [[ "$name" == *"Steamworks"* ]] && continue
            [[ "$name" == *"Proton"* ]] && continue
            [[ "$name" == *"Steam Linux Runtime"* ]] && continue
            [[ "$name" == *"SteamVR"* ]] && continue

            count=$((count + 1))
            if [ -f "${OPTIMIZED_DIR}/${appid}.state" ]; then
                skipped=$((skipped + 1))
            else
                _optimize_game "$appid" "$name" "$installdir"
                optimized=$((optimized + 1))
            fi
        done
    done < <(_get_library_folders 2>/dev/null)

    _log "Scan complete: $count games found, $optimized newly optimized, $skipped already done"
    _notify "24HG Game Ready" "Scanned $count games, optimized $optimized new" "input-gaming"
}

cmd_watch() {
    _ensure_dirs
    _init_game_db

    # Check for inotifywait
    if ! command -v inotifywait &>/dev/null; then
        _die "inotifywait not found. Install inotify-tools: sudo dnf install inotify-tools"
    fi

    # Check if already running
    if [ -f "$WATCH_PID_FILE" ]; then
        local old_pid
        old_pid=$(cat "$WATCH_PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            _die "Watch daemon already running (PID $old_pid). Stop it first or remove $WATCH_PID_FILE"
        fi
        rm -f "$WATCH_PID_FILE"
    fi

    # Run initial scan
    cmd_scan

    _log "Starting watch daemon for new game installs..."
    echo $$ > "$WATCH_PID_FILE"

    # Build list of library folders to watch
    local watch_dirs=()
    while IFS= read -r lib_folder; do
        [ -d "$lib_folder" ] && watch_dirs+=("$lib_folder")
    done < <(_get_library_folders 2>/dev/null)

    if [ ${#watch_dirs[@]} -eq 0 ]; then
        rm -f "$WATCH_PID_FILE"
        _die "No Steam library folders found to watch"
    fi

    _log "Watching ${#watch_dirs[@]} library folder(s)..."

    trap 'rm -f "$WATCH_PID_FILE"; _log "Watch daemon stopped"; exit 0' INT TERM

    inotifywait -m -e create -e modify --format '%w%f' "${watch_dirs[@]}" 2>/dev/null | \
    while IFS= read -r file; do
        if [[ "$file" == */appmanifest_*.acf ]]; then
            # Wait a moment for the file to be fully written
            sleep 2
            [ -f "$file" ] || continue

            local info
            info=$(_get_game_info "$file")
            IFS='|' read -r appid name installdir <<< "$info"
            [ -z "$appid" ] && continue

            [[ "$name" == *"Steamworks"* ]] && continue
            [[ "$name" == *"Proton"* ]] && continue
            [[ "$name" == *"Steam Linux Runtime"* ]] && continue

            _log "Detected new/updated game: $name ($appid)"
            _optimize_game "$appid" "$name" "$installdir" "true"
        fi
    done

    rm -f "$WATCH_PID_FILE"
}

cmd_status() {
    _ensure_dirs
    _init_game_db

    local total=0 optimized=0

    printf "%-10s %-40s %-10s %-12s %s\n" "APPID" "NAME" "PROFILE" "PROTON" "OPTIMIZED"
    printf "%-10s %-40s %-10s %-12s %s\n" "-----" "----" "-------" "------" "---------"

    # List all installed games and their status
    while IFS= read -r lib_folder; do
        for acf in "${lib_folder}"/appmanifest_*.acf; do
            [ -f "$acf" ] || continue
            local info
            info=$(_get_game_info "$acf")
            IFS='|' read -r appid name installdir <<< "$info"
            [ -z "$appid" ] && continue

            [[ "$name" == *"Steamworks"* ]] && continue
            [[ "$name" == *"Proton"* ]] && continue
            [[ "$name" == *"Steam Linux Runtime"* ]] && continue

            total=$((total + 1))
            local state_file="${OPTIMIZED_DIR}/${appid}.state"
            local status="no" proton="-" profile="-"

            if [ -f "$state_file" ]; then
                optimized=$((optimized + 1))
                status="yes"
                proton=$(grep '^proton=' "$state_file" 2>/dev/null | cut -d= -f2 | head -1)
                profile=$(grep '^perf_profile=' "$state_file" 2>/dev/null | cut -d= -f2 | head -1)
            fi

            # Truncate name if too long
            local disp_name="${name:0:38}"
            [ ${#name} -gt 38 ] && disp_name="${disp_name}.."

            printf "%-10s %-40s %-10s %-12s %s\n" "$appid" "$disp_name" "${profile:-—}" "${proton:-—}" "$status"
        done
    done < <(_get_library_folders 2>/dev/null)

    echo ""
    echo "Total: $total games | Optimized: $optimized | Pending: $((total - optimized))"

    # Watch daemon status
    if [ -f "$WATCH_PID_FILE" ]; then
        local pid
        pid=$(cat "$WATCH_PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            echo "Watch daemon: running (PID $pid)"
        else
            echo "Watch daemon: stale PID file (not running)"
        fi
    else
        echo "Watch daemon: not running"
    fi
}

cmd_optimize() {
    local appid="${1:-}"
    [ -z "$appid" ] && _die "Usage: 24hg-game-ready optimize <appid>"

    _ensure_dirs
    _init_game_db

    # Find the game's ACF file
    local found=false
    while IFS= read -r lib_folder; do
        local acf="${lib_folder}/appmanifest_${appid}.acf"
        if [ -f "$acf" ]; then
            local info
            info=$(_get_game_info "$acf")
            IFS='|' read -r id name installdir <<< "$info"
            _optimize_game "$appid" "$name" "$installdir" "true"
            found=true
            break
        fi
    done < <(_get_library_folders 2>/dev/null)

    $found || _die "Game $appid not found in any Steam library folder"
}

cmd_reset() {
    local appid="${1:-}"
    [ -z "$appid" ] && _die "Usage: 24hg-game-ready reset <appid>"

    _ensure_dirs

    local state_file="${OPTIMIZED_DIR}/${appid}.state"
    local profile_file="${OPTIMIZED_DIR}/${appid}.profile"
    local name="$appid"

    if [ -f "$state_file" ]; then
        name=$(grep '^name=' "$state_file" 2>/dev/null | cut -d= -f2 | head -1)
        name="${name:-$appid}"
    fi

    local removed=false
    for f in "$state_file" "$profile_file"; do
        [ -f "$f" ] && rm -f "$f" && removed=true
    done

    # Also remove from 24hg-game-profiles if available
    if command -v 24hg-game-profiles &>/dev/null; then
        local gp_file="${HOME}/.config/24hg/game-profiles/${appid}.json"
        if [ -f "$gp_file" ]; then
            _log "Removing 24hg-game-profiles entry for $appid"
            rm -f "$gp_file"
            removed=true
        fi
    fi

    if $removed; then
        _log "Reset optimizations for $name ($appid)"
        _notify "Game Ready: Reset" "$name — optimizations removed" "edit-undo"
    else
        _warn "No optimizations found for $appid"
    fi
}

cmd_help() {
    cat <<'HELP'
24HG Game Ready — Auto-Optimizer

Detects newly installed Steam games and applies optimal settings including
Proton selection, launch arguments, shader pre-caching, controller configs,
and per-game performance profiles.

USAGE:
    24hg-game-ready <command> [options]

COMMANDS:
    scan              Scan all installed games and optimize unoptimized ones
    watch             Watch for new installs in daemon mode (runs scan first)
    status            Show optimization status for all installed games
    optimize <appid>  Manually optimize (or re-optimize) a specific game
    reset <appid>     Remove all optimizations for a specific game
    help              Show this help message

EXAMPLES:
    24hg-game-ready scan
    24hg-game-ready watch &           # Run in background
    24hg-game-ready optimize 252490   # Optimize Rust
    24hg-game-ready reset 252490      # Reset Rust optimizations
    24hg-game-ready status

STATE:
    Optimization state stored in ~/.config/24hg/game-ready/
    ProtonDB cache stored in ~/.config/24hg/game-ready/cache/protondb/

BUILT-IN DATABASE:
    Includes optimal settings for 20+ popular games including Rust, CS2,
    Apex Legends, Dota 2, Elden Ring, Cyberpunk 2077, Baldur's Gate 3,
    Hogwarts Legacy, Palworld, Lethal Company, Helldivers 2, Forza Horizon 5,
    GTA V, Starfield, Red Dead Redemption 2, The Witcher 3, Valheim,
    Deep Rock Galactic, No Man's Sky, ARK Survival, and more.

    Unknown games are checked against ProtonDB for compatibility guidance.
HELP
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        scan)           cmd_scan ;;
        watch)          cmd_watch ;;
        status)         cmd_status ;;
        optimize)       cmd_optimize "$@" ;;
        reset)          cmd_reset "$@" ;;
        help|--help|-h) cmd_help ;;
        *)              _err "Unknown command: $cmd"; cmd_help; exit 1 ;;
    esac
}

main "$@"
