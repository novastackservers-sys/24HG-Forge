#!/usr/bin/env bash
# 24HG Forge Flatpak Gaming Permission Fixer — Auto-fix sandbox issues for gaming apps
# Part of 24HG Forge — a custom Linux gaming distro based on Bazzite/Fedora Atomic
set -euo pipefail

# ─── Constants ───────────────────────────────────────────────────────────────

readonly VERSION="1.0.0"
readonly SCRIPT_NAME="forge-flatpak-fix"
readonly OVERRIDES_DIR="$HOME/.local/share/flatpak/overrides"

# Color codes
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly DIM='\033[2m'
readonly RESET='\033[0m'

# Known gaming Flatpaks — app ID : friendly name
declare -A GAMING_APPS=(
    [com.valvesoftware.Steam]="Steam"
    [net.lutris.Lutris]="Lutris"
    [com.heroicgameslauncher.hgl]="Heroic Games Launcher"
    [com.usebottles.bottles]="Bottles"
    [com.discordapp.Discord]="Discord"
    [com.obsproject.Studio]="OBS Studio"
    [org.prismlauncher.PrismLauncher]="PrismLauncher"
    [io.github.ArcanePlugins.NexusModManager]="Nexus Mod Manager"
)

# Ordered list for consistent display
readonly APP_ORDER=(
    com.valvesoftware.Steam
    net.lutris.Lutris
    com.heroicgameslauncher.hgl
    com.usebottles.bottles
    com.discordapp.Discord
    com.obsproject.Studio
    org.prismlauncher.PrismLauncher
    io.github.ArcanePlugins.NexusModManager
)

# ─── Global state ────────────────────────────────────────────────────────────

DRY_RUN=false
GUI_MODE=false
FIRST_BOOT=false
ISSUE_COUNT=0
FIX_COUNT=0
declare -a INSTALLED_GAMING_APPS=()
declare -a SCAN_ISSUES=()
declare -a SCAN_WARNINGS=()

# ─── Helpers ─────────────────────────────────────────────────────────────────

print_header() {
    echo -e "\n${BOLD}${BLUE}╔══════════════════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${BLUE}║${RESET} ${BOLD}$1${RESET}"
    echo -e "${BOLD}${BLUE}╚══════════════════════════════════════════════════════╝${RESET}"
}

print_section() {
    echo -e "\n${BOLD}${CYAN}── $1 ──${RESET}"
}

ok()      { echo -e "  ${GREEN}✓${RESET} $1"; }
warn()    { echo -e "  ${YELLOW}⚠${RESET} $1"; }
fail()    { echo -e "  ${RED}✗${RESET} $1"; }
info()    { echo -e "  ${BLUE}ℹ${RESET} $1"; }
dimtext() { echo -e "  ${DIM}$1${RESET}"; }

gui_notify() {
    if $GUI_MODE && command -v zenity &>/dev/null; then
        zenity --info --title="24HG Forge Flatpak Fix" --text="$1" --no-wrap 2>/dev/null || true
    fi
}

gui_confirm() {
    if $GUI_MODE && command -v zenity &>/dev/null; then
        zenity --question --title="24HG Forge Flatpak Fix" --text="$1" --no-wrap 2>/dev/null
        return $?
    else
        read -rp "  $1 [y/N] " answer
        [[ "$answer" =~ ^[Yy] ]]
    fi
}

# Resolve a friendly name (e.g. "steam") to an app ID
resolve_app_id() {
    local input="${1,,}"  # lowercase
    for app_id in "${APP_ORDER[@]}"; do
        local name="${GAMING_APPS[$app_id]}"
        local name_lower="${name,,}"
        local short="${app_id##*.}"
        short="${short,,}"
        if [[ "$input" == "$app_id" || "$input" == "$name_lower" || "$input" == "$short" ]]; then
            echo "$app_id"
            return 0
        fi
    done
    # Try partial match
    for app_id in "${APP_ORDER[@]}"; do
        if [[ "${app_id,,}" == *"$input"* || "${GAMING_APPS[$app_id],,}" == *"$input"* ]]; then
            echo "$app_id"
            return 0
        fi
    done
    return 1
}

# ─── Detection ───────────────────────────────────────────────────────────────

detect_installed_apps() {
    INSTALLED_GAMING_APPS=()
    local all_flatpaks
    all_flatpaks=$(flatpak list --app --columns=application 2>/dev/null || true)
    for app_id in "${APP_ORDER[@]}"; do
        if echo "$all_flatpaks" | grep -qx "$app_id"; then
            INSTALLED_GAMING_APPS+=("$app_id")
        fi
    done
}

detect_gpu_vendor() {
    # Returns: nvidia, amd, intel, or unknown
    if lspci 2>/dev/null | grep -qi 'nvidia'; then
        echo "nvidia"
    elif lspci 2>/dev/null | grep -qi 'amd.*radeon\|amd.*navi\|amd.*vega\|advanced micro'; then
        echo "amd"
    elif lspci 2>/dev/null | grep -qi 'intel.*graphics\|intel.*iris\|intel.*arc'; then
        echo "intel"
    else
        echo "unknown"
    fi
}

detect_nvidia_driver_version() {
    local ver=""
    if [[ -f /sys/module/nvidia/version ]]; then
        ver=$(cat /sys/module/nvidia/version)
    elif command -v nvidia-smi &>/dev/null; then
        ver=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1 | tr -d '[:space:]')
    fi
    echo "$ver"
}

get_mounted_drives() {
    # Return non-root, non-tmpfs, non-snap mounted filesystems
    lsblk -nro MOUNTPOINT,FSTYPE,NAME 2>/dev/null | while read -r mount fstype name; do
        [[ -z "$mount" || "$mount" == "/" ]] && continue
        [[ "$mount" == /boot* || "$mount" == /snap* ]] && continue
        [[ "$fstype" == "tmpfs" || "$fstype" == "squashfs" || "$fstype" == "devtmpfs" ]] && continue
        echo "$mount"
    done | sort -u
}

# ─── Permission checking ────────────────────────────────────────────────────

get_app_permissions() {
    local app_id="$1"
    flatpak info --show-permissions "$app_id" 2>/dev/null || true
}

get_app_overrides() {
    local app_id="$1"
    local override_file="$OVERRIDES_DIR/$app_id"
    if [[ -f "$override_file" ]]; then
        cat "$override_file"
    fi
}

check_permission() {
    # Check if a permission string exists in the app's effective permissions
    local app_id="$1"
    local section="$2"  # e.g., "filesystems", "devices"
    local value="$3"    # e.g., "host", "all"
    local perms
    perms=$(get_app_permissions "$app_id")
    local overrides
    overrides=$(get_app_overrides "$app_id")

    # Check both base permissions and overrides
    local combined="${perms}${overrides}"
    if echo "$combined" | grep -qi "\[$section\]" 2>/dev/null; then
        local in_section=false
        while IFS= read -r line; do
            if [[ "$line" == "[$section]" ]]; then
                in_section=true
                continue
            elif [[ "$line" == "["* ]]; then
                in_section=false
                continue
            fi
            if $in_section && [[ "$line" == *"$value"* ]]; then
                return 0
            fi
        done <<< "$combined"
    fi
    return 1
}

has_filesystem_access() {
    local app_id="$1"
    local path="$2"
    check_permission "$app_id" "Context" "filesystems=$path" 2>/dev/null ||
    check_permission "$app_id" "Context" "filesystems=host" 2>/dev/null ||
    check_permission "$app_id" "Session Bus Policy" "" 2>/dev/null  # dummy to avoid set -e
    # More thorough check via metadata + overrides
    local perms overrides
    perms=$(get_app_permissions "$app_id")
    overrides=$(get_app_overrides "$app_id")
    if echo "$perms" "$overrides" | grep -qE "filesystems=(host|$path)" 2>/dev/null; then
        return 0
    fi
    return 1
}

has_device_access() {
    local app_id="$1"
    local perms overrides
    perms=$(get_app_permissions "$app_id")
    overrides=$(get_app_overrides "$app_id")
    echo "$perms" "$overrides" | grep -qE "devices=(all|dri)" 2>/dev/null
}

has_socket() {
    local app_id="$1"
    local socket="$2"
    local perms overrides
    perms=$(get_app_permissions "$app_id")
    overrides=$(get_app_overrides "$app_id")
    echo "$perms" "$overrides" | grep -qE "sockets=.*$socket" 2>/dev/null
}

has_network() {
    local app_id="$1"
    local perms overrides
    perms=$(get_app_permissions "$app_id")
    overrides=$(get_app_overrides "$app_id")
    echo "$perms" "$overrides" | grep -qE "shared=.*network" 2>/dev/null
}

has_dbus_access() {
    local app_id="$1"
    local bus_name="$2"
    local perms overrides
    perms=$(get_app_permissions "$app_id")
    overrides=$(get_app_overrides "$app_id")
    echo "$perms" "$overrides" | grep -q "$bus_name" 2>/dev/null
}

# ─── Scan engine ─────────────────────────────────────────────────────────────

scan_app() {
    local app_id="$1"
    local name="${GAMING_APPS[$app_id]}"
    local issues=0
    local warnings=0

    print_section "$name ($app_id)"

    # --- Filesystem access ---
    if has_filesystem_access "$app_id" "host"; then
        ok "Filesystem: host access"
    else
        # Check specific paths
        local missing_fs=()
        for dir in /mnt /run/media "$HOME/Games"; do
            if ! has_filesystem_access "$app_id" "$dir"; then
                missing_fs+=("$dir")
            fi
        done
        if [[ ${#missing_fs[@]} -gt 0 ]]; then
            fail "$name can't access: ${missing_fs[*]} — games on those drives won't launch"
            SCAN_ISSUES+=("$app_id:filesystem:${missing_fs[*]}")
            ((issues++))
        else
            ok "Filesystem: essential paths accessible"
        fi
    fi

    # Check external drives specifically
    local drives
    drives=$(get_mounted_drives)
    if [[ -n "$drives" ]]; then
        while read -r drive; do
            if ! has_filesystem_access "$app_id" "$drive"; then
                warn "$name can't see drive: $drive"
                SCAN_WARNINGS+=("$app_id:drive:$drive")
                ((warnings++))
            fi
        done <<< "$drives"
    fi

    # --- Device access ---
    if has_device_access "$app_id"; then
        ok "Device access: all devices (controllers, GPU)"
    else
        fail "$name has no device access — controllers and GPU won't work properly"
        SCAN_ISSUES+=("$app_id:device:all")
        ((issues++))
    fi

    # --- GPU / DRI ---
    local gpu_vendor
    gpu_vendor=$(detect_gpu_vendor)
    if [[ "$gpu_vendor" == "nvidia" ]]; then
        if [[ -e /dev/nvidia0 ]]; then
            # NVIDIA devices exist
            if has_device_access "$app_id"; then
                ok "NVIDIA GPU: accessible"
            else
                fail "$name can't access NVIDIA GPU — games will use software rendering"
                SCAN_ISSUES+=("$app_id:nvidia:devices")
                ((issues++))
            fi
        fi
    fi

    # --- Socket access ---
    local socket_ok=true
    if has_socket "$app_id" "x11"; then
        ok "Socket: X11"
    else
        warn "$name has no X11 socket — some games may not display"
        SCAN_WARNINGS+=("$app_id:socket:x11")
        ((warnings++))
        socket_ok=false
    fi

    if has_socket "$app_id" "wayland"; then
        ok "Socket: Wayland"
    else
        warn "$name has no Wayland socket — may fall back to XWayland"
        SCAN_WARNINGS+=("$app_id:socket:wayland")
        ((warnings++))
    fi

    if has_socket "$app_id" "pulseaudio"; then
        ok "Socket: Audio (PulseAudio/PipeWire)"
    else
        fail "$name has no audio socket — no game audio"
        SCAN_ISSUES+=("$app_id:socket:pulseaudio")
        ((issues++))
    fi

    # --- Network ---
    if has_network "$app_id"; then
        ok "Network: enabled"
    else
        fail "$name has no network access — online features won't work"
        SCAN_ISSUES+=("$app_id:network:share")
        ((issues++))
    fi

    # --- D-Bus (app-specific) ---
    case "$app_id" in
        com.valvesoftware.Steam)
            if has_dbus_access "$app_id" "com.feralinteractive.GameMode"; then
                ok "D-Bus: GameMode"
            else
                warn "GameMode integration not configured — no automatic CPU governor switching"
                SCAN_WARNINGS+=("$app_id:dbus:com.feralinteractive.GameMode")
                ((warnings++))
            fi
            if has_dbus_access "$app_id" "org.freedesktop.Notifications"; then
                ok "D-Bus: Notifications"
            else
                warn "Notification access missing — no desktop notifications from Steam"
                SCAN_WARNINGS+=("$app_id:dbus:org.freedesktop.Notifications")
                ((warnings++))
            fi
            ;;
        com.discordapp.Discord)
            if has_filesystem_access "$app_id" "xdg-run/pipewire-0"; then
                ok "PipeWire: screen share audio"
            else
                fail "Discord can't access PipeWire — screen sharing will have no audio"
                SCAN_ISSUES+=("$app_id:filesystem:xdg-run/pipewire-0")
                ((issues++))
            fi
            if has_dbus_access "$app_id" "org.freedesktop.portal.ScreenCast"; then
                ok "D-Bus: ScreenCast portal"
            else
                fail "Discord can't use ScreenCast portal — screen sharing won't work on Wayland"
                SCAN_ISSUES+=("$app_id:dbus:org.freedesktop.portal.ScreenCast")
                ((issues++))
            fi
            ;;
        com.obsproject.Studio)
            if has_filesystem_access "$app_id" "xdg-run/pipewire-0"; then
                ok "PipeWire: capture access"
            else
                fail "OBS can't access PipeWire — screen/audio capture will fail"
                SCAN_ISSUES+=("$app_id:filesystem:xdg-run/pipewire-0")
                ((issues++))
            fi
            if has_dbus_access "$app_id" "org.freedesktop.portal.ScreenCast"; then
                ok "D-Bus: ScreenCast portal"
            else
                fail "OBS can't use ScreenCast portal — window/screen capture won't work"
                SCAN_ISSUES+=("$app_id:dbus:org.freedesktop.portal.ScreenCast")
                ((issues++))
            fi
            ;;
    esac

    # --- Summary for this app ---
    if [[ $issues -eq 0 && $warnings -eq 0 ]]; then
        echo -e "\n  ${GREEN}${BOLD}All clear!${RESET} No permission issues detected."
    else
        [[ $issues -gt 0 ]] && echo -e "\n  ${RED}${BOLD}$issues issue(s)${RESET} need fixing."
        [[ $warnings -gt 0 ]] && echo -e "  ${YELLOW}${BOLD}$warnings warning(s)${RESET} — recommended fixes available."
    fi

    ISSUE_COUNT=$((ISSUE_COUNT + issues))
    return 0
}

# ─── Fix engine ──────────────────────────────────────────────────────────────

apply_override() {
    local app_id="$1"
    shift
    local args=("$@")

    if $DRY_RUN; then
        dimtext "[dry-run] flatpak override --user $app_id ${args[*]}"
    else
        flatpak override --user "$app_id" "${args[@]}" 2>/dev/null
    fi
}

fix_steam() {
    local app_id="com.valvesoftware.Steam"
    print_section "Fixing Steam"

    local overrides=(
        --filesystem=host
        --filesystem=/mnt
        --filesystem=/run/media
        "--filesystem=xdg-run/app/com.discordapp.Discord:create"
        --device=all
        --share=network
        --socket=wayland
        --socket=x11
        --socket=pulseaudio
        --env=MANGOHUD=1
        --env=PROTON_ENABLE_NVAPI=1
        --talk-name=org.freedesktop.Notifications
        --talk-name=com.feralinteractive.GameMode
    )

    apply_override "$app_id" "${overrides[@]}"
    ok "Host filesystem, all drives, devices"
    ok "Wayland + X11 + audio sockets"
    ok "MangoHud + NVAPI environment"
    ok "Notifications + GameMode D-Bus"
    ok "Discord Rich Presence socket"
    ((FIX_COUNT++))
}

fix_discord() {
    local app_id="com.discordapp.Discord"
    print_section "Fixing Discord"

    local overrides=(
        --filesystem=xdg-run/pipewire-0
        --socket=wayland
        --socket=x11
        --socket=pulseaudio
        --device=all
        --share=network
        --env=DISCORD_DISABLE_GPU_SANDBOX=1
        --talk-name=org.freedesktop.ScreenCast
        --talk-name=org.freedesktop.portal.ScreenCast
        --talk-name=org.freedesktop.Notifications
    )

    apply_override "$app_id" "${overrides[@]}"
    ok "PipeWire access for screen share audio"
    ok "Wayland + X11 + audio sockets"
    ok "ScreenCast portal for Wayland screen sharing"
    ok "GPU sandbox workaround"
    ((FIX_COUNT++))
}

