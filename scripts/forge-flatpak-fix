# Map app IDs to fix functions
fix_app() {
    local app_id="$1"
    case "$app_id" in
        com.valvesoftware.Steam)                    fix_steam ;;
        net.lutris.Lutris)                          fix_lutris ;;
        com.heroicgameslauncher.hgl)                fix_heroic ;;
        com.usebottles.bottles)                     fix_bottles ;;
        com.discordapp.Discord)                     fix_discord ;;
        com.obsproject.Studio)                      fix_obs ;;
        org.prismlauncher.PrismLauncher)            fix_prismlauncher ;;
        io.github.ArcanePlugins.NexusModManager)    fix_nexusmods ;;
        *) warn "No fix profile for $app_id" ;;
    esac
}

# ─── NVIDIA runtime check ───────────────────────────────────────────────────

check_nvidia_runtime() {
    local gpu_vendor
    gpu_vendor=$(detect_gpu_vendor)

    if [[ "$gpu_vendor" != "nvidia" ]]; then
        return 0
    fi

    print_section "NVIDIA Runtime Check"

    local driver_ver
    driver_ver=$(detect_nvidia_driver_version)
    if [[ -z "$driver_ver" ]]; then
        warn "NVIDIA GPU detected but couldn't determine driver version"
        return 0
    fi

    info "NVIDIA driver version: $driver_ver"

    # Convert driver version to Flatpak GL runtime format (e.g., 550.54.14 -> nvidia-550-54-14)
    local runtime_suffix
    runtime_suffix=$(echo "$driver_ver" | tr '.' '-')
    local runtime_id="org.freedesktop.Platform.GL.nvidia-${runtime_suffix}"

    # Check if runtime is installed
    if flatpak list --runtime --columns=application 2>/dev/null | grep -q "org.freedesktop.Platform.GL.nvidia"; then
        local installed_runtime
        installed_runtime=$(flatpak list --runtime --columns=application 2>/dev/null | grep "org.freedesktop.Platform.GL.nvidia" | head -1)
        ok "NVIDIA Flatpak GL runtime installed: $installed_runtime"

        # Check version match
        if flatpak list --runtime --columns=application 2>/dev/null | grep -q "$runtime_id"; then
            ok "Runtime matches driver version ($driver_ver)"
        else
            warn "Runtime version mismatch — installed runtime may not match driver $driver_ver"
            warn "Expected: $runtime_id"
            if ! $DRY_RUN; then
                info "Run: flatpak install flathub $runtime_id"
            fi
        fi
    else
        fail "NVIDIA Flatpak GL runtime NOT installed — GPU acceleration won't work in Flatpaks"
        if $DRY_RUN; then
            dimtext "[dry-run] flatpak install -y flathub $runtime_id"
        else
            info "Installing: $runtime_id"
            if flatpak install -y flathub "$runtime_id" 2>/dev/null; then
                ok "NVIDIA runtime installed successfully"
            else
                # Try the 32-bit variant too
                warn "Could not install runtime — try manually: flatpak install flathub $runtime_id"
            fi
        fi
    fi

    # Check 32-bit runtime (needed for many games)
    local runtime_id_32="org.freedesktop.Platform.GL32.nvidia-${runtime_suffix}"
    if flatpak list --runtime --columns=application 2>/dev/null | grep -q "org.freedesktop.Platform.GL32.nvidia"; then
        ok "NVIDIA 32-bit GL runtime installed (needed for many games)"
    else
        warn "NVIDIA 32-bit GL runtime missing — some 32-bit games may not work"
        info "Install: flatpak install flathub $runtime_id_32"
    fi
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_scan() {
    print_header "Flatpak Gaming Permission Scan"

    detect_installed_apps

    if [[ ${#INSTALLED_GAMING_APPS[@]} -eq 0 ]]; then
        warn "No gaming Flatpaks detected."
        info "Install gaming apps: flatpak install flathub com.valvesoftware.Steam"
        return 0
    fi

    info "Found ${#INSTALLED_GAMING_APPS[@]} gaming Flatpak(s) installed"
    echo ""

    ISSUE_COUNT=0
    SCAN_ISSUES=()
    SCAN_WARNINGS=()

    for app_id in "${INSTALLED_GAMING_APPS[@]}"; do
        scan_app "$app_id"
    done

    # GPU runtime check
    check_nvidia_runtime

    # Overall summary
    print_section "Summary"
    if [[ $ISSUE_COUNT -eq 0 ]]; then
        echo -e "\n  ${GREEN}${BOLD}All gaming Flatpaks look healthy!${RESET}"
    else
        echo -e "\n  ${RED}${BOLD}$ISSUE_COUNT issue(s) found.${RESET}"
        echo -e "  Run ${BOLD}$SCRIPT_NAME fix${RESET} to auto-fix all issues."
    fi
    if [[ ${#SCAN_WARNINGS[@]} -gt 0 ]]; then
        echo -e "  ${YELLOW}${#SCAN_WARNINGS[@]} warning(s)${RESET} — recommended improvements available."
    fi
}

cmd_fix() {
    local target="${1:-all}"

    if [[ "$target" == "all" ]]; then
        print_header "Fixing All Gaming Flatpaks"
    else
        print_header "Fixing: $target"
    fi

    $DRY_RUN && info "DRY RUN — no changes will be made"

    detect_installed_apps

    if [[ ${#INSTALLED_GAMING_APPS[@]} -eq 0 ]]; then
        warn "No gaming Flatpaks detected."
        return 0
    fi

    # Ensure overrides directory exists
    if ! $DRY_RUN; then
        mkdir -p "$OVERRIDES_DIR"
    fi

    FIX_COUNT=0

    if [[ "$target" == "all" ]]; then
        for app_id in "${INSTALLED_GAMING_APPS[@]}"; do
            fix_app "$app_id"
        done
        # Also fix NVIDIA runtime
        check_nvidia_runtime
        # Fix drive access
        fix_drives_silent
    else
        local app_id
        if app_id=$(resolve_app_id "$target"); then
            # Verify it's installed
            local found=false
            for installed in "${INSTALLED_GAMING_APPS[@]}"; do
                if [[ "$installed" == "$app_id" ]]; then
                    found=true
                    break
                fi
            done
            if $found; then
                fix_app "$app_id"
            else
                fail "${GAMING_APPS[$app_id]:-$app_id} is not installed"
                return 1
            fi
        else
            fail "Unknown app: $target"
            info "Known apps: steam, discord, lutris, heroic, bottles, obs, prismlauncher"
            return 1
        fi
    fi

    print_section "Done"
    if $DRY_RUN; then
        info "$FIX_COUNT app(s) would be fixed. Run without --dry-run to apply."
    else
        ok "$FIX_COUNT app(s) fixed successfully"
        info "Changes take effect next time you launch the app."
    fi

    gui_notify "Fixed permissions for $FIX_COUNT gaming app(s). Restart apps to apply."
}

cmd_status() {
    print_header "Flatpak Gaming Health Status"

    detect_installed_apps

    if [[ ${#INSTALLED_GAMING_APPS[@]} -eq 0 ]]; then
        warn "No gaming Flatpaks installed."
        return 0
    fi

    # App status table
    print_section "Installed Gaming Apps"
    printf "  ${BOLD}%-35s %-12s %-10s${RESET}\n" "App" "Overrides" "Health"
    printf "  %-35s %-12s %-10s\n" "---" "---" "---"

    for app_id in "${INSTALLED_GAMING_APPS[@]}"; do
        local name="${GAMING_APPS[$app_id]}"
        local override_file="$OVERRIDES_DIR/$app_id"
        local override_status="${DIM}none${RESET}"
        local health=""

        if [[ -f "$override_file" ]]; then
            local line_count
            line_count=$(wc -l < "$override_file")
            override_status="${GREEN}$line_count rules${RESET}"
        fi

        # Quick health check
        local issues=0
        has_device_access "$app_id" || ((issues++))
        has_network "$app_id" || ((issues++))
        has_socket "$app_id" "pulseaudio" || ((issues++))

        if [[ $issues -eq 0 ]]; then
            health="${GREEN}OK${RESET}"
        elif [[ $issues -le 1 ]]; then
            health="${YELLOW}Fair${RESET}"
        else
            health="${RED}Issues${RESET}"
        fi

        printf "  %-35s %-22b %-20b\n" "$name" "$override_status" "$health"
    done

    # Drive access
    print_section "Drive Access"
    local drives
    drives=$(get_mounted_drives)
    if [[ -n "$drives" ]]; then
        while read -r drive; do
            local accessible_by=()
            for app_id in "${INSTALLED_GAMING_APPS[@]}"; do
                if has_filesystem_access "$app_id" "$drive"; then
                    accessible_by+=("${GAMING_APPS[$app_id]}")
                fi
            done
            if [[ ${#accessible_by[@]} -gt 0 ]]; then
                ok "$drive — accessible by: ${accessible_by[*]}"
            else
                warn "$drive — no gaming apps can access this drive"
            fi
        done <<< "$drives"
    else
        dimtext "No additional drives detected"
    fi

    # GPU info
    print_section "GPU"
    local gpu_vendor
    gpu_vendor=$(detect_gpu_vendor)
    info "Detected GPU vendor: $gpu_vendor"

    if [[ "$gpu_vendor" == "nvidia" ]]; then
        local driver_ver
        driver_ver=$(detect_nvidia_driver_version)
        [[ -n "$driver_ver" ]] && info "NVIDIA driver: $driver_ver"

        if flatpak list --runtime --columns=application 2>/dev/null | grep -q "org.freedesktop.Platform.GL.nvidia"; then
            ok "NVIDIA Flatpak GL runtime installed"
        else
            fail "NVIDIA Flatpak GL runtime MISSING"
        fi
        if flatpak list --runtime --columns=application 2>/dev/null | grep -q "org.freedesktop.Platform.GL32.nvidia"; then
            ok "NVIDIA 32-bit GL runtime installed"
        else
            warn "NVIDIA 32-bit GL runtime missing"
        fi
    elif [[ "$gpu_vendor" == "amd" ]]; then
        ok "AMD GPU — Mesa drivers (no extra Flatpak runtime needed)"
    elif [[ "$gpu_vendor" == "intel" ]]; then
        ok "Intel GPU — Mesa drivers (no extra Flatpak runtime needed)"
    fi

    # Outdated runtimes
    print_section "Runtime Health"
    local outdated
    outdated=$(flatpak remote-ls --updates --columns=application 2>/dev/null | head -20 || true)
    if [[ -n "$outdated" ]]; then
        local runtime_updates
        runtime_updates=$(echo "$outdated" | grep -c "org.freedesktop.Platform" || true)
        if [[ "$runtime_updates" -gt 0 ]]; then
            warn "$runtime_updates runtime update(s) available — run: flatpak update"
        else
            ok "All runtimes up to date"
        fi
    else
        ok "All Flatpaks up to date"
    fi
}

cmd_permissions() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        fail "Usage: $SCRIPT_NAME permissions <app>"
        info "Example: $SCRIPT_NAME permissions steam"
        return 1
    fi

    local app_id
    if ! app_id=$(resolve_app_id "$target"); then
        fail "Unknown app: $target"
        return 1
    fi

    local name="${GAMING_APPS[$app_id]:-$app_id}"
    print_header "Permissions: $name"

    # Check installed
    if ! flatpak list --app --columns=application 2>/dev/null | grep -qx "$app_id"; then
        fail "$name is not installed"
        return 1
    fi

    # Base permissions
    print_section "Base Permissions (from manifest)"
    local base_perms
    base_perms=$(flatpak info --show-permissions "$app_id" 2>/dev/null || echo "(none)")
    if [[ -n "$base_perms" && "$base_perms" != "(none)" ]]; then
        echo "$base_perms" | while IFS= read -r line; do
            dimtext "$line"
        done
    else
        dimtext "No base permissions found"
    fi

    # User overrides
    print_section "User Overrides"
    local override_file="$OVERRIDES_DIR/$app_id"
    if [[ -f "$override_file" ]]; then
        cat "$override_file" | while IFS= read -r line; do
            dimtext "$line"
        done
    else
        dimtext "No user overrides applied"
    fi

    # Gaming feature analysis
    print_section "Gaming Feature Checklist"

    # Controllers
    if has_device_access "$app_id"; then
        ok "Controllers: device=all (gamepad, joystick, wheel)"
    else
        fail "Controllers: NO device access"
        dimtext "Fix: device=all + /dev/uinput access"
    fi

    # External drives
    if has_filesystem_access "$app_id" "host" || has_filesystem_access "$app_id" "/mnt"; then
        ok "External drives: filesystem access to /mnt, /run/media"
    else
        fail "External drives: no access to /mnt or /run/media"
        dimtext "Fix: filesystem=/mnt + filesystem=/run/media"
    fi

    # MangoHud
    local perms_all
    perms_all="$(get_app_permissions "$app_id")$(get_app_overrides "$app_id")"
    if echo "$perms_all" | grep -q "MANGOHUD=1"; then
        ok "MangoHud: enabled via environment"
    else
        warn "MangoHud: not configured"
        dimtext "Fix: env=MANGOHUD=1"
    fi

    # GameMode
    if has_dbus_access "$app_id" "com.feralinteractive.GameMode"; then
        ok "GameMode: D-Bus access configured"
    else
        warn "GameMode: not configured"
        dimtext "Fix: talk-name=com.feralinteractive.GameMode"
    fi

    # Discord Rich Presence (for game launchers)
    case "$app_id" in
        com.valvesoftware.Steam|net.lutris.Lutris|com.heroicgameslauncher.hgl)
            if has_filesystem_access "$app_id" "xdg-run/app/com.discordapp.Discord"; then
                ok "Discord Rich Presence: socket access configured"
            else
                warn "Discord Rich Presence: not configured"
                dimtext "Fix: filesystem=xdg-run/app/com.discordapp.Discord:create"
            fi
            ;;
    esac

    # Audio
    if has_socket "$app_id" "pulseaudio"; then
        ok "Audio: PulseAudio/PipeWire socket"
    else
        fail "Audio: no audio socket"
        dimtext "Fix: socket=pulseaudio"
    fi

    # Display
    if has_socket "$app_id" "x11" && has_socket "$app_id" "wayland"; then
        ok "Display: X11 + Wayland"
    elif has_socket "$app_id" "x11"; then
        warn "Display: X11 only (no native Wayland)"
    elif has_socket "$app_id" "wayland"; then
        warn "Display: Wayland only (no X11 fallback)"
    else
        fail "Display: no display socket!"
    fi

    # Network
    if has_network "$app_id"; then
        ok "Network: enabled"
    else
        fail "Network: disabled"
    fi
}

cmd_reset() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        fail "Usage: $SCRIPT_NAME reset <app>"
        info "Example: $SCRIPT_NAME reset steam"
        return 1
    fi

    local app_id
    if ! app_id=$(resolve_app_id "$target"); then
        fail "Unknown app: $target"
        return 1
    fi

    local name="${GAMING_APPS[$app_id]:-$app_id}"
    print_header "Reset Permissions: $name"

    local override_file="$OVERRIDES_DIR/$app_id"
    if [[ ! -f "$override_file" ]]; then
        info "No user overrides exist for $name — nothing to reset."
        return 0
    fi

    # Show current overrides
    print_section "Current overrides to be removed"
    cat "$override_file" | while IFS= read -r line; do
        dimtext "$line"
    done
    echo ""

    if $DRY_RUN; then
        dimtext "[dry-run] Would remove: $override_file"
        return 0
    fi

    if ! gui_confirm "Remove all user overrides for $name?"; then
        info "Cancelled."
        return 0
    fi

    # Remove overrides
    flatpak override --user --reset "$app_id" 2>/dev/null || rm -f "$override_file"
    ok "All user overrides removed for $name"

    echo ""
    if gui_confirm "Re-apply gaming defaults for $name?"; then
        fix_app "$app_id"
        ok "Gaming defaults re-applied"
    else
        info "App reset to Flatpak defaults. Run '$SCRIPT_NAME fix $target' to re-apply gaming permissions."
    fi
}

cmd_drives() {
    print_header "Drive Access Fix"

    detect_installed_apps

    if [[ ${#INSTALLED_GAMING_APPS[@]} -eq 0 ]]; then
        warn "No gaming Flatpaks detected."
        return 0
    fi

    $DRY_RUN && info "DRY RUN — no changes will be made"

    # Detect all drives
    print_section "Detected Drives"
    local drives
    drives=$(get_mounted_drives)

    if [[ -z "$drives" ]]; then
        info "No additional drives detected (only root filesystem)."
        info "If you have drives that aren't showing up, make sure they're mounted."
        return 0
    fi

    # Also check common mount points even if not in lsblk
    local extra_mounts=()
    for dir in /mnt /run/media /media; do
        if [[ -d "$dir" ]] && ! echo "$drives" | grep -q "^${dir}$"; then
            local subdirs
            subdirs=$(find "$dir" -maxdepth 2 -mindepth 1 -type d 2>/dev/null | head -10)
            if [[ -n "$subdirs" ]]; then
                while read -r subdir; do
                    if mountpoint -q "$subdir" 2>/dev/null || [[ -n "$(ls -A "$subdir" 2>/dev/null)" ]]; then
                        extra_mounts+=("$subdir")
                    fi
                done <<< "$subdirs"
            fi
        fi
    done

    # Combine
    local all_drives=()
    while read -r d; do
        [[ -n "$d" ]] && all_drives+=("$d")
    done <<< "$drives"
    all_drives+=("${extra_mounts[@]}")

    # Remove duplicates
    local unique_drives=()
    declare -A seen_drives=()
    for d in "${all_drives[@]}"; do
        if [[ -z "${seen_drives[$d]:-}" ]]; then
            seen_drives[$d]=1
            unique_drives+=("$d")
        fi
    done

    if [[ ${#unique_drives[@]} -eq 0 ]]; then
        info "No additional drives found."
        return 0
    fi

    for drive in "${unique_drives[@]}"; do
        local label=""
        label=$(lsblk -nro LABEL "$(findmnt -nro SOURCE "$drive" 2>/dev/null || echo "")" 2>/dev/null || echo "")
        local display="$drive"
        [[ -n "$label" ]] && display="$drive ($label)"
        info "Found: $display"
    done

    # Check and fix access per app
    print_section "Fixing Drive Access"
    local fixes_applied=0

    for app_id in "${INSTALLED_GAMING_APPS[@]}"; do
        local name="${GAMING_APPS[$app_id]}"
        local app_needs_fix=false
        local missing_drives=()

        for drive in "${unique_drives[@]}"; do
            if ! has_filesystem_access "$app_id" "$drive"; then
                app_needs_fix=true
                missing_drives+=("$drive")
            fi
        done

        if $app_needs_fix; then
            info "Fixing $name — adding access to: ${missing_drives[*]}"
            for drive in "${missing_drives[@]}"; do
                apply_override "$app_id" "--filesystem=$drive"
            done
            # Also ensure parent mount dirs are accessible
            apply_override "$app_id" "--filesystem=/mnt"
            apply_override "$app_id" "--filesystem=/run/media"
            ok "$name: drive access fixed"
            ((fixes_applied++))
        else
            ok "$name: all drives already accessible"
        fi
    done

    print_section "Done"
    if [[ $fixes_applied -gt 0 ]]; then
        ok "Fixed drive access for $fixes_applied app(s)"
        info "Restart affected apps to apply changes."
    else
        ok "All gaming apps already have drive access"
    fi
}

# Silent version for use within fix command
fix_drives_silent() {
    local drives
    drives=$(get_mounted_drives)
    [[ -z "$drives" ]] && return 0

    for app_id in "${INSTALLED_GAMING_APPS[@]}"; do
        while read -r drive; do
            [[ -z "$drive" ]] && continue
            if ! has_filesystem_access "$app_id" "$drive"; then
                apply_override "$app_id" "--filesystem=$drive"
            fi
        done <<< "$drives"
    done
}

# ─── First boot integration ─────────────────────────────────────────────────

cmd_first_boot() {
    # Called during 24HG Forge first-boot setup
    # Silently pre-configures all installed gaming Flatpaks

    detect_installed_apps

    if [[ ${#INSTALLED_GAMING_APPS[@]} -eq 0 ]]; then
        # Nothing to do yet — Flatpaks may not be installed during first boot
        exit 0
    fi

    mkdir -p "$OVERRIDES_DIR"

    # Apply all fixes silently
    FIX_COUNT=0
    for app_id in "${INSTALLED_GAMING_APPS[@]}"; do
        fix_app "$app_id" >/dev/null 2>&1
    done

    # Fix NVIDIA if applicable
    local gpu_vendor
    gpu_vendor=$(detect_gpu_vendor)
    if [[ "$gpu_vendor" == "nvidia" ]]; then
        check_nvidia_runtime >/dev/null 2>&1 || true
    fi

    # Fix drives
    fix_drives_silent >/dev/null 2>&1 || true

    echo "forge-flatpak-fix: configured $FIX_COUNT gaming app(s) on first boot"
}

# ─── Usage ───────────────────────────────────────────────────────────────────

usage() {
    echo -e "${BOLD}24HG Forge Flatpak Gaming Permission Fixer${RESET} v$VERSION"
    echo "Auto-detect and fix Flatpak sandbox permission issues for gaming apps."
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo "  $SCRIPT_NAME <command> [options]"
    echo ""
    echo -e "${BOLD}Commands:${RESET}"
    echo "  scan                  Scan all gaming Flatpaks for permission issues"
    echo "  fix [app]             Auto-fix all issues (or fix a specific app)"
    echo "  status                Show Flatpak gaming health overview"
    echo "  permissions <app>     Show detailed permissions for an app"
    echo "  reset <app>           Reset an app's permissions to defaults"
    echo "  drives                Detect and fix drive access issues"
    echo ""
    echo -e "${BOLD}Options:${RESET}"
    echo "  --dry-run             Preview changes without applying them"
    echo "  --gui                 Show zenity dialogs for desktop integration"
    echo "  --first-boot          Run in first-boot mode (silent, auto-configure)"
    echo "  -h, --help            Show this help"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo "  $SCRIPT_NAME scan                    # Find all issues"
    echo "  $SCRIPT_NAME fix                     # Fix everything"
    echo "  $SCRIPT_NAME fix steam               # Fix only Steam"
    echo "  $SCRIPT_NAME fix --dry-run           # Preview fixes"
    echo "  $SCRIPT_NAME permissions discord     # Check Discord permissions"
    echo "  $SCRIPT_NAME drives                  # Fix drive access"
    echo "  $SCRIPT_NAME reset steam             # Reset Steam to defaults"
    echo ""
    echo -e "${BOLD}Supported Apps:${RESET}"
    echo "  steam, discord, lutris, heroic, bottles, obs, prismlauncher, nexusmods"
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    # Parse global flags first (so --help works without flatpak)
    local args=()
    for arg in "$@"; do
        case "$arg" in
            --dry-run)    DRY_RUN=true ;;
            --gui)        GUI_MODE=true ;;
            --first-boot) FIRST_BOOT=true ;;
            *)            args+=("$arg") ;;
        esac
    done

    local command="${args[0]:-}"
    local subarg="${args[1]:-}"

    # Show help without requiring flatpak
    if [[ "$command" == "-h" || "$command" == "--help" || "$command" == "help" || -z "$command" ]]; then
        usage
        return 0
    fi

    # Check for flatpak
    if ! command -v flatpak &>/dev/null; then
        echo -e "${RED}Error:${RESET} flatpak is not installed."
        echo "24HG Forge should have flatpak pre-installed. Something is wrong with your system."
        exit 1
    fi

    # First boot mode
    if $FIRST_BOOT; then
        cmd_first_boot
        exit 0
    fi

    case "$command" in
        scan)
            cmd_scan
            ;;
        fix)
            cmd_fix "$subarg"
            ;;
        status)
            cmd_status
            ;;
        permissions|perms)
            cmd_permissions "$subarg"
            ;;
        reset)
            cmd_reset "$subarg"
            ;;
        drives)
            cmd_drives
            ;;
        *)
            fail "Unknown command: $command"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
