#!/bin/bash
# HubOS Neofetch — Custom system info display with 24HG branding
# Shown on terminal launch (optional via .bashrc)

# Colors
C0='\033[0m'       # Reset
C1='\033[1;34m'    # Bold Blue (accent)
C2='\033[0;36m'    # Cyan
C3='\033[0;37m'    # Light gray
C4='\033[1;37m'    # White bold
C5='\033[0;90m'    # Dark gray
CB='\033[1;34m'    # Bold blue for logo

# Gather system info
OS=$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo "HubOS")
KERNEL=$(uname -r)
UPTIME=$(uptime -p 2>/dev/null | sed 's/up //')
SHELL_NAME=$(basename "$SHELL")
CPU=$(grep "model name" /proc/cpuinfo 2>/dev/null | head -1 | cut -d: -f2 | sed 's/^ //' | sed 's/(R)//g;s/(TM)//g;s/CPU //g')
CPU_CORES=$(nproc 2>/dev/null || echo "?")

# GPU detection
GPU=$(lspci 2>/dev/null | grep -E "VGA|3D|Display" | head -1 | sed 's/.*: //' | cut -c1-50)
GPU="${GPU:-Unknown}"

# Memory
MEM_TOTAL=$(free -m | awk '/^Mem:/ {print $2}')
MEM_USED=$(free -m | awk '/^Mem:/ {print $3}')
MEM_PERCENT=$((MEM_USED * 100 / MEM_TOTAL))

# Disk
DISK_INFO=$(df -h / 2>/dev/null | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}')

# Resolution
RES=$(xdpyinfo 2>/dev/null | grep dimensions | awk '{print $2}' || echo "N/A")

# Desktop
DE="${XDG_CURRENT_DESKTOP:-Unknown}"

# Package count (rpm-ostree + flatpak)
RPMS=$(rpm -qa 2>/dev/null | wc -l)
FLATPAKS=$(flatpak list 2>/dev/null | wc -l)
PKGS="${RPMS} (rpm), ${FLATPAKS} (flatpak)"

cat << EOF

${CB}    ██╗  ██╗██╗   ██╗██████╗  ██████╗ ███████╗${C0}
${CB}    ██║  ██║██║   ██║██╔══██╗██╔═══██╗██╔════╝${C0}    ${C1}OS${C0}        ${C3}${OS}${C0}
${CB}    ███████║██║   ██║██████╔╝██║   ██║███████╗${C0}    ${C1}Kernel${C0}    ${C3}${KERNEL}${C0}
${CB}    ██╔══██║██║   ██║██╔══██╗██║   ██║╚════██║${C0}    ${C1}Uptime${C0}    ${C3}${UPTIME}${C0}
${CB}    ██║  ██║╚██████╔╝██████╔╝╚██████╔╝███████║${C0}    ${C1}Shell${C0}     ${C3}${SHELL_NAME}${C0}
${CB}    ╚═╝  ╚═╝ ╚═════╝ ╚═════╝  ╚═════╝ ╚══════╝${C0}    ${C1}DE${C0}        ${C3}${DE}${C0}
${C5}         24 HOUR GAMING${C0}                          ${C1}CPU${C0}       ${C3}${CPU} (${CPU_CORES} cores)${C0}
                                                    ${C1}GPU${C0}       ${C3}${GPU}${C0}
${C2}    ■${C0} Servers: ${C4}88+${C0}  ${C2}■${C0} hub.24hgaming.com          ${C1}Memory${C0}    ${C3}${MEM_USED}MiB / ${MEM_TOTAL}MiB (${MEM_PERCENT}%)${C0}
${C2}    ■${C0} Voice: LiveKit  ${C2}■${C0} discord.gg/ymfEjH6EJN     ${C1}Disk${C0}      ${C3}${DISK_INFO}${C0}
                                                    ${C1}Packages${C0}  ${C3}${PKGS}${C0}
                                                    ${C1}Display${C0}   ${C3}${RES}${C0}

    ${C5}────────────────────────────────────────────────────────────────────${C0}
    ${C1}[F12]${C0} Toggle MangoHud  ${C1}[Super]${C0} App Launcher  ${C1}[Tray]${C0} Quick Connect
${C0}
EOF
