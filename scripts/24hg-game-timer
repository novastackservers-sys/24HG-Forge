#!/usr/bin/env python3
"""
24HG Game Timer — Track playtime across all game launchers.

Monitors Steam, Lutris/Wine, Heroic, native Linux games, and GameMode sessions.
Stores per-session data and provides statistics, reports, and hub sync.

Commands:
  start <game>       Manually start tracking a game session
  stop [game]        Stop tracking (most recent if no game specified)
  status             Show currently tracked sessions with elapsed time
  stats [game]       Playtime statistics (top 10 if no game specified)
  report [period]    Weekly/monthly/all-time breakdown (default: weekly)
  export             Export all data as JSON to stdout
  daemon             Auto-detect game sessions by polling /proc
  help               Show this help text

Data: ~/.local/share/24hg/game-timer.json
"""

import json
import os
import re
import signal
import subprocess
import sys
import time
import urllib.request
import urllib.error
from datetime import datetime, timedelta
from pathlib import Path

# ── Configuration ──

DATA_DIR = os.path.expanduser("~/.local/share/24hg")
DATA_FILE = os.path.join(DATA_DIR, "game-timer.json")
HUB_TOKEN_FILE = os.path.expanduser("~/.config/24hg/hub-token")
HUB_API_URL = "https://api.24hgaming.com/activity/playtime"
STEAM_LIBRARY_PATHS = [
    os.path.expanduser("~/.steam/steam/steamapps/libraryfolders.vdf"),
    os.path.expanduser("~/.local/share/Steam/steamapps/libraryfolders.vdf"),
]
POLL_INTERVAL = 30  # seconds between /proc scans in daemon mode

# Known launcher process patterns
WINE_PREFIXES = ("wine", "wine64", "wineserver", "proton")
HEROIC_PATTERNS = ("heroic", "legendary")
GAMEMODE_CMD = "gamemoded"

running = True


def handle_signal(sig, frame):
    global running
    running = False


signal.signal(signal.SIGINT, handle_signal)
signal.signal(signal.SIGTERM, handle_signal)


# ── Data Layer ──

def load_data():
    """Load the game timer database."""
    if os.path.exists(DATA_FILE):
        try:
            with open(DATA_FILE, "r") as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            pass
    return {"sessions": [], "active": []}


def save_data(data):
    """Persist the game timer database."""
    os.makedirs(DATA_DIR, exist_ok=True)
    tmp = DATA_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
    os.replace(tmp, DATA_FILE)


# ── Steam Integration ──

def parse_libraryfolders_vdf():
    """Parse Steam's libraryfolders.vdf to find all library paths."""
    paths = []
    for vdf_path in STEAM_LIBRARY_PATHS:
        if not os.path.exists(vdf_path):
            continue
        try:
            with open(vdf_path, "r") as f:
                content = f.read()
            # Match "path" entries
            for match in re.finditer(r'"path"\s+"([^"]+)"', content):
                lib = match.group(1)
                steamapps = os.path.join(lib, "steamapps")
                if os.path.isdir(steamapps):
                    paths.append(steamapps)
        except IOError:
            continue
    return paths


def get_steam_app_manifest_map():
    """Build a map of AppID -> game name from Steam manifests."""
    app_map = {}
    for steamapps in parse_libraryfolders_vdf():
        try:
            for entry in os.listdir(steamapps):
                if entry.startswith("appmanifest_") and entry.endswith(".acf"):
                    acf_path = os.path.join(steamapps, entry)
                    try:
                        with open(acf_path, "r") as f:
                            text = f.read()
                        appid_m = re.search(r'"appid"\s+"(\d+)"', text)
                        name_m = re.search(r'"name"\s+"([^"]+)"', text)
                        if appid_m and name_m:
                            app_map[appid_m.group(1)] = name_m.group(1)
                    except IOError:
                        continue
        except OSError:
            continue
    return app_map


def get_steam_running_appids():
    """Detect running Steam game AppIDs via steam's process cmdlines."""
    appids = set()
    try:
        for pid_dir in Path("/proc").iterdir():
            if not pid_dir.name.isdigit():
                continue
            try:
                cmdline_file = pid_dir / "cmdline"
                cmdline = cmdline_file.read_bytes().decode("utf-8", errors="replace")
                # Steam launches games with AppId in the command line
                m = re.search(r"AppId[= ](\d+)", cmdline)
                if m:
                    appids.add(m.group(1))
                # Also check for SteamAppId env
                environ_file = pid_dir / "environ"
                if environ_file.exists():
                    env = environ_file.read_bytes().decode("utf-8", errors="replace")
                    for em in re.finditer(r"SteamAppId=(\d+)", env):
                        aid = em.group(1)
                        if aid != "0":
                            appids.add(aid)
            except (PermissionError, OSError, IOError):
                continue
    except OSError:
        pass
    return appids


# ── Process Detection ──

def get_running_games():
    """Scan /proc to find running game processes. Returns dict of id -> name."""
    games = {}

    # Steam games
    app_map = get_steam_app_manifest_map()
    for appid in get_steam_running_appids():
        name = app_map.get(appid, f"Steam App {appid}")
        games[f"steam:{appid}"] = name

    # Scan all processes for Wine/Lutris/Heroic/native game indicators
    try:
        for pid_dir in Path("/proc").iterdir():
            if not pid_dir.name.isdigit():
                continue
            try:
                cmdline_raw = (pid_dir / "cmdline").read_bytes()
                cmdline = cmdline_raw.decode("utf-8", errors="replace")
                args = cmdline.replace("\x00", " ").strip()
                exe_path = ""
                try:
                    exe_path = os.readlink(pid_dir / "exe")
                except (OSError, PermissionError):
                    pass

                # Lutris-launched Wine games
                if "lutris" in args.lower() and any(w in args.lower() for w in WINE_PREFIXES):
                    # Try to extract game name from wine prefix path or exe
                    name = _extract_wine_game_name(args, exe_path)
                    if name:
                        games[f"lutris:{pid_dir.name}:{name}"] = name

                # Heroic launcher games
                if any(h in args.lower() for h in HEROIC_PATTERNS):
                    name = _extract_heroic_game_name(args)
                    if name:
                        games[f"heroic:{name}"] = name

                # Generic Wine/Proton .exe (not already captured by Steam)
                if exe_path and any(exe_path.endswith(w) for w in ("/wine", "/wine64", "/wine-preloader")):
                    if ".exe" in args.lower():
                        name = _extract_wine_game_name(args, exe_path)
                        key = f"wine:{name}" if name else f"wine:{pid_dir.name}"
                        if key not in games and name:
                            games[key] = name

            except (PermissionError, OSError, IOError):
                continue
    except OSError:
        pass

    return games


def _extract_wine_game_name(cmdline, exe_path):
    """Try to extract a meaningful game name from Wine process args."""
    # Look for .exe name in the command line
    m = re.search(r'[\\/]([^\\/]+)\.exe', cmdline, re.IGNORECASE)
    if m:
        name = m.group(1)
        # Skip common non-game executables
        skip = {"explorer", "services", "winedevice", "plugplay", "svchost",
                "rpcss", "tabtip", "conhost", "cmd", "start", "wineconsole",
                "winedbg", "crashreporter", "uninstall", "setup", "installer"}
        if name.lower() not in skip:
            return name
    return None


def _extract_heroic_game_name(cmdline):
    """Try to extract game name from Heroic launcher process."""
    # Heroic stores games in ~/Games/Heroic/<title>/
    m = re.search(r'/Games/Heroic/([^/]+)/', cmdline)
    if m:
        return m.group(1)
    m = re.search(r'--game[= ]([^\s]+)', cmdline)
    if m:
        return m.group(1).replace("-", " ").title()
    return None


def is_gamemode_active():
    """Check if GameMode is currently active (a signal someone is gaming)."""
    try:
        result = subprocess.run(
            ["gamemoded", "-s"], capture_output=True, text=True, timeout=5
        )
        return "active" in result.stdout.lower()
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        return False


# ── Notifications ──

def notify(title, body):
    """Send a desktop notification (best effort)."""
    try:
        subprocess.Popen(
            ["notify-send", "-a", "24HG Game Timer", "-i", "applications-games", title, body],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    except (FileNotFoundError, OSError):
        pass


# ── Hub Integration ──

def sync_to_hub(game_name, duration_secs, start_time, end_time):
    """POST session data to 24HG Hub API (fire and forget)."""
    if not os.path.exists(HUB_TOKEN_FILE):
        return
    try:
        with open(HUB_TOKEN_FILE, "r") as f:
            token = f.read().strip()
        if not token:
            return
    except IOError:
        return

    payload = json.dumps({
        "game": game_name,
        "duration": int(duration_secs),
        "start": start_time,
        "end": end_time,
        "source": "24hg-game-timer",
    }).encode("utf-8")

    req = urllib.request.Request(
        HUB_API_URL,
        data=payload,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {token}",
        },
        method="POST",
    )
    try:
        urllib.request.urlopen(req, timeout=10)
    except (urllib.error.URLError, OSError, ValueError):
        pass  # Fire and forget


# ── Session Management ──

def start_session(game_name, source="manual"):
    """Start tracking a new game session."""
    data = load_data()
    # Check if already tracking this game
    for s in data["active"]:
        if s["game"] == game_name:
            print(f"Already tracking: {game_name} (started {_format_ago(s['start'])})")
            return
    now = time.time()
    data["active"].append({
        "game": game_name,
        "start": now,
        "start_iso": datetime.fromtimestamp(now).isoformat(),
        "source": source,
    })
    save_data(data)
    print(f"Started tracking: {game_name}")


def stop_session(game_name=None):
    """Stop tracking a game session. Returns the completed session or None."""
    data = load_data()
    if not data["active"]:
        print("No active sessions.")
        return None

    target = None
    if game_name:
        for s in data["active"]:
            if s["game"].lower() == game_name.lower():
                target = s
                break
        if not target:
            print(f"No active session for: {game_name}")
            return None
    else:
        # Stop most recent
        target = data["active"][-1]

    data["active"].remove(target)
    now = time.time()
    duration = now - target["start"]
    session = {
        "game": target["game"],
        "start": target["start"],
        "end": now,
        "start_iso": target.get("start_iso", datetime.fromtimestamp(target["start"]).isoformat()),
        "end_iso": datetime.fromtimestamp(now).isoformat(),
        "duration": duration,
        "source": target.get("source", "manual"),
    }
    data["sessions"].append(session)
    save_data(data)

    dur_str = _format_duration(duration)
    print(f"Stopped tracking: {target['game']} ({dur_str})")
    notify(f"{target['game']} session ended", f"Played for {dur_str}")
    sync_to_hub(target["game"], duration, session["start_iso"], session["end_iso"])
    return session


def stop_session_by_name_silent(game_name, data):
    """Stop a session during daemon mode without printing. Returns updated data."""
    target = None
    for s in data["active"]:
        if s["game"] == game_name:
            target = s
            break
    if not target:
        return data

    data["active"].remove(target)
    now = time.time()
    duration = now - target["start"]
    session = {
        "game": target["game"],
        "start": target["start"],
        "end": now,
        "start_iso": target.get("start_iso", datetime.fromtimestamp(target["start"]).isoformat()),
        "end_iso": datetime.fromtimestamp(now).isoformat(),
        "duration": duration,
        "source": target.get("source", "daemon"),
    }
    data["sessions"].append(session)

    dur_str = _format_duration(duration)
    notify(f"{target['game']} session ended", f"Played for {dur_str}")
    sync_to_hub(target["game"], duration, session["start_iso"], session["end_iso"])
    return data


# ── Formatting Helpers ──

def _format_duration(secs):
    """Format seconds as human-readable duration."""
    secs = int(secs)
    if secs < 60:
        return f"{secs}s"
    mins = secs // 60
    if mins < 60:
        return f"{mins}m {secs % 60}s"
    hours = mins // 60
    remaining_mins = mins % 60
    if hours < 24:
        return f"{hours}h {remaining_mins}m"
    days = hours // 24
    return f"{days}d {hours % 24}h {remaining_mins}m"


def _format_ago(timestamp):
    """Format a timestamp as 'X ago'."""
    delta = time.time() - timestamp
    return _format_duration(delta) + " ago"


def _format_datetime(timestamp):
    """Format a timestamp as a readable date/time."""
    return datetime.fromtimestamp(timestamp).strftime("%Y-%m-%d %H:%M")


# ── Commands ──

def cmd_status():
    """Show currently active sessions."""
    data = load_data()
    if not data["active"]:
        print("No active game sessions.")
        return
    print(f"{'Game':<30} {'Started':<20} {'Elapsed':>12}")
    print("-" * 64)
    for s in data["active"]:
        elapsed = _format_duration(time.time() - s["start"])
        started = _format_datetime(s["start"])
        print(f"{s['game']:<30} {started:<20} {elapsed:>12}")


def cmd_stats(game_name=None):
    """Show playtime statistics for a game or top 10."""
    data = load_data()
    sessions = data.get("sessions", [])
    if not sessions:
        print("No recorded sessions yet.")
        return

    if game_name:
        _show_game_stats(game_name, sessions)
    else:
        _show_top_games(sessions)


def _show_game_stats(game_name, sessions):
    """Display detailed stats for a single game."""
    matching = [s for s in sessions if s["game"].lower() == game_name.lower()]
    if not matching:
        print(f"No sessions found for: {game_name}")
        return

    actual_name = matching[0]["game"]
    total = sum(s["duration"] for s in matching)
    count = len(matching)
    avg = total / count
    longest = max(s["duration"] for s in matching)
    last = max(s["end"] for s in matching)

    print(f"Stats for: {actual_name}")
    print("-" * 40)
    print(f"  Total playtime:     {_format_duration(total)}")
    print(f"  Sessions:           {count}")
    print(f"  Average session:    {_format_duration(avg)}")
    print(f"  Longest session:    {_format_duration(longest)}")
    print(f"  Last played:        {_format_datetime(last)}")


def _show_top_games(sessions):
    """Display top 10 games by total playtime."""
    totals = {}
    counts = {}
    for s in sessions:
        name = s["game"]
        totals[name] = totals.get(name, 0) + s["duration"]
        counts[name] = counts.get(name, 0) + 1

    ranked = sorted(totals.items(), key=lambda x: x[1], reverse=True)[:10]
    if not ranked:
        print("No recorded sessions yet.")
        return

    print(f"{'#':<4} {'Game':<30} {'Playtime':>12} {'Sessions':>10}")
    print("-" * 58)
    for i, (name, total) in enumerate(ranked, 1):
        print(f"{i:<4} {name:<30} {_format_duration(total):>12} {counts[name]:>10}")


def cmd_report(period="weekly"):
    """Generate a playtime report for the given period."""
    data = load_data()
    sessions = data.get("sessions", [])
    if not sessions:
        print("No recorded sessions yet.")
        return

    now = time.time()
    if period in ("week", "weekly"):
        cutoff = now - 7 * 86400
        label = "Weekly Report (last 7 days)"
    elif period in ("month", "monthly"):
        cutoff = now - 30 * 86400
        label = "Monthly Report (last 30 days)"
    elif period in ("all", "all-time", "alltime"):
        cutoff = 0
        label = "All-Time Report"
    else:
        print(f"Unknown period: {period}. Use: weekly, monthly, all-time")
        return

    filtered = [s for s in sessions if s["end"] >= cutoff]
    if not filtered:
        print(f"{label}\n  No sessions in this period.")
        return

    # Per-game breakdown
    totals = {}
    counts = {}
    for s in filtered:
        name = s["game"]
        totals[name] = totals.get(name, 0) + s["duration"]
        counts[name] = counts.get(name, 0) + 1

    ranked = sorted(totals.items(), key=lambda x: x[1], reverse=True)
    grand_total = sum(totals.values())
    days = max(1, (now - cutoff) / 86400) if cutoff > 0 else max(1, (now - min(s["start"] for s in sessions)) / 86400)
    avg_per_day = grand_total / days

    print(f"\n  {label}")
    print(f"  {'=' * 56}")
    print(f"  {'Game':<30} {'Time':>12} {'Sessions':>10}")
    print(f"  {'-' * 56}")
    for name, total in ranked:
        print(f"  {name:<30} {_format_duration(total):>12} {counts[name]:>10}")
    print(f"  {'-' * 56}")
    print(f"  {'Total':<30} {_format_duration(grand_total):>12} {sum(counts.values()):>10}")
    print(f"  Average per day: {_format_duration(avg_per_day)}")
    print()


def cmd_export():
    """Export all data as JSON to stdout."""
    data = load_data()
    json.dump(data, sys.stdout, indent=2)
    sys.stdout.write("\n")


# ── Daemon Mode ──

def cmd_daemon():
    """Run as a daemon, auto-detecting game sessions by polling /proc."""
    print("24hg-game-timer daemon started (Ctrl+C to stop)")
    print(f"Polling /proc every {POLL_INTERVAL}s for game processes...")

    # Track which daemon-started games we're monitoring
    tracked_keys = {}  # key -> game_name

    while running:
        try:
            detected = get_running_games()
            data = load_data()

            # Also check GameMode as a general gaming signal
            gamemode_active = is_gamemode_active()

            # Start sessions for newly detected games
            current_game_names = set()
            for key, name in detected.items():
                current_game_names.add(name)
                if key not in tracked_keys:
                    # New game detected
                    already_active = any(s["game"] == name for s in data["active"])
                    if not already_active:
                        now = time.time()
                        data["active"].append({
                            "game": name,
                            "start": now,
                            "start_iso": datetime.fromtimestamp(now).isoformat(),
                            "source": "daemon",
                        })
                        print(f"[{datetime.now().strftime('%H:%M:%S')}] Detected: {name}")
                    tracked_keys[key] = name

            # Stop sessions for games that are no longer running
            stale_keys = [k for k in tracked_keys if k not in detected]
            for key in stale_keys:
                name = tracked_keys.pop(key)
                # Only stop if no other key is still tracking the same game
                if name not in current_game_names:
                    data = stop_session_by_name_silent(name, data)
                    print(f"[{datetime.now().strftime('%H:%M:%S')}] Ended: {name}")

            save_data(data)

        except Exception as e:
            print(f"[{datetime.now().strftime('%H:%M:%S')}] Error: {e}", file=sys.stderr)

        # Sleep in small increments so we respond to signals
        for _ in range(POLL_INTERVAL):
            if not running:
                break
            time.sleep(1)

    # Daemon shutting down — close any remaining daemon-started sessions
    print("\nDaemon stopping, closing active daemon sessions...")
    data = load_data()
    daemon_active = [s for s in data["active"] if s.get("source") == "daemon"]
    for s in daemon_active:
        data = stop_session_by_name_silent(s["game"], data)
        print(f"  Closed: {s['game']}")
    save_data(data)
    print("Daemon stopped.")


# ── Help ──

HELP_TEXT = """\
24hg-game-timer — Track playtime across all game launchers

Usage:
  24hg-game-timer start <game>       Start tracking a game session manually
  24hg-game-timer stop [game]        Stop tracking (most recent if no game)
  24hg-game-timer status             Show active sessions with elapsed time
  24hg-game-timer stats [game]       Playtime stats (top 10 if no game)
  24hg-game-timer report [period]    Report: weekly (default), monthly, all-time
  24hg-game-timer export             Export all data as JSON to stdout
  24hg-game-timer daemon             Auto-detect sessions (poll /proc every 30s)
  24hg-game-timer help               Show this help text

Daemon mode detects:
  - Steam games (via AppID in process environment/cmdline)
  - Lutris/Wine games (via .exe in Wine process cmdline)
  - Heroic launcher games (via ~/Games/Heroic paths)
  - GameMode activation (as a general gaming signal)

Data stored in: ~/.local/share/24hg/game-timer.json

Hub integration:
  If ~/.config/24hg/hub-token exists, sessions are synced to the
  24HG Hub API at https://api.24hgaming.com/activity/playtime.
  This is fire-and-forget; failures are silently ignored.

Desktop notifications are sent when sessions end (via notify-send).
"""


# ── Main ──

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("help", "--help", "-h"):
        print(HELP_TEXT)
        return

    cmd = sys.argv[1].lower()

    if cmd == "start":
        if len(sys.argv) < 3:
            print("Usage: 24hg-game-timer start <game>")
            sys.exit(1)
        game = " ".join(sys.argv[2:])
        start_session(game, source="manual")

    elif cmd == "stop":
        game = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else None
        stop_session(game)

    elif cmd == "status":
        cmd_status()

    elif cmd == "stats":
        game = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else None
        cmd_stats(game)

    elif cmd == "report":
        period = sys.argv[2] if len(sys.argv) > 2 else "weekly"
        cmd_report(period)

    elif cmd == "export":
        cmd_export()

    elif cmd == "daemon":
        cmd_daemon()

    else:
        print(f"Unknown command: {cmd}")
        print("Run '24hg-game-timer help' for usage.")
        sys.exit(1)


if __name__ == "__main__":
    main()
