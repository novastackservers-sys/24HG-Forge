        },
        {
            "prev_ver": 503316482,
            "name": "Desktop Audio",
            "uuid": "a1b2c3d4-0004-4000-8000-000000000004",
            "id": "pulse_output_capture",
            "versioned_id": "pulse_output_capture",
            "settings": {
                "device_id": "default"
            },
            "mixers": 3,
            "flags": 0,
