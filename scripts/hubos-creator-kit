# ─── ImageMagick Helpers ─────────────────────────────────────────────
_magick_cmd() {
    # Use 'magick' (ImageMagick 7) or 'convert' (ImageMagick 6)
    if command -v magick &>/dev/null; then
        magick "$@"
    elif command -v convert &>/dev/null; then
        convert "$@"
    else
        error "ImageMagick not found. Install with: sudo dnf install ImageMagick"
        return 1
    fi
}

_generate_watermark_image() {
    local output="$1"
    local opacity="${2:-30}"
    local alpha_hex
    alpha_hex=$(printf '%02x' $(( opacity * 255 / 100 )))
    _magick_cmd -size 320x60 xc:transparent \
        -font "Inter" -pointsize 28 -weight 600 \
        -fill "#ffffff${alpha_hex}" \
        -gravity center -annotate +0+0 "Powered by HubOS" \
        "$output" 2>/dev/null || \
    _magick_cmd -size 320x60 xc:transparent \
        -pointsize 28 \
        -fill "#ffffff${alpha_hex}" \
        -gravity center -annotate +0+0 "Powered by HubOS" \
        "$output"
}

_generate_scene_background() {
    local output="$1" main_text="$2" sub_text="${3:-}"
    # Dark gradient background with subtle grid pattern
    _magick_cmd -size 1920x1080 \
        -define gradient:angle=135 \
        "gradient:${COLOR_BG}-${COLOR_BG_LIGHT}" \
        -fill "rgba(0,212,255,0.03)" \
        -draw "line 0,0 1920,1080" \
        -draw "line 0,1080 1920,0" \
        \( -size 1920x1080 xc:transparent \
           -fill "rgba(0,212,255,0.05)" \
           -draw "rectangle 0,535 1920,545" \
           -draw "rectangle 955,0 965,1080" \
        \) -composite \
        \( -size 1920x1080 xc:transparent \
           -font "Inter" -pointsize 72 -weight 700 \
           -fill "${COLOR_PRIMARY}" \
           -gravity center -annotate +0-60 "$main_text" \
        \) -composite \
        "$output" 2>/dev/null || \
    _magick_cmd -size 1920x1080 \
        xc:"${COLOR_BG}" \
        -pointsize 72 \
        -fill "${COLOR_PRIMARY}" \
        -gravity center -annotate +0-60 "$main_text" \
        "$output"

    # Add sub-text if provided
    if [ -n "$sub_text" ]; then
        _magick_cmd "$output" \
            \( -size 1920x1080 xc:transparent \
               -pointsize 28 \
               -fill "${COLOR_TEXT}" \
               -gravity center -annotate +0+80 "$sub_text" \
            \) -composite \
            "$output" 2>/dev/null || true
    fi
}

# ─── Command: overlay ────────────────────────────────────────────────
cmd_overlay() {
    header "HubOS Creator Kit — Stream Overlay Generator"

    require_cmd convert ImageMagick || require_cmd magick ImageMagick || exit 1

    mkdir -p "$OVERLAYS_DIR/dark" "$OVERLAYS_DIR/light"
    local total=12 current=0

    # 1. Webcam frame — dark variant
    current=$((current + 1)); progress_bar $current $total "Webcam frame (dark)"
    _magick_cmd -size 372x214 xc:transparent \
        -fill none -stroke "${COLOR_PRIMARY}" -strokewidth 4 \
        -draw "roundrectangle 2,2 370,212 12,12" \
        \( -size 60x24 xc:"#ff0000" \
           -fill white -pointsize 14 -gravity center -annotate +0+0 "LIVE" \
           -draw "roundrectangle 0,0 59,23 6,6" \
        \) -gravity northwest -geometry +8+8 -composite \
        "$OVERLAYS_DIR/dark/webcam-frame.png" 2>/dev/null || \
    _magick_cmd -size 372x214 xc:transparent \
        -fill none -stroke "${COLOR_PRIMARY}" -strokewidth 4 \
        -draw "roundrectangle 2,2 370,212 12,12" \
        "$OVERLAYS_DIR/dark/webcam-frame.png"

    # 2. Webcam frame — light variant
    current=$((current + 1)); progress_bar $current $total "Webcam frame (light)"
    _magick_cmd -size 372x214 xc:transparent \
        -fill none -stroke "#0088aa" -strokewidth 4 \
        -draw "roundrectangle 2,2 370,212 12,12" \
        "$OVERLAYS_DIR/light/webcam-frame.png" 2>/dev/null || \
    _magick_cmd -size 372x214 xc:transparent \
        -fill none -stroke "#0088aa" -strokewidth 4 \
        -draw "roundrectangle 2,2 370,212 12,12" \
        "$OVERLAYS_DIR/light/webcam-frame.png"

    # 3. Lower third banner — dark
    current=$((current + 1)); progress_bar $current $total "Lower third (dark)"
    _magick_cmd -size 1920x100 xc:transparent \
        -fill "rgba(10,10,20,0.85)" \
        -draw "roundrectangle 0,0 1919,99 0,0" \
        -fill "${COLOR_PRIMARY}" \
        -draw "rectangle 0,0 6,100" \
        -pointsize 24 \
        -fill "${COLOR_TEXT_BRIGHT}" \
        -gravity west -annotate +24+0 "Playing on 24HG  |  os.24hgaming.com" \
        -pointsize 16 \
        -fill "rgba(0,212,255,0.8)" \
        -gravity east -annotate +24+0 "Powered by HubOS" \
        "$OVERLAYS_DIR/dark/lower-third.png" 2>/dev/null || \
    _magick_cmd -size 1920x100 xc:"rgba(10,10,20,0.85)" \
        -pointsize 24 -fill white \
        -gravity center -annotate +0+0 "Playing on 24HG | os.24hgaming.com | Powered by HubOS" \
        "$OVERLAYS_DIR/dark/lower-third.png"

    # 4. Lower third banner — light
    current=$((current + 1)); progress_bar $current $total "Lower third (light)"
    _magick_cmd -size 1920x100 xc:transparent \
        -fill "rgba(240,240,255,0.90)" \
        -draw "roundrectangle 0,0 1919,99 0,0" \
        -fill "${COLOR_PRIMARY}" \
        -draw "rectangle 0,0 6,100" \
        -pointsize 24 \
        -fill "#1a1a2e" \
        -gravity west -annotate +24+0 "Playing on 24HG  |  os.24hgaming.com" \
        -pointsize 16 \
        -fill "#0088aa" \
        -gravity east -annotate +24+0 "Powered by HubOS" \
        "$OVERLAYS_DIR/light/lower-third.png" 2>/dev/null || \
    _magick_cmd -size 1920x100 xc:"rgba(240,240,255,0.90)" \
        -pointsize 24 -fill "#1a1a2e" \
        -gravity center -annotate +0+0 "Playing on 24HG | os.24hgaming.com" \
        "$OVERLAYS_DIR/light/lower-third.png"

    # 5. Watermark — dark
    current=$((current + 1)); progress_bar $current $total "Watermark (dark)"
    _generate_watermark_image "$OVERLAYS_DIR/dark/hubos-watermark.png" "$WM_OPACITY"

    # 6. Watermark — light
    current=$((current + 1)); progress_bar $current $total "Watermark (light)"
    _magick_cmd -size 320x60 xc:transparent \
        -pointsize 28 \
        -fill "rgba(26,26,46,0.30)" \
        -gravity center -annotate +0+0 "Powered by HubOS" \
        "$OVERLAYS_DIR/light/hubos-watermark.png" 2>/dev/null || \
    _magick_cmd -size 320x60 xc:transparent \
        -pointsize 28 \
        -fill "rgba(26,26,46,0.30)" \
        -gravity center -annotate +0+0 "Powered by HubOS" \
        "$OVERLAYS_DIR/light/hubos-watermark.png"

    # 7. Social bar — dark
    current=$((current + 1)); progress_bar $current $total "Social bar (dark)"
    _magick_cmd -size 600x50 xc:transparent \
        -fill "rgba(10,10,20,0.80)" \
        -draw "roundrectangle 0,0 599,49 8,8" \
        -pointsize 18 \
        -fill "${COLOR_PRIMARY}" \
        -gravity center -annotate +0+0 "Discord: ${BRAND_DISCORD}  |  Hub: ${BRAND_HUB}" \
        "$OVERLAYS_DIR/dark/social-bar.png" 2>/dev/null || \
    _magick_cmd -size 600x50 xc:"rgba(10,10,20,0.80)" \
        -pointsize 18 -fill "${COLOR_PRIMARY}" \
        -gravity center -annotate +0+0 "Discord: ${BRAND_DISCORD} | Hub: ${BRAND_HUB}" \
        "$OVERLAYS_DIR/dark/social-bar.png"

    # 8. Social bar — light
    current=$((current + 1)); progress_bar $current $total "Social bar (light)"
    _magick_cmd -size 600x50 xc:transparent \
        -fill "rgba(240,240,255,0.85)" \
        -draw "roundrectangle 0,0 599,49 8,8" \
        -pointsize 18 \
        -fill "#0088aa" \
        -gravity center -annotate +0+0 "Discord: ${BRAND_DISCORD}  |  Hub: ${BRAND_HUB}" \
        "$OVERLAYS_DIR/light/social-bar.png" 2>/dev/null || \
    _magick_cmd -size 600x50 xc:"rgba(240,240,255,0.85)" \
        -pointsize 18 -fill "#0088aa" \
        -gravity center -annotate +0+0 "Discord: ${BRAND_DISCORD} | Hub: ${BRAND_HUB}" \
        "$OVERLAYS_DIR/light/social-bar.png"

    # 9-10. Alert backgrounds (follower, subscriber, donation)
    current=$((current + 1)); progress_bar $current $total "Alert boxes (dark)"
    for alert_type in "follower:New Follower" "subscriber:New Sub" "donation:Donation"; do
        local atype="${alert_type%%:*}" alabel="${alert_type##*:}"
        _magick_cmd -size 400x120 xc:transparent \
            -fill "rgba(10,10,20,0.90)" \
            -draw "roundrectangle 0,0 399,119 12,12" \
            -fill "${COLOR_PRIMARY}" \
            -draw "rectangle 0,0 5,120" \
            -pointsize 22 \
            -fill "${COLOR_PRIMARY}" \
            -gravity northwest -annotate +20+18 "$alabel!" \
            -pointsize 16 \
            -fill "${COLOR_TEXT}" \
            -gravity northwest -annotate +20+52 "{name}" \
            -pointsize 12 \
            -fill "rgba(0,212,255,0.5)" \
            -gravity southeast -annotate +12+12 "24HG" \
            "$OVERLAYS_DIR/dark/alert-${atype}.png" 2>/dev/null || \
        _magick_cmd -size 400x120 xc:"rgba(10,10,20,0.90)" \
            -pointsize 22 -fill "${COLOR_PRIMARY}" \
            -gravity center -annotate +0+0 "$alabel!" \
            "$OVERLAYS_DIR/dark/alert-${atype}.png"
    done

    current=$((current + 1)); progress_bar $current $total "Alert boxes (light)"
    for alert_type in "follower:New Follower" "subscriber:New Sub" "donation:Donation"; do
        local atype="${alert_type%%:*}" alabel="${alert_type##*:}"
        _magick_cmd -size 400x120 xc:transparent \
            -fill "rgba(240,240,255,0.92)" \
            -draw "roundrectangle 0,0 399,119 12,12" \
            -fill "#0088aa" \
            -draw "rectangle 0,0 5,120" \
            -pointsize 22 \
            -fill "#0088aa" \
            -gravity northwest -annotate +20+18 "$alabel!" \
            -pointsize 16 \
            -fill "#333333" \
            -gravity northwest -annotate +20+52 "{name}" \
            "$OVERLAYS_DIR/light/alert-${atype}.png" 2>/dev/null || \
        _magick_cmd -size 400x120 xc:"rgba(240,240,255,0.92)" \
            -pointsize 22 -fill "#0088aa" \
            -gravity center -annotate +0+0 "$alabel!" \
            "$OVERLAYS_DIR/light/alert-${atype}.png"
    done

    # 11. Scene backgrounds (Starting Soon, BRB, Ending)
    current=$((current + 1)); progress_bar $current $total "Scene backgrounds"
    _generate_scene_background "$OVERLAYS_DIR/starting-soon-bg.png" "STARTING SOON" "${BRAND_DISCORD}  |  ${BRAND_HUB}  |  ${BRAND_URL}"
    _generate_scene_background "$OVERLAYS_DIR/brb-bg.png" "BE RIGHT BACK" "Hang tight — we'll be back shortly"
    _generate_scene_background "$OVERLAYS_DIR/ending-bg.png" "THANKS FOR WATCHING" "Join us at 24hgaming.com  |  Discord: ${BRAND_DISCORD}"

    # 12. Copy default variant to root overlays
    current=$((current + 1)); progress_bar $current $total "Finalizing"
    for f in "$OVERLAYS_DIR/dark/"*.png; do
        [ -f "$f" ] && cp "$f" "$OVERLAYS_DIR/$(basename "$f")"
    done

    echo ""
    success "All overlays generated!"
    echo ""
    echo -e "  ${BOLD}Output directory:${NC} $OVERLAYS_DIR"
    echo ""
    echo -e "  ${BOLD}Dark variants:${NC}  $OVERLAYS_DIR/dark/"
    echo -e "  ${BOLD}Light variants:${NC} $OVERLAYS_DIR/light/"
    echo ""
    echo -e "  ${BOLD}Files:${NC}"
    echo -e "    webcam-frame.png     — Rounded cyan border with LIVE indicator"
    echo -e "    lower-third.png      — \"Playing on 24HG\" banner"
    echo -e "    hubos-watermark.png  — Semi-transparent \"Powered by HubOS\""
    echo -e "    social-bar.png       — Discord and Hub links"
    echo -e "    alert-follower.png   — Follower alert background"
    echo -e "    alert-subscriber.png — Subscriber alert background"
    echo -e "    alert-donation.png   — Donation alert background"
    echo -e "    starting-soon-bg.png — Starting Soon scene background"
    echo -e "    brb-bg.png           — BRB scene background"
    echo -e "    ending-bg.png        — Ending scene background"
}

# ─── Command: clip ───────────────────────────────────────────────────
cmd_clip() {
    local subcommand="${1:-help}"
    shift || true

    load_config
    mkdir -p "$CLIPS_DIR"

    case "$subcommand" in
        last)
            _clip_last "${1:-30}"
            ;;
        screenshot)
            _clip_screenshot
            ;;
        gif)
            _clip_gif "${1:-10}"
            ;;
        help|*)
            echo -e "${BOLD}HubOS Creator Kit — Clip Tool${NC}"
            echo ""
            echo -e "  ${CYAN}hubos-creator-kit clip last [seconds]${NC}     — Save last N seconds"
            echo -e "  ${CYAN}hubos-creator-kit clip screenshot${NC}         — Capture screenshot"
            echo -e "  ${CYAN}hubos-creator-kit clip gif [seconds]${NC}      — Capture animated GIF"
            echo ""
            echo -e "  Clips saved to: $CLIPS_DIR"
            echo -e "  Watermark: ${WM_ENABLED} (${WM_OPACITY}% opacity, ${WM_POSITION})"
            ;;
    esac
}

_clip_last() {
    local duration="${1:-30}"
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local output="$CLIPS_DIR/clip_${timestamp}.mp4"

    step "Saving last ${duration}s of gameplay..."

    # Try gpu-screen-recorder replay first
    if command -v gpu-screen-recorder &>/dev/null; then
        local replay_pid_file="${XDG_RUNTIME_DIR:-/tmp}/hubos-replay/replay.pid"
        if [ -f "$replay_pid_file" ] && kill -0 "$(cat "$replay_pid_file")" 2>/dev/null; then
            # Signal the replay buffer to save
            kill -USR1 "$(cat "$replay_pid_file")" 2>/dev/null
            info "Signaled replay buffer to save clip"
            # Wait a moment for file to appear
            sleep 2
            local latest_clip
            latest_clip=$(find "$HOME/Videos/HubOS Clips" -name '*.mp4' -newer "$replay_pid_file" -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)
            if [ -n "$latest_clip" ] && [ -f "$latest_clip" ]; then
                if [ "$WM_ENABLED" = "true" ]; then
                    _apply_watermark_video "$latest_clip" "$output"
                    success "Clip saved: $output (watermarked)"
                else
                    cp "$latest_clip" "$output"
                    success "Clip saved: $output"
                fi
                return 0
            fi
        fi
    fi

    # Fallback: record last N seconds using ffmpeg screen capture
    info "No active replay buffer — recording ${duration}s now..."
    local encoder_args=()
    local gpu_vendor
    gpu_vendor=$(detect_gpu_vendor)
    case "$gpu_vendor" in
        nvidia)
            encoder_args=(-c:v h264_nvenc -preset p4 -cq 23)
            ;;
        amd|intel)
            if [ -e /dev/dri/renderD128 ]; then
                encoder_args=(-vaapi_device /dev/dri/renderD128 -c:v h264_vaapi -qp 23)
            else
                encoder_args=(-c:v libx264 -preset fast -crf 23)
            fi
            ;;
        *)
            encoder_args=(-c:v libx264 -preset fast -crf 23)
            ;;
    esac

    local capture_input=()
    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        # Wayland: use PipeWire capture via wf-recorder or ffmpeg pipewire
        if command -v wf-recorder &>/dev/null; then
            wf-recorder -d /dev/dri/renderD128 -f "$output" --duration "$duration" 2>/dev/null &
            local rec_pid=$!
            _show_recording_timer "$duration" "$rec_pid"
            wait "$rec_pid" 2>/dev/null || true
        else
            warn "wf-recorder not found for Wayland capture. Install: sudo dnf install wf-recorder"
            return 1
        fi
    else
        # X11: ffmpeg with x11grab
        require_cmd ffmpeg ffmpeg || return 1
        local screen_res
        screen_res=$(detect_resolution)
        ffmpeg -y -video_size "$screen_res" -framerate 60 -f x11grab -i "${DISPLAY:-:0}" \
            -f pulse -i default \
            "${encoder_args[@]}" -c:a aac -b:a 160k \
            -t "$duration" "$output" &>/dev/null &
        local rec_pid=$!
        _show_recording_timer "$duration" "$rec_pid"
        wait "$rec_pid" 2>/dev/null || true
    fi

    if [ -f "$output" ]; then
        if [ "$WM_ENABLED" = "true" ]; then
            local tmp_output="${output%.mp4}_nowm.mp4"
            mv "$output" "$tmp_output"
            _apply_watermark_video "$tmp_output" "$output"
            rm -f "$tmp_output"
            success "Clip saved: $output (watermarked)"
        else
            success "Clip saved: $output"
        fi
    else
        error "Failed to capture clip"
    fi
}

_show_recording_timer() {
    local duration=$1 pid=$2
    local elapsed=0
    while [ $elapsed -lt "$duration" ] && kill -0 "$pid" 2>/dev/null; do
        progress_bar $elapsed "$duration" "Recording..."
        sleep 1
        elapsed=$((elapsed + 1))
    done
    progress_bar "$duration" "$duration" "Done"
}

_clip_screenshot() {
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local output="$CLIPS_DIR/screenshot_${timestamp}.png"

    step "Capturing screenshot..."

    # Capture
    local raw_output="/tmp/hubos-screenshot-raw-$$.png"
    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        if command -v grim &>/dev/null; then
            grim "$raw_output"
        elif command -v spectacle &>/dev/null; then
            spectacle -b -n -f -o "$raw_output"
        else
            error "No screenshot tool. Install grim or spectacle."
            return 1
        fi
    else
        if command -v spectacle &>/dev/null; then
            spectacle -b -n -f -o "$raw_output"
        elif command -v scrot &>/dev/null; then
            scrot "$raw_output"
        else
            error "No screenshot tool found."
            return 1
        fi
    fi

    if [ ! -f "$raw_output" ]; then
        error "Screenshot capture failed"
        return 1
    fi

    # Apply watermark if enabled
    if [ "$WM_ENABLED" = "true" ] && (command -v magick &>/dev/null || command -v convert &>/dev/null); then
        local wm_gravity=""
        case "$WM_POSITION" in
            top-left)     wm_gravity="northwest" ;;
            top-right)    wm_gravity="northeast" ;;
            bottom-left)  wm_gravity="southwest" ;;
            bottom-right) wm_gravity="southeast" ;;
            *)            wm_gravity="southeast" ;;
        esac
        local alpha_hex
        alpha_hex=$(printf '%02x' $(( WM_OPACITY * 255 / 100 )))
        _magick_cmd "$raw_output" \
            -pointsize 20 \
            -fill "rgba(255,255,255,0.${WM_OPACITY})" \
            -gravity "$wm_gravity" -annotate +15+15 "Powered by HubOS" \
            "$output" 2>/dev/null || cp "$raw_output" "$output"
        rm -f "$raw_output"
    else
        mv "$raw_output" "$output"
    fi

    success "Screenshot saved: $output"
}

_clip_gif() {
    local duration="${1:-10}"
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local output="$CLIPS_DIR/gif_${timestamp}.gif"

    require_cmd ffmpeg ffmpeg || return 1

    step "Capturing ${duration}s GIF..."

    local screen_res
    screen_res=$(detect_resolution)
    # Scale to 640px wide for reasonable GIF size
    local palette="/tmp/hubos-gif-palette-$$.png"

    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        if command -v wf-recorder &>/dev/null; then
            local tmp_vid="/tmp/hubos-gif-raw-$$.mp4"
            wf-recorder -d /dev/dri/renderD128 -f "$tmp_vid" --duration "$duration" 2>/dev/null &
            local rec_pid=$!
            _show_recording_timer "$duration" "$rec_pid"
            wait "$rec_pid" 2>/dev/null || true
            # Convert to GIF with palette optimization
            ffmpeg -y -i "$tmp_vid" -vf "fps=15,scale=640:-1:flags=lanczos,palettegen" "$palette" &>/dev/null
            ffmpeg -y -i "$tmp_vid" -i "$palette" -lavfi "fps=15,scale=640:-1:flags=lanczos[x];[x][1:v]paletteuse" "$output" &>/dev/null
            rm -f "$tmp_vid" "$palette"
        else
            warn "wf-recorder not found for Wayland GIF capture"
            return 1
        fi
    else
        # X11: two-pass GIF with palette
        ffmpeg -y -video_size "$screen_res" -framerate 15 -f x11grab -i "${DISPLAY:-:0}" \
            -t "$duration" -vf "fps=15,scale=640:-1:flags=lanczos,palettegen" "$palette" &>/dev/null
        ffmpeg -y -video_size "$screen_res" -framerate 15 -f x11grab -i "${DISPLAY:-:0}" \
            -t "$duration" -i "$palette" -lavfi "fps=15,scale=640:-1:flags=lanczos[x];[x][1:v]paletteuse" "$output" &>/dev/null
        rm -f "$palette"
    fi

    if [ -f "$output" ]; then
        local size
        size=$(du -h "$output" | cut -f1)
        success "GIF saved: $output ($size)"
    else
        error "Failed to capture GIF"
    fi
}

_apply_watermark_video() {
    local input="$1" output="$2"
    local wm_x="" wm_y=""
    case "$WM_POSITION" in
        top-left)     wm_x="15"; wm_y="15" ;;
        top-right)    wm_x="W-tw-15"; wm_y="15" ;;
        bottom-left)  wm_x="15"; wm_y="H-th-15" ;;
        bottom-right) wm_x="W-tw-15"; wm_y="H-th-15" ;;
        *)            wm_x="W-tw-15"; wm_y="H-th-15" ;;
    esac
    local alpha
    alpha=$(awk "BEGIN{printf \"%.2f\", $WM_OPACITY / 100}")
    ffmpeg -y -i "$input" \
        -vf "drawtext=text='Powered by HubOS':fontsize=18:fontcolor=white@${alpha}:x=${wm_x}:y=${wm_y}" \
        -c:a copy "$output" &>/dev/null
}

# ─── Command: watermark ─────────────────────────────────────────────
cmd_watermark() {
    local subcommand="${1:-status}"
    shift || true
    load_config

    case "$subcommand" in
        on|enable)
            WM_ENABLED="true"
            save_config
            success "Watermark enabled"
            ;;
        off|disable)
            WM_ENABLED="false"
            save_config
            success "Watermark disabled"
            ;;
        position)
            local pos="${1:-}"
            case "$pos" in
                top-left|top-right|bottom-left|bottom-right)
                    WM_POSITION="$pos"
                    save_config
                    success "Watermark position: $WM_POSITION"
                    ;;
                *)
                    echo -e "  ${BOLD}Usage:${NC} hubos-creator-kit watermark position <corner>"
                    echo -e "  ${DIM}Options: top-left, top-right, bottom-left, bottom-right${NC}"
                    ;;
            esac
            ;;
        opacity)
            local val="${1:-}"
            if [[ "$val" =~ ^[0-9]+$ ]] && [ "$val" -ge 0 ] && [ "$val" -le 100 ]; then
                WM_OPACITY="$val"
                save_config
                success "Watermark opacity: ${WM_OPACITY}%"
            else
                echo -e "  ${BOLD}Usage:${NC} hubos-creator-kit watermark opacity <0-100>"
            fi
            ;;
        preview)
            step "Generating watermark preview..."
            local preview="$CREATOR_DIR/watermark-preview.png"
            mkdir -p "$CREATOR_DIR"
            if command -v magick &>/dev/null || command -v convert &>/dev/null; then
                local wm_gravity=""
                case "$WM_POSITION" in
                    top-left)     wm_gravity="northwest" ;;
                    top-right)    wm_gravity="northeast" ;;
                    bottom-left)  wm_gravity="southwest" ;;
                    bottom-right) wm_gravity="southeast" ;;
                esac
                _magick_cmd -size 960x540 \
                    -define gradient:angle=135 \
                    "gradient:${COLOR_BG}-${COLOR_BG_LIGHT}" \
                    -pointsize 36 -fill "${COLOR_TEXT}" \
                    -gravity center -annotate +0+0 "Game Screen Preview" \
                    -pointsize 14 \
                    -fill "rgba(255,255,255,0.${WM_OPACITY})" \
                    -gravity "$wm_gravity" -annotate +10+10 "Powered by HubOS" \
                    "$preview" 2>/dev/null || \
                _magick_cmd -size 960x540 xc:"${COLOR_BG}" \
                    -pointsize 14 -fill white \
                    -gravity southeast -annotate +10+10 "Powered by HubOS" \
                    "$preview"
                success "Preview saved: $preview"
                # Try to open it
                if command -v xdg-open &>/dev/null; then
                    xdg-open "$preview" 2>/dev/null &
                fi
            else
                error "ImageMagick required for preview"
            fi
            ;;
        status|*)
            echo -e "${BOLD}HubOS Creator Kit — Watermark Settings${NC}"
            echo ""
            echo -e "  Enabled:  ${WM_ENABLED}"
            echo -e "  Position: ${WM_POSITION}"
            echo -e "  Opacity:  ${WM_OPACITY}%"
            echo ""
            echo -e "  ${BOLD}Commands:${NC}"
            echo -e "    ${CYAN}watermark on${NC}                     — Enable watermark"
            echo -e "    ${CYAN}watermark off${NC}                    — Disable watermark"
            echo -e "    ${CYAN}watermark position bottom-right${NC}  — Set position"
            echo -e "    ${CYAN}watermark opacity 30${NC}             — Set opacity (0-100)"
            echo -e "    ${CYAN}watermark preview${NC}                — Preview watermark"
            ;;
    esac
}

# ─── Command: intro ──────────────────────────────────────────────────
cmd_intro() {
    header "HubOS Creator Kit — Intro Video Generator"

    require_cmd ffmpeg ffmpeg || exit 1
    mkdir -p "$CREATOR_DIR"

    local intro_output="$CREATOR_DIR/intro.mp4"
    local transition_output="$CREATOR_DIR/transition.mp4"
    local tmp_dir="/tmp/hubos-intro-$$"
    mkdir -p "$tmp_dir"

    local total=6 current=0

    # Step 1: Generate background frames (dark with simulated particle effects)
    current=$((current + 1)); progress_bar $current $total "Background frames"
    local num_frames=150  # 5 seconds at 30fps
    local frame_w=1920 frame_h=1080

    # Generate keyframe backgrounds using ImageMagick
    if command -v magick &>/dev/null || command -v convert &>/dev/null; then
        # Create base dark frame
        _magick_cmd -size ${frame_w}x${frame_h} \
            -define gradient:angle=135 \
            "gradient:${COLOR_BG}-${COLOR_BG_LIGHT}" \
            "$tmp_dir/base.png" 2>/dev/null || \
        _magick_cmd -size ${frame_w}x${frame_h} xc:"${COLOR_BG}" "$tmp_dir/base.png"

        # Create particle overlay frames (simulated with random dots)
        for i in $(seq 0 4); do
            local particle_cmd=("$tmp_dir/base.png")
            particle_cmd+=(-fill "rgba(0,212,255,0.15)")
            # Add random "particles" — small circles at various positions
            for _ in $(seq 1 20); do
                local px=$(( RANDOM % frame_w ))
                local py=$(( RANDOM % frame_h ))
                local pr=$(( RANDOM % 3 + 1 ))
                particle_cmd+=(-draw "circle $px,$py $((px+pr)),$py")
            done
            # Add subtle glow lines
            particle_cmd+=(-fill "rgba(0,212,255,0.05)")
            local lx=$(( RANDOM % frame_w ))
            particle_cmd+=(-draw "line $lx,0 $((frame_w - lx)),$frame_h")
            particle_cmd+=("$tmp_dir/particles_${i}.png")
            _magick_cmd "${particle_cmd[@]}" 2>/dev/null || \
                cp "$tmp_dir/base.png" "$tmp_dir/particles_${i}.png"
        done
    else
        # Fallback: generate solid color frames with ffmpeg
        ffmpeg -y -f lavfi -i "color=c=0x0a0a14:s=${frame_w}x${frame_h}:d=1" \
            -frames:v 1 "$tmp_dir/base.png" &>/dev/null
    fi

    # Step 2: Generate logo frame
    current=$((current + 1)); progress_bar $current $total "Logo frame"
    if command -v magick &>/dev/null || command -v convert &>/dev/null; then
        _magick_cmd -size ${frame_w}x${frame_h} xc:transparent \
            -pointsize 120 -weight 700 \
            -fill "${COLOR_PRIMARY}" \
            -gravity center -annotate +0-40 "24HG" \
            "$tmp_dir/logo_text.png" 2>/dev/null || \
        _magick_cmd -size ${frame_w}x${frame_h} xc:transparent \
            -pointsize 120 \
            -fill "${COLOR_PRIMARY}" \
            -gravity center -annotate +0-40 "24HG" \
            "$tmp_dir/logo_text.png"

        # Cyan glow effect behind text
        _magick_cmd "$tmp_dir/logo_text.png" \
            -blur 0x20 \
            -channel A -evaluate multiply 0.6 +channel \
            "$tmp_dir/logo_glow.png" 2>/dev/null || \
            cp "$tmp_dir/logo_text.png" "$tmp_dir/logo_glow.png"
    else
        ffmpeg -y -f lavfi -i "color=c=0x0a0a14:s=${frame_w}x${frame_h}:d=1" \
            -frames:v 1 "$tmp_dir/logo_text.png" &>/dev/null
        cp "$tmp_dir/logo_text.png" "$tmp_dir/logo_glow.png"
    fi

    # Step 3: Generate "Powered by HubOS" text frame
    current=$((current + 1)); progress_bar $current $total "Subtitle frame"
    if command -v magick &>/dev/null || command -v convert &>/dev/null; then
        _magick_cmd -size ${frame_w}x${frame_h} xc:transparent \
            -pointsize 36 \
            -fill "${COLOR_TEXT}" \
            -gravity center -annotate +0+60 "Powered by HubOS" \
            "$tmp_dir/subtitle.png" 2>/dev/null || \
        _magick_cmd -size ${frame_w}x${frame_h} xc:transparent \
            -pointsize 36 \
            -fill "${COLOR_TEXT}" \
            -gravity center -annotate +0+60 "Powered by HubOS" \
            "$tmp_dir/subtitle.png"
    fi

    # Step 4: Compose the intro video with ffmpeg
    current=$((current + 1)); progress_bar $current $total "Compositing intro"

    # Build the 5-second intro:
    #   0.0-1.0s: Dark background with particles fade in
    #   1.0-2.5s: 24HG logo fades in with glow
    #   2.5-3.5s: "Powered by HubOS" fades in
    #   3.5-5.0s: Everything holds, then fades out
    local bg_input="$tmp_dir/base.png"
    [ -f "$tmp_dir/particles_0.png" ] && bg_input="$tmp_dir/particles_0.png"

    local filter_complex=""
    if [ -f "$tmp_dir/logo_glow.png" ] && [ -f "$tmp_dir/subtitle.png" ]; then
        filter_complex="[0:v]loop=loop=${num_frames}:size=1:start=0,setpts=N/30/TB,format=yuva420p[bg];"
        filter_complex+="[1:v]format=yuva420p,fade=in:st=0.8:d=0.8:alpha=1[glow];"
        filter_complex+="[2:v]format=yuva420p,fade=in:st=1.0:d=0.8:alpha=1[logo];"
        filter_complex+="[3:v]format=yuva420p,fade=in:st=2.2:d=0.8:alpha=1[sub];"
        filter_complex+="[bg][glow]overlay=0:0:format=auto[tmp1];"
        filter_complex+="[tmp1][logo]overlay=0:0:format=auto[tmp2];"
        filter_complex+="[tmp2][sub]overlay=0:0:format=auto,"
        filter_complex+="fade=out:st=4.2:d=0.8,format=yuv420p[out]"

        ffmpeg -y \
            -i "$bg_input" \
            -i "$tmp_dir/logo_glow.png" \
            -i "$tmp_dir/logo_text.png" \
            -i "$tmp_dir/subtitle.png" \
            -filter_complex "$filter_complex" \
            -map "[out]" \
            -c:v libx264 -preset medium -crf 18 \
            -t 5 -r 30 \
            -pix_fmt yuv420p \
            "$intro_output" &>/dev/null
    else
        # Simple fallback with just text overlay
        ffmpeg -y \
            -f lavfi -i "color=c=0x0a0a14:s=${frame_w}x${frame_h}:d=5:r=30" \
            -vf "drawtext=text='24HG':fontsize=120:fontcolor=${COLOR_PRIMARY}:x=(w-tw)/2:y=(h-th)/2-40:alpha='if(lt(t,1),0,if(lt(t,2),(t-1),1))',drawtext=text='Powered by HubOS':fontsize=36:fontcolor=${COLOR_TEXT}:x=(w-tw)/2:y=(h-th)/2+60:alpha='if(lt(t,2.5),0,if(lt(t,3.5),(t-2.5),1))',fade=out:st=4.2:d=0.8" \
            -c:v libx264 -preset medium -crf 18 \
            -pix_fmt yuv420p \
            "$intro_output" &>/dev/null
    fi

    # Step 5: Add sound effect if hubos-sounds exist
    current=$((current + 1)); progress_bar $current $total "Audio"
    local sound_file="/usr/share/hubos/sounds/intro.ogg"
    if [ ! -f "$sound_file" ]; then
        sound_file="${XDG_DATA_HOME:-$HOME/.local/share}/hubos/sounds/intro.ogg"
    fi
    if [ -f "$sound_file" ] && [ -f "$intro_output" ]; then
        local tmp_with_audio="${intro_output%.mp4}_audio.mp4"
        ffmpeg -y -i "$intro_output" -i "$sound_file" \
            -c:v copy -c:a aac -b:a 192k -shortest \
            "$tmp_with_audio" &>/dev/null && \
        mv "$tmp_with_audio" "$intro_output"
        info "Added intro sound effect"
    else
        info "No intro sound found — video-only (place intro.ogg in hubos sounds directory)"
    fi

    # Step 6: Generate 3-second transition video
    current=$((current + 1)); progress_bar $current $total "Transition video"
    if [ -f "$bg_input" ] && [ -f "$tmp_dir/logo_text.png" ]; then
        ffmpeg -y \
            -i "$bg_input" \
            -i "$tmp_dir/logo_text.png" \
            -filter_complex "[0:v]loop=loop=90:size=1:start=0,setpts=N/30/TB,format=yuva420p,scale=${frame_w}:${frame_h}[bg];[1:v]format=yuva420p,fade=in:st=0:d=0.5:alpha=1,fade=out:st=2.0:d=1.0:alpha=1[logo];[bg][logo]overlay=0:0:format=auto,format=yuv420p[out]" \
            -map "[out]" \
            -c:v libx264 -preset medium -crf 18 \
            -t 3 -r 30 -pix_fmt yuv420p \
            "$transition_output" &>/dev/null
    else
        ffmpeg -y \
            -f lavfi -i "color=c=0x0a0a14:s=${frame_w}x${frame_h}:d=3:r=30" \
            -vf "drawtext=text='24HG':fontsize=80:fontcolor=${COLOR_PRIMARY}:x=(w-tw)/2:y=(h-th)/2:alpha='if(lt(t,0.5),t*2,if(gt(t,2),(3-t),1))',fade=in:d=0.5,fade=out:st=2:d=1" \
            -c:v libx264 -preset medium -crf 18 \
            -pix_fmt yuv420p \
            "$transition_output" &>/dev/null
    fi

    # Cleanup temp files
    rm -rf "$tmp_dir"

    echo ""
    success "Intro and transition videos generated!"
    echo ""
    echo -e "  ${BOLD}Intro (5s):${NC}       $intro_output"
    echo -e "  ${BOLD}Transition (3s):${NC}  $transition_output"
    echo ""
    echo -e "  ${DIM}Use the intro at the start of your stream.${NC}"
    echo -e "  ${DIM}Use the transition between scenes (Stinger transition in OBS).${NC}"
}

# ─── Command: export ─────────────────────────────────────────────────
cmd_export() {
    header "HubOS Creator Kit — Export & Share"

    load_config
    mkdir -p "$CREATOR_DIR"

    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local zip_name="hubos-creator-kit_${timestamp}.zip"
    local zip_path="$CREATOR_DIR/$zip_name"

    require_cmd zip zip || exit 1

    step "Packaging creator assets..."

    # Create a README for the bundle
    local readme="$CREATOR_DIR/README-CreatorKit.txt"
    cat > "$readme" <<READMEEOF
=============================================================
  HubOS Content Creator Kit
  Generated: $(date -Iseconds)
=============================================================

This bundle contains branded streaming assets for 24 Hour
Gaming (24HG) content creators using HubOS.

CONTENTS:
  overlays/         — Stream overlay images (dark + light)
    webcam-frame.png     Rounded webcam border
    lower-third.png      "Playing on 24HG" banner
    hubos-watermark.png  Semi-transparent watermark
    social-bar.png       Discord & Hub links
    alert-*.png          Alert box backgrounds
    *-bg.png             Scene background cards

  intro.mp4         — 5-second stream intro
  transition.mp4    — 3-second scene transition

SETUP:
  1. Import the scene collection JSON into OBS:
     Scene Collection > Import > select the .json file

  2. Copy overlays to your preferred location and update
     image source paths in OBS if needed.

  3. Drop intro.mp4 into a Media Source for your starting
     scene, or use transition.mp4 as a Stinger transition.

CUSTOMIZING:
  Run 'hubos-creator-kit overlay' to regenerate overlays.
  Run 'hubos-creator-kit watermark' to adjust watermark.
  Run 'hubos-creator-kit intro' to regenerate intro video.

Share this kit with other HubOS creators!

  Website: os.24hgaming.com
  Discord: discord.gg/ymfEjH6EJN
  Hub:     hub.24hgaming.com
=============================================================
READMEEOF

    # Find the scene collection JSON
    local scene_json=""
    for candidate in \
        "$OBS_FLATPAK_DIR/basic/scenes/24HG Creator Kit.json" \
        "$OBS_NATIVE_DIR/basic/scenes/24HG Creator Kit.json" \
        "$OBS_DIR/basic/scenes/24HG Creator Kit.json"; do
        if [ -f "$candidate" ]; then
            scene_json="$candidate"
            break
        fi
    done

    # Build zip
    local zip_files=()
    [ -f "$readme" ] && zip_files+=("$readme")
    [ -d "$OVERLAYS_DIR" ] && zip_files+=("$OVERLAYS_DIR")
    [ -f "$CREATOR_DIR/intro.mp4" ] && zip_files+=("$CREATOR_DIR/intro.mp4")
    [ -f "$CREATOR_DIR/transition.mp4" ] && zip_files+=("$CREATOR_DIR/transition.mp4")

    # Create the zip from the creator directory
    (
        cd "$CREATOR_DIR"
        local rel_files=()
        [ -f "README-CreatorKit.txt" ] && rel_files+=("README-CreatorKit.txt")
        [ -d "overlays" ] && rel_files+=("overlays/")
        [ -f "intro.mp4" ] && rel_files+=("intro.mp4")
        [ -f "transition.mp4" ] && rel_files+=("transition.mp4")

        if [ -n "$scene_json" ]; then
            cp "$scene_json" "24HG-Creator-Kit-Scenes.json"
            rel_files+=("24HG-Creator-Kit-Scenes.json")
        fi

        if [ ${#rel_files[@]} -gt 0 ]; then
            zip -r "$zip_name" "${rel_files[@]}" &>/dev/null
        else
            error "No assets found to export. Run setup, scenes, overlay, and intro first."
            exit 1
        fi

        # Cleanup temp copy
        rm -f "24HG-Creator-Kit-Scenes.json"
    )

    if [ -f "$zip_path" ]; then
        local size
        size=$(du -h "$zip_path" | cut -f1)
        success "Creator kit exported!"
        echo ""
        echo -e "  ${BOLD}File:${NC} $zip_path"
        echo -e "  ${BOLD}Size:${NC} $size"
        echo ""
        echo -e "  ${DIM}Share this zip with other HubOS creators!${NC}"
        echo -e "  ${DIM}They can import the scenes and overlays into their OBS.${NC}"
    else
        error "Failed to create export zip"
    fi

    # Cleanup readme (keep it around for reference)
}

# ─── Usage / Main ────────────────────────────────────────────────────
usage() {
    echo -e "${BOLD}HubOS Content Creator Kit${NC} v${VERSION}"
    echo -e "${DIM}Branded streaming toolkit for 24HG content creators${NC}"
    echo ""
    echo -e "${BOLD}Usage:${NC} hubos-creator-kit <command> [args]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo -e "  ${CYAN}setup${NC}         One-time creator setup (OBS profile, encoder, replay buffer)"
    echo -e "  ${CYAN}scenes${NC}        Generate OBS scene collection with 24HG branding"
    echo -e "  ${CYAN}overlay${NC}       Generate stream overlay images (dark + light variants)"
    echo -e "  ${CYAN}clip${NC}          Quick clip tool (last N seconds, screenshot, GIF)"
    echo -e "  ${CYAN}watermark${NC}     Manage watermark settings (on/off, position, opacity)"
    echo -e "  ${CYAN}intro${NC}         Generate stream intro and transition videos"
    echo -e "  ${CYAN}export${NC}        Package all creator assets into a shareable zip"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo -e "  hubos-creator-kit setup"
    echo -e "  hubos-creator-kit clip last 30"
    echo -e "  hubos-creator-kit clip screenshot"
    echo -e "  hubos-creator-kit clip gif 10"
    echo -e "  hubos-creator-kit watermark position bottom-right"
    echo -e "  hubos-creator-kit watermark opacity 20"
    echo ""
    echo -e "${DIM}Assets saved to: ~/HubOS-Creator/${NC}"
}

main() {
    local command="${1:-help}"
    shift || true

    load_config

    case "$command" in
        setup)      cmd_setup ;;
        scenes)     cmd_scenes ;;
        overlay)    cmd_overlay ;;
        clip)       cmd_clip "$@" ;;
        watermark)  cmd_watermark "$@" ;;
        intro)      cmd_intro ;;
        export)     cmd_export ;;
        help|--help|-h)
            usage
            ;;
        version|--version|-v)
            echo "hubos-creator-kit v${VERSION}"
            ;;
        *)
            error "Unknown command: $command"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
