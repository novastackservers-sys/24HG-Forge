#!/usr/bin/env bash
# HubOS Content Creator Kit
# Streamlined toolkit for content creators using HubOS — generates OBS scenes,
# overlays, intros, clips, and branded assets for 24 Hour Gaming streamers.
#
# Usage: hubos-creator-kit [setup|scenes|overlay|clip|watermark|intro|export]

set -euo pipefail

# ─── Constants & Paths ───────────────────────────────────────────────
VERSION="1.0.0"
BRAND_NAME="24HG"
BRAND_FULL="24 Hour Gaming"
BRAND_URL="os.24hgaming.com"
BRAND_DISCORD="discord.gg/ymfEjH6EJN"
BRAND_HUB="hub.24hgaming.com"

COLOR_PRIMARY="#00d4ff"     # Cyan
COLOR_BG="#0a0a14"          # Dark background
COLOR_BG_LIGHT="#1a1a2e"    # Lighter dark
COLOR_ACCENT="#ff6b35"      # Orange accent
COLOR_TEXT="#e0e0e0"        # Light text
COLOR_TEXT_BRIGHT="#ffffff"  # White

CREATOR_DIR="$HOME/HubOS-Creator"
OVERLAYS_DIR="$CREATOR_DIR/overlays"
CLIPS_DIR="$CREATOR_DIR/clips"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hubos"
CONFIG_FILE="$CONFIG_DIR/creator-kit.conf"

# OBS paths — Flatpak and native
OBS_FLATPAK_DIR="$HOME/.var/app/com.obsproject.Studio/config/obs-studio"
OBS_NATIVE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/obs-studio"
OBS_DIR=""  # Set during detection

# Watermark defaults
WM_ENABLED="true"
WM_POSITION="bottom-right"
WM_OPACITY="30"

# ─── Terminal Colors ─────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ─── Helpers ─────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}[INFO]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
step()    { echo -e "${MAGENTA}>>>${NC} ${BOLD}$*${NC}"; }
header()  { echo -e "\n${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"; echo -e "${BOLD}  $*${NC}"; echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"; }

progress_bar() {
    local current=$1 total=$2 label="${3:-}"
    local width=40
    local pct=$(( current * 100 / total ))
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    printf "\r  ${DIM}[${NC}${CYAN}"
    printf '%0.s#' $(seq 1 "$filled" 2>/dev/null) || true
    printf "${DIM}"
    printf '%0.s-' $(seq 1 "$empty" 2>/dev/null) || true
    printf "${NC}${DIM}]${NC} %3d%% %s" "$pct" "$label"
    if [ "$current" -eq "$total" ]; then echo; fi
}

require_cmd() {
    local cmd="$1" pkg="${2:-$1}"
    if ! command -v "$cmd" &>/dev/null; then
        error "$cmd is not installed. Install with: sudo dnf install $pkg"
        return 1
    fi
}

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
# HubOS Creator Kit Configuration
# Generated $(date -Iseconds)
WM_ENABLED="$WM_ENABLED"
WM_POSITION="$WM_POSITION"
WM_OPACITY="$WM_OPACITY"
OBS_DIR="$OBS_DIR"
EOF
    chmod 600 "$CONFIG_FILE"
}

# ─── Detection ───────────────────────────────────────────────────────
detect_obs() {
    # Check Flatpak first
    if flatpak list --app 2>/dev/null | grep -q com.obsproject.Studio; then
        OBS_DIR="$OBS_FLATPAK_DIR"
        echo "flatpak"
        return 0
    fi
    # Check native
    if command -v obs &>/dev/null || command -v obs-studio &>/dev/null; then
        OBS_DIR="$OBS_NATIVE_DIR"
        echo "native"
        return 0
    fi
    echo "none"
    return 1
}

detect_encoder() {
    # NVENC (NVIDIA)
    if command -v nvidia-smi &>/dev/null && nvidia-smi -L &>/dev/null 2>&1; then
        echo "nvenc"
        return
    fi
    # VAAPI (AMD / Intel)
    if [ -e /dev/dri/renderD128 ]; then
        echo "vaapi"
        return
    fi
    echo "x264"
}

detect_resolution() {
    local res=""
    # Try xdpyinfo first (X11)
    if command -v xdpyinfo &>/dev/null 2>&1; then
        res=$(xdpyinfo 2>/dev/null | grep dimensions | head -1 | awk '{print $2}')
    fi
    # Try wlr-randr (Wayland)
    if [ -z "$res" ] && command -v wlr-randr &>/dev/null; then
        res=$(wlr-randr 2>/dev/null | grep -oP '\d+x\d+' | head -1)
    fi
    # Try xrandr
    if [ -z "$res" ] && command -v xrandr &>/dev/null; then
        res=$(xrandr 2>/dev/null | grep '\*' | head -1 | awk '{print $1}')
    fi
    # Fallback
    echo "${res:-1920x1080}"
}

detect_gpu_vendor() {
    if command -v nvidia-smi &>/dev/null && nvidia-smi -L &>/dev/null 2>&1; then
        echo "nvidia"
    elif lspci 2>/dev/null | grep -qi "amd\|radeon"; then
        echo "amd"
    else
        echo "intel"
    fi
}

# ─── Command: setup ──────────────────────────────────────────────────
cmd_setup() {
    header "HubOS Creator Kit — Initial Setup"

    # Step 1: Detect OBS
    step "Detecting OBS Studio installation..."
    local obs_type
    obs_type=$(detect_obs) || true
    case "$obs_type" in
        flatpak)
            success "OBS Studio found (Flatpak: com.obsproject.Studio)"
            info "Config path: $OBS_DIR"
            ;;
        native)
            success "OBS Studio found (native installation)"
            info "Config path: $OBS_DIR"
            ;;
        *)
            warn "OBS Studio not found"
            echo ""
            echo -e "  Install OBS with:"
            echo -e "    ${CYAN}flatpak install flathub com.obsproject.Studio${NC}"
            echo ""
            read -rp "  Continue without OBS? (scenes will be exported as standalone JSON) [Y/n] " yn
            if [[ "${yn,,}" == "n" ]]; then exit 0; fi
            OBS_DIR="$OBS_FLATPAK_DIR"
            ;;
    esac

    # Step 2: Detect monitor
    step "Detecting monitor resolution..."
    local monitor_res
    monitor_res=$(detect_resolution)
    local height
    height=$(echo "$monitor_res" | cut -dx -f2)
    local quality_preset="1080p60"
    if [ "${height:-0}" -ge 1440 ]; then
        quality_preset="1440p60"
    fi
    success "Monitor: $monitor_res — Output preset: $quality_preset"

    # Step 3: Detect GPU encoder
    step "Detecting hardware encoder..."
    local encoder
    encoder=$(detect_encoder)
    local encoder_label=""
    case "$encoder" in
        nvenc)  encoder_label="NVENC (NVIDIA hardware)" ;;
        vaapi)  encoder_label="VAAPI (AMD/Intel hardware)" ;;
        x264)   encoder_label="x264 (CPU software — consider a GPU upgrade)" ;;
    esac
    success "Encoder: $encoder_label"

    # Step 4: Create OBS profile
    step "Creating HubOS Creator OBS profile..."
    local profiles_dir="$OBS_DIR/basic/profiles/HubOS Creator"
    mkdir -p "$profiles_dir"

    local base_cx=1920 base_cy=1080 out_cx=1920 out_cy=1080 fps=60
    local stream_bitrate=6000
    if [ "$quality_preset" = "1440p60" ]; then
        base_cx=2560; base_cy=1440; out_cx=2560; out_cy=1440
        stream_bitrate=10000
    fi

    # Determine OBS encoder IDs
    local obs_stream_encoder="obs_x264"
    local obs_rec_encoder="obs_x264"
    local encoder_preset="veryfast"
    case "$encoder" in
        nvenc)
            obs_stream_encoder="jim_nvenc"
            obs_rec_encoder="jim_nvenc"
            encoder_preset="hp"
            ;;
        vaapi)
            obs_stream_encoder="ffmpeg_vaapi"
            obs_rec_encoder="ffmpeg_vaapi"
            encoder_preset=""
            ;;
    esac

    cat > "$profiles_dir/basic.ini" <<PROFILE
[General]
Name=HubOS Creator

[Video]
BaseCX=$base_cx
BaseCY=$base_cy
OutputCX=$out_cx
OutputCY=$out_cy
FPSType=0
FPSCommon=$fps

[Output]
Mode=Advanced

[AdvOut]
TrackIndex=1
RecType=Standard
RecFormat=mkv
RecEncoder=$obs_rec_encoder
StreamEncoder=$obs_stream_encoder
FFOutputToFile=true
RescaleRes=${out_cx}x${out_cy}

[AdvOut.Streaming]
Encoder=$obs_stream_encoder
Bitrate=$stream_bitrate
KeyframeIntervalSec=2
Preset=$encoder_preset
Profile=high
Tune=zerolatency
RateControl=CBR

[AdvOut.Recording]
RecFilePath=$HOME/Videos/HubOS Recordings/
RecFormat2=mkv
RecEncoder=$obs_rec_encoder
Bitrate=15000
Preset=fast

[AdvOut.FFmpeg]
RecSplitFileType=Time
RecSplitFileTime=60

[Audio]
SampleRate=48000
ChannelSetup=Stereo
BitrateAAC=160

[Hotkeys]
ReplayBuffer.Save={"OBSBasic.ReplayBuffer": [{"key": "OBS_KEY_F9", "control": true}]}
PROFILE
    success "OBS profile created at: $profiles_dir"

    # Step 5: Streaming service
    step "Streaming platform setup..."
    echo ""
    echo -e "  ${BOLD}Select streaming platform:${NC}"
    echo -e "    ${CYAN}1${NC}) Twitch  (bitrate: 6000kbps)"
    echo -e "    ${CYAN}2${NC}) YouTube (bitrate: 10000kbps)"
    echo -e "    ${CYAN}3${NC}) Kick"
    echo -e "    ${CYAN}4${NC}) Skip for now"
    echo ""
    read -rp "  Choice [1-4]: " platform_choice
    local service_file="$profiles_dir/service.json"
    case "${platform_choice:-4}" in
        1)
            read -rsp "  Enter Twitch stream key: " stream_key; echo
            cat > "$service_file" <<SVCEOF
{
    "settings": {
        "key": "$stream_key",
        "server": "auto",
        "service": "Twitch"
    },
    "type": "rtmp_common"
}
SVCEOF
            success "Twitch configured"
            ;;
        2)
            read -rsp "  Enter YouTube stream key: " stream_key; echo
            cat > "$service_file" <<SVCEOF
{
    "settings": {
        "key": "$stream_key",
        "server": "Primary YouTube ingest server",
        "service": "YouTube - RTMPS"
    },
    "type": "rtmp_common"
}
SVCEOF
            success "YouTube configured"
            ;;
        3)
            read -rsp "  Enter Kick stream key: " stream_key; echo
            cat > "$service_file" <<SVCEOF
{
    "settings": {
        "key": "$stream_key",
        "server": "auto",
        "service": "Kick"
    },
    "type": "rtmp_common"
}
SVCEOF
            success "Kick configured"
            ;;
        *)
            info "Skipped — configure later in OBS Settings > Stream"
            ;;
    esac

    # Step 6: Configure replay buffer
    step "Configuring replay buffer (2 minutes, Ctrl+F9 to save)..."
    local replay_ini="$profiles_dir/recordEncoder.json"
    cat > "$replay_ini" <<REOF
{
    "replay_buffer": {
        "max_time_sec": 120,
        "max_size_mb": 512
    }
}
REOF
    success "Replay buffer: 2 minutes, hotkey Ctrl+F9"

    # Step 7: Install fonts if missing
    step "Checking for required fonts..."
    local fonts_dir="$HOME/.local/share/fonts"
    local missing_fonts=0
    for font_name in "Inter" "JetBrains Mono"; do
        if ! fc-list 2>/dev/null | grep -qi "$font_name"; then
            missing_fonts=1
            warn "$font_name not found"
        else
            success "$font_name found"
        fi
    done
    if [ "$missing_fonts" -eq 1 ]; then
        info "Installing missing fonts..."
        mkdir -p "$fonts_dir"
        # Attempt to fetch Inter and JetBrains Mono
        for font_url in \
            "https://github.com/rsms/inter/releases/download/v4.0/Inter-4.0.zip" \
            "https://github.com/JetBrains/JetBrainsMono/releases/download/v2.304/JetBrainsMono-2.304.zip"; do
            local zip_name
            zip_name=$(basename "$font_url")
            if curl -fsSL -o "/tmp/$zip_name" "$font_url" 2>/dev/null; then
                unzip -qo "/tmp/$zip_name" -d "/tmp/hubos-fonts-$$" 2>/dev/null || true
                find "/tmp/hubos-fonts-$$" -name '*.ttf' -o -name '*.otf' 2>/dev/null | \
                    while read -r f; do cp "$f" "$fonts_dir/"; done
                rm -rf "/tmp/hubos-fonts-$$" "/tmp/$zip_name"
            fi
        done
        fc-cache -f "$fonts_dir" 2>/dev/null || true
        success "Fonts installed to $fonts_dir"
    fi

    # Step 8: Create directories
    mkdir -p "$CREATOR_DIR" "$OVERLAYS_DIR" "$CLIPS_DIR" "$HOME/Videos/HubOS Recordings"

    save_config

    echo ""
    header "Setup Complete"
    echo -e "  ${BOLD}Profile:${NC}     HubOS Creator (${quality_preset}, $encoder_label)"
    echo -e "  ${BOLD}Replay:${NC}      2 min buffer, Ctrl+F9 to save"
    echo -e "  ${BOLD}Creator dir:${NC} $CREATOR_DIR"
    echo ""
    echo -e "  ${DIM}Next steps:${NC}"
    echo -e "    ${CYAN}hubos-creator-kit scenes${NC}   — Generate branded OBS scenes"
    echo -e "    ${CYAN}hubos-creator-kit overlay${NC}  — Generate stream overlay images"
    echo -e "    ${CYAN}hubos-creator-kit intro${NC}    — Generate stream intro video"
}

# ─── Command: scenes ─────────────────────────────────────────────────
cmd_scenes() {
    header "HubOS Creator Kit — OBS Scene Collection"

    load_config
    if [ -z "$OBS_DIR" ]; then
        detect_obs >/dev/null 2>&1 || true
        if [ -z "$OBS_DIR" ]; then
            OBS_DIR="$OBS_FLATPAK_DIR"
        fi
    fi

    local scenes_dir="$OBS_DIR/basic/scenes"
    mkdir -p "$scenes_dir" "$OVERLAYS_DIR"

    step "Generating 24HG Creator scene collection..."

    local scene_file="$scenes_dir/24HG Creator Kit.json"
    local webcam_overlay="$OVERLAYS_DIR/webcam-frame.png"
    local watermark_img="$OVERLAYS_DIR/hubos-watermark.png"
    local lower_third="$OVERLAYS_DIR/lower-third.png"
    local starting_bg="$OVERLAYS_DIR/starting-soon-bg.png"
    local brb_bg="$OVERLAYS_DIR/brb-bg.png"
    local ending_bg="$OVERLAYS_DIR/ending-bg.png"

    # Generate overlay images if not present (quick versions for scene references)
    if [ ! -f "$watermark_img" ]; then
