#!/bin/bash
# 24HG Forge Live Wallpaper — Dynamic wallpaper that reacts to your gaming activity
set -euo pipefail

# ── Constants ────────────────────────────────────────────────────────────────

WALLPAPER_DIR="/usr/share/forge/wallpapers"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge"
CONFIG_FILE="$CONFIG_DIR/live-wallpaper.conf"
STATE_FILE="/tmp/forge-live-wallpaper.state"
PID_FILE="/tmp/forge-live-wallpaper.pid"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/forge/live-wallpaper"
OVERLAY_DIR="$CACHE_DIR/overlays"
HUB_API="https://hub.24hgaming.com/api/servers/stats"

# Wallpaper filenames
WP_DARK="forge-dark.png"
WP_MINIMAL="forge-minimal.png"
WP_NEON="forge-neon.png"
WP_CIRCUIT="forge-circuit.png"

# Game process patterns to detect
GAME_PATTERNS=(
    "steam_app_"
    "gamescope"
    "lutris-wrapper"
    "heroic"
    "wine"
    "proton"
)

# ── Colors ───────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ──────────────────────────────────────────────────────────────────

log_info()  { logger -t forge-wallpaper "[INFO]  $*"; }
log_warn()  { logger -t forge-wallpaper "[WARN]  $*"; }
log_error() { logger -t forge-wallpaper "[ERROR] $*"; }

print_header() {
    echo -e "${MAGENTA}${BOLD}"
    echo "  ╔═══════════════════════════════════════════════╗"
    echo "  ║   🖼  Forge Live Wallpaper                    ║"
    echo "  ║   Dynamic wallpaper for your gaming desktop   ║"
    echo "  ╚═══════════════════════════════════════════════╝"
    echo -e "${RESET}"
}

info()  { echo -e "  ${CYAN}[INFO]${RESET}  $*"; }
ok()    { echo -e "  ${GREEN}[  OK]${RESET}  $*"; }
warn()  { echo -e "  ${YELLOW}[WARN]${RESET}  $*"; }
err()   { echo -e "  ${RED}[ ERR]${RESET}  $*"; }

# ── Config ───────────────────────────────────────────────────────────────────

load_config() {
    # Defaults
    MODE="time"
    GAMING_WALLPAPER="$WP_MINIMAL"
    ENABLE_SERVER_OVERLAY="yes"
    IDLE_SLIDESHOW="yes"
    IDLE_TIMEOUT=600
    CHECK_INTERVAL=30

    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

ensure_config() {
    mkdir -p "$CONFIG_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" <<'CONF'
# Forge Live Wallpaper Configuration
# Modes: time, gaming, servers, static
MODE=time
GAMING_WALLPAPER=forge-minimal.png
ENABLE_SERVER_OVERLAY=yes
IDLE_SLIDESHOW=yes
IDLE_TIMEOUT=600
CHECK_INTERVAL=30
CONF
        log_info "Created default config at $CONFIG_FILE"
    fi
}

# ── State Management ─────────────────────────────────────────────────────────

read_state() {
    if [[ -f "$STATE_FILE" ]]; then
        cat "$STATE_FILE"
    else
        echo "none|none|0"
    fi
}

write_state() {
    local current_mode="$1" current_wallpaper="$2"
    echo "${current_mode}|${current_wallpaper}|$(date +%s)" > "$STATE_FILE"
}

get_state_field() {
    local field="$1"
    local state
    state="$(read_state)"
    case "$field" in
        mode)      echo "$state" | cut -d'|' -f1 ;;
        wallpaper) echo "$state" | cut -d'|' -f2 ;;
        timestamp) echo "$state" | cut -d'|' -f3 ;;
    esac
}

# ── Wallpaper Application ───────────────────────────────────────────────────

apply_wallpaper() {
    local wp_file="$1"
    local wp_path="$WALLPAPER_DIR/$wp_file"

    # If it's an overlay (absolute path), use directly
    if [[ "$wp_file" == /* ]]; then
        wp_path="$wp_file"
    fi

    if [[ ! -f "$wp_path" ]]; then
        log_warn "Wallpaper not found: $wp_path"
        return 1
    fi

    local current_wp
    current_wp="$(get_state_field wallpaper)"
    if [[ "$current_wp" == "$wp_file" ]]; then
        return 0  # No change needed
    fi

    if command -v plasma-apply-wallpaperimage &>/dev/null; then
        plasma-apply-wallpaperimage "$wp_path" 2>/dev/null && {
            log_info "Applied wallpaper: $wp_file"
            return 0
        }
    fi

    # Fallback: try gsettings for GNOME-based desktops
    if command -v gsettings &>/dev/null; then
        gsettings set org.gnome.desktop.background picture-uri "file://$wp_path" 2>/dev/null
        gsettings set org.gnome.desktop.background picture-uri-dark "file://$wp_path" 2>/dev/null
        log_info "Applied wallpaper via gsettings: $wp_file"
        return 0
    fi

    log_error "No supported wallpaper setter found"
    return 1
}

# ── Detection Functions ──────────────────────────────────────────────────────

get_time_period() {
    local hour
    hour="$(date +%H)"
    hour="${hour#0}"  # strip leading zero

    if (( hour >= 6 && hour < 12 )); then
        echo "morning"
    elif (( hour >= 12 && hour < 18 )); then
        echo "afternoon"
    elif (( hour >= 18 && hour < 22 )); then
        echo "evening"
    else
        echo "night"
    fi
}

get_time_wallpaper() {
    local period
    period="$(get_time_period)"
    case "$period" in
        morning)   echo "$WP_DARK" ;;
        afternoon) echo "$WP_DARK" ;;
        evening)   echo "$WP_NEON" ;;
        night)     echo "$WP_CIRCUIT" ;;
    esac
}

is_game_running() {
    for pattern in "${GAME_PATTERNS[@]}"; do
        if pgrep -f "$pattern" &>/dev/null; then
            return 0
        fi
    done
    return 1
}

get_idle_time() {
    # Try xprintidle first (X11, returns milliseconds)
    if command -v xprintidle &>/dev/null; then
        local ms
        ms="$(xprintidle 2>/dev/null || echo 0)"
        echo $(( ms / 1000 ))
        return
    fi

    # Try kdotool (Wayland)
    if command -v kdotool &>/dev/null; then
        kdotool idle 2>/dev/null || echo 0
        return
    fi

    # No idle detection available
    echo 0
}

is_idle() {
    local idle_seconds
    idle_seconds="$(get_idle_time)"
    (( idle_seconds >= IDLE_TIMEOUT ))
}

# ── Server Overlay ───────────────────────────────────────────────────────────

fetch_server_stats() {
    if [[ "$ENABLE_SERVER_OVERLAY" != "yes" ]]; then
        return 1
    fi

    local stats_file="$CACHE_DIR/server-stats.json"
    mkdir -p "$CACHE_DIR"

    if curl -sf --connect-timeout 5 --max-time 10 "$HUB_API" -o "$stats_file" 2>/dev/null; then
        log_info "Fetched server stats"
        return 0
    else
        log_warn "Failed to fetch server stats"
        return 1
    fi
}

generate_overlay() {
    local base_wp="$1"
    local base_path="$WALLPAPER_DIR/$base_wp"
    local stats_file="$CACHE_DIR/server-stats.json"
    local overlay_path="$OVERLAY_DIR/current-overlay.png"

    mkdir -p "$OVERLAY_DIR"

    if [[ ! -f "$stats_file" ]] || [[ ! -f "$base_path" ]]; then
        return 1
    fi

    if ! command -v convert &>/dev/null; then
        log_warn "ImageMagick not installed, skipping overlay"
        return 1
    fi

    # Parse server stats — extract total players and server count
    local total_players server_count stats_text
    total_players="$(jq -r '.total_players // 0' "$stats_file" 2>/dev/null || echo "?")"
    server_count="$(jq -r '.total_servers // 0' "$stats_file" 2>/dev/null || echo "?")"
    stats_text="24HG Servers: ${server_count} active | ${total_players} players online"

    # Generate overlay with semi-transparent bar and text at bottom
    convert "$base_path" \
        -gravity South \
        -fill 'rgba(0,0,0,0.6)' \
        -draw "rectangle 0,%[fx:h-60] %[fx:w],h" \
        -fill '#00FFAA' \
        -font 'DejaVu-Sans' \
        -pointsize 18 \
        -gravity South \
        -annotate +0+20 "$stats_text" \
        "$overlay_path" 2>/dev/null && {
        echo "$overlay_path"
        return 0
    }

    return 1
}

# ── Slideshow (Idle Mode) ───────────────────────────────────────────────────

SLIDESHOW_INDEX=0
SLIDESHOW_FILES=()

init_slideshow() {
    SLIDESHOW_FILES=()
    if [[ -d "$WALLPAPER_DIR" ]]; then
        while IFS= read -r -d '' f; do
            SLIDESHOW_FILES+=("$f")
        done < <(find "$WALLPAPER_DIR" -maxdepth 1 -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' \) -print0 2>/dev/null | sort -z)
    fi
    SLIDESHOW_INDEX=0
}

next_slideshow() {
    if [[ ${#SLIDESHOW_FILES[@]} -eq 0 ]]; then
        init_slideshow
    fi
    if [[ ${#SLIDESHOW_FILES[@]} -eq 0 ]]; then
        return 1
    fi

    local wp="${SLIDESHOW_FILES[$SLIDESHOW_INDEX]}"
    SLIDESHOW_INDEX=$(( (SLIDESHOW_INDEX + 1) % ${#SLIDESHOW_FILES[@]} ))
    echo "$wp"
}

# ── Main Daemon Loop ────────────────────────────────────────────────────────

FOREGROUND=false
LAST_OVERLAY_FETCH=0
OVERLAY_INTERVAL=300  # 5 minutes

daemon_loop() {
    load_config
    mkdir -p "$CACHE_DIR" "$OVERLAY_DIR"
    log_info "Daemon starting (mode=$MODE, interval=${CHECK_INTERVAL}s)"

    local tick=0

    while true; do
        load_config  # reload config each cycle for live changes

        local target_mode="$MODE"
        local target_wp=""
        local now
        now="$(date +%s)"

        # ── Gaming override (highest priority) ──
        if is_game_running; then
            target_mode="gaming"
            target_wp="$GAMING_WALLPAPER"
        # ── Idle slideshow ──
        elif [[ "$IDLE_SLIDESHOW" == "yes" ]] && is_idle; then
            target_mode="idle"
            local slide
            slide="$(next_slideshow)" || true
            if [[ -n "$slide" ]]; then
                target_wp="$slide"
            else
                target_wp="$(get_time_wallpaper)"
            fi
        else
            # ── Mode-based selection ──
            case "$MODE" in
                time)
                    target_mode="time"
                    target_wp="$(get_time_wallpaper)"
                    ;;
                gaming)
                    target_mode="gaming-standby"
                    target_wp="$GAMING_WALLPAPER"
                    ;;
                servers)
                    target_mode="servers"
                    target_wp="$(get_time_wallpaper)"
                    ;;
                static)
                    target_mode="static"
                    target_wp="$WP_DARK"
                    ;;
                *)
                    target_mode="time"
                    target_wp="$(get_time_wallpaper)"
                    ;;
            esac
        fi

        # ── Server overlay (if enabled and in servers mode or overlay mode) ──
        if [[ "$ENABLE_SERVER_OVERLAY" == "yes" ]] && [[ "$target_mode" == "servers" || "$MODE" == "servers" ]]; then
            if (( now - LAST_OVERLAY_FETCH >= OVERLAY_INTERVAL )); then
                fetch_server_stats && LAST_OVERLAY_FETCH="$now"
            fi
            local overlay
            overlay="$(generate_overlay "$target_wp")" && target_wp="$overlay"
        fi

        # ── Apply wallpaper only if state changed ──
        local prev_state
        prev_state="$(read_state)"
        local prev_mode prev_wp
        prev_mode="$(echo "$prev_state" | cut -d'|' -f1)"
        prev_wp="$(echo "$prev_state" | cut -d'|' -f2)"

        if [[ "$target_mode" != "$prev_mode" ]] || [[ "$target_wp" != "$prev_wp" ]]; then
            if apply_wallpaper "$target_wp"; then
                write_state "$target_mode" "$target_wp"
                log_info "State changed: $prev_mode -> $target_mode ($target_wp)"
            fi
        fi

        sleep "$CHECK_INTERVAL"
        tick=$(( tick + 1 ))
    done
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_start() {
    ensure_config
    load_config

    # Check if already running
    if [[ -f "$PID_FILE" ]]; then
        local existing_pid
        existing_pid="$(cat "$PID_FILE")"
        if kill -0 "$existing_pid" 2>/dev/null; then
            err "Daemon already running (PID $existing_pid)"
            info "Use ${BOLD}forge-live-wallpaper stop${RESET} first"
            return 1
        fi
        rm -f "$PID_FILE"
    fi

    if [[ "$FOREGROUND" == "true" ]]; then
        ok "Starting daemon in foreground (mode=${CYAN}$MODE${RESET})"
        echo "$$" > "$PID_FILE"
        trap 'rm -f "$PID_FILE" "$STATE_FILE"; log_info "Daemon stopped"; exit 0' INT TERM
        daemon_loop
    else
        print_header
        info "Starting live wallpaper daemon..."
        daemon_loop &
        local daemon_pid=$!
        echo "$daemon_pid" > "$PID_FILE"
        ok "Daemon started (PID ${BOLD}$daemon_pid${RESET})"
        info "Mode: ${CYAN}$MODE${RESET}"
        info "Interval: ${CYAN}${CHECK_INTERVAL}s${RESET}"
        info "PID file: ${DIM}$PID_FILE${RESET}"
        echo ""
        info "Stop with: ${BOLD}forge-live-wallpaper stop${RESET}"
        log_info "Daemon started (PID=$daemon_pid, mode=$MODE)"
    fi
}

cmd_stop() {
    print_header
    if [[ ! -f "$PID_FILE" ]]; then
        warn "No PID file found — daemon may not be running"
        return 0
    fi

    local pid
    pid="$(cat "$PID_FILE")"

    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null
        # Wait briefly for clean exit
        local i=0
        while kill -0 "$pid" 2>/dev/null && (( i < 10 )); do
            sleep 0.2
            i=$(( i + 1 ))
        done
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null
        fi
        ok "Daemon stopped (was PID $pid)"
        log_info "Daemon stopped (PID=$pid)"
    else
        warn "PID $pid is not running (stale PID file)"
    fi

    rm -f "$PID_FILE" "$STATE_FILE"
}

cmd_status() {
    print_header
    load_config

    # Daemon status
    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            ok "Daemon: ${GREEN}running${RESET} (PID $pid)"
        else
            warn "Daemon: ${YELLOW}stale PID${RESET} ($pid not running)"
        fi
    else
        info "Daemon: ${DIM}not running${RESET}"
    fi

    # Current state
    local state_mode state_wp state_ts
    state_mode="$(get_state_field mode)"
    state_wp="$(get_state_field wallpaper)"
    state_ts="$(get_state_field timestamp)"

    echo ""
    info "Current mode:      ${CYAN}${state_mode}${RESET}"
    info "Current wallpaper: ${CYAN}${state_wp}${RESET}"
    if [[ "$state_ts" != "0" ]] && [[ "$state_ts" != "none" ]]; then
        local ago
        ago="$(( $(date +%s) - state_ts ))"
        info "Last change:       ${DIM}${ago}s ago${RESET}"
    fi

    # Context
    echo ""
    info "Time period:  ${MAGENTA}$(get_time_period)${RESET}"
    if is_game_running; then
        info "Game running: ${YELLOW}yes${RESET}"
    else
        info "Game running: ${DIM}no${RESET}"
    fi
    local idle_s
    idle_s="$(get_idle_time)"
    info "Idle time:    ${DIM}${idle_s}s${RESET} (threshold: ${IDLE_TIMEOUT}s)"

    # Config
    echo ""
    info "Config mode:       ${CYAN}$MODE${RESET}"
    info "Server overlay:    ${CYAN}$ENABLE_SERVER_OVERLAY${RESET}"
    info "Idle slideshow:    ${CYAN}$IDLE_SLIDESHOW${RESET}"
    info "Check interval:    ${CYAN}${CHECK_INTERVAL}s${RESET}"
}

cmd_set() {
    local target_mode="${1:-}"
    if [[ -z "$target_mode" ]]; then
        err "Usage: forge-live-wallpaper set <mode>"
        info "Modes: ${CYAN}time${RESET}, ${CYAN}gaming${RESET}, ${CYAN}servers${RESET}, ${CYAN}static${RESET}"
        return 1
    fi

    case "$target_mode" in
        time|gaming|servers|static) ;;
        *)
            err "Unknown mode: $target_mode"
            info "Valid modes: ${CYAN}time${RESET}, ${CYAN}gaming${RESET}, ${CYAN}servers${RESET}, ${CYAN}static${RESET}"
            return 1
            ;;
    esac

    ensure_config

    if [[ -f "$CONFIG_FILE" ]]; then
        # Update MODE in config
        if grep -q '^MODE=' "$CONFIG_FILE"; then
            sed -i "s/^MODE=.*/MODE=$target_mode/" "$CONFIG_FILE"
        else
            echo "MODE=$target_mode" >> "$CONFIG_FILE"
        fi
    fi

    ok "Mode set to ${CYAN}${BOLD}$target_mode${RESET}"
    log_info "Mode changed to $target_mode"

    # If daemon is running, it will pick up the change on next cycle
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        info "Daemon will apply on next check cycle"
    else
        info "Start the daemon to apply: ${BOLD}forge-live-wallpaper start${RESET}"
    fi
}

cmd_config() {
    print_header
    ensure_config
    load_config

    echo -e "  ${BOLD}Configuration${RESET} ${DIM}($CONFIG_FILE)${RESET}"
    echo ""
    echo -e "  ${CYAN}MODE${RESET}                  = ${BOLD}$MODE${RESET}"
    echo -e "  ${CYAN}GAMING_WALLPAPER${RESET}      = ${BOLD}$GAMING_WALLPAPER${RESET}"
    echo -e "  ${CYAN}ENABLE_SERVER_OVERLAY${RESET}  = ${BOLD}$ENABLE_SERVER_OVERLAY${RESET}"
    echo -e "  ${CYAN}IDLE_SLIDESHOW${RESET}        = ${BOLD}$IDLE_SLIDESHOW${RESET}"
    echo -e "  ${CYAN}IDLE_TIMEOUT${RESET}          = ${BOLD}${IDLE_TIMEOUT}s${RESET}"
    echo -e "  ${CYAN}CHECK_INTERVAL${RESET}        = ${BOLD}${CHECK_INTERVAL}s${RESET}"
    echo ""
    echo -e "  ${BOLD}Wallpaper directory:${RESET} ${DIM}$WALLPAPER_DIR${RESET}"
    echo -e "  ${BOLD}Available wallpapers:${RESET}"

    if [[ -d "$WALLPAPER_DIR" ]]; then
        local count=0
        for f in "$WALLPAPER_DIR"/*.png "$WALLPAPER_DIR"/*.jpg "$WALLPAPER_DIR"/*.jpeg; do
            [[ -f "$f" ]] || continue
            echo -e "    ${GREEN}-${RESET} $(basename "$f")"
            count=$(( count + 1 ))
        done
        if (( count == 0 )); then
            echo -e "    ${DIM}(none found)${RESET}"
        fi
    else
        echo -e "    ${DIM}(directory not found)${RESET}"
    fi

    echo ""
    info "Edit config: ${BOLD}\${EDITOR:-nano} $CONFIG_FILE${RESET}"
}

# ── Usage ────────────────────────────────────────────────────────────────────

usage() {
    print_header
    echo -e "  ${BOLD}Usage:${RESET} forge-live-wallpaper <command> [options]"
    echo ""
    echo -e "  ${BOLD}Commands:${RESET}"
    echo -e "    ${GREEN}start${RESET}              Start the wallpaper daemon"
    echo -e "    ${GREEN}stop${RESET}               Stop the wallpaper daemon"
    echo -e "    ${GREEN}status${RESET}             Show current mode and wallpaper"
    echo -e "    ${GREEN}set${RESET} <mode>         Force a mode (time/gaming/servers/static)"
    echo -e "    ${GREEN}config${RESET}             Show/edit configuration"
    echo ""
    echo -e "  ${BOLD}Options:${RESET}"
    echo -e "    ${CYAN}--foreground${RESET}        Run daemon in foreground (for systemd)"
    echo ""
    echo -e "  ${BOLD}Modes:${RESET}"
    echo -e "    ${MAGENTA}time${RESET}       Wallpaper changes with time of day"
    echo -e "    ${MAGENTA}gaming${RESET}     Minimal wallpaper when games are running"
    echo -e "    ${MAGENTA}servers${RESET}    Overlay with live 24HG server stats"
    echo -e "    ${MAGENTA}static${RESET}     Single static wallpaper"
    echo ""
}

# ── Entry Point ──────────────────────────────────────────────────────────────

main() {
    # Parse global flags
    local args=()
    for arg in "$@"; do
        case "$arg" in
            --foreground) FOREGROUND=true ;;
            *) args+=("$arg") ;;
        esac
    done

    local command="${args[0]:-}"
    local subargs=("${args[@]:1}")

    case "$command" in
        start)   cmd_start ;;
        stop)    cmd_stop ;;
        status)  cmd_status ;;
        set)     cmd_set "${subargs[0]:-}" ;;
        config)  cmd_config ;;
        help|-h|--help) usage ;;
        "")      usage ;;
        *)
            err "Unknown command: $command"
            usage
            return 1
            ;;
    esac
}

main "$@"
