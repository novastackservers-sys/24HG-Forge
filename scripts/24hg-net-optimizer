#!/bin/bash
# 24HG Network Optimizer — Gaming-aware network stack optimization
set -euo pipefail

# ── Paths ──
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/24hg/net-optimizer"
CONFIG_FILE="$CONFIG_DIR/config.conf"
STATE_FILE="$CONFIG_DIR/state.json"
BACKUP_DIR="$CONFIG_DIR/backup"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/24hg/net-optimizer"
LOG_TAG="24hg-net-opt"
SYSCTL_CONF="/etc/sysctl.d/99-24hg-net-optimizer.conf"
TC_MARK_FILE="$CONFIG_DIR/.tc-active"
IPTABLES_SAVE="$CONFIG_DIR/iptables-backup.rules"

# ── Defaults ──
GAMING_MODE="off"
PREFERRED_DNS="cloudflare"
PREFER_WIRED="yes"
FAILOVER_ENABLED="yes"
QOS_BANDWIDTH="0"  # 0 = auto-detect

# ── Colors ──
RED='\033[1;31m'
ORANGE='\033[1;33m'
YELLOW='\033[0;33m'
GREEN='\033[1;32m'
CYAN='\033[1;36m'
BLUE='\033[1;34m'
MAGENTA='\033[1;35m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Unicode ──
BLOCK_FULL='█'
CHECK='✓'
CROSS='✗'
ARROW='→'
DOT='●'

# ── DNS Resolvers ──
declare -A DNS_PROVIDERS=(
    [cloudflare]="1.1.1.1 1.0.0.1"
    [google]="8.8.8.8 8.8.4.4"
    [quad9]="9.9.9.9 149.112.112.112"
    [opendns]="208.67.222.222 208.67.220.220"
)

# ── Game Servers (host:port pairs) ──
declare -a GAME_SERVERS_24HG=(
    "91.99.37.118:27015:Rust NML"
    "91.99.37.118:27021:Rust NML Alt"
    "91.99.37.118:28083:Rust StarWars"
)

declare -a GAME_SERVERS_POPULAR=(
    "162.254.197.40:27015:Valve EU West"
    "155.133.248.36:27015:Valve EU East"
    "162.254.199.170:27015:Valve US East"
    "146.66.152.10:27015:Valve EU North"
)

# ── Common Game UDP Ports ──
declare -A GAME_PORTS=(
    [rust]="28015:28090"
    [csgo]="27015:27050"
    [valorant]="7000:8000"
    [fortnite]="5222 5795:5847 9000:9100"
    [minecraft]="25565"
    [overwatch]="26503:36503"
    [apex]="37000:40000"
    [steam]="27000:27100 4380"
)

# ── Init ──
mkdir -p "$CONFIG_DIR" "$BACKUP_DIR" "$CACHE_DIR"

log() {
    logger -t "$LOG_TAG" "$*" 2>/dev/null || true
}

info()  { echo -e "  ${CYAN}${DOT}${RESET} $*"; }
ok()    { echo -e "  ${GREEN}${CHECK}${RESET} $*"; }
warn()  { echo -e "  ${YELLOW}${CROSS}${RESET} $*"; }
err()   { echo -e "  ${RED}${CROSS}${RESET} $*"; }
header() {
    echo ""
    echo -e "  ${MAGENTA}${BOLD}$*${RESET}"
    echo -e "  ${DIM}$(printf '%.0s─' $(seq 1 50))${RESET}"
}

need_root() {
    if [[ $EUID -ne 0 ]]; then
        err "This operation requires root. Re-running with pkexec..."
        exec pkexec "$0" "$@"
    fi
}

# ── Config Management ──
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE"
    fi
}

save_config() {
    cat > "$CONFIG_FILE" <<CONF
# 24HG Net Optimizer config — auto-generated
GAMING_MODE="${GAMING_MODE}"
PREFERRED_DNS="${PREFERRED_DNS}"
PREFER_WIRED="${PREFER_WIRED}"
FAILOVER_ENABLED="${FAILOVER_ENABLED}"
QOS_BANDWIDTH="${QOS_BANDWIDTH}"
CONF
    log "Config saved"
}

# ── Network Detection ──
get_default_iface() {
    ip route show default 2>/dev/null | awk '/default/ {print $5; exit}'
}

get_all_ifaces() {
    ip -o link show up 2>/dev/null | awk -F': ' '{print $2}' | grep -vE '^(lo|docker|veth|br-|virbr)'
}

is_wireless() {
    local iface="$1"
    [[ -d "/sys/class/net/${iface}/wireless" ]] || iw dev "$iface" info &>/dev/null
}

get_iface_type() {
    local iface="$1"
    if is_wireless "$iface" 2>/dev/null; then
        echo "wifi"
    else
        echo "wired"
    fi
}

get_ip_addr() {
    local iface="$1"
    ip -4 addr show "$iface" 2>/dev/null | awk '/inet / {print $2; exit}'
}

get_gateway() {
    ip route show default 2>/dev/null | awk '/default/ {print $3; exit}'
}

detect_bandwidth() {
    # Quick bandwidth estimate using fast.com or fallback
    if command -v speedtest-cli &>/dev/null; then
        local result
        result=$(speedtest-cli --simple 2>/dev/null | awk '/Download:/ {print int($2)}')
        echo "${result:-100}"
    else
        echo "100"  # assume 100 Mbit
    fi
}

# ── Status Command ──
cmd_status() {
    local iface gateway ip_addr
    iface=$(get_default_iface)
    gateway=$(get_gateway)

    header "Network Status"

    if [[ -z "$iface" ]]; then
        err "No active network interface detected"
        return 1
    fi

    ip_addr=$(get_ip_addr "$iface")
    local iface_type
    iface_type=$(get_iface_type "$iface")

    info "Interface:    ${WHITE}${iface}${RESET} (${iface_type})"
    info "IP Address:   ${WHITE}${ip_addr:-none}${RESET}"
    info "Gateway:      ${WHITE}${gateway:-none}${RESET}"

    # DNS servers
    local dns_servers
    dns_servers=$(grep '^nameserver' /etc/resolv.conf 2>/dev/null | awk '{print $2}' | head -3 | tr '\n' ' ')
    info "DNS:          ${WHITE}${dns_servers:-unknown}${RESET}"

    # WiFi info
    if [[ "$iface_type" == "wifi" ]]; then
        local ssid freq signal
        ssid=$(iw dev "$iface" link 2>/dev/null | awk '/SSID:/ {print $2}')
        freq=$(iw dev "$iface" link 2>/dev/null | awk '/freq:/ {print $2}')
        signal=$(iw dev "$iface" link 2>/dev/null | awk '/signal:/ {print $2" "$3}')
        info "WiFi SSID:    ${WHITE}${ssid:-unknown}${RESET}"
        info "Frequency:    ${WHITE}${freq:-unknown} MHz${RESET}"
        info "Signal:       ${WHITE}${signal:-unknown}${RESET}"

        local powersave
        powersave=$(iw dev "$iface" get power_save 2>/dev/null | awk '{print $NF}')
        if [[ "$powersave" == "on" ]]; then
            warn "Power save:   ${YELLOW}ON${RESET} (increases latency)"
        else
            ok "Power save:   ${GREEN}OFF${RESET}"
        fi
    fi

    # Gaming mode
    header "Gaming Mode"
    if [[ -f "$TC_MARK_FILE" ]]; then
        ok "Gaming mode:  ${GREEN}ACTIVE${RESET}"
    else
        info "Gaming mode:  ${DIM}inactive${RESET}"
    fi

    # Quick latency check
    header "Quick Latency"
    local gw_ping
    if [[ -n "$gateway" ]]; then
        gw_ping=$(ping -c 3 -W 2 "$gateway" 2>/dev/null | awk -F'/' '/avg/ {printf "%.1f", $5}')
        if [[ -n "$gw_ping" ]]; then
            local color=$GREEN
            (( $(echo "$gw_ping > 5" | bc -l 2>/dev/null || echo 0) )) && color=$YELLOW
            (( $(echo "$gw_ping > 20" | bc -l 2>/dev/null || echo 0) )) && color=$RED
            info "Gateway:      ${color}${gw_ping} ms${RESET}"
        else
            warn "Gateway:      unreachable"
        fi
    fi

    local ext_ping
    ext_ping=$(ping -c 3 -W 2 1.1.1.1 2>/dev/null | awk -F'/' '/avg/ {printf "%.1f", $5}')
    if [[ -n "$ext_ping" ]]; then
        local color=$GREEN
        (( $(echo "$ext_ping > 30" | bc -l 2>/dev/null || echo 0) )) && color=$YELLOW
        (( $(echo "$ext_ping > 80" | bc -l 2>/dev/null || echo 0) )) && color=$RED
        info "Internet:     ${color}${ext_ping} ms${RESET} (Cloudflare)"
    else
        warn "Internet:     unreachable"
    fi

    # Connection failover status
    header "Failover"
    local wired_count=0 wifi_count=0
    for ifc in $(get_all_ifaces); do
        local t
        t=$(get_iface_type "$ifc")
        if [[ "$t" == "wired" ]]; then
            ((wired_count++))
            ok "Wired:  ${WHITE}${ifc}${RESET} $(get_ip_addr "$ifc")"
        else
            ((wifi_count++))
            info "WiFi:   ${WHITE}${ifc}${RESET} $(get_ip_addr "$ifc")"
        fi
    done
    if [[ $wired_count -gt 0 && $wifi_count -gt 0 ]]; then
        ok "Failover available (wired ${ARROW} WiFi)"
    elif [[ $((wired_count + wifi_count)) -le 1 ]]; then
        warn "No failover — single connection"
    fi

    echo ""
}

# ── Ping Command ──
ping_server() {
    local host="$1" port="$2" name="$3"
    local result
    # Try TCP ping first (more accurate for game servers), fall back to ICMP
    if command -v nping &>/dev/null; then
        result=$(nping --tcp -p "$port" -c 4 --delay 200ms "$host" 2>/dev/null \
            | awk '/Avg/ {gsub(/ms/,""); print $NF}')
    fi
    if [[ -z "$result" ]]; then
        result=$(ping -c 4 -W 2 "$host" 2>/dev/null | awk -F'/' '/avg/ {printf "%.1f", $5}')
    fi

    if [[ -n "$result" ]]; then
        local color=$GREEN
        local val=${result%.*}
        [[ ${val:-0} -gt 50 ]] && color=$YELLOW
        [[ ${val:-0} -gt 100 ]] && color=$ORANGE
        [[ ${val:-0} -gt 150 ]] && color=$RED
        printf "  ${color}%6s ms${RESET}  %s\n" "$result" "$name"
    else
        printf "  ${RED}%6s   ${RESET}  %s\n" "timeout" "$name"
    fi
}

cmd_ping() {
    local target="${1:-}"

    if [[ -n "$target" ]]; then
        header "Ping: $target"
        local result
        result=$(ping -c 10 -W 2 "$target" 2>/dev/null)
        echo "$result" | tail -2
        return
    fi

    header "24HG Game Servers"
    for entry in "${GAME_SERVERS_24HG[@]}"; do
        IFS=':' read -r host port name <<< "$entry"
        ping_server "$host" "$port" "$name" &
    done
    wait

    header "Popular Game Servers"
    for entry in "${GAME_SERVERS_POPULAR[@]}"; do
        IFS=':' read -r host port name <<< "$entry"
        ping_server "$host" "$port" "$name" &
    done
    wait

    echo ""
}

# ── DNS Command ──
dns_test_provider() {
    local name="$1" servers="$2"
    local primary secondary
    primary=$(echo "$servers" | awk '{print $1}')
    secondary=$(echo "$servers" | awk '{print $2}')

    local total=0 count=0
    for domain in google.com cloudflare.com steam.community.com epicgames.com; do
        local ms
        ms=$(dig @"$primary" "$domain" +noall +stats +tries=1 +time=2 2>/dev/null \
            | awk '/Query time:/ {print $4}')
        if [[ -n "$ms" ]]; then
            total=$((total + ms))
            ((count++))
        fi
    done

    if [[ $count -gt 0 ]]; then
        local avg=$((total / count))
        local color=$GREEN
        [[ $avg -gt 20 ]] && color=$YELLOW
        [[ $avg -gt 50 ]] && color=$RED
        printf "  ${color}%4d ms${RESET}  %-12s  ${DIM}(%s)${RESET}\n" "$avg" "$name" "$primary"
        echo "$avg:$name"
    else
        printf "  ${RED}  fail${RESET}  %-12s  ${DIM}(%s)${RESET}\n" "$name" "$primary"
        echo "9999:$name"
    fi
}

cmd_dns() {
    local subcmd="${1:-test}"

    case "$subcmd" in
        test)
            header "DNS Resolver Comparison"
            info "Testing resolution speed for game-related domains..."
            echo ""

            local best_time=9999 best_name=""
            for provider in "${!DNS_PROVIDERS[@]}"; do
                local output
                output=$(dns_test_provider "$provider" "${DNS_PROVIDERS[$provider]}" 2>/dev/null | tail -1)
                local time=${output%%:*}
                local name=${output#*:}
                if [[ ${time:-9999} -lt $best_time ]]; then
                    best_time=$time
                    best_name=$name
                fi
            done

            echo ""
            ok "Fastest resolver: ${GREEN}${best_name}${RESET} (${best_time} ms avg)"
            info "Apply with: ${WHITE}24hg-net-optimizer dns set ${best_name}${RESET}"
            echo ""
            ;;

        set)
            local provider="${2:-}"
            if [[ -z "$provider" || -z "${DNS_PROVIDERS[$provider]:-}" ]]; then
                err "Unknown provider. Available: ${!DNS_PROVIDERS[*]}"
                return 1
            fi
            need_root "$@"

            local servers="${DNS_PROVIDERS[$provider]}"
            local primary secondary
            primary=$(echo "$servers" | awk '{print $1}')
            secondary=$(echo "$servers" | awk '{print $2}')

            # Backup current resolv.conf
            cp /etc/resolv.conf "$BACKUP_DIR/resolv.conf.bak" 2>/dev/null || true

            # Try systemd-resolved first
            if systemctl is-active systemd-resolved &>/dev/null; then
                mkdir -p /etc/systemd/resolved.conf.d
                cat > /etc/systemd/resolved.conf.d/24hg-dns.conf <<DNSCONF
[Resolve]
DNS=${primary} ${secondary}
DNSOverTLS=opportunistic
DNSCONF
                systemctl restart systemd-resolved
                ok "Set DNS to ${GREEN}${provider}${RESET} via systemd-resolved"
            else
                # Direct resolv.conf
                cat > /etc/resolv.conf <<RESOLV
# 24HG Net Optimizer — $provider
nameserver $primary
nameserver $secondary
RESOLV
                ok "Set DNS to ${GREEN}${provider}${RESET} via resolv.conf"
            fi

            PREFERRED_DNS="$provider"
            save_config
            log "DNS set to $provider ($primary, $secondary)"
            ;;

        *)
            err "Usage: 24hg-net-optimizer dns [test|set <provider>]"
            ;;
    esac
}

# ── Buffer Tuning ──
apply_buffer_tuning() {
    need_root "$@"

    header "Kernel Network Buffer Tuning"

    # Backup current sysctl values
    local backup_file="$BACKUP_DIR/sysctl-$(date +%Y%m%d%H%M%S).conf"
    sysctl -a 2>/dev/null | grep -E '^net\.(core|ipv4)\.' > "$backup_file" || true

    cat > "$SYSCTL_CONF" <<'SYSCTL'
# 24HG Net Optimizer — Low-latency gaming network tuning

# Reduce TCP bufferbloat
net.ipv4.tcp_congestion_control = bbr
net.core.default_qdisc = fq

# Smaller buffers for lower latency (gaming priority over throughput)
net.core.rmem_default = 262144
net.core.wmem_default = 262144
net.core.rmem_max = 4194304
net.core.wmem_max = 4194304
net.ipv4.tcp_rmem = 4096 87380 4194304
net.ipv4.tcp_wmem = 4096 65536 4194304

# Faster connection handling
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15
net.ipv4.tcp_keepalive_time = 300
net.ipv4.tcp_keepalive_intvl = 15
net.ipv4.tcp_keepalive_probes = 5

# Reduce latency
net.ipv4.tcp_low_latency = 1
net.ipv4.tcp_timestamps = 1
net.ipv4.tcp_sack = 1
net.ipv4.tcp_window_scaling = 1

# UDP buffer optimization
net.core.netdev_max_backlog = 5000
net.core.netdev_budget = 600

# Conntrack tuning for game ports
net.netfilter.nf_conntrack_udp_timeout = 30
net.netfilter.nf_conntrack_udp_timeout_stream = 60
SYSCTL

    sysctl -p "$SYSCTL_CONF" &>/dev/null
    ok "Applied low-latency kernel buffer settings"
    ok "TCP congestion: ${WHITE}BBR${RESET}"
    ok "Queue discipline: ${WHITE}fq${RESET}"
    ok "Backup saved to ${DIM}${backup_file}${RESET}"
    log "Buffer tuning applied, backup at $backup_file"
}

# ── WiFi Optimization ──
optimize_wifi() {
    local iface="$1"

    if ! is_wireless "$iface" 2>/dev/null; then
        info "Interface ${iface} is not wireless, skipping WiFi optimization"
        return
    fi

    header "WiFi Optimization: $iface"
    need_root "$@"

    # Disable power saving
    if iw dev "$iface" set power_save off 2>/dev/null; then
        ok "Power save disabled"
    else
        warn "Could not disable power save"
    fi

    # Attempt to set regulatory domain for best channel selection
    if command -v iw &>/dev/null; then
        local current_channel
        current_channel=$(iw dev "$iface" info 2>/dev/null | awk '/channel/ {print $2; exit}')
        info "Current channel: ${WHITE}${current_channel:-unknown}${RESET}"

        # Scan for least congested channel
        local scan_results
        scan_results=$(iw dev "$iface" scan 2>/dev/null | awk '/primary channel:/ {print $NF}' | sort | uniq -c | sort -n)
        if [[ -n "$scan_results" ]]; then
            info "Channel congestion (fewer APs = better):"
            echo "$scan_results" | head -5 | while read -r count ch; do
                local color=$GREEN
                [[ $count -gt 3 ]] && color=$YELLOW
                [[ $count -gt 6 ]] && color=$RED
                printf "    ${color}Channel %2s${RESET}: %d APs\n" "$ch" "$count"
            done
        fi
    fi

    # Set WiFi adapter to maximum performance if available
    for param in /sys/class/net/"$iface"/device/power/control; do
        if [[ -w "$param" ]]; then
            echo "on" > "$param" 2>/dev/null && ok "Device power control: on"
        fi
    done

    log "WiFi optimized on $iface"
}

# ── Traffic Prioritization (tc + iptables) ──
gaming_on() {
    need_root "$@"

    local iface
    iface=$(get_default_iface)
    if [[ -z "$iface" ]]; then
        err "No active interface"
        return 1
    fi

    header "Enabling Gaming Priority Mode"

    # Save existing iptables rules
    iptables-save > "$IPTABLES_SAVE" 2>/dev/null || true

    # Clear existing qdisc
    tc qdisc del dev "$iface" root 2>/dev/null || true

    # Create HTB qdisc with priority classes
    # Class 1:10 = high priority (game traffic)
    # Class 1:20 = normal traffic
    # Class 1:30 = low priority (bulk downloads)
    local bandwidth="${QOS_BANDWIDTH}"
    if [[ "$bandwidth" == "0" ]]; then
        bandwidth=100  # default to 100mbit
    fi

    tc qdisc add dev "$iface" root handle 1: htb default 20
    tc class add dev "$iface" parent 1: classid 1:1 htb rate "${bandwidth}mbit" burst 15k
    tc class add dev "$iface" parent 1:1 classid 1:10 htb rate "$((bandwidth * 60 / 100))mbit" ceil "${bandwidth}mbit" burst 15k prio 1
    tc class add dev "$iface" parent 1:1 classid 1:20 htb rate "$((bandwidth * 30 / 100))mbit" ceil "${bandwidth}mbit" burst 15k prio 2
    tc class add dev "$iface" parent 1:1 classid 1:30 htb rate "$((bandwidth * 10 / 100))mbit" ceil "$((bandwidth * 80 / 100))mbit" burst 15k prio 3

    # Low-latency qdisc on gaming class
    tc qdisc add dev "$iface" parent 1:10 handle 10: sfq perturb 10
    tc qdisc add dev "$iface" parent 1:20 handle 20: sfq perturb 10
    tc qdisc add dev "$iface" parent 1:30 handle 30: sfq perturb 10

    ok "Traffic shaping configured (${bandwidth} Mbit)"

    # Mark game traffic with iptables
    local mark_count=0
    for game in "${!GAME_PORTS[@]}"; do
        local ports="${GAME_PORTS[$game]}"
        for port_range in $ports; do
            if [[ "$port_range" == *:* ]]; then
                iptables -t mangle -A OUTPUT -p udp --dport "$port_range" -j MARK --set-mark 10 2>/dev/null && ((mark_count++)) || true
                iptables -t mangle -A OUTPUT -p tcp --dport "$port_range" -j MARK --set-mark 10 2>/dev/null || true
            else
                iptables -t mangle -A OUTPUT -p udp --dport "$port_range" -j MARK --set-mark 10 2>/dev/null && ((mark_count++)) || true
                iptables -t mangle -A OUTPUT -p tcp --dport "$port_range" -j MARK --set-mark 10 2>/dev/null || true
            fi
        done
    done

    # Route marked traffic to high-priority class
    tc filter add dev "$iface" parent 1: protocol ip handle 10 fw flowid 1:10

    # Mark bulk traffic (large downloads, torrents) as low priority
    iptables -t mangle -A OUTPUT -p tcp --dport 80 -m length --length 512: -j MARK --set-mark 30 2>/dev/null || true
    iptables -t mangle -A OUTPUT -p tcp --dport 443 -m length --length 1400: -j MARK --set-mark 30 2>/dev/null || true
    tc filter add dev "$iface" parent 1: protocol ip handle 30 fw flowid 1:30

    ok "Game port rules applied (${mark_count} port ranges marked)"

    # Record active state
    echo "$iface" > "$TC_MARK_FILE"
    GAMING_MODE="on"
    save_config

    ok "Gaming priority mode: ${GREEN}ACTIVE${RESET}"
    info "Game traffic gets 60% guaranteed bandwidth with full burst"
    log "Gaming mode enabled on $iface"
    echo ""
}

gaming_off() {
    need_root "$@"

    header "Disabling Gaming Priority Mode"

    local iface
    if [[ -f "$TC_MARK_FILE" ]]; then
        iface=$(cat "$TC_MARK_FILE")
    else
        iface=$(get_default_iface)
    fi

    if [[ -n "$iface" ]]; then
        tc qdisc del dev "$iface" root 2>/dev/null || true
        ok "Traffic shaping removed from $iface"
    fi

    # Restore iptables mangle rules
    if [[ -f "$IPTABLES_SAVE" ]]; then
        iptables-restore < "$IPTABLES_SAVE" 2>/dev/null || true
        ok "Firewall rules restored"
    else
        iptables -t mangle -F 2>/dev/null || true
        ok "Mangle table flushed"
    fi

    rm -f "$TC_MARK_FILE"
    GAMING_MODE="off"
    save_config

    ok "Gaming priority mode: ${DIM}disabled${RESET}"
    log "Gaming mode disabled"
    echo ""
}

cmd_gaming() {
    local action="${1:-}"
    case "$action" in
        on)  gaming_on ;;
        off) gaming_off ;;
        *)
            if [[ -f "$TC_MARK_FILE" ]]; then
                info "Gaming mode is ${GREEN}ON${RESET}"
                echo -e "  Use ${WHITE}24hg-net-optimizer gaming off${RESET} to disable"
            else
                info "Gaming mode is ${DIM}OFF${RESET}"
                echo -e "  Use ${WHITE}24hg-net-optimizer gaming on${RESET} to enable"
            fi
            ;;
    esac
}

# ── Failover Management ──
setup_failover() {
    local wired="" wifi=""

    for ifc in $(get_all_ifaces); do
        local t
        t=$(get_iface_type "$ifc")
        if [[ "$t" == "wired" && -z "$wired" ]]; then
            wired="$ifc"
        elif [[ "$t" == "wifi" && -z "$wifi" ]]; then
            wifi="$ifc"
        fi
    done

    if [[ -z "$wired" || -z "$wifi" ]]; then
        info "Failover requires both wired and WiFi interfaces"
        return
    fi

    header "Connection Failover"

    # Check if wired is preferred and has link
    local wired_carrier
    wired_carrier=$(cat "/sys/class/net/${wired}/carrier" 2>/dev/null || echo 0)
    local current_default
    current_default=$(get_default_iface)

    if [[ "$wired_carrier" == "1" && "$PREFER_WIRED" == "yes" ]]; then
        if [[ "$current_default" != "$wired" ]]; then
            info "Wired link detected, switching default route to ${WHITE}${wired}${RESET}"
            local gw
            gw=$(ip route show dev "$wired" 2>/dev/null | awk '/default/ {print $3}')
            if [[ -n "$gw" ]]; then
                ip route replace default via "$gw" dev "$wired" metric 100 2>/dev/null || true
                ip route replace default via "$(get_gateway)" dev "$wifi" metric 200 2>/dev/null || true
                ok "Default route: ${WHITE}${wired}${RESET} (wired preferred)"
            fi
        else
            ok "Already using wired: ${WHITE}${wired}${RESET}"
        fi
    elif [[ "$wired_carrier" != "1" ]]; then
        warn "Wired link down, using WiFi: ${WHITE}${wifi}${RESET}"
        if [[ "$current_default" == "$wired" ]]; then
            local wifi_gw
            wifi_gw=$(ip route show dev "$wifi" 2>/dev/null | awk '/default/ {print $3; exit}')
            if [[ -n "$wifi_gw" ]]; then
                ip route replace default via "$wifi_gw" dev "$wifi" metric 100 2>/dev/null || true
                ok "Failover to WiFi active"
            fi
        fi
    fi

    log "Failover check: wired=$wired wifi=$wifi carrier=$wired_carrier"
}

# ── Bandwidth Monitor ──
cmd_monitor() {
    header "Live Bandwidth Monitor"
    info "Press Ctrl+C to exit"
    echo ""

    if command -v nethogs &>/dev/null; then
        need_root "$@"
        local iface
        iface=$(get_default_iface)
        nethogs -d 2 "$iface" 2>/dev/null
    elif command -v iftop &>/dev/null; then
        need_root "$@"
        local iface
        iface=$(get_default_iface)
        iftop -i "$iface" -n -P 2>/dev/null
    elif command -v ss &>/dev/null; then
        # Fallback: poll /proc/net/dev + ss
        local iface
        iface=$(get_default_iface)
        local prev_rx=0 prev_tx=0

        while true; do
            local stats rx tx
            stats=$(awk -v iface="$iface:" '$1 == iface {print $2, $10}' /proc/net/dev)
            rx=$(echo "$stats" | awk '{print $1}')
            tx=$(echo "$stats" | awk '{print $2}')

            if [[ $prev_rx -gt 0 ]]; then
                local drx=$((rx - prev_rx))
                local dtx=$((tx - prev_tx))
                local drx_kb=$((drx / 1024))
                local dtx_kb=$((dtx / 1024))

                printf "\r  ${CYAN}▼${RESET} %7d KB/s  ${MAGENTA}▲${RESET} %7d KB/s  ${DIM}(%s)${RESET}   " \
                    "$drx_kb" "$dtx_kb" "$iface"

                # Top connections
                echo ""
                ss -tunp 2>/dev/null | awk 'NR>1 {print $5, $6}' | head -5 | while read -r peer proc; do
                    local pname
                    pname=$(echo "$proc" | grep -oP '"\K[^"]+' | head -1)
                    printf "    ${DIM}%-20s %s${RESET}\n" "$peer" "${pname:-unknown}"
                done
                # Move cursor up for overwrite
                printf "\033[6A"
            fi

            prev_rx=$rx
            prev_tx=$tx
            sleep 1
        done
    else
        err "Install nethogs or iftop for best experience"
        err "  sudo dnf install nethogs iftop"
    fi
}

# ── Game Port Forwarding ──
cmd_ports() {
    header "Game Port Configuration"

    local iface
    iface=$(get_default_iface)

    # Detect running games and needed ports
    info "Scanning for game processes..."
    echo ""

    local found=0
    for game in "${!GAME_PORTS[@]}"; do
        local ports="${GAME_PORTS[$game]}"
        # Check if any process is listening on these ports
        local listening=false
        for port_range in $ports; do
            local start_port end_port
            if [[ "$port_range" == *:* ]]; then
                start_port="${port_range%%:*}"
                end_port="${port_range##*:}"
            else
                start_port="$port_range"
                end_port="$port_range"
            fi

            if ss -ulnp 2>/dev/null | awk '{print $5}' | grep -qE ":($start_port)" 2>/dev/null; then
                listening=true
                break
            fi
        done

        local status_icon="${DIM}${CROSS}${RESET}"
        if $listening; then
            status_icon="${GREEN}${CHECK}${RESET}"
            ((found++))
        fi

        printf "  %s  %-14s  ${DIM}UDP %s${RESET}\n" "$status_icon" "$game" "$ports"
    done

    echo ""
    if [[ $found -gt 0 ]]; then
        ok "$found game(s) detected with active ports"
    else
        info "No game servers currently listening"
    fi

    # Check firewall status
    header "Firewall Status"
    if command -v firewall-cmd &>/dev/null; then
        local zone
        zone=$(firewall-cmd --get-default-zone 2>/dev/null || echo "unknown")
        info "Firewalld zone: ${WHITE}${zone}${RESET}"

        local open_ports
        open_ports=$(firewall-cmd --list-ports 2>/dev/null || echo "none")
        info "Open ports: ${WHITE}${open_ports}${RESET}"
    elif command -v ufw &>/dev/null; then
        local ufw_status
        ufw_status=$(ufw status 2>/dev/null | head -1)
        info "UFW: ${WHITE}${ufw_status}${RESET}"
    else
        info "No firewall manager detected"
    fi

    echo ""
    info "To open ports for a game:"
    echo -e "  ${WHITE}sudo firewall-cmd --add-port=27015-27050/udp --permanent${RESET}"
    echo ""
}

# ── Comprehensive Test ──
cmd_test() {
    header "Comprehensive Network Test"

    local score=0 max_score=0

    # 1. Interface check
    local iface
    iface=$(get_default_iface)
    ((max_score += 10))
    if [[ -n "$iface" ]]; then
        ok "Active interface: $iface"
        ((score += 10))
    else
        err "No active interface"
    fi

    # 2. Gateway latency
    local gw
    gw=$(get_gateway)
    ((max_score += 15))
    if [[ -n "$gw" ]]; then
        local gw_ping
        gw_ping=$(ping -c 5 -W 2 "$gw" 2>/dev/null | awk -F'/' '/avg/ {printf "%.0f", $5}')
        if [[ -n "$gw_ping" && "${gw_ping:-999}" -lt 10 ]]; then
            ok "Gateway latency: ${gw_ping} ms (excellent)"
            ((score += 15))
        elif [[ -n "$gw_ping" && "${gw_ping:-999}" -lt 30 ]]; then
            warn "Gateway latency: ${gw_ping} ms (acceptable)"
            ((score += 10))
        else
            err "Gateway latency: ${gw_ping:-timeout} ms (poor)"
        fi
    fi

    # 3. Internet connectivity
    ((max_score += 10))
    local inet_ping
    inet_ping=$(ping -c 5 -W 2 1.1.1.1 2>/dev/null | awk -F'/' '/avg/ {printf "%.0f", $5}')
    if [[ -n "$inet_ping" ]]; then
        ok "Internet reachable: ${inet_ping} ms"
        ((score += 10))
    else
        err "Internet unreachable"
    fi

    # 4. DNS resolution speed
    ((max_score += 15))
    local dns_time
    dns_time=$(dig google.com +noall +stats +tries=1 +time=3 2>/dev/null | awk '/Query time:/ {print $4}')
    if [[ -n "$dns_time" && "${dns_time:-999}" -lt 20 ]]; then
        ok "DNS resolution: ${dns_time} ms (fast)"
        ((score += 15))
    elif [[ -n "$dns_time" && "${dns_time:-999}" -lt 50 ]]; then
        warn "DNS resolution: ${dns_time} ms (moderate)"
        ((score += 10))
    else
        err "DNS resolution: ${dns_time:-timeout} ms (slow)"
    fi

    # 5. Packet loss
    ((max_score += 15))
    local loss
    loss=$(ping -c 20 -W 2 1.1.1.1 2>/dev/null | awk -F'[,%]' '/loss/ {print $2}' | tr -d ' ')
    if [[ "${loss:-100}" == "0" ]]; then
        ok "Packet loss: 0% (perfect)"
        ((score += 15))
    elif [[ "${loss:-100}" -lt 3 ]]; then
        warn "Packet loss: ${loss}%"
        ((score += 10))
    else
        err "Packet loss: ${loss}%"
    fi

    # 6. TCP congestion control
    ((max_score += 10))
    local cc
    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    if [[ "$cc" == "bbr" ]]; then
        ok "TCP congestion: BBR (optimal)"
        ((score += 10))
    else
        warn "TCP congestion: ${cc:-unknown} (BBR recommended)"
        ((score += 5))
    fi

    # 7. WiFi power save
    ((max_score += 10))
    if is_wireless "$iface" 2>/dev/null; then
        local ps
        ps=$(iw dev "$iface" get power_save 2>/dev/null | awk '{print $NF}')
        if [[ "$ps" == "off" ]]; then
            ok "WiFi power save: off (good for gaming)"
            ((score += 10))
        else
            warn "WiFi power save: on (adds latency)"
            ((score += 5))
        fi
    else
        ok "Wired connection (no WiFi latency)"
        ((score += 10))
    fi

    # 8. Gaming mode
    ((max_score += 15))
    if [[ -f "$TC_MARK_FILE" ]]; then
        ok "Gaming priority: active"
        ((score += 15))
    else
        info "Gaming priority: not active"
        ((score += 5))
    fi

    # Final score
    echo ""
    local pct=$((score * 100 / max_score))
    local grade_color=$RED grade="F"
    if [[ $pct -ge 90 ]]; then grade_color=$GREEN; grade="A"
    elif [[ $pct -ge 75 ]]; then grade_color=$GREEN; grade="B"
    elif [[ $pct -ge 60 ]]; then grade_color=$YELLOW; grade="C"
    elif [[ $pct -ge 40 ]]; then grade_color=$ORANGE; grade="D"
    fi

    header "Network Score"
    echo -e "  ${grade_color}${BOLD}  ${grade}  ${RESET}  ${WHITE}${score}/${max_score}${RESET} (${pct}%)"
    echo ""

    if [[ $pct -lt 75 ]]; then
        info "Run ${WHITE}24hg-net-optimizer optimize${RESET} to improve your score"
    fi
    echo ""
}

# ── Optimize All ──
cmd_optimize() {
    header "Full Network Optimization"
    info "Applying all gaming network optimizations..."
    echo ""

    need_root "$@"

    # 1. Buffer tuning
    apply_buffer_tuning

    # 2. WiFi optimization
    local iface
    iface=$(get_default_iface)
    if is_wireless "$iface" 2>/dev/null; then
        optimize_wifi "$iface"
    fi

    # 3. Failover setup
    setup_failover

    # 4. Enable gaming mode
    gaming_on

    # 5. DNS test and set fastest
    echo ""
    info "Testing DNS resolvers..."
    local best_time=9999 best_provider=""
    for provider in "${!DNS_PROVIDERS[@]}"; do
        local total=0 count=0
        local primary
        primary=$(echo "${DNS_PROVIDERS[$provider]}" | awk '{print $1}')
        for domain in google.com steam.community.com; do
            local ms
            ms=$(dig @"$primary" "$domain" +noall +stats +tries=1 +time=2 2>/dev/null \
                | awk '/Query time:/ {print $4}')
            if [[ -n "$ms" ]]; then
                total=$((total + ms))
                ((count++))
            fi
        done
        if [[ $count -gt 0 ]]; then
            local avg=$((total / count))
            if [[ $avg -lt $best_time ]]; then
                best_time=$avg
                best_provider=$provider
            fi
        fi
    done
    if [[ -n "$best_provider" ]]; then
        cmd_dns set "$best_provider"
    fi

    echo ""
    ok "${GREEN}${BOLD}All optimizations applied!${RESET}"
    info "Run ${WHITE}24hg-net-optimizer test${RESET} to verify improvements"
    info "Run ${WHITE}24hg-net-optimizer reset${RESET} to undo all changes"
    echo ""
    log "Full optimization applied"
}

# ── Reset ──
cmd_reset() {
    need_root "$@"

    header "Resetting Network Optimizations"

    # Remove tc rules
    local iface
    iface=$(get_default_iface)
    if [[ -n "$iface" ]]; then
        tc qdisc del dev "$iface" root 2>/dev/null || true
        ok "Traffic shaping removed"
    fi

    # Restore iptables
    if [[ -f "$IPTABLES_SAVE" ]]; then
        iptables-restore < "$IPTABLES_SAVE" 2>/dev/null || true
        ok "Firewall rules restored"
    else
        iptables -t mangle -F 2>/dev/null || true
        ok "Mangle table flushed"
    fi

    # Remove sysctl overrides
    if [[ -f "$SYSCTL_CONF" ]]; then
        rm -f "$SYSCTL_CONF"
        sysctl --system &>/dev/null
        ok "Kernel tuning reset to defaults"
    fi

    # Restore DNS
    if [[ -f "$BACKUP_DIR/resolv.conf.bak" ]]; then
        cp "$BACKUP_DIR/resolv.conf.bak" /etc/resolv.conf 2>/dev/null || true
        ok "DNS restored"
    fi
    rm -f /etc/systemd/resolved.conf.d/24hg-dns.conf 2>/dev/null
    systemctl restart systemd-resolved 2>/dev/null || true

    # Re-enable WiFi power save
    if [[ -n "$iface" ]] && is_wireless "$iface" 2>/dev/null; then
        iw dev "$iface" set power_save on 2>/dev/null || true
        ok "WiFi power save re-enabled"
    fi

    # Clean state files
    rm -f "$TC_MARK_FILE"
    GAMING_MODE="off"
    save_config

    echo ""
    ok "${GREEN}All network tweaks reset to system defaults${RESET}"
    log "All optimizations reset"
    echo ""
}

# ── Help ──
show_help() {
    echo ""
    echo -e "  ${MAGENTA}${BOLD}24HG Net Optimizer${RESET} ${DIM}— Gaming network stack optimization${RESET}"
    echo ""
    echo -e "  ${WHITE}USAGE${RESET}"
    echo -e "    24hg-net-optimizer <command> [options]"
    echo ""
    echo -e "  ${WHITE}COMMANDS${RESET}"
    echo -e "    ${CYAN}status${RESET}              Show network status and latency"
    echo -e "    ${CYAN}test${RESET}                Run comprehensive network test"
    echo -e "    ${CYAN}ping${RESET} [server]       Ping test to game servers"
    echo -e "    ${CYAN}dns${RESET} [test|set <p>]  DNS optimization (cloudflare/google/quad9/opendns)"
    echo -e "    ${CYAN}optimize${RESET}            Apply all network optimizations"
    echo -e "    ${CYAN}gaming${RESET} [on|off]     Toggle gaming priority mode"
    echo -e "    ${CYAN}monitor${RESET}             Live bandwidth monitor"
    echo -e "    ${CYAN}reset${RESET}               Reset all network tweaks to default"
    echo ""
    echo -e "  ${WHITE}EXAMPLES${RESET}"
    echo -e "    ${DIM}24hg-net-optimizer optimize       ${RESET}# Apply all optimizations"
    echo -e "    ${DIM}24hg-net-optimizer gaming on       ${RESET}# Enable traffic prioritization"
    echo -e "    ${DIM}24hg-net-optimizer ping 91.99.37.118${RESET}# Ping a specific server"
    echo -e "    ${DIM}24hg-net-optimizer dns set google  ${RESET}# Switch to Google DNS"
    echo ""
    echo -e "  ${WHITE}CONFIG${RESET}"
    echo -e "    ${DIM}${CONFIG_DIR}/${RESET}"
    echo ""
}

# ── Main ──
load_config

case "${1:-}" in
    status)                cmd_status ;;
    test)                  cmd_test ;;
    ping)                  shift; cmd_ping "$@" ;;
    dns)                   shift; cmd_dns "$@" ;;
    optimize)              cmd_optimize ;;
    gaming)                shift; cmd_gaming "$@" ;;
    monitor)               cmd_monitor ;;
    ports)                 cmd_ports ;;
    reset)                 cmd_reset ;;
    -h|--help|help|"")     show_help ;;
    *)
        err "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
