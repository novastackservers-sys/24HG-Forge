#!/usr/bin/env bash
# forge-boot-select — Boot mode selector for 24HG Forge Linux
# Switch between Desktop Mode (KDE Plasma) and Game Mode (Gamescope/Steam Big Picture)
# seamlessly without a full reboot.

set -euo pipefail

VERSION="1.0.0"
SCRIPT_NAME="forge-boot-select"

# --- Paths ---
SYSTEM_CONF="/etc/forge/boot-select.conf"
USER_CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge/boot-select"
USER_CONF="$USER_CONF_DIR/config"
STATE_FILE="$USER_CONF_DIR/last-mode"
GAMESCOPE_CONF="$USER_CONF_DIR/gamescope.conf"

# --- Desktop session identifiers ---
DESKTOP_SESSION="plasma"
GAMEMODE_SESSION="gamescope-session"

# --- Defaults ---
DEFAULT_MODE="desktop"
DEFAULT_RESOLUTION="1920x1080"
DEFAULT_REFRESH="60"
DEFAULT_VRR="off"
DEFAULT_HDR="off"
DEFAULT_FILTER="linear"
DEFAULT_FSR="off"
DEFAULT_FSR_SHARPNESS="5"
DEFAULT_MANGOAPP="on"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# --- Helpers ---

log_info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

ensure_dirs() {
    mkdir -p "$USER_CONF_DIR"
    if [[ $EUID -eq 0 ]]; then
        mkdir -p "$(dirname "$SYSTEM_CONF")"
    fi
}

# Load system config, then user config (user overrides system)
load_config() {
    # System-level defaults
    if [[ -f "$SYSTEM_CONF" ]]; then
        # shellcheck source=/dev/null
        source "$SYSTEM_CONF"
    fi
    # User-level overrides
    if [[ -f "$USER_CONF" ]]; then
        # shellcheck source=/dev/null
        source "$USER_CONF"
    fi
    # Gamescope settings
    if [[ -f "$GAMESCOPE_CONF" ]]; then
        # shellcheck source=/dev/null
        source "$GAMESCOPE_CONF"
    fi

    BOOT_MODE="${BOOT_MODE:-$DEFAULT_MODE}"
    GS_RESOLUTION="${GS_RESOLUTION:-$DEFAULT_RESOLUTION}"
    GS_REFRESH="${GS_REFRESH:-$DEFAULT_REFRESH}"
    GS_VRR="${GS_VRR:-$DEFAULT_VRR}"
    GS_HDR="${GS_HDR:-$DEFAULT_HDR}"
    GS_FILTER="${GS_FILTER:-$DEFAULT_FILTER}"
    GS_FSR="${GS_FSR:-$DEFAULT_FSR}"
    GS_FSR_SHARPNESS="${GS_FSR_SHARPNESS:-$DEFAULT_FSR_SHARPNESS}"
    GS_MANGOAPP="${GS_MANGOAPP:-$DEFAULT_MANGOAPP}"
    AUTO_LOGIN="${AUTO_LOGIN:-off}"
}

save_user_config() {
    ensure_dirs
    cat > "$USER_CONF" <<EOF
# Forge Boot Select — User Config
# Generated $(date -Iseconds)
BOOT_MODE="$BOOT_MODE"
AUTO_LOGIN="$AUTO_LOGIN"
EOF
}

save_gamescope_config() {
    ensure_dirs
    cat > "$GAMESCOPE_CONF" <<EOF
# Forge Boot Select — Gamescope Settings
# Generated $(date -Iseconds)
GS_RESOLUTION="$GS_RESOLUTION"
GS_REFRESH="$GS_REFRESH"
GS_VRR="$GS_VRR"
GS_HDR="$GS_HDR"
GS_FILTER="$GS_FILTER"
GS_FSR="$GS_FSR"
GS_FSR_SHARPNESS="$GS_FSR_SHARPNESS"
GS_MANGOAPP="$GS_MANGOAPP"
EOF
}

save_system_default() {
    local mode="$1"
    if [[ $EUID -ne 0 ]]; then
        log_warn "Setting system default requires root. Trying with sudo..."
        sudo mkdir -p "$(dirname "$SYSTEM_CONF")"
        sudo tee "$SYSTEM_CONF" > /dev/null <<EOF
# Forge Boot Select — System Default
# Set by $SCRIPT_NAME on $(date -Iseconds)
BOOT_MODE="$mode"
EOF
    else
        mkdir -p "$(dirname "$SYSTEM_CONF")"
        cat > "$SYSTEM_CONF" <<EOF
# Forge Boot Select — System Default
# Set by $SCRIPT_NAME on $(date -Iseconds)
BOOT_MODE="$mode"
EOF
    fi
}

save_last_mode() {
    ensure_dirs
    echo "$1" > "$STATE_FILE"
}

get_last_mode() {
    if [[ -f "$STATE_FILE" ]]; then
        cat "$STATE_FILE"
    else
        echo "$BOOT_MODE"
    fi
}

# Detect which session is currently running
detect_current_mode() {
    local session="${XDG_SESSION_DESKTOP:-${XDG_CURRENT_DESKTOP:-unknown}}"
    session="${session,,}" # lowercase

    if [[ "$session" == *"gamescope"* ]] || pgrep -x gamescope &>/dev/null; then
        echo "gamemode"
    elif [[ "$session" == *"kde"* || "$session" == *"plasma"* ]] || pgrep -x plasmashell &>/dev/null; then
        echo "desktop"
    else
        echo "unknown"
    fi
}

# Get the display manager in use
detect_dm() {
    if systemctl is-active --quiet sddm 2>/dev/null; then
        echo "sddm"
    elif systemctl is-active --quiet gdm 2>/dev/null; then
        echo "gdm"
    elif systemctl is-active --quiet lightdm 2>/dev/null; then
        echo "lightdm"
    else
        echo "unknown"
    fi
}

# Build gamescope command line from config
build_gamescope_cmd() {
    local width height
    width="${GS_RESOLUTION%%x*}"
    height="${GS_RESOLUTION##*x}"

    local cmd="gamescope"
    cmd+=" -W $width -H $height"
    cmd+=" -r $GS_REFRESH"

    [[ "$GS_VRR" == "on" ]]  && cmd+=" --adaptive-sync"
    [[ "$GS_HDR" == "on" ]]  && cmd+=" --hdr-enabled"
    [[ "$GS_FSR" == "on" ]]  && cmd+=" --fsr-sharpness $GS_FSR_SHARPNESS"
    [[ "$GS_FILTER" != "linear" ]] && cmd+=" --filter $GS_FILTER"
    [[ "$GS_MANGOAPP" == "on" ]] && cmd+=" --mangoapp"

    cmd+=" -e -- steam -gamepadui"
    echo "$cmd"
}

# Configure auto-login for SDDM
configure_auto_login() {
    local state="$1"
    local user="${SUDO_USER:-$USER}"
    local sddm_conf="/etc/sddm.conf.d/forge-autologin.conf"

    if [[ $EUID -ne 0 ]]; then
        log_warn "Auto-login configuration requires root. Trying with sudo..."
        if [[ "$state" == "on" ]]; then
            local session_name
            [[ "$BOOT_MODE" == "gamemode" ]] && session_name="$GAMEMODE_SESSION" || session_name="$DESKTOP_SESSION"
            sudo mkdir -p /etc/sddm.conf.d
            sudo tee "$sddm_conf" > /dev/null <<EOF
[Autologin]
User=$user
Session=$session_name
EOF
        else
            sudo rm -f "$sddm_conf"
        fi
    else
        if [[ "$state" == "on" ]]; then
            local session_name
            [[ "$BOOT_MODE" == "gamemode" ]] && session_name="$GAMEMODE_SESSION" || session_name="$DESKTOP_SESSION"
            mkdir -p /etc/sddm.conf.d
            cat > "$sddm_conf" <<EOF
[Autologin]
User=$user
Session=$session_name
EOF
        else
            rm -f "$sddm_conf"
        fi
    fi
}

# --- Switch Logic ---

switch_to_mode() {
    local target="$1"
    local current
    current="$(detect_current_mode)"

    if [[ "$current" == "$target" ]]; then
        log_info "Already in ${BOLD}${target}${NC} mode."
        return 0
    fi

    log_info "Switching from ${BOLD}${current}${NC} to ${BOLD}${target}${NC} mode..."

    BOOT_MODE="$target"
    save_user_config
    save_last_mode "$target"

    # Update auto-login session if enabled
    if [[ "$AUTO_LOGIN" == "on" ]]; then
        configure_auto_login on
    fi

    local dm
    dm="$(detect_dm)"

    echo ""
    log_warn "This will restart your display session. Save all work first!"
    echo -en "${YELLOW}Proceed? [y/N]:${NC} "
    read -r confirm
    if [[ "${confirm,,}" != "y" ]]; then
        log_info "Switch cancelled."
        return 1
    fi

    log_info "Restarting display manager ($dm)..."

    case "$dm" in
        sddm)
            if [[ $EUID -ne 0 ]]; then
                sudo systemctl restart sddm
            else
                systemctl restart sddm
            fi
            ;;
        gdm)
            if [[ $EUID -ne 0 ]]; then
                sudo systemctl restart gdm
            else
                systemctl restart gdm
            fi
            ;;
        *)
            log_error "Could not detect display manager. Please log out and select '$target' session manually."
            return 1
            ;;
    esac
}

# --- Commands ---

cmd_status() {
    load_config
    local current last_mode dm

    current="$(detect_current_mode)"
    last_mode="$(get_last_mode)"
    dm="$(detect_dm)"

    echo -e "${BOLD}${CYAN}=== Forge Boot Select ===${NC}"
    echo ""
    echo -e "  ${BOLD}Current mode:${NC}   $(
        case "$current" in
            desktop)  echo -e "${GREEN}Desktop Mode${NC} (KDE Plasma)" ;;
            gamemode) echo -e "${BLUE}Game Mode${NC} (Gamescope + Steam)" ;;
            *)        echo -e "${YELLOW}Unknown${NC}" ;;
        esac
    )"
    echo -e "  ${BOLD}Default mode:${NC}   $BOOT_MODE"
    echo -e "  ${BOLD}Last used:${NC}      $last_mode"
    echo -e "  ${BOLD}Auto-login:${NC}     $AUTO_LOGIN"
    echo -e "  ${BOLD}Display mgr:${NC}    $dm"
    echo ""

    if [[ "$current" == "gamemode" ]] || [[ "$last_mode" == "gamemode" ]]; then
        echo -e "  ${BOLD}Gamescope Settings:${NC}"
        echo -e "    Resolution:   $GS_RESOLUTION @ ${GS_REFRESH}Hz"
        echo -e "    VRR:          $GS_VRR"
        echo -e "    HDR:          $GS_HDR"
        echo -e "    Filter:       $GS_FILTER"
        echo -e "    FSR:          $GS_FSR (sharpness: $GS_FSR_SHARPNESS)"
        echo -e "    MangoHud:     $GS_MANGOAPP"
        echo ""
        echo -e "  ${BOLD}Gamescope cmd:${NC}"
        echo -e "    $(build_gamescope_cmd)"
        echo ""
    fi
}

cmd_desktop() {
    load_config
    switch_to_mode "desktop"
}

cmd_gamemode() {
    load_config
    switch_to_mode "gamemode"
}

cmd_toggle() {
    load_config
    local current
    current="$(detect_current_mode)"
    case "$current" in
        desktop)  switch_to_mode "gamemode" ;;
        gamemode) switch_to_mode "desktop" ;;
        *)
            log_warn "Cannot detect current mode. Switching to default ($BOOT_MODE)."
            local target
            [[ "$BOOT_MODE" == "gamemode" ]] && target="desktop" || target="gamemode"
            switch_to_mode "$target"
            ;;
    esac
}

cmd_default() {
    local mode="${1:-}"
    if [[ -z "$mode" ]]; then
        log_error "Usage: $SCRIPT_NAME default <desktop|gamemode>"
        return 1
    fi
    case "$mode" in
        desktop|gamemode)
            load_config
            BOOT_MODE="$mode"
            save_user_config
            save_system_default "$mode"
            log_info "Default boot mode set to ${BOLD}${mode}${NC}."
            if [[ "$AUTO_LOGIN" == "on" ]]; then
                configure_auto_login on
                log_info "Auto-login session updated."
            fi
            ;;
        *)
            log_error "Invalid mode '$mode'. Use 'desktop' or 'gamemode'."
            return 1
            ;;
    esac
}

cmd_config() {
    load_config
    echo -e "${BOLD}${CYAN}=== Game Mode Configuration ===${NC}"
    echo ""
    echo -e "Current settings:"
    echo -e "  ${BOLD}1)${NC} Resolution:     $GS_RESOLUTION"
    echo -e "  ${BOLD}2)${NC} Refresh rate:   ${GS_REFRESH}Hz"
    echo -e "  ${BOLD}3)${NC} VRR:            $GS_VRR"
    echo -e "  ${BOLD}4)${NC} HDR:            $GS_HDR"
    echo -e "  ${BOLD}5)${NC} Scaling filter:  $GS_FILTER"
    echo -e "  ${BOLD}6)${NC} FSR:            $GS_FSR (sharpness: $GS_FSR_SHARPNESS)"
    echo -e "  ${BOLD}7)${NC} MangoHud:       $GS_MANGOAPP"
    echo -e "  ${BOLD}0)${NC} Save & exit"
    echo ""

    while true; do
        echo -en "${YELLOW}Select option [0-7]:${NC} "
        read -r choice
        case "$choice" in
            1)
                echo -en "  Resolution (e.g. 1920x1080, 2560x1440, 3840x2160): "
                read -r val
                if [[ "$val" =~ ^[0-9]+x[0-9]+$ ]]; then
                    GS_RESOLUTION="$val"
                    log_info "Resolution set to $val"
                else
                    log_error "Invalid format. Use WIDTHxHEIGHT."
                fi
                ;;
            2)
                echo -en "  Refresh rate (Hz): "
                read -r val
                if [[ "$val" =~ ^[0-9]+$ ]] && (( val >= 24 && val <= 360 )); then
                    GS_REFRESH="$val"
                    log_info "Refresh rate set to ${val}Hz"
                else
                    log_error "Invalid value. Enter a number between 24 and 360."
                fi
                ;;
            3)
                GS_VRR=$([[ "$GS_VRR" == "on" ]] && echo "off" || echo "on")
                log_info "VRR toggled to $GS_VRR"
                ;;
            4)
                GS_HDR=$([[ "$GS_HDR" == "on" ]] && echo "off" || echo "on")
                log_info "HDR toggled to $GS_HDR"
                ;;
            5)
                echo -en "  Filter (linear, nearest, pixel): "
                read -r val
                case "$val" in
                    linear|nearest|pixel)
                        GS_FILTER="$val"
                        log_info "Filter set to $val"
                        ;;
                    *) log_error "Invalid filter. Use linear, nearest, or pixel." ;;
                esac
                ;;
            6)
                GS_FSR=$([[ "$GS_FSR" == "on" ]] && echo "off" || echo "on")
                if [[ "$GS_FSR" == "on" ]]; then
                    echo -en "  FSR sharpness (0-20, default 5): "
                    read -r val
                    if [[ "$val" =~ ^[0-9]+$ ]] && (( val >= 0 && val <= 20 )); then
                        GS_FSR_SHARPNESS="$val"
                    fi
                fi
                log_info "FSR toggled to $GS_FSR"
                ;;
            7)
                GS_MANGOAPP=$([[ "$GS_MANGOAPP" == "on" ]] && echo "off" || echo "on")
                log_info "MangoHud toggled to $GS_MANGOAPP"
                ;;
            0)
                save_gamescope_config
                log_info "Game Mode settings saved."
                echo ""
                echo -e "  ${BOLD}Gamescope cmd:${NC} $(build_gamescope_cmd)"
                return 0
                ;;
            *)
                log_error "Invalid option."
                ;;
        esac
    done
}

cmd_auto_login() {
    local state="${1:-}"
    if [[ -z "$state" ]]; then
        load_config
        echo -e "Auto-login is currently ${BOLD}${AUTO_LOGIN}${NC}."
        echo -e "Usage: $SCRIPT_NAME auto-login [on|off]"
        return 0
    fi
    case "$state" in
        on|off)
            load_config
            AUTO_LOGIN="$state"
            save_user_config
            configure_auto_login "$state"
            log_info "Auto-login ${BOLD}${state}${NC}."
            ;;
        *)
            log_error "Invalid value '$state'. Use 'on' or 'off'."
            return 1
            ;;
    esac
}

cmd_help() {
    echo -e "${BOLD}${CYAN}forge-boot-select${NC} v${VERSION} — Boot mode selector for 24HG Forge Linux"
    echo ""
    echo -e "${BOLD}USAGE:${NC}"
    echo "  $SCRIPT_NAME <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo "  status              Show current mode and configuration"
    echo "  desktop             Switch to Desktop Mode (KDE Plasma)"
    echo "  gamemode            Switch to Game Mode (Gamescope + Steam)"
    echo "  toggle              Toggle between Desktop and Game Mode"
    echo "  default <mode>      Set default boot mode (desktop|gamemode)"
    echo "  config              Configure Game Mode settings interactively"
    echo "  auto-login [on|off] Toggle auto-login for chosen mode"
    echo "  help                Show this help message"
    echo "  version             Show version"
    echo ""
    echo -e "${BOLD}MODES:${NC}"
    echo "  desktop   Full KDE Plasma desktop environment"
    echo "  gamemode  Gamescope compositor with Steam Big Picture (console-like)"
    echo ""
    echo -e "${BOLD}CONFIG FILES:${NC}"
    echo "  User:     $USER_CONF_DIR/"
    echo "  System:   $SYSTEM_CONF"
    echo ""
    echo -e "${BOLD}CONTROLLER:${NC}"
    echo "  Steam button or Guide button opens the mode switcher overlay"
    echo "  when running in Game Mode via Steam Big Picture."
    echo ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo "  $SCRIPT_NAME gamemode          # Switch to Game Mode now"
    echo "  $SCRIPT_NAME default gamemode  # Boot into Game Mode by default"
    echo "  $SCRIPT_NAME auto-login on     # Enable auto-login"
    echo "  $SCRIPT_NAME config            # Tune Gamescope settings"
}

cmd_version() {
    echo "$SCRIPT_NAME v$VERSION"
}

# --- Main ---

main() {
    local command="${1:-}"
    shift 2>/dev/null || true

    case "$command" in
        status)      cmd_status ;;
        desktop)     cmd_desktop ;;
        gamemode)    cmd_gamemode ;;
        toggle)      cmd_toggle ;;
        default)     cmd_default "$@" ;;
        config)      cmd_config ;;
        auto-login)  cmd_auto_login "$@" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) cmd_version ;;
        "")
            cmd_help
            ;;
        *)
            log_error "Unknown command '$command'."
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
