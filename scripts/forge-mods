#!/bin/bash
set -euo pipefail
# 24HG Forge Mod Manager — Download, install, and manage game mods

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Paths ───────────────────────────────────────────────────────────────────
FORGE_DIR="${HOME}/.config/forge"
MODS_DIR="${FORGE_DIR}/mods"
PROFILES_DIR="${FORGE_DIR}/profiles"
BACKUPS_DIR="${FORGE_DIR}/backups"
CACHE_DIR="${FORGE_DIR}/cache"
TEMP_DIR="${FORGE_DIR}/tmp"

# ── Hub API ─────────────────────────────────────────────────────────────────
HUB_API="https://hub.24hgaming.com/api/mods"

# ── Logging ─────────────────────────────────────────────────────────────────
log_info()  { logger -t forge-mods "INFO: $*";  echo -e "${GREEN}[✓]${RESET} $*"; }
log_warn()  { logger -t forge-mods "WARN: $*";  echo -e "${YELLOW}[!]${RESET} $*"; }
log_error() { logger -t forge-mods "ERROR: $*"; echo -e "${RED}[✗]${RESET} $*" >&2; }
log_step()  { logger -t forge-mods "STEP: $*";  echo -e "${CYAN}[→]${RESET} $*"; }

# ── Game Database ───────────────────────────────────────────────────────────
# Each entry: slug|display_name|relative_mod_path|detection_hints
declare -A GAME_DB
GAME_DB=(
  [minecraft]="minecraft|Minecraft|.minecraft/mods|.minecraft/versions"
  [skyrimse]="skyrimse|Skyrim Special Edition|compatdata/489830/pfx/drive_c/users/steamuser/AppData/Local/Skyrim Special Edition/Data|SkyrimSE.exe"
  [cyberpunk2077]="cyberpunk2077|Cyberpunk 2077|compatdata/1091500/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/Cyberpunk 2077/archive/pc/mod|Cyberpunk2077.exe"
  [stardewvalley]="stardewvalley|Stardew Valley|compatdata/413150/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/Stardew Valley/Mods|StardewModdingAPI"
  [valheim]="valheim|Valheim|compatdata/892970/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/Valheim/BepInEx/plugins|valheim.exe"
  [terraria]="terraria|Terraria|compatdata/105600/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/Terraria/tModLoader/Mods|Terraria.exe"
  [rimworld]="rimworld|RimWorld|compatdata/294100/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/RimWorld/Mods|RimWorldLinux"
  [ksp]="ksp|Kerbal Space Program|compatdata/220200/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/Kerbal Space Program/GameData|KSP.exe"
  [citiesskylines]="citiesskylines|Cities: Skylines|compatdata/255710/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/Cities_Skylines/Files/Mods|Cities.exe"
  [factorio]="factorio|Factorio|.factorio/mods|factorio"
  [fallout4]="fallout4|Fallout 4|compatdata/377160/pfx/drive_c/users/steamuser/AppData/Local/Fallout4/Data|Fallout4.exe"
  [witcher3]="witcher3|The Witcher 3|compatdata/292030/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/The Witcher 3/Mods|witcher3.exe"
  [gtav]="gtav|Grand Theft Auto V|compatdata/271590/pfx/drive_c/Program Files (x86)/Steam/steamapps/common/Grand Theft Auto V/mods/update|GTA5.exe"
  [ets2]="ets2|Euro Truck Simulator 2|compatdata/227300/pfx/drive_c/users/steamuser/Documents/Euro Truck Simulator 2/mod|eurotrucks2.exe"
  [baldursgate3]="baldursgate3|Baldur's Gate 3|compatdata/1086940/pfx/drive_c/users/steamuser/AppData/Local/Larian Studios/Baldur's Gate 3/Mods|bg3.exe"
)

# ── Helpers ──────────────────────────────────────────────────────────────────

ensure_dirs() {
  mkdir -p "${MODS_DIR}" "${PROFILES_DIR}" "${BACKUPS_DIR}" "${CACHE_DIR}" "${TEMP_DIR}"
}

# Resolve the actual mod path for a game on the local system
resolve_mod_path() {
  local game="$1"
  local entry="${GAME_DB[$game]:-}"
  if [[ -z "$entry" ]]; then
    log_error "Unknown game: ${game}"
    echo "Supported games:"
    list_supported_games
    return 1
  fi

  local rel_path
  rel_path="$(echo "$entry" | cut -d'|' -f3)"

  # Handle absolute-ish paths (starting with . means relative to $HOME)
  if [[ "$rel_path" == .* ]]; then
    echo "${HOME}/${rel_path}"
  else
    # Steam compatdata paths — search common Steam library locations
    local steam_dirs=(
      "${HOME}/.local/share/Steam/steamapps"
      "${HOME}/.steam/steam/steamapps"
      "${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps"
    )
    for sdir in "${steam_dirs[@]}"; do
      if [[ -d "${sdir}/${rel_path}" ]]; then
        echo "${sdir}/${rel_path}"
        return 0
      fi
    done
    # Default to first Steam path
    echo "${HOME}/.local/share/Steam/steamapps/${rel_path}"
  fi
}

game_display_name() {
  local game="$1"
  local entry="${GAME_DB[$game]:-}"
  if [[ -n "$entry" ]]; then
    echo "$entry" | cut -d'|' -f2
  else
    echo "$game"
  fi
}

list_supported_games() {
  echo -e "${BOLD}${CYAN}Supported Games:${RESET}"
  printf "  ${DIM}%-20s %-30s${RESET}\n" "SLUG" "NAME"
  echo -e "  ${DIM}$(printf '─%.0s' {1..52})${RESET}"
  for key in $(echo "${!GAME_DB[@]}" | tr ' ' '\n' | sort); do
    local name
    name="$(echo "${GAME_DB[$key]}" | cut -d'|' -f2)"
    printf "  ${GREEN}%-20s${RESET} %-30s\n" "$key" "$name"
  done
}

# Get the mods.json path for a game
mods_json() {
  local game="$1"
  local dir="${MODS_DIR}/${game}"
  mkdir -p "$dir"
  local json="${dir}/mods.json"
  if [[ ! -f "$json" ]]; then
    echo '[]' > "$json"
  fi
  echo "$json"
}

# Read a field from mods.json using jq
mod_count() {
  local json
  json="$(mods_json "$1")"
  jq length "$json"
}

# Pretty-print a table of mods for a game
print_mod_table() {
  local game="$1"
  local json
  json="$(mods_json "$game")"
  local count
  count="$(jq length "$json")"

  local display
  display="$(game_display_name "$game")"

  if [[ "$count" -eq 0 ]]; then
    echo -e "  ${DIM}No mods installed for ${display}${RESET}"
    return
  fi

  echo -e "\n${BOLD}${MAGENTA}  ${display}${RESET} ${DIM}(${count} mods)${RESET}"
  printf "  ${BOLD}%-30s %-12s %-10s %-10s %-10s${RESET}\n" "NAME" "VERSION" "SOURCE" "STATUS" "SIZE"
  echo -e "  ${DIM}$(printf '─%.0s' {1..74})${RESET}"

  jq -r '.[] | "\(.name)|\(.version)|\(.source)|\(.enabled)|\(.files | length)"' "$json" | while IFS='|' read -r name ver src enabled fcount; do
    local status_color status_text size_text
    if [[ "$enabled" == "true" ]]; then
      status_color="${GREEN}"
      status_text="enabled"
    else
      status_color="${RED}"
      status_text="disabled"
    fi
    size_text="${fcount} files"
    printf "  %-30s %-12s %-10s ${status_color}%-10s${RESET} %-10s\n" \
      "${name:0:29}" "${ver:0:11}" "${src:0:9}" "$status_text" "$size_text"
  done
}

# Extract an archive to a target directory
extract_archive() {
  local archive="$1"
  local dest="$2"

  mkdir -p "$dest"

  case "$archive" in
    *.zip)
      if command -v unzip &>/dev/null; then
        unzip -o -q "$archive" -d "$dest"
      else
        log_error "unzip not found. Install it: sudo dnf install unzip"
        return 1
      fi
      ;;
    *.tar.gz|*.tgz)
      tar -xzf "$archive" -C "$dest"
      ;;
    *.tar.bz2|*.tbz2)
      tar -xjf "$archive" -C "$dest"
      ;;
    *.tar.xz|*.txz)
      tar -xJf "$archive" -C "$dest"
      ;;
    *.rar)
      if command -v unrar &>/dev/null; then
        unrar x -o+ -y "$archive" "$dest/"
      else
        log_error "unrar not found. Install it: sudo dnf install unrar"
        return 1
      fi
      ;;
    *.7z)
      if command -v 7z &>/dev/null; then
        7z x -o"$dest" -y "$archive"
      else
        log_error "7z not found. Install it: sudo dnf install p7zip-plugins"
        return 1
      fi
      ;;
    *)
      log_error "Unsupported archive format: $archive"
      return 1
      ;;
  esac
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_list() {
  local filter="${1:-}"
  ensure_dirs

  echo -e "\n${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║       24HG Forge — Installed Mods            ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}"

  if [[ -n "$filter" ]]; then
    if [[ -z "${GAME_DB[$filter]:-}" ]]; then
      log_error "Unknown game: ${filter}"
      list_supported_games
      return 1
    fi
    print_mod_table "$filter"
  else
    local found=false
    for game_dir in "${MODS_DIR}"/*/; do
      [[ -d "$game_dir" ]] || continue
      local game
      game="$(basename "$game_dir")"
      local json="${game_dir}/mods.json"
      [[ -f "$json" ]] || continue
      local count
      count="$(jq length "$json" 2>/dev/null || echo 0)"
      if [[ "$count" -gt 0 ]]; then
        print_mod_table "$game"
        found=true
      fi
    done
    if [[ "$found" == "false" ]]; then
      echo -e "\n  ${DIM}No mods installed. Use ${GREEN}forge-mods search <query>${DIM} to find mods.${RESET}"
    fi
  fi
  echo ""
}

cmd_search() {
  local query="${1:-}"
  if [[ -z "$query" ]]; then
    log_error "Usage: forge-mods search <query>"
    return 1
  fi

  echo -e "\n${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║       24HG Forge — Mod Search                ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}\n"

  # Search Hub Community
  log_step "Searching Hub Community for '${query}'..."
  local hub_results=""
  if hub_results="$(curl -sf --max-time 10 "${HUB_API}/search?q=$(printf '%s' "$query" | jq -sRr @uri)" 2>/dev/null)"; then
    local hub_count
    hub_count="$(echo "$hub_results" | jq '.results | length' 2>/dev/null || echo 0)"
    if [[ "$hub_count" -gt 0 ]]; then
      echo -e "${BOLD}${GREEN}Hub Community Results:${RESET}"
      printf "  ${BOLD}%-8s %-30s %-12s %-15s %-10s${RESET}\n" "ID" "NAME" "VERSION" "GAME" "DOWNLOADS"
      echo -e "  ${DIM}$(printf '─%.0s' {1..77})${RESET}"
      echo "$hub_results" | jq -r '.results[] | "\(.id)|\(.name)|\(.version)|\(.game)|\(.downloads)"' 2>/dev/null | head -20 | while IFS='|' read -r id name ver game dl; do
        printf "  ${CYAN}%-8s${RESET} %-30s %-12s %-15s %-10s\n" "$id" "${name:0:29}" "${ver:0:11}" "${game:0:14}" "$dl"
      done
      echo ""
    else
      echo -e "  ${DIM}No Hub Community results for '${query}'${RESET}\n"
    fi
  else
    echo -e "  ${DIM}Hub Community unavailable — searching offline cache...${RESET}\n"
  fi

  # Nexus Mods hint
  echo -e "${BOLD}${YELLOW}Nexus Mods:${RESET}"
  echo -e "  Browse ${BLUE}https://www.nexusmods.com${RESET} and click 'Mod Manager Download'"
  echo -e "  to use the NXM protocol handler (${DIM}nxm:// links${RESET}).\n"

  echo -e "${DIM}Install a mod:  ${GREEN}forge-mods install <mod_id>${RESET}"
  echo -e "${DIM}Install from URL: ${GREEN}forge-mods install --url <download_url> --game <game>${RESET}"
  echo -e "${DIM}Install local:  ${GREEN}forge-mods install --file <archive> --game <game>${RESET}\n"
}

cmd_install() {
  ensure_dirs
  local mod_id="" url="" file="" game="" name="" version="" source_type="hub"

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url)    url="$2"; source_type="url"; shift 2 ;;
      --file)   file="$2"; source_type="local"; shift 2 ;;
      --game)   game="$2"; shift 2 ;;
      --name)   name="$2"; shift 2 ;;
      --version) version="$2"; shift 2 ;;
      *)        mod_id="$1"; shift ;;
    esac
  done

  local archive_path=""
  local extract_dir="${TEMP_DIR}/extract_$$"
  mkdir -p "$extract_dir"

  # Cleanup on exit
  trap "rm -rf '${extract_dir}'" EXIT

  if [[ "$source_type" == "hub" ]]; then
    # Download from Hub
    if [[ -z "$mod_id" ]]; then
      log_error "Usage: forge-mods install <mod_id> [--game <game>]"
      return 1
    fi

    log_step "Fetching mod info from Hub Community (ID: ${mod_id})..."
    local mod_info
    if ! mod_info="$(curl -sf --max-time 15 "${HUB_API}/${mod_id}" 2>/dev/null)"; then
      log_error "Failed to fetch mod info for ID: ${mod_id}"
      return 1
    fi

    name="$(echo "$mod_info" | jq -r '.name // "Unknown"')"
    version="$(echo "$mod_info" | jq -r '.version // "1.0.0"')"
    game="$(echo "$mod_info" | jq -r '.game // empty')"
    local download_url
    download_url="$(echo "$mod_info" | jq -r '.download_url // empty')"

    if [[ -z "$game" ]]; then
      log_error "Could not determine game for this mod. Use --game <game>"
      return 1
    fi

    if [[ -z "$download_url" ]]; then
      download_url="${HUB_API}/download/${mod_id}"
    fi

    log_step "Downloading ${BOLD}${name}${RESET} v${version}..."
    archive_path="${CACHE_DIR}/${mod_id}_${version}.zip"
    if ! curl -fL --max-time 120 --progress-bar -o "$archive_path" "$download_url" 2>/dev/null; then
      log_error "Download failed"
      return 1
    fi

  elif [[ "$source_type" == "url" ]]; then
    if [[ -z "$url" || -z "$game" ]]; then
      log_error "Usage: forge-mods install --url <url> --game <game> [--name <name>]"
      return 1
    fi
    [[ -z "$name" ]] && name="$(basename "$url" | sed 's/\.[^.]*$//')"
    [[ -z "$version" ]] && version="1.0.0"

    log_step "Downloading from URL..."
    local ext
    ext="$(echo "$url" | grep -oP '\.\w+$' || echo ".zip")"
    archive_path="${CACHE_DIR}/url_${name}${ext}"
    if ! curl -fL --max-time 300 --progress-bar -o "$archive_path" "$url"; then
      log_error "Download failed"
      return 1
    fi
    mod_id="url_$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')"

  elif [[ "$source_type" == "local" ]]; then
    if [[ -z "$file" || -z "$game" ]]; then
      log_error "Usage: forge-mods install --file <archive> --game <game> [--name <name>]"
      return 1
    fi
    if [[ ! -f "$file" ]]; then
      log_error "File not found: ${file}"
      return 1
    fi
    archive_path="$(realpath "$file")"
    [[ -z "$name" ]] && name="$(basename "$file" | sed 's/\.[^.]*$//')"
    [[ -z "$version" ]] && version="1.0.0"
    mod_id="local_$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')"
  fi

  # Validate game
  if [[ -z "${GAME_DB[$game]:-}" ]]; then
    log_error "Unknown game: ${game}"
    list_supported_games
    return 1
  fi

  local mod_path
  mod_path="$(resolve_mod_path "$game")"
  local display
  display="$(game_display_name "$game")"

  # Extract archive
  log_step "Extracting archive..."
  if ! extract_archive "$archive_path" "$extract_dir"; then
    log_error "Extraction failed"
    return 1
  fi

  # Create mod directory if needed
  mkdir -p "$mod_path"

  # Copy files and track them
  log_step "Installing to ${DIM}${mod_path}${RESET}..."
  local installed_files=()
  while IFS= read -r -d '' f; do
    local relpath="${f#${extract_dir}/}"
    local dest="${mod_path}/${relpath}"
    mkdir -p "$(dirname "$dest")"
    cp -f "$f" "$dest"
    installed_files+=("$relpath")
  done < <(find "$extract_dir" -type f -print0)

  if [[ ${#installed_files[@]} -eq 0 ]]; then
    log_warn "No files extracted from archive"
    return 1
  fi

  # Record in mods.json
  local json
  json="$(mods_json "$game")"
  local files_json
  files_json="$(printf '%s\n' "${installed_files[@]}" | jq -R . | jq -s .)"
  local new_entry
  new_entry="$(jq -n \
    --arg id "$mod_id" \
    --arg name "$name" \
    --arg version "$version" \
    --arg source "$source_type" \
    --argjson files "$files_json" \
    '{id: $id, name: $name, version: $version, source: $source, files: $files, enabled: true}')"

  # Remove existing entry with same id, then add new
  local updated
  updated="$(jq --arg id "$mod_id" '[.[] | select(.id != $id)]' "$json")"
  echo "$updated" | jq ". + [$new_entry]" > "$json"

  log_info "Installed ${BOLD}${name}${RESET} v${version} for ${display} (${#installed_files[@]} files)"
  echo -e "  ${DIM}Location: ${mod_path}${RESET}\n"
}

cmd_install_nxm() {
  local nxm_url="${1:-}"
  if [[ -z "$nxm_url" ]]; then
    log_error "Usage: forge-mods install-nxm <nxm://...>"
    return 1
  fi

  # Parse nxm://game/mods/mod_id/files/file_id
  local parsed
  parsed="$(echo "$nxm_url" | sed -n 's|nxm://\([^/]*\)/mods/\([^/]*\)/files/\([^/?]*\).*|\1 \2 \3|p')"
  if [[ -z "$parsed" ]]; then
    log_error "Invalid NXM URL format: ${nxm_url}"
    log_error "Expected: nxm://<game>/mods/<mod_id>/files/<file_id>"
    return 1
  fi

  local nxm_game nxm_mod_id nxm_file_id
  read -r nxm_game nxm_mod_id nxm_file_id <<< "$parsed"

  echo -e "\n${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║       24HG Forge — NXM Download              ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}\n"

  log_step "NXM link detected:"
  echo -e "  ${DIM}Game:${RESET}    ${nxm_game}"
  echo -e "  ${DIM}Mod ID:${RESET}  ${nxm_mod_id}"
  echo -e "  ${DIM}File ID:${RESET} ${nxm_file_id}"
  echo ""

  # Map NXM game slug to our game slug
  local game_slug=""
  case "${nxm_game,,}" in
    skyrimspecialedition) game_slug="skyrimse" ;;
    cyberpunk2077)        game_slug="cyberpunk2077" ;;
    stardewvalley)        game_slug="stardewvalley" ;;
    valheim)              game_slug="valheim" ;;
    fallout4)             game_slug="fallout4" ;;
    witcher3)             game_slug="witcher3" ;;
    baldursgate3)         game_slug="baldursgate3" ;;
    kerbalspaceprogram)   game_slug="ksp" ;;
    rimworld)             game_slug="rimworld" ;;
    citiesskylines)       game_slug="citiesskylines" ;;
    *)                    game_slug="${nxm_game,,}" ;;
  esac

  if [[ -z "${GAME_DB[$game_slug]:-}" ]]; then
    log_warn "Game '${nxm_game}' not in built-in database. Attempting with slug: ${game_slug}"
    echo -e "  ${DIM}You may need to specify the game manually.${RESET}\n"
  fi

  log_warn "Nexus Mods API key required for automated downloads."
  echo -e "  ${DIM}Set ${CYAN}NEXUS_API_KEY${DIM} in ~/.config/forge/nexus.conf${RESET}"
  echo -e "  ${DIM}Or download manually and use: ${GREEN}forge-mods install --file <archive> --game ${game_slug}${RESET}\n"

  # Attempt download if API key is available
  local nexus_conf="${FORGE_DIR}/nexus.conf"
  local api_key=""
  if [[ -f "$nexus_conf" ]]; then
    api_key="$(grep -oP 'NEXUS_API_KEY=\K.*' "$nexus_conf" 2>/dev/null || true)"
  fi
  api_key="${NEXUS_API_KEY:-$api_key}"

  if [[ -n "$api_key" ]]; then
    log_step "Using Nexus API key to fetch download link..."
    local dl_info
    if dl_info="$(curl -sf --max-time 15 \
        -H "apikey: ${api_key}" \
        "https://api.nexusmods.com/v1/games/${nxm_game}/mods/${nxm_mod_id}/files/${nxm_file_id}/download_link.json" 2>/dev/null)"; then
      local dl_url
      dl_url="$(echo "$dl_info" | jq -r '.[0].URI // empty')"
      if [[ -n "$dl_url" ]]; then
        cmd_install --url "$dl_url" --game "$game_slug" --name "nexus_${nxm_mod_id}"
        return $?
      fi
    fi
    log_warn "Could not obtain download link from Nexus API"
  fi
}

cmd_remove() {
  local game="${1:-}"
  local mod="${2:-}"
  if [[ -z "$game" || -z "$mod" ]]; then
    log_error "Usage: forge-mods remove <game> <mod_name_or_id>"
    return 1
  fi

  ensure_dirs

  if [[ -z "${GAME_DB[$game]:-}" ]]; then
    log_error "Unknown game: ${game}"
    return 1
  fi

  local json
  json="$(mods_json "$game")"
  local mod_path
  mod_path="$(resolve_mod_path "$game")"

  # Find mod by id or name (case-insensitive partial match)
  local mod_entry
  mod_entry="$(jq -r --arg q "$mod" '.[] | select(.id == $q or (.name | ascii_downcase | contains($q | ascii_downcase)))' "$json" | head -1)"
  if [[ -z "$mod_entry" ]]; then
    log_error "Mod '${mod}' not found for ${game}"
    return 1
  fi

  local mod_id mod_name
  mod_id="$(echo "$mod_entry" | jq -r '.id')"
  mod_name="$(echo "$mod_entry" | jq -r '.name')"
  local enabled
  enabled="$(echo "$mod_entry" | jq -r '.enabled')"

  echo -e "${YELLOW}Remove ${BOLD}${mod_name}${RESET}${YELLOW} from $(game_display_name "$game")?${RESET}"
  read -rp "Confirm [y/N]: " confirm
  if [[ "${confirm,,}" != "y" ]]; then
    log_info "Cancelled"
    return 0
  fi

  # Delete installed files
  local source_dir="$mod_path"
  if [[ "$enabled" != "true" ]]; then
    source_dir="${MODS_DIR}/${game}/disabled/${mod_id}"
  fi

  echo "$mod_entry" | jq -r '.files[]' 2>/dev/null | while read -r f; do
    local target="${source_dir}/${f}"
    if [[ -f "$target" ]]; then
      rm -f "$target"
    fi
  done

  # Remove empty directories
  if [[ -d "$source_dir" ]]; then
    find "$source_dir" -type d -empty -delete 2>/dev/null || true
  fi

  # Update mods.json
  jq --arg id "$mod_id" '[.[] | select(.id != $id)]' "$json" > "${json}.tmp"
  mv "${json}.tmp" "$json"

  log_info "Removed ${BOLD}${mod_name}${RESET} from $(game_display_name "$game")"
}

cmd_update() {
  local game="${1:-}"
  ensure_dirs

  echo -e "\n${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║       24HG Forge — Update Check              ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}\n"

  local games=()
  if [[ -n "$game" ]]; then
    if [[ -z "${GAME_DB[$game]:-}" ]]; then
      log_error "Unknown game: ${game}"
      return 1
    fi
    games=("$game")
  else
    for game_dir in "${MODS_DIR}"/*/; do
      [[ -d "$game_dir" ]] || continue
      games+=("$(basename "$game_dir")")
    done
  fi

  if [[ ${#games[@]} -eq 0 ]]; then
    echo -e "  ${DIM}No mods installed to update.${RESET}\n"
    return 0
  fi

  local updates_found=0
  for g in "${games[@]}"; do
    local json
    json="$(mods_json "$g")"
    local display
    display="$(game_display_name "$g")"
    local count
    count="$(jq length "$json")"
    [[ "$count" -eq 0 ]] && continue

    log_step "Checking ${display}..."

    jq -r '.[] | select(.source == "hub") | "\(.id)|\(.name)|\(.version)"' "$json" | while IFS='|' read -r mid mname mver; do
      local remote_info
      if remote_info="$(curl -sf --max-time 10 "${HUB_API}/${mid}" 2>/dev/null)"; then
        local remote_ver
        remote_ver="$(echo "$remote_info" | jq -r '.version // ""')"
        if [[ -n "$remote_ver" && "$remote_ver" != "$mver" ]]; then
          echo -e "  ${GREEN}↑${RESET} ${BOLD}${mname}${RESET}: ${RED}${mver}${RESET} → ${GREEN}${remote_ver}${RESET}"
          ((updates_found++)) || true
        else
          echo -e "  ${DIM}✓ ${mname} (${mver}) — up to date${RESET}"
        fi
      else
        echo -e "  ${DIM}? ${mname} — could not check (source: hub)${RESET}"
      fi
    done

    jq -r '.[] | select(.source != "hub") | "\(.name)|\(.version)|\(.source)"' "$json" | while IFS='|' read -r mname mver msrc; do
      echo -e "  ${DIM}— ${mname} (${mver}) — manual check needed (source: ${msrc})${RESET}"
    done
  done

  if [[ "$updates_found" -eq 0 ]]; then
    echo -e "\n  ${GREEN}All mods are up to date.${RESET}\n"
  else
    echo -e "\n  ${YELLOW}Run ${GREEN}forge-mods install <mod_id>${YELLOW} to update a mod.${RESET}\n"
  fi
}

cmd_enable() {
  local game="${1:-}"
  local mod="${2:-}"
  if [[ -z "$game" || -z "$mod" ]]; then
    log_error "Usage: forge-mods enable <game> <mod>"
    return 1
  fi

  ensure_dirs

  if [[ -z "${GAME_DB[$game]:-}" ]]; then
    log_error "Unknown game: ${game}"
    return 1
  fi

  local json
  json="$(mods_json "$game")"
  local mod_path
  mod_path="$(resolve_mod_path "$game")"

  # Find mod
  local mod_entry
  mod_entry="$(jq --arg q "$mod" '.[] | select(.id == $q or (.name | ascii_downcase | contains($q | ascii_downcase)))' "$json" | jq -s '.[0] // empty')"
  if [[ -z "$mod_entry" ]]; then
    log_error "Mod '${mod}' not found for ${game}"
    return 1
  fi

  local mod_id mod_name enabled
  mod_id="$(echo "$mod_entry" | jq -r '.id')"
  mod_name="$(echo "$mod_entry" | jq -r '.name')"
  enabled="$(echo "$mod_entry" | jq -r '.enabled')"

  if [[ "$enabled" == "true" ]]; then
    log_info "${mod_name} is already enabled"
    return 0
  fi

  local disabled_dir="${MODS_DIR}/${game}/disabled/${mod_id}"
  if [[ ! -d "$disabled_dir" ]]; then
    log_error "Disabled mod files not found at ${disabled_dir}"
    return 1
  fi

  # Move files back to game mod directory
  log_step "Enabling ${BOLD}${mod_name}${RESET}..."
  mkdir -p "$mod_path"

  echo "$mod_entry" | jq -r '.files[]' 2>/dev/null | while read -r f; do
    local src="${disabled_dir}/${f}"
    local dest="${mod_path}/${f}"
    if [[ -f "$src" ]]; then
      mkdir -p "$(dirname "$dest")"
      mv -f "$src" "$dest"
    fi
  done

  # Cleanup disabled dir
  rm -rf "$disabled_dir"

  # Update mods.json
  jq --arg id "$mod_id" '[.[] | if .id == $id then .enabled = true else . end]' "$json" > "${json}.tmp"
  mv "${json}.tmp" "$json"

  log_info "Enabled ${BOLD}${mod_name}${RESET}"
}

cmd_disable() {
  local game="${1:-}"
  local mod="${2:-}"
  if [[ -z "$game" || -z "$mod" ]]; then
    log_error "Usage: forge-mods disable <game> <mod>"
    return 1
  fi

  ensure_dirs

  if [[ -z "${GAME_DB[$game]:-}" ]]; then
    log_error "Unknown game: ${game}"
    return 1
  fi

  local json
  json="$(mods_json "$game")"
  local mod_path
  mod_path="$(resolve_mod_path "$game")"

  # Find mod
  local mod_entry
  mod_entry="$(jq --arg q "$mod" '.[] | select(.id == $q or (.name | ascii_downcase | contains($q | ascii_downcase)))' "$json" | jq -s '.[0] // empty')"
  if [[ -z "$mod_entry" ]]; then
    log_error "Mod '${mod}' not found for ${game}"
    return 1
  fi

  local mod_id mod_name enabled
  mod_id="$(echo "$mod_entry" | jq -r '.id')"
  mod_name="$(echo "$mod_entry" | jq -r '.name')"
  enabled="$(echo "$mod_entry" | jq -r '.enabled')"

  if [[ "$enabled" != "true" ]]; then
    log_info "${mod_name} is already disabled"
    return 0
  fi

  local disabled_dir="${MODS_DIR}/${game}/disabled/${mod_id}"
  mkdir -p "$disabled_dir"

  # Move files from game mod directory to disabled storage
  log_step "Disabling ${BOLD}${mod_name}${RESET}..."

  echo "$mod_entry" | jq -r '.files[]' 2>/dev/null | while read -r f; do
    local src="${mod_path}/${f}"
    local dest="${disabled_dir}/${f}"
    if [[ -f "$src" ]]; then
      mkdir -p "$(dirname "$dest")"
      mv -f "$src" "$dest"
    fi
  done

  # Update mods.json
  jq --arg id "$mod_id" '[.[] | if .id == $id then .enabled = false else . end]' "$json" > "${json}.tmp"
  mv "${json}.tmp" "$json"

  log_info "Disabled ${BOLD}${mod_name}${RESET} — files moved to ${DIM}${disabled_dir}${RESET}"
}

cmd_backup() {
  local game="${1:-}"
  if [[ -z "$game" ]]; then
    log_error "Usage: forge-mods backup <game>"
    return 1
  fi

  ensure_dirs

  if [[ -z "${GAME_DB[$game]:-}" ]]; then
    log_error "Unknown game: ${game}"
    return 1
  fi

  local mod_path
  mod_path="$(resolve_mod_path "$game")"
  local display
  display="$(game_display_name "$game")"
  local timestamp
  timestamp="$(date +%Y%m%d_%H%M%S)"
  local backup_file="${BACKUPS_DIR}/${game}_${timestamp}.tar.gz"

  log_step "Backing up ${display} mods..."

  local json
  json="$(mods_json "$game")"

  # Create a temp dir with mod dir contents + metadata
  local backup_tmp="${TEMP_DIR}/backup_$$"
  mkdir -p "${backup_tmp}/metadata"

  # Copy mods.json
  cp "$json" "${backup_tmp}/metadata/mods.json"

  # Copy mod files if the directory exists
  if [[ -d "$mod_path" ]]; then
    mkdir -p "${backup_tmp}/mods"
    cp -a "$mod_path/." "${backup_tmp}/mods/" 2>/dev/null || true
  fi

  # Copy disabled mods
  local disabled_base="${MODS_DIR}/${game}/disabled"
  if [[ -d "$disabled_base" ]]; then
    mkdir -p "${backup_tmp}/disabled"
    cp -a "$disabled_base/." "${backup_tmp}/disabled/" 2>/dev/null || true
  fi

  # Create tar.gz
  tar -czf "$backup_file" -C "$backup_tmp" .
  rm -rf "$backup_tmp"

  local size
  size="$(du -sh "$backup_file" | cut -f1)"
  log_info "Backup created: ${DIM}${backup_file}${RESET} (${size})"
}

cmd_restore() {
  local game="${1:-}"
  if [[ -z "$game" ]]; then
    log_error "Usage: forge-mods restore <game>"
    return 1
  fi

  ensure_dirs

  if [[ -z "${GAME_DB[$game]:-}" ]]; then
    log_error "Unknown game: ${game}"
    return 1
  fi

  local display
  display="$(game_display_name "$game")"

  # List available backups
  local backups=()
  while IFS= read -r f; do
    backups+=("$f")
  done < <(find "${BACKUPS_DIR}" -name "${game}_*.tar.gz" -type f 2>/dev/null | sort -r)

  if [[ ${#backups[@]} -eq 0 ]]; then
    log_error "No backups found for ${display}"
    return 1
  fi

  echo -e "\n${BOLD}Available backups for ${display}:${RESET}"
  local i=0
  for b in "${backups[@]}"; do
    local bname
    bname="$(basename "$b")"
    local bsize
    bsize="$(du -sh "$b" | cut -f1)"
    local bdate
    bdate="$(echo "$bname" | sed "s/${game}_//" | sed 's/.tar.gz//' | sed 's/_/ /')"
    printf "  ${CYAN}[%d]${RESET} %s ${DIM}(%s)${RESET}\n" "$i" "$bdate" "$bsize"
    ((i++))
  done

  echo ""
  read -rp "Select backup number [0]: " selection
  selection="${selection:-0}"

  if [[ "$selection" -ge "${#backups[@]}" ]]; then
    log_error "Invalid selection"
    return 1
  fi

  local chosen="${backups[$selection]}"
  local mod_path
  mod_path="$(resolve_mod_path "$game")"

  echo -e "${YELLOW}This will replace current mods for ${display}. Continue?${RESET}"
  read -rp "Confirm [y/N]: " confirm
  if [[ "${confirm,,}" != "y" ]]; then
    log_info "Cancelled"
    return 0
  fi

  local restore_tmp="${TEMP_DIR}/restore_$$"
  mkdir -p "$restore_tmp"

  log_step "Extracting backup..."
  tar -xzf "$chosen" -C "$restore_tmp"

  # Restore metadata
  if [[ -f "${restore_tmp}/metadata/mods.json" ]]; then
    local json
    json="$(mods_json "$game")"
    cp -f "${restore_tmp}/metadata/mods.json" "$json"
  fi

  # Restore mod files
  if [[ -d "${restore_tmp}/mods" ]]; then
    mkdir -p "$mod_path"
    cp -af "${restore_tmp}/mods/." "$mod_path/"
  fi

  # Restore disabled mods
  if [[ -d "${restore_tmp}/disabled" ]]; then
    local disabled_base="${MODS_DIR}/${game}/disabled"
    mkdir -p "$disabled_base"
    cp -af "${restore_tmp}/disabled/." "$disabled_base/"
  fi

  rm -rf "$restore_tmp"
  log_info "Restored ${display} mods from backup"
}

cmd_profiles() {
  local game="${1:-}"
  if [[ -z "$game" ]]; then
    log_error "Usage: forge-mods profiles <game>"
    return 1
  fi

  ensure_dirs

  if [[ -z "${GAME_DB[$game]:-}" ]]; then
    log_error "Unknown game: ${game}"
    return 1
  fi

  local display
  display="$(game_display_name "$game")"
  local profile_dir="${PROFILES_DIR}/${game}"
  mkdir -p "$profile_dir"

  echo -e "\n${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║       24HG Forge — Mod Profiles              ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}\n"

  echo -e "${BOLD}${display} — Profiles:${RESET}\n"

  # List existing profiles
  local profiles=()
  while IFS= read -r p; do
    [[ -n "$p" ]] && profiles+=("$p")
  done < <(find "$profile_dir" -name "*.json" -type f 2>/dev/null | sort)

  if [[ ${#profiles[@]} -eq 0 ]]; then
    echo -e "  ${DIM}No profiles saved.${RESET}"
  else
    for p in "${profiles[@]}"; do
      local pname
      pname="$(basename "$p" .json)"
      local pcount
      pcount="$(jq length "$p" 2>/dev/null || echo 0)"
      printf "  ${GREEN}%-20s${RESET} ${DIM}(%d mods)${RESET}\n" "$pname" "$pcount"
    done
  fi

  echo -e "\n${BOLD}Actions:${RESET}"
  echo -e "  ${CYAN}[s]${RESET} Save current mod setup as profile"
  echo -e "  ${CYAN}[l]${RESET} Load a profile"
  echo -e "  ${CYAN}[d]${RESET} Delete a profile"
  echo -e "  ${CYAN}[q]${RESET} Quit"
  echo ""
  read -rp "Choice: " choice

  case "${choice,,}" in
    s)
      read -rp "Profile name: " pname
      if [[ -z "$pname" ]]; then
        log_error "Profile name required"
        return 1
      fi
      pname="$(echo "$pname" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')"
      local json
      json="$(mods_json "$game")"
      cp "$json" "${profile_dir}/${pname}.json"
      log_info "Saved profile '${pname}' for ${display}"
      ;;
    l)
      if [[ ${#profiles[@]} -eq 0 ]]; then
        log_error "No profiles to load"
        return 1
      fi
      echo ""
      local i=0
      for p in "${profiles[@]}"; do
        printf "  ${CYAN}[%d]${RESET} %s\n" "$i" "$(basename "$p" .json)"
        ((i++))
      done
      echo ""
      read -rp "Select profile: " sel
      if [[ "$sel" -ge "${#profiles[@]}" ]]; then
        log_error "Invalid selection"
        return 1
      fi
      local json
      json="$(mods_json "$game")"
      cp "${profiles[$sel]}" "$json"
      local pname
      pname="$(basename "${profiles[$sel]}" .json)"
      log_info "Loaded profile '${pname}' for ${display}"
      log_warn "You may need to re-download mod files. Run: forge-mods update ${game}"
      ;;
    d)
      if [[ ${#profiles[@]} -eq 0 ]]; then
        log_error "No profiles to delete"
        return 1
      fi
      echo ""
      local i=0
      for p in "${profiles[@]}"; do
        printf "  ${CYAN}[%d]${RESET} %s\n" "$i" "$(basename "$p" .json)"
        ((i++))
      done
      echo ""
      read -rp "Select profile to delete: " sel
      if [[ "$sel" -ge "${#profiles[@]}" ]]; then
        log_error "Invalid selection"
        return 1
      fi
      rm -f "${profiles[$sel]}"
      log_info "Deleted profile '$(basename "${profiles[$sel]}" .json)'"
      ;;
    q|*)
      return 0
      ;;
  esac
}

cmd_scan() {
  ensure_dirs

  echo -e "\n${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║       24HG Forge — Game Mod Scanner          ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}\n"

  log_step "Scanning for installed games and existing mods...\n"

  local found=0
  for game in $(echo "${!GAME_DB[@]}" | tr ' ' '\n' | sort); do
    local mod_path
    mod_path="$(resolve_mod_path "$game")"
    local display
    display="$(game_display_name "$game")"

    if [[ -d "$mod_path" ]]; then
      local file_count
      file_count="$(find "$mod_path" -type f 2>/dev/null | wc -l)"
      if [[ "$file_count" -gt 0 ]]; then
        echo -e "  ${GREEN}[Found]${RESET} ${BOLD}${display}${RESET}"
        echo -e "         ${DIM}Path: ${mod_path}${RESET}"
        echo -e "         ${DIM}Files: ${file_count}${RESET}"

        # Check if we already track mods for this game
        local json
        json="$(mods_json "$game")"
        local tracked
        tracked="$(jq length "$json")"
        if [[ "$tracked" -gt 0 ]]; then
          echo -e "         ${CYAN}Tracked: ${tracked} mods in registry${RESET}"
        else
          echo -e "         ${YELLOW}Untracked — use 'install --file' to register${RESET}"
        fi
        echo ""
        ((found++))
      fi
    fi
  done

  if [[ "$found" -eq 0 ]]; then
    echo -e "  ${DIM}No games with mods found in standard locations.${RESET}"
    echo -e "  ${DIM}Games are detected via Steam compatdata and standard paths.${RESET}\n"
  else
    echo -e "  ${GREEN}Found ${found} game(s) with mod content.${RESET}\n"
  fi
}

# ── NXM Protocol Registration ──────────────────────────────────────────────

cmd_register_nxm() {
  local desktop_src="/usr/share/applications/forge-nxm-handler.desktop"
  local desktop_local="${HOME}/.local/share/applications/forge-nxm-handler.desktop"

  # Copy desktop file to user applications if not there
  if [[ -f "$desktop_src" ]]; then
    mkdir -p "${HOME}/.local/share/applications"
    cp "$desktop_src" "$desktop_local"
  elif [[ ! -f "$desktop_local" ]]; then
    log_warn "forge-nxm-handler.desktop not found. Creating..."
    mkdir -p "${HOME}/.local/share/applications"
    cat > "$desktop_local" << 'DESKTOP'
[Desktop Entry]
Name=24HG Mod Handler
Comment=Handle Nexus Mod download links
Exec=forge-mods install-nxm %u
Icon=forge-logo
Terminal=true
Type=Application
MimeType=x-scheme-handler/nxm;
NoDisplay=true
DESKTOP
  fi

  if command -v xdg-mime &>/dev/null; then
    xdg-mime default forge-nxm-handler.desktop x-scheme-handler/nxm
    log_info "Registered forge-mods as NXM protocol handler"
  else
    log_warn "xdg-mime not available — NXM handler not registered"
  fi
}

# ── Usage ────────────────────────────────────────────────────────────────────

usage() {
  echo -e "\n${BOLD}${CYAN}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${CYAN}║    24HG Forge Mod Manager                    ║${RESET}"
  echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${RESET}\n"

  echo -e "${BOLD}Usage:${RESET} forge-mods <command> [options]\n"

  echo -e "${BOLD}Commands:${RESET}"
  printf "  ${GREEN}%-35s${RESET} %s\n" "list [game]"                     "List installed mods, optionally filtered by game"
  printf "  ${GREEN}%-35s${RESET} %s\n" "search <query>"                  "Search for mods on Hub Community or Nexus"
  printf "  ${GREEN}%-35s${RESET} %s\n" "install <mod_id>"                "Download and install a mod from Hub"
  printf "  ${GREEN}%-35s${RESET} %s\n" "install --url <url> --game <g>"  "Install a mod from a direct URL"
  printf "  ${GREEN}%-35s${RESET} %s\n" "install --file <path> --game <g>" "Install a mod from a local archive"
  printf "  ${GREEN}%-35s${RESET} %s\n" "install-nxm <nxm://...>"        "Handle an NXM protocol link"
  printf "  ${GREEN}%-35s${RESET} %s\n" "remove <game> <mod>"             "Uninstall a mod"
  printf "  ${GREEN}%-35s${RESET} %s\n" "update [game]"                   "Check for and apply mod updates"
  printf "  ${GREEN}%-35s${RESET} %s\n" "enable <game> <mod>"             "Enable a disabled mod"
  printf "  ${GREEN}%-35s${RESET} %s\n" "disable <game> <mod>"            "Disable a mod without removing"
  printf "  ${GREEN}%-35s${RESET} %s\n" "backup <game>"                   "Backup current mod setup"
  printf "  ${GREEN}%-35s${RESET} %s\n" "restore <game>"                  "Restore mod setup from backup"
  printf "  ${GREEN}%-35s${RESET} %s\n" "profiles <game>"                 "List/switch mod profiles"
  printf "  ${GREEN}%-35s${RESET} %s\n" "scan"                            "Scan installed games for existing mods"
  printf "  ${GREEN}%-35s${RESET} %s\n" "register-nxm"                    "Register as NXM protocol handler"
  printf "  ${GREEN}%-35s${RESET} %s\n" "games"                           "List all supported games"

  echo -e "\n${BOLD}Supported archives:${RESET} .zip, .tar.gz, .rar, .7z\n"
  echo -e "${BOLD}Config:${RESET} ${DIM}~/.config/forge/mods/<game>/mods.json${RESET}"
  echo -e "${BOLD}Backups:${RESET} ${DIM}~/.config/forge/backups/${RESET}"
  echo -e "${BOLD}Profiles:${RESET} ${DIM}~/.config/forge/profiles/<game>/${RESET}\n"
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    list)         cmd_list "$@" ;;
    search)       cmd_search "$@" ;;
    install)      cmd_install "$@" ;;
    install-nxm)  cmd_install_nxm "$@" ;;
    remove)       cmd_remove "$@" ;;
    update)       cmd_update "$@" ;;
    enable)       cmd_enable "$@" ;;
    disable)      cmd_disable "$@" ;;
    backup)       cmd_backup "$@" ;;
    restore)      cmd_restore "$@" ;;
    profiles)     cmd_profiles "$@" ;;
    scan)         cmd_scan "$@" ;;
    register-nxm) cmd_register_nxm ;;
    games)        list_supported_games ;;
    help|--help|-h) usage ;;
    *)
      log_error "Unknown command: ${cmd}"
      usage
      return 1
      ;;
  esac
}

main "$@"
