#!/usr/bin/env bash
# HubOS Discord Wayland Screen Share Fix
# ═══════════════════════════════════════════════════════════════════════
# Fixes the well-known Discord screen sharing issue on Wayland by
# configuring xwaylandvideobridge, PipeWire audio routing, OBS virtual
# camera fallback, and XDG portal preferences.
#
# Designed for HubOS (custom Linux gaming distro based on Bazzite/Fedora
# Atomic, KDE Plasma on Wayland).
#
# Usage: hubos-discord-screen [setup|start|stop|status|fix|test] [--gui]
#
# Copyright (c) 2026 24 Hour Gaming — MIT License
# ═══════════════════════════════════════════════════════════════════════

set -euo pipefail

# ─── Constants & Paths ───────────────────────────────────────────────

readonly VERSION="1.0.0"
readonly SCRIPT_NAME="hubos-discord-screen"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hubos"
readonly STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/hubos-discord-screen"
readonly XDG_RUNTIME="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
readonly DISCORD_FLATPAK="com.discordapp.Discord"
readonly XWVB_FLATPAK="org.kde.xwaylandvideobridge"
readonly PW_SINK_NAME="discord-share"
readonly PW_SINK_DESC="Discord Share Audio"
readonly AUTOSTART_DIR="$HOME/.config/autostart"
readonly ENV_DIR="$HOME/.config/environment.d"
readonly PORTAL_USER_DIR="$HOME/.config/xdg-desktop-portal"
readonly LOG_FILE="${STATE_DIR}/session.log"
readonly PID_FILE="${STATE_DIR}/pw-sink.pid"
readonly LOOPBACK_FILE="${STATE_DIR}/pw-loopback.pid"

# ─── Global flags ────────────────────────────────────────────────────

GUI_MODE=false
VERBOSE=false

# ─── Color Output ────────────────────────────────────────────────────

if [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]]; then
    readonly C_RED=$'\033[1;31m'
    readonly C_GREEN=$'\033[1;32m'
    readonly C_YELLOW=$'\033[1;33m'
    readonly C_BLUE=$'\033[1;34m'
    readonly C_CYAN=$'\033[1;36m'
    readonly C_BOLD=$'\033[1m'
    readonly C_DIM=$'\033[2m'
    readonly C_RESET=$'\033[0m'
else
    readonly C_RED="" C_GREEN="" C_YELLOW="" C_BLUE="" C_CYAN="" C_BOLD="" C_DIM="" C_RESET=""
fi

# ─── Logging Helpers ─────────────────────────────────────────────────

ok()   { echo "  ${C_GREEN}[OK]${C_RESET}  $*"; }
fail() { echo "  ${C_RED}[!!]${C_RESET}  $*"; }
warn() { echo "  ${C_YELLOW}[--]${C_RESET}  $*"; }
info() { echo "  ${C_BLUE}[ii]${C_RESET}  $*"; }
step() { echo "${C_CYAN}===${C_RESET} ${C_BOLD}$*${C_RESET} ${C_CYAN}===${C_RESET}"; }
debug() { [[ "$VERBOSE" == true ]] && echo "  ${C_DIM}[DBG] $*${C_RESET}" || true; }

log_to_file() {
    mkdir -p "$STATE_DIR"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

# ─── Desktop Notifications ───────────────────────────────────────────

notify() {
    local title="$1" body="${2:-}" icon="${3:-dialog-information}"
    if command -v notify-send &>/dev/null; then
        notify-send -a "HubOS Discord Screen" -i "$icon" "$title" "$body" 2>/dev/null || true
    fi
    log_to_file "NOTIFY: $title — $body"
}

# ─── GUI Dialogs (zenity) ───────────────────────────────────────────

gui_info() {
    if [[ "$GUI_MODE" == true ]] && command -v zenity &>/dev/null; then
        zenity --info --title="HubOS Discord Screen" --text="$1" --width=400 2>/dev/null || true
    fi
}

gui_error() {
    if [[ "$GUI_MODE" == true ]] && command -v zenity &>/dev/null; then
        zenity --error --title="HubOS Discord Screen" --text="$1" --width=400 2>/dev/null || true
    fi
}

gui_question() {
    if [[ "$GUI_MODE" == true ]] && command -v zenity &>/dev/null; then
        zenity --question --title="HubOS Discord Screen" --text="$1" --width=400 2>/dev/null
        return $?
    fi
    return 0
}

gui_progress() {
    if [[ "$GUI_MODE" == true ]] && command -v zenity &>/dev/null; then
        zenity --progress --title="HubOS Discord Screen" --text="$1" \
            --pulsate --auto-close --width=400 2>/dev/null || true
    fi
}

# ─── Detection Helpers ───────────────────────────────────────────────

detect_session() {
    if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        echo "wayland"
    elif [[ "${XDG_SESSION_TYPE:-}" == "x11" ]] || [[ -n "${DISPLAY:-}" ]]; then
        echo "x11"
    else
        echo "unknown"
    fi
}

is_flatpak_discord() {
    flatpak list --app 2>/dev/null | grep -qi "discord" && return 0
    return 1
}

is_native_discord() {
    command -v discord &>/dev/null && return 0
    command -v Discord &>/dev/null && return 0
    [[ -d "$HOME/.config/discord" ]] && return 0
    [[ -d "/opt/discord" ]] && return 0
    [[ -d "/usr/share/discord" ]] && return 0
    return 1
}

discord_type() {
    if is_flatpak_discord; then
        echo "flatpak"
    elif is_native_discord; then
        echo "native"
    else
        echo "none"
    fi
}

is_discord_running() {
    pgrep -fi "discord" &>/dev/null && return 0
    flatpak ps 2>/dev/null | grep -qi "discord" && return 0
    return 1
}

is_xwvb_installed() {
    command -v xwaylandvideobridge &>/dev/null && return 0
    flatpak info "$XWVB_FLATPAK" &>/dev/null 2>&1 && return 0
    return 1
}

is_xwvb_running() {
    pgrep -x xwaylandvideobridge &>/dev/null
}

is_pw_sink_active() {
    pw-cli ls Node 2>/dev/null | grep -q "$PW_SINK_NAME" 2>/dev/null
}

get_discord_config_dir() {
    local dtype
    dtype=$(discord_type)
    if [[ "$dtype" == "flatpak" ]]; then
        echo "$HOME/.var/app/$DISCORD_FLATPAK/config/discord"
    elif [[ "$dtype" == "native" ]]; then
        echo "$HOME/.config/discord"
    else
        echo ""
    fi
}

require_wayland() {
    local session
    session=$(detect_session)
    if [[ "$session" == "x11" ]]; then
        info "X11 detected — screen sharing works natively in Discord."
        info "This tool is primarily for Wayland sessions."
        return 1
    fi
    return 0
}

# ─── Package Installation (Fedora Atomic / Bazzite) ─────────────────

install_package() {
    local pkg="$1"
    local desc="${2:-$pkg}"

    info "Installing $desc..."

    # Fedora Atomic / Bazzite: rpm-ostree is the primary method
    if command -v rpm-ostree &>/dev/null; then
        if rpm -q "$pkg" &>/dev/null 2>&1; then
            ok "$desc already installed (rpm)"
            return 0
        fi
        info "Using rpm-ostree to layer $pkg (requires reboot for full effect)..."
        sudo rpm-ostree install --idempotent "$pkg" 2>/dev/null && {
            ok "Installed $desc via rpm-ostree (may need reboot)"
            return 0
        } || {
            warn "rpm-ostree install failed, trying flatpak..."
        }
    fi

    # Try flatpak as fallback for GUI apps
    if command -v flatpak &>/dev/null; then
        local flatpak_id="${3:-}"
        if [[ -n "$flatpak_id" ]]; then
            flatpak install -y flathub "$flatpak_id" 2>/dev/null && {
                ok "Installed $desc via flatpak"
                return 0
            }
        fi
    fi

    # Traditional package managers
    if command -v dnf &>/dev/null; then
        sudo dnf install -y "$pkg" 2>/dev/null && { ok "Installed via dnf"; return 0; }
    fi

    fail "Could not install $desc. Install it manually."
    return 1
}

# ═══════════════════════════════════════════════════════════════════════
#  SETUP — One-time configuration
# ═══════════════════════════════════════════════════════════════════════

cmd_setup() {
    local session dtype
    session=$(detect_session)
    dtype=$(discord_type)

    echo ""
    echo "${C_BOLD}HubOS Discord Wayland Screen Share — Setup${C_RESET}"
    echo "${C_DIM}Session: $session | Discord: $dtype | v$VERSION${C_RESET}"
    echo ""

    if [[ "$session" == "x11" ]]; then
        info "X11 detected — screen sharing works natively."
        info "Run this on a Wayland session for full setup."
        gui_info "X11 detected. Screen sharing works natively on X11."
        return 0
    fi

    mkdir -p "$CONFIG_DIR" "$STATE_DIR" "$AUTOSTART_DIR" "$ENV_DIR" "$PORTAL_USER_DIR"

    setup_xwaylandvideobridge
    setup_pipewire_virtual_sink
    setup_obs_virtual_camera
    setup_autostart
    setup_discord_env
    setup_portal_preferences
    setup_kwin_rule
    setup_discord_permissions

    echo ""
    echo "${C_GREEN}${C_BOLD}Setup complete!${C_RESET}"
    echo ""
    echo "  Next steps:"
    echo "  1. Log out and back in for environment changes to take effect"
    echo "  2. Run '${C_CYAN}$SCRIPT_NAME start${C_RESET}' to begin a screen sharing session"
    echo "  3. Run '${C_CYAN}$SCRIPT_NAME test${C_RESET}' to verify everything works"
    echo ""

    notify "Setup Complete" "Discord screen sharing configured. Restart your session." "dialog-positive"
    gui_info "Setup complete!\n\nLog out and back in, then run:\n  hubos-discord-screen start"
    log_to_file "SETUP: completed successfully"
}

setup_xwaylandvideobridge() {
    step "xwaylandvideobridge"

    if command -v xwaylandvideobridge &>/dev/null; then
        ok "xwaylandvideobridge installed (native)"
        return 0
    fi

    if flatpak info "$XWVB_FLATPAK" &>/dev/null 2>&1; then
        ok "xwaylandvideobridge installed (flatpak)"
        return 0
    fi

    # Try flatpak first (doesn't require reboot on atomic systems)
    if command -v flatpak &>/dev/null; then
        info "Installing xwaylandvideobridge via flatpak..."
        flatpak install -y flathub "$XWVB_FLATPAK" 2>/dev/null && {
            ok "Installed xwaylandvideobridge via flatpak"
            return 0
        } || warn "Flatpak install failed"
    fi

    # rpm-ostree for Bazzite / Fedora Atomic
    if command -v rpm-ostree &>/dev/null; then
        info "Installing xwaylandvideobridge via rpm-ostree..."
        sudo rpm-ostree install --idempotent xwaylandvideobridge 2>/dev/null && {
            ok "Installed via rpm-ostree (reboot may be required)"
            return 0
        } || warn "rpm-ostree install failed"
    fi

    # Fallback dnf
    if command -v dnf &>/dev/null; then
        sudo dnf install -y xwaylandvideobridge 2>/dev/null && {
            ok "Installed via dnf"
            return 0
        }
    fi

    fail "Could not install xwaylandvideobridge"
    fail "Install manually: flatpak install flathub $XWVB_FLATPAK"
    echo ""
}

setup_pipewire_virtual_sink() {
    step "PipeWire Virtual Audio Sink"

    if ! command -v pw-cli &>/dev/null; then
        fail "pw-cli not found — PipeWire may not be installed"
        warn "On Bazzite/Fedora Atomic, PipeWire should be pre-installed"
        return 1
    fi

    ok "PipeWire available (pw-cli found)"

    # Create a WirePlumber config for the persistent virtual sink
    local wp_conf_dir="$HOME/.config/wireplumber/wireplumber.conf.d"
    local wp_sink_conf="$wp_conf_dir/50-discord-share-sink.conf"
    mkdir -p "$wp_conf_dir"

    if [[ ! -f "$wp_sink_conf" ]]; then
        cat > "$wp_sink_conf" << 'WPEOF'
# HubOS Discord Share — Persistent virtual audio sink
# This creates a null sink that game audio can be routed through
# so Discord can capture game audio via its monitor source.
monitor.alsa.rules = [
]

wireplumber.components = [
]

# The actual sink is created dynamically by hubos-discord-screen start
# This file ensures WirePlumber doesn't interfere with it
wireplumber.settings = {
  ["discord-share-configured"] = true
}
WPEOF
        ok "WirePlumber configuration created"
        debug "Config at: $wp_sink_conf"
    else
        ok "WirePlumber configuration exists"
    fi

    info "Virtual sink will be created when you run '$SCRIPT_NAME start'"
    echo ""
}

setup_obs_virtual_camera() {
    step "OBS Virtual Camera (Fallback)"

    # Check for OBS installation
    local obs_found=false
    if command -v obs &>/dev/null; then
        ok "OBS Studio installed (native)"
        obs_found=true
    elif flatpak list --app 2>/dev/null | grep -qi "obs"; then
        ok "OBS Studio installed (flatpak)"
        obs_found=true
    fi

    if [[ "$obs_found" == false ]]; then
        info "OBS Studio not installed (optional fallback method)"
        info "Install with: flatpak install flathub com.obsproject.Studio"
        echo ""
        return 0
    fi

    # Check v4l2loopback for virtual camera
    if lsmod 2>/dev/null | grep -q v4l2loopback; then
        ok "v4l2loopback kernel module loaded"
    elif modinfo v4l2loopback &>/dev/null 2>&1; then
        ok "v4l2loopback available (not loaded — load with 'start')"
    else
        info "v4l2loopback not available"
        info "OBS virtual camera needs v4l2loopback kernel module"
        if command -v rpm-ostree &>/dev/null; then
            info "Install: rpm-ostree install v4l2loopback (then reboot)"
        fi
    fi

    echo ""
    echo "  ${C_DIM}OBS Virtual Camera can be used as a fallback screen share method:${C_RESET}"
    echo "  ${C_DIM}1. Capture your screen/game in OBS${C_RESET}"
    echo "  ${C_DIM}2. Start Virtual Camera in OBS${C_RESET}"
    echo "  ${C_DIM}3. Share the virtual camera in Discord video call${C_RESET}"
    echo ""
}

setup_autostart() {
    step "Autostart Entry"

    local autostart_file="$AUTOSTART_DIR/xwaylandvideobridge.desktop"

    # Determine the launch command
    local xwvb_cmd="xwaylandvideobridge"
    if ! command -v xwaylandvideobridge &>/dev/null; then
        if flatpak info "$XWVB_FLATPAK" &>/dev/null 2>&1; then
            xwvb_cmd="flatpak run $XWVB_FLATPAK"
        else
            warn "xwaylandvideobridge not installed — skipping autostart"
            return 0
        fi
    fi

    cat > "$autostart_file" << EOF
[Desktop Entry]
Type=Application
Name=XWayland Video Bridge
Comment=Bridges Wayland screen capture to XWayland apps like Discord (HubOS)
Exec=$xwvb_cmd
X-KDE-autostart-after=plasma-workspace
X-KDE-StartupNotify=false
X-HubOS-Component=discord-screen
NoDisplay=true
EOF

    ok "Autostart entry created: $autostart_file"
    debug "Command: $xwvb_cmd"
    echo ""
}

setup_discord_env() {
    step "Discord Environment Configuration"

    local dtype
    dtype=$(discord_type)

    # Flatpak Discord environment override
    if [[ "$dtype" == "flatpak" ]]; then
        # Set environment via flatpak override
        flatpak override --user "$DISCORD_FLATPAK" \
            --env=DISCORD_DISABLE_GPU_SANDBOX=1 \
            2>/dev/null || true
        ok "Flatpak Discord: DISCORD_DISABLE_GPU_SANDBOX=1"

        # Also set Electron flags for better Wayland support
        local discord_flags_dir="$HOME/.var/app/$DISCORD_FLATPAK/config"
        mkdir -p "$discord_flags_dir"
        local flags_file="$discord_flags_dir/discord-flags.conf"
        if [[ ! -f "$flags_file" ]]; then
            cat > "$flags_file" << 'EOF'
--enable-features=UseOzonePlatform,WebRTCPipeWireCapturer,WaylandWindowDecorations
--ozone-platform=wayland
--enable-webrtc-pipewire-capturer
EOF
            ok "Discord Electron flags configured for Wayland"
        else
            ok "Discord flags file exists"
        fi
    elif [[ "$dtype" == "native" ]]; then
        # For native Discord, set env in the session
        local env_file="$ENV_DIR/hubos-discord-screen.conf"
        cat > "$env_file" << 'EOF'
# HubOS Discord Screen Sharing — Environment overrides
DISCORD_DISABLE_GPU_SANDBOX=1
XDG_CURRENT_DESKTOP=KDE
EOF
        ok "Session environment configured: $env_file"
    else
        warn "Discord not detected — environment not configured"
        warn "Install Discord first, then re-run setup"
    fi
    echo ""
}

setup_portal_preferences() {
    step "XDG Portal Preferences"

    # Configure portal to prefer wlr-screencopy / KDE portal for screen sharing
    local portal_conf="$PORTAL_USER_DIR/portals.conf"

    cat > "$portal_conf" << 'EOF'
[preferred]
default=kde
org.freedesktop.impl.portal.ScreenCast=kde
org.freedesktop.impl.portal.RemoteDesktop=kde
org.freedesktop.impl.portal.Screenshot=kde
org.freedesktop.impl.portal.Inhibit=kde
org.freedesktop.impl.portal.FileChooser=kde
EOF

    ok "Portal preferences set (prefer KDE portal for ScreenCast)"
    debug "Config at: $portal_conf"

    # Ensure the KDE portal is running
    if systemctl --user is-active xdg-desktop-portal-kde.service &>/dev/null; then
        ok "xdg-desktop-portal-kde is active"
    else
        info "Restarting portal services..."
        systemctl --user restart xdg-desktop-portal.service 2>/dev/null || true
        systemctl --user restart xdg-desktop-portal-kde.service 2>/dev/null || true
        ok "Portal services restarted"
    fi

    # Check for wlr-screencopy support (preferred capture method)
    if command -v pw-cli &>/dev/null; then
        local screencopy_nodes
        screencopy_nodes=$(pw-cli ls Node 2>/dev/null | grep -ci "screencopy\|screen.cast" || echo "0")
        if [[ "$screencopy_nodes" -gt 0 ]]; then
            ok "wlr-screencopy PipeWire nodes detected ($screencopy_nodes)"
        else
            info "wlr-screencopy nodes not active (normal at this stage)"
        fi
    fi
    echo ""
}

setup_kwin_rule() {
    step "KWin Window Rule (Hide xwaylandvideobridge)"

    local kwin_rules="$HOME/.config/kwinrulesrc"

    # Check if rule already exists
    if [[ -f "$kwin_rules" ]] && grep -q "xwaylandvideobridge" "$kwin_rules" 2>/dev/null; then
        ok "KWin rule already configured"
        echo ""
        return 0
    fi

    # Find the next rule number
    local rule_count=0
    if [[ -f "$kwin_rules" ]]; then
        rule_count=$(grep -c '^\[' "$kwin_rules" 2>/dev/null || echo "0")
    fi
    local rule_num=$((rule_count + 1))

    # Append rule to hide xwaylandvideobridge window from taskbar/pager
    cat >> "$kwin_rules" << EOF

[${rule_num}]
Description=Hide xwaylandvideobridge window (HubOS)
minimizeRule=3
minimized=true
skippagerRule=3
skippager=true
skiptaskbarRule=3
skiptaskbar=true
title=xwaylandvideobridge
titlematch=0
wmclass=xwaylandvideobridge
wmclassmatch=1
EOF

    # Update count in General section
    if grep -q '^\[General\]' "$kwin_rules" 2>/dev/null; then
        sed -i "s/^count=.*/count=$rule_num/" "$kwin_rules" 2>/dev/null || true
    else
        echo -e "[General]\ncount=$rule_num" >> "$kwin_rules"
    fi

    # Reload KWin rules
    dbus-send --type=signal --dest=org.kde.KWin /KWin org.kde.KWin.reloadConfig 2>/dev/null || true
    ok "KWin rule added (window hidden from taskbar and pager)"
    echo ""
}

setup_discord_permissions() {
    step "Discord Permissions"

    local dtype
    dtype=$(discord_type)

    if [[ "$dtype" == "flatpak" ]]; then
        # Grant all necessary permissions for screen sharing on Wayland
        flatpak override --user "$DISCORD_FLATPAK" \
            --device=all \
            --socket=wayland \
            --socket=x11 \
            --socket=pulseaudio \
            --filesystem=xdg-run/pipewire-0:ro \
            --talk-name=org.freedesktop.portal.Desktop \
            --talk-name=org.freedesktop.portal.ScreenCast \
            --talk-name=org.freedesktop.portal.RemoteDesktop \
            --talk-name=org.kde.StatusNotifierWatcher \
            --talk-name=org.freedesktop.Notifications \
            2>/dev/null || true

        ok "Flatpak Discord permissions configured:"
        info "  Wayland + X11 sockets"
        info "  PipeWire access (pipewire-0)"
        info "  Portal D-Bus access (ScreenCast, RemoteDesktop)"
        info "  PulseAudio socket"
    elif [[ "$dtype" == "native" ]]; then
        ok "Native Discord — no extra sandbox permissions needed"
    else
        warn "Discord not installed — install it and re-run setup"
    fi
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════
#  START — Begin a screen sharing session
# ═══════════════════════════════════════════════════════════════════════

cmd_start() {
    local session
    session=$(detect_session)

    echo ""
    echo "${C_BOLD}HubOS Discord Screen Share — Start Session${C_RESET}"
    echo "${C_DIM}Session: $session | Discord: $(discord_type)${C_RESET}"
    echo ""

    if [[ "$session" == "x11" ]]; then
        info "X11 session — screen sharing works natively."
        info "No special setup needed. Just share your screen in Discord."
        return 0
    fi

    mkdir -p "$STATE_DIR"

    # Step 1: Launch xwaylandvideobridge
    step "Starting xwaylandvideobridge"

    if is_xwvb_running; then
        ok "Already running (PID $(pgrep -x xwaylandvideobridge))"
    elif is_xwvb_installed; then
        if command -v xwaylandvideobridge &>/dev/null; then
            xwaylandvideobridge &>/dev/null &
            disown
        else
            flatpak run "$XWVB_FLATPAK" &>/dev/null &
            disown
        fi
        sleep 1
        if is_xwvb_running; then
            ok "Started xwaylandvideobridge (PID $(pgrep -x xwaylandvideobridge))"
        else
            fail "Failed to start xwaylandvideobridge"
            warn "Run '$SCRIPT_NAME setup' first"
        fi
    else
        fail "xwaylandvideobridge not installed"
        warn "Run '$SCRIPT_NAME setup' to install it"
        return 1
    fi
    echo ""

    # Step 2: Create PipeWire audio loopback
    step "Creating PipeWire Audio Routing"

    if ! command -v pw-cli &>/dev/null; then
        fail "pw-cli not found — cannot create audio routing"
    else
        # Remove old sink if it exists
        if is_pw_sink_active; then
            info "Removing existing virtual sink..."
            pw-cli destroy "$PW_SINK_NAME" 2>/dev/null || true
            sleep 0.5
        fi

        # Create the virtual null sink for game audio capture
        info "Creating virtual audio sink: $PW_SINK_DESC"
        local sink_id
        sink_id=$(pw-cli create-node adapter \
            "{ factory.name=support.null audio.position=[FL FR] media.class=Audio/Sink node.name=$PW_SINK_NAME node.description=\"$PW_SINK_DESC\" object.linger=true }" \
            2>/dev/null | grep -oP 'id:\s*\K\d+' || echo "")

        if [[ -n "$sink_id" ]]; then
            echo "$sink_id" > "$PID_FILE"
            ok "Virtual sink created (node ID: $sink_id)"
        else
            # Try alternate method via pactl
            info "Trying pactl method..."
            pactl load-module module-null-sink \
                media.class=Audio/Sink \
                sink_name="$PW_SINK_NAME" \
                channel_map=stereo \
                "sink_properties=device.description='$PW_SINK_DESC'" \
                2>/dev/null && {
                ok "Virtual sink created via pactl"
            } || {
                fail "Could not create virtual audio sink"
                warn "Audio sharing may not work"
            }
        fi

        # Create loopback: game audio -> virtual sink -> Discord can read the monitor
        echo ""
        info "Audio routing diagram:"
        echo ""
        echo "    ${C_DIM}Game Audio --> [$PW_SINK_DESC] --> Monitor Source --> Discord Input${C_RESET}"
        echo "    ${C_DIM}Your Mic   -->                                   --> Discord Input${C_RESET}"
        echo "    ${C_DIM}Desktop    --> Speakers/Headphones (unchanged)${C_RESET}"
        echo ""

        # Create a loopback from default output to the virtual sink
        if command -v pw-loopback &>/dev/null; then
            pw-loopback \
                --capture-props="media.class=Audio/Sink node.name=${PW_SINK_NAME}-loopback node.description=Discord-Loopback" \
                --playback-props="media.class=Audio/Sink node.target=$PW_SINK_NAME" \
                &>/dev/null &
            local lb_pid=$!
            echo "$lb_pid" > "$LOOPBACK_FILE"
            disown
            ok "PipeWire loopback created (PID: $lb_pid)"
        else
            info "pw-loopback not found — manual audio routing required"
            info "Use pavucontrol or Helvum to route game audio to '$PW_SINK_DESC'"
        fi
    fi
    echo ""

    # Step 3: Instructions
    step "Screen Sharing Instructions"
    echo ""
    echo "  ${C_BOLD}To share your screen in Discord:${C_RESET}"
    echo ""
    echo "  1. Open Discord and join a voice channel"
    echo "  2. Click the ${C_BOLD}Screen${C_RESET} button (monitor icon) at the bottom"
    echo "  3. In the screen picker, look for a window called:"
    echo ""
    echo "     ${C_GREEN}${C_BOLD}\"xwaylandvideobridge\"${C_RESET}"
    echo ""
    echo "  4. Select it — this captures your entire Wayland desktop"
    echo "  5. For audio: in Discord Voice Settings, set Input Device to:"
    echo ""
    echo "     ${C_GREEN}${C_BOLD}\"Monitor of $PW_SINK_DESC\"${C_RESET}"
    echo ""
    echo "  ${C_DIM}Tip: If you don't see xwaylandvideobridge, try the 'Screens' tab${C_RESET}"
    echo "  ${C_DIM}     instead of 'Applications'. It may appear as a blank window.${C_RESET}"
    echo ""

    notify "Screen Share Ready" "Select 'xwaylandvideobridge' in Discord screen picker" "video-display"
    gui_info "Screen sharing session started!\n\nIn Discord, select 'xwaylandvideobridge' from the screen picker.\n\nFor audio, set Discord input to 'Monitor of $PW_SINK_DESC'."
    log_to_file "START: session started"
}

# ═══════════════════════════════════════════════════════════════════════
#  STOP — Clean up screen sharing session
# ═══════════════════════════════════════════════════════════════════════

cmd_stop() {
    echo ""
    echo "${C_BOLD}HubOS Discord Screen Share — Stop Session${C_RESET}"
    echo ""

    local cleaned=false

    # Remove PipeWire loopback
    step "PipeWire Loopback"
    if [[ -f "$LOOPBACK_FILE" ]]; then
        local lb_pid
        lb_pid=$(cat "$LOOPBACK_FILE" 2>/dev/null || echo "")
        if [[ -n "$lb_pid" ]] && kill -0 "$lb_pid" 2>/dev/null; then
            kill "$lb_pid" 2>/dev/null || true
            ok "Killed loopback process (PID: $lb_pid)"
            cleaned=true
        else
            info "Loopback process not running"
        fi
        rm -f "$LOOPBACK_FILE"
    else
        info "No loopback PID file found"
    fi

    # Also kill any lingering pw-loopback with our sink name
    pkill -f "pw-loopback.*${PW_SINK_NAME}" 2>/dev/null && {
        ok "Killed lingering pw-loopback processes"
        cleaned=true
    } || true
    echo ""

    # Remove PipeWire virtual sink
    step "PipeWire Virtual Sink"
    if is_pw_sink_active; then
        pw-cli destroy "$PW_SINK_NAME" 2>/dev/null && {
            ok "Removed virtual sink: $PW_SINK_NAME"
            cleaned=true
        } || {
            # Try pactl method
            local module_id
            module_id=$(pactl list modules short 2>/dev/null | grep "$PW_SINK_NAME" | awk '{print $1}')
            if [[ -n "$module_id" ]]; then
                pactl unload-module "$module_id" 2>/dev/null && {
                    ok "Removed virtual sink via pactl (module $module_id)"
                    cleaned=true
                } || fail "Could not remove virtual sink"
            fi
        }
    else
        info "Virtual sink not active"
    fi
    rm -f "$PID_FILE"

    # Also clean up any stale pactl null-sink modules matching our name
    pactl list modules short 2>/dev/null | grep "$PW_SINK_NAME" | while read -r mod_id _rest; do
        pactl unload-module "$mod_id" 2>/dev/null && {
            ok "Removed pactl module #$mod_id"
            cleaned=true
        } || true
    done
    echo ""

    # Optionally stop xwaylandvideobridge
    step "xwaylandvideobridge"
    if is_xwvb_running; then
        local xwvb_pid
        xwvb_pid=$(pgrep -x xwaylandvideobridge)
        echo ""
        if [[ "$GUI_MODE" == true ]]; then
            if gui_question "Stop xwaylandvideobridge? (PID: $xwvb_pid)\n\nNote: It will restart on next login if autostart is enabled."; then
                kill "$xwvb_pid" 2>/dev/null || true
                ok "Stopped xwaylandvideobridge"
                cleaned=true
            else
                info "xwaylandvideobridge left running"
            fi
        else
            info "xwaylandvideobridge is still running (PID: $xwvb_pid)"
            info "It's usually fine to leave it running."
            info "To stop it: kill $xwvb_pid"
        fi
    else
        info "xwaylandvideobridge not running"
    fi
    echo ""

    if [[ "$cleaned" == true ]]; then
        ok "Session cleaned up"
        notify "Session Stopped" "Screen sharing resources cleaned up" "dialog-information"
    else
        info "Nothing to clean up"
    fi
    log_to_file "STOP: session stopped"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════
#  STATUS — Show current state of all components
# ═══════════════════════════════════════════════════════════════════════

cmd_status() {
    local session dtype
    session=$(detect_session)
    dtype=$(discord_type)

    echo ""
    echo "${C_BOLD}HubOS Discord Screen Share — Status${C_RESET}"
    echo "${C_DIM}Session: $session | Discord: $dtype | v$VERSION${C_RESET}"
    echo ""

    # Session type
    step "Display Session"
    if [[ "$session" == "wayland" ]]; then
        ok "Wayland session (WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset})"
    elif [[ "$session" == "x11" ]]; then
        info "X11 session — screen sharing works natively"
    else
        warn "Could not detect session type"
    fi
    echo ""

    # xwaylandvideobridge
    step "xwaylandvideobridge"
    if is_xwvb_running; then
        ok "Running (PID $(pgrep -x xwaylandvideobridge))"
    else
        if is_xwvb_installed; then
            warn "Installed but not running"
        else
            fail "Not installed"
        fi
    fi

    # Autostart
    if [[ -f "$AUTOSTART_DIR/xwaylandvideobridge.desktop" ]]; then
        ok "Autostart entry present"
    else
        warn "No autostart entry"
    fi
    echo ""

    # PipeWire virtual sink
    step "PipeWire Audio"
    if pgrep -x pipewire &>/dev/null; then
        ok "PipeWire daemon running"
    else
        fail "PipeWire daemon NOT running"
    fi

    if is_pw_sink_active; then
        ok "Virtual sink '$PW_SINK_NAME' active"
    else
        info "Virtual sink not active (created by '$SCRIPT_NAME start')"
    fi

    if [[ -f "$LOOPBACK_FILE" ]]; then
        local lb_pid
        lb_pid=$(cat "$LOOPBACK_FILE" 2>/dev/null || echo "")
        if [[ -n "$lb_pid" ]] && kill -0 "$lb_pid" 2>/dev/null; then
            ok "Audio loopback active (PID: $lb_pid)"
        else
            warn "Loopback PID file exists but process not running"
        fi
    else
        info "No audio loopback active"
    fi
    echo ""

    # Discord process
    step "Discord"
    if is_discord_running; then
        ok "Discord is running"
    else
        info "Discord not running"
    fi

    if [[ "$dtype" == "flatpak" ]]; then
        local override_file="$HOME/.local/share/flatpak/overrides/$DISCORD_FLATPAK"
        if [[ -f "$override_file" ]]; then
            grep -q "pipewire" "$override_file" 2>/dev/null && \
                ok "Flatpak: PipeWire access configured" || \
                warn "Flatpak: PipeWire access NOT configured"
            grep -q "wayland" "$override_file" 2>/dev/null && \
                ok "Flatpak: Wayland socket configured" || \
                warn "Flatpak: Wayland socket NOT configured"
        else
            warn "No Flatpak permission overrides found"
        fi

        # Check GPU sandbox env
        if flatpak info --show-metadata "$DISCORD_FLATPAK" 2>/dev/null | grep -q "DISCORD_DISABLE_GPU_SANDBOX"; then
            ok "DISCORD_DISABLE_GPU_SANDBOX set"
        else
            # Check user override
            local user_override="$HOME/.local/share/flatpak/overrides/$DISCORD_FLATPAK"
            if [[ -f "$user_override" ]] && grep -q "DISCORD_DISABLE_GPU_SANDBOX" "$user_override" 2>/dev/null; then
                ok "DISCORD_DISABLE_GPU_SANDBOX set (user override)"
            else
                warn "DISCORD_DISABLE_GPU_SANDBOX not detected"
            fi
        fi
    elif [[ "$dtype" == "native" ]]; then
        ok "Native Discord installation"
    fi
    echo ""

    # Portal configuration
    step "XDG Portal"
    if pgrep -f "xdg-desktop-portal$" &>/dev/null || pgrep -x "xdg-desktop-portal" &>/dev/null; then
        ok "xdg-desktop-portal running"
    else
        fail "xdg-desktop-portal NOT running"
    fi

    local portal_running=false
    for portal in xdg-desktop-portal-kde xdg-desktop-portal-gnome xdg-desktop-portal-wlr; do
        if pgrep -f "$portal" &>/dev/null; then
            ok "$portal running"
            portal_running=true
        fi
    done
    [[ "$portal_running" == false ]] && fail "No portal backend running"

    local portal_conf="$PORTAL_USER_DIR/portals.conf"
    if [[ -f "$portal_conf" ]]; then
        if grep -q "ScreenCast=kde" "$portal_conf" 2>/dev/null; then
            ok "Portal preference: ScreenCast=kde"
        else
            warn "ScreenCast portal preference not set to KDE"
        fi
    else
        warn "No portal preference file found"
    fi
    echo ""

    # KWin rule
    step "KWin Configuration"
    local kwin_rules="$HOME/.config/kwinrulesrc"
    if [[ -f "$kwin_rules" ]] && grep -q "xwaylandvideobridge" "$kwin_rules" 2>/dev/null; then
        ok "KWin window hiding rule configured"
    else
        warn "KWin rule for xwaylandvideobridge not found"
    fi
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════
#  FIX — Auto-fix common issues
# ═══════════════════════════════════════════════════════════════════════

cmd_fix() {
    local session dtype
    session=$(detect_session)
    dtype=$(discord_type)

    echo ""
    echo "${C_BOLD}HubOS Discord Screen Share — Auto Fix${C_RESET}"
    echo "${C_DIM}Session: $session | Discord: $dtype${C_RESET}"
    echo ""

    if [[ "$session" == "x11" ]]; then
        info "X11 session — screen sharing should work natively."
        info "If you see issues, make sure Discord is up to date."
        return 0
    fi

    local fixes_applied=0

    # Fix 1: Discord not detecting screens — restart xdg-desktop-portal-kde
    step "Fix: Portal Services (screen detection)"

    info "Restarting portal services..."
    systemctl --user restart xdg-desktop-portal.service 2>/dev/null && {
        ok "Restarted xdg-desktop-portal"
        fixes_applied=$((fixes_applied + 1))
    } || warn "Could not restart xdg-desktop-portal"

    systemctl --user restart xdg-desktop-portal-kde.service 2>/dev/null && {
        ok "Restarted xdg-desktop-portal-kde"
        fixes_applied=$((fixes_applied + 1))
    } || {
        systemctl --user restart xdg-desktop-portal-gnome.service 2>/dev/null && {
            ok "Restarted xdg-desktop-portal-gnome"
            fixes_applied=$((fixes_applied + 1))
        } || {
            systemctl --user restart xdg-desktop-portal-wlr.service 2>/dev/null && {
                ok "Restarted xdg-desktop-portal-wlr"
                fixes_applied=$((fixes_applied + 1))
            } || warn "No portal backend to restart"
        }
    }

    # Wait for portals to come back up
    sleep 2

    # Verify portal is running
    if pgrep -f "xdg-desktop-portal-kde" &>/dev/null; then
        ok "Portal backend verified running"
    elif pgrep -f "xdg-desktop-portal-gnome" &>/dev/null; then
        ok "Portal backend verified running"
    else
        fail "Portal backend did not restart properly"
        warn "Try logging out and back in"
    fi
    echo ""

    # Fix 2: Audio not routing — recreate PipeWire nodes
    step "Fix: Audio Routing (PipeWire)"

    # Kill any stale loopbacks
    if [[ -f "$LOOPBACK_FILE" ]]; then
        local lb_pid
        lb_pid=$(cat "$LOOPBACK_FILE" 2>/dev/null || echo "")
        if [[ -n "$lb_pid" ]]; then
            kill "$lb_pid" 2>/dev/null || true
            rm -f "$LOOPBACK_FILE"
            info "Cleaned up stale loopback"
        fi
    fi
    pkill -f "pw-loopback.*${PW_SINK_NAME}" 2>/dev/null || true

    # Remove and recreate virtual sink
    if is_pw_sink_active; then
        pw-cli destroy "$PW_SINK_NAME" 2>/dev/null || true
        sleep 0.5
        info "Removed old virtual sink"
    fi

    # Also check for stale pactl modules
    pactl list modules short 2>/dev/null | grep "$PW_SINK_NAME" | while read -r mod_id _rest; do
        pactl unload-module "$mod_id" 2>/dev/null || true
    done

    # Recreate if a session is active
    if is_xwvb_running; then
        info "Session appears active — recreating audio nodes..."
        pw-cli create-node adapter \
            "{ factory.name=support.null audio.position=[FL FR] media.class=Audio/Sink node.name=$PW_SINK_NAME node.description=\"$PW_SINK_DESC\" object.linger=true }" \
            2>/dev/null && {
            ok "Recreated virtual sink"
            fixes_applied=$((fixes_applied + 1))
        } || warn "Could not recreate virtual sink"
    else
        info "No active session — audio nodes will be created on '$SCRIPT_NAME start'"
    fi
    echo ""

    # Fix 3: Black screen — check compositing
    step "Fix: Black Screen (Compositing Check)"

    # Check if KWin compositing is enabled
    if command -v qdbus &>/dev/null || command -v qdbus6 &>/dev/null; then
        local qdbus_cmd="qdbus"
        command -v qdbus6 &>/dev/null && qdbus_cmd="qdbus6"

        local compositing_active
        compositing_active=$($qdbus_cmd org.kde.KWin /Compositor active 2>/dev/null || echo "unknown")

        if [[ "$compositing_active" == "true" ]]; then
            ok "KWin compositing is active (required for screen capture)"
        elif [[ "$compositing_active" == "false" ]]; then
            fail "KWin compositing is DISABLED — screen capture will show black!"
            info "Attempting to re-enable compositing..."
            $qdbus_cmd org.kde.KWin /Compositor resume 2>/dev/null && {
                ok "Compositing re-enabled"
                fixes_applied=$((fixes_applied + 1))
            } || {
                fail "Could not re-enable compositing"
                warn "Go to System Settings > Display & Monitor > Compositor and enable it"
            }
        else
            info "Could not determine compositing state"
        fi
    else
        info "qdbus not available — cannot check compositing state"
        info "Ensure compositing is enabled in System Settings > Compositor"
    fi
    echo ""

    # Fix 4: Permission issues — check and fix xdg-portal settings
    step "Fix: Portal Permissions"

    local portal_conf="$PORTAL_USER_DIR/portals.conf"
    if [[ ! -f "$portal_conf" ]] || ! grep -q "ScreenCast=kde" "$portal_conf" 2>/dev/null; then
        mkdir -p "$PORTAL_USER_DIR"
        cat > "$portal_conf" << 'EOF'
[preferred]
default=kde
org.freedesktop.impl.portal.ScreenCast=kde
org.freedesktop.impl.portal.RemoteDesktop=kde
org.freedesktop.impl.portal.Screenshot=kde
org.freedesktop.impl.portal.Inhibit=kde
org.freedesktop.impl.portal.FileChooser=kde
EOF
        ok "Portal preferences repaired"
        fixes_applied=$((fixes_applied + 1))
    else
        ok "Portal preferences look correct"
    fi

    # Check Flatpak permissions
    if [[ "$dtype" == "flatpak" ]]; then
        local override_file="$HOME/.local/share/flatpak/overrides/$DISCORD_FLATPAK"
        local needs_fix=false

        if [[ ! -f "$override_file" ]]; then
            needs_fix=true
        else
            grep -q "pipewire" "$override_file" 2>/dev/null || needs_fix=true
            grep -q "wayland" "$override_file" 2>/dev/null || needs_fix=true
        fi

        if [[ "$needs_fix" == true ]]; then
            info "Reapplying Flatpak Discord permissions..."
            setup_discord_permissions
            fixes_applied=$((fixes_applied + 1))
        else
            ok "Flatpak Discord permissions look correct"
        fi
    fi
    echo ""

    # Fix 5: Restart xwaylandvideobridge
    step "Fix: xwaylandvideobridge"

    if is_xwvb_installed; then
        info "Restarting xwaylandvideobridge..."
        pkill -x xwaylandvideobridge 2>/dev/null || true
        sleep 1

        if command -v xwaylandvideobridge &>/dev/null; then
            xwaylandvideobridge &>/dev/null &
            disown
        else
            flatpak run "$XWVB_FLATPAK" &>/dev/null &
            disown
        fi

        sleep 1
        if is_xwvb_running; then
            ok "xwaylandvideobridge restarted (PID $(pgrep -x xwaylandvideobridge))"
            fixes_applied=$((fixes_applied + 1))
        else
            fail "xwaylandvideobridge failed to start"
        fi
    else
        fail "xwaylandvideobridge not installed — run '$SCRIPT_NAME setup'"
    fi
    echo ""

    # Fix 6: Clear Discord cache
    step "Fix: Discord Cache"

    local discord_dir
    discord_dir=$(get_discord_config_dir)

    if [[ -n "$discord_dir" ]] && [[ -d "$discord_dir" ]]; then
        local cache_cleared=false
        for subdir in Cache "Code Cache" GPUCache; do
            local target="$discord_dir/$subdir"
            if [[ -d "$target" ]]; then
                rm -rf "$target"
                cache_cleared=true
            fi
        done
        if [[ "$cache_cleared" == true ]]; then
            ok "Discord cache cleared (restart Discord to apply)"
            fixes_applied=$((fixes_applied + 1))
        else
            info "No Discord cache directories found"
        fi
    else
        info "Discord config directory not found"
    fi
    echo ""

    # Summary
    echo "${C_BOLD}Fix Summary${C_RESET}"
    echo ""
    if [[ $fixes_applied -gt 0 ]]; then
        ok "$fixes_applied fix(es) applied"
        echo ""
        echo "  ${C_BOLD}Recommended next steps:${C_RESET}"
        echo "  1. Restart Discord"
        echo "  2. Run '${C_CYAN}$SCRIPT_NAME start${C_RESET}'"
        echo "  3. Try screen sharing again"
        notify "Fixes Applied" "$fixes_applied fix(es) applied. Restart Discord." "dialog-positive"
    else
        info "No fixes were needed — everything looks correct"
        echo ""
        echo "  If screen sharing still doesn't work:"
        echo "  - Make sure Discord is up to date"
        echo "  - Try logging out and back in"
        echo "  - Run '${C_CYAN}$SCRIPT_NAME test${C_RESET}' for diagnostics"
    fi
    gui_info "Fix complete!\n\n$fixes_applied fix(es) applied.\n\nRestart Discord and try again."
    log_to_file "FIX: applied $fixes_applied fixes"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════
#  TEST — Quick verification tests
# ═══════════════════════════════════════════════════════════════════════

cmd_test() {
    local session
    session=$(detect_session)

    echo ""
    echo "${C_BOLD}HubOS Discord Screen Share — Test${C_RESET}"
    echo "${C_DIM}Session: $session${C_RESET}"
    echo ""

    local passed=0
    local failed=0
    local skipped=0

    # Test 1: PipeWire
    step "Test 1: PipeWire"
    if pgrep -x pipewire &>/dev/null; then
        ok "PipeWire daemon running"
        passed=$((passed + 1))
    else
        fail "PipeWire daemon NOT running"
        failed=$((failed + 1))
    fi

    if command -v pw-cli &>/dev/null; then
        local pw_version
        pw_version=$(pw-cli --version 2>/dev/null | head -1 || echo "unknown")
        ok "pw-cli available ($pw_version)"
        passed=$((passed + 1))
    else
        fail "pw-cli not found"
        failed=$((failed + 1))
    fi
    echo ""

    # Test 2: Portal
    step "Test 2: Desktop Portal"
    if pgrep -f "xdg-desktop-portal" &>/dev/null; then
        ok "xdg-desktop-portal running"
        passed=$((passed + 1))
    else
        fail "xdg-desktop-portal NOT running"
        failed=$((failed + 1))
    fi

    local portal_backend=""
    for p in kde gnome wlr; do
        if pgrep -f "xdg-desktop-portal-$p" &>/dev/null; then
            portal_backend="$p"
            ok "Portal backend: $p"
            passed=$((passed + 1))
            break
        fi
    done
    if [[ -z "$portal_backend" ]]; then
        fail "No portal backend running"
        failed=$((failed + 1))
    fi
    echo ""

    # Test 3: xwaylandvideobridge
    step "Test 3: xwaylandvideobridge"
    if [[ "$session" == "wayland" ]]; then
        if is_xwvb_running; then
            ok "xwaylandvideobridge running (PID $(pgrep -x xwaylandvideobridge))"
            passed=$((passed + 1))
        else
            if is_xwvb_installed; then
                fail "xwaylandvideobridge installed but not running"
                warn "Run '$SCRIPT_NAME start' to launch it"
            else
                fail "xwaylandvideobridge not installed"
                warn "Run '$SCRIPT_NAME setup' to install it"
            fi
            failed=$((failed + 1))
        fi
    else
        info "Not needed on X11 — skipped"
        skipped=$((skipped + 1))
    fi
    echo ""

    # Test 4: Screen capture frame test
    step "Test 4: Screen Capture"

    local capture_ok=false
    local test_img="$STATE_DIR/test-capture-$(date +%s).png"
    mkdir -p "$STATE_DIR"

    if [[ "$session" == "wayland" ]]; then
        # Try grim first (Wayland native)
        if command -v grim &>/dev/null; then
            info "Attempting screen capture via grim..."
            if timeout 5 grim -t png -l 1 "$test_img" 2>/dev/null; then
                local size
                size=$(stat -c%s "$test_img" 2>/dev/null || echo "0")
                if [[ "$size" -gt 1000 ]]; then
                    ok "Screen captured: $test_img ($size bytes)"
                    capture_ok=true

                    # Check if the image is all black
                    if command -v magick &>/dev/null || command -v identify &>/dev/null; then
                        local identify_cmd="identify"
                        command -v magick &>/dev/null && identify_cmd="magick identify"
                        local mean_val
                        mean_val=$($identify_cmd -verbose "$test_img" 2>/dev/null | grep "mean:" | head -1 | grep -oP '[\d.]+' | head -1 || echo "unknown")
                        if [[ "$mean_val" != "unknown" ]] && [[ "${mean_val%.*}" == "0" ]]; then
                            fail "Capture appears to be all black!"
                            warn "Compositing may be disabled or capture pipeline broken"
                            capture_ok=false
                        else
                            ok "Capture content verified (not black)"
                        fi
                    fi
                else
                    fail "Capture file too small ($size bytes) — may be empty"
                fi
            else
                warn "grim capture failed (may need portal interaction)"
            fi
        elif command -v spectacle &>/dev/null; then
            info "Attempting screen capture via spectacle..."
            if timeout 10 spectacle -b -n -o "$test_img" 2>/dev/null; then
                ok "Screen captured via Spectacle: $test_img"
                capture_ok=true
            else
                warn "Spectacle capture failed"
            fi
        else
            info "No screenshot tool found (install grim or spectacle)"
            skipped=$((skipped + 1))
        fi
    else
        # X11 capture
        if command -v import &>/dev/null; then
            info "Attempting X11 screen capture..."
            if timeout 5 import -window root -resize 640x360 "$test_img" 2>/dev/null; then
                ok "Screen captured: $test_img"
                capture_ok=true
            else
                fail "Screen capture failed"
            fi
        elif command -v scrot &>/dev/null; then
            if timeout 5 scrot "$test_img" 2>/dev/null; then
                ok "Screen captured: $test_img"
                capture_ok=true
            else
                fail "Screen capture failed"
            fi
        else
            info "No X11 screenshot tool — skipping"
            skipped=$((skipped + 1))
        fi
    fi

    if [[ "$capture_ok" == true ]]; then
        passed=$((passed + 1))
    elif [[ $skipped -eq 0 ]]; then
        failed=$((failed + 1))
    fi

    # Clean up test image
    rm -f "$test_img" 2>/dev/null || true
    echo ""

    # Test 5: Audio routing test
    step "Test 5: Audio Routing"

    if command -v pw-cli &>/dev/null; then
        if is_pw_sink_active; then
            ok "Virtual sink '$PW_SINK_NAME' is active"
            passed=$((passed + 1))

            # Test tone
            if command -v pw-play &>/dev/null || command -v speaker-test &>/dev/null; then
                info "Testing audio routing with short tone..."
                if command -v pw-cat &>/dev/null; then
                    # Generate a very short test tone via PipeWire
                    timeout 1 pw-cat --playback --target "$PW_SINK_NAME" /dev/zero 2>/dev/null &
                    local tone_pid=$!
                    sleep 0.5
                    kill "$tone_pid" 2>/dev/null || true

                    # Check if the sink received audio
                    local sink_state
                    sink_state=$(pw-cli info "$PW_SINK_NAME" 2>/dev/null | grep "state:" | head -1 || echo "unknown")
                    if echo "$sink_state" | grep -qi "running\|idle"; then
                        ok "Audio routed to virtual sink successfully"
                        passed=$((passed + 1))
                    else
                        warn "Sink state: $sink_state (may need active audio)"
                        skipped=$((skipped + 1))
                    fi
                elif command -v speaker-test &>/dev/null; then
                    info "Running 0.5s test tone on virtual sink..."
                    timeout 1 speaker-test -D "$PW_SINK_NAME" -t sine -f 440 -l 1 2>/dev/null &
                    sleep 0.5
                    pkill -f "speaker-test.*$PW_SINK_NAME" 2>/dev/null || true
                    ok "Test tone sent to virtual sink"
                    passed=$((passed + 1))
                else
                    info "No audio test tool available — skipping tone test"
                    skipped=$((skipped + 1))
                fi
            else
                info "pw-play/speaker-test not found — skipping audio test"
                skipped=$((skipped + 1))
            fi
        else
            info "Virtual sink not active (run '$SCRIPT_NAME start' first)"
            skipped=$((skipped + 1))
        fi
    else
        fail "PipeWire tools not available"
        failed=$((failed + 1))
    fi
    echo ""

    # Test 6: Discord reachability
    step "Test 6: Discord"
    if is_discord_running; then
        ok "Discord process detected"
        passed=$((passed + 1))
    else
        info "Discord not running (start it to test screen sharing)"
        skipped=$((skipped + 1))
    fi
    echo ""

    # Summary
    echo "${C_BOLD}Test Results${C_RESET}"
    echo ""
    echo "  ${C_GREEN}Passed:${C_RESET}  $passed"
    echo "  ${C_RED}Failed:${C_RESET}  $failed"
    echo "  ${C_DIM}Skipped:${C_RESET} $skipped"
    echo ""

    if [[ $failed -eq 0 ]]; then
        ok "All tests passed! Screen sharing should work."
        echo ""
        echo "  Start a screen share in Discord to fully verify the pipeline."
        notify "Tests Passed" "All $passed tests passed" "dialog-positive"
    else
        fail "$failed test(s) failed"
        echo ""
        echo "  Run '${C_CYAN}$SCRIPT_NAME fix${C_RESET}' to attempt automatic repair."
        notify "Tests Failed" "$failed test(s) failed. Run 'hubos-discord-screen fix'." "dialog-warning"
    fi

    gui_info "Test results:\n\nPassed: $passed\nFailed: $failed\nSkipped: $skipped"
    log_to_file "TEST: passed=$passed failed=$failed skipped=$skipped"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════
#  Help / Usage
# ═══════════════════════════════════════════════════════════════════════

cmd_help() {
    echo ""
    echo "${C_BOLD}HubOS Discord Wayland Screen Share Fix${C_RESET} ${C_DIM}v$VERSION${C_RESET}"
    echo ""
    echo "Fixes Discord screen sharing on Wayland by configuring"
    echo "xwaylandvideobridge, PipeWire audio routing, and XDG portals."
    echo ""
    echo "${C_BOLD}Usage:${C_RESET} $SCRIPT_NAME <command> [options]"
    echo ""
    echo "${C_BOLD}Commands:${C_RESET}"
    echo ""
    echo "  ${C_CYAN}setup${C_RESET}    One-time setup (install xwaylandvideobridge, configure"
    echo "           portals, PipeWire, Discord permissions, autostart)"
    echo ""
    echo "  ${C_CYAN}start${C_RESET}    Start a screen sharing session (launch xwaylandvideobridge,"
    echo "           create PipeWire audio loopback, show Discord instructions)"
    echo ""
    echo "  ${C_CYAN}stop${C_RESET}     Stop session and clean up (remove PipeWire virtual devices,"
    echo "           optionally stop xwaylandvideobridge)"
    echo ""
    echo "  ${C_CYAN}status${C_RESET}   Show the current state of all components (xwaylandvideobridge,"
    echo "           PipeWire sink, Discord, portal configuration)"
    echo ""
    echo "  ${C_CYAN}fix${C_RESET}      Auto-fix common issues (restart portals, recreate PipeWire"
    echo "           nodes, check compositing, fix permissions, clear cache)"
    echo ""
    echo "  ${C_CYAN}test${C_RESET}     Quick diagnostic tests (capture frame, check audio routing,"
    echo "           verify pipeline is not producing black screen)"
    echo ""
    echo "${C_BOLD}Options:${C_RESET}"
    echo ""
    echo "  ${C_DIM}--gui${C_RESET}      Show zenity dialogs for status changes"
    echo "  ${C_DIM}--verbose${C_RESET}  Enable debug output"
    echo "  ${C_DIM}--help${C_RESET}     Show this help message"
    echo "  ${C_DIM}--version${C_RESET}  Show version"
    echo ""
    echo "${C_BOLD}Examples:${C_RESET}"
    echo ""
    echo "  $SCRIPT_NAME setup          # First-time configuration"
    echo "  $SCRIPT_NAME start          # Before Discord screen sharing"
    echo "  $SCRIPT_NAME stop           # After you're done"
    echo "  $SCRIPT_NAME fix            # If screen sharing breaks"
    echo "  $SCRIPT_NAME test --gui     # Test with desktop notifications"
    echo ""
    echo "${C_BOLD}How it works:${C_RESET}"
    echo ""
    echo "  Discord (Electron) doesn't natively support Wayland screen capture."
    echo "  xwaylandvideobridge creates a virtual XWayland window that mirrors"
    echo "  your Wayland desktop. Discord sees it as a regular X11 window and"
    echo "  can capture it. PipeWire routes game audio to a virtual sink that"
    echo "  Discord can use as an audio input source."
    echo ""
    echo "${C_DIM}Supports both Flatpak and native Discord installations.${C_RESET}"
    echo "${C_DIM}Designed for HubOS (Bazzite/Fedora Atomic, KDE Plasma on Wayland).${C_RESET}"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════
#  Argument Parsing & Main
# ═══════════════════════════════════════════════════════════════════════

parse_flags() {
    local args=()
    for arg in "$@"; do
        case "$arg" in
            --gui)     GUI_MODE=true ;;
            --verbose) VERBOSE=true ;;
            --version)
                echo "$SCRIPT_NAME v$VERSION"
                exit 0
                ;;
            --help|-h)
                cmd_help
                exit 0
                ;;
            *)         args+=("$arg") ;;
        esac
    done
    # Return the non-flag arguments
    echo "${args[@]:-}"
}

main() {
    local remaining
    remaining=$(parse_flags "$@")

    # Read the command from remaining args
    local cmd
    cmd=$(echo "$remaining" | awk '{print $1}')
    cmd="${cmd:-help}"

    case "$cmd" in
        setup)   cmd_setup ;;
        start)   cmd_start ;;
        stop)    cmd_stop ;;
        status)  cmd_status ;;
        fix)     cmd_fix ;;
        test)    cmd_test ;;
        help)    cmd_help ;;
        *)
            echo "${C_RED}Unknown command:${C_RESET} $cmd"
            echo "Run '$SCRIPT_NAME --help' for usage."
            exit 1
            ;;
    esac
}

main "$@"
