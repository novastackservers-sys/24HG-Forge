# ── Colors ─────────────────────────────────────────────────────────────────────

class C:
    """Terminal color codes."""
    RESET = "\033[0m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    RED = "\033[91m"
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    BLUE = "\033[94m"
    MAGENTA = "\033[95m"
    CYAN = "\033[96m"
    WHITE = "\033[97m"
    GRAY = "\033[90m"
    BG_RED = "\033[41m"
    BG_GREEN = "\033[42m"
    BG_YELLOW = "\033[43m"

    @staticmethod
    def strip(text: str) -> str:
        return re.sub(r'\033\[[0-9;]*m', '', text)

def use_color() -> bool:
    return sys.stdout.isatty() and os.environ.get("NO_COLOR") is None

NO_COLOR = not use_color()

def c(code: str, text: str) -> str:
    if NO_COLOR:
        return text
    return f"{code}{text}{C.RESET}"

def status_color(status: str) -> str:
    colors = {
        "supported": C.GREEN,
        "denied": C.YELLOW,
        "broken": C.RED,
        "unknown": C.GRAY,
    }
    return colors.get(status, C.WHITE)

def status_label(status: str) -> str:
    labels = {
        "supported": "SUPPORTED",
        "denied": "DENIED",
        "broken": "BROKEN",
        "unknown": "UNKNOWN",
    }
    return c(status_color(status), f" {labels.get(status, status.upper()):^11s} ")

def status_badge(status: str) -> str:
    bg = {
        "supported": C.BG_GREEN,
        "denied": C.BG_YELLOW,
        "broken": C.BG_RED,
    }
    label = {"supported": " WORKS ", "denied": " DENIED ", "broken": " BROKEN ", "unknown": " ??? "}
    code = bg.get(status, "")
    if NO_COLOR:
        return label.get(status, f" {status.upper()} ")
    return f"{code}{C.BOLD}{label.get(status, f' {status.upper()} ')}{C.RESET}"

