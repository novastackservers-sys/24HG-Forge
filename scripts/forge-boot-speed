#!/bin/bash
# 24HG Forge Boot Speed Optimizer — Analyze and reduce boot time
# Usage: forge-boot-speed <command> [options]

set -euo pipefail

CONFIG_DIR="${HOME}/.config/forge/boot-speed"
BASELINE_FILE="${CONFIG_DIR}/baseline"
DISABLED_SERVICES_FILE="${CONFIG_DIR}/disabled-services"
APPLIED_OPTS_FILE="${CONFIG_DIR}/applied-optimizations"
ORIGINAL_CMDLINE_FILE="${CONFIG_DIR}/original-cmdline"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# Services safe to disable on a gaming-focused system
GAMING_SAFE_DISABLE=(
    "cups.service:Printing service (CUPS)"
    "cups-browsed.service:Printer auto-discovery"
    "avahi-daemon.service:mDNS/DNS-SD service discovery"
    "ModemManager.service:Modem management (mobile broadband)"
    "bluetooth.service:Bluetooth stack (if unused)"
    "fwupd.service:Firmware update daemon"
    "packagekit.service:PackageKit update backend"
    "switcheroo-control.service:GPU switching (single-GPU systems)"
    "accounts-daemon.service:User account management"
    "geoclue.service:Geolocation service"
    "sssd.service:System security services (enterprise auth)"
    "livesys.service:Live system setup (post-install leftover)"
    "lvm2-monitor.service:LVM monitoring (if not using LVM)"
    "dmraid-activation.service:Device-mapper RAID activation"
    "multipathd.service:Multipath device management"
    "iscsi.service:iSCSI initiator (SAN storage)"
    "rpcbind.service:NFS RPC portmapper"
    "nfs-client.target:NFS client support"
    "remote-fs.target:Remote filesystem mounts"
)

# Kernel cmdline optimizations for fast boot
KERNEL_OPTS=(
    "quiet:Suppress most kernel messages"
    "splash:Show splash screen instead of text"
    "rd.udev.log_priority=3:Reduce udev logging"
    "systemd.show_status=auto:Only show status on slow boot"
    "nowatchdog:Disable hardware watchdog"
    "nmi_watchdog=0:Disable NMI watchdog"
    "cryptomgr.notests:Skip crypto self-tests"
    "tsc=reliable:Trust TSC clocksource (modern CPUs)"
    "fsck.mode=skip:Skip filesystem check (risky)"
)

init_config() {
    mkdir -p "$CONFIG_DIR"
    touch "$DISABLED_SERVICES_FILE" 2>/dev/null || true
    touch "$APPLIED_OPTS_FILE" 2>/dev/null || true
}

header() {
    echo -e "${BOLD}${CYAN}"
    echo "  Forge Boot Speed Optimizer"
    echo -e "  24HG Forge Linux${RESET}"
    echo ""
}

require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}Error: This operation requires root privileges.${RESET}"
        echo "  Run with: sudo forge-boot-speed $*"
        exit 1
    fi
}

get_boot_time() {
    systemd-analyze 2>/dev/null | head -1 | grep -oP '[\d.]+s\s*\(.*\)' || \
    systemd-analyze 2>/dev/null | head -1
}

get_boot_seconds() {
    local total
    total=$(systemd-analyze 2>/dev/null | head -1 | grep -oP '= [\d.]+s' | grep -oP '[\d.]+' || true)
    if [ -z "$total" ]; then
        total=$(systemd-analyze 2>/dev/null | head -1 | \
            grep -oP '(\d+min\s*)?[\d.]+s' | tail -1 | \
            awk '{
                t=0;
                if (match($0, /([0-9]+)min/, m)) t += m[1]*60;
                if (match($0, /([0-9.]+)s/, m)) t += m[1];
                print t
            }')
    fi
    echo "${total:-0}"
}

cmd_analyze() {
    header
    echo -e "${BOLD}Boot Time Analysis${RESET}"
    echo ""

    echo -e "${CYAN}Overall Boot Time:${RESET}"
    systemd-analyze 2>/dev/null || echo "  systemd-analyze not available"
    echo ""

    echo -e "${CYAN}Boot Phases:${RESET}"
    systemd-analyze time 2>/dev/null | tail -n +2 || true
    echo ""

    echo -e "${CYAN}Critical Chain (longest dependency path):${RESET}"
    systemd-analyze critical-chain --no-pager 2>/dev/null | head -25 || \
        echo "  Could not retrieve critical chain"
    echo ""

    # Check for initramfs time
    local initrd_time
    initrd_time=$(systemd-analyze 2>/dev/null | grep -oP 'initrd\): [\d.]+s' | grep -oP '[\d.]+' || true)
    if [ -n "$initrd_time" ]; then
        echo -e "${CYAN}Initramfs Time:${RESET} ${initrd_time}s"
        if (( $(echo "$initrd_time > 5" | bc -l 2>/dev/null || echo 0) )); then
            echo -e "  ${YELLOW}Initramfs is slow — consider running 'forge-boot-speed recommend'${RESET}"
        fi
        echo ""
    fi

    # Check kernel cmdline
    echo -e "${CYAN}Current Kernel Parameters:${RESET}"
    cat /proc/cmdline 2>/dev/null || echo "  N/A"
    echo ""

    # Count enabled services
    local svc_count
    svc_count=$(systemctl list-unit-files --state=enabled --type=service --no-pager 2>/dev/null | \
        grep -c '\.service' || echo "?")
    echo -e "${CYAN}Enabled Services:${RESET} ${svc_count}"
    echo ""

    if [ -f "$BASELINE_FILE" ]; then
        echo -e "${DIM}Baseline saved. Run 'forge-boot-speed compare' to see changes.${RESET}"
    else
        echo -e "${DIM}No baseline saved. Run 'forge-boot-speed baseline' to save current boot time.${RESET}"
    fi
}

cmd_blame() {
    header
    echo -e "${BOLD}Slowest Boot Services${RESET}"
    echo ""

    local count="${1:-20}"
    echo -e "${CYAN}Top ${count} slowest services:${RESET}"
    echo ""

    systemd-analyze blame --no-pager 2>/dev/null | head -"$count" | while IFS= read -r line; do
        local time_val svc
        time_val=$(echo "$line" | awk '{print $1}')
        svc=$(echo "$line" | awk '{print $2}')

        # Color code by time
        local ms
        ms=$(echo "$time_val" | grep -oP '[\d.]+' | head -1)
        local unit
        unit=$(echo "$time_val" | grep -oP '[a-z]+$' || echo "ms")

        local color="$GREEN"
        if [ "$unit" = "s" ] && (( $(echo "${ms:-0} > 5" | bc -l 2>/dev/null || echo 0) )); then
            color="$RED"
        elif [ "$unit" = "s" ] && (( $(echo "${ms:-0} > 2" | bc -l 2>/dev/null || echo 0) )); then
            color="$YELLOW"
        elif [ "$unit" = "min" ]; then
            color="$RED"
        fi

        printf "  ${color}%12s${RESET}  %s\n" "$time_val" "$svc"
    done
    echo ""

    echo -e "${DIM}Services over 5s are highlighted in red, over 2s in yellow.${RESET}"
}

cmd_recommend() {
    header
    echo -e "${BOLD}Safe Optimization Recommendations${RESET}"
    echo -e "${DIM}For gaming-focused systems${RESET}"
    echo ""

    # Service recommendations
    echo -e "${CYAN}[1] Services Safe to Disable:${RESET}"
    echo ""

    local found=0
    for entry in "${GAMING_SAFE_DISABLE[@]}"; do
        local svc="${entry%%:*}"
        local desc="${entry#*:}"

        if systemctl is-enabled "$svc" &>/dev/null; then
            local time_info
            time_info=$(systemd-analyze blame --no-pager 2>/dev/null | grep "$svc" | awk '{print $1}' || true)
            printf "  ${YELLOW}%-40s${RESET} %s" "$svc" "$desc"
            if [ -n "$time_info" ]; then
                printf " ${DIM}(%s)${RESET}" "$time_info"
            fi
            echo ""
            found=$((found + 1))
        fi
    done

    if [ "$found" -eq 0 ]; then
        echo -e "  ${GREEN}No unnecessary services found enabled.${RESET}"
    else
        echo ""
        echo -e "  ${DIM}Disable with: forge-boot-speed services disable <service>${RESET}"
    fi
    echo ""

    # Kernel parameter recommendations
    echo -e "${CYAN}[2] Kernel Parameter Optimizations:${RESET}"
    echo ""

    local cmdline
    cmdline=$(cat /proc/cmdline 2>/dev/null || echo "")

    for entry in "${KERNEL_OPTS[@]}"; do
        local param="${entry%%:*}"
        local desc="${entry#*:}"
        local key="${param%%=*}"

        if echo "$cmdline" | grep -qw "$key"; then
            printf "  ${GREEN}[applied]${RESET}  %-30s %s\n" "$param" "$desc"
        else
            printf "  ${YELLOW}[missing]${RESET}  %-30s %s\n" "$param" "$desc"
        fi
    done
    echo ""

    # Initramfs recommendations
    echo -e "${CYAN}[3] Initramfs (dracut) Optimization:${RESET}"
    echo ""

    if [ -f /etc/dracut.conf ] || [ -d /etc/dracut.conf.d ]; then
        local dracut_mods
        dracut_mods=$(dracut --list-modules 2>/dev/null | wc -l || echo "?")
        echo "  Current dracut modules: ${dracut_mods}"

        local unnecessary_mods=("bluetooth" "cifs" "nfs" "iscsi" "multipath" "fcoe" "plymouth")
        echo "  Modules that may be unnecessary for gaming:"
        for mod in "${unnecessary_mods[@]}"; do
            if dracut --list-modules 2>/dev/null | grep -qw "$mod"; then
                echo -e "    ${YELLOW}$mod${RESET} — loaded, consider adding to omit_dracutmodules"
            fi
        done
    else
        echo "  dracut configuration not found"
    fi
    echo ""

    # Auto-login recommendation
    echo -e "${CYAN}[4] Auto-Login:${RESET}"
    echo ""

    local autologin_active=false
    if [ -f /etc/gdm/custom.conf ] && grep -q "AutomaticLogin" /etc/gdm/custom.conf 2>/dev/null; then
        autologin_active=true
    elif [ -f /etc/sddm.conf ] && grep -q "Autologin" /etc/sddm.conf 2>/dev/null; then
        autologin_active=true
    fi

    if $autologin_active; then
        echo -e "  ${GREEN}Auto-login is already configured.${RESET}"
    else
        echo -e "  ${YELLOW}Auto-login is not configured.${RESET}"
        echo "  Enable with: forge-boot-speed optimize --autologin"
    fi
    echo ""

    echo -e "${BOLD}Run 'forge-boot-speed optimize' to apply all safe recommendations.${RESET}"
}

cmd_optimize() {
    require_root "$@"
    header
    echo -e "${BOLD}Applying Boot Optimizations${RESET}"
    echo ""

    init_config

    # Save baseline if none exists
    if [ ! -f "$BASELINE_FILE" ]; then
        echo -e "${DIM}Saving current boot time as baseline...${RESET}"
        cmd_baseline_internal
    fi

    # Save original kernel cmdline
    if [ ! -f "$ORIGINAL_CMDLINE_FILE" ]; then
        cat /proc/cmdline > "$ORIGINAL_CMDLINE_FILE" 2>/dev/null || true
    fi

    local do_autologin=false
    local do_all=true

    for arg in "$@"; do
        case "$arg" in
            --autologin) do_autologin=true; do_all=false ;;
            --services) do_all=false ;;
            --kernel) do_all=false ;;
        esac
    done

    local changes=0

    # Disable unnecessary services
    if $do_all || [[ " $* " == *" --services "* ]]; then
        echo -e "${CYAN}Disabling unnecessary services...${RESET}"
        for entry in "${GAMING_SAFE_DISABLE[@]}"; do
            local svc="${entry%%:*}"
            local desc="${entry#*:}"

            # Skip bluetooth if it appears to be in use
            if [ "$svc" = "bluetooth.service" ]; then
                if bluetoothctl show 2>/dev/null | grep -q "Powered: yes"; then
                    echo -e "  ${DIM}Skipping $svc (bluetooth is active)${RESET}"
                    continue
                fi
            fi

            if systemctl is-enabled "$svc" &>/dev/null; then
                systemctl disable "$svc" 2>/dev/null && {
                    echo -e "  ${GREEN}Disabled:${RESET} $svc ($desc)"
                    echo "$svc" >> "$DISABLED_SERVICES_FILE"
                    echo "service:$svc" >> "$APPLIED_OPTS_FILE"
                    changes=$((changes + 1))
                } || echo -e "  ${DIM}Could not disable $svc${RESET}"
            fi
        done
        echo ""
    fi

    # Configure auto-login
    if $do_autologin || $do_all; then
        echo -e "${CYAN}Configuring auto-login...${RESET}"
        local current_user
        current_user="${SUDO_USER:-$(logname 2>/dev/null || echo "")}"

        if [ -z "$current_user" ]; then
            echo -e "  ${YELLOW}Could not determine user for auto-login. Skipping.${RESET}"
        elif [ -f /etc/gdm/custom.conf ]; then
            # GDM (GNOME)
            if ! grep -q "AutomaticLoginEnable" /etc/gdm/custom.conf 2>/dev/null; then
                sed -i '/^\[daemon\]/a AutomaticLoginEnable=True\nAutomaticLogin='"$current_user" \
                    /etc/gdm/custom.conf 2>/dev/null && {
                    echo -e "  ${GREEN}GDM auto-login enabled for ${current_user}${RESET}"
                    echo "autologin:gdm:$current_user" >> "$APPLIED_OPTS_FILE"
                    changes=$((changes + 1))
                }
            else
                echo -e "  ${DIM}GDM auto-login already configured${RESET}"
            fi
        elif [ -f /etc/sddm.conf ] || [ -d /etc/sddm.conf.d ]; then
            # SDDM (KDE)
            local sddm_conf="/etc/sddm.conf.d/forge-autologin.conf"
            mkdir -p /etc/sddm.conf.d
            cat > "$sddm_conf" <<SDDM
[Autologin]
User=$current_user
Session=plasma.desktop
SDDM
            echo -e "  ${GREEN}SDDM auto-login enabled for ${current_user}${RESET}"
            echo "autologin:sddm:$current_user" >> "$APPLIED_OPTS_FILE"
            changes=$((changes + 1))
        else
            echo -e "  ${YELLOW}No supported display manager found (GDM/SDDM).${RESET}"
        fi
        echo ""
    fi

    # Kernel parameter suggestions (cannot apply without bootloader write)
    if $do_all; then
        echo -e "${CYAN}Kernel Parameter Suggestions:${RESET}"
        echo -e "  ${DIM}Kernel params require bootloader config changes.${RESET}"

        local cmdline
        cmdline=$(cat /proc/cmdline 2>/dev/null || echo "")
        local missing_params=""

        for entry in "${KERNEL_OPTS[@]}"; do
            local param="${entry%%:*}"
            local key="${param%%=*}"
            if ! echo "$cmdline" | grep -qw "$key"; then
                missing_params="${missing_params} ${param}"
            fi
        done

        if [ -n "$missing_params" ]; then
            echo "  Add to /etc/default/grub GRUB_CMDLINE_LINUX_DEFAULT:"
            echo -e "  ${YELLOW}${missing_params}${RESET}"
            echo ""

            # Try to apply if grub config exists
            if [ -f /etc/default/grub ]; then
                echo -e "  ${BOLD}Apply kernel params to GRUB? [y/N]${RESET} "
                read -r reply
                if [[ "$reply" =~ ^[Yy] ]]; then
                    local current_params
                    current_params=$(grep '^GRUB_CMDLINE_LINUX_DEFAULT=' /etc/default/grub | \
                        sed 's/GRUB_CMDLINE_LINUX_DEFAULT="//;s/"$//')
                    local new_params="${current_params}${missing_params}"
                    sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"${new_params}\"|" \
                        /etc/default/grub
                    grub2-mkconfig -o /boot/grub2/grub.cfg 2>/dev/null || \
                    grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null || true
                    echo -e "  ${GREEN}Kernel params applied. Reboot required.${RESET}"
                    echo "kernel:${missing_params}" >> "$APPLIED_OPTS_FILE"
                    changes=$((changes + 1))
                fi
            fi
        else
            echo -e "  ${GREEN}All recommended params already present.${RESET}"
        fi
        echo ""
    fi

    # Initramfs optimization hint
    if $do_all; then
        echo -e "${CYAN}Initramfs Optimization:${RESET}"
        local dracut_forge="/etc/dracut.conf.d/forge-optimize.conf"
        if [ ! -f "$dracut_forge" ]; then
            cat > "$dracut_forge" <<'DRACUT'
# 24HG Forge — boot speed optimizations
# Omit modules not needed for gaming desktops
omit_dracutmodules+=" bluetooth cifs nfs iscsi multipath fcoe "
# Compress with zstd for fast decompression
compress="zstd"
DRACUT
            echo -e "  ${GREEN}Created ${dracut_forge}${RESET}"
            echo -e "  ${YELLOW}Run 'dracut --force --regenerate-all' to apply.${RESET}"
            echo "dracut:$dracut_forge" >> "$APPLIED_OPTS_FILE"
            changes=$((changes + 1))
        else
            echo -e "  ${DIM}Forge dracut config already exists.${RESET}"
        fi
        echo ""
    fi

    echo "---"
    if [ "$changes" -gt 0 ]; then
        echo -e "${GREEN}Applied ${changes} optimization(s).${RESET} Reboot to see the effect."
        echo -e "Run ${BOLD}forge-boot-speed compare${RESET} after reboot to measure improvement."
        echo -e "Run ${BOLD}forge-boot-speed undo${RESET} to revert all changes."
    else
        echo -e "${DIM}No changes applied — system already optimized or nothing to do.${RESET}"
    fi
}

cmd_services() {
    local action="${1:-}"
    local service="${2:-}"

    if [ -z "$action" ] || [ -z "$service" ]; then
        echo "Usage: forge-boot-speed services [disable|enable] <service>"
        echo ""
        echo "Examples:"
        echo "  forge-boot-speed services disable cups.service"
        echo "  forge-boot-speed services enable bluetooth.service"
        exit 1
    fi

    require_root services "$@"
    init_config

    case "$action" in
        disable)
            if systemctl is-enabled "$service" &>/dev/null; then
                systemctl disable "$service" && systemctl stop "$service" 2>/dev/null || true
                echo "$service" >> "$DISABLED_SERVICES_FILE"
                echo -e "${GREEN}Disabled and stopped:${RESET} $service"
            else
                echo -e "${DIM}$service is already disabled or does not exist.${RESET}"
            fi
            ;;
        enable)
            systemctl enable "$service" 2>/dev/null && {
                echo -e "${GREEN}Enabled:${RESET} $service"
                # Remove from tracked disabled list
                if [ -f "$DISABLED_SERVICES_FILE" ]; then
                    sed -i "\|^${service}$|d" "$DISABLED_SERVICES_FILE"
                fi
            } || echo -e "${RED}Failed to enable $service${RESET}"
            ;;
        *)
            echo "Unknown action: $action (use 'disable' or 'enable')"
            exit 1
            ;;
    esac
}

cmd_baseline() {
    init_config
    cmd_baseline_internal
    echo -e "${GREEN}Baseline saved.${RESET}"
}

cmd_baseline_internal() {
    local boot_time
    boot_time=$(get_boot_seconds)
    local boot_detail
    boot_detail=$(systemd-analyze 2>/dev/null | head -1 || echo "unknown")
    local timestamp
    timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC')

    cat > "$BASELINE_FILE" <<EOF
timestamp=$timestamp
total_seconds=$boot_time
detail=$boot_detail
services_enabled=$(systemctl list-unit-files --state=enabled --type=service --no-pager 2>/dev/null | grep -c '\.service' || echo 0)
EOF
}

cmd_compare() {
    header
    echo -e "${BOLD}Boot Time Comparison${RESET}"
    echo ""

    if [ ! -f "$BASELINE_FILE" ]; then
        echo -e "${YELLOW}No baseline found. Run 'forge-boot-speed baseline' first.${RESET}"
        exit 1
    fi

    # Read baseline
    local bl_time bl_detail bl_services bl_timestamp
    bl_time=$(grep '^total_seconds=' "$BASELINE_FILE" | cut -d= -f2)
    bl_detail=$(grep '^detail=' "$BASELINE_FILE" | cut -d= -f2-)
    bl_services=$(grep '^services_enabled=' "$BASELINE_FILE" | cut -d= -f2)
    bl_timestamp=$(grep '^timestamp=' "$BASELINE_FILE" | cut -d= -f2-)

    # Current values
    local cur_time cur_detail cur_services
    cur_time=$(get_boot_seconds)
    cur_detail=$(systemd-analyze 2>/dev/null | head -1 || echo "unknown")
    cur_services=$(systemctl list-unit-files --state=enabled --type=service --no-pager 2>/dev/null | \
        grep -c '\.service' || echo 0)

    echo -e "${CYAN}Baseline${RESET} (${bl_timestamp}):"
    echo "  Boot time: ${bl_detail}"
    echo "  Enabled services: ${bl_services}"
    echo ""

    echo -e "${CYAN}Current:${RESET}"
    echo "  Boot time: ${cur_detail}"
    echo "  Enabled services: ${cur_services}"
    echo ""

    # Calculate difference
    if command -v bc &>/dev/null && [ -n "$bl_time" ] && [ -n "$cur_time" ]; then
        local diff
        diff=$(echo "$bl_time - $cur_time" | bc -l 2>/dev/null || echo "0")
        local abs_diff
        abs_diff=$(echo "$diff" | sed 's/^-//')

        echo -e "${BOLD}Difference:${RESET}"
        if (( $(echo "$diff > 0.1" | bc -l 2>/dev/null || echo 0) )); then
            echo -e "  ${GREEN}${abs_diff}s faster${RESET} than baseline"
        elif (( $(echo "$diff < -0.1" | bc -l 2>/dev/null || echo 0) )); then
            echo -e "  ${RED}${abs_diff}s slower${RESET} than baseline"
        else
            echo -e "  ${DIM}No significant change${RESET}"
        fi

        local svc_diff=$((bl_services - cur_services))
        if [ "$svc_diff" -gt 0 ]; then
            echo -e "  ${GREEN}${svc_diff} fewer services enabled${RESET}"
        elif [ "$svc_diff" -lt 0 ]; then
            echo -e "  ${YELLOW}$((-svc_diff)) more services enabled${RESET}"
        fi
    fi
}

cmd_undo() {
    require_root undo
    header
    echo -e "${BOLD}Reverting Boot Optimizations${RESET}"
    echo ""

    if [ ! -f "$APPLIED_OPTS_FILE" ]; then
        echo -e "${DIM}No optimizations to revert.${RESET}"
        exit 0
    fi

    local changes=0

    while IFS= read -r line; do
        local type="${line%%:*}"
        local value="${line#*:}"

        case "$type" in
            service)
                if ! systemctl is-enabled "$value" &>/dev/null; then
                    systemctl enable "$value" 2>/dev/null && {
                        echo -e "  ${GREEN}Re-enabled:${RESET} $value"
                        changes=$((changes + 1))
                    }
                fi
                ;;
            autologin)
                local dm="${value%%:*}"
                case "$dm" in
                    gdm)
                        if [ -f /etc/gdm/custom.conf ]; then
                            sed -i '/^AutomaticLoginEnable=/d;/^AutomaticLogin=/d' /etc/gdm/custom.conf
                            echo -e "  ${GREEN}Removed GDM auto-login${RESET}"
                            changes=$((changes + 1))
                        fi
                        ;;
                    sddm)
                        rm -f /etc/sddm.conf.d/forge-autologin.conf
                        echo -e "  ${GREEN}Removed SDDM auto-login${RESET}"
                        changes=$((changes + 1))
                        ;;
                esac
                ;;
            kernel)
                echo -e "  ${YELLOW}Kernel params were modified — check /etc/default/grub manually${RESET}"
                if [ -f "$ORIGINAL_CMDLINE_FILE" ]; then
                    echo -e "  Original cmdline: $(cat "$ORIGINAL_CMDLINE_FILE")"
                fi
                ;;
            dracut)
                local conf="${value}"
                if [ -f "$conf" ]; then
                    rm -f "$conf"
                    echo -e "  ${GREEN}Removed ${conf}${RESET}"
                    echo -e "  ${YELLOW}Run 'dracut --force --regenerate-all' to rebuild initramfs.${RESET}"
                    changes=$((changes + 1))
                fi
                ;;
        esac
    done < "$APPLIED_OPTS_FILE"

    # Clear tracking files
    : > "$APPLIED_OPTS_FILE"
    : > "$DISABLED_SERVICES_FILE"

    echo ""
    if [ "$changes" -gt 0 ]; then
        echo -e "${GREEN}Reverted ${changes} change(s).${RESET} Reboot to take effect."
    else
        echo -e "${DIM}Nothing to revert.${RESET}"
    fi
}

usage() {
    echo -e "${BOLD}Forge Boot Speed Optimizer${RESET}"
    echo ""
    echo "Usage: forge-boot-speed <command> [options]"
    echo ""
    echo "Commands:"
    echo "  analyze              Show full boot time analysis"
    echo "  blame [count]        Show slowest boot services (default: top 20)"
    echo "  recommend            Show safe optimization recommendations"
    echo "  optimize             Apply recommended optimizations (requires root)"
    echo "  services <action> <svc>  Disable/enable a specific service"
    echo "  compare              Compare current vs baseline boot time"
    echo "  baseline             Save current boot time as baseline"
    echo "  undo                 Revert all applied optimizations"
    echo ""
    echo "Examples:"
    echo "  forge-boot-speed analyze"
    echo "  forge-boot-speed blame 30"
    echo "  forge-boot-speed services disable cups.service"
    echo "  sudo forge-boot-speed optimize"
    echo "  sudo forge-boot-speed undo"
}

# Main
init_config

case "${1:-}" in
    analyze)    cmd_analyze ;;
    blame)      cmd_blame "${2:-20}" ;;
    recommend)  cmd_recommend ;;
    optimize)   shift; cmd_optimize "$@" ;;
    services)   shift; cmd_services "$@" ;;
    compare)    cmd_compare ;;
    baseline)   cmd_baseline ;;
    undo)       shift 2>/dev/null || true; cmd_undo ;;
    -h|--help|help) usage ;;
    *)          usage; exit 1 ;;
esac
