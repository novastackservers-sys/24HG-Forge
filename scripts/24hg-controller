#!/bin/bash
# 24HG Controller Manager
# Detects, calibrates, profiles, remaps, and troubleshoots gamepads.
# Supports Xbox, PlayStation, Nintendo, 8BitDo, and generic HID controllers.
#
# Usage: 24hg-controller [list|test|calibrate|profile|map|fix|status] [args...]

set -euo pipefail

ACTION="${1:-status}"
DEVICE="${2:-}"
PROFILE_DIR="${HOME}/.config/24hg/controller"
CALIBRATION_DIR="${PROFILE_DIR}/calibrations"
MAPPING_DIR="${PROFILE_DIR}/mappings"
UDEV_RULES_DIR="/etc/udev/rules.d"
ACTIVE_PROFILE_FILE="${PROFILE_DIR}/active-profile"
HAS_ZENITY=false

command -v zenity &>/dev/null && HAS_ZENITY=true

mkdir -p "$PROFILE_DIR" "$CALIBRATION_DIR" "$MAPPING_DIR"

# ──────────────────────────────────────────────
# Colors
# ──────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

info()  { echo -e "${GREEN}[+]${RESET} $*"; }
warn()  { echo -e "${YELLOW}[!]${RESET} $*"; }
err()   { echo -e "${RED}[-]${RESET} $*"; }
head_()  { echo -e "\n${BOLD}${CYAN}=== $* ===${RESET}\n"; }

# ──────────────────────────────────────────────
# Helper: get controller info from sysfs
# ──────────────────────────────────────────────
get_device_name() {
    local dev="$1"
    local sysfs_path

    if [[ "$dev" == /dev/input/js* ]]; then
        local num="${dev#/dev/input/js}"
        sysfs_path="/sys/class/input/js${num}/device/name"
    elif [[ "$dev" == /dev/input/event* ]]; then
        local num="${dev#/dev/input/event}"
        sysfs_path="/sys/class/input/event${num}/device/name"
    else
        echo "Unknown"
        return
    fi

    if [[ -r "$sysfs_path" ]]; then
        cat "$sysfs_path"
    else
        # Fallback to udevadm
        udevadm info --query=property --name="$dev" 2>/dev/null \
            | grep '^ID_INPUT_.*=1' | head -1 | cut -d= -f1 || echo "Unknown"
    fi
}

get_vendor_product() {
    local dev="$1"
    local vendor product
    vendor=$(udevadm info --query=property --name="$dev" 2>/dev/null | grep '^ID_VENDOR_ID=' | cut -d= -f2 || echo "0000")
    product=$(udevadm info --query=property --name="$dev" 2>/dev/null | grep '^ID_MODEL_ID=' | cut -d= -f2 || echo "0000")
    echo "${vendor:-0000}:${product:-0000}"
}

get_driver() {
    local dev="$1"
    local driver
    driver=$(udevadm info --attribute-walk --name="$dev" 2>/dev/null \
        | grep 'DRIVERS==' | grep -v '""' | head -1 | sed 's/.*DRIVERS=="\(.*\)"/\1/')
    echo "${driver:-generic}"
}

get_connection_type() {
    local dev="$1"
    local devpath
    devpath=$(udevadm info --query=property --name="$dev" 2>/dev/null | grep '^DEVPATH=' | cut -d= -f2 || echo "")

    if echo "$devpath" | grep -qi "bluetooth\|hci"; then
        echo "Bluetooth"
    elif echo "$devpath" | grep -qi "usb"; then
        echo "USB"
    else
        echo "Unknown"
    fi
}

get_controller_type() {
    local name="$1"
    local vendor="$2"
    local name_lower="${name,,}"

    # Xbox controllers
    if echo "$name_lower" | grep -qE "xbox|x-box|microsoft.*controller|xpad|xone"; then
        echo "Xbox"
    # PlayStation controllers
    elif echo "$name_lower" | grep -qE "playstation|dualshock|dualsense|sony|ps[345]"; then
        echo "PlayStation"
    # Nintendo controllers
    elif echo "$name_lower" | grep -qE "nintendo|pro controller|joy-con|switch"; then
        echo "Nintendo"
    # 8BitDo controllers
    elif echo "$name_lower" | grep -qE "8bitdo|8bit"; then
        echo "8BitDo"
    else
        echo "Generic"
    fi
}

# ──────────────────────────────────────────────
# Enumerate all joystick/gamepad devices
# ──────────────────────────────────────────────
find_controllers() {
    local devices=()

    # Check joystick devices
    for js in /dev/input/js*; do
        [[ -e "$js" ]] || continue
        devices+=("$js")
    done

    # Check event devices that are joysticks/gamepads
    for ev in /dev/input/event*; do
        [[ -e "$ev" ]] || continue
        local props
        props=$(udevadm info --query=property --name="$ev" 2>/dev/null || true)
        if echo "$props" | grep -q 'ID_INPUT_JOYSTICK=1'; then
            devices+=("$ev")
        fi
    done

    printf '%s\n' "${devices[@]}" 2>/dev/null | sort -u
}

# ──────────────────────────────────────────────
# Select a device (GUI or terminal)
# ──────────────────────────────────────────────
select_device() {
    local prompt="${1:-Select a controller}"
    local devices=()
    local names=()

    while IFS= read -r dev; do
        [[ -n "$dev" ]] || continue
        devices+=("$dev")
        names+=("$(get_device_name "$dev")")
    done < <(find_controllers)

    if [[ ${#devices[@]} -eq 0 ]]; then
        err "No controllers detected."
        return 1
    fi

    if [[ ${#devices[@]} -eq 1 ]]; then
        echo "${devices[0]}"
        return 0
    fi

    # Try zenity first
    if $HAS_ZENITY && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
        local zenity_args=()
        for i in "${!devices[@]}"; do
            zenity_args+=("${devices[$i]}" "${names[$i]}")
        done
        local choice
        choice=$(zenity --list --title="$prompt" --column="Device" --column="Name" \
            --width=500 --height=300 "${zenity_args[@]}" 2>/dev/null) || return 1
        echo "$choice"
        return 0
    fi

    # Terminal fallback
    echo ""
    echo "  $prompt:"
    echo ""
    for i in "${!devices[@]}"; do
        echo "    [$((i+1))] ${names[$i]}  (${devices[$i]})"
    done
    echo ""
    read -rp "  Choice [1-${#devices[@]}]: " choice
    local idx=$((choice - 1))
    if [[ $idx -ge 0 && $idx -lt ${#devices[@]} ]]; then
        echo "${devices[$idx]}"
    else
        err "Invalid selection."
        return 1
    fi
}

resolve_device() {
    local input="$1"

    # Already a full path
    if [[ "$input" == /dev/input/* ]]; then
        if [[ -e "$input" ]]; then
            echo "$input"
            return 0
        fi
        err "Device $input does not exist."
        return 1
    fi

    # Shorthand: "js0", "event5", "0"
    if [[ "$input" =~ ^js[0-9]+$ ]]; then
        echo "/dev/input/$input"
        return 0
    elif [[ "$input" =~ ^event[0-9]+$ ]]; then
        echo "/dev/input/$input"
        return 0
    elif [[ "$input" =~ ^[0-9]+$ ]]; then
        echo "/dev/input/js${input}"
        return 0
    fi

    err "Cannot resolve device: $input"
    return 1
}

# ──────────────────────────────────────────────
# Command: list
# ──────────────────────────────────────────────
cmd_list() {
    head_ "Connected Controllers"

    local found=0
    local seen_names=()

    # List joystick devices (primary view)
    for js in /dev/input/js*; do
        [[ -e "$js" ]] || continue
        found=1

        local name vendor_product driver conn_type ctrl_type
        name=$(get_device_name "$js")
        vendor_product=$(get_vendor_product "$js")
        driver=$(get_driver "$js")
        conn_type=$(get_connection_type "$js")
        ctrl_type=$(get_controller_type "$name" "$vendor_product")

        local icon
        case "$ctrl_type" in
            Xbox)        icon="[XB]" ;;
            PlayStation) icon="[PS]" ;;
            Nintendo)    icon="[NS]" ;;
            8BitDo)     icon="[8B]" ;;
            *)          icon="[--]" ;;
        esac

        echo -e "  ${BOLD}${icon} ${name}${RESET}"
        echo -e "      Device:     ${js}"

        # Find corresponding event device
        local js_num="${js#/dev/input/js}"
        local phys_path
        phys_path=$(readlink -f "/sys/class/input/js${js_num}/device" 2>/dev/null || echo "")
        if [[ -n "$phys_path" ]]; then
            for ev_dir in "$phys_path"/event*; do
                [[ -d "$ev_dir" ]] || continue
                local ev_name
                ev_name=$(basename "$ev_dir")
                echo -e "      Event:      /dev/input/${ev_name}"
            done
        fi

        echo -e "      ID:         ${vendor_product}"
        echo -e "      Driver:     ${driver}"
        echo -e "      Connection: ${conn_type}"

        # Show battery if available (PlayStation, Nintendo, Xbox wireless)
        local power_dir
        for power_dir in /sys/class/power_supply/*; do
            [[ -d "$power_dir" ]] || continue
            local scope
            scope=$(cat "$power_dir/scope" 2>/dev/null || echo "")
            if [[ "$scope" == "Device" ]]; then
                local cap
                cap=$(cat "$power_dir/capacity" 2>/dev/null || echo "")
                local status
                status=$(cat "$power_dir/status" 2>/dev/null || echo "")
                if [[ -n "$cap" ]]; then
                    local bat_color="$GREEN"
                    [[ "$cap" -lt 30 ]] && bat_color="$RED"
                    [[ "$cap" -ge 30 && "$cap" -lt 60 ]] && bat_color="$YELLOW"
                    echo -e "      Battery:    ${bat_color}${cap}%${RESET} (${status})"
                    break
                fi
            fi
        done

        echo ""
        seen_names+=("$name")
    done

    if [[ $found -eq 0 ]]; then
        warn "No controllers detected."
        echo ""
        echo "  Tips:"
        echo "    - Plug in a USB controller or pair via Bluetooth"
        echo "    - Run '24hg-controller fix' to reload drivers"
        echo "    - Check dmesg: dmesg | tail -20"
    fi
}

# ──────────────────────────────────────────────
# Command: test <device>
# ──────────────────────────────────────────────
cmd_test() {
    local dev

    if [[ -n "$DEVICE" ]]; then
        dev=$(resolve_device "$DEVICE")
    else
        dev=$(select_device "Select controller to test") || exit 1
    fi

    head_ "Input Test: $(get_device_name "$dev")"
    echo -e "  ${DIM}Press Ctrl+C to stop${RESET}\n"

    if [[ "$dev" == /dev/input/event* ]]; then
        # Prefer evtest for event devices
        if command -v evtest &>/dev/null; then
            info "Using evtest on $dev"
            echo ""
            exec evtest "$dev"
        else
            err "evtest not installed. Install: sudo apt install evtest"
            exit 1
        fi
    elif [[ "$dev" == /dev/input/js* ]]; then
        # Use jstest for joystick devices
        if command -v jstest &>/dev/null; then
            info "Using jstest on $dev"
            echo ""
            exec jstest "$dev"
        elif command -v evtest &>/dev/null; then
            # Find corresponding event device and use evtest
            local js_num="${dev#/dev/input/js}"
            local phys_path
            phys_path=$(readlink -f "/sys/class/input/js${js_num}/device" 2>/dev/null || echo "")
            if [[ -n "$phys_path" ]]; then
                for ev_dir in "$phys_path"/event*; do
                    [[ -d "$ev_dir" ]] || continue
                    local ev_name
                    ev_name=$(basename "$ev_dir")
                    info "Using evtest on /dev/input/${ev_name} (jstest not available)"
                    echo ""
                    exec evtest "/dev/input/${ev_name}"
                done
            fi
            err "Could not find event device for $dev"
            exit 1
        else
            err "Neither jstest nor evtest installed."
            echo "  Install: sudo apt install joystick evtest"
            exit 1
        fi
    fi
}

# ──────────────────────────────────────────────
# Command: calibrate <device>
# ──────────────────────────────────────────────
cmd_calibrate() {
    local dev

    if [[ -n "$DEVICE" ]]; then
        dev=$(resolve_device "$DEVICE")
    else
        dev=$(select_device "Select controller to calibrate") || exit 1
    fi

    # Calibration only works on js* devices
    if [[ "$dev" != /dev/input/js* ]]; then
        err "Calibration requires a joystick device (/dev/input/js*), got: $dev"
        echo "  Use '24hg-controller list' to find the js* device."
        exit 1
    fi

    if ! command -v jscal &>/dev/null; then
        err "jscal not installed. Install: sudo apt install joystick"
        exit 1
    fi

    local name
    name=$(get_device_name "$dev")
    local vendor_product
    vendor_product=$(get_vendor_product "$dev")
    local js_num="${dev#/dev/input/js}"

    head_ "Calibrate: $name ($dev)"

    # Show current calibration
    info "Current calibration:"
    jscal -q "$dev" 2>/dev/null || warn "Could not read current calibration"
    echo ""

    # GUI wizard or terminal
    if $HAS_ZENITY && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
        zenity --info --title="Controller Calibration" \
            --text="Calibration wizard for: $name\n\nStep 1: Center all sticks and press OK.\nDo not touch anything." \
            --width=400 2>/dev/null || true
    else
        echo -e "  ${BOLD}Step 1: Center all sticks${RESET}"
        echo "  Leave all sticks in their neutral position."
        read -rp "  Press Enter when ready... "
    fi

    # Perform calibration
    info "Reading center positions..."
    if ! sudo jscal -c "$dev" 2>/dev/null; then
        # Non-interactive calibration fallback: use stored or default
        warn "Interactive calibration needs terminal input routed to jscal."
        echo ""
        echo "  Running jscal in calibration mode. Follow the prompts:"
        echo "  - Move each axis to its extremes when prompted"
        echo "  - Press buttons when asked"
        echo ""
        sudo jscal -c "$dev"
    fi

    # Read back the calibration
    local cal_data
    cal_data=$(jscal -q "$dev" 2>/dev/null || echo "")

    if [[ -z "$cal_data" ]]; then
        err "Failed to read calibration data."
        exit 1
    fi

    info "Calibration complete."
    echo ""

    # Offer deadzone adjustment
    local deadzone=4096
    if $HAS_ZENITY && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
        deadzone=$(zenity --scale --title="Deadzone" \
            --text="Set stick deadzone (higher = less drift, less precision)" \
            --min-value=0 --max-value=16384 --value=4096 --step=256 \
            --width=400 2>/dev/null) || deadzone=4096
    else
        echo -e "  ${BOLD}Step 2: Set deadzone${RESET}"
        echo "  Higher values reduce stick drift but decrease precision."
        echo "  Recommended: 2048 (tight) - 6144 (loose)"
        read -rp "  Deadzone [4096]: " deadzone
        deadzone="${deadzone:-4096}"
    fi

    # Save calibration data
    local cal_file="${CALIBRATION_DIR}/${js_num}_$(echo "$vendor_product" | tr ':' '_').cal"
    echo "$cal_data" > "$cal_file"
    echo "DEADZONE=$deadzone" >> "$cal_file"
    info "Saved calibration to: $cal_file"

    # Create persistent udev rule
    local rule_file="${UDEV_RULES_DIR}/85-24hg-controller-${js_num}.rules"
    local escaped_cal
    escaped_cal=$(echo "$cal_data" | sed 's/jscal -s//' | xargs)

    local udev_rule="# 24HG controller calibration for $name ($vendor_product)
# Generated by 24hg-controller on $(date -I)
ACTION==\"add\", ATTRS{idVendor}==\"${vendor_product%%:*}\", ATTRS{idProduct}==\"${vendor_product##*:}\", KERNEL==\"js*\", RUN+=\"/usr/bin/jscal -s ${escaped_cal} /dev/input/%k\""

    echo ""
    info "Creating persistent udev rule..."
    if echo "$udev_rule" | sudo tee "$rule_file" >/dev/null 2>&1; then
        sudo udevadm control --reload-rules 2>/dev/null || true
        info "Udev rule written: $rule_file"
        info "Calibration will persist across reboots."
    else
        warn "Could not write udev rule (need sudo). Calibration saved locally only."
        echo "  Manual install: sudo cp '$cal_file' and create udev rule"
    fi

    echo ""
    info "Done. Test with: 24hg-controller test $dev"
}

# ──────────────────────────────────────────────
# Command: profile <name>
# ──────────────────────────────────────────────

# Profile definitions: name -> jscal correction parameters
# These adjust deadzones and axis response curves
declare -A PROFILES
PROFILES=(
    [default]="Standard deadzone, linear response"
    [fps]="High deadzone, fast response for shooters"
    [racing]="Wide axis range, low deadzone for precision steering"
    [retro]="D-pad priority, snappy digital-feel response"
)

get_profile_jscal_args() {
    local profile="$1"
    local num_axes="${2:-6}"

    case "$profile" in
        default)
            # Standard linear correction, moderate deadzone (4096)
            local corrections=""
            for ((i=0; i<num_axes; i++)); do
                [[ -n "$corrections" ]] && corrections+=","
                corrections+="1,0,4096,16384,16384"
            done
            echo "${num_axes},${corrections}"
            ;;
        fps)
            # High deadzone (8192) to prevent drift, steeper curve
            local corrections=""
            for ((i=0; i<num_axes; i++)); do
                [[ -n "$corrections" ]] && corrections+=","
                corrections+="1,0,8192,24576,24576"
            done
            echo "${num_axes},${corrections}"
            ;;
        racing)
            # Low deadzone (1024), wide range for analog precision
            local corrections=""
            for ((i=0; i<num_axes; i++)); do
                [[ -n "$corrections" ]] && corrections+=","
                corrections+="1,0,1024,32768,32768"
            done
            echo "${num_axes},${corrections}"
            ;;
        retro)
            # Very high deadzone (12288) for digital-feel snapping
            local corrections=""
            for ((i=0; i<num_axes; i++)); do
                [[ -n "$corrections" ]] && corrections+=","
                corrections+="1,0,12288,16384,16384"
            done
            echo "${num_axes},${corrections}"
            ;;
    esac
}

cmd_profile() {
    local profile_name="${DEVICE:-}"

    # No profile given — show list or selector
    if [[ -z "$profile_name" ]]; then
        local active
        active=$(cat "$ACTIVE_PROFILE_FILE" 2>/dev/null || echo "default")

        if $HAS_ZENITY && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
            profile_name=$(zenity --list --title="Controller Profile" \
                --column="Profile" --column="Description" \
                "default" "Standard deadzone, linear response" \
                "fps" "High deadzone, fast response for shooters" \
                "racing" "Wide axis range, low deadzone for steering" \
                "retro" "D-pad priority, snappy digital-feel" \
                --width=500 --height=300 2>/dev/null) || exit 0
        else
            head_ "Controller Profiles"
            echo -e "  Active: ${BOLD}${active}${RESET}\n"
            echo -e "  ${BOLD}default${RESET}  Standard deadzone, linear response"
            echo -e "  ${BOLD}fps${RESET}      High deadzone, fast response for shooters"
            echo -e "  ${BOLD}racing${RESET}   Wide axis range, low deadzone for steering"
            echo -e "  ${BOLD}retro${RESET}    D-pad priority, snappy digital-feel response"
            echo ""
            echo "  Usage: 24hg-controller profile <name>"
            return 0
        fi
    fi

    if [[ -z "${PROFILES[$profile_name]+x}" ]]; then
        err "Unknown profile: $profile_name"
        echo "  Available: default, fps, racing, retro"
        exit 1
    fi

    head_ "Applying Profile: $profile_name"
    info "${PROFILES[$profile_name]}"
    echo ""

    if ! command -v jscal &>/dev/null; then
        err "jscal not installed. Install: sudo apt install joystick"
        exit 1
    fi

    local applied=0

    for js in /dev/input/js*; do
        [[ -e "$js" ]] || continue

        local name
        name=$(get_device_name "$js")

        # Determine number of axes
        local num_axes=6
        if command -v jscal &>/dev/null; then
            local axis_info
            axis_info=$(jscal -q "$js" 2>/dev/null | head -1 || echo "")
            if [[ "$axis_info" =~ ^([0-9]+), ]]; then
                num_axes="${BASH_REMATCH[1]}"
            fi
        fi

        local cal_args
        cal_args=$(get_profile_jscal_args "$profile_name" "$num_axes")

        if jscal -s "$cal_args" "$js" 2>/dev/null; then
            info "Applied to: $name ($js) [$num_axes axes]"
            applied=$((applied + 1))
        else
            warn "Failed on: $name ($js) — may need sudo"
        fi
    done

    if [[ $applied -eq 0 ]]; then
        warn "No controllers found to apply profile."
    else
        echo "$profile_name" > "$ACTIVE_PROFILE_FILE"
        info "Profile '$profile_name' active on $applied controller(s)."
        notify-send -a "24HG" -i "input-gaming" "Controller Profile" \
            "Switched to: $profile_name" 2>/dev/null || true
    fi
}

# ──────────────────────────────────────────────
# Command: map <device>
# ──────────────────────────────────────────────
cmd_map() {
    local dev

    if [[ -n "$DEVICE" ]]; then
        dev=$(resolve_device "$DEVICE")
    else
        dev=$(select_device "Select controller to remap") || exit 1
    fi

    local name
    name=$(get_device_name "$dev")

    head_ "Button/Axis Mapping: $name ($dev)"

    # Show current mapping
    if [[ "$dev" == /dev/input/js* ]] && command -v jstest &>/dev/null; then
        info "Current axis/button layout:"
        echo ""
        # Quick non-interactive read of available axes/buttons
        local js_num="${dev#/dev/input/js}"
        local num_axes num_buttons
        num_axes=$(cat "/sys/class/input/js${js_num}/device/id/axes" 2>/dev/null \
            || jscal -q "$dev" 2>/dev/null | head -1 | cut -d, -f1 || echo "?")
        num_buttons=$(cat "/sys/class/input/js${js_num}/device/id/buttons" 2>/dev/null || echo "?")
        echo -e "    Axes:    ${num_axes}"
        echo -e "    Buttons: ${num_buttons}"
        echo ""
    fi

    if [[ "$dev" == /dev/input/event* ]] && command -v evtest &>/dev/null; then
        info "Capabilities:"
        evtest --query "$dev" EV_KEY 0 2>/dev/null
        evtest "$dev" 2>/dev/null &
        local evtest_pid=$!
        sleep 0.5
        kill "$evtest_pid" 2>/dev/null || true
        wait "$evtest_pid" 2>/dev/null || true
    fi

    # Check for existing SDL mapping
    local sdl_env_file="${MAPPING_DIR}/sdl_gamecontroller.env"
    if [[ -f "$sdl_env_file" ]]; then
        info "Existing SDL mapping found:"
        echo -e "    ${DIM}$(cat "$sdl_env_file")${RESET}"
        echo ""
    fi

    # Offer remapping options
    echo -e "  ${BOLD}Remapping options:${RESET}\n"
    echo "    [1] Generate SDL_GAMECONTROLLERCONFIG (works with most games)"
    echo "    [2] Use xboxdrv for full remapping (Xbox emulation)"
    echo "    [3] Show raw mapping and exit"
    echo ""

    local choice
    if $HAS_ZENITY && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
        choice=$(zenity --list --title="Remap Method" \
            --column="Option" --column="Description" \
            "1" "Generate SDL_GAMECONTROLLERCONFIG" \
            "2" "Use xboxdrv for full Xbox emulation" \
            "3" "Show raw mapping only" \
            --width=450 --height=250 2>/dev/null | head -c1) || return 0
    else
        read -rp "  Choice [1-3]: " choice
    fi

    case "$choice" in
        1)  _map_sdl "$dev" "$name" ;;
        2)  _map_xboxdrv "$dev" "$name" ;;
        3)
            info "Run for detailed raw output:"
            echo "    evtest $dev"
            echo "    jstest --normal $dev"
            ;;
        *)  warn "No action taken." ;;
    esac
}

_map_sdl() {
    local dev="$1"
    local name="$2"
    local vendor_product
    vendor_product=$(get_vendor_product "$dev")
    local vendor="${vendor_product%%:*}"
    local product="${vendor_product##*:}"

    # Generate a GUID following SDL convention: bustype-vendor-product-version
    local guid
    guid=$(printf "03000000%s0000%s0000000000000000" "$vendor" "$product")

    head_ "SDL Gamepad Mapping"
    echo ""
    echo "  Interactive mapping: press each button/move each axis when prompted."
    echo "  This generates an SDL_GAMECONTROLLERCONFIG string."
    echo ""

    # Check if controllermap tool is available (ships with SDL2)
    if command -v controllermap &>/dev/null; then
        info "Found SDL controllermap tool. Launching..."
        local js_num
        js_num="${dev#/dev/input/js}"
        [[ "$dev" == /dev/input/js* ]] || js_num=0
        local mapping
        mapping=$(controllermap "$js_num" 2>/dev/null || echo "")
        if [[ -n "$mapping" ]]; then
            echo ""
            info "Generated mapping:"
            echo "  $mapping"
            echo ""
            echo "SDL_GAMECONTROLLERCONFIG=\"$mapping\"" > "${MAPPING_DIR}/sdl_gamecontroller.env"
            info "Saved to: ${MAPPING_DIR}/sdl_gamecontroller.env"
            echo ""
            info "To use system-wide, add to your shell profile:"
            echo "    export SDL_GAMECONTROLLERCONFIG=\"$mapping\""
            return
        fi
    fi

    # Manual mapping template
    warn "controllermap tool not found. Generating a template..."
    echo ""

    local mapping="${guid},${name},platform:Linux,"
    mapping+="a:b0,b:b1,x:b2,y:b3,"
    mapping+="back:b6,start:b7,guide:b8,"
    mapping+="leftshoulder:b4,rightshoulder:b5,"
    mapping+="leftstick:b9,rightstick:b10,"
    mapping+="dpup:h0.1,dpdown:h0.4,dpleft:h0.8,dpright:h0.2,"
    mapping+="leftx:a0,lefty:a1,rightx:a3,righty:a4,"
    mapping+="lefttrigger:a2,righttrigger:a5"

    info "Template mapping (edit button numbers to match your controller):"
    echo ""
    echo "  $mapping"
    echo ""

    echo "SDL_GAMECONTROLLERCONFIG=\"$mapping\"" > "${MAPPING_DIR}/sdl_gamecontroller.env"
    info "Saved to: ${MAPPING_DIR}/sdl_gamecontroller.env"
    echo ""
    info "To activate:"
    echo "    export SDL_GAMECONTROLLERCONFIG=\"$mapping\""
    echo ""
    echo "  Or source it in your profile:"
    echo "    echo 'source ${MAPPING_DIR}/sdl_gamecontroller.env' >> ~/.bashrc"
}

_map_xboxdrv() {
    local dev="$1"
    local name="$2"

    if ! command -v xboxdrv &>/dev/null; then
        err "xboxdrv not installed."
        echo "  Install: sudo apt install xboxdrv"
        exit 1
    fi

    head_ "xboxdrv Remapping"
    info "This will create an Xbox 360 emulation layer for: $name"
    echo ""
    warn "xboxdrv requires sudo and takes exclusive access to the device."
    echo ""

    local evdev_path="$dev"
    if [[ "$dev" == /dev/input/js* ]]; then
        local js_num="${dev#/dev/input/js}"
        local phys_path
        phys_path=$(readlink -f "/sys/class/input/js${js_num}/device" 2>/dev/null || echo "")
        for ev_dir in "$phys_path"/event*; do
            [[ -d "$ev_dir" ]] || continue
            evdev_path="/dev/input/$(basename "$ev_dir")"
            break
        done
    fi

    local config_file="${MAPPING_DIR}/xboxdrv_$(basename "$dev").conf"
    cat > "$config_file" << 'XBOXCONF'
# 24HG xboxdrv config — edit button mappings as needed
# See: man xboxdrv
[xboxdrv]
evdev-grab = true
mimic-xpad = true
silent = true

[evdev-absmap]
ABS_X = x1
ABS_Y = y1
ABS_RX = x2
ABS_RY = y2
ABS_Z = lt
ABS_RZ = rt

[evdev-keymap]
BTN_SOUTH = a
BTN_EAST = b
BTN_WEST = x
BTN_NORTH = y
BTN_TL = lb
BTN_TR = rb
BTN_SELECT = back
BTN_START = start
BTN_MODE = guide
BTN_THUMBL = tl
BTN_THUMBR = tr
XBOXCONF

    info "Config written: $config_file"
    echo ""
    echo "  To run:"
    echo "    sudo xboxdrv --evdev \"$evdev_path\" --config \"$config_file\""
    echo ""
    echo "  To run in daemon mode:"
    echo "    sudo xboxdrv --evdev \"$evdev_path\" --config \"$config_file\" --daemon"
}

# ──────────────────────────────────────────────
# Command: fix
# ──────────────────────────────────────────────
cmd_fix() {
    head_ "Controller Troubleshooting"

    local issues=0

    # 1. Check /dev/input permissions
    info "Checking /dev/input permissions..."
    local bad_perms=0
    for dev in /dev/input/js* /dev/input/event*; do
        [[ -e "$dev" ]] || continue
        if [[ ! -r "$dev" ]]; then
            warn "  No read access: $dev"
            bad_perms=1
        fi
    done
    if [[ $bad_perms -eq 1 ]]; then
        issues=$((issues + 1))
        info "  Fixing permissions..."
        sudo chmod a+r /dev/input/js* 2>/dev/null || true
        sudo chmod a+r /dev/input/event* 2>/dev/null || true
        # Ensure user is in input group
        if ! groups | grep -q '\binput\b'; then
            warn "  User not in 'input' group. Adding..."
            sudo usermod -aG input "$USER" 2>/dev/null || true
            warn "  Log out and back in for group change to take effect."
        fi
        info "  Permissions fixed."
    else
        info "  Permissions OK."
    fi
    echo ""

    # 2. Reload Xbox controller modules
    info "Reloading Xbox controller modules..."
    for mod in xpad xone xpadneo; do
        if lsmod | grep -q "^${mod} "; then
            info "  Reloading $mod..."
            sudo modprobe -r "$mod" 2>/dev/null || true
            sleep 0.5
            sudo modprobe "$mod" 2>/dev/null || true
        elif modinfo "$mod" &>/dev/null; then
            info "  Loading $mod (was not loaded)..."
            sudo modprobe "$mod" 2>/dev/null || true
        fi
    done
    echo ""

    # 3. Reload PlayStation and Nintendo modules
    info "Reloading gamepad HID modules..."
    for mod in hid-playstation hid-nintendo hid-sony; do
        if modinfo "$mod" &>/dev/null; then
            if lsmod | grep -q "^${mod//-/_} "; then
                info "  Reloading $mod..."
                sudo modprobe -r "${mod}" 2>/dev/null || true
                sleep 0.3
                sudo modprobe "${mod}" 2>/dev/null || true
            fi
        fi
    done
    echo ""

    # 4. Restart Bluetooth
    info "Checking Bluetooth..."
    if systemctl is-active --quiet bluetooth.service 2>/dev/null; then
        info "  Restarting bluetooth.service..."
        sudo systemctl restart bluetooth.service 2>/dev/null || true
        sleep 1
        info "  Bluetooth restarted."
    elif command -v bluetoothctl &>/dev/null; then
        warn "  bluetooth.service not running. Starting..."
        sudo systemctl start bluetooth.service 2>/dev/null || true
    else
        warn "  Bluetooth not available on this system."
    fi
    echo ""

    # 5. Check for steam-devices udev rules
    info "Checking steam-devices udev rules..."
    if [[ -f /usr/lib/udev/rules.d/60-steam-input.rules ]] || \
       [[ -f /lib/udev/rules.d/60-steam-input.rules ]] || \
       [[ -f /etc/udev/rules.d/60-steam-input.rules ]] || \
       dpkg -l steam-devices 2>/dev/null | grep -q '^ii'; then
        info "  steam-devices rules found."
    else
        issues=$((issues + 1))
        warn "  steam-devices udev rules NOT found."
        echo "    Many controllers need these rules for proper permissions."
        echo "    Install: sudo apt install steam-devices"
        echo "    Or download from: https://github.com/ValveSoftware/steam-devices"
    fi
    echo ""

    # 6. Check uinput module (needed for xboxdrv and other emulation)
    info "Checking uinput..."
    if [[ -e /dev/uinput ]]; then
        info "  /dev/uinput present."
    else
        issues=$((issues + 1))
        warn "  /dev/uinput missing. Loading module..."
        sudo modprobe uinput 2>/dev/null || true
        if [[ -e /dev/uinput ]]; then
            info "  uinput loaded successfully."
        else
            err "  Failed to load uinput module."
        fi
    fi
    echo ""

    # 7. Trigger udev re-scan
    info "Triggering udev re-scan..."
    sudo udevadm control --reload-rules 2>/dev/null || true
    sudo udevadm trigger --subsystem-match=input 2>/dev/null || true
    info "  Done."
    echo ""

    # Summary
    if [[ $issues -eq 0 ]]; then
        info "No issues found. All checks passed."
    else
        warn "$issues issue(s) addressed. Re-plug your controller or reboot if problems persist."
    fi

    echo ""
    info "Re-check: 24hg-controller list"
}

# ──────────────────────────────────────────────
# Command: status
# ──────────────────────────────────────────────
cmd_status() {
    head_ "Controller Status"

    # Active profile
    local active_profile
    active_profile=$(cat "$ACTIVE_PROFILE_FILE" 2>/dev/null || echo "default")
    echo -e "  Active profile: ${BOLD}${active_profile}${RESET}"
    echo ""

    # Connected controllers
    local count=0
    echo -e "  ${BOLD}Connected controllers:${RESET}"
    echo ""

    for js in /dev/input/js*; do
        [[ -e "$js" ]] || continue
        count=$((count + 1))

        local name conn_type ctrl_type vendor_product
        name=$(get_device_name "$js")
        conn_type=$(get_connection_type "$js")
        vendor_product=$(get_vendor_product "$js")
        ctrl_type=$(get_controller_type "$name" "$vendor_product")

        local status_icon="${GREEN}OK${RESET}"

        # Check if device is readable
        if [[ ! -r "$js" ]]; then
            status_icon="${RED}NO ACCESS${RESET}"
        fi

        echo -e "    ${BOLD}$name${RESET}"
        echo -e "      ${js}  |  ${ctrl_type}  |  ${conn_type}  |  ${status_icon}"
    done

    if [[ $count -eq 0 ]]; then
        echo -e "    ${DIM}(none)${RESET}"
    fi
    echo ""

    # Diagnostics
    echo -e "  ${BOLD}Diagnostics:${RESET}"
    echo ""

    # Check key modules
    local module_status=""
    for mod in xpad xone hid_playstation hid_nintendo uinput; do
        local mod_file="${mod//-/_}"
        if lsmod | grep -q "^${mod_file} "; then
            module_status+="    ${mod}: ${GREEN}loaded${RESET}\n"
        elif modinfo "${mod//_/-}" &>/dev/null 2>&1; then
            module_status+="    ${mod}: ${DIM}available (not loaded)${RESET}\n"
        fi
    done

    if [[ -n "$module_status" ]]; then
        echo -e "  Kernel modules:"
        echo -e "$module_status"
    fi

    # Bluetooth
    if systemctl is-active --quiet bluetooth.service 2>/dev/null; then
        echo -e "  Bluetooth: ${GREEN}active${RESET}"
    else
        echo -e "  Bluetooth: ${YELLOW}inactive${RESET}"
    fi

    # Steam devices
    if [[ -f /usr/lib/udev/rules.d/60-steam-input.rules ]] || \
       [[ -f /lib/udev/rules.d/60-steam-input.rules ]] || \
       dpkg -l steam-devices 2>/dev/null | grep -q '^ii'; then
        echo -e "  Steam udev rules: ${GREEN}installed${RESET}"
    else
        echo -e "  Steam udev rules: ${YELLOW}not found${RESET}"
    fi

    # Custom SDL mapping
    if [[ -f "${MAPPING_DIR}/sdl_gamecontroller.env" ]]; then
        echo -e "  Custom SDL mapping: ${GREEN}configured${RESET}"
    fi

    # Saved calibrations
    local cal_count
    cal_count=$(find "$CALIBRATION_DIR" -name '*.cal' 2>/dev/null | wc -l)
    if [[ $cal_count -gt 0 ]]; then
        echo -e "  Saved calibrations: ${cal_count}"
    fi

    echo ""
}

# ──────────────────────────────────────────────
# Help
# ──────────────────────────────────────────────
cmd_help() {
    echo ""
    echo -e "${BOLD}24hg-controller${RESET} — 24HG Gamepad Manager"
    echo ""
    echo "Usage: 24hg-controller <command> [args]"
    echo ""
    echo "Commands:"
    echo "  list                  Detect and list all connected controllers"
    echo "  test [device]         Live input test (button presses, axis values)"
    echo "  calibrate [device]    Deadzone calibration with persistent udev rules"
    echo "  profile [name]        Switch controller profile (default/fps/racing/retro)"
    echo "  map [device]          Show and remap buttons/axes (SDL or xboxdrv)"
    echo "  fix                   Auto-fix common issues (drivers, permissions, BT)"
    echo "  status                Overview of controllers, profile, and system state"
    echo "  help                  Show this help"
    echo ""
    echo "Device can be specified as:"
    echo "  /dev/input/js0        Full path"
    echo "  js0                   Shorthand"
    echo "  event5                Event device shorthand"
    echo "  0                     Joystick number"
    echo ""
    echo "Supported controllers:"
    echo "  Xbox (xpad/xone/xpadneo), PlayStation (DualShock/DualSense),"
    echo "  Nintendo (Pro Controller/Joy-Con), 8BitDo, generic HID"
    echo ""
    echo "Profiles:"
    echo "  default   Standard deadzone, linear response"
    echo "  fps       High deadzone, fast response for shooters"
    echo "  racing    Wide axis range, low deadzone for precision steering"
    echo "  retro     D-pad priority, snappy digital-feel response"
    echo ""
    echo "Dependencies: joystick (jstest/jscal), evtest, udevadm"
    echo "Optional: xboxdrv, zenity (GUI), controllermap (SDL2)"
    echo ""
}

# ──────────────────────────────────────────────
# Main dispatch
# ──────────────────────────────────────────────
case "$ACTION" in
    list)       cmd_list ;;
    test)       cmd_test ;;
    calibrate)  cmd_calibrate ;;
    profile)    cmd_profile ;;
    map)        cmd_map ;;
    fix)        cmd_fix ;;
    status)     cmd_status ;;
    help|-h|--help)
                cmd_help ;;
    *)
        err "Unknown command: $ACTION"
        cmd_help
        exit 1
        ;;
esac
