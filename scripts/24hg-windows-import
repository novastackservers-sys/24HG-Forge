#!/usr/bin/env bash
# 24HG Windows Game Library Import
# Migrate games and save files from a Windows installation to 24HG.
# Detects Steam, Epic, GOG installations on NTFS partitions, copies game files,
# configures Proton prefixes, and maps save file locations.
#
# Usage: 24hg-windows-import [command] [args]
# Commands: scan, list, import, import-all, saves, saves-all, status, verify

set -euo pipefail

# ── Global Configuration ─────────────────────────────────────────────────────

readonly VERSION="1.0.0"
readonly SCRIPT_NAME="24hg-windows-import"
readonly MOUNT_BASE="/tmp/24hg-win-import"
readonly STATE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/24hg/windows-import"
readonly STEAM_COMMON="$HOME/.local/share/Steam/steamapps/common"
readonly STEAM_COMPAT="$HOME/.local/share/Steam/steamapps/compatdata"
readonly STEAM_APPS="$HOME/.local/share/Steam/steamapps"
readonly GAMES_DIR="$HOME/Games"
readonly IMPORT_LOG="$STATE_DIR/import.log"
readonly DETECTED_CACHE="$STATE_DIR/detected-games.json"

# ── Colors & Formatting ──────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

if [[ ! -t 1 ]]; then
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA='' BOLD='' DIM='' NC=''
fi

# ── Logging Helpers ───────────────────────────────────────────────────────────

info()    { echo -e "${BLUE}[INFO]${NC}    $*"; }
ok()      { echo -e "${GREEN}[OK]${NC}      $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}    $*"; }
err()     { echo -e "${RED}[ERROR]${NC}   $*"; }
header()  { echo -e "\n${BOLD}${CYAN}── $* ──${NC}"; }
detail()  { echo -e "  ${DIM}$*${NC}"; }
bullet()  { echo -e "  ${MAGENTA}*${NC} $*"; }

log_action() {
    mkdir -p "$STATE_DIR"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$IMPORT_LOG"
}

die() { err "$*"; exit 1; }

# ── Dependency Checks ────────────────────────────────────────────────────────

check_deps() {
    local missing=()
    for cmd in ntfs-3g lsblk blkid rsync jq; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        err "Missing required tools: ${missing[*]}"
        info "Install with: sudo dnf install ntfs-3g util-linux rsync jq"
        exit 1
    fi
}

# ── Progress Bar ──────────────────────────────────────────────────────────────

progress_bar() {
    local current=$1 total=$2 label="${3:-Copying}"
    local pct=0 filled=0 empty=40 bar=""
    if [[ $total -gt 0 ]]; then
        pct=$(( current * 100 / total ))
        filled=$(( current * 40 / total ))
        empty=$(( 40 - filled ))
    fi
    bar=$(printf '%0.s█' $(seq 1 $filled 2>/dev/null) 2>/dev/null || true)
    bar+=$(printf '%0.s░' $(seq 1 $empty 2>/dev/null) 2>/dev/null || true)
    printf "\r  ${CYAN}%s${NC} [${GREEN}%-40s${NC}] %3d%% " "$label" "$bar" "$pct"
}

progress_done() {
    echo ""
}

# ── Human-readable Sizes ─────────────────────────────────────────────────────

human_size() {
    local bytes=$1
    if [[ $bytes -ge 1073741824 ]]; then
        printf "%.1f GB" "$(echo "scale=1; $bytes / 1073741824" | bc 2>/dev/null || echo "?")"
    elif [[ $bytes -ge 1048576 ]]; then
        printf "%.1f MB" "$(echo "scale=1; $bytes / 1048576" | bc 2>/dev/null || echo "?")"
    elif [[ $bytes -ge 1024 ]]; then
        printf "%.0f KB" "$(echo "scale=0; $bytes / 1024" | bc 2>/dev/null || echo "?")"
    else
        printf "%d B" "$bytes"
    fi
}

# ── Partition Detection ──────────────────────────────────────────────────────

find_ntfs_partitions() {
    local parts=()
    while IFS= read -r line; do
        local dev size
        dev=$(echo "$line" | awk '{print $1}')
        size=$(echo "$line" | awk '{print $4}')
        [[ -n "$dev" ]] && parts+=("$dev|$size")
    done < <(lsblk -rno NAME,FSTYPE,TYPE,SIZE 2>/dev/null | awk '$2 == "ntfs" && $3 == "part" {print "/dev/"$1, $2, $3, $4}')
    echo "${parts[@]}"
}

mount_partition() {
    local dev="$1"
    local label
    label=$(echo "$dev" | sed 's|/dev/||; s|/|_|g')
    local mount_point="$MOUNT_BASE/$label"

    if mountpoint -q "$mount_point" 2>/dev/null; then
        echo "$mount_point"
        return 0
    fi

    mkdir -p "$mount_point"
    if sudo ntfs-3g -o ro,noexec,nosuid,nodev,noatime "$dev" "$mount_point" 2>/dev/null; then
        echo "$mount_point"
        return 0
    else
        err "Failed to mount $dev"
        return 1
    fi
}

unmount_partition() {
    local mount_point="$1"
    if mountpoint -q "$mount_point" 2>/dev/null; then
        sudo umount "$mount_point" 2>/dev/null || sudo umount -l "$mount_point" 2>/dev/null
    fi
}

unmount_all() {
    if [[ -d "$MOUNT_BASE" ]]; then
        for mp in "$MOUNT_BASE"/*/; do
            [[ -d "$mp" ]] && unmount_partition "$mp"
        done
    fi
}

is_windows_partition() {
    local mp="$1"
    [[ -d "$mp/Windows/System32" ]] && [[ -d "$mp/Users" ]]
}

detect_windows_version() {
    local mp="$1"
    local kernel="$mp/Windows/System32/ntoskrnl.exe"
    if [[ -f "$kernel" ]]; then
        # Try to extract version info
        local size
        size=$(stat -c%s "$kernel" 2>/dev/null || echo "0")
        if [[ $size -gt 8000000 ]]; then
            echo "Windows 10/11"
        elif [[ $size -gt 5000000 ]]; then
            echo "Windows 8/8.1"
        else
            echo "Windows 7 or earlier"
        fi
    else
        echo "Unknown"
    fi

    # Better detection via registry if hivexget is available
    if command -v hivexget &>/dev/null; then
        local sw_hive="$mp/Windows/System32/config/SOFTWARE"
        if [[ -f "$sw_hive" ]]; then
            local product
            product=$(hivexget "$sw_hive" 'Microsoft\Windows NT\CurrentVersion' ProductName 2>/dev/null || true)
            [[ -n "$product" ]] && echo "$product" && return 0
        fi
    fi
}

get_windows_users() {
    local mp="$1"
    local users=()
    for udir in "$mp"/Users/*/; do
        local uname
        uname=$(basename "$udir")
        [[ "$uname" == "Public" || "$uname" == "Default" || "$uname" == "Default User" || "$uname" == "All Users" ]] && continue
        [[ -d "$udir/AppData" ]] && users+=("$uname")
    done
    echo "${users[@]}"
}

# ── Steam Game Detection ─────────────────────────────────────────────────────

find_steam_libraries() {
    local mp="$1"
    local libs=()
    # Default Steam location
    local default_steam="$mp/Program Files (x86)/Steam"
    [[ -d "$default_steam/steamapps/common" ]] && libs+=("$default_steam/steamapps")
    # Check libraryfolders.vdf for additional library paths
    local vdf="$default_steam/steamapps/libraryfolders.vdf"
    if [[ -f "$vdf" ]]; then
        while IFS= read -r path; do
            path=$(echo "$path" | tr -d '"' | sed 's|\\\\|/|g' | xargs)
            # Convert Windows drive letter to mount point subdirectory
            if [[ "$path" =~ ^[A-Za-z]: ]]; then
                local drive="${path:0:1}"
                local rest="${path:2}"
                # Try to find this drive's mount
                for check_mp in "$MOUNT_BASE"/*/; do
                    if [[ -d "${check_mp}${rest}/common" ]]; then
                        libs+=("${check_mp}${rest}")
                    fi
                done
            fi
        done < <(grep -oP '"path"\s+"[^"]+"' "$vdf" 2>/dev/null | grep -oP '"[^"]+"\s*$' | tr -d '"')
    fi
    echo "${libs[@]}"
}

detect_steam_games() {
    local mp="$1"
    local count=0
    local libs
    libs=$(find_steam_libraries "$mp")

    for lib in $libs; do
        local common="$lib/common"
        [[ -d "$common" ]] || continue
        for game_dir in "$common"/*/; do
            [[ -d "$game_dir" ]] || continue
            local game_name
            game_name=$(basename "$game_dir")
            [[ "$game_name" == "Steamworks Shared" ]] && continue
            local size
            size=$(du -sb "$game_dir" 2>/dev/null | awk '{print $1}')
            size=${size:-0}
            # Try to find appid from manifest
            local appid=""
            for acf in "$lib"/appmanifest_*.acf; do
                if [[ -f "$acf" ]] && grep -q "\"installdir\".*\"$game_name\"" "$acf" 2>/dev/null; then
                    appid=$(grep -oP '"appid"\s+"\K[0-9]+' "$acf" 2>/dev/null || true)
                    break
                fi
            done
            echo "steam|$game_name|$appid|$size|$game_dir"
            count=$((count + 1))
        done
    done
    return 0
}

# ── Epic Games Detection ─────────────────────────────────────────────────────

detect_epic_games() {
    local mp="$1"
    local epic_dir="$mp/Program Files/Epic Games"
    [[ -d "$epic_dir" ]] || return 0

    for game_dir in "$epic_dir"/*/; do
        [[ -d "$game_dir" ]] || continue
        local game_name
        game_name=$(basename "$game_dir")
        [[ "$game_name" == "Launcher" || "$game_name" == "DirectXRedist" ]] && continue
        local size
        size=$(du -sb "$game_dir" 2>/dev/null | awk '{print $1}')
        size=${size:-0}
        echo "epic|$game_name||$size|$game_dir"
    done

    # Also check Epic manifests for non-default install paths
    local manifest_dir="$mp/ProgramData/Epic/EpicGamesLauncher/Data/Manifests"
    if [[ -d "$manifest_dir" ]]; then
        for manifest in "$manifest_dir"/*.item; do
            [[ -f "$manifest" ]] || continue
            local name path
            name=$(jq -r '.DisplayName // empty' "$manifest" 2>/dev/null || true)
            path=$(jq -r '.InstallLocation // empty' "$manifest" 2>/dev/null || true)
            [[ -z "$name" || -z "$path" ]] && continue
            # Convert Windows path
            path=$(echo "$path" | sed 's|\\|/|g')
            if [[ "$path" =~ ^[A-Za-z]: ]]; then
                local rest="${path:2}"
                for check_mp in "$MOUNT_BASE"/*/; do
                    if [[ -d "${check_mp}${rest}" ]]; then
                        local size
                        size=$(du -sb "${check_mp}${rest}" 2>/dev/null | awk '{print $1}')
                        echo "epic|$name||${size:-0}|${check_mp}${rest}"
                    fi
                done
            fi
        done
    fi
}

# ── GOG Games Detection ──────────────────────────────────────────────────────

detect_gog_games() {
    local mp="$1"
    local gog_dir="$mp/GOG Games"
    [[ -d "$gog_dir" ]] || return 0

    for game_dir in "$gog_dir"/*/; do
        [[ -d "$game_dir" ]] || continue
        local game_name
        game_name=$(basename "$game_dir")
        local size
        size=$(du -sb "$game_dir" 2>/dev/null | awk '{print $1}')
        size=${size:-0}
        echo "gog|$game_name||$size|$game_dir"
    done
}

# ── Proton Compatdata Detection ──────────────────────────────────────────────

detect_proton_prefixes() {
    local mp="$1"
    local compat_dir="$mp/Program Files (x86)/Steam/steamapps/compatdata"
    [[ -d "$compat_dir" ]] || return 0

    for prefix_dir in "$compat_dir"/*/; do
        [[ -d "$prefix_dir/pfx" ]] || continue
        local appid
        appid=$(basename "$prefix_dir")
        [[ "$appid" =~ ^[0-9]+$ ]] || continue
        echo "proton_prefix|$appid|$appid|0|$prefix_dir"
    done
}

# ── Registry-based Detection ─────────────────────────────────────────────────

detect_registry_games() {
    local mp="$1"
    command -v hivexget &>/dev/null || return 0

    local users
    users=$(get_windows_users "$mp")
    for user in $users; do
        local hive="$mp/Users/$user/NTUSER.DAT"
        [[ -f "$hive" ]] || continue

        # Check Uninstall keys for custom install paths
        for key in \
            'SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall' \
            'SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'; do
            local subkeys
            subkeys=$(hivexget "$hive" "$key" 2>/dev/null | head -100 || true)
            for subkey in $subkeys; do
                local loc
                loc=$(hivexget "$hive" "$key\\$subkey" InstallLocation 2>/dev/null || true)
                [[ -z "$loc" ]] && continue
                loc=$(echo "$loc" | sed 's|\\|/|g')
                if [[ "$loc" =~ ^[A-Za-z]: ]]; then
                    local rest="${loc:2}"
                    for check_mp in "$MOUNT_BASE"/*/; do
                        if [[ -d "${check_mp}${rest}" ]]; then
                            local name
                            name=$(hivexget "$hive" "$key\\$subkey" DisplayName 2>/dev/null || echo "$subkey")
                            local size
                            size=$(du -sb "${check_mp}${rest}" 2>/dev/null | awk '{print $1}')
                            echo "registry|$name||${size:-0}|${check_mp}${rest}"
                        fi
                    done
                fi
            done
        done
    done
}

# ── Comprehensive Game Detection ─────────────────────────────────────────────

detect_all_games() {
    local mp="$1"
    local all_games=()

    info "Scanning Steam libraries..."
    while IFS= read -r line; do
        [[ -n "$line" ]] && all_games+=("$line")
    done < <(detect_steam_games "$mp")

    info "Scanning Epic Games..."
    while IFS= read -r line; do
        [[ -n "$line" ]] && all_games+=("$line")
    done < <(detect_epic_games "$mp")

    info "Scanning GOG Games..."
    while IFS= read -r line; do
        [[ -n "$line" ]] && all_games+=("$line")
    done < <(detect_gog_games "$mp")

    info "Scanning Proton prefixes..."
    while IFS= read -r line; do
        [[ -n "$line" ]] && all_games+=("$line")
    done < <(detect_proton_prefixes "$mp")

    info "Scanning registry for custom installs..."
    while IFS= read -r line; do
        [[ -n "$line" ]] && all_games+=("$line")
    done < <(detect_registry_games "$mp")

    # Deduplicate by game path
    local seen=()
    for entry in "${all_games[@]}"; do
        local path
        path=$(echo "$entry" | awk -F'|' '{print $5}')
        local dupe=false
        for s in "${seen[@]+"${seen[@]}"}"; do
            [[ "$s" == "$path" ]] && dupe=true && break
        done
        $dupe || { seen+=("$path"); echo "$entry"; }
    done
}

