# ── Redistributable Detection ────────────────────────────────────────────────

detect_redists() {
    local game_dir="$1"
    local redists=()

    # Check for common redistributable installers in game directory
    if find "$game_dir" -maxdepth 3 -iname "dxsetup.exe" 2>/dev/null | grep -q .; then
        redists+=("DirectX")
    fi
    if find "$game_dir" -maxdepth 3 -iname "vcredist*.exe" 2>/dev/null | grep -q .; then
        redists+=("Visual C++ Runtime")
    fi
    if find "$game_dir" -maxdepth 3 -iname "dotnet*.exe" -o -iname "NDP*.exe" 2>/dev/null | grep -q .; then
        redists+=(".NET Framework")
    fi
    if find "$game_dir" -maxdepth 3 -iname "xnafx*.msi" 2>/dev/null | grep -q .; then
        redists+=("XNA Framework")
    fi
    if find "$game_dir" -maxdepth 3 -iname "physx*.exe" -o -iname "PhysX*.msi" 2>/dev/null | grep -q .; then
        redists+=("PhysX")
    fi
    if find "$game_dir" -maxdepth 3 -iname "oalinst.exe" 2>/dev/null | grep -q .; then
        redists+=("OpenAL")
    fi

    echo "${redists[@]}"
}

recommend_proton() {
    local game_name="$1"
    # Default recommendation — GE-Proton is usually the safest bet
    local rec="GE-Proton (latest)"

    # Some games work better with specific versions
    case "$game_name" in
        *"Elden Ring"*|*"Dark Souls"*) rec="GE-Proton (latest)" ;;
        *"Cyberpunk"*) rec="Proton Experimental" ;;
        *"Halo"*|*"Forza"*|*"Sea of Thieves"*) rec="Proton Experimental (may require EAC/BattlEye)" ;;
        *"Destiny"*|*"PUBG"*|*"Valorant"*|*"Fortnite"*) rec="UNSUPPORTED (kernel-level anti-cheat)" ;;
    esac
    echo "$rec"
}

# ── Import Functions ─────────────────────────────────────────────────────────

copy_with_progress() {
    local src="$1" dst="$2"
    local total_size
    total_size=$(du -sb "$src" 2>/dev/null | awk '{print $1}')
    total_size=${total_size:-0}

    info "Copying $(human_size "$total_size") ..."

    mkdir -p "$dst"

    # Use rsync with progress
    rsync -a --info=progress2 --no-inc-recursive "$src/" "$dst/" 2>&1 | \
        while IFS= read -r line; do
            if [[ "$line" =~ ([0-9]+)% ]]; then
                local pct="${BASH_REMATCH[1]}"
                progress_bar "$pct" 100 "Copying"
            fi
        done
    progress_done
}

verify_copy() {
    local src="$1" dst="$2"
    info "Verifying file integrity..."

    local src_count dst_count
    src_count=$(find "$src" -type f 2>/dev/null | wc -l)
    dst_count=$(find "$dst" -type f 2>/dev/null | wc -l)

    if [[ "$src_count" -ne "$dst_count" ]]; then
        warn "File count mismatch: source=$src_count, destination=$dst_count"
        return 1
    fi

    # Spot-check checksums on a sample of files
    local checked=0 failed=0
    while IFS= read -r src_file; do
        local rel_path="${src_file#$src/}"
        local dst_file="$dst/$rel_path"
        [[ -f "$dst_file" ]] || { failed=$((failed + 1)); continue; }

        local src_sum dst_sum
        src_sum=$(md5sum "$src_file" 2>/dev/null | awk '{print $1}')
        dst_sum=$(md5sum "$dst_file" 2>/dev/null | awk '{print $1}')
        [[ "$src_sum" != "$dst_sum" ]] && failed=$((failed + 1))

        checked=$((checked + 1))
        [[ $checked -ge 20 ]] && break
    done < <(find "$src" -type f -size +1k 2>/dev/null | shuf | head -20)

    if [[ $failed -gt 0 ]]; then
        warn "$failed of $checked sampled files had mismatches"
        return 1
    fi
    ok "Verified $checked files — all checksums match"
    return 0
}

check_disk_space() {
    local required=$1 dest_dir="$2"
    mkdir -p "$dest_dir"
    local available
    available=$(df -B1 "$dest_dir" 2>/dev/null | awk 'NR==2{print $4}')
    available=${available:-0}

    if [[ $required -gt $available ]]; then
        err "Insufficient disk space"
        detail "Required: $(human_size "$required")"
        detail "Available: $(human_size "$available")"
        return 1
    fi
    ok "Disk space check passed: need $(human_size "$required"), have $(human_size "$available")"
    return 0
}

setup_proton_prefix() {
    local game_name="$1" appid="$2"
    local prefix_dir="$STEAM_COMPAT/${appid:-0}"

    if [[ -z "$appid" || "$appid" == "0" ]]; then
        info "No Steam App ID — skipping Proton prefix setup"
        info "You can configure this manually in Steam or Lutris"
        return 0
    fi

    if [[ -d "$prefix_dir/pfx" ]]; then
        info "Proton prefix already exists for appid $appid"
        return 0
    fi

    info "Proton prefix will be created on first launch via Steam"
    detail "Expected location: $prefix_dir"
    return 0
}

create_steam_acf() {
    local game_name="$1" appid="$2" install_dir="$3"
    [[ -z "$appid" || "$appid" == "0" ]] && return 0

    local acf_path="$STEAM_APPS/appmanifest_${appid}.acf"
    if [[ -f "$acf_path" ]]; then
        info "Steam manifest already exists: $acf_path"
        return 0
    fi

    local size_kb
    size_kb=$(du -sk "$install_dir" 2>/dev/null | awk '{print $1}')
    size_kb=${size_kb:-0}

    cat > "$acf_path" <<ACF
"AppState"
{
	"appid"		"$appid"
	"Universe"		"1"
	"name"		"$game_name"
	"StateFlags"		"4"
	"installdir"		"$game_name"
	"SizeOnDisk"		"${size_kb}000"
	"buildid"		"0"
	"AutoUpdateBehavior"		"1"
}
ACF
    ok "Created Steam manifest: $acf_path"
    detail "Steam will verify and update the game on next launch"
}

create_lutris_config() {
    local game_name="$1" store="$2" install_dir="$3"
    local slug
    slug=$(echo "$game_name" | tr '[:upper:] ' '[:lower:]-' | sed 's/[^a-z0-9-]//g')
    local lutris_dir="$HOME/.config/lutris/games"
    mkdir -p "$lutris_dir"

    local config_file="$lutris_dir/${slug}.yml"
    if [[ -f "$config_file" ]]; then
        info "Lutris config already exists: $config_file"
        return 0
    fi

    # Find the main executable
    local exe=""
    exe=$(find "$install_dir" -maxdepth 2 -iname "*.exe" -not -iname "unins*" -not -iname "crash*" \
          -not -iname "redis*" -not -iname "vc_*" -not -iname "dxsetup*" 2>/dev/null | head -1)

    cat > "$config_file" <<YML
game:
  exe: ${exe:-$install_dir}
  prefix: $HOME/.wine/prefixes/$slug
  working_dir: $install_dir
runner: wine
name: "$game_name"
slug: $slug
year: 0
system:
  disable_runtime: false
wine:
  runner: lutris-GE-Proton
YML
    ok "Created Lutris config: $config_file"
}

import_game() {
    local store="$1" game_name="$2" appid="$3" size="$4" source_dir="$5"

    header "Importing: $game_name"
    detail "Store: $store | App ID: ${appid:-N/A} | Size: $(human_size "$size")"
    echo ""

    # Determine destination
    local dest_dir
    case "$store" in
        steam)
            dest_dir="$STEAM_COMMON/$game_name"
            ;;
        *)
            dest_dir="$GAMES_DIR/$store/$game_name"
            ;;
    esac

    if [[ -d "$dest_dir" ]] && [[ "$(ls -A "$dest_dir" 2>/dev/null)" ]]; then
        warn "Destination already exists: $dest_dir"
        echo -n "  Overwrite? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy] ]] || { info "Skipped"; return 0; }
    fi

    # Check disk space (require 10% extra headroom)
    local required=$(( size + size / 10 ))
    check_disk_space "$required" "$(dirname "$dest_dir")" || return 1

    # Detect redistributables
    local redists
    redists=$(detect_redists "$source_dir")
    if [[ -n "$redists" ]]; then
        info "Detected redistributables: $redists"
        detail "These will be handled by Proton/Wine automatically"
    fi

    # Recommend Proton version
    local proton_rec
    proton_rec=$(recommend_proton "$game_name")
    info "Recommended Proton: $proton_rec"

    # Copy files
    copy_with_progress "$source_dir" "$dest_dir"

    # Verify
    verify_copy "$source_dir" "$dest_dir"
    local verify_status=$?

    # Set up store integration
    case "$store" in
        steam)
            create_steam_acf "$game_name" "$appid" "$dest_dir"
            setup_proton_prefix "$game_name" "$appid"
            ;;
        epic|gog|registry)
            create_lutris_config "$game_name" "$store" "$dest_dir"
            ;;
    esac

    # Run compatibility check if 24hg-game-compat exists
    if command -v 24hg-compat &>/dev/null && [[ -n "$appid" ]]; then
        info "Running compatibility check..."
        24hg-compat check "$appid" 2>/dev/null || true
    fi

    # Record import
    mkdir -p "$STATE_DIR"
    local record
    record=$(jq -n \
        --arg name "$game_name" \
        --arg store "$store" \
        --arg appid "${appid:-}" \
        --arg size "$size" \
        --arg dest "$dest_dir" \
        --arg proton "$proton_rec" \
        --arg date "$(date -Iseconds)" \
        --argjson verified "$( [[ $verify_status -eq 0 ]] && echo true || echo false )" \
        '{name:$name, store:$store, appid:$appid, size:($size|tonumber), dest:$dest, proton:$proton, date:$date, verified:$verified}')

    local imports_file="$STATE_DIR/imported-games.json"
    if [[ -f "$imports_file" ]]; then
        local tmp
        tmp=$(jq --argjson new "$record" '. + [$new]' "$imports_file")
        echo "$tmp" > "$imports_file"
    else
        echo "[$record]" > "$imports_file"
    fi

    log_action "IMPORTED $store/$game_name -> $dest_dir ($(human_size "$size"))"
    echo ""
    ok "Successfully imported: ${BOLD}$game_name${NC}"
    detail "Location: $dest_dir"
    detail "Proton: $proton_rec"
    [[ $verify_status -eq 0 ]] && detail "Integrity: Verified" || detail "Integrity: ${YELLOW}Check recommended${NC}"
    echo ""
}

# ── Save File Functions ──────────────────────────────────────────────────────

find_game_saves() {
    local mp="$1" game_name="$2"
    local found=0

    local users
    users=$(get_windows_users "$mp")

    while IFS='|' read -r db_game win_path linux_path; do
        # Fuzzy match game name
        local db_lower="${db_game,,}"
        local search_lower="${game_name,,}"
        [[ "$db_lower" != *"$search_lower"* && "$search_lower" != *"$db_lower"* ]] && continue

        for user in $users; do
            local full_path="$mp/Users/$user/$win_path"
            if [[ -d "$full_path" ]]; then
                local save_size
                save_size=$(du -sb "$full_path" 2>/dev/null | awk '{print $1}')
                echo "$db_game|$user|$full_path|$linux_path|${save_size:-0}"
                found=$((found + 1))
            fi
        done
    done < <(get_save_db)

    # Also scan generic save locations if no database match
    if [[ $found -eq 0 ]]; then
        for user in $users; do
            for base_dir in \
                "$mp/Users/$user/Documents/My Games" \
                "$mp/Users/$user/Saved Games" \
                "$mp/Users/$user/AppData/Local" \
                "$mp/Users/$user/AppData/Roaming" \
                "$mp/Users/$user/AppData/LocalLow"; do
                [[ -d "$base_dir" ]] || continue
                for save_dir in "$base_dir"/*/; do
                    [[ -d "$save_dir" ]] || continue
                    local dir_name
                    dir_name=$(basename "$save_dir")
                    local dir_lower="${dir_name,,}"
                    local search_lower="${game_name,,}"
                    [[ "$dir_lower" == *"$search_lower"* || "$search_lower" == *"$dir_lower"* ]] || continue
                    local rel_path="${save_dir#$mp/Users/$user/}"
                    local save_size
                    save_size=$(du -sb "$save_dir" 2>/dev/null | awk '{print $1}')
                    echo "$dir_name|$user|$save_dir|pfx/drive_c/users/steamuser/$rel_path|${save_size:-0}"
                done
            done
        done
    fi
}

find_all_saves() {
    local mp="$1"
    local users
    users=$(get_windows_users "$mp")

    while IFS='|' read -r db_game win_path linux_path; do
        for user in $users; do
            local full_path="$mp/Users/$user/$win_path"
            if [[ -d "$full_path" ]]; then
                local save_size
                save_size=$(du -sb "$full_path" 2>/dev/null | awk '{print $1}')
                echo "$db_game|$user|$full_path|$linux_path|${save_size:-0}"
            fi
        done
    done < <(get_save_db)
}

import_saves() {
    local game_name="$1" user="$2" source="$3" linux_rel="$4" size="$5"
    local appid=""

    header "Importing saves: $game_name"
    detail "User: $user | Size: $(human_size "$size")"

    # Try to find the appid from imported games
    local imports_file="$STATE_DIR/imported-games.json"
    if [[ -f "$imports_file" ]]; then
        appid=$(jq -r --arg name "$game_name" '.[] | select(.name == $name) | .appid // ""' "$imports_file" 2>/dev/null || true)
    fi

    # Determine destination
    local dest
    if [[ -n "$appid" && "$appid" != "null" && "$appid" != "" ]]; then
        dest="$STEAM_COMPAT/$appid/$linux_rel"
    else
        # Fall back to a generic Proton-style prefix
        local slug
        slug=$(echo "$game_name" | tr '[:upper:] ' '[:lower:]-' | sed 's/[^a-z0-9-]//g')
        dest="$HOME/.wine/prefixes/$slug/$linux_rel"
    fi

    mkdir -p "$(dirname "$dest")"
    copy_with_progress "$source" "$dest"
    verify_copy "$source" "$dest"

    log_action "SAVES IMPORTED $game_name ($user) -> $dest"
    ok "Saves imported for $game_name"
    detail "Location: $dest"
}

# ── Verify Function ──────────────────────────────────────────────────────────

verify_game() {
    local game_name="$1"
    local imports_file="$STATE_DIR/imported-games.json"

    if [[ ! -f "$imports_file" ]]; then
        die "No imported games found. Run 'import' first."
    fi

    local entry
    entry=$(jq -r --arg name "$game_name" '.[] | select(.name | ascii_downcase | contains($name | ascii_downcase))' "$imports_file" 2>/dev/null | head -1)

    if [[ -z "$entry" ]]; then
        die "Game '$game_name' not found in import history"
    fi

    local dest store appid
    dest=$(echo "$entry" | jq -r '.dest')
    store=$(echo "$entry" | jq -r '.store')
    appid=$(echo "$entry" | jq -r '.appid // ""')

    header "Verifying: $game_name"
    detail "Location: $dest"

    if [[ ! -d "$dest" ]]; then
        err "Game directory not found: $dest"
        return 1
    fi

    local file_count total_size
    file_count=$(find "$dest" -type f 2>/dev/null | wc -l)
    total_size=$(du -sb "$dest" 2>/dev/null | awk '{print $1}')

    info "Files: $file_count | Size: $(human_size "${total_size:-0}")"

    # Check for Steam manifest if applicable
    if [[ "$store" == "steam" && -n "$appid" && "$appid" != "null" ]]; then
        local acf="$STEAM_APPS/appmanifest_${appid}.acf"
        if [[ -f "$acf" ]]; then
            ok "Steam manifest present"
        else
            warn "Steam manifest missing — game may not appear in Steam library"
            detail "Run Steam to trigger a library scan, or reinstall via Steam"
        fi
    fi

    # Check for common game files
    local exe_count
    exe_count=$(find "$dest" -maxdepth 3 -iname "*.exe" 2>/dev/null | wc -l)
    [[ $exe_count -gt 0 ]] && ok "Found $exe_count executable(s)" || warn "No .exe files found"

    # Check for Proton prefix
    if [[ -n "$appid" && "$appid" != "null" && -d "$STEAM_COMPAT/$appid/pfx" ]]; then
        ok "Proton prefix exists"
    elif [[ -n "$appid" && "$appid" != "null" ]]; then
        info "Proton prefix will be created on first launch"
    fi

    # Check permissions
    if [[ -r "$dest" && -x "$dest" ]]; then
        ok "Directory permissions OK"
    else
        warn "Directory permissions may need adjustment"
        detail "Run: chmod -R u+rwX '$dest'"
    fi

    echo ""
    ok "Verification complete for ${BOLD}$game_name${NC}"
}

# ── Command: scan ─────────────────────────────────────────────────────────────

cmd_scan() {
    header "Scanning for Windows partitions"
    check_deps

    local parts
    parts=$(find_ntfs_partitions)
    if [[ -z "$parts" ]]; then
        warn "No NTFS partitions found"
        detail "Ensure your Windows drive is connected and visible in /dev/"
        return 1
    fi

    local win_found=0
    for part_info in $parts; do
        IFS='|' read -r dev size <<< "$part_info"
        info "Found NTFS partition: ${BOLD}$dev${NC} ($size)"

        local mp
        mp=$(mount_partition "$dev") || continue

        if is_windows_partition "$mp"; then
            local version
            version=$(detect_windows_version "$mp")
            ok "Windows installation detected: $version"
            local users
            users=$(get_windows_users "$mp")
            detail "Users: $users"

            # Count games
            local game_count=0
            while IFS= read -r _; do
                game_count=$((game_count + 1))
            done < <(detect_all_games "$mp")

            ok "Found ${BOLD}$game_count${NC} games on $dev"
            win_found=$((win_found + 1))

            # Cache results
            mkdir -p "$STATE_DIR"
            echo "$dev" >> "$STATE_DIR/detected-partitions.txt"
        else
            detail "Not a Windows system partition (may be a data drive)"
            # Still check for game folders
            local game_count=0
            while IFS= read -r _; do
                game_count=$((game_count + 1))
            done < <(detect_all_games "$mp")
            if [[ $game_count -gt 0 ]]; then
                ok "Found $game_count games on data partition $dev"
                win_found=$((win_found + 1))
            fi
        fi
    done

    echo ""
    if [[ $win_found -gt 0 ]]; then
        ok "Scan complete. Use ${BOLD}24hg-windows-import list <partition>${NC} to see games"
        info "All partitions mounted read-only — your Windows data is safe"
    else
        warn "No Windows game installations found"
    fi
}

# ── Command: list ─────────────────────────────────────────────────────────────

cmd_list() {
    local partition="${1:-}"
    check_deps

    if [[ -z "$partition" ]]; then
        # Try to find the first Windows partition
        local parts
        parts=$(find_ntfs_partitions)
        if [[ -z "$parts" ]]; then
            die "No NTFS partitions found. Specify a partition or run 'scan' first."
        fi
        for part_info in $parts; do
            IFS='|' read -r dev _ <<< "$part_info"
            partition="$dev"
            break
        done
    fi

    local mp
    mp=$(mount_partition "$partition") || die "Failed to mount $partition"

    header "Games on $partition"
    echo ""

    printf "  ${BOLD}%-6s  %-40s  %-10s  %s${NC}\n" "STORE" "GAME" "SIZE" "APP ID"
    printf "  %-6s  %-40s  %-10s  %s\n" "------" "$(printf '%0.s-' {1..40})" "----------" "------"

    local total_count=0 total_size=0
    while IFS='|' read -r store name appid size path; do
        [[ -z "$store" ]] && continue
        local store_colored
        case "$store" in
            steam)   store_colored="${CYAN}Steam${NC}" ;;
            epic)    store_colored="${YELLOW}Epic${NC}" ;;
            gog)     store_colored="${MAGENTA}GOG${NC}" ;;
            registry) store_colored="${DIM}Other${NC}" ;;
            proton_prefix) store_colored="${GREEN}Proton${NC}" ;;
            *)       store_colored="$store" ;;
        esac
        printf "  %-17s  %-40s  %-10s  %s\n" "$store_colored" "${name:0:40}" "$(human_size "$size")" "${appid:-—}"
        total_count=$((total_count + 1))
        total_size=$((total_size + size))
    done < <(detect_all_games "$mp")

    echo ""
    printf "  ${BOLD}Total: %d games, %s${NC}\n" "$total_count" "$(human_size "$total_size")"
    echo ""
    info "Import with: ${BOLD}24hg-windows-import import <game-name>${NC}"
    info "Import all:  ${BOLD}24hg-windows-import import-all${NC}"
}

# ── Command: import ───────────────────────────────────────────────────────────

cmd_import() {
    local game_query="${1:-}"
    local partition="${2:-}"
    check_deps

    [[ -z "$game_query" ]] && die "Usage: 24hg-windows-import import <game-name> [partition]"

    if [[ -z "$partition" ]]; then
        local parts
        parts=$(find_ntfs_partitions)
        for part_info in $parts; do
            IFS='|' read -r dev _ <<< "$part_info"
            partition="$dev"
            break
        done
    fi
    [[ -z "$partition" ]] && die "No NTFS partitions found"

    local mp
    mp=$(mount_partition "$partition") || die "Failed to mount $partition"

    # Find matching game
    local match_store="" match_name="" match_appid="" match_size="" match_path=""
    local matches=0
    local query_lower="${game_query,,}"

    while IFS='|' read -r store name appid size path; do
        [[ -z "$store" ]] && continue
        local name_lower="${name,,}"
        if [[ "$name_lower" == *"$query_lower"* ]]; then
            match_store="$store"
            match_name="$name"
            match_appid="$appid"
            match_size="$size"
            match_path="$path"
            matches=$((matches + 1))
        fi
    done < <(detect_all_games "$mp")

    if [[ $matches -eq 0 ]]; then
        die "No game matching '$game_query' found on $partition"
    elif [[ $matches -gt 1 ]]; then
        warn "Multiple games match '$game_query'. Please be more specific:"
        while IFS='|' read -r store name appid size path; do
            local name_lower="${name,,}"
            [[ "$name_lower" == *"$query_lower"* ]] && bullet "$name ($store)"
        done < <(detect_all_games "$mp")
        return 1
    fi

    import_game "$match_store" "$match_name" "$match_appid" "$match_size" "$match_path"
}

# ── Command: import-all ──────────────────────────────────────────────────────

cmd_import_all() {
    local partition="${1:-}"
    check_deps

    if [[ -z "$partition" ]]; then
        local parts
        parts=$(find_ntfs_partitions)
        for part_info in $parts; do
            IFS='|' read -r dev _ <<< "$part_info"
            partition="$dev"
            break
        done
    fi
    [[ -z "$partition" ]] && die "No NTFS partitions found"

    local mp
    mp=$(mount_partition "$partition") || die "Failed to mount $partition"

    local games=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && games+=("$line")
    done < <(detect_all_games "$mp")

    if [[ ${#games[@]} -eq 0 ]]; then
        die "No games found on $partition"
    fi

    header "Importing ${#games[@]} games from $partition"

    # Calculate total size
    local total_size=0
    for entry in "${games[@]}"; do
        local size
        size=$(echo "$entry" | awk -F'|' '{print $4}')
        total_size=$((total_size + size))
    done
    info "Total size: $(human_size "$total_size")"
    echo ""

    echo -n "  Proceed with importing all ${#games[@]} games? [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy] ]] || { info "Cancelled"; return 0; }

    local imported=0 failed=0
    for entry in "${games[@]}"; do
        IFS='|' read -r store name appid size path <<< "$entry"
        if import_game "$store" "$name" "$appid" "$size" "$path"; then
            imported=$((imported + 1))
        else
            failed=$((failed + 1))
            warn "Failed to import: $name"
        fi
    done

    echo ""
    header "Import Summary"
    ok "Successfully imported: $imported"
    [[ $failed -gt 0 ]] && warn "Failed: $failed"
}

# ── Command: saves ────────────────────────────────────────────────────────────

cmd_saves() {
    local game_query="${1:-}"
    check_deps

    [[ -z "$game_query" ]] && die "Usage: 24hg-windows-import saves <game-name>"

    local parts
    parts=$(find_ntfs_partitions)
    [[ -z "$parts" ]] && die "No NTFS partitions found"

    header "Searching for save files: $game_query"

    local found=0
    for part_info in $parts; do
        IFS='|' read -r dev _ <<< "$part_info"
        local mp
        mp=$(mount_partition "$dev") || continue
        is_windows_partition "$mp" || continue

        while IFS='|' read -r game_name user source linux_rel size; do
            [[ -z "$game_name" ]] && continue
            found=$((found + 1))

            bullet "${BOLD}$game_name${NC} — User: $user"
            detail "Source: $source"
            detail "Size: $(human_size "$size")"
            echo ""

            echo -n "  Import these saves? [y/N] "
            read -r answer
            if [[ "$answer" =~ ^[Yy] ]]; then
                import_saves "$game_name" "$user" "$source" "$linux_rel" "$size"
            fi
        done < <(find_game_saves "$mp" "$game_query")
    done

    if [[ $found -eq 0 ]]; then
        warn "No save files found for '$game_query'"
        detail "Save files are detected from known locations in Windows user profiles"
        detail "If your game saves are in a non-standard location, copy them manually"
    fi
}

# ── Command: saves-all ────────────────────────────────────────────────────────

cmd_saves_all() {
    check_deps

    local parts
    parts=$(find_ntfs_partitions)
    [[ -z "$parts" ]] && die "No NTFS partitions found"

    header "Scanning for all save files"

    local found=0 imported=0
    for part_info in $parts; do
        IFS='|' read -r dev _ <<< "$part_info"
        local mp
        mp=$(mount_partition "$dev") || continue
        is_windows_partition "$mp" || continue

        while IFS='|' read -r game_name user source linux_rel size; do
            [[ -z "$game_name" ]] && continue
            found=$((found + 1))
            bullet "${BOLD}$game_name${NC} — User: $user — $(human_size "$size")"
        done < <(find_all_saves "$mp")
    done

    if [[ $found -eq 0 ]]; then
        warn "No save files found"
        return 0
    fi

    echo ""
    info "Found saves for $found game(s)"
    echo -n "  Import all? [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy] ]] || { info "Cancelled"; return 0; }

    for part_info in $parts; do
        IFS='|' read -r dev _ <<< "$part_info"
        local mp
        mp=$(mount_partition "$dev") || continue
        is_windows_partition "$mp" || continue

        while IFS='|' read -r game_name user source linux_rel size; do
            [[ -z "$game_name" ]] && continue
            import_saves "$game_name" "$user" "$source" "$linux_rel" "$size"
            imported=$((imported + 1))
        done < <(find_all_saves "$mp")
    done

    echo ""
    ok "Imported saves for $imported game(s)"
}

# ── Command: status ───────────────────────────────────────────────────────────

cmd_status() {
    header "Windows Import Status"

    local imports_file="$STATE_DIR/imported-games.json"
    if [[ ! -f "$imports_file" ]]; then
        info "No games have been imported yet"
        detail "Run ${BOLD}24hg-windows-import scan${NC} to get started"
        return 0
    fi

    local count
    count=$(jq 'length' "$imports_file" 2>/dev/null || echo 0)
    local total_size
    total_size=$(jq '[.[].size] | add // 0' "$imports_file" 2>/dev/null || echo 0)

    echo ""
    info "Imported games: ${BOLD}$count${NC}"
    info "Total size: ${BOLD}$(human_size "$total_size")${NC}"
    echo ""

    printf "  ${BOLD}%-6s  %-35s  %-10s  %-10s  %s${NC}\n" "STORE" "GAME" "SIZE" "VERIFIED" "DATE"
    printf "  %-6s  %-35s  %-10s  %-10s  %s\n" "------" "$(printf '%0.s-' {1..35})" "----------" "----------" "----------"

    jq -r '.[] | "\(.store)|\(.name)|\(.size)|\(.verified)|\(.date)"' "$imports_file" 2>/dev/null | \
    while IFS='|' read -r store name size verified date; do
        local store_colored
        case "$store" in
            steam)   store_colored="${CYAN}Steam${NC}" ;;
            epic)    store_colored="${YELLOW}Epic${NC}" ;;
            gog)     store_colored="${MAGENTA}GOG${NC}" ;;
            *)       store_colored="${DIM}$store${NC}" ;;
        esac
        local verify_colored
        if [[ "$verified" == "true" ]]; then
            verify_colored="${GREEN}Yes${NC}"
        else
            verify_colored="${YELLOW}No${NC}"
        fi
        local short_date="${date:0:10}"
        printf "  %-17s  %-35s  %-10s  %-21s  %s\n" \
            "$store_colored" "${name:0:35}" "$(human_size "$size")" "$verify_colored" "$short_date"
    done

    echo ""

    # Show mounted partitions
    if [[ -d "$MOUNT_BASE" ]]; then
        local mounted=0
        for mp in "$MOUNT_BASE"/*/; do
            if mountpoint -q "$mp" 2>/dev/null; then
                [[ $mounted -eq 0 ]] && info "Mounted partitions:"
                detail "$mp"
                mounted=$((mounted + 1))
            fi
        done
        [[ $mounted -gt 0 ]] && detail "Run 'scan' to refresh or unmount will happen on reboot"
    fi

    # Show import log tail
    if [[ -f "$IMPORT_LOG" ]]; then
        echo ""
        info "Recent activity:"
        tail -5 "$IMPORT_LOG" | while IFS= read -r line; do
            detail "$line"
        done
    fi
}

# ── Command: verify ───────────────────────────────────────────────────────────

cmd_verify() {
    local game_query="${1:-}"
    [[ -z "$game_query" ]] && die "Usage: 24hg-windows-import verify <game-name>"
    verify_game "$game_query"
}

# ── Cleanup ───────────────────────────────────────────────────────────────────

cleanup() {
    # Do not unmount on exit — let the user keep browsing
    # Mounts are read-only and in /tmp, so they'll be cleaned on reboot
    true
}
trap cleanup EXIT

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${BOLD}${CYAN}24HG Windows Game Library Import${NC} v${VERSION}

${BOLD}USAGE:${NC}
    $SCRIPT_NAME [command] [args]

${BOLD}COMMANDS:${NC}
    ${GREEN}scan${NC}                      Scan for Windows partitions and game installations
    ${GREEN}list${NC} [partition]           List all detected games on a Windows partition
    ${GREEN}import${NC} <game> [partition]  Import a specific game (copy files + configure)
    ${GREEN}import-all${NC} [partition]     Import all detected games
    ${GREEN}saves${NC} <game>              Find and import save files for a game
    ${GREEN}saves-all${NC}                 Import all detected save files
    ${GREEN}status${NC}                    Show import progress and imported games
    ${GREEN}verify${NC} <game>             Verify imported game files

${BOLD}EXAMPLES:${NC}
    $SCRIPT_NAME scan
    $SCRIPT_NAME list /dev/sda2
    $SCRIPT_NAME import "Cyberpunk 2077"
    $SCRIPT_NAME import-all /dev/nvme0n1p3
    $SCRIPT_NAME saves "Elden Ring"
    $SCRIPT_NAME saves-all
    $SCRIPT_NAME verify "The Witcher 3"

${BOLD}SAFETY:${NC}
    - Windows partitions are always mounted ${GREEN}read-only${NC}
    - Disk space is checked before every import
    - File integrity is verified after copy (md5 spot-checks)
    - No modifications are made to the Windows partition

${BOLD}NOTES:${NC}
    - Steam games are placed in ~/.local/share/Steam/steamapps/common/
    - Non-Steam games are placed in ~/Games/<store>/<game>/
    - Steam manifests are created so games appear in your Steam library
    - Lutris configs are created for Epic/GOG games
    - Proton prefixes are set up automatically on first launch
    - Save file locations are mapped from Windows to Linux equivalents
EOF
}

# ── Main Dispatch ─────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        scan|"")
            cmd_scan "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        import)
            cmd_import "$@"
            ;;
        import-all)
            cmd_import_all "$@"
            ;;
        saves)
            cmd_saves "$@"
            ;;
        saves-all)
            cmd_saves_all "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        verify)
            cmd_verify "$@"
            ;;
        -h|--help|help)
            usage
            ;;
        -v|--version)
            echo "$SCRIPT_NAME v$VERSION"
            ;;
        *)
            err "Unknown command: $cmd"
            usage
            exit 1
            ;;
    esac
}

main "$@"
