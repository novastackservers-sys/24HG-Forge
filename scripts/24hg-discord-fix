#!/bin/bash
# 24HG Discord Flatpak Fix
# Bridges Discord Rich Presence IPC between Flatpak sandboxes.
# Problem: Steam Flatpak can't talk to Discord Flatpak because each
# has its own /tmp, so the discord-ipc-0 socket is invisible.
#
# This creates a symlink bridge so games show "Playing X" in Discord.
# Runs as a user service on login.

set -euo pipefail

DISCORD_FLATPAK="com.discordapp.Discord"
STEAM_FLATPAK="com.valvesoftware.Steam"

# Real XDG_RUNTIME_DIR
XDG="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

# Discord creates its IPC socket here inside its Flatpak sandbox
# But we need it visible to other sandboxes too
DISCORD_IPC="discord-ipc-0"

# Possible socket locations
FLATPAK_DISCORD_TMP="$HOME/.var/app/$DISCORD_FLATPAK/cache/tmp"
SYSTEM_TMP="/tmp"
APP_TMP="$XDG/app/$DISCORD_FLATPAK"

setup_bridge() {
    echo "24HG Discord Rich Presence Bridge"
    echo ""

    # Method 1: XDG_RUNTIME_DIR bridge (works for most setups)
    # Create the socket path that Wine/Proton looks for
    for i in 0 1 2 3; do
        local SOCK="$XDG/discord-ipc-$i"
        # If it already exists as a real socket, Discord native is running — don't touch
        if [ -S "$SOCK" ]; then
            echo "  discord-ipc-$i: native socket exists (OK)"
            continue
        fi

        # Check Flatpak Discord's tmp for the socket
        local FLATPAK_SOCK="$FLATPAK_DISCORD_TMP/discord-ipc-$i"
        if [ -S "$FLATPAK_SOCK" ]; then
            ln -sf "$FLATPAK_SOCK" "$SOCK"
            echo "  discord-ipc-$i: bridged from Flatpak"
            continue
        fi

        # Check app runtime dir
        local APP_SOCK="$APP_TMP/discord-ipc-$i"
        if [ -S "$APP_SOCK" ]; then
            ln -sf "$APP_SOCK" "$SOCK"
            echo "  discord-ipc-$i: bridged from app runtime"
            continue
        fi
    done

    # Method 2: Flatpak override to share /tmp between Steam and Discord
    # This allows Steam games (Proton/Wine) to see Discord's IPC socket
    mkdir -p "$HOME/.local/share/flatpak/overrides"

    # Allow Steam to access Discord's socket
    local STEAM_OVERRIDE="$HOME/.local/share/flatpak/overrides/$STEAM_FLATPAK"
    if [ ! -f "$STEAM_OVERRIDE" ] || ! grep -q "discord-ipc" "$STEAM_OVERRIDE" 2>/dev/null; then
        # Add filesystem access to XDG_RUNTIME_DIR (where Discord puts IPC sockets)
        flatpak override --user "$STEAM_FLATPAK" \
            --filesystem=xdg-run/discord-ipc-0:ro \
            --filesystem=xdg-run/discord-ipc-1:ro \
            2>/dev/null || true
        echo "  Steam Flatpak: granted Discord IPC access"
    fi

    echo ""
    echo "Discord Rich Presence bridge active."
    echo "Games launched via Steam should now show in Discord."
}

monitor_mode() {
    # Daemon mode: watch for Discord socket appearing and bridge it
    echo "Monitoring for Discord IPC sockets..."
    while true; do
        for i in 0 1; do
            local SOCK="$XDG/discord-ipc-$i"
            # Skip if already a socket or valid symlink
            [ -S "$SOCK" ] && continue

            # Check Flatpak Discord paths
            for SEARCH_DIR in "$FLATPAK_DISCORD_TMP" "$APP_TMP" "$SYSTEM_TMP"; do
                local CANDIDATE="$SEARCH_DIR/discord-ipc-$i"
                if [ -S "$CANDIDATE" ]; then
                    ln -sf "$CANDIDATE" "$SOCK"
                    echo "  Bridged discord-ipc-$i from $SEARCH_DIR"
                    break
                fi
            done
        done
        sleep 5
    done
}

case "${1:-setup}" in
    setup)   setup_bridge ;;
    monitor) monitor_mode ;;
    status)
        echo "=== Discord IPC Status ==="
        for i in 0 1 2 3; do
            local SOCK="$XDG/discord-ipc-$i"
            if [ -S "$SOCK" ]; then
                if [ -L "$SOCK" ]; then
                    TARGET=$(readlink "$SOCK")
                    echo "  discord-ipc-$i: BRIDGED -> $TARGET"
                else
                    echo "  discord-ipc-$i: NATIVE socket"
                fi
            elif [ -L "$SOCK" ]; then
                echo "  discord-ipc-$i: STALE symlink (Discord not running?)"
            else
                echo "  discord-ipc-$i: not found"
            fi
        done
        ;;
    *)
        echo "24HG Discord Rich Presence Fix"
        echo "Usage: 24hg-discord-fix [setup|monitor|status]"
        ;;
esac
