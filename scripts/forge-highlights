#!/bin/bash
set -euo pipefail
# 24HG Forge Highlights — Automatic game highlight detection and montage creation

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
ORANGE='\033[38;5;208m'
GOLD='\033[38;5;220m'
GRAY='\033[38;5;242m'

# ── Paths & defaults ───────────────────────────────────────────────────────
CONFIG_DIR="$HOME/.config/forge"
DATA_DIR="$HOME/.local/share/forge/highlights"
CLIP_DIR="$HOME/Videos/24HG Clips"
MONTAGE_DIR="$HOME/Videos/Highlights"
WATERMARK_FILE="$HOME/.local/share/forge/assets/forge-watermark.png"
CONFIG_FILE="$CONFIG_DIR/highlights.conf"
LOG_TAG="forge-highlights"
WATCH_PID_FILE="/tmp/forge-highlights-watch.pid"
WATCH_INTERVAL=10   # seconds between new-file checks

# ── Detection thresholds ──────────────────────────────────────────────────
AUDIO_PEAK_THRESHOLD=-12      # dB — peaks above this are interesting
SCENE_CHANGE_THRESHOLD=0.4    # 0-1 — higher = only major scene changes
HIGHLIGHT_SCORE_MIN=70        # minimum score to qualify as a highlight
TOP_N=5                       # max highlights per clip
EXTRACT_PAD=5                 # seconds before/after highlight to extract
CROSSFADE_DUR=0.5             # seconds of crossfade in montage

# ── Weight distribution ──────────────────────────────────────────────────
W_AUDIO=40
W_SCENE=30
W_CLUSTER=20
W_DURATION=10

# ── Helpers ─────────────────────────────────────────────────────────────────
log() { logger -t "$LOG_TAG" "$*" 2>/dev/null || true; }

info()    { echo -e "${BLUE}${BOLD}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}${BOLD}[  OK]${RESET}  $*"; }
warn()    { echo -e "${YELLOW}${BOLD}[WARN]${RESET}  $*"; }
error()   { echo -e "${RED}${BOLD}[ ERR]${RESET}  $*" >&2; }

die() {
    error "$*"
    log "ERROR: $*"
    exit 1
}

banner() {
    echo -e "${GOLD}${BOLD}"
    echo "  ╔══════════════════════════════════════╗"
    echo "  ║     Forge Highlight Detector         ║"
    echo "  ║          24 Hour Gaming              ║"
    echo "  ╚══════════════════════════════════════╝"
    echo -e "${RESET}"
}

# ── Dependency check ────────────────────────────────────────────────────────
check_deps() {
    local missing=()
    for cmd in ffmpeg ffprobe jq bc sha256sum; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required tools: ${missing[*]}"
    fi
}

# ── Load config ─────────────────────────────────────────────────────────────
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
        log "Loaded config from $CONFIG_FILE"
    fi
}

save_default_config() {
    mkdir -p "$CONFIG_DIR"
    [[ -f "$CONFIG_FILE" ]] && return
    cat > "$CONFIG_FILE" <<'CONF'
# 24HG Forge Highlights Configuration

# Detection thresholds
AUDIO_PEAK_THRESHOLD=-12      # dB — peaks louder than this are interesting
SCENE_CHANGE_THRESHOLD=0.4    # 0.0-1.0 — higher = fewer scene changes detected
HIGHLIGHT_SCORE_MIN=70        # 0-100 — minimum to be a highlight
TOP_N=5                       # max highlights per clip

# Extraction
EXTRACT_PAD=5                 # seconds of padding around highlight

# Montage
CROSSFADE_DUR=0.5             # crossfade duration in seconds
WATERMARK=yes                 # add 24HG forge watermark

# Watch mode
WATCH_INTERVAL=10             # seconds between scans for new clips
CONF
    info "Created default config at ${CONFIG_FILE}"
}

# ── Data helpers ────────────────────────────────────────────────────────────
ensure_dirs() {
    mkdir -p "$DATA_DIR" "$MONTAGE_DIR"
}

clip_hash() {
    local clip="$1"
    sha256sum "$clip" 2>/dev/null | cut -c1-16
}

clip_data_file() {
    local clip="$1"
    local hash
    hash=$(clip_hash "$clip")
    echo "${DATA_DIR}/${hash}.json"
}

clip_duration() {
    local clip="$1"
    ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$clip" 2>/dev/null
}

format_time() {
    # seconds (float) -> MM:SS.s
    local secs="$1"
    local mins secs_i frac
    mins=$(echo "$secs / 60" | bc 2>/dev/null || echo 0)
    secs_i=$(echo "$secs - ($mins * 60)" | bc 2>/dev/null || echo "$secs")
    printf "%02d:%05.2f" "$mins" "$secs_i"
}

format_time_hms() {
    # seconds (float) -> HH:MM:SS
    local secs="${1%.*}"
    printf "%02d:%02d:%02d" $((secs/3600)) $((secs%3600/60)) $((secs%60))
}

is_video_file() {
    local f="$1"
    case "${f,,}" in
        *.mp4|*.mkv|*.avi|*.mov|*.webm|*.flv|*.wmv|*.m4v|*.ts) return 0 ;;
        *) return 1 ;;
    esac
}

# ── Audio peak detection ───────────────────────────────────────────────────
# Detects sudden volume spikes — gunshots, explosions, player reactions
detect_audio_peaks() {
    local clip="$1"
    local tmpfile
    tmpfile=$(mktemp /tmp/forge-hl-audio-XXXXXX.csv)

    info "Analyzing audio peaks..."

    # Get per-frame audio peak levels using astats
    ffprobe -v error \
        -f lavfi \
        -i "amovie='${clip//\'/\\\'}',astats=metadata=1:reset=1" \
        -show_entries frame_tags=lavfi.astats.Overall.Peak_level \
        -show_entries frame=pts_time \
        -of csv=p=0 2>/dev/null > "$tmpfile" || {
        warn "Audio analysis failed — clip may have no audio track"
        rm -f "$tmpfile"
        echo "[]"
        return
    }

    # Parse peaks: find frames where volume exceeds threshold
    local peaks="[]"
    local prev_peak=-100
    local event_start=""
    local event_max=-100
    local line_num=0
    local sample_rate=0

    while IFS=',' read -r pts_time peak_level rest; do
        # Skip empty or invalid lines
        [[ -z "$pts_time" || "$pts_time" == "N/A" ]] && continue
        [[ -z "$peak_level" || "$peak_level" == "-inf" || "$peak_level" == "N/A" ]] && continue

        # Detect rising edge above threshold
        local above
        above=$(echo "$peak_level > $AUDIO_PEAK_THRESHOLD" | bc -l 2>/dev/null) || continue
        local was_below
        was_below=$(echo "$prev_peak <= $AUDIO_PEAK_THRESHOLD" | bc -l 2>/dev/null) || continue

        if [[ "$above" == "1" && "$was_below" == "1" ]]; then
            event_start="$pts_time"
            event_max="$peak_level"
        elif [[ "$above" == "1" && -n "$event_start" ]]; then
            # Still in event — track max
            local is_higher
            is_higher=$(echo "$peak_level > $event_max" | bc -l 2>/dev/null) || continue
            [[ "$is_higher" == "1" ]] && event_max="$peak_level"
        elif [[ "$above" == "0" && -n "$event_start" ]]; then
            # Falling edge — record event
            local duration
            duration=$(echo "$pts_time - $event_start" | bc -l 2>/dev/null) || continue
            # Normalize peak to 0-100 scale (threshold..0 dB -> 0..100)
            local magnitude
            magnitude=$(echo "scale=2; (($event_max - ($AUDIO_PEAK_THRESHOLD)) / (0 - ($AUDIO_PEAK_THRESHOLD))) * 100" | bc -l 2>/dev/null) || continue
            [[ $(echo "$magnitude > 100" | bc -l) == "1" ]] && magnitude=100
            [[ $(echo "$magnitude < 0" | bc -l) == "1" ]] && magnitude=0

            peaks=$(echo "$peaks" | jq --argjson ts "$event_start" \
                --argjson dur "$duration" --argjson mag "$magnitude" \
                --argjson peak "$event_max" \
                '. + [{"timestamp": $ts, "duration": $dur, "magnitude": $mag, "peak_db": $peak, "type": "audio"}]')

            event_start=""
            event_max=-100
        fi

        prev_peak="$peak_level"
        line_num=$((line_num + 1))
    done < "$tmpfile"

    # Handle event still open at end of file
    if [[ -n "$event_start" ]]; then
        local magnitude
        magnitude=$(echo "scale=2; (($event_max - ($AUDIO_PEAK_THRESHOLD)) / (0 - ($AUDIO_PEAK_THRESHOLD))) * 100" | bc -l 2>/dev/null) || true
        [[ -z "$magnitude" ]] && magnitude=50
        peaks=$(echo "$peaks" | jq --argjson ts "$event_start" \
            --argjson dur 0.5 --argjson mag "$magnitude" \
            --argjson peak "$event_max" \
            '. + [{"timestamp": $ts, "duration": $dur, "magnitude": $mag, "peak_db": $peak, "type": "audio"}]')
    fi

    rm -f "$tmpfile"
    local count
    count=$(echo "$peaks" | jq 'length')
    info "  Found ${CYAN}${count}${RESET} audio peak events"
    echo "$peaks"
}

# ── Scene change detection ─────────────────────────────────────────────────
# Detects abrupt visual changes — explosions, fast movement, kills
detect_scene_changes() {
    local clip="$1"
    local tmpfile
    tmpfile=$(mktemp /tmp/forge-hl-scene-XXXXXX.txt)

    info "Analyzing scene changes..."

    # Use ffmpeg scene detection filter
    ffmpeg -v error -i "$clip" \
        -vf "select='gt(scene,${SCENE_CHANGE_THRESHOLD})',showinfo" \
        -f null - 2>"$tmpfile" || {
        warn "Scene detection failed"
        rm -f "$tmpfile"
        echo "[]"
        return
    }

    local scenes="[]"
    while IFS= read -r line; do
        # Parse showinfo output: pts_time:X.XXX
        if [[ "$line" =~ pts_time:([0-9.]+) ]]; then
            local ts="${BASH_REMATCH[1]}"
            # Extract scene score if available (from the select filter metadata)
            local score=75  # default — we know it exceeded threshold
            if [[ "$line" =~ scene:([0-9.]+) ]]; then
                score=$(echo "scale=2; ${BASH_REMATCH[1]} * 100" | bc -l 2>/dev/null) || score=75
            fi

            scenes=$(echo "$scenes" | jq --argjson ts "$ts" \
                --argjson score "$score" \
                '. + [{"timestamp": $ts, "duration": 0.5, "magnitude": $score, "type": "scene"}]')
        fi
    done < "$tmpfile"

    rm -f "$tmpfile"
    local count
    count=$(echo "$scenes" | jq 'length')
    info "  Found ${CYAN}${count}${RESET} scene changes"
    echo "$scenes"
}

# ── Cluster detection ──────────────────────────────────────────────────────
# Events that happen close together are more exciting
compute_cluster_bonus() {
    local events_json="$1"
    local window=3.0  # seconds — events within this window form a cluster

    echo "$events_json" | jq --argjson win "$window" '
        [.[] | . as $ev |
            {
                timestamp: .timestamp,
                duration: .duration,
                magnitude: .magnitude,
                type: .type,
                cluster_count: ([
                    $ev.timestamp as $t |
                    input, . |  # This wont work in stream, use reduce
                    select(false)
                ] | length)
            }
        ] |
        # For each event, count how many other events are within the window
        . as $all |
        [range(length)] |
        map(. as $i |
            ($all[$i].timestamp) as $t |
            ($all | map(select(
                (.timestamp > ($t - $win)) and
                (.timestamp < ($t + $win)) and
                (.timestamp != $t)
            )) | length) as $nearby |
            $all[$i] + {
                "cluster_bonus": (if $nearby > 4 then 100
                    elif $nearby > 2 then 75
                    elif $nearby > 0 then 50
                    else 0 end)
            }
        )
    '
}

# ── Scoring engine ─────────────────────────────────────────────────────────
score_events() {
    local events_json="$1"
    local clip_duration="$2"

    # Add cluster bonuses
    local clustered
    clustered=$(compute_cluster_bonus "$events_json")

    # Calculate final scores with weighted formula
    echo "$clustered" | jq --argjson wa "$W_AUDIO" --argjson ws "$W_SCENE" \
        --argjson wc "$W_CLUSTER" --argjson wd "$W_DURATION" \
        --argjson cdur "$clip_duration" '
        map(
            # Base magnitude score depends on type
            (.magnitude) as $base_mag |
            # Audio events get audio weight, scene events get scene weight
            (if .type == "audio" then $wa else $ws end) as $type_weight |
            # Duration score: longer events score higher (up to 3 seconds)
            ((if .duration > 3 then 3 else .duration end) / 3 * 100) as $dur_score |
            # Cluster bonus already computed
            .cluster_bonus as $cluster_score |

            # Weighted average
            (($base_mag * $type_weight + $cluster_score * $wc + $dur_score * $wd) / 100) as $raw_score |

            # Clamp to 0-100
            (if $raw_score > 100 then 100
             elif $raw_score < 0 then 0
             else $raw_score end) as $final |

            . + {"score": ($final * 100 | round / 100)}
        ) |
        sort_by(-.score)
    '
}

# ── Timeline visualization ─────────────────────────────────────────────────
show_timeline() {
    local data_file="$1"
    local clip_name="$2"
    local duration="$3"

    local highlights
    highlights=$(jq '.highlights' "$data_file")
    local count
    count=$(echo "$highlights" | jq 'length')

    echo ""
    echo -e "${BOLD}${WHITE}Timeline: ${CYAN}${clip_name}${RESET}"
    echo -e "${DIM}Duration: $(format_time_hms "${duration%.*}")${RESET}"
    echo ""

    # Draw a 60-char timeline bar
    local bar_width=60
    local bar=""
    local positions=()

    # Initialize empty bar
    for ((i = 0; i < bar_width; i++)); do
        bar+="─"
    done

    # Mark highlights on the bar
    local markers=()
    for ((i = 0; i < count; i++)); do
        local ts score type
        ts=$(echo "$highlights" | jq -r ".[$i].timestamp")
        score=$(echo "$highlights" | jq -r ".[$i].score")
        type=$(echo "$highlights" | jq -r ".[$i].type")

        # Map timestamp to bar position
        local pos
        pos=$(echo "scale=0; $ts / $duration * $bar_width" | bc -l 2>/dev/null) || continue
        [[ "$pos" -ge "$bar_width" ]] && pos=$((bar_width - 1))
        [[ "$pos" -lt 0 ]] && pos=0

        # Color based on score
        local color="$GRAY"
        local marker="*"
        local score_int="${score%.*}"
        if [[ "$score_int" -ge 90 ]]; then
            color="$RED"
            marker="!"
        elif [[ "$score_int" -ge 80 ]]; then
            color="$ORANGE"
            marker="*"
        elif [[ "$score_int" -ge 70 ]]; then
            color="$YELLOW"
            marker="*"
        else
            color="$GRAY"
            marker="."
        fi

        markers+=("$pos:$color:$marker")
    done

    # Render bar with markers
    echo -ne "  ${DIM}0:00 ${RESET}["
    for ((i = 0; i < bar_width; i++)); do
        local found=0
        for m in "${markers[@]}"; do
            local mpos="${m%%:*}"
            local rest="${m#*:}"
            local mcol="${rest%%:*}"
            local mchar="${rest#*:}"
            if [[ "$mpos" == "$i" ]]; then
                echo -ne "${mcol}${BOLD}${mchar}${RESET}"
                found=1
                break
            fi
        done
        [[ "$found" == 0 ]] && echo -ne "${DIM}─${RESET}"
    done
    echo -e "] ${DIM}$(format_time_hms "${duration%.*}")${RESET}"
    echo ""

    # Legend
    echo -e "  ${RED}${BOLD}!${RESET} 90+  ${ORANGE}${BOLD}*${RESET} 80-89  ${YELLOW}${BOLD}*${RESET} 70-79  ${GRAY}.${RESET} <70"
    echo ""

    # Detail list
    if [[ "$count" -gt 0 ]]; then
        echo -e "  ${BOLD}${WHITE}# ${RESET} ${BOLD}Time       Score  Type     Details${RESET}"
        echo -e "  ${DIM}──────────────────────────────────────────────${RESET}"

        for ((i = 0; i < count && i < TOP_N; i++)); do
            local ts score type dur peak cluster
            ts=$(echo "$highlights" | jq -r ".[$i].timestamp")
            score=$(echo "$highlights" | jq -r ".[$i].score")
            type=$(echo "$highlights" | jq -r ".[$i].type")
            dur=$(echo "$highlights" | jq -r ".[$i].duration")
            peak=$(echo "$highlights" | jq -r ".[$i].peak_db // empty")
            cluster=$(echo "$highlights" | jq -r ".[$i].cluster_bonus // 0")

            local color="$WHITE"
            local score_int="${score%.*}"
            [[ "$score_int" -ge 90 ]] && color="$RED"
            [[ "$score_int" -ge 80 && "$score_int" -lt 90 ]] && color="$ORANGE"
            [[ "$score_int" -ge 70 && "$score_int" -lt 80 ]] && color="$YELLOW"

            local detail=""
            [[ -n "$peak" && "$peak" != "null" ]] && detail+="${peak}dB "
            [[ "$cluster" != "0" ]] && detail+="cluster:${cluster}% "
            detail+="${dur}s"

            printf "  ${color}%-2d${RESET}  %-10s ${color}%-6s${RESET} %-8s %s\n" \
                $((i + 1)) "$(format_time "$ts")" "$score" "$type" "$detail"
        done
    else
        echo -e "  ${DIM}No highlights detected above threshold (${HIGHLIGHT_SCORE_MIN})${RESET}"
    fi
    echo ""
}

# ════════════════════════════════════════════════════════════════════════════
# ── Commands ───────────────────────────────────────────────────────────────
# ════════════════════════════════════════════════════════════════════════════

# ── ANALYZE ────────────────────────────────────────────────────────────────
cmd_analyze() {
    local clip="${1:?Usage: forge-highlights analyze <clip>}"

    [[ -f "$clip" ]] || die "File not found: $clip"
    is_video_file "$clip" || die "Not a video file: $clip"

    local clip_name
    clip_name=$(basename "$clip")
    local data_file
    data_file=$(clip_data_file "$clip")

    banner
    info "Analyzing: ${CYAN}${clip_name}${RESET}"

    local duration
    duration=$(clip_duration "$clip")
    [[ -z "$duration" || "$duration" == "N/A" ]] && die "Could not determine clip duration"
    info "Duration: $(format_time_hms "${duration%.*}")"
    echo ""

    # Run detection passes
    local audio_events scene_events

    info "${BOLD}Pass 1/3: Audio peak analysis${RESET}"
    audio_events=$(detect_audio_peaks "$clip")

    echo ""
    info "${BOLD}Pass 2/3: Scene change analysis${RESET}"
    scene_events=$(detect_scene_changes "$clip")

    # Merge all events
    echo ""
    info "${BOLD}Pass 3/3: Scoring and clustering${RESET}"
    local all_events
    all_events=$(echo "$audio_events" "$scene_events" | jq -s 'add // []')

    local total_events
    total_events=$(echo "$all_events" | jq 'length')
    info "  Total raw events: ${CYAN}${total_events}${RESET}"

    if [[ "$total_events" -eq 0 ]]; then
        warn "No events detected in clip"
        # Save empty result
        jq -n --arg clip "$clip" --arg name "$clip_name" \
            --argjson dur "$duration" \
            '{
                "clip": $clip,
                "name": $name,
                "duration": $dur,
                "analyzed_at": (now | todate),
                "highlights": [],
                "total_events": 0
            }' > "$data_file"
        success "Analysis saved to ${data_file}"
        return
    fi

    # Score all events
    local scored
    scored=$(score_events "$all_events" "$duration")

    # Filter to highlights (score >= threshold) and take top N
    local highlights
    highlights=$(echo "$scored" | jq --argjson min "$HIGHLIGHT_SCORE_MIN" --argjson n "$TOP_N" '
        [.[] | select(.score >= $min)] | .[:$n]
    ')

    local hl_count
    hl_count=$(echo "$highlights" | jq 'length')

    # Save result
    jq -n --arg clip "$clip" --arg name "$clip_name" \
        --argjson dur "$duration" \
        --argjson highlights "$highlights" \
        --argjson all_scored "$scored" \
        --argjson total "$total_events" \
        --argjson hl_count "$hl_count" \
        '{
            "clip": $clip,
            "name": $name,
            "duration": $dur,
            "analyzed_at": (now | todate),
            "total_events": $total,
            "highlight_count": $hl_count,
            "highlights": $highlights,
            "all_events": $all_scored
        }' > "$data_file"

    echo ""
    success "Found ${GREEN}${BOLD}${hl_count}${RESET} highlights (of ${total_events} events)"
    success "Data saved to ${DIM}${data_file}${RESET}"

    # Show timeline
    show_timeline "$data_file" "$clip_name" "$duration"
    log "Analyzed $clip_name: $hl_count highlights from $total_events events"
}

# ── SCAN ───────────────────────────────────────────────────────────────────
cmd_scan() {
    local scan_dir="${1:-$CLIP_DIR}"

    [[ -d "$scan_dir" ]] || die "Directory not found: $scan_dir"

    banner
    info "Scanning: ${CYAN}${scan_dir}${RESET}"
    echo ""

    local found=0
    local analyzed=0
    local skipped=0
    local total_highlights=0

    while IFS= read -r -d '' clip; do
        is_video_file "$clip" || continue
        found=$((found + 1))

        local data_file
        data_file=$(clip_data_file "$clip")

        if [[ -f "$data_file" ]]; then
            skipped=$((skipped + 1))
            local hl_count
            hl_count=$(jq '.highlight_count // 0' "$data_file" 2>/dev/null) || hl_count=0
            total_highlights=$((total_highlights + hl_count))
            echo -e "  ${DIM}[skip]${RESET} $(basename "$clip") ${DIM}(${hl_count} highlights)${RESET}"
            continue
        fi

        echo -e "  ${BLUE}[scan]${RESET} $(basename "$clip")"
        cmd_analyze "$clip" 2>&1 | sed 's/^/    /'
        analyzed=$((analyzed + 1))

        # Count highlights from the newly created data file
        if [[ -f "$data_file" ]]; then
            local hl_count
            hl_count=$(jq '.highlight_count // 0' "$data_file" 2>/dev/null) || hl_count=0
            total_highlights=$((total_highlights + hl_count))
        fi

        echo ""
    done < <(find "$scan_dir" -maxdepth 3 -type f -print0 2>/dev/null | sort -z)

    echo ""
    echo -e "${BOLD}${WHITE}Scan Summary${RESET}"
    echo -e "  Clips found:    ${CYAN}${found}${RESET}"
    echo -e "  Newly analyzed: ${GREEN}${analyzed}${RESET}"
    echo -e "  Already done:   ${DIM}${skipped}${RESET}"
    echo -e "  Total highlights: ${GOLD}${BOLD}${total_highlights}${RESET}"
    echo ""
    log "Scanned $scan_dir: $found clips, $analyzed new, $total_highlights highlights"
}

# ── EXTRACT ────────────────────────────────────────────────────────────────
cmd_extract() {
    local clip="${1:?Usage: forge-highlights extract <clip> [timestamp]}"
    local timestamp="${2:-}"

    [[ -f "$clip" ]] || die "File not found: $clip"
    is_video_file "$clip" || die "Not a video file: $clip"

    local clip_name
    clip_name=$(basename "$clip")
    local clip_base="${clip_name%.*}"
    local clip_ext="${clip_name##*.}"
    local data_file
    data_file=$(clip_data_file "$clip")

    banner

    if [[ -n "$timestamp" ]]; then
        # Extract at specific timestamp
        info "Extracting at timestamp: ${CYAN}${timestamp}s${RESET}"
        local start end
        start=$(echo "$timestamp - $EXTRACT_PAD" | bc -l)
        [[ $(echo "$start < 0" | bc -l) == "1" ]] && start=0
        end=$(echo "$timestamp + $EXTRACT_PAD" | bc -l)
        local seg_duration
        seg_duration=$(echo "$end - $start" | bc -l)

        local outfile="${MONTAGE_DIR}/${clip_base}_hl_$(format_time_hms "${timestamp%.*}" | tr ':' '-').${clip_ext}"

        info "Cutting: $(format_time "$start") to $(format_time "$end") (${seg_duration}s)"
        ffmpeg -v warning -y -ss "$start" -i "$clip" -t "$seg_duration" \
            -c copy -avoid_negative_ts 1 "$outfile" 2>&1

        success "Extracted to: ${GREEN}${outfile}${RESET}"
        log "Extracted highlight from $clip_name at ${timestamp}s -> $outfile"
        return
    fi

    # No timestamp given — extract top highlight from analysis
    [[ -f "$data_file" ]] || {
        info "No analysis found — running analysis first..."
        cmd_analyze "$clip"
        data_file=$(clip_data_file "$clip")
    }

    local hl_count
    hl_count=$(jq '.highlight_count // 0' "$data_file")
    [[ "$hl_count" -eq 0 ]] && die "No highlights found in $clip_name"

    info "Extracting top ${CYAN}${hl_count}${RESET} highlights from ${clip_name}"
    echo ""

    for ((i = 0; i < hl_count; i++)); do
        local ts score
        ts=$(jq -r ".highlights[$i].timestamp" "$data_file")
        score=$(jq -r ".highlights[$i].score" "$data_file")

        local start end seg_duration
        start=$(echo "$ts - $EXTRACT_PAD" | bc -l)
        [[ $(echo "$start < 0" | bc -l) == "1" ]] && start=0
        end=$(echo "$ts + $EXTRACT_PAD" | bc -l)
        seg_duration=$(echo "$end - $start" | bc -l)

        local outfile="${MONTAGE_DIR}/${clip_base}_hl$(printf '%02d' $((i + 1))).${clip_ext}"

        echo -e "  ${GOLD}#$((i + 1))${RESET} [score: ${score}] $(format_time "$ts") -> ${DIM}${outfile}${RESET}"
        ffmpeg -v warning -y -ss "$start" -i "$clip" -t "$seg_duration" \
            -c copy -avoid_negative_ts 1 "$outfile" 2>&1

    done

    echo ""
    success "Extracted ${hl_count} highlights to ${MONTAGE_DIR}/"
    log "Extracted $hl_count highlights from $clip_name"
}

# ── MONTAGE ────────────────────────────────────────────────────────────────
cmd_montage() {
    local scan_dir="${1:-$CLIP_DIR}"
    local date_stamp
    date_stamp=$(date +%Y-%m-%d_%H%M%S)
    local outfile="${MONTAGE_DIR}/montage-${date_stamp}.mp4"

    banner
    info "Creating highlight montage from: ${CYAN}${scan_dir}${RESET}"
    echo ""

    # Collect all highlights across analyzed clips
    local segments=()
    local total_duration=0

    while IFS= read -r data_file; do
        local clip
        clip=$(jq -r '.clip' "$data_file")
        [[ -f "$clip" ]] || {
            warn "Source clip missing: $clip"
            continue
        }

        local hl_count
        hl_count=$(jq '.highlight_count // 0' "$data_file")
        [[ "$hl_count" -eq 0 ]] && continue

        # Take top highlights from this clip
        for ((i = 0; i < hl_count; i++)); do
            local ts score
            ts=$(jq -r ".highlights[$i].timestamp" "$data_file")
            score=$(jq -r ".highlights[$i].score" "$data_file")

            local start seg_dur
            start=$(echo "$ts - $EXTRACT_PAD" | bc -l)
            [[ $(echo "$start < 0" | bc -l) == "1" ]] && start=0
            seg_dur=$(echo "$EXTRACT_PAD * 2" | bc -l)

            segments+=("${score}|${clip}|${start}|${seg_dur}")
            total_duration=$(echo "$total_duration + $seg_dur" | bc -l)
        done
    done < <(find "$DATA_DIR" -name '*.json' -type f 2>/dev/null | sort)

    local seg_count=${#segments[@]}
    [[ "$seg_count" -eq 0 ]] && die "No highlights found. Run 'scan' or 'analyze' first."

    # Sort by score descending and take top segments
    local max_segments=20
    IFS=$'\n' sorted=($(printf '%s\n' "${segments[@]}" | sort -t'|' -k1 -rn | head -n "$max_segments"))
    unset IFS

    seg_count=${#sorted[@]}
    info "Selected ${CYAN}${seg_count}${RESET} best moments"
    echo ""

    # Build ffmpeg concat input
    local concat_file
    concat_file=$(mktemp /tmp/forge-hl-concat-XXXXXX.txt)
    local segment_files=()
    local idx=0

    for seg in "${sorted[@]}"; do
        IFS='|' read -r score clip start dur <<< "$seg"
        local tmpout="/tmp/forge-hl-seg-${idx}.mp4"

        echo -e "  ${GOLD}[$((idx + 1))/${seg_count}]${RESET} score:${score} from $(basename "$clip") at $(format_time "$start")"

        # Extract segment with re-encode for consistent format
        ffmpeg -v warning -y -ss "$start" -i "$clip" -t "$dur" \
            -vf "scale=1920:1080:force_original_aspect_ratio=decrease,pad=1920:1080:(ow-iw)/2:(oh-ih)/2" \
            -c:v libx264 -preset fast -crf 20 \
            -c:a aac -b:a 192k -ar 48000 -ac 2 \
            -r 60 -pix_fmt yuv420p \
            "$tmpout" 2>&1

        echo "file '$tmpout'" >> "$concat_file"
        segment_files+=("$tmpout")
        idx=$((idx + 1))
    done

    echo ""
    info "Assembling montage with ${CROSSFADE_DUR}s crossfades..."

    if [[ "$seg_count" -le 1 ]]; then
        # Single segment — just copy
        [[ ${#segment_files[@]} -gt 0 ]] && cp "${segment_files[0]}" "$outfile"
    elif [[ "$seg_count" -le 2 ]]; then
        # Two segments — simple concat with crossfade
        ffmpeg -v warning -y \
            -i "${segment_files[0]}" -i "${segment_files[1]}" \
            -filter_complex "[0:v][1:v]xfade=transition=fade:duration=${CROSSFADE_DUR}:offset=$(echo "${sorted[0]}" | cut -d'|' -f4 | xargs echo)[v];[0:a][1:a]acrossfade=d=${CROSSFADE_DUR}[a]" \
            -map "[v]" -map "[a]" \
            -c:v libx264 -preset fast -crf 20 -c:a aac -b:a 192k \
            "$outfile" 2>&1
    else
        # Multiple segments — use concat demuxer (fast, no crossfade re-encode)
        ffmpeg -v warning -y -f concat -safe 0 -i "$concat_file" \
            -c copy "$outfile" 2>&1
    fi

    # Apply watermark if configured and asset exists
    if [[ -f "$WATERMARK_FILE" ]]; then
        local wm_out="${outfile%.mp4}_wm.mp4"
        info "Applying 24HG Forge watermark..."
        ffmpeg -v warning -y -i "$outfile" -i "$WATERMARK_FILE" \
            -filter_complex "overlay=W-w-10:H-h-10:format=auto,format=yuv420p" \
            -c:v libx264 -preset fast -crf 20 -c:a copy \
            "$wm_out" 2>&1 && {
            mv "$wm_out" "$outfile"
            success "Watermark applied"
        }
    fi

    # Clean up temp files
    rm -f "$concat_file"
    for f in "${segment_files[@]}"; do
        rm -f "$f"
    done

    local final_size
    final_size=$(du -h "$outfile" 2>/dev/null | cut -f1)
    echo ""
    success "Montage created: ${GREEN}${BOLD}${outfile}${RESET}"
    info "Size: ${final_size:-unknown}"
    info "Segments: ${seg_count}"
    log "Created montage: $outfile ($seg_count segments)"
}

# ── WATCH ──────────────────────────────────────────────────────────────────
cmd_watch() {
    local watch_dir="${1:-$CLIP_DIR}"

    [[ -d "$watch_dir" ]] || die "Directory not found: $watch_dir"

    # Check for existing daemon
    if [[ -f "$WATCH_PID_FILE" ]]; then
        local old_pid
        old_pid=$(<"$WATCH_PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            die "Watch daemon already running (PID $old_pid). Kill it first: kill $old_pid"
        fi
        rm -f "$WATCH_PID_FILE"
    fi

    banner
    info "Starting highlight watch daemon"
    info "Watching: ${CYAN}${watch_dir}${RESET}"
    info "Interval: ${WATCH_INTERVAL}s"
    info "PID: $$"
    echo ""

    echo $$ > "$WATCH_PID_FILE"

    # Build initial file list
    declare -A known_files
    while IFS= read -r -d '' f; do
        is_video_file "$f" && known_files["$f"]=1
    done < <(find "$watch_dir" -maxdepth 3 -type f -print0 2>/dev/null)
    info "Tracking ${#known_files[@]} existing clips"

    # Cleanup on exit
    trap 'rm -f "$WATCH_PID_FILE"; info "Watch daemon stopped"; exit 0' INT TERM

    # Watch loop
    while true; do
        sleep "$WATCH_INTERVAL"

        while IFS= read -r -d '' f; do
            is_video_file "$f" || continue
            [[ -n "${known_files[$f]:-}" ]] && continue

            # New file found — wait for it to finish writing
            local prev_size=0
            local curr_size
            curr_size=$(stat -c%s "$f" 2>/dev/null) || continue

            while [[ "$curr_size" -ne "$prev_size" ]]; do
                prev_size=$curr_size
                sleep 2
                curr_size=$(stat -c%s "$f" 2>/dev/null) || break
            done

            known_files["$f"]=1
            echo ""
            echo -e "${GOLD}${BOLD}[NEW CLIP]${RESET} $(basename "$f")"
            log "New clip detected: $f"

            # Analyze it
            cmd_analyze "$f" 2>&1 | while IFS= read -r line; do
                echo "  $line"
            done

            # Desktop notification if notify-send is available
            if command -v notify-send &>/dev/null; then
                local data_file
                data_file=$(clip_data_file "$f")
                local hl_count=0
                [[ -f "$data_file" ]] && hl_count=$(jq '.highlight_count // 0' "$data_file" 2>/dev/null)
                notify-send -a "Forge Highlights" \
                    "Clip Analyzed" \
                    "$(basename "$f"): ${hl_count} highlights detected" \
                    --icon=video-x-generic 2>/dev/null || true
            fi
        done < <(find "$watch_dir" -maxdepth 3 -type f -print0 2>/dev/null)
    done
}

# ── LIST ───────────────────────────────────────────────────────────────────
cmd_list() {
    banner

    local data_files
    data_files=$(find "$DATA_DIR" -name '*.json' -type f 2>/dev/null | sort)

    if [[ -z "$data_files" ]]; then
        info "No analyzed clips found."
        info "Run: ${CYAN}forge-highlights analyze <clip>${RESET}"
        info "  or: ${CYAN}forge-highlights scan [dir]${RESET}"
        return
    fi

    local total_clips=0
    local total_highlights=0
    local total_events=0

    echo -e "${BOLD}${WHITE}Analyzed Clips${RESET}"
    echo -e "${DIM}─────────────────────────────────────────────────────────────────${RESET}"
    printf "  ${BOLD}%-35s %8s %6s %6s  %s${RESET}\n" "Clip" "Duration" "Events" "HL" "Top Score"
    echo -e "  ${DIM}─────────────────────────────────────────────────────────────${RESET}"

    while IFS= read -r data_file; do
        [[ -z "$data_file" ]] && continue

        local name dur events hl_count top_score analyzed_at clip_path
        name=$(jq -r '.name // "unknown"' "$data_file")
        dur=$(jq -r '.duration // 0' "$data_file")
        events=$(jq -r '.total_events // 0' "$data_file")
        hl_count=$(jq -r '.highlight_count // 0' "$data_file")
        top_score=$(jq -r '.highlights[0].score // "-"' "$data_file")
        analyzed_at=$(jq -r '.analyzed_at // "unknown"' "$data_file")
        clip_path=$(jq -r '.clip // ""' "$data_file")

        total_clips=$((total_clips + 1))
        total_highlights=$((total_highlights + hl_count))
        total_events=$((total_events + events))

        # Truncate name if too long
        local display_name="$name"
        [[ ${#display_name} -gt 33 ]] && display_name="${display_name:0:30}..."

        # Color based on highlights
        local color="$DIM"
        [[ "$hl_count" -gt 0 ]] && color="$WHITE"
        [[ "$hl_count" -ge 3 ]] && color="$YELLOW"
        [[ "$hl_count" -ge 5 ]] && color="$GOLD"

        local dur_str
        dur_str=$(format_time_hms "${dur%.*}")

        # File exists indicator
        local exists_mark="${GREEN}*${RESET}"
        [[ ! -f "$clip_path" ]] && exists_mark="${RED}x${RESET}"

        printf "  ${color}%-35s${RESET} %8s %6s ${color}%6s${RESET}  %s %s\n" \
            "$display_name" "$dur_str" "$events" "$hl_count" "$top_score" "$exists_mark"

    done <<< "$data_files"

    echo ""
    echo -e "  ${BOLD}${WHITE}Totals:${RESET} ${total_clips} clips, ${total_events} events, ${GOLD}${BOLD}${total_highlights}${RESET} highlights"
    echo -e "  ${DIM}Data dir: ${DATA_DIR}${RESET}"
    echo -e "  ${GREEN}*${RESET} source exists  ${RED}x${RESET} source missing"
    echo ""
}

# ── Usage ──────────────────────────────────────────────────────────────────
usage() {
    banner
    echo -e "${BOLD}Usage:${RESET} forge-highlights <command> [args]"
    echo ""
    echo -e "${BOLD}Commands:${RESET}"
    echo -e "  ${CYAN}analyze${RESET} <clip>            Analyze a video clip for exciting moments"
    echo -e "  ${CYAN}scan${RESET}    [dir]             Scan a directory of clips and mark highlights"
    echo -e "  ${CYAN}extract${RESET} <clip> [timestamp] Extract a highlight segment from a clip"
    echo -e "  ${CYAN}montage${RESET} [dir]             Create a highlight montage from best moments"
    echo -e "  ${CYAN}watch${RESET}                     Watch for new clips and auto-analyze (daemon)"
    echo -e "  ${CYAN}list${RESET}                      Show analyzed clips with highlight markers"
    echo ""
    echo -e "${BOLD}Detection:${RESET}"
    echo -e "  Audio peaks:    Gunshots, explosions, player reactions"
    echo -e "  Scene changes:  Fast movement, kills, visual effects"
    echo -e "  Clustering:     Groups of nearby events score higher"
    echo ""
    echo -e "${BOLD}Scoring:${RESET} Audio ${W_AUDIO}% + Scene ${W_SCENE}% + Cluster ${W_CLUSTER}% + Duration ${W_DURATION}%"
    echo -e "         Highlights require score >= ${HIGHLIGHT_SCORE_MIN}/100"
    echo ""
    echo -e "${BOLD}Config:${RESET}  ${DIM}${CONFIG_FILE}${RESET}"
    echo -e "${BOLD}Data:${RESET}    ${DIM}${DATA_DIR}/${RESET}"
    echo -e "${BOLD}Output:${RESET}  ${DIM}${MONTAGE_DIR}/${RESET}"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo -e "  forge-highlights analyze ~/Videos/gameplay.mp4"
    echo -e "  forge-highlights scan ~/Videos/24HG\\ Clips/"
    echo -e "  forge-highlights extract ~/Videos/gameplay.mp4 42.5"
    echo -e "  forge-highlights montage"
    echo -e "  forge-highlights watch &"
    echo ""
}

# ════════════════════════════════════════════════════════════════════════════
# ── Main ───────────────────────────────────────────────────────────────────
# ════════════════════════════════════════════════════════════════════════════
main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    # Help doesn't need deps
    case "$cmd" in
        help|-h|--help) usage; return ;;
    esac

    check_deps
    load_config
    save_default_config
    ensure_dirs

    case "$cmd" in
        analyze)    cmd_analyze "$@" ;;
        scan)       cmd_scan "$@" ;;
        extract)    cmd_extract "$@" ;;
        montage)    cmd_montage "$@" ;;
        watch)      cmd_watch "$@" ;;
        list)       cmd_list "$@" ;;
        *)
            error "Unknown command: $cmd"
            usage
            exit 1
            ;;
    esac
}

main "$@"
