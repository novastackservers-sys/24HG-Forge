#!/bin/bash
# HubOS Diagnostics — Collect system info for support tickets
# Usage: hubos-diag [--paste]
#   --paste: Upload to termbin.com and return URL (redacts sensitive info)

set -euo pipefail

PASTE=false
if [ "${1:-}" = "--paste" ]; then
    PASTE=true
fi

redact_ip() {
    # Redact public IPs but keep private ranges visible (192.168.x, 10.x, 172.16-31.x)
    # First mark private IPs with a safe prefix, then redact all remaining IPs, then restore private ones
    sed -E \
        -e 's/(192\.168\.[0-9]{1,3}\.[0-9]{1,3})/__PRIV_\1__/g' \
        -e 's/(10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})/__PRIV_\1__/g' \
        -e 's/(172\.(1[6-9]|2[0-9]|3[01])\.[0-9]{1,3}\.[0-9]{1,3})/__PRIV_\1__/g' \
        -e 's/([0-9]{1,3}\.){3}[0-9]{1,3}/[REDACTED]/g' \
        -e 's/__PRIV_([^_]+)__/\1/g'
}

collect() {
    echo "============================================"
    echo "  HubOS Diagnostics Report"
    echo "  Generated: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
    echo "============================================"
    echo ""

    echo "── OS ──"
    cat /etc/os-release 2>/dev/null || echo "N/A"
    echo ""
    echo "Kernel: $(uname -r)"
    echo "Arch: $(uname -m)"
    echo ""

    echo "── Hardware ──"
    echo "CPU: $(grep 'model name' /proc/cpuinfo 2>/dev/null | head -1 | cut -d: -f2 | sed 's/^ //')"
    echo "Cores: $(nproc)"
    echo "Memory: $(free -h | awk '/^Mem:/ {print $2}')"
    echo ""

    echo "── GPU ──"
    lspci -nn 2>/dev/null | grep -iE "VGA|3D|Display" || echo "N/A"
    echo ""

    echo "GPU Driver:"
    if command -v nvidia-smi &>/dev/null; then
        nvidia-smi --query-gpu=driver_version,name,memory.total --format=csv,noheader 2>/dev/null || echo "NVIDIA driver present but query failed"
    elif [ -d /sys/class/drm/card0 ]; then
        cat /sys/class/drm/card0/device/vendor 2>/dev/null && echo "(AMD/Intel - Mesa)"
        glxinfo 2>/dev/null | grep "OpenGL renderer" || true
    fi
    echo ""

    echo "── Vulkan ──"
    if command -v vulkaninfo &>/dev/null; then
        vulkaninfo --summary 2>/dev/null | head -20 || echo "vulkaninfo failed"
    else
        echo "vulkaninfo not found"
    fi
    echo ""

    echo "── Display ──"
    echo "Session: ${XDG_SESSION_TYPE:-unknown}"
    echo "Desktop: ${XDG_CURRENT_DESKTOP:-unknown}"
    echo "Gamescope: ${GAMESCOPE_WAYLAND_DISPLAY:-not running}"
    # Wayland-first display info
    if command -v wlr-randr &>/dev/null; then
        wlr-randr 2>/dev/null | head -10 || true
    elif [ -n "${WAYLAND_DISPLAY:-}" ]; then
        echo "Wayland session active"
    fi
    xdpyinfo 2>/dev/null | grep -E "dimensions|depth" | head -2 || echo "No X display"
    echo ""

    echo "── Storage ──"
    df -h / /home 2>/dev/null || df -h /
    echo ""
    echo "I/O Scheduler:"
    for dev in /sys/block/*/queue/scheduler; do
        [ -f "$dev" ] && echo "  $(basename $(dirname $(dirname $dev))): $(cat $dev)"
    done
    echo ""

    echo "── rpm-ostree Status ──"
    rpm-ostree status 2>/dev/null | head -30 || echo "Not an ostree system"
    echo ""

    echo "── Flatpak ──"
    flatpak list --app 2>/dev/null || echo "No flatpaks"
    echo ""

    echo "── Steam ──"
    STEAM_DIR="${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam"
    if [ -d "$STEAM_DIR" ]; then
        echo "Installed: Yes (Flatpak)"
        echo "Proton versions:"
        ls "$STEAM_DIR/compatibilitytools.d/" 2>/dev/null || echo "  None (using bundled)"
    else
        echo "Not installed yet"
    fi
    echo ""

    echo "── Network ──"
    echo "Interfaces:"
    ip -brief addr 2>/dev/null || ifconfig 2>/dev/null | grep -E "^[a-z]|inet "
    echo ""
    echo "DNS:"
    resolvectl status 2>/dev/null | head -5 || cat /etc/resolv.conf 2>/dev/null | grep nameserver
    echo ""

    echo "── Ping Tests ──"
    for host in hub.24hgaming.com 91.99.37.118 8.8.8.8; do
        PING=$(ping -c 3 -W 2 "$host" 2>/dev/null | tail -1 | awk -F'/' '{print $5}')
        echo "  $host: ${PING:-timeout}ms"
    done
    echo ""

    echo "── Gaming Tweaks ──"
    echo "THP: $(cat /sys/kernel/mm/transparent_hugepage/enabled 2>/dev/null || echo 'N/A')"
    echo "Swappiness: $(cat /proc/sys/vm/swappiness 2>/dev/null)"
    echo "max_map_count: $(cat /proc/sys/vm/max_map_count 2>/dev/null)"
    echo "TCP Congestion: $(cat /proc/sys/net/ipv4/tcp_congestion_control 2>/dev/null)"
    echo "CPU Governor: $(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo 'N/A')"
    echo "GameMode: $(gamemoded -s 2>/dev/null || echo 'not running')"
    echo "MangoHud: ${MANGOHUD:-not set}"
    echo ""

    echo "── HubOS Services ──"
    for svc in hubos-gaming-tweaks hubos-first-boot-setup hubos-auto-update.timer; do
        STATUS=$(systemctl is-active "$svc" 2>/dev/null || echo "missing")
        echo "  $svc: $STATUS"
    done
    echo ""

    echo "── Journal (last 20 HubOS entries) ──"
    journalctl -t hubos-update -t hubos -n 20 --no-pager 2>/dev/null || echo "No entries"
    echo ""

    echo "── Errors (last 10 critical/error) ──"
    journalctl -p err -n 10 --no-pager 2>/dev/null || echo "No errors"
    echo ""

    echo "============================================"
    echo "  End of HubOS Diagnostics"
    echo "============================================"
}

if [ "$PASTE" = true ]; then
    echo ""
    echo "WARNING: This will upload system diagnostics to a public paste service."
    echo "Public IP addresses will be redacted, but hardware info will be visible."
    echo ""
    read -p "Continue? [y/N] " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Cancelled."
        exit 0
    fi

    URL=$(collect | redact_ip | nc termbin.com 9999 2>/dev/null)
    if [ -n "$URL" ]; then
        echo ""
        echo "Diagnostics uploaded: $URL"
        echo "Share this URL in #support on Discord"
    else
        echo "Upload failed. Run without --paste and copy the output manually."
        collect
    fi
else
    collect
fi
