#!/usr/bin/env bash
# 24HG Forge Update Prompt — Shows GUI dialog when update is staged
# Runs at login via autostart desktop entry

set -euo pipefail

LOG_TAG="forge-update-prompt"
MARKER_FILE="/tmp/.forge-update-staged"
SKIP_FILE="${HOME}/.cache/forge/update-skip-$(date +%Y%m%d)"

log() {
    logger -t "$LOG_TAG" "$1"
}

# Wait for desktop to be fully loaded
sleep 5

# Skip if user already dismissed today
if [[ -f "$SKIP_FILE" ]]; then
    log "User already skipped update today"
    exit 0
fi

# Check if an update is actually staged (pending deployment)
check_update_available() {
    if ! command -v rpm-ostree &>/dev/null; then
        return 1
    fi

    # Check for pending deployment
    local status
    status=$(rpm-ostree status --json 2>/dev/null) || return 1

    local has_pending
    has_pending=$(echo "$status" | python3 -c "
import sys, json
data = json.load(sys.stdin)
deploys = data.get('deployments', [])
booted_idx = -1
for i, d in enumerate(deploys):
    if d.get('booted', False):
        booted_idx = i
        break
# If there's a deployment before the booted one, an update is staged
if booted_idx > 0:
    print('yes')
else:
    print('no')
" 2>/dev/null) || return 1

    [[ "$has_pending" == "yes" ]]
}

# Also check if there's an available update not yet staged
check_update_remote() {
    if ! command -v rpm-ostree &>/dev/null; then
        return 1
    fi

    local check_output
    check_output=$(rpm-ostree upgrade --check 2>&1) || true

    if echo "$check_output" | grep -q "No updates available"; then
        return 1
    fi

    # There is an available update
    return 0
}

# Get version info for the dialog
get_update_info() {
    rpm-ostree status --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
deploys = data.get('deployments', [])
booted_idx = -1
for i, d in enumerate(deploys):
    if d.get('booted', False):
        booted_idx = i
        break

current = deploys[booted_idx] if booted_idx >= 0 else {}
current_ver = current.get('version', current.get('checksum', 'unknown')[:12])

if booted_idx > 0:
    pending = deploys[booted_idx - 1]
    pending_ver = pending.get('version', pending.get('checksum', 'unknown')[:12])
    print(f'Current: {current_ver}')
    print(f'New:     {pending_ver}')
else:
    print(f'Current: {current_ver}')
    print(f'New:     Available')
" 2>/dev/null || echo "Update available"
}

# ── Main logic ──

# First check if update is already staged (downloaded and ready)
if check_update_available; then
    log "Staged update detected, showing prompt"

    UPDATE_INFO=$(get_update_info)

    # Show the dialog
    if command -v kdialog &>/dev/null; then
        RESULT=$(kdialog \
            --icon forge-logo \
            --title "24HG Forge Update" \
            --yesnocancel "A system update is ready to install!\n\n${UPDATE_INFO}\n\nReboot now to apply the update?" \
            --yes-label "Reboot Now" \
            --no-label "Later Today" \
            --cancel-label "Skip Until Tomorrow" \
            2>/dev/null) || RESULT=$?

        case "$RESULT" in
            0)  # Yes - Reboot
                log "User chose to reboot for update"
                systemctl reboot
                ;;
            1)  # No - Later
                log "User chose to update later today"
                ;;
            2|*)  # Cancel - Skip today
                log "User chose to skip update today"
                mkdir -p "${HOME}/.cache/forge"
                touch "$SKIP_FILE"
                ;;
        esac
    elif command -v zenity &>/dev/null; then
        CHOICE=$(zenity --question \
            --title="24HG Forge Update" \
            --text="A system update is ready to install!\n\n${UPDATE_INFO}\n\nReboot now to apply the update?" \
            --ok-label="Reboot Now" \
            --cancel-label="Later" \
            --extra-button="Skip Today" \
            --width=400 \
            --window-icon=forge-logo \
            2>/dev/null) && ZENITY_RC=$? || ZENITY_RC=$?

        if [[ $ZENITY_RC -eq 0 ]]; then
            log "User chose to reboot for update"
            systemctl reboot
        elif [[ "$CHOICE" == "Skip Today" ]]; then
            log "User chose to skip update today"
            mkdir -p "${HOME}/.cache/forge"
            touch "$SKIP_FILE"
        else
            log "User chose to update later today"
        fi
    else
        # Fallback: desktop notification with action
        notify-send \
            --app-name="24HG Forge" \
            --icon=forge-logo \
            --urgency=normal \
            "System Update Ready" \
            "A 24HG Forge update is ready. Run 'systemctl reboot' to apply." \
            2>/dev/null || true
    fi

    exit 0
fi

# No staged update — check if there's one available remotely
if check_update_remote; then
    log "Remote update available, staging it in background"

    # Stage the update silently
    rpm-ostree upgrade &>/dev/null &
    UPDATE_PID=$!

    # Notify user that an update is downloading
    notify-send \
        --app-name="24HG Forge" \
        --icon=forge-logo \
        "Downloading Update" \
        "A 24HG Forge update is being downloaded. You'll be prompted to reboot when it's ready." \
        2>/dev/null || true

    # Wait for it to finish, then prompt
    if wait $UPDATE_PID 2>/dev/null; then
        log "Update staged successfully, showing prompt"

        UPDATE_INFO=$(get_update_info)

        if command -v kdialog &>/dev/null; then
            RESULT=$(kdialog \
                --icon forge-logo \
                --title "24HG Forge Update" \
                --yesno "A system update has been downloaded!\n\n${UPDATE_INFO}\n\nReboot now to apply?" \
                --yes-label "Reboot Now" \
                --no-label "Later" \
                2>/dev/null) || RESULT=$?

            if [[ "$RESULT" -eq 0 ]]; then
                log "User chose to reboot for update"
                systemctl reboot
            else
                log "User chose to update later"
            fi
        elif command -v zenity &>/dev/null; then
            zenity --question \
                --title="24HG Forge Update" \
                --text="A system update has been downloaded!\n\n${UPDATE_INFO}\n\nReboot now to apply?" \
                --ok-label="Reboot Now" \
                --cancel-label="Later" \
                --width=400 \
                --window-icon=forge-logo \
                2>/dev/null && systemctl reboot || log "User chose to update later"
        else
            notify-send \
                --app-name="24HG Forge" \
                --icon=forge-logo \
                --urgency=normal \
                "Update Ready" \
                "A 24HG Forge update is ready. Reboot to apply." \
                2>/dev/null || true
        fi
    else
        log "Update staging failed"
    fi
else
    log "System is up to date"
fi
