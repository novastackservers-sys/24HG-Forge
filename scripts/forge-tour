#!/usr/bin/env python3
"""
24HG Forge Desktop Tour — Post-first-boot onboarding overlay.

Shows an 8-step guided tour of key Forge features using zenity dialogs.
Designed to be Wayland-safe (centered dialogs only, no xdotool/wmctrl).

Usage:
    forge-tour              Run the tour (skips if already completed)
    forge-tour --force      Run even if previously completed
    forge-tour --reset      Clear completion marker and exit
    forge-tour --step N     Jump to step N (1-8)
"""

import subprocess
import os
import sys
import json
import logging
import argparse
import textwrap
from pathlib import Path

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

APP_NAME = "24HG Forge Tour"
CONFIG_DIR = Path.home() / ".config" / "forge"
MARKER = CONFIG_DIR / "tour-done"
LOG_FILE = CONFIG_DIR / "tour.log"
HUB_URL = "https://hub.24hgaming.com"
DISCORD_URL = "discord.gg/ymfEjH6EJN"

TOTAL_STEPS = 8
WINDOW_WIDTH = 520
WINDOW_HEIGHT = 320
ICON_NAME = "forge-logo"


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def setup_logging():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    logging.basicConfig(
        filename=str(LOG_FILE),
        level=logging.INFO,
        format="%(asctime)s [%(levelname)s] %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )


# ---------------------------------------------------------------------------
# Display helpers
# ---------------------------------------------------------------------------

def has_display():
    """Return True if a graphical session is available."""
    return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))


def has_zenity():
    """Return True if zenity is installed."""
    try:
        subprocess.run(
            ["zenity", "--version"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return True
    except FileNotFoundError:
        return False


def zenity_info(title: str, text: str, ok_label: str = "OK",
                extra_buttons: list | None = None,
                width: int = WINDOW_WIDTH, height: int = WINDOW_HEIGHT) -> str:
    """
    Show a zenity --info dialog and return which button was pressed.

    Returns:
        "ok"    — the OK/Next button
        "extra:Label" — an --extra-button that was clicked
        "cancel" — dialog was closed / cancelled
    """
    cmd = [
        "zenity", "--info",
        "--title", title,
        "--text", text,
        "--ok-label", ok_label,
        "--width", str(width),
        "--height", str(height),
        "--icon-name", ICON_NAME,
        "--no-wrap",
    ]
    for btn in (extra_buttons or []):
        cmd += ["--extra-button", btn]

    result = subprocess.run(cmd, capture_output=True, text=True)
    stdout = result.stdout.strip()

    # zenity returns 0 for OK, 1 for Cancel, 5 for timeout
    # extra-button clicks return 1 but print the label to stdout
    if result.returncode == 0:
        return "ok"
    if stdout:
        return f"extra:{stdout}"
    return "cancel"


def zenity_question(title: str, text: str,
                    ok_label: str = "Yes", cancel_label: str = "No",
                    extra_buttons: list | None = None,
                    width: int = WINDOW_WIDTH, height: int = WINDOW_HEIGHT) -> str:
    """Show a zenity --question dialog. Returns 'ok', 'cancel', or 'extra:Label'."""
    cmd = [
        "zenity", "--question",
        "--title", title,
        "--text", text,
        "--ok-label", ok_label,
        "--cancel-label", cancel_label,
        "--width", str(width),
        "--height", str(height),
        "--icon-name", ICON_NAME,
        "--no-wrap",
    ]
    for btn in (extra_buttons or []):
        cmd += ["--extra-button", btn]

    result = subprocess.run(cmd, capture_output=True, text=True)
    stdout = result.stdout.strip()

    if result.returncode == 0:
        return "ok"
    if stdout:
        return f"extra:{stdout}"
    return "cancel"


# ---------------------------------------------------------------------------
# Fallback: terminal-based tour
# ---------------------------------------------------------------------------

def terminal_step(step_num: int, title: str, body: str) -> str:
    """Render a tour step in the terminal. Returns 'next', 'skip', or 'close'."""
    hr = "=" * 60
    progress = f"  Step {step_num} of {TOTAL_STEPS}"
    print(f"\n{hr}")
    print(f"  {APP_NAME}{progress}")
    print(f"{hr}")
    print(f"\n  {title}\n")
    for line in body.strip().splitlines():
        print(f"    {line}")
    print()
    while True:
        choice = input("  [N]ext  [S]kip all  [Q]uit > ").strip().lower()
        if choice in ("n", "next", ""):
            return "next"
        if choice in ("s", "skip"):
            return "skip"
        if choice in ("q", "quit", "c", "close"):
            return "close"


