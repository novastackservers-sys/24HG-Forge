# ---------------------------------------------------------------------------
# Tour runner
# ---------------------------------------------------------------------------

def mark_complete():
    """Write the completion marker file."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    MARKER.write_text(json.dumps({
        "completed": True,
        "timestamp": __import__("datetime").datetime.now().isoformat(),
        "version": 1,
    }))
    logging.info("Tour marked as complete.")


def is_complete() -> bool:
    """Check if the tour has already been completed."""
    return MARKER.exists()


def run_tour_gui(start_step: int = 1):
    """Run the full graphical tour using zenity dialogs."""
    logging.info("Starting GUI tour from step %d", start_step)

    step_idx = start_step - 1  # 0-based

    while 0 <= step_idx < TOTAL_STEPS:
        step = STEPS[step_idx]
        step_num = step_idx + 1
        is_last = (step_num == TOTAL_STEPS)

        # Build title with progress
        title = f"{APP_NAME} \u2014 Step {step_num} of {TOTAL_STEPS}"

        # Build body with step title header
        header = f'<span size="x-large"><b>{step["title"]}</b></span>\n\n'
        body = header + step["body"]

        if is_last:
            # Final step: special buttons
            result = zenity_question(
                title=title,
                text=body,
                ok_label="Open Hub",
                cancel_label="Don't show again",
                extra_buttons=["Finish"],
            )
            if result == "ok":
                # Open Hub
                logging.info("User chose to open Hub")
                try:
                    subprocess.Popen(
                        ["xdg-open", HUB_URL],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                    )
                except Exception as e:
                    logging.warning("Failed to open Hub URL: %s", e)
                mark_complete()
                break
            elif result == "extra:Finish":
                logging.info("User finished tour")
                mark_complete()
                break
            else:
                # "Don't show again" or window closed
                logging.info("User chose don't show again")
                mark_complete()
                break
        else:
            # Regular step: Next / Skip / Back
            extra = []
            if step_idx > 0:
                extra.append("Back")
            extra.append("Skip Tour")

            result = zenity_info(
                title=title,
                text=body,
                ok_label=f"Next ({step_num}/{TOTAL_STEPS})",
                extra_buttons=extra,
            )

            if result == "ok":
                logging.info("Step %d: next", step_num)
                step_idx += 1
            elif result == "extra:Back":
                logging.info("Step %d: back", step_num)
                step_idx -= 1
            elif result == "extra:Skip Tour":
                logging.info("Step %d: skip tour", step_num)
                mark_complete()
                break
            else:
                # Window closed
                logging.info("Step %d: closed", step_num)
                break

    logging.info("Tour ended at step %d", step_idx + 1)


def run_tour_terminal(start_step: int = 1):
    """Run the tour in a terminal fallback mode."""
    logging.info("Starting terminal tour from step %d", start_step)

    step_idx = start_step - 1

    while 0 <= step_idx < TOTAL_STEPS:
        step = STEPS[step_idx]
        step_num = step_idx + 1

        action = terminal_step(step_num, step["title"], step["body_plain"])

        if action == "next":
            step_idx += 1
        elif action == "skip":
            mark_complete()
            print("\n  Tour skipped. Run `forge-tour --force` to see it again.\n")
            break
        elif action == "close":
            print("\n  Tour closed.\n")
            break

    if step_idx >= TOTAL_STEPS:
        mark_complete()
        print(f"\n  Tour complete! Join us: {DISCORD_URL}\n")

    logging.info("Terminal tour ended at step %d", step_idx + 1)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def parse_args():
    parser = argparse.ArgumentParser(
        prog="forge-tour",
        description="24HG Forge Desktop Tour — guided onboarding walkthrough",
    )
    parser.add_argument(
        "--force", action="store_true",
        help="Run the tour even if previously completed",
    )
    parser.add_argument(
        "--reset", action="store_true",
        help="Clear the completion marker and exit",
    )
    parser.add_argument(
        "--step", type=int, default=1, choices=range(1, TOTAL_STEPS + 1),
        metavar="N",
        help=f"Start at step N (1-{TOTAL_STEPS})",
    )
    parser.add_argument(
        "--terminal", action="store_true",
        help="Force terminal mode (no GUI)",
    )
    return parser.parse_args()


def main():
    setup_logging()
    args = parse_args()

    # --reset: remove marker and exit
    if args.reset:
        if MARKER.exists():
            MARKER.unlink()
            print("Tour completion marker removed.")
            logging.info("Tour marker reset.")
        else:
            print("No completion marker found.")
        return 0

    # Check if already done
    if is_complete() and not args.force:
        logging.info("Tour already completed. Use --force to re-run.")
        return 0

    # Validate step
    if args.step < 1 or args.step > TOTAL_STEPS:
        print(f"Error: --step must be between 1 and {TOTAL_STEPS}")
        return 1

    # Choose GUI or terminal mode
    use_gui = (not args.terminal) and has_display() and has_zenity()

    if use_gui:
        logging.info("Using GUI mode (zenity)")
        run_tour_gui(start_step=args.step)
    else:
        if not args.terminal and not has_display():
            logging.info("No display detected, falling back to terminal")
        elif not args.terminal and not has_zenity():
            logging.info("zenity not found, falling back to terminal")
        run_tour_terminal(start_step=args.step)

    return 0


if __name__ == "__main__":
    sys.exit(main())
