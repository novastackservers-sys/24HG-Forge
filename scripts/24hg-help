# ── Main Overview ──

show_overview() {
  banner
  echo ""
  echo -e "  ${DIM}Type${RESET} ${GREEN}24hg-help <topic>${RESET} ${DIM}for detailed info on any topic below.${RESET}"

  header "Command Categories"

  section "Getting Started"
  cmd "24hg-first-boot"       "Setup wizard"
  cmd "24hg-tour"             "Interactive feature tour"
  cmd "24hg-tips"             "Random gaming tips"
  echo ""

  section "Gaming"
  cmd "24hg-games"            "Browse and launch games"
  cmd "24hg-launch <game>"    "Launch with optimal settings"
  cmd "24hg-mods"             "Mod browser and installer"
  cmd "24hg-compat <game>"    "Check game compatibility"
  echo ""

  section "Performance"
  cmd "24hg-overlay"          "FPS overlay (F12)"
  cmd "24hg-performance"      "Auto-tune system"
  cmd "24hg-benchmark"        "Run benchmarks"
  cmd "24hg-focus"            "Gaming focus mode"
  echo ""

  section "Recording & Streaming"
  cmd "24hg-clip"             "Save last 30s of gameplay"
  cmd "24hg-record"           "Start/stop recording"
  cmd "24hg-go-live"          "One-click streaming"
  cmd "24hg-screenshot"       "Take a screenshot"
  echo ""

  section "Multiplayer & Social"
  cmd "24hg-server-status"    "24HG server status"
  cmd "24hg-voice"            "Voice chat"
  cmd "24hg-invite"           "Invite friends"
  cmd "24hg-tournament"       "Join tournaments"
  echo ""

  section "Customization"
  cmd "24hg-themes"           "Desktop themes"
  cmd "24hg-controller"       "Controller setup"
  cmd "24hg-overlay"          "Customize HUD overlay"
  echo ""

  section "Smart OS"
  cmd "24hg-game-ready"        "Auto-optimize games on install"
  cmd "24hg-smart-updates"     "Gaming-aware updates"
  cmd "24hg-quick-resume"      "Save/restore sessions"
  cmd "24hg-lan-mode"          "LAN party mode"
  echo ""

  section "Hardware Control"
  cmd "24hg-peripherals"       "Mouse DPI, RGB, macros"
  cmd "24hg-audio-router"      "Per-app audio routing"
  cmd "24hg-dual-gpu"          "GPU switching"
  cmd "24hg-cleaner"           "System cleanup"
  echo ""

  section "Troubleshooting"
  cmd "24hg-diag"             "System diagnostics"
  cmd "24hg-crash-fix"        "Auto-fix crashes"
  cmd "24hg-rescue"           "Emergency rescue mode"
  echo ""

  echo -e "  ${DIM}──────────────────────────────────────────────────${RESET}"
  echo -e "  ${DIM}Topics:${RESET} getting-started gaming connect economy"
  echo -e "  ${DIM}        ${RESET} performance streaming recording"
  echo -e "  ${DIM}        ${RESET} customization hardware smart"
  echo -e "  ${DIM}        ${RESET} social troubleshooting"
  echo ""
  echo -e "  ${BLUE}24hgaming.com${RESET}  |  ${BLUE}discord.gg/ymfEjH6EJN${RESET}"
  echo ""
}

# ── Dispatch ──

case "${TOPIC}" in
  "")                show_overview ;;
  getting-started)   topic_getting_started ;;
  gaming)            topic_gaming ;;
  connect)           topic_connect ;;
  economy)           topic_economy ;;
  performance)       topic_performance ;;
  streaming)         topic_streaming ;;
  recording)         topic_recording ;;
  customization)     topic_customization ;;
  hardware)        topic_hardware ;;
  smart)           topic_smart ;;
  social)            topic_social ;;
  troubleshooting)   topic_troubleshooting ;;
  *)
    echo -e "${YELLOW}Unknown topic:${RESET} ${TOPIC}"
    echo ""
    echo -e "Available topics: getting-started gaming connect economy"
    echo -e "                  performance streaming recording"
    echo -e "                  customization hardware smart"
    echo -e "                  social troubleshooting"
    echo ""
    echo -e "Run ${GREEN}24hg-help${RESET} with no arguments for a full overview."
    exit 1
    ;;
esac
