#!/usr/bin/env bash
# 24HG Help — Quick reference for all 24HG commands and features.
#
# Usage: 24hg-help [topic]
#   (no args)        Show categorized command overview
#   getting-started  First steps after install
#   gaming           Game launching, compatibility, mods
#   connect          Multiplayer, servers, voice chat
#   economy          Shop, VIP perks, rewards
#   performance      FPS tuning, benchmarks, thermals
#   streaming        Go live on Twitch/YouTube
#   recording        Clips, replays, screenshots
#   customization    Themes, wallpapers, overlays
#   hardware         Peripherals, display, audio, maintenance
#   smart            Game automation, system intelligence, networking
#   social           Community, feed, invites
#   troubleshooting  Fixes for common issues

set -euo pipefail

# ── Colors ──

BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
MAGENTA='\033[35m'
BLUE='\033[34m'
WHITE='\033[97m'
RESET='\033[0m'

TOPIC="${1:-}"

# ── Helpers ──

header() {
  echo ""
  echo -e "${BOLD}${CYAN}═══ $1 ═══${RESET}"
  echo ""
}

cmd() {
  printf "  ${GREEN}%-28s${RESET} %s\n" "$1" "$2"
}

tip() {
  echo -e "  ${YELLOW}TIP:${RESET} $1"
}

section() {
  echo -e "  ${BOLD}${WHITE}$1${RESET}"
}

banner() {
  echo ""
  echo -e "${BOLD}${MAGENTA}  ╔═══════════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${MAGENTA}  ║${RESET}  ${BOLD}24HG${RESET} — Gaming Linux by 24 Hour Gaming   ${BOLD}${MAGENTA}║${RESET}"
  echo -e "${BOLD}${MAGENTA}  ╚═══════════════════════════════════════════════════╝${RESET}"
}

# ── Topic: Getting Started ──

topic_getting_started() {
  header "Getting Started"
  echo -e "  Welcome to 24HG! Here's how to get going fast."
  echo ""
  section "First Steps"
  cmd "24hg-first-boot"       "Run the setup wizard (auto-runs on first login)"
  cmd "24hg-tour"             "Interactive tour of 24HG features"
  cmd "24hg-settings"         "Open 24HG settings panel"
  cmd "24hg-tips"             "Show a random gaming tip"
  cmd "24hg-neofetch"         "System info with 24HG branding"
  echo ""
  section "Installing Games"
  cmd "steam"                  "Launch Steam (pre-installed)"
  cmd "lutris"                 "Launch Lutris for non-Steam games"
  cmd "24hg-games"            "Browse and launch installed games"
  cmd "24hg-game-setup"       "Guided setup for a specific game"
  echo ""
  tip "Run ${GREEN}24hg-rig-score${RESET} to see how your hardware stacks up."
}

# ── Topic: Gaming ──

topic_gaming() {
  header "Gaming"
  section "Launch & Manage"
  cmd "24hg-games"            "Browse and launch your games"
  cmd "24hg-launch <game>"    "Launch a game with optimized settings"
  cmd "24hg-smart-launch"     "Auto-detect best settings for a game"
  cmd "24hg-game-profiles"    "Per-game performance profiles"
  echo ""
  section "Compatibility"
  cmd "24hg-compat <game>"    "Check Proton/Wine compatibility"
  cmd "24hg-game-compat"      "Scan all games for issues"
  cmd "24hg-proton-pick"      "Choose best Proton version for a game"
  cmd "24hg-proton-fix"       "Fix common Proton issues"
  cmd "24hg-prefix <game>"    "Manage Wine prefixes"
  cmd "24hg-windows-import"   "Import games from a Windows install"
  echo ""
  section "Mods & Saves"
  cmd "24hg-mods"             "Browse and install mods"
  cmd "24hg-mod-manager"      "Manage installed mods"
  cmd "24hg-save-manager"     "Backup/restore game saves"
  cmd "24hg-cloud-saves"      "Sync saves across devices"
  cmd "24hg-game-backup"      "Full game backup/restore"
  echo ""
  section "Retro & VR"
  cmd "24hg-retro"            "Retro game emulation setup"
  cmd "24hg-vr"               "VR headset setup and launch"
  echo ""
  tip "Use ${GREEN}24hg-shader-cache${RESET} to pre-compile shaders and avoid stuttering."
}

