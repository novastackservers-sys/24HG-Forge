SCENEEOF

    echo "Generated OBS scene collection: $SCENE_FILE"

    # Import into OBS
    mkdir -p "$OBS_SCENE_DIR" 2>/dev/null || true
    local DEST="$OBS_SCENE_DIR/24HG Scenes.json"
    if [ -d "$OBS_SCENE_DIR" ]; then
        cp "$SCENE_FILE" "$DEST"
        echo "Imported to: $DEST"
        echo ""
        echo "In OBS: Scene Collection → Import → select '24HG Scenes'"
    else
        echo ""
        echo "OBS scenes directory not found. Copy manually:"
        echo "  cp '$SCENE_FILE' ~/.config/obs-studio/basic/scenes/"
    fi

    echo ""
    echo "Scenes created:"
    echo "  1. Gaming     — Game capture + webcam (bottom-right) + chat overlay (left)"
    echo "  2. Just Chatting — Webcam centered + background"
    echo "  3. BRB        — Static image + 'Be Right Back!' text"
    echo ""
    echo "NOTE: Edit 'Chat Overlay' URL and 'BRB Image' path in OBS to customize."
}

# ─── Help ────────────────────────────────────────────────────────────

cmd_help() {
    cat <<'HELPEOF'
24HG Stream — One-command streaming setup

USAGE:
    24hg-stream <command> [options]

COMMANDS:
    setup                Interactive setup wizard (platform, key, quality, encoder, audio)
    start [platform]     Start streaming (twitch|youtube|kick|custom)
                         Uses OBS if installed, FFmpeg otherwise
    stop                 Stop the active stream gracefully
    status               Show stream status, uptime, bitrate, dropped frames
    config [key value]   Show config, or set a specific key
    obs-scenes           Generate and import OBS scene collection
                         (Gaming, Just Chatting, BRB scenes)
    help                 Show this help

CONFIG KEYS:
    platform             twitch, youtube, kick, custom
    key                  Stream key (stored securely, chmod 600)
    quality              1080p60, 720p60, 720p30, 480p30
    encoder              nvenc, vaapi, x264, auto
    audio-input          PulseAudio/PipeWire source name
    audio-output         PulseAudio/PipeWire sink monitor
    rtmp-url             Custom RTMP ingest URL

QUALITY PRESETS:
    1080p60              1920x1080 @ 60fps — 6000 kbps
    720p60               1280x720  @ 60fps — 4500 kbps
    720p30               1280x720  @ 30fps — 2500 kbps
    480p30               854x480   @ 30fps — 1500 kbps

ENCODERS:
    nvenc                NVIDIA GPU (lowest CPU usage, best quality)
    vaapi                AMD / Intel GPU (low CPU usage)
    x264                 CPU software encoding (universal fallback)
    auto                 Auto-detect best available encoder

EXAMPLES:
    24hg-stream setup                   # First-time interactive setup
    24hg-stream start                   # Start streaming to configured platform
    24hg-stream start twitch            # Start streaming to Twitch
    24hg-stream stop                    # End the stream
    24hg-stream status                  # Check if you're live
    24hg-stream config quality 720p60   # Switch to 720p60
    24hg-stream obs-scenes              # Generate OBS scenes

DEPENDENCIES:
    Required:  ffmpeg
    Optional:  obs-studio (Flatpak), wf-recorder (Wayland), zenity (setup wizard)
    Audio:     pipewire, pactl
    Encoders:  nvidia-smi (NVENC), vainfo (VAAPI)
HELPEOF
}

# ─── Main ────────────────────────────────────────────────────────────

load_config

case "${1:-help}" in
    setup)      cmd_setup ;;
    start)      cmd_start "${2:-}" ;;
    stop)       cmd_stop ;;
    status)     cmd_status ;;
    config)     cmd_config "${2:-}" "${3:-}" ;;
    obs-scenes) cmd_obs_scenes ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $1"
        echo "Run '24hg-stream help' for usage."
        exit 1
        ;;
esac
