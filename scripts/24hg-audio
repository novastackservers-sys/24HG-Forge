#!/bin/bash
# 24HG Audio Optimizer
# Configures PipeWire for low-latency gaming audio,
# noise cancellation, and easy device switching.
#
# Usage: 24hg-audio [gaming|desktop|devices|switch <name>|noise-cancel|status]

set -euo pipefail

ACTION="${1:-status}"

get_default_sink() {
    pactl get-default-sink 2>/dev/null || wpctl status 2>/dev/null | grep -A1 "Audio/Sink" | tail -1 | xargs
}

get_default_source() {
    pactl get-default-source 2>/dev/null || echo "unknown"
}

list_sinks() {
    pactl list sinks short 2>/dev/null | while read -r idx name driver format state; do
        # Get human-readable description
        DESC=$(pactl list sinks 2>/dev/null | grep -A1 "Name: $name" | grep "Description:" | sed 's/.*Description: //')
        DEFAULT=""
        [ "$name" = "$(get_default_sink)" ] && DEFAULT=" [DEFAULT]"
        echo "  [$idx] $DESC${DEFAULT}"
        echo "        $name"
    done
}

list_sources() {
    pactl list sources short 2>/dev/null | grep -v ".monitor" | while read -r idx name driver format state; do
        DESC=$(pactl list sources 2>/dev/null | grep -A1 "Name: $name" | grep "Description:" | sed 's/.*Description: //')
        DEFAULT=""
        [ "$name" = "$(get_default_source)" ] && DEFAULT=" [DEFAULT]"
        echo "  [$idx] $DESC${DEFAULT}"
        echo "        $name"
    done
}

switch_output() {
    local SEARCH="${1,,}"  # lowercase
    local FOUND=""

    while read -r idx name _rest; do
        DESC=$(pactl list sinks 2>/dev/null | grep -A1 "Name: $name" | grep "Description:" | sed 's/.*Description: //')
        if echo "${DESC,,}" | grep -q "$SEARCH" || echo "${name,,}" | grep -q "$SEARCH"; then
            FOUND="$name"
            break
        fi
    done < <(pactl list sinks short 2>/dev/null)

    if [ -n "$FOUND" ]; then
        pactl set-default-sink "$FOUND"
        DESC=$(pactl list sinks 2>/dev/null | grep -A1 "Name: $FOUND" | grep "Description:" | sed 's/.*Description: //')
        echo "Switched audio output to: $DESC"
        notify-send -a "24HG" -i "audio-headphones" "Audio Output" "$DESC" 2>/dev/null || true

        # Move all currently playing streams to the new sink
        pactl list sink-inputs short 2>/dev/null | while read -r si_idx _rest; do
            pactl move-sink-input "$si_idx" "$FOUND" 2>/dev/null || true
        done
    else
        echo "No audio device matching '$1' found"
        echo ""
        echo "Available devices:"
        list_sinks
        exit 1
    fi
}

apply_gaming_audio() {
    echo "Applying gaming audio profile..."

    # Override PipeWire settings for low latency
    local PIPEWIRE_CONF_DIR="${HOME}/.config/pipewire/pipewire.conf.d"
    mkdir -p "$PIPEWIRE_CONF_DIR"

    cat > "$PIPEWIRE_CONF_DIR/99-24hg-gaming.conf" << 'EOF'
# 24HG Gaming Audio — Low latency PipeWire config
context.properties = {
    default.clock.quantum = 256
    default.clock.min-quantum = 64
    default.clock.max-quantum = 1024
    default.clock.rate = 48000
}
EOF

    echo "  PipeWire: 256 quantum, 48kHz (5.3ms latency)"

    # Restart PipeWire to apply
    systemctl --user restart pipewire.service 2>/dev/null || true
    systemctl --user restart pipewire-pulse.service 2>/dev/null || true

    echo "  Audio services restarted"
    echo ""
    echo "Gaming audio active — low-latency mode enabled"
}

apply_desktop_audio() {
    echo "Restoring desktop audio profile..."

    local PIPEWIRE_CONF="${HOME}/.config/pipewire/pipewire.conf.d/99-24hg-gaming.conf"
    if [ -f "$PIPEWIRE_CONF" ]; then
        cat > "$PIPEWIRE_CONF" << 'EOF'
# 24HG Desktop Audio — Balanced settings
context.properties = {
    default.clock.quantum = 1024
    default.clock.min-quantum = 256
    default.clock.max-quantum = 2048
    default.clock.rate = 48000
}
EOF
    fi

    systemctl --user restart pipewire.service 2>/dev/null || true
    systemctl --user restart pipewire-pulse.service 2>/dev/null || true

    echo "Desktop audio restored — balanced latency"
}

toggle_noise_cancel() {
    # Check if noise cancellation is already active
    local NC_RUNNING
    NC_RUNNING=$(pactl list modules short 2>/dev/null | grep -c "echo-cancel" || echo 0)

    if [ "$NC_RUNNING" -gt 0 ]; then
        echo "Disabling noise cancellation..."
        pactl list modules short 2>/dev/null | grep "echo-cancel" | awk '{print $1}' | while read -r mod; do
            pactl unload-module "$mod" 2>/dev/null || true
        done
        echo "Noise cancellation: OFF"
        notify-send -a "24HG" -i "audio-input-microphone" "Noise Cancel OFF" 2>/dev/null || true
    else
        echo "Enabling noise cancellation..."
        # PipeWire's built-in echo cancellation module
        pactl load-module module-echo-cancel \
            use_master_format=1 \
            aec_method=webrtc \
            source_name=hg24_clean_mic \
            source_master="$(get_default_source)" \
            sink_name=hg24_clean_out \
            sink_master="$(get_default_sink)" 2>/dev/null || {
            echo "Built-in echo-cancel not available."
            echo "Try installing: pipewire-module-filter-chain-lv2"
            exit 1
        }
        pactl set-default-source hg24_clean_mic 2>/dev/null || true
        echo "Noise cancellation: ON (WebRTC AEC)"
        echo "Clean mic source: hg24_clean_mic"
        notify-send -a "24HG" -i "audio-input-microphone" "Noise Cancel ON" \
            "Using WebRTC echo cancellation" 2>/dev/null || true
    fi
}

show_status() {
    echo "=== 24HG Audio Status ==="

    echo ""
    echo "Output: $(get_default_sink)"
    DESC=$(pactl list sinks 2>/dev/null | grep -A1 "Name: $(get_default_sink)" | grep "Description:" | sed 's/.*Description: //' || echo "unknown")
    echo "  $DESC"

    echo ""
    echo "Input: $(get_default_source)"
    DESC=$(pactl list sources 2>/dev/null | grep -A1 "Name: $(get_default_source)" | grep "Description:" | sed 's/.*Description: //' || echo "unknown")
    echo "  $DESC"

    echo ""
    echo "PipeWire:"
    if command -v pw-cli &>/dev/null; then
        QUANTUM=$(pw-cli info 0 2>/dev/null | grep "default.clock.quantum" | grep -oP '\d+' || echo "?")
        RATE=$(pw-cli info 0 2>/dev/null | grep "default.clock.rate" | grep -oP '\d+' || echo "?")
        if [ "$QUANTUM" != "?" ] && [ "$RATE" != "?" ] && [ "$RATE" -gt 0 ] 2>/dev/null; then
            LATENCY=$(echo "scale=1; $QUANTUM * 1000 / $RATE" | bc 2>/dev/null || echo "?")
            echo "  Quantum: $QUANTUM | Rate: $RATE Hz | Latency: ~${LATENCY}ms"
        else
            echo "  Quantum: $QUANTUM | Rate: $RATE Hz"
        fi
    fi

    echo ""
    echo "Noise Cancellation:"
    local NC
    NC=$(pactl list modules short 2>/dev/null | grep -c "echo-cancel" || echo 0)
    echo "  $([ "$NC" -gt 0 ] && echo "ON (WebRTC AEC)" || echo "OFF")"

    echo ""
    echo "Volume:"
    pactl get-sink-volume "$(get_default_sink)" 2>/dev/null | head -1 | sed 's/^/  /' || echo "  unknown"
}

case "$ACTION" in
    gaming)      apply_gaming_audio ;;
    desktop)     apply_desktop_audio ;;
    devices)
        echo "=== Audio Outputs ==="
        list_sinks
        echo ""
        echo "=== Audio Inputs ==="
        list_sources
        ;;
    switch)
        if [ -z "${2:-}" ]; then
            echo "Usage: 24hg-audio switch <device-name>"
            echo "  e.g.: 24hg-audio switch headset"
            echo "        24hg-audio switch speakers"
            echo ""
            echo "Available:"
            list_sinks
            exit 1
        fi
        switch_output "$2"
        ;;
    noise-cancel) toggle_noise_cancel ;;
    status)       show_status ;;
    *)
        echo "24HG Audio Optimizer"
        echo "Usage: 24hg-audio [gaming|desktop|devices|switch <name>|noise-cancel|status]"
        echo ""
        echo "  gaming       — Low-latency audio (5ms buffer)"
        echo "  desktop      — Balanced audio settings"
        echo "  devices      — List all audio devices"
        echo "  switch <name>— Switch output (e.g., 'headset', 'speakers')"
        echo "  noise-cancel — Toggle microphone noise cancellation"
        echo "  status       — Show current audio configuration"
        exit 1
        ;;
esac
