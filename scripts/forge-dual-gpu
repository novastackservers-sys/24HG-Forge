#!/usr/bin/env bash
# forge-dual-gpu — Hybrid GPU manager for 24HG Forge Linux
# Manages NVIDIA Optimus / AMD switchable graphics on laptops.
set -euo pipefail

VERSION="1.0.0"
CONFIG_DIR="${HOME}/.config/forge/dual-gpu"
ASSIGN_FILE="${CONFIG_DIR}/assignments.conf"
SETTINGS_FILE="${CONFIG_DIR}/settings.conf"
LOG_FILE="${CONFIG_DIR}/dual-gpu.log"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

init_config() {
    mkdir -p "$CONFIG_DIR"
    [[ -f "$ASSIGN_FILE" ]] || touch "$ASSIGN_FILE"
    if [[ ! -f "$SETTINGS_FILE" ]]; then
        cat > "$SETTINGS_FILE" <<'CONF'
# forge-dual-gpu settings
MODE=hybrid
AUTO_POWER_OFF=true
POWER_METHOD=auto
CONF
    fi
    source "$SETTINGS_FILE"
}

log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE" 2>/dev/null || true
}

# ── GPU Detection ───────────────────────────────────────────────────────────

detect_gpus() {
    IGPU_PCI="" ; IGPU_NAME="" ; IGPU_VENDOR=""
    DGPU_PCI="" ; DGPU_NAME="" ; DGPU_VENDOR="" ; DGPU_DRIVER=""

    while IFS= read -r line; do
        pci=$(echo "$line" | awk '{print $1}')
        name=$(echo "$line" | sed 's/^[^ ]* [^:]*: //')
        if echo "$name" | grep -qi "intel"; then
            IGPU_PCI="$pci"; IGPU_NAME="$name"; IGPU_VENDOR="intel"
        elif echo "$name" | grep -qi "AMD.*Radeon.*Graphics" && [[ -z "$IGPU_PCI" || "$name" =~ Vega|Renoir|Cezanne|Barcelo|Rembrandt|Phoenix|Hawk ]]; then
            # AMD APU integrated graphics
            if [[ -z "$DGPU_PCI" ]] || echo "$name" | grep -qi "Vega\|Renoir\|Cezanne\|Barcelo\|Rembrandt\|Phoenix\|Hawk"; then
                IGPU_PCI="$pci"; IGPU_NAME="$name"; IGPU_VENDOR="amd"
            fi
        elif echo "$name" | grep -qi "NVIDIA"; then
            DGPU_PCI="$pci"; DGPU_NAME="$name"; DGPU_VENDOR="nvidia"
        elif echo "$name" | grep -qi "AMD\|ATI\|Radeon"; then
            # Discrete AMD GPU (Navi, RDNA, etc.)
            if [[ -n "$IGPU_PCI" ]]; then
                DGPU_PCI="$pci"; DGPU_NAME="$name"; DGPU_VENDOR="amd"
            elif [[ -z "$IGPU_PCI" ]]; then
                IGPU_PCI="$pci"; IGPU_NAME="$name"; IGPU_VENDOR="amd"
            fi
        fi
    done < <(lspci -D 2>/dev/null | grep -i 'VGA\|3D\|Display')

    # Determine dGPU driver
    if [[ -n "$DGPU_PCI" ]]; then
        if [[ "$DGPU_VENDOR" == "nvidia" ]]; then
            if lsmod 2>/dev/null | grep -q "^nvidia "; then
                DGPU_DRIVER="nvidia"
            else
                DGPU_DRIVER="nouveau"
            fi
        elif [[ "$DGPU_VENDOR" == "amd" ]]; then
            DGPU_DRIVER="amdgpu"
        fi
    fi
}

get_dgpu_power_state() {
    # Check bbswitch
    if [[ -f /proc/acpi/bbswitch ]]; then
        awk '{print $2}' /proc/acpi/bbswitch
        return
    fi
    # Check runtime PM
    local sysfs_path
    sysfs_path=$(find /sys/bus/pci/devices/ -maxdepth 1 -name "*${DGPU_PCI#*:}" 2>/dev/null | head -1)
    if [[ -n "$sysfs_path" && -f "${sysfs_path}/power/runtime_status" ]]; then
        cat "${sysfs_path}/power/runtime_status"
        return
    fi
    echo "unknown"
}

get_render_nodes() {
    # List DRI render nodes and their associated GPUs
    local nodes=()
    for node in /sys/class/drm/renderD*; do
        [[ -d "$node" ]] || continue
        local dev_path pci_addr gpu_name
        dev_path=$(readlink -f "$node/device" 2>/dev/null)
        pci_addr=$(basename "$dev_path" 2>/dev/null)
        gpu_name=$(lspci -s "$pci_addr" 2>/dev/null | sed 's/^[^:]*: //' || echo "Unknown")
        nodes+=("$(basename "$node"):${pci_addr}:${gpu_name}")
    done
    printf '%s\n' "${nodes[@]}"
}

# ── Status Display ──────────────────────────────────────────────────────────

cmd_status() {
    detect_gpus
    echo -e "${BOLD}${CYAN}=== Forge Dual-GPU Status ===${RESET}\n"

    # iGPU info
    if [[ -n "$IGPU_PCI" ]]; then
        echo -e "${GREEN}Integrated GPU (iGPU):${RESET}"
        echo -e "  PCI:    ${IGPU_PCI}"
        echo -e "  Name:   ${IGPU_NAME}"
        echo -e "  Vendor: ${IGPU_VENDOR}"
    else
        echo -e "${YELLOW}No integrated GPU detected.${RESET}"
    fi

    echo ""

    # dGPU info
    if [[ -n "$DGPU_PCI" ]]; then
        local pwr
        pwr=$(get_dgpu_power_state)
        echo -e "${GREEN}Discrete GPU (dGPU):${RESET}"
        echo -e "  PCI:    ${DGPU_PCI}"
        echo -e "  Name:   ${DGPU_NAME}"
        echo -e "  Vendor: ${DGPU_VENDOR}"
        echo -e "  Driver: ${DGPU_DRIVER}"
        case "$pwr" in
            ON|active|suspended) echo -e "  Power:  ${GREEN}${pwr}${RESET}" ;;
            OFF)                 echo -e "  Power:  ${RED}${pwr}${RESET}" ;;
            *)                   echo -e "  Power:  ${YELLOW}${pwr}${RESET}" ;;
        esac
    else
        echo -e "${YELLOW}No discrete GPU detected.${RESET}"
    fi

    echo ""
    echo -e "${BOLD}Mode:${RESET} ${MODE:-hybrid}"
    echo -e "${BOLD}Auto power-off:${RESET} ${AUTO_POWER_OFF:-true}"

    # Render nodes
    echo -e "\n${BOLD}Render Nodes:${RESET}"
    for node in /sys/class/drm/renderD*; do
        [[ -d "$node" ]] || continue
        local dev_path pci_addr gpu_name
        dev_path=$(readlink -f "$node/device" 2>/dev/null || true)
        pci_addr=$(basename "$dev_path" 2>/dev/null || echo "?")
        gpu_name=$(lspci -s "$pci_addr" 2>/dev/null | sed 's/^[^:]*: //' || echo "Unknown")
        echo -e "  /dev/dri/$(basename "$node") -> ${gpu_name}"
    done
}

# ── Run on dGPU ─────────────────────────────────────────────────────────────

build_dgpu_env() {
    detect_gpus
    local env_vars=()

    if [[ -z "$DGPU_PCI" ]]; then
        echo -e "${RED}Error: No discrete GPU detected.${RESET}" >&2
        return 1
    fi

    if [[ "$DGPU_VENDOR" == "nvidia" && "$DGPU_DRIVER" == "nvidia" ]]; then
        env_vars+=(
            "__NV_PRIME_RENDER_OFFLOAD=1"
            "__NV_PRIME_RENDER_OFFLOAD_PROVIDER=NVIDIA-G0"
            "__GLX_VENDOR_LIBRARY_NAME=nvidia"
            "__VK_LAYER_NV_optimus=NVIDIA_only"
            "VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json"
        )
    elif [[ "$DGPU_VENDOR" == "nvidia" && "$DGPU_DRIVER" == "nouveau" ]]; then
        env_vars+=("DRI_PRIME=1")
    elif [[ "$DGPU_VENDOR" == "amd" ]]; then
        env_vars+=("DRI_PRIME=1")
    fi

    printf '%s\n' "${env_vars[@]}"
}

cmd_run() {
    if [[ $# -eq 0 ]]; then
        echo -e "${RED}Usage: forge-dual-gpu run <command> [args...]${RESET}" >&2
        exit 1
    fi

    # Ensure dGPU is powered on
    local pwr
    pwr=$(get_dgpu_power_state)
    if [[ "$pwr" == "OFF" ]]; then
        echo -e "${YELLOW}dGPU is powered off. Powering on...${RESET}"
        cmd_power on 2>/dev/null || true
        sleep 1
    fi

    local env_line
    env_line=$(build_dgpu_env) || exit 1

    echo -e "${GREEN}Running on dGPU:${RESET} $*"
    log_msg "RUN on dGPU: $*"

    # Export each variable and run
    while IFS= read -r var; do
        export "${var?}"
    done <<< "$env_line"

    exec "$@"
}

# ── GPU Mode Switching ──────────────────────────────────────────────────────

cmd_mode() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        echo -e "${BOLD}Current mode:${RESET} ${MODE:-hybrid}"
        echo -e "Available: hybrid, dgpu, igpu"
        return
    fi

    case "$target" in
        hybrid|dgpu|igpu) ;;
        *) echo -e "${RED}Invalid mode: $target (use hybrid, dgpu, igpu)${RESET}" >&2; exit 1 ;;
    esac

    detect_gpus

    case "$target" in
        hybrid)
            echo -e "${GREEN}Switching to hybrid mode.${RESET}"
            echo "iGPU handles desktop, dGPU available for offloading."
            ;;
        dgpu)
            if [[ -z "$DGPU_PCI" ]]; then
                echo -e "${RED}No dGPU detected. Cannot switch to dgpu mode.${RESET}" >&2
                exit 1
            fi
            echo -e "${GREEN}Switching to dGPU-only mode.${RESET}"
            echo "All rendering will use the discrete GPU."
            cmd_power on 2>/dev/null || true
            ;;
        igpu)
            if [[ -z "$IGPU_PCI" ]]; then
                echo -e "${RED}No iGPU detected. Cannot switch to igpu mode.${RESET}" >&2
                exit 1
            fi
            echo -e "${GREEN}Switching to iGPU-only mode.${RESET}"
            echo "Discrete GPU will be powered off for battery savings."
            cmd_power off 2>/dev/null || true
            ;;
    esac

    sed -i "s/^MODE=.*/MODE=${target}/" "$SETTINGS_FILE"
    MODE="$target"
    log_msg "Mode changed to $target"
    echo -e "${YELLOW}Note: A session restart may be needed for full effect.${RESET}"
}

# ── Power Management ────────────────────────────────────────────────────────

cmd_power() {
    local action="${1:-}"
    detect_gpus

    if [[ -z "$DGPU_PCI" ]]; then
        echo -e "${RED}No discrete GPU detected.${RESET}" >&2
        exit 1
    fi

    if [[ -z "$action" ]]; then
        local pwr
        pwr=$(get_dgpu_power_state)
        echo -e "${BOLD}dGPU power state:${RESET} $pwr"
        return
    fi

    local sysfs_path
    sysfs_path=$(find /sys/bus/pci/devices/ -maxdepth 1 -name "*${DGPU_PCI#*:}" 2>/dev/null | head -1)

    case "$action" in
        on)
            echo -e "${GREEN}Powering on dGPU...${RESET}"
            if [[ -f /proc/acpi/bbswitch ]]; then
                echo ON | sudo tee /proc/acpi/bbswitch > /dev/null
            elif [[ -n "$sysfs_path" ]]; then
                echo "on" | sudo tee "${sysfs_path}/power/control" > /dev/null 2>&1 || true
            fi
            log_msg "dGPU powered on"
            ;;
        off)
            echo -e "${YELLOW}Powering off dGPU...${RESET}"
            # Check if anything is using it
            local users
            users=$(cmd_apps_list 2>/dev/null | grep -c "dGPU" || true)
            if [[ "$users" -gt 0 ]]; then
                echo -e "${RED}Warning: $users app(s) currently using dGPU.${RESET}"
                read -rp "Power off anyway? [y/N] " confirm
                [[ "$confirm" =~ ^[Yy] ]] || return
            fi
            if [[ -f /proc/acpi/bbswitch ]]; then
                echo OFF | sudo tee /proc/acpi/bbswitch > /dev/null
            elif [[ -n "$sysfs_path" ]]; then
                echo "auto" | sudo tee "${sysfs_path}/power/control" > /dev/null 2>&1 || true
            fi
            log_msg "dGPU powered off"
            ;;
        *)
            echo -e "${RED}Usage: forge-dual-gpu power [on|off]${RESET}" >&2
            exit 1
            ;;
    esac
    sleep 0.5
    local pwr
    pwr=$(get_dgpu_power_state)
    echo -e "dGPU power state: ${BOLD}${pwr}${RESET}"
}

# ── Per-App GPU Assignment ──────────────────────────────────────────────────

cmd_assign() {
    local appid="${1:-}" gpu="${2:-dgpu}"

    if [[ -z "$appid" ]]; then
        echo -e "${BOLD}Current GPU assignments:${RESET}"
        if [[ -s "$ASSIGN_FILE" ]]; then
            while IFS='=' read -r app target; do
                [[ -z "$app" || "$app" =~ ^# ]] && continue
                echo -e "  ${CYAN}${app}${RESET} -> ${target}"
            done < "$ASSIGN_FILE"
        else
            echo "  (none)"
        fi
        echo -e "\nUsage: forge-dual-gpu assign <appid|name> [dgpu|igpu|auto]"
        return
    fi

    case "$gpu" in
        dgpu|igpu|auto) ;;
        *) echo -e "${RED}Invalid target: $gpu (use dgpu, igpu, auto)${RESET}" >&2; exit 1 ;;
    esac

    if [[ "$gpu" == "auto" ]]; then
        sed -i "/^${appid}=/d" "$ASSIGN_FILE"
        echo -e "${GREEN}Removed assignment for ${appid} (will use default).${RESET}"
    else
        sed -i "/^${appid}=/d" "$ASSIGN_FILE"
        echo "${appid}=${gpu}" >> "$ASSIGN_FILE"
        echo -e "${GREEN}Assigned ${appid} -> ${gpu}.${RESET}"
    fi
    log_msg "Assignment: $appid -> $gpu"
}

get_assignment() {
    local appid="$1"
    if [[ -f "$ASSIGN_FILE" ]]; then
        grep "^${appid}=" "$ASSIGN_FILE" 2>/dev/null | cut -d= -f2 | tail -1
    fi
}

# ── App GPU Tracking ────────────────────────────────────────────────────────

cmd_apps_list() {
    detect_gpus
    # Find processes with GPU env vars or active on render nodes
    local found=0
    echo -e "${BOLD}${CYAN}Apps and their GPU usage:${RESET}\n"
    printf "  ${BOLD}%-8s %-30s %-10s %s${RESET}\n" "PID" "COMMAND" "GPU" "DETAILS"
    echo "  -----------------------------------------------------------------------"

    while IFS= read -r pid; do
        [[ -d "/proc/$pid" ]] || continue
        local cmd gpu_label details=""
        cmd=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null | cut -c1-28 || continue)
        [[ -z "$cmd" ]] && continue
        local env_data
        env_data=$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null || true)
        gpu_label="iGPU"

        if echo "$env_data" | grep -q "__NV_PRIME_RENDER_OFFLOAD=1"; then
            gpu_label="dGPU"; details="nvidia-offload"
        elif echo "$env_data" | grep -q "DRI_PRIME=1"; then
            gpu_label="dGPU"; details="DRI_PRIME"
        fi

        # Only show graphical apps (have DISPLAY or WAYLAND_DISPLAY)
        if echo "$env_data" | grep -qE "^(DISPLAY|WAYLAND_DISPLAY)="; then
            printf "  %-8s %-30s %-10s %s\n" "$pid" "$cmd" "$gpu_label" "$details"
            found=1
        fi
    done < <(ls /proc/ 2>/dev/null | grep '^[0-9]*$' | head -200)

    if [[ $found -eq 0 ]]; then
        echo -e "  ${YELLOW}No graphical apps detected.${RESET}"
    fi
}

cmd_apps() {
    cmd_apps_list
}

# ── Benchmark ───────────────────────────────────────────────────────────────

cmd_benchmark() {
    detect_gpus

    echo -e "${BOLD}${CYAN}=== Forge Dual-GPU Benchmark ===${RESET}\n"

    local has_glxgears=false has_vulkaninfo=false
    command -v glxgears &>/dev/null && has_glxgears=true
    command -v vulkaninfo &>/dev/null && has_vulkaninfo=true

    if ! $has_glxgears; then
        echo -e "${YELLOW}glxgears not found. Install mesa-demos for OpenGL benchmarks.${RESET}"
        echo -e "Falling back to basic GPU info comparison.\n"
    fi

    # iGPU benchmark
    echo -e "${GREEN}--- iGPU: ${IGPU_NAME:-unknown} ---${RESET}"
    if $has_glxgears; then
        echo "Running glxgears for 5 seconds..."
        local igpu_fps
        igpu_fps=$(timeout 6 glxgears -info 2>&1 | grep -oP '[\d.]+ frames in [\d.]+ seconds = \K[\d.]+' | tail -1 || echo "N/A")
        echo -e "  OpenGL FPS: ${BOLD}${igpu_fps}${RESET}"
    fi
    if $has_vulkaninfo; then
        local igpu_vk
        igpu_vk=$(vulkaninfo --summary 2>/dev/null | grep -i "deviceName" | head -1 | sed 's/.*= //' || echo "N/A")
        echo -e "  Vulkan device: ${igpu_vk}"
    fi

    echo ""

    # dGPU benchmark
    if [[ -z "$DGPU_PCI" ]]; then
        echo -e "${YELLOW}No dGPU detected, skipping dGPU benchmark.${RESET}"
        return
    fi

    local pwr
    pwr=$(get_dgpu_power_state)
    if [[ "$pwr" == "OFF" ]]; then
        echo -e "${YELLOW}dGPU is powered off. Powering on for benchmark...${RESET}"
        cmd_power on 2>/dev/null || true
        sleep 2
    fi

    echo -e "${GREEN}--- dGPU: ${DGPU_NAME:-unknown} ---${RESET}"
    local env_line
    env_line=$(build_dgpu_env 2>/dev/null) || { echo -e "${RED}Cannot configure dGPU offload.${RESET}"; return; }

    # Temporarily set env
    local saved_env=()
    while IFS= read -r var; do
        local key="${var%%=*}"
        saved_env+=("${key}=${!key:-}")
        export "${var?}"
    done <<< "$env_line"

    if $has_glxgears; then
        echo "Running glxgears for 5 seconds..."
        local dgpu_fps
        dgpu_fps=$(timeout 6 glxgears -info 2>&1 | grep -oP '[\d.]+ frames in [\d.]+ seconds = \K[\d.]+' | tail -1 || echo "N/A")
        echo -e "  OpenGL FPS: ${BOLD}${dgpu_fps}${RESET}"
    fi
    if $has_vulkaninfo; then
        local dgpu_vk
        dgpu_vk=$(VK_ICD_FILENAMES="${VK_ICD_FILENAMES:-}" vulkaninfo --summary 2>/dev/null | grep -i "deviceName" | head -1 | sed 's/.*= //' || echo "N/A")
        echo -e "  Vulkan device: ${dgpu_vk}"
    fi

    # NVIDIA-specific stats
    if [[ "$DGPU_VENDOR" == "nvidia" ]] && command -v nvidia-smi &>/dev/null; then
        echo -e "\n  ${BOLD}NVIDIA SMI:${RESET}"
        nvidia-smi --query-gpu=gpu_name,temperature.gpu,power.draw,memory.total,memory.used,driver_version \
            --format=csv,noheader 2>/dev/null | while IFS=',' read -r name temp pwr mem_total mem_used drv; do
            echo "    GPU:         $name"
            echo "    Temperature: ${temp}C"
            echo "    Power draw:  $pwr"
            echo "    VRAM:        ${mem_used} / ${mem_total}"
            echo "    Driver:      $drv"
        done
    fi

    # Restore env
    for var in "${saved_env[@]}"; do
        local key="${var%%=*}" val="${var#*=}"
        if [[ -z "$val" ]]; then
            unset "$key" 2>/dev/null || true
        else
            export "${key}=${val}"
        fi
    done

    echo -e "\n${BOLD}Benchmark complete.${RESET}"
    log_msg "Benchmark run"
}

# ── Usage / Help ────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${BOLD}forge-dual-gpu${RESET} v${VERSION} — Hybrid GPU manager for Forge Linux

${BOLD}USAGE:${RESET}
    forge-dual-gpu <command> [options]

${BOLD}COMMANDS:${RESET}
    status              Show GPU status, power state, render nodes
    run <cmd> [args]    Run a command on the discrete GPU
    mode [hybrid|dgpu|igpu]
                        Get or set GPU mode
    assign <app> [dgpu|igpu|auto]
                        Assign a game/app to always use a specific GPU
    power [on|off]      Toggle discrete GPU power
    apps                Show which GPU each running app is using
    benchmark           Quick benchmark comparison of both GPUs
    help                Show this help

${BOLD}EXAMPLES:${RESET}
    forge-dual-gpu status
    forge-dual-gpu run glxgears
    forge-dual-gpu run steam steam://rungameid/730
    forge-dual-gpu mode dgpu
    forge-dual-gpu assign 730 dgpu
    forge-dual-gpu power off
    forge-dual-gpu benchmark

${BOLD}CONFIG:${RESET}
    Settings:    ${CONFIG_DIR}/settings.conf
    Assignments: ${CONFIG_DIR}/assignments.conf
    Log:         ${CONFIG_DIR}/dual-gpu.log

EOF
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    init_config

    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        status)    cmd_status "$@" ;;
        run)       cmd_run "$@" ;;
        mode)      cmd_mode "$@" ;;
        assign)    cmd_assign "$@" ;;
        power)     cmd_power "$@" ;;
        apps)      cmd_apps "$@" ;;
        benchmark) cmd_benchmark "$@" ;;
        help|--help|-h) usage ;;
        version|--version|-v) echo "forge-dual-gpu v${VERSION}" ;;
        *)
            echo -e "${RED}Unknown command: $cmd${RESET}" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
