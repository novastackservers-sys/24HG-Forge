#!/bin/bash
# forge-desktop-setup — Configure KDE Plasma desktop for 24HG Forge gaming environment
# Safe to run multiple times (idempotent).

set -euo pipefail

# Brand colors
COLOR_BG="#0a0a14"
COLOR_CYAN="#00d4ff"
COLOR_BLUE="#3b82f6"
COLOR_DIM="#8080b0"
COLOR_FG="#e0e0f0"

# Detect kwriteconfig binary
if command -v kwriteconfig6 &>/dev/null; then
    KWC=kwriteconfig6
elif command -v kwriteconfig5 &>/dev/null; then
    KWC=kwriteconfig5
else
    echo "[forge] ERROR: Neither kwriteconfig6 nor kwriteconfig5 found." >&2
    exit 1
fi

log() { echo "[forge] $*"; }

# ---------------------------------------------------------------------------
# apply — Full desktop customization
# ---------------------------------------------------------------------------
apply_all() {
    log "Applying 24HG Forge desktop customizations..."

    # --- Cursor theme ---
    log "Setting cursor theme: breeze_cursors, size 28"
    $KWC --file kcminputrc --group Mouse --key cursorTheme "breeze_cursors"
    $KWC --file kcminputrc --group Mouse --key cursorSize 28

    # --- KWin compositor settings ---
    log "Configuring KWin compositor for gaming"
    $KWC --file kwinrc --group Compositing --key AnimationSpeed 3
    $KWC --file kwinrc --group Compositing --key Backend "OpenGL"
    $KWC --file kwinrc --group Compositing --key Enabled true
    $KWC --file kwinrc --group Compositing --key GLCore true
    $KWC --file kwinrc --group Compositing --key HiddenPreviews 5
    $KWC --file kwinrc --group Compositing --key OpenGLIsUnsafe false
    $KWC --file kwinrc --group Compositing --key WindowsBlockCompositing true

    # --- KWin effects ---
    log "Setting window effects: magic lamp minimize, no wobbly, no slide"
    $KWC --file kwinrc --group Plugins --key magiclampEnabled true
    $KWC --file kwinrc --group Plugins --key wobblywindowsEnabled false
    $KWC --file kwinrc --group Plugins --key slideEnabled false
    $KWC --file kwinrc --group Plugins --key blurEnabled true
    $KWC --file kwinrc --group Plugins --key contrastEnabled true
    $KWC --file kwinrc --group "Effect-magiclamp" --key AnimationDuration 200

    # --- Window behavior ---
    log "Setting window behavior: click to focus, no auto-raise"
    $KWC --file kwinrc --group Windows --key FocusPolicy "ClickToFocus"
    $KWC --file kwinrc --group Windows --key AutoRaise false
    $KWC --file kwinrc --group Windows --key AutoRaiseInterval 0
    $KWC --file kwinrc --group Windows --key FocusStealingPreventionLevel 1

    # --- Overview edge trigger off (no accidental activation) ---
    $KWC --file kwinrc --group "Effect-overview" --key BorderActivate 9

    # --- Tab box / alt-tab ---
    $KWC --file kwinrc --group TabBox --key DesktopLayout "org.kde.breeze.desktop"
    $KWC --file kwinrc --group TabBox --key LayoutName "org.kde.breeze.desktop"

    # --- Konsole color scheme ---
    log "Setting Konsole default profile to 24HG Forge color scheme"
    local konsole_dir="$HOME/.local/share/konsole"
    mkdir -p "$konsole_dir"

    # Create 24HG Forge Konsole profile if it doesn't exist
    if [ ! -f "$konsole_dir/24HG Forge.profile" ]; then
        cat > "$konsole_dir/24HG Forge.profile" <<'PROFILE'
[Appearance]
ColorScheme=24HG Forge
Font=Hack,11,-1,5,50,0,0,0,0,0

[General]
Command=/bin/bash
Name=24HG Forge
Parent=FALLBACK/

[Scrolling]
HistoryMode=2
ScrollBarPosition=2

[Terminal Features]
BlinkingCursorEnabled=true
PROFILE
    fi

    # Set 24HG Forge as default Konsole profile
    $KWC --file konsolerc --group "Desktop Entry" --key DefaultProfile "24HG Forge.profile"

    # --- Desktop shortcuts ---
    log "Creating desktop shortcuts"
    local desktop_dir
    desktop_dir=$(xdg-user-dir DESKTOP 2>/dev/null || echo "$HOME/Desktop")
    mkdir -p "$desktop_dir"

    # Hub shortcut
    if [ ! -f "$desktop_dir/hub.desktop" ]; then
        cat > "$desktop_dir/hub.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=Hub
Comment=24HG Forge Gaming Hub
Exec=forge-hub
Icon=forge
Terminal=false
Categories=Game;
DESKTOP
        chmod +x "$desktop_dir/hub.desktop"
    fi

    # Steam shortcut
    if [ ! -f "$desktop_dir/steam.desktop" ]; then
        cat > "$desktop_dir/steam.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=Steam
Comment=Launch Steam
Exec=flatpak run com.valvesoftware.Steam
Icon=steam
Terminal=false
Categories=Game;
DESKTOP
        chmod +x "$desktop_dir/steam.desktop"
    fi

    # Discord shortcut
    if [ ! -f "$desktop_dir/discord.desktop" ]; then
        cat > "$desktop_dir/discord.desktop" <<'DESKTOP'
[Desktop Entry]
Type=Application
Name=Discord
Comment=Launch Discord
Exec=flatpak run com.discordapp.Discord
Icon=discord
Terminal=false
Categories=Network;Chat;
DESKTOP
        chmod +x "$desktop_dir/discord.desktop"
    fi

    # --- File associations ---
    log "Setting file associations and protocol handlers"
    local mimeapps="$HOME/.config/mimeapps.list"
    mkdir -p "$(dirname "$mimeapps")"

    # Ensure [Default Applications] section exists
    if [ ! -f "$mimeapps" ]; then
        echo "[Default Applications]" > "$mimeapps"
    fi

    # .dem files -> Steam
    if ! grep -q "application/x-demo" "$mimeapps" 2>/dev/null; then
        echo "application/x-demo=com.valvesoftware.Steam.desktop" >> "$mimeapps"
    fi

    # steam:// protocol
    if ! grep -q "x-scheme-handler/steam" "$mimeapps" 2>/dev/null; then
        echo "x-scheme-handler/steam=com.valvesoftware.Steam.desktop" >> "$mimeapps"
    fi

    # 24hg:// protocol
    local forge_handler="$HOME/.local/share/applications/forge-protocol.desktop"
    mkdir -p "$(dirname "$forge_handler")"
    if [ ! -f "$forge_handler" ]; then
        cat > "$forge_handler" <<'HANDLER'
[Desktop Entry]
Type=Application
Name=24HG Forge Protocol Handler
Exec=forge-hub --uri %u
Icon=forge
Terminal=false
MimeType=x-scheme-handler/24hg;
NoDisplay=true
HANDLER
    fi
    if ! grep -q "x-scheme-handler/24hg" "$mimeapps" 2>/dev/null; then
        echo "x-scheme-handler/24hg=forge-protocol.desktop" >> "$mimeapps"
    fi

    # Update MIME database
    if command -v update-desktop-database &>/dev/null; then
        update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true
    fi

    # --- Wallpaper ---
    log "Setting wallpaper if available"
    local wallpaper="/usr/share/wallpapers/forge-dark.png"
    if [ -f "$wallpaper" ]; then
        if command -v qdbus &>/dev/null; then
            qdbus org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "
                var allDesktops = desktops();
                for (var i = 0; i < allDesktops.length; i++) {
                    var d = allDesktops[i];
                    d.wallpaperPlugin = 'org.kde.image';
                    d.currentConfigGroup = ['Wallpaper', 'org.kde.image', 'General'];
                    d.writeConfig('Image', 'file://$wallpaper');
                }
            " 2>/dev/null || true
        fi
    else
        log "Wallpaper not found at $wallpaper, skipping"
    fi

    # --- Create required directories ---
    log "Creating gaming directories"
    mkdir -p "$HOME/Pictures/Screenshots"
    mkdir -p "$HOME/Videos/24HG Forge-Replays"
    mkdir -p "$HOME/24HG Forge-Backups"
    mkdir -p "$HOME/.config/forge"

    # --- Reload KWin if running ---
    if command -v qdbus &>/dev/null && qdbus org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null; then
        log "KWin reconfigured"
    fi

    log "Desktop customization complete."
}

# ---------------------------------------------------------------------------
# gaming — Minimal compositing for maximum game performance
# ---------------------------------------------------------------------------
apply_gaming() {
    log "Switching to gaming mode (minimal compositing)..."

    $KWC --file kwinrc --group Compositing --key AnimationSpeed 0
    $KWC --file kwinrc --group Compositing --key WindowsBlockCompositing true

    $KWC --file kwinrc --group Plugins --key blurEnabled false
    $KWC --file kwinrc --group Plugins --key contrastEnabled false
    $KWC --file kwinrc --group Plugins --key magiclampEnabled false
    $KWC --file kwinrc --group Plugins --key slideEnabled false
    $KWC --file kwinrc --group Plugins --key wobblywindowsEnabled false
    $KWC --file kwinrc --group Plugins --key translucencyEnabled false
    $KWC --file kwinrc --group Plugins --key kwin4_effect_fadeEnabled false
    $KWC --file kwinrc --group Plugins --key dimscreenEnabled false

    # Reduce latency: disable VSync for desktop
    $KWC --file kwinrc --group Compositing --key GLPreferBufferSwap "n"

    if command -v qdbus &>/dev/null; then
        qdbus org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
    fi

    log "Gaming mode active. Run '$0 desktop' to restore effects."
}

# ---------------------------------------------------------------------------
# desktop — Full desktop effects restored
# ---------------------------------------------------------------------------
apply_desktop() {
    log "Switching to desktop mode (full effects)..."

    $KWC --file kwinrc --group Compositing --key AnimationSpeed 3
    $KWC --file kwinrc --group Compositing --key WindowsBlockCompositing true

    $KWC --file kwinrc --group Plugins --key blurEnabled true
    $KWC --file kwinrc --group Plugins --key contrastEnabled true
    $KWC --file kwinrc --group Plugins --key magiclampEnabled true
    $KWC --file kwinrc --group Plugins --key slideEnabled false
    $KWC --file kwinrc --group Plugins --key wobblywindowsEnabled false
    $KWC --file kwinrc --group Plugins --key translucencyEnabled true
    $KWC --file kwinrc --group Plugins --key kwin4_effect_fadeEnabled true
    $KWC --file kwinrc --group Plugins --key dimscreenEnabled true

    $KWC --file kwinrc --group Compositing --key GLPreferBufferSwap "a"

    if command -v qdbus &>/dev/null; then
        qdbus org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
    fi

    log "Desktop mode active. Full effects restored."
}

# ---------------------------------------------------------------------------
# reset — Reset all 24HG Forge desktop customizations
# ---------------------------------------------------------------------------
reset_all() {
    log "Resetting 24HG Forge desktop customizations..."

    # Reset cursor
    $KWC --file kcminputrc --group Mouse --key cursorTheme --delete 2>/dev/null || true
    $KWC --file kcminputrc --group Mouse --key cursorSize --delete 2>/dev/null || true

    # Reset KWin compositor to defaults
    $KWC --file kwinrc --group Compositing --key AnimationSpeed --delete 2>/dev/null || true
    $KWC --file kwinrc --group Compositing --key WindowsBlockCompositing --delete 2>/dev/null || true
    $KWC --file kwinrc --group Compositing --key GLPreferBufferSwap --delete 2>/dev/null || true

    # Reset plugins
    for plugin in blur contrast magiclamp slide wobblywindows translucency kwin4_effect_fade dimscreen; do
        $KWC --file kwinrc --group Plugins --key "${plugin}Enabled" --delete 2>/dev/null || true
    done

    # Reset window behavior
    $KWC --file kwinrc --group Windows --key FocusPolicy --delete 2>/dev/null || true
    $KWC --file kwinrc --group Windows --key AutoRaise --delete 2>/dev/null || true

    # Reset Konsole default
    $KWC --file konsolerc --group "Desktop Entry" --key DefaultProfile --delete 2>/dev/null || true

    # Remove desktop shortcuts we created
    local desktop_dir
    desktop_dir=$(xdg-user-dir DESKTOP 2>/dev/null || echo "$HOME/Desktop")
    rm -f "$desktop_dir/hub.desktop" "$desktop_dir/steam.desktop" "$desktop_dir/discord.desktop"

    if command -v qdbus &>/dev/null; then
        qdbus org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
    fi

    log "Reset complete. Log out and back in for full effect."
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
case "${1:-apply}" in
    apply)   apply_all ;;
    gaming)  apply_gaming ;;
    desktop) apply_desktop ;;
    reset)   reset_all ;;
    *)
        echo "Usage: $0 {apply|gaming|desktop|reset}"
        echo ""
        echo "  apply   — Apply all 24HG Forge desktop customizations (default)"
        echo "  gaming  — Switch to gaming-optimized settings (no effects)"
        echo "  desktop — Restore full desktop effects"
        echo "  reset   — Remove all 24HG Forge customizations"
        exit 1
        ;;
esac
