#!/usr/bin/env bash
# forge-cleaner — System cleaner for 24HG Forge Linux
# Cleans gaming-related junk to reclaim disk space.
set -euo pipefail

VERSION="1.0.0"
CONFIG_DIR="${HOME}/.config/forge/cleaner"
CONFIG_FILE="${CONFIG_DIR}/cleaner.conf"
LOG_FILE="${CONFIG_DIR}/cleaner.log"
STEAM_DIR="${HOME}/.steam/steam"
STEAM_ALT="${HOME}/.local/share/Steam"
DRY_RUN=false
VERBOSE=false

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

# Track space reclaimed per category
declare -A RECLAIMED
CATEGORIES=(shaders prefixes proton workshop downloads flatpak temp crashes logs)
for cat in "${CATEGORIES[@]}"; do RECLAIMED[$cat]=0; done

# ── Helpers ──────────────────────────────────────────────────────────────────

init_config() {
    mkdir -p "$CONFIG_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" <<'CONF'
# forge-cleaner configuration
KEEP_PROTON_VERSIONS=2
MAX_CACHE_AGE_DAYS=30
MAX_LOG_AGE_DAYS=14
MAX_CRASH_AGE_DAYS=7
AUTO_CLEAN_ENABLED=false
AUTO_CLEAN_DAY=Sun
CONF
    fi
    source "$CONFIG_FILE"
    : "${KEEP_PROTON_VERSIONS:=2}" "${MAX_CACHE_AGE_DAYS:=30}"
    : "${MAX_LOG_AGE_DAYS:=14}" "${MAX_CRASH_AGE_DAYS:=7}"
}

log_msg() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"; }

info()  { echo -e "${BLUE}[INFO]${RESET} $*"; }
ok()    { echo -e "${GREEN}[OK]${RESET} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${RESET} $*"; }
err()   { echo -e "${RED}[ERR]${RESET} $*" >&2; }
header(){ echo -e "\n${BOLD}${CYAN}=== $* ===${RESET}"; }

human_size() {
    local bytes=$1
    if (( bytes >= 1073741824 )); then
        echo "$(awk "BEGIN{printf \"%.2f\", $bytes/1073741824}")G"
    elif (( bytes >= 1048576 )); then
        echo "$(awk "BEGIN{printf \"%.1f\", $bytes/1048576}")M"
    elif (( bytes >= 1024 )); then
        echo "$(awk "BEGIN{printf \"%.0f\", $bytes/1024}")K"
    else
        echo "${bytes}B"
    fi
}

dir_size() {
    local path="$1"
    [[ -e "$path" ]] && du -sb "$path" 2>/dev/null | awk '{print $1}' || echo 0
}

remove_path() {
    local path="$1" category="$2" size
    [[ ! -e "$path" ]] && return
    size=$(dir_size "$path")
    if $DRY_RUN; then
        info "[DRY RUN] Would remove: $path ($(human_size "$size"))"
    else
        rm -rf "$path" 2>/dev/null && {
            ok "Removed: $path ($(human_size "$size"))"
            log_msg "Removed $path ($size bytes)"
        }
    fi
    RECLAIMED[$category]=$(( ${RECLAIMED[$category]} + size ))
}

find_steam_dir() {
    if [[ -d "$STEAM_DIR" ]]; then echo "$STEAM_DIR"
    elif [[ -d "$STEAM_ALT" ]]; then echo "$STEAM_ALT"
    else return 1; fi
}

# ── Cleaning Functions ───────────────────────────────────────────────────────

clean_shaders() {
    header "Shader Caches"
    local dirs=(
        "${HOME}/.cache/mesa_shader_cache"
        "${HOME}/.cache/mesa_shader_cache_db"
        "${HOME}/.cache/nvidia/GLCache"
        "${HOME}/.cache/nvidia/ComputeCache"
        "${HOME}/.cache/dxvk_state_cache"
        "${HOME}/.cache/vkd3d-proton"
        "${HOME}/.nv/GLCache"
        "${HOME}/.nv/ComputeCache"
    )
    local steam
    if steam=$(find_steam_dir); then
        dirs+=("${steam}/shadercache")
    fi
    for d in "${dirs[@]}"; do
        if [[ -d "$d" ]]; then
            # Remove old files within the cache
            local old_files
            old_files=$(find "$d" -type f -mtime +"$MAX_CACHE_AGE_DAYS" 2>/dev/null | head -500)
            if [[ -n "$old_files" ]]; then
                local count=0
                while IFS= read -r f; do
                    local fsize
                    fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
                    if $DRY_RUN; then
                        $VERBOSE && info "[DRY RUN] Would remove: $f"
                    else
                        rm -f "$f" 2>/dev/null
                    fi
                    RECLAIMED[shaders]=$(( ${RECLAIMED[shaders]} + fsize ))
                    (( count++ ))
                done <<< "$old_files"
                info "Shader cache $d: $count old files (>${MAX_CACHE_AGE_DAYS} days)"
            fi
        fi
    done
    # Remove orphaned shader caches (Steam apps that no longer exist)
    if steam=$(find_steam_dir) && [[ -d "${steam}/shadercache" ]]; then
        for sc in "${steam}/shadercache"/*/; do
            [[ ! -d "$sc" ]] && continue
            local appid
            appid=$(basename "$sc")
            [[ "$appid" =~ ^[0-9]+$ ]] || continue
            if [[ ! -d "${steam}/steamapps/common" ]] || \
               ! grep -rql "\"appid\".*\"$appid\"" "${steam}/steamapps/"*.acf 2>/dev/null; then
                remove_path "$sc" shaders
            fi
        done
    fi
    ok "Shader cache scan complete"
}

clean_prefixes() {
    header "Orphaned Wine/Proton Prefixes"
    local steam
    steam=$(find_steam_dir) || { warn "Steam not found, skipping prefix scan"; return; }
    local compat="${steam}/steamapps/compatdata"
    [[ -d "$compat" ]] || return
    for prefix in "${compat}"/*/; do
        [[ ! -d "$prefix" ]] && continue
        local appid
        appid=$(basename "$prefix")
        [[ "$appid" =~ ^[0-9]+$ ]] || continue
        # Check if the game is still installed
        if ! ls "${steam}/steamapps/"appmanifest_"${appid}".acf &>/dev/null; then
            remove_path "$prefix" prefixes
        fi
    done
    # Check standalone Wine prefixes
    for wp in "${HOME}/.wine" "${HOME}/.wine"_*; do
        [[ ! -d "$wp" ]] && continue
        local age_days
        age_days=$(( ( $(date +%s) - $(stat -c%Y "$wp") ) / 86400 ))
        if (( age_days > 90 )); then
            local sz
            sz=$(dir_size "$wp")
            if $DRY_RUN; then
                warn "[DRY RUN] Stale Wine prefix (${age_days}d old): $wp ($(human_size "$sz"))"
            else
                warn "Stale Wine prefix (${age_days}d old): $wp — skipping (remove manually)"
            fi
        fi
    done
    ok "Prefix scan complete"
}

clean_proton() {
    header "Old Proton-GE Versions"
    local compat_dir="${steam:-${STEAM_DIR}}/compatibilitytools.d"
    [[ -d "$compat_dir" ]] || compat_dir="${HOME}/.steam/root/compatibilitytools.d"
    [[ -d "$compat_dir" ]] || { warn "No Proton-GE directory found"; return; }
    local -a proton_dirs=()
    while IFS= read -r d; do
        proton_dirs+=("$d")
    done < <(find "$compat_dir" -maxdepth 1 -type d -name "GE-Proton*" 2>/dev/null | sort -V)
    local total=${#proton_dirs[@]}
    if (( total <= KEEP_PROTON_VERSIONS )); then
        info "Found $total Proton-GE version(s), keeping all (threshold: $KEEP_PROTON_VERSIONS)"
        return
    fi
    local remove_count=$(( total - KEEP_PROTON_VERSIONS ))
    info "Found $total Proton-GE versions, removing oldest $remove_count"
    for (( i=0; i<remove_count; i++ )); do
        remove_path "${proton_dirs[$i]}" proton
    done
    ok "Proton cleanup complete"
}

clean_workshop() {
    header "Steam Workshop Content"
    local steam
    steam=$(find_steam_dir) || { warn "Steam not found"; return; }
    local ws="${steam}/steamapps/workshop/content"
    [[ -d "$ws" ]] || return
    for game_dir in "${ws}"/*/; do
        [[ ! -d "$game_dir" ]] && continue
        local appid
        appid=$(basename "$game_dir")
        [[ "$appid" =~ ^[0-9]+$ ]] || continue
        if ! ls "${steam}/steamapps/"appmanifest_"${appid}".acf &>/dev/null; then
            remove_path "$game_dir" workshop
        fi
    done
    # Clean workshop downloads cache
    local dl_cache="${steam}/steamapps/workshop/downloads"
    if [[ -d "$dl_cache" ]]; then
        local sz
        sz=$(dir_size "$dl_cache")
        if (( sz > 0 )); then
            remove_path "$dl_cache" workshop
        fi
    fi
    ok "Workshop cleanup complete"
}

clean_downloads() {
    header "Incomplete Steam Downloads"
    local steam
    steam=$(find_steam_dir) || { warn "Steam not found"; return; }
    local dl_dir="${steam}/steamapps/downloading"
    if [[ -d "$dl_dir" ]]; then
        for item in "${dl_dir}"/*/; do
            [[ -d "$item" ]] && remove_path "$item" downloads
        done
    fi
    # Staged downloads
    local staging="${steam}/steamapps/staging"
    if [[ -d "$staging" ]]; then
        for item in "${staging}"/*/; do
            [[ -d "$item" ]] && remove_path "$item" downloads
        done
    fi
    ok "Downloads cleanup complete"
}

clean_flatpak() {
    header "Flatpak Unused Runtimes"
    if ! command -v flatpak &>/dev/null; then
        warn "Flatpak not installed, skipping"
        return
    fi
    local unused
    unused=$(flatpak uninstall --unused 2>/dev/null | grep -c "^" || true)
    if (( unused > 0 )); then
        if $DRY_RUN; then
            info "[DRY RUN] Would remove $unused unused Flatpak runtime(s):"
            flatpak uninstall --unused 2>/dev/null || true
        else
            info "Removing $unused unused Flatpak runtime(s)..."
            flatpak uninstall --unused -y 2>/dev/null && ok "Flatpak cleanup done" || warn "Some runtimes could not be removed"
        fi
    else
        info "No unused Flatpak runtimes found"
    fi
}

clean_temp() {
    header "Temp Files & Gaming Cache"
    local dirs_to_clean=(
        "${HOME}/.cache/lutris"
        "${HOME}/.cache/heroic"
        "${HOME}/.cache/bottles"
        "${HOME}/.cache/gamemode"
        "${HOME}/.cache/mangohud"
        "${HOME}/.cache/gamescope"
    )
    for d in "${dirs_to_clean[@]}"; do
        [[ -d "$d" ]] && remove_path "$d" temp
    done
    # Old /tmp gaming files (only user-owned)
    local tmp_cleaned=0
    while IFS= read -r f; do
        local fsize
        fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
        if $DRY_RUN; then
            $VERBOSE && info "[DRY RUN] Would remove: $f"
        else
            rm -f "$f" 2>/dev/null
        fi
        RECLAIMED[temp]=$(( ${RECLAIMED[temp]} + fsize ))
        (( tmp_cleaned++ ))
    done < <(find /tmp -maxdepth 2 -user "$(id -u)" -type f \
        \( -name "*.dmp" -o -name "vk_*" -o -name "steam_*" -o -name "proton_*" \) \
        -mtime +1 2>/dev/null | head -200)
    (( tmp_cleaned > 0 )) && info "Cleaned $tmp_cleaned temp files from /tmp"
    # Thumbnail cache (can grow large with game screenshots)
    local thumb="${HOME}/.cache/thumbnails"
    if [[ -d "$thumb" ]]; then
        local old_thumbs=0
        while IFS= read -r f; do
            local fsize
            fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
            $DRY_RUN || rm -f "$f" 2>/dev/null
            RECLAIMED[temp]=$(( ${RECLAIMED[temp]} + fsize ))
            (( old_thumbs++ ))
        done < <(find "$thumb" -type f -mtime +"$MAX_CACHE_AGE_DAYS" 2>/dev/null | head -500)
        (( old_thumbs > 0 )) && info "Cleaned $old_thumbs old thumbnails"
    fi
    ok "Temp file cleanup complete"
}

clean_crashes() {
    header "Crash Dumps & Core Files"
    local crash_dirs=(
        "${HOME}/.local/share/Crash Reports"
        "${HOME}/.config/unity3d/*/crash.dmp"
        "/var/lib/systemd/coredump"
    )
    # User core dumps
    while IFS= read -r f; do
        local fsize
        fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
        if $DRY_RUN; then
            info "[DRY RUN] Would remove core dump: $f ($(human_size "$fsize"))"
        else
            rm -f "$f" 2>/dev/null
            ok "Removed core dump: $f ($(human_size "$fsize"))"
        fi
        RECLAIMED[crashes]=$(( ${RECLAIMED[crashes]} + fsize ))
    done < <(find "${HOME}" -maxdepth 3 -name "core" -o -name "core.*" -o -name "*.dmp" \
        -type f -mtime +"$MAX_CRASH_AGE_DAYS" 2>/dev/null | head -100)
    # Steam minidumps
    local steam
    if steam=$(find_steam_dir); then
        local dumps="${steam}/dumps"
        if [[ -d "$dumps" ]]; then
            while IFS= read -r f; do
                local fsize
                fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
                $DRY_RUN || rm -f "$f" 2>/dev/null
                RECLAIMED[crashes]=$(( ${RECLAIMED[crashes]} + fsize ))
            done < <(find "$dumps" -type f -mtime +"$MAX_CRASH_AGE_DAYS" 2>/dev/null)
            info "Cleaned old Steam crash dumps"
        fi
    fi
    # systemd coredumps (needs sudo)
    if command -v coredumpctl &>/dev/null; then
        local core_count
        core_count=$(coredumpctl list --no-pager 2>/dev/null | grep -c "^" || true)
        (( core_count > 0 )) && info "Found $core_count systemd coredump(s) — run 'sudo journalctl --vacuum-size=100M' to clean"
    fi
    ok "Crash dump cleanup complete"
}

clean_logs() {
    header "Old Game Logs"
    local log_dirs=(
        "${HOME}/.local/share/Steam/logs"
        "${HOME}/.local/share/lutris/runtime/log"
        "${HOME}/.config/heroic/logs"
    )
    # Unity game logs
    while IFS= read -r f; do
        local fsize
        fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
        $DRY_RUN || rm -f "$f" 2>/dev/null
        RECLAIMED[logs]=$(( ${RECLAIMED[logs]} + fsize ))
    done < <(find "${HOME}/.config/unity3d" -name "Player.log" -o -name "Player-prev.log" \
        -type f -mtime +"$MAX_LOG_AGE_DAYS" 2>/dev/null | head -200)
    # Other game log directories
    for ld in "${log_dirs[@]}"; do
        [[ ! -d "$ld" ]] && continue
        while IFS= read -r f; do
            local fsize
            fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
            $DRY_RUN || rm -f "$f" 2>/dev/null
            RECLAIMED[logs]=$(( ${RECLAIMED[logs]} + fsize ))
        done < <(find "$ld" -type f -mtime +"$MAX_LOG_AGE_DAYS" 2>/dev/null | head -200)
    done
    # Wine/Proton logs in prefixes
    local steam
    if steam=$(find_steam_dir) && [[ -d "${steam}/steamapps/compatdata" ]]; then
        while IFS= read -r f; do
            local fsize
            fsize=$(stat -c%s "$f" 2>/dev/null || echo 0)
            $DRY_RUN || rm -f "$f" 2>/dev/null
            RECLAIMED[logs]=$(( ${RECLAIMED[logs]} + fsize ))
        done < <(find "${steam}/steamapps/compatdata" -maxdepth 4 \
            \( -name "*.log" -o -name "*.old" \) -type f \
            -mtime +"$MAX_LOG_AGE_DAYS" 2>/dev/null | head -500)
    fi
    ok "Log cleanup complete"
}

# ── Commands ─────────────────────────────────────────────────────────────────

run_clean() {
    local target="${1:-all}"
    if [[ "$target" == "all" ]]; then
        for cat in "${CATEGORIES[@]}"; do
            "clean_${cat}" 2>/dev/null || warn "Category '$cat' encountered errors"
        done
    else
        local found=false
        for cat in "${CATEGORIES[@]}"; do
            if [[ "$cat" == "$target" ]]; then
                "clean_${cat}"
                found=true
                break
            fi
        done
        $found || { err "Unknown category: $target"; err "Valid: ${CATEGORIES[*]}"; exit 1; }
    fi
    print_summary
}

cmd_scan() {
    DRY_RUN=true
    header "Scanning for cleanable items (dry run)"
    run_clean "${1:-all}"
}

cmd_clean() {
    echo -e "${BOLD}${RED}This will permanently delete files.${RESET}"
    if [[ -t 0 ]] && [[ "${FORGE_CLEANER_YES:-}" != "1" ]]; then
        read -rp "Continue? [y/N] " ans
        [[ "$ans" =~ ^[Yy] ]] || { info "Cancelled."; exit 0; }
    fi
    run_clean "${1:-all}"
    log_msg "Clean completed — total: $(human_size $(total_reclaimed))"
}

cmd_status() {
    header "Gaming Disk Usage Breakdown"
    local steam total=0
    steam=$(find_steam_dir) || { warn "Steam not found"; steam=""; }
    local -A usage
    local paths=(
        "steamapps:${steam}/steamapps"
        "shadercache:${steam}/shadercache"
        "compatdata:${steam}/steamapps/compatdata"
        "workshop:${steam}/steamapps/workshop"
        "downloads:${steam}/steamapps/downloading"
        "mesa_cache:${HOME}/.cache/mesa_shader_cache"
        "nvidia_cache:${HOME}/.nv"
        "lutris:${HOME}/.local/share/lutris"
        "heroic:${HOME}/.config/heroic"
        "bottles:${HOME}/.local/share/bottles"
        "wine:${HOME}/.wine"
    )
    printf "\n  %-20s %10s\n" "Category" "Size"
    printf "  %-20s %10s\n" "--------------------" "----------"
    for entry in "${paths[@]}"; do
        local label="${entry%%:*}" path="${entry#*:}"
        if [[ -n "$path" && -d "$path" ]]; then
            local sz
            sz=$(du -sb "$path" 2>/dev/null | awk '{print $1}')
            sz=${sz:-0}
            printf "  %-20s %10s\n" "$label" "$(human_size "$sz")"
            total=$(( total + sz ))
        fi
    done
    printf "  %-20s %10s\n" "--------------------" "----------"
    printf "  ${BOLD}%-20s %10s${RESET}\n" "TOTAL" "$(human_size $total)"
    # Disk free
    echo ""
    local disk_free
    disk_free=$(df -h "${HOME}" | awk 'NR==2{printf "%s free / %s total (%s used)", $4, $2, $5}')
    info "Home partition: $disk_free"
}

cmd_schedule() {
    local action="${1:-}"
    local timer_dir="${HOME}/.config/systemd/user"
    local service_file="${timer_dir}/forge-cleaner.service"
    local timer_file="${timer_dir}/forge-cleaner.timer"
    case "$action" in
        on)
            mkdir -p "$timer_dir"
            cat > "$service_file" <<EOF
[Unit]
Description=24HG Forge System Cleaner (weekly)

[Service]
Type=oneshot
Environment=FORGE_CLEANER_YES=1
ExecStart=$(readlink -f "$0") clean
EOF
            cat > "$timer_file" <<EOF
[Unit]
Description=Weekly Forge cleaner

[Timer]
OnCalendar=${AUTO_CLEAN_DAY} 04:00
Persistent=true

[Install]
WantedBy=timers.target
EOF
            systemctl --user daemon-reload
            systemctl --user enable --now forge-cleaner.timer
            sed -i 's/^AUTO_CLEAN_ENABLED=.*/AUTO_CLEAN_ENABLED=true/' "$CONFIG_FILE"
            ok "Weekly auto-clean enabled (${AUTO_CLEAN_DAY} at 04:00)"
            ;;
        off)
            systemctl --user disable --now forge-cleaner.timer 2>/dev/null || true
            rm -f "$service_file" "$timer_file"
            systemctl --user daemon-reload 2>/dev/null || true
            sed -i 's/^AUTO_CLEAN_ENABLED=.*/AUTO_CLEAN_ENABLED=false/' "$CONFIG_FILE"
            ok "Auto-clean disabled"
            ;;
        *)
            if systemctl --user is-active forge-cleaner.timer &>/dev/null; then
                ok "Auto-clean is ENABLED"
                systemctl --user status forge-cleaner.timer --no-pager 2>/dev/null || true
            else
                info "Auto-clean is DISABLED — use 'forge-cleaner schedule on' to enable"
            fi
            ;;
    esac
}

# ── Summary ──────────────────────────────────────────────────────────────────

total_reclaimed() {
    local total=0
    for cat in "${CATEGORIES[@]}"; do
        total=$(( total + ${RECLAIMED[$cat]} ))
    done
    echo $total
}

print_summary() {
    header "Cleanup Summary"
    local action="reclaimed"
    $DRY_RUN && action="reclaimable"
    printf "\n  %-15s %12s\n" "Category" "Space ${action}"
    printf "  %-15s %12s\n" "---------------" "------------"
    for cat in "${CATEGORIES[@]}"; do
        local val=${RECLAIMED[$cat]}
        (( val > 0 )) && printf "  %-15s %12s\n" "$cat" "$(human_size "$val")"
    done
    local total
    total=$(total_reclaimed)
    printf "  %-15s %12s\n" "---------------" "------------"
    printf "  ${BOLD}%-15s %12s${RESET}\n" "TOTAL" "$(human_size "$total")"
    echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${BOLD}forge-cleaner${RESET} v${VERSION} — 24HG Forge System Cleaner

${BOLD}Usage:${RESET}
  forge-cleaner scan [category]       Scan for cleanable items (dry run)
  forge-cleaner clean [category]      Clean all or specific category
  forge-cleaner status                Show gaming disk usage breakdown
  forge-cleaner schedule [on|off]     Toggle weekly auto-clean

${BOLD}Categories:${RESET}
  shaders    Shader caches (Mesa, NVIDIA, DXVK, VKD3D)
  prefixes   Orphaned Wine/Proton prefixes
  proton     Old Proton-GE versions (keeps latest ${KEEP_PROTON_VERSIONS:-2})
  workshop   Unused Steam Workshop content
  downloads  Incomplete Steam downloads
  flatpak    Unused Flatpak runtimes
  temp       Temp files and gaming cache
  crashes    Crash dumps and core files
  logs       Old game logs

${BOLD}Options:${RESET}
  -v, --verbose    Verbose output
  -y, --yes        Skip confirmation prompt
  -h, --help       Show this help
  --version        Show version

${BOLD}Config:${RESET} ${CONFIG_DIR}/cleaner.conf
EOF
}

main() {
    init_config

    # Parse global flags
    local args=()
    for arg in "$@"; do
        case "$arg" in
            -v|--verbose) VERBOSE=true ;;
            -y|--yes) export FORGE_CLEANER_YES=1 ;;
            -h|--help) usage; exit 0 ;;
            --version) echo "forge-cleaner v${VERSION}"; exit 0 ;;
            *) args+=("$arg") ;;
        esac
    done
    set -- "${args[@]+"${args[@]}"}"

    local command="${1:-}"
    shift || true

    case "$command" in
        scan)       cmd_scan "$@" ;;
        clean)      cmd_clean "$@" ;;
        status)     cmd_status ;;
        schedule)   cmd_schedule "$@" ;;
        "")         usage ;;
        *)          err "Unknown command: $command"; usage; exit 1 ;;
    esac
}

main "$@"
