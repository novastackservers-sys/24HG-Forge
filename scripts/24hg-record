#!/bin/bash
set -euo pipefail
# 24HG Record — Per-game screen recording profile manager

# ── Colors & formatting ────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'
CYAN='\033[0;36m'; MAGENTA='\033[0;35m'; BOLD='\033[1m'; DIM='\033[2m'
RESET='\033[0m'; ORANGE='\033[38;5;208m'; GOLD='\033[38;5;220m'

# ── Paths & defaults ───────────────────────────────────────────────────────
CONFIG_DIR="$HOME/.config/24hg"
PROFILE_DIR="$CONFIG_DIR/recording-profiles"
RECORDINGS_DIR="$HOME/Videos/Recordings"
PID_FILE="/tmp/24hg-record.pid"
STATE_FILE="/tmp/24hg-record.state"
DAEMON_PID_FILE="/tmp/24hg-record-daemon.pid"
LOG_TAG="24hg-record"
AUTO_RECORD_FILE="$CONFIG_DIR/auto-record"

# ── Helpers ─────────────────────────────────────────────────────────────────
log() { logger -t "$LOG_TAG" "$*" 2>/dev/null || true; }
info()    { echo -e "${BLUE}${BOLD}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}${BOLD}[  OK]${RESET}  $*"; }
warn()    { echo -e "${YELLOW}${BOLD}[WARN]${RESET}  $*"; }
error()   { echo -e "${RED}${BOLD}[ ERR]${RESET}  $*" >&2; }
die() { error "$*"; log "ERROR: $*"; exit 1; }

banner() {
    echo -e "${ORANGE}${BOLD}"
    echo "  +-----------------------------------------+"
    echo "  |       24HG Screen Recorder             |"
    echo "  |          24 Hour Gaming                 |"
    echo "  +-----------------------------------------+"
    echo -e "${RESET}"
}

notify() {
    notify-send -a "24HG Record" -i "${3:-24hg-logo}" "$1" "$2" 2>/dev/null || true
}

ensure_dirs() { mkdir -p "$CONFIG_DIR" "$PROFILE_DIR" "$RECORDINGS_DIR"; }

# ── GPU & display detection ────────────────────────────────────────────────
detect_gpu() {
    if lspci 2>/dev/null | grep -qi "nvidia"; then echo "nvidia"
    elif lspci 2>/dev/null | grep -qi "amd.*radeon\|advanced micro"; then echo "amd"
    elif lspci 2>/dev/null | grep -qi "intel.*graphics\|intel.*uhd\|intel.*iris"; then echo "intel"
    else echo "unknown"; fi
}

detect_display() {
    if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then echo "wayland"
    elif [[ -n "${DISPLAY:-}" ]]; then echo "x11"
    else echo "headless"; fi
}

detect_encoder() {
    local pref="${1:-auto}"
    [[ "$pref" != "auto" ]] && { echo "$pref"; return; }
    case "$(detect_gpu)" in
        nvidia) echo "nvenc" ;; amd) echo "amf" ;; intel) echo "vaapi" ;; *) echo "x264" ;;
    esac
}

choose_recorder() {
    if command -v gpu-screen-recorder &>/dev/null; then echo "gpu-screen-recorder"
    elif [[ "$(detect_display)" == "wayland" ]] && command -v wf-recorder &>/dev/null; then echo "wf-recorder"
    elif command -v ffmpeg &>/dev/null; then echo "ffmpeg"
    else echo "none"; fi
}

get_screen_resolution() {
    local res=""
    if command -v xdpyinfo &>/dev/null && [[ -n "${DISPLAY:-}" ]]; then
        res=$(xdpyinfo 2>/dev/null | awk '/dimensions/{print $2}')
    elif command -v wlr-randr &>/dev/null; then
        res=$(wlr-randr 2>/dev/null | awk '/current/{print $1}' | head -1)
    elif command -v xrandr &>/dev/null; then
        res=$(xrandr 2>/dev/null | awk '/\*/{print $1}' | head -1)
    fi
    echo "${res:-1920x1080}"
}

# ── Game detection ──────────────────────────────────────────────────────────
detect_running_game() {
    local pid name cmdline
    for pid in /proc/[0-9]*/; do
        [[ -f "${pid}comm" ]] || continue
        name=$(cat "${pid}comm" 2>/dev/null) || continue
        cmdline=$(tr '\0' ' ' < "${pid}cmdline" 2>/dev/null) || continue
        case "$name" in
            bash|sh|zsh|fish|python*|node|java|systemd*|dbus*|pipewire*|pulseaudio*) continue ;;
        esac
        if [[ "$cmdline" == *"SteamApps/common/"* ]]; then
            local gp; gp=$(echo "$cmdline" | grep -oP 'SteamApps/common/\K[^/]+' | head -1)
            [[ -n "$gp" ]] && { echo "$gp"; return 0; }
        fi
        if [[ "$cmdline" == *"/drive_c/"* ]] || [[ "$cmdline" == *"lutris"* ]]; then
            local en; en=$(echo "$cmdline" | grep -oP '[^/\\]+\.exe' | head -1 | sed 's/\.exe$//')
            [[ -n "$en" ]] && { echo "$en"; return 0; }
        fi
    done
    pgrep -x gamescope &>/dev/null && { echo "gamescope-session"; return 0; }
    echo ""; return 1
}

sanitize_game_name() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g; s/--*/-/g; s/^-//; s/-$//'
}

# ── Profile management ─────────────────────────────────────────────────────
default_profile_json() {
    cat <<'PROF'
{
    "resolution": "native",
    "fps": 60,
    "encoder": "auto",
    "bitrate": "high",
    "bitrate_custom_kbps": 20000,
    "audio": "desktop-only",
    "mic_noise_suppression": true,
    "container": "mp4",
    "output_dir": "",
    "max_file_size_mb": 4000,
    "max_duration_minutes": 0,
    "webcam_enabled": false,
    "webcam_device": "/dev/video0",
    "webcam_position": "bottom-right",
    "webcam_size": "small",
    "auto_highlights": true
}
PROF
}

get_profile_path() { echo "$PROFILE_DIR/$(sanitize_game_name "$1").json"; }

load_profile() {
    local pp; pp=$(get_profile_path "$1")
    if [[ -f "$pp" ]]; then cat "$pp"
    elif [[ -f "$PROFILE_DIR/default.json" ]]; then cat "$PROFILE_DIR/default.json"
    else default_profile_json; fi
}

read_profile_field() {
    echo "$1" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('$2',''))" 2>/dev/null
}

# Interactive menu helper: prints options and returns chosen value
_menu() {
    local prompt="$1"; shift
    echo -e "\n  ${BOLD}${prompt}:${RESET}"
    local i=1; for opt in "$@"; do echo "    $i) $opt"; ((i++)); done
    read -rp "  Choose [1]: " choice
    echo "${choice:-1}"
}

profile_create() {
    local game="$1" profile_path
    profile_path=$(get_profile_path "$game")
    if [[ -f "$profile_path" ]]; then
        warn "Profile already exists at $profile_path"
        read -rp "Overwrite? [y/N] " ans
        [[ "${ans,,}" == "y" ]] || { info "Cancelled."; return 0; }
    fi
    info "Creating recording profile for: ${CYAN}${game}${RESET}"

    # Resolution
    local rc; rc=$(_menu "Resolution" "native (screen resolution)" "1080p" "720p" "match-game")
    local res; case "$rc" in 2) res="1080p";; 3) res="720p";; 4) res="match-game";; *) res="native";; esac

    # FPS
    local fc; fc=$(_menu "FPS" "60" "30" "match-game")
    local fps; case "$fc" in 2) fps=30;; 3) fps=0;; *) fps=60;; esac

    # Encoder
    local detected_enc; detected_enc=$(detect_encoder "auto")
    local ec; ec=$(_menu "Encoder" "auto (detected: $detected_enc)" "nvenc (NVIDIA)" "amf (AMD)" "vaapi (Intel/AMD)" "x264 (CPU)")
    local encoder; case "$ec" in 2) encoder="nvenc";; 3) encoder="amf";; 4) encoder="vaapi";; 5) encoder="x264";; *) encoder="auto";; esac

    # Bitrate
    local bc; bc=$(_menu "Bitrate" "high (20 Mbps)" "medium (10 Mbps)" "low (5 Mbps)" "custom")
    local bitrate="high" bitrate_custom=20000
    case "$bc" in
        2) bitrate="medium"; bitrate_custom=10000;;
        3) bitrate="low"; bitrate_custom=5000;;
        4) bitrate="custom"; read -rp "  Bitrate in kbps [20000]: " cv; bitrate_custom="${cv:-20000}";;
    esac

    # Audio
    local ac; ac=$(_menu "Audio capture" "desktop-only" "desktop+mic" "mic-only")
    local audio; case "$ac" in 2) audio="desktop+mic";; 3) audio="mic-only";; *) audio="desktop-only";; esac

    # Noise suppression (if mic involved)
    local mic_ns="true"
    if [[ "$audio" == *"mic"* ]]; then
        read -rp "  Enable mic noise suppression (RNNoise)? [Y/n]: " ns
        [[ "${ns,,}" == "n" ]] && mic_ns="false"
    fi

    # Container
    local cc; cc=$(_menu "Container format" "mp4" "mkv")
    local container; case "$cc" in 2) container="mkv";; *) container="mp4";; esac

    # Limits
    read -rp "  Max file size in MB (0=unlimited) [4000]: " max_size; max_size="${max_size:-4000}"
    read -rp "  Max duration in minutes (0=unlimited) [0]: " max_dur; max_dur="${max_dur:-0}"

    # Webcam
    local wc_on="false" wc_dev="/dev/video0" wc_pos="bottom-right" wc_sz="small"
    read -rp "  Enable webcam overlay? [y/N]: " wc
    if [[ "${wc,,}" == "y" ]]; then
        wc_on="true"
        read -rp "  Webcam device [/dev/video0]: " wd; wc_dev="${wd:-/dev/video0}"
        local wp; wp=$(_menu "Webcam position" "bottom-right" "bottom-left" "top-right" "top-left")
        case "$wp" in 2) wc_pos="bottom-left";; 3) wc_pos="top-right";; 4) wc_pos="top-left";; esac
        local ws; ws=$(_menu "Webcam size" "small (160x120)" "medium (320x240)" "large (480x360)")
        case "$ws" in 2) wc_sz="medium";; 3) wc_sz="large";; esac
    fi

    # Write profile JSON
    local fps_json="$fps"; [[ "$fps" -eq 0 ]] && fps_json='"match-game"'
    mkdir -p "$PROFILE_DIR"
    cat > "$profile_path" <<EOF
{
    "game": "$game",
    "resolution": "$res",
    "fps": $fps_json,
    "encoder": "$encoder",
    "bitrate": "$bitrate",
    "bitrate_custom_kbps": $bitrate_custom,
    "audio": "$audio",
    "mic_noise_suppression": $mic_ns,
    "container": "$container",
    "output_dir": "",
    "max_file_size_mb": $max_size,
    "max_duration_minutes": $max_dur,
    "webcam_enabled": $wc_on,
    "webcam_device": "$wc_dev",
    "webcam_position": "$wc_pos",
    "webcam_size": "$wc_sz",
    "auto_highlights": true
}
EOF
    success "Profile saved: $profile_path"
    log "Created profile for $game at $profile_path"
}

profile_list() {
    ensure_dirs
    local count=0
    echo -e "\n  ${BOLD}Recording Profiles:${RESET}\n"
    if [[ -d "$PROFILE_DIR" ]]; then
        for f in "$PROFILE_DIR"/*.json; do
            [[ -f "$f" ]] || continue
            local name; name=$(basename "$f" .json)
            local res fps enc br
            res=$(python3 -c "import json; d=json.load(open('$f')); print(d.get('resolution','?'))" 2>/dev/null || echo "?")
            fps=$(python3 -c "import json; d=json.load(open('$f')); print(d.get('fps','?'))" 2>/dev/null || echo "?")
            enc=$(python3 -c "import json; d=json.load(open('$f')); print(d.get('encoder','?'))" 2>/dev/null || echo "?")
            br=$(python3 -c "import json; d=json.load(open('$f')); print(d.get('bitrate','?'))" 2>/dev/null || echo "?")
            local label="${CYAN}${name}${RESET}"
            [[ "$name" == "default" ]] && label="${GOLD}${name} (fallback)${RESET}"
            printf "    %-30b  %s @ %s fps  |  %s  |  %s\n" "$label" "$res" "$fps" "$enc" "$br"
            ((count++))
        done
    fi
    (( count == 0 )) && echo -e "    ${DIM}No profiles. Create one: 24hg-record profile create <game>${RESET}"
    echo ""
}

profile_edit() {
    local pp; pp=$(get_profile_path "$1")
    [[ -f "$pp" ]] || die "No profile for '$1'. Create first: 24hg-record profile create $1"
    local editor="${VISUAL:-${EDITOR:-nano}}"
    info "Opening $pp with $editor"
    "$editor" "$pp"
    if python3 -c "import json; json.load(open('$pp'))" 2>/dev/null; then
        success "Profile saved and validated."
    else
        error "Profile contains invalid JSON. Please fix it."
    fi
}

profile_delete() {
    local pp; pp=$(get_profile_path "$1")
    [[ -f "$pp" ]] || die "No profile for '$1'."
    read -rp "Delete profile '$(basename "$pp" .json)'? [y/N] " ans
    [[ "${ans,,}" == "y" ]] && { rm -f "$pp"; success "Deleted $pp"; } || info "Cancelled."
}

# ── Resolve profile settings to concrete values ────────────────────────────
resolve_resolution() {
    case "$1" in
        native|match-game) get_screen_resolution;; 1080p) echo "1920x1080";;
        720p) echo "1280x720";; *) echo "$1";;
    esac
}

resolve_bitrate() {
    case "$1" in
        high) echo "20000000";; medium) echo "10000000";; low) echo "5000000";;
        custom) echo "$(( ${2:-20000} * 1000 ))";; *) echo "20000000";;
    esac
}

# ── PipeWire audio source selection ────────────────────────────────────────
get_audio_sources() {
    local desktop_src mic_src
    desktop_src=$(pactl info 2>/dev/null | awk -F': ' '/Default Sink/{print $2}')
    [[ -n "$desktop_src" ]] && desktop_src="${desktop_src}.monitor"
    mic_src=$(pactl info 2>/dev/null | awk -F': ' '/Default Source/{print $2}')
    [[ "$mic_src" == *".monitor" ]] && \
        mic_src=$(pactl list short sources 2>/dev/null | grep -v monitor | awk '{print $2}' | head -1)
    case "$1" in
        desktop-only) echo "${desktop_src:-auto}";;
        desktop+mic)  echo "${desktop_src:-auto}|${mic_src:-auto}";;
        mic-only)     echo "${mic_src:-auto}";;
        *)            echo "${desktop_src:-auto}";;
    esac
}

# ── Build recorder command ──────────────────────────────────────────────────
build_record_cmd() {
    local profile_json="$1" output_file="$2"
    local recorder; recorder=$(choose_recorder)
    [[ "$recorder" == "none" ]] && die "No recorder found. Install gpu-screen-recorder, wf-recorder, or ffmpeg."

    local enc_setting res_setting fps_val bitrate_name custom_kbps audio_mode container
    enc_setting=$(read_profile_field "$profile_json" "encoder")
    res_setting=$(read_profile_field "$profile_json" "resolution")
    fps_val=$(read_profile_field "$profile_json" "fps")
    bitrate_name=$(read_profile_field "$profile_json" "bitrate")
    custom_kbps=$(read_profile_field "$profile_json" "bitrate_custom_kbps")
    audio_mode=$(read_profile_field "$profile_json" "audio")
    container=$(read_profile_field "$profile_json" "container")

    local res_px enc bitrate_bps fps_num audio_sources
    res_px=$(resolve_resolution "${res_setting:-native}")
    enc=$(detect_encoder "${enc_setting:-auto}")
    bitrate_bps=$(resolve_bitrate "${bitrate_name:-high}" "${custom_kbps:-20000}")
    fps_num="${fps_val:-60}"
    [[ "$fps_num" == "match-game" || "$fps_num" == "0" ]] && fps_num=60
    audio_sources=$(get_audio_sources "${audio_mode:-desktop-only}")

    local cmd=()
    case "$recorder" in
        gpu-screen-recorder)
            cmd=(gpu-screen-recorder -w screen -f "$fps_num" -a "$(echo "$audio_sources" | cut -d'|' -f1)")
            [[ "$audio_sources" == *"|"* ]] && cmd+=(-a "$(echo "$audio_sources" | cut -d'|' -f2)")
            case "$enc" in x264) cmd+=(-encoder cpu);; *) cmd+=(-encoder gpu);; esac
            local qlabel="ultra"
            case "${bitrate_name:-high}" in medium) qlabel="high";; low) qlabel="medium";; esac
            cmd+=(-q "$qlabel" -c "${container:-mp4}" -o "$output_file")
            ;;
        wf-recorder)
            cmd=(wf-recorder -f "$output_file" --framerate "$fps_num")
            local pw_src; pw_src=$(echo "$audio_sources" | cut -d'|' -f1)
            [[ "$pw_src" != "auto" ]] && cmd+=(--audio="$pw_src")
            case "$enc" in
                nvenc) cmd+=(--codec h264_nvenc);; vaapi) cmd+=(--codec h264_vaapi);;
                amf) cmd+=(--codec h264_amf);; *) cmd+=(--codec libx264);;
            esac
            cmd+=(-p "b=${bitrate_bps}")
            ;;
        ffmpeg)
            [[ "$(detect_display)" != "x11" ]] && die "ffmpeg fallback requires X11."
            cmd=(ffmpeg -y -f x11grab -video_size "$res_px" -framerate "$fps_num" -i "${DISPLAY:-:0}")
            local pw_src; pw_src=$(echo "$audio_sources" | cut -d'|' -f1)
            [[ "$pw_src" != "auto" ]] && cmd+=(-f pulse -i "$pw_src")
            case "$enc" in
                nvenc) cmd+=(-c:v h264_nvenc -preset p4 -b:v "$bitrate_bps");;
                vaapi) cmd+=(-vaapi_device /dev/dri/renderD128 -c:v h264_vaapi -b:v "$bitrate_bps");;
                amf)   cmd+=(-c:v h264_amf -b:v "$bitrate_bps");;
                *)     cmd+=(-c:v libx264 -preset fast -b:v "$bitrate_bps");;
            esac
            cmd+=(-c:a aac -b:a 192k "$output_file")
            ;;
    esac
    echo "${cmd[@]}"
}

ensure_default_profile() {
    local dp="$PROFILE_DIR/default.json"
    [[ -f "$dp" ]] || { mkdir -p "$PROFILE_DIR"; default_profile_json > "$dp"; log "Created default profile"; }
}

# ── Noise suppression helpers ──────────────────────────────────────────────
start_noise_suppression() {
    if command -v noisetorch &>/dev/null; then
        noisetorch -i 2>/dev/null & disown; log "Started NoiseTorch"
    elif command -v easyeffects &>/dev/null; then
        log "EasyEffects available for noise suppression (user must configure)"
    else log "No noise suppression tool found"; fi
}
stop_noise_suppression() {
    command -v noisetorch &>/dev/null && { noisetorch -u 2>/dev/null || true; log "Stopped NoiseTorch"; }
}

# ── File size monitor for auto-splitting ────────────────────────────────────
_monitor_file_size() {
    local file="$1" max_bytes=$(( $2 * 1024 * 1024 )) rec_pid="$3" game="$4"
    while kill -0 "$rec_pid" 2>/dev/null; do
        sleep 10
        if [[ -f "$file" ]]; then
            local size; size=$(stat -c%s "$file" 2>/dev/null || echo 0)
            if (( size >= max_bytes )); then
                log "File size limit reached ($2 MB), splitting"
                kill "$rec_pid" 2>/dev/null || true
                wait "$rec_pid" 2>/dev/null || true
                notify "Recording Split" "File reached ${2}MB, starting new segment" "media-record"
                cmd_start "$game"; break
            fi
        fi
    done
}

# ── Start recording ────────────────────────────────────────────────────────
cmd_start() {
    local game="${1:-}"
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        die "Already recording (PID $(cat "$PID_FILE")). Stop first: 24hg-record stop"
    fi
    ensure_dirs; ensure_default_profile

    # Auto-detect game if not specified
    if [[ -z "$game" ]]; then
        game=$(detect_running_game) || true
        if [[ -z "$game" ]]; then game="manual"; info "No game detected, using 'manual' profile"
        else info "Detected game: ${CYAN}${game}${RESET}"; fi
    fi

    local safe_game; safe_game=$(sanitize_game_name "$game")
    local profile_json; profile_json=$(load_profile "$game")

    # Output directory and filename
    local out_dir; out_dir=$(read_profile_field "$profile_json" "output_dir")
    [[ -z "$out_dir" || "$out_dir" == "null" ]] && out_dir="$RECORDINGS_DIR/$safe_game"
    mkdir -p "$out_dir"
    local container; container=$(read_profile_field "$profile_json" "container"); container="${container:-mp4}"
    local output_file="$out_dir/${safe_game}_$(date +%Y-%m-%d_%H-%M-%S).${container}"

    # Build and start recorder
    local record_cmd; record_cmd=$(build_record_cmd "$profile_json" "$output_file")
    log "Starting: $record_cmd"
    info "Starting recording..."
    info "  Game:   ${CYAN}${game}${RESET}"
    info "  Output: ${DIM}${output_file}${RESET}"

    # Start RNNoise if mic is in use
    local mic_ns; mic_ns=$(read_profile_field "$profile_json" "mic_noise_suppression")
    local audio_mode; audio_mode=$(read_profile_field "$profile_json" "audio")
    [[ "${mic_ns:-false}" == "true" && "$audio_mode" == *"mic"* ]] && start_noise_suppression

    # Launch recorder in background
    # shellcheck disable=SC2086
    eval $record_cmd &
    local rec_pid=$!
    echo "$rec_pid" > "$PID_FILE"

    local max_dur; max_dur=$(read_profile_field "$profile_json" "max_duration_minutes"); max_dur="${max_dur:-0}"
    cat > "$STATE_FILE" <<EOF
GAME=$game
SAFE_GAME=$safe_game
OUTPUT_FILE=$output_file
START_TIME=$(date +%s)
RECORDER_PID=$rec_pid
CONTAINER=$container
MAX_DURATION=$max_dur
PAUSED=false
EOF
    success "Recording started (PID $rec_pid)"
    notify "Recording Started" "Game: $game\nOutput: $(basename "$output_file")" "media-record"

    # Auto-split monitor
    local max_size_mb; max_size_mb=$(read_profile_field "$profile_json" "max_file_size_mb"); max_size_mb="${max_size_mb:-4000}"
    (( max_size_mb > 0 )) && { _monitor_file_size "$output_file" "$max_size_mb" "$rec_pid" "$game" & disown; }

    # Duration limit
    if (( max_dur > 0 )); then
        ( sleep $((max_dur * 60)); kill -0 "$rec_pid" 2>/dev/null && cmd_stop ) & disown
    fi
    log "Recording started for $game -> $output_file (PID $rec_pid)"
}

# ── Stop recording ─────────────────────────────────────────────────────────
cmd_stop() {
    [[ -f "$PID_FILE" ]] || die "No active recording found."
    local rec_pid; rec_pid=$(cat "$PID_FILE")
    if ! kill -0 "$rec_pid" 2>/dev/null; then
        warn "Recorder ($rec_pid) already stopped."; rm -f "$PID_FILE" "$STATE_FILE"; return 0
    fi
    info "Stopping recording (PID $rec_pid)..."

    # Graceful SIGINT then force-kill after 10s
    kill -INT "$rec_pid" 2>/dev/null || true
    local w=0
    while kill -0 "$rec_pid" 2>/dev/null && (( w < 10 )); do sleep 1; ((w++)); done
    kill -0 "$rec_pid" 2>/dev/null && { kill -9 "$rec_pid" 2>/dev/null || true; warn "Force-killed after 10s."; }
    stop_noise_suppression

    # Read state
    local output_file="" game="" start_time=0
    if [[ -f "$STATE_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$STATE_FILE"
        output_file="${OUTPUT_FILE:-}"; game="${GAME:-unknown}"; start_time="${START_TIME:-0}"
    fi
    rm -f "$PID_FILE" "$STATE_FILE"

    local duration_str="" file_size=""
    if (( start_time > 0 )); then
        local el=$(( $(date +%s) - start_time ))
        duration_str="$((el / 60))m $((el % 60))s"
    fi
    [[ -n "$output_file" && -f "$output_file" ]] && file_size=$(du -h "$output_file" 2>/dev/null | awk '{print $1}')

    success "Recording stopped."
    [[ -n "$duration_str" ]] && info "  Duration: ${CYAN}${duration_str}${RESET}"
    [[ -n "$file_size" ]]    && info "  Size:     ${CYAN}${file_size}${RESET}"
    [[ -n "$output_file" ]]  && info "  File:     ${DIM}${output_file}${RESET}"
    notify "Recording Saved" "Duration: ${duration_str}\nSize: ${file_size}\n$(basename "${output_file:-recording}")" "media-playback-stop"

    # Auto-highlight analysis via 24hg-highlights integration
    if [[ -n "$output_file" && -f "$output_file" ]]; then
        local pj; pj=$(load_profile "${game:-manual}")
        local ahl; ahl=$(read_profile_field "$pj" "auto_highlights")
        if [[ "${ahl:-true}" == "true" ]] && command -v 24hg-highlights &>/dev/null; then
            info "Queuing highlight analysis..."
            24hg-highlights analyze "$output_file" & disown
        fi
    fi
    log "Recording stopped: $output_file ($duration_str, $file_size)"
}

# ── Pause / Resume ─────────────────────────────────────────────────────────
cmd_pause() {
    [[ -f "$PID_FILE" ]] || die "No active recording found."
    local rec_pid; rec_pid=$(cat "$PID_FILE")
    kill -0 "$rec_pid" 2>/dev/null || die "Recorder process not running."
    if [[ -f "$STATE_FILE" ]]; then
        local paused; paused=$(grep "^PAUSED=" "$STATE_FILE" | cut -d= -f2)
        [[ "$paused" == "true" ]] && { warn "Already paused."; return 0; }
    fi
    kill -STOP "$rec_pid" 2>/dev/null || die "Failed to pause."
    sed -i 's/^PAUSED=.*/PAUSED=true/' "$STATE_FILE" 2>/dev/null || true
    success "Recording paused."
    notify "Recording Paused" "Press resume to continue" "media-playback-pause"
    log "Recording paused (PID $rec_pid)"
}

cmd_resume() {
    [[ -f "$PID_FILE" ]] || die "No active recording found."
    local rec_pid; rec_pid=$(cat "$PID_FILE")
    kill -0 "$rec_pid" 2>/dev/null || die "Recorder process not running."
    kill -CONT "$rec_pid" 2>/dev/null || die "Failed to resume."
    sed -i 's/^PAUSED=.*/PAUSED=false/' "$STATE_FILE" 2>/dev/null || true
    success "Recording resumed."
    notify "Recording Resumed" "Recording is active" "media-record"
    log "Recording resumed (PID $rec_pid)"
}

# ── Status ──────────────────────────────────────────────────────────────────
cmd_status() {
    echo ""
    if [[ ! -f "$PID_FILE" ]]; then
        echo -e "  ${BOLD}Status:${RESET}      ${DIM}Not recording${RESET}"
        echo ""
        if [[ -f "$AUTO_RECORD_FILE" ]] && [[ "$(cat "$AUTO_RECORD_FILE")" == "on" ]]; then
            echo -e "  ${BOLD}Auto-record:${RESET} ${GREEN}enabled${RESET}"
        else
            echo -e "  ${BOLD}Auto-record:${RESET} ${DIM}disabled${RESET}"
        fi
        if [[ -f "$DAEMON_PID_FILE" ]] && kill -0 "$(cat "$DAEMON_PID_FILE")" 2>/dev/null; then
            echo -e "  ${BOLD}Daemon:${RESET}      ${GREEN}running${RESET} (PID $(cat "$DAEMON_PID_FILE"))"
        else
            echo -e "  ${BOLD}Daemon:${RESET}      ${DIM}stopped${RESET}"
        fi
        echo ""
        echo -e "  ${BOLD}Recorder:${RESET}    ${CYAN}$(choose_recorder)${RESET}"
        echo -e "  ${BOLD}Encoder:${RESET}     ${CYAN}$(detect_encoder auto)${RESET} ($(detect_gpu) GPU)"
        echo -e "  ${BOLD}Display:${RESET}     ${CYAN}$(detect_display)${RESET}"
        echo ""; return 0
    fi

    local rec_pid; rec_pid=$(cat "$PID_FILE")
    if ! kill -0 "$rec_pid" 2>/dev/null; then
        echo -e "  ${BOLD}Status:${RESET} ${YELLOW}Stale PID (process gone)${RESET}"
        rm -f "$PID_FILE" "$STATE_FILE"; echo ""; return 0
    fi

    local game="" output_file="" start_time=0 paused="false"
    if [[ -f "$STATE_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$STATE_FILE"
        game="${GAME:-unknown}"; output_file="${OUTPUT_FILE:-}"
        start_time="${START_TIME:-0}"; paused="${PAUSED:-false}"
    fi

    local sl="${GREEN}RECORDING${RESET}"
    [[ "$paused" == "true" ]] && sl="${YELLOW}PAUSED${RESET}"
    echo -e "  ${BOLD}Status:${RESET}   $sl"
    echo -e "  ${BOLD}Game:${RESET}     ${CYAN}${game}${RESET}"
    echo -e "  ${BOLD}PID:${RESET}      ${rec_pid}"
    if (( start_time > 0 )); then
        local el=$(( $(date +%s) - start_time ))
        printf "  ${BOLD}Duration:${RESET} %02d:%02d:%02d\n" $((el/3600)) $(((el%3600)/60)) $((el%60))
    fi
    if [[ -n "$output_file" && -f "$output_file" ]]; then
        echo -e "  ${BOLD}Size:${RESET}     $(du -h "$output_file" 2>/dev/null | awk '{print $1}')"
        echo -e "  ${BOLD}File:${RESET}     ${DIM}${output_file}${RESET}"
    fi
    echo ""
}

# ── Auto-record toggle ─────────────────────────────────────────────────────
cmd_auto() {
    ensure_dirs
    case "${1:-}" in
        on)
            echo "on" > "$AUTO_RECORD_FILE"
            success "Auto-recording enabled. Start daemon: 24hg-record daemon"
            ;;
        off)
            echo "off" > "$AUTO_RECORD_FILE"
            if [[ -f "$DAEMON_PID_FILE" ]] && kill -0 "$(cat "$DAEMON_PID_FILE")" 2>/dev/null; then
                kill "$(cat "$DAEMON_PID_FILE")" 2>/dev/null || true; rm -f "$DAEMON_PID_FILE"
                info "Daemon stopped."
            fi
            success "Auto-recording disabled."
            ;;
        *)
            if [[ -f "$AUTO_RECORD_FILE" ]] && [[ "$(cat "$AUTO_RECORD_FILE")" == "on" ]]; then
                echo -e "  Auto-record: ${GREEN}on${RESET}"
            else echo -e "  Auto-record: ${DIM}off${RESET}"; fi
            echo -e "\n  Usage: 24hg-record auto on|off"
            ;;
    esac
}

# ── Auto-record daemon ─────────────────────────────────────────────────────
cmd_daemon() {
    if [[ -f "$DAEMON_PID_FILE" ]] && kill -0 "$(cat "$DAEMON_PID_FILE")" 2>/dev/null; then
        die "Daemon already running (PID $(cat "$DAEMON_PID_FILE"))."
    fi
    if [[ ! -f "$AUTO_RECORD_FILE" ]] || [[ "$(cat "$AUTO_RECORD_FILE")" != "on" ]]; then
        warn "Auto-record not enabled."
        read -rp "Enable and start? [Y/n] " ans
        [[ "${ans,,}" != "n" ]] && echo "on" > "$AUTO_RECORD_FILE" || return 0
    fi
    info "Starting auto-record daemon..."
    echo $$ > "$DAEMON_PID_FILE"
    log "Daemon started (PID $$)"

    local last_game=""
    trap 'rm -f "$DAEMON_PID_FILE"; log "Daemon stopped"; exit 0' INT TERM

    while true; do
        # Exit if auto-record disabled
        if [[ ! -f "$AUTO_RECORD_FILE" ]] || [[ "$(cat "$AUTO_RECORD_FILE")" != "on" ]]; then
            log "Auto-record disabled, exiting"; rm -f "$DAEMON_PID_FILE"; exit 0
        fi
        local cg; cg=$(detect_running_game 2>/dev/null) || cg=""

        if [[ -n "$cg" && "$cg" != "$last_game" ]]; then
            log "Game detected: $cg"
            # Stop any existing recording
            if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
                cmd_stop 2>/dev/null || true; sleep 2
            fi
            cmd_start "$cg" 2>/dev/null || log "Failed to start for $cg"
            last_game="$cg"
        elif [[ -z "$cg" && -n "$last_game" ]]; then
            log "Game stopped: $last_game"
            [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null && { cmd_stop 2>/dev/null || true; }
            last_game=""
        fi
        sleep 5
    done
}

# ── Usage ───────────────────────────────────────────────────────────────────
usage() {
    banner
    cat <<EOF
  ${BOLD}USAGE:${RESET}
    24hg-record <command> [args]

  ${BOLD}COMMANDS:${RESET}
    ${CYAN}start${RESET} [game]              Start recording (auto-detect or specify game)
    ${CYAN}stop${RESET}                      Stop recording
    ${CYAN}pause${RESET}                     Pause recording
    ${CYAN}resume${RESET}                    Resume recording
    ${CYAN}status${RESET}                    Show recording status and system info

  ${BOLD}PROFILES:${RESET}
    ${CYAN}profile create${RESET} <game>     Create recording profile for a game
    ${CYAN}profile list${RESET}              List all profiles
    ${CYAN}profile edit${RESET} <game>       Edit a profile in your editor
    ${CYAN}profile delete${RESET} <game>     Delete a profile

  ${BOLD}AUTOMATION:${RESET}
    ${CYAN}auto${RESET} on|off               Toggle auto-recording when games launch
    ${CYAN}daemon${RESET}                    Run auto-record daemon (detects game start/stop)

  ${BOLD}PROFILE SETTINGS:${RESET}
    resolution    native, 1080p, 720p, match-game
    fps           60, 30, match-game
    encoder       auto, nvenc, amf, vaapi, x264
    bitrate       high (20Mbps), medium (10Mbps), low (5Mbps), custom
    audio         desktop-only, desktop+mic, mic-only
    container     mp4, mkv
    webcam        position, size, on/off

  ${BOLD}PROFILES:${RESET}  ~/.config/24hg/recording-profiles/<game>.json
  ${BOLD}RECORDINGS:${RESET} ~/Videos/Recordings/<game>/
  ${BOLD}BACKENDS:${RESET}   gpu-screen-recorder > wf-recorder (Wayland) > ffmpeg (X11)

  ${BOLD}EXAMPLES:${RESET}
    24hg-record start                  # Auto-detect game and record
    24hg-record start Cyberpunk        # Record with Cyberpunk profile
    24hg-record profile create cs2     # Create profile for CS2
    24hg-record auto on && 24hg-record daemon  # Auto-record all games

EOF
}

# ── Main dispatch ───────────────────────────────────────────────────────────
main() {
    local cmd="${1:-help}"; shift || true
    case "$cmd" in
        start)   cmd_start "${1:-}" ;;
        stop)    cmd_stop ;;
        pause)   cmd_pause ;;
        resume)  cmd_resume ;;
        status)  cmd_status ;;
        profile)
            local sub="${1:-list}"; shift || true
            case "$sub" in
                create) [[ -z "${1:-}" ]] && die "Usage: 24hg-record profile create <game>"; profile_create "$1" ;;
                list)   profile_list ;;
                edit)   [[ -z "${1:-}" ]] && die "Usage: 24hg-record profile edit <game>"; profile_edit "$1" ;;
                delete) [[ -z "${1:-}" ]] && die "Usage: 24hg-record profile delete <game>"; profile_delete "$1" ;;
                *)      die "Unknown profile command: $sub" ;;
            esac ;;
        auto)    cmd_auto "${1:-}" ;;
        daemon)  cmd_daemon ;;
        help|--help|-h) usage ;;
        *)       die "Unknown command: $cmd. Run '24hg-record help' for usage." ;;
    esac
}

main "$@"
