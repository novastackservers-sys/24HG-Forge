#!/usr/bin/env bash
# forge-hw-scout — Hardware Scout: continuous monitoring & anomaly detection for 24HG Forge
# Learns your system's normal behavior and alerts on deviations.
set -euo pipefail

APP_NAME="forge-hw-scout"
DATA_DIR="${HOME}/.local/share/forge/hw-scout"
BASELINE_FILE="${DATA_DIR}/baseline.json"
HISTORY_DIR="${DATA_DIR}/history"
ALERTS_FILE="${DATA_DIR}/alerts.log"
CONFIG_FILE="${DATA_DIR}/config.json"
PID_FILE="${DATA_DIR}/daemon.pid"
REPORT_DIR="${DATA_DIR}/reports"

# Thresholds (deviation multipliers from baseline std-dev)
TEMP_DEVIATION=2.0
USAGE_DEVIATION=2.5
DISK_WARN_PCT=85
DISK_CRIT_PCT=95
SWAP_WARN_MB=1024
PACKET_LOSS_WARN=2
BATTERY_WARN_PCT=40
SSD_WEAR_WARN=80
DAEMON_INTERVAL=60

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'
DIM='\033[2m'; RESET='\033[0m'

init_dirs() {
    mkdir -p "$DATA_DIR" "$HISTORY_DIR" "$REPORT_DIR"
    [[ -f "$ALERTS_FILE" ]] || touch "$ALERTS_FILE"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" <<'CONF'
{"daemon_interval":60,"notify_desktop":true,"game_servers":["8.8.8.8","1.1.1.1"]}
CONF
    fi
}

log_alert() {
    local severity="$1" component="$2" message="$3"
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "${ts}|${severity}|${component}|${message}" >> "$ALERTS_FILE"
    if command -v notify-send &>/dev/null; then
        local icon="dialog-warning"
        [[ "$severity" == "CRITICAL" ]] && icon="dialog-error"
        notify-send -u "$([ "$severity" = "CRITICAL" ] && echo critical || echo normal)" \
            "HW Scout: ${component}" "$message" -i "$icon" 2>/dev/null || true
    fi
}

# ─── Data Collection ──────────────────────────────────────────────────────────

get_gpu_info() {
    local gpu_temp="" gpu_clock="" gpu_vram="" gpu_fan="" gpu_type="none"
    if command -v nvidia-smi &>/dev/null; then
        gpu_type="nvidia"
        gpu_temp=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null | head -1 || echo "")
        gpu_clock=$(nvidia-smi --query-gpu=clocks.current.graphics --format=csv,noheader,nounits 2>/dev/null | head -1 || echo "")
        gpu_vram=$(nvidia-smi --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null | head -1 || echo "")
        gpu_fan=$(nvidia-smi --query-gpu=fan.speed --format=csv,noheader,nounits 2>/dev/null | head -1 || echo "")
    elif [[ -d /sys/class/drm/card0/device/hwmon ]]; then
        gpu_type="amd"
        local hwmon_dir
        hwmon_dir=$(find /sys/class/drm/card0/device/hwmon -maxdepth 1 -name 'hwmon*' | head -1)
        if [[ -n "$hwmon_dir" ]]; then
            [[ -f "${hwmon_dir}/temp1_input" ]] && gpu_temp=$(( $(cat "${hwmon_dir}/temp1_input") / 1000 ))
            [[ -f "${hwmon_dir}/fan1_input" ]] && gpu_fan=$(cat "${hwmon_dir}/fan1_input")
        fi
        if [[ -f /sys/class/drm/card0/device/gpu_busy_percent ]]; then
            gpu_clock=$(cat /sys/class/drm/card0/device/gpu_busy_percent)
        fi
        if [[ -f /sys/class/drm/card0/device/mem_info_vram_used ]]; then
            gpu_vram=$(( $(cat /sys/class/drm/card0/device/mem_info_vram_used) / 1048576 ))
        fi
    fi
    echo "{\"type\":\"${gpu_type}\",\"temp\":\"${gpu_temp}\",\"clock\":\"${gpu_clock}\",\"vram_mb\":\"${gpu_vram}\",\"fan\":\"${gpu_fan}\"}"
}

get_cpu_info() {
    local cpu_temp="" cpu_freq="" cpu_usage=""
    if command -v sensors &>/dev/null; then
        cpu_temp=$(sensors -j 2>/dev/null | python3 -c "
import json,sys
d=json.load(sys.stdin)
for chip in d.values():
    if isinstance(chip,dict):
        for k,v in chip.items():
            if isinstance(v,dict):
                for sk,sv in v.items():
                    if 'input' in sk and isinstance(sv,(int,float)) and sv>0:
                        print(int(sv)); sys.exit()
" 2>/dev/null || echo "")
    fi
    if [[ -z "$cpu_temp" && -f /sys/class/thermal/thermal_zone0/temp ]]; then
        cpu_temp=$(( $(cat /sys/class/thermal/thermal_zone0/temp) / 1000 ))
    fi
    if [[ -f /proc/cpuinfo ]]; then
        cpu_freq=$(awk '/cpu MHz/{sum+=$4;n++}END{if(n)printf "%.0f",sum/n}' /proc/cpuinfo 2>/dev/null)
    fi
    cpu_usage=$(awk '/^cpu /{u=$2+$4;t=$2+$3+$4+$5+$6+$7+$8; printf "%.1f", u/t*100}' /proc/stat 2>/dev/null || echo "")
    echo "{\"temp\":\"${cpu_temp}\",\"freq_mhz\":\"${cpu_freq}\",\"usage_pct\":\"${cpu_usage}\"}"
}

get_disk_info() {
    local disks="["
    local first=true
    while IFS= read -r line; do
        local dev mount use_pct
        dev=$(echo "$line" | awk '{print $1}')
        mount=$(echo "$line" | awk '{print $6}')
        use_pct=$(echo "$line" | awk '{gsub(/%/,""); print $5}')
        local smart_status="unknown" wear_level=""
        if command -v smartctl &>/dev/null; then
            local base_dev
            base_dev=$(echo "$dev" | sed 's/[0-9]*$//')
            smart_status=$(sudo smartctl -H "$base_dev" 2>/dev/null | grep -i 'result' | awk -F: '{gsub(/^[ \t]+/,"",$2); print $2}' || echo "unknown")
            wear_level=$(sudo smartctl -A "$base_dev" 2>/dev/null | awk '/Wear_Leveling_Count|Media_Wearout/{print $4}' | head -1 || echo "")
        fi
        [[ "$first" == true ]] || disks+=","
        first=false
        disks+="{\"dev\":\"${dev}\",\"mount\":\"${mount}\",\"use_pct\":\"${use_pct}\",\"smart\":\"${smart_status}\",\"wear\":\"${wear_level}\"}"
    done < <(df -h --output=source,size,used,avail,pcent,target -x tmpfs -x devtmpfs -x squashfs 2>/dev/null | tail -n +2)
    disks+="]"
    echo "$disks"
}

get_ram_info() {
    local total used available swap_used swap_total
    read -r total used available < <(free -m | awk '/^Mem:/{print $2,$3,$7}')
    read -r swap_total swap_used < <(free -m | awk '/^Swap:/{print $2,$3}')
    echo "{\"total_mb\":\"${total}\",\"used_mb\":\"${used}\",\"available_mb\":\"${available}\",\"swap_total_mb\":\"${swap_total}\",\"swap_used_mb\":\"${swap_used}\"}"
}

get_network_info() {
    local results="["
    local first=true
    local servers=("8.8.8.8" "1.1.1.1")
    if [[ -f "$CONFIG_FILE" ]]; then
        local custom
        custom=$(python3 -c "import json;d=json.load(open('${CONFIG_FILE}'));print(' '.join(d.get('game_servers',[])))" 2>/dev/null || echo "")
        [[ -n "$custom" ]] && read -ra servers <<< "$custom"
    fi
    for srv in "${servers[@]}"; do
        local loss="" latency=""
        if command -v ping &>/dev/null; then
            local ping_out
            ping_out=$(ping -c 3 -W 2 "$srv" 2>/dev/null || echo "")
            loss=$(echo "$ping_out" | awk -F'[,%]' '/packet loss/{print $3}' | tr -d ' ')
            latency=$(echo "$ping_out" | awk -F'[=/]' '/rtt|round-trip/{print $5}')
        fi
        [[ "$first" == true ]] || results+=","
        first=false
        results+="{\"server\":\"${srv}\",\"loss_pct\":\"${loss}\",\"latency_ms\":\"${latency}\"}"
    done
    results+="]"
    echo "$results"
}

get_battery_info() {
    local bat_dir="/sys/class/power_supply/BAT0"
    [[ -d "$bat_dir" ]] || bat_dir="/sys/class/power_supply/BAT1"
    [[ -d "$bat_dir" ]] || { echo "{\"present\":false}"; return; }
    local status capacity cycle_count energy_full energy_full_design health
    status=$(cat "${bat_dir}/status" 2>/dev/null || echo "unknown")
    capacity=$(cat "${bat_dir}/capacity" 2>/dev/null || echo "")
    cycle_count=$(cat "${bat_dir}/cycle_count" 2>/dev/null || echo "")
    energy_full=$(cat "${bat_dir}/energy_full" 2>/dev/null || cat "${bat_dir}/charge_full" 2>/dev/null || echo "0")
    energy_full_design=$(cat "${bat_dir}/energy_full_design" 2>/dev/null || cat "${bat_dir}/charge_full_design" 2>/dev/null || echo "0")
    if [[ "$energy_full_design" -gt 0 ]] 2>/dev/null; then
        health=$(python3 -c "print(round(${energy_full}/${energy_full_design}*100,1))" 2>/dev/null || echo "")
    else
        health=""
    fi
    echo "{\"present\":true,\"status\":\"${status}\",\"capacity_pct\":\"${capacity}\",\"cycle_count\":\"${cycle_count}\",\"health_pct\":\"${health}\"}"
}

collect_snapshot() {
    local ts
    ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
    local gpu cpu disk ram net bat
    gpu=$(get_gpu_info)
    cpu=$(get_cpu_info)
    disk=$(get_disk_info)
    ram=$(get_ram_info)
    net=$(get_network_info)
    bat=$(get_battery_info)
    cat <<EOF
{"timestamp":"${ts}","gpu":${gpu},"cpu":${cpu},"disks":${disk},"ram":${ram},"network":${net},"battery":${bat}}
EOF
}

# ─── Baseline ─────────────────────────────────────────────────────────────────

cmd_baseline() {
    init_dirs
    echo -e "${CYAN}${BOLD}Capturing baseline readings...${RESET}"
    echo -e "${DIM}Taking 5 samples over ~25 seconds for statistical baseline.${RESET}\n"
    local samples=()
    for i in 1 2 3 4 5; do
        printf "  Sample %d/5..." "$i"
        samples+=("$(collect_snapshot)")
        echo -e " ${GREEN}done${RESET}"
        [[ $i -lt 5 ]] && sleep 5
    done
    python3 -c "
import json, statistics, sys

samples = [json.loads(s) for s in sys.argv[1:]]

def safe_floats(vals):
    return [float(v) for v in vals if v not in ('', None, 'unknown')]

def stats(vals):
    fl = safe_floats(vals)
    if not fl: return {'mean':0,'stddev':0,'min':0,'max':0}
    m = statistics.mean(fl)
    s = statistics.pstdev(fl) if len(fl)>1 else 0
    return {'mean':round(m,2),'stddev':round(s,2),'min':round(min(fl),2),'max':round(max(fl),2)}

baseline = {
    'created': samples[0]['timestamp'],
    'sample_count': len(samples),
    'gpu_temp': stats([s['gpu']['temp'] for s in samples]),
    'gpu_clock': stats([s['gpu']['clock'] for s in samples]),
    'gpu_vram': stats([s['gpu']['vram_mb'] for s in samples]),
    'gpu_fan': stats([s['gpu']['fan'] for s in samples]),
    'cpu_temp': stats([s['cpu']['temp'] for s in samples]),
    'cpu_freq': stats([s['cpu']['freq_mhz'] for s in samples]),
    'cpu_usage': stats([s['cpu']['usage_pct'] for s in samples]),
    'ram_used': stats([s['ram']['used_mb'] for s in samples]),
    'swap_used': stats([s['ram']['swap_used_mb'] for s in samples]),
}
with open('${BASELINE_FILE}','w') as f:
    json.dump(baseline, f, indent=2)
print(json.dumps(baseline, indent=2))
" "${samples[@]}"
    echo -e "\n${GREEN}Baseline saved to ${BASELINE_FILE}${RESET}"
}

# ─── Anomaly Detection ────────────────────────────────────────────────────────

check_anomalies() {
    local snapshot="$1"
    [[ -f "$BASELINE_FILE" ]] || return 0
    python3 -c "
import json, sys

snap = json.loads(sys.argv[1])
with open('${BASELINE_FILE}') as f:
    bl = json.load(f)

def check(label, current, bl_key, dev_mult=${TEMP_DEVIATION}):
    if not current or current in ('', 'unknown'): return
    val = float(current)
    mean = bl[bl_key]['mean']
    sd = bl[bl_key]['stddev']
    threshold = mean + (sd * dev_mult) if sd > 0 else mean * 1.3
    if val > threshold and threshold > 0:
        sev = 'CRITICAL' if val > mean + (sd * dev_mult * 1.5) else 'WARNING'
        print(f'{sev}|{label}|{label} at {val:.0f} (baseline: {mean:.0f} +/- {sd:.1f})')

check('GPU Temp', snap['gpu']['temp'], 'gpu_temp')
check('GPU Fan', snap['gpu']['fan'], 'gpu_fan')
check('CPU Temp', snap['cpu']['temp'], 'cpu_temp')
check('RAM Usage', snap['ram']['used_mb'], 'ram_used', ${USAGE_DEVIATION})
" "$snapshot" 2>/dev/null | while IFS='|' read -r sev comp msg; do
        log_alert "$sev" "$comp" "$msg"
        if [[ "$sev" == "CRITICAL" ]]; then
            echo -e "  ${RED}CRITICAL: ${msg}${RESET}"
        else
            echo -e "  ${YELLOW}WARNING: ${msg}${RESET}"
        fi
    done

    # Disk space checks
    python3 -c "
import json, sys
snap = json.loads(sys.argv[1])
for d in snap.get('disks', []):
    pct = d.get('use_pct','')
    if pct and int(pct) >= ${DISK_CRIT_PCT}:
        print(f'CRITICAL|Disk {d[\"mount\"]}|Disk {d[\"mount\"]} at {pct}% usage')
    elif pct and int(pct) >= ${DISK_WARN_PCT}:
        print(f'WARNING|Disk {d[\"mount\"]}|Disk {d[\"mount\"]} at {pct}% usage')
    wear = d.get('wear','')
    if wear and int(wear) >= ${SSD_WEAR_WARN}:
        print(f'WARNING|SSD Wear {d[\"dev\"]}|SSD wear level at {wear}%')
" "$snapshot" 2>/dev/null | while IFS='|' read -r sev comp msg; do
        log_alert "$sev" "$comp" "$msg"
        echo -e "  ${YELLOW}${sev}: ${msg}${RESET}"
    done

    # Swap check
    local swap_used
    swap_used=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['ram']['swap_used_mb'])" 2>/dev/null || echo "0")
    if [[ -n "$swap_used" && "$swap_used" != "" ]] && (( $(echo "$swap_used > $SWAP_WARN_MB" | bc -l 2>/dev/null || echo 0) )); then
        log_alert "WARNING" "Swap" "Swap usage at ${swap_used}MB (threshold: ${SWAP_WARN_MB}MB)"
    fi

    # Network check
    python3 -c "
import json, sys
snap = json.loads(sys.argv[1])
for n in snap.get('network', []):
    loss = n.get('loss_pct','')
    if loss and float(loss) > ${PACKET_LOSS_WARN}:
        print(f'WARNING|Network|Packet loss to {n[\"server\"]}: {loss}%')
" "$snapshot" 2>/dev/null | while IFS='|' read -r sev comp msg; do
        log_alert "$sev" "$comp" "$msg"
        echo -e "  ${YELLOW}${msg}${RESET}"
    done
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_status() {
    init_dirs
    echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${CYAN}║     Hardware Scout — System Status       ║${RESET}"
    echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════╝${RESET}\n"

    local snapshot
    snapshot=$(collect_snapshot)

    # Save to history
    local today
    today=$(date '+%Y-%m-%d')
    echo "$snapshot" >> "${HISTORY_DIR}/${today}.jsonl"

    # GPU
    echo -e "${BOLD}  GPU${RESET}"
    local gpu_type gpu_temp gpu_clock gpu_vram gpu_fan
    gpu_type=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['gpu']['type'])" 2>/dev/null)
    if [[ "$gpu_type" != "none" ]]; then
        gpu_temp=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['gpu']['temp'])" 2>/dev/null)
        gpu_clock=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['gpu']['clock'])" 2>/dev/null)
        gpu_vram=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['gpu']['vram_mb'])" 2>/dev/null)
        gpu_fan=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['gpu']['fan'])" 2>/dev/null)
        local temp_color="$GREEN"
        [[ -n "$gpu_temp" && "$gpu_temp" -gt 75 ]] 2>/dev/null && temp_color="$YELLOW"
        [[ -n "$gpu_temp" && "$gpu_temp" -gt 90 ]] 2>/dev/null && temp_color="$RED"
        echo -e "    Type: ${gpu_type^^}  Temp: ${temp_color}${gpu_temp:-?}C${RESET}  Clock: ${gpu_clock:-?}MHz  VRAM: ${gpu_vram:-?}MB  Fan: ${gpu_fan:-?}%"
    else
        echo -e "    ${DIM}No dedicated GPU detected${RESET}"
    fi

    # CPU
    echo -e "\n${BOLD}  CPU${RESET}"
    local cpu_temp cpu_freq cpu_usage
    cpu_temp=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['cpu']['temp'])" 2>/dev/null)
    cpu_freq=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['cpu']['freq_mhz'])" 2>/dev/null)
    cpu_usage=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['cpu']['usage_pct'])" 2>/dev/null)
    local cpu_color="$GREEN"
    [[ -n "$cpu_temp" && "$cpu_temp" -gt 70 ]] 2>/dev/null && cpu_color="$YELLOW"
    [[ -n "$cpu_temp" && "$cpu_temp" -gt 85 ]] 2>/dev/null && cpu_color="$RED"
    echo -e "    Temp: ${cpu_color}${cpu_temp:-?}C${RESET}  Freq: ${cpu_freq:-?}MHz  Usage: ${cpu_usage:-?}%"

    # RAM
    echo -e "\n${BOLD}  Memory${RESET}"
    local ram_total ram_used ram_avail swap_total swap_used
    ram_total=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['ram']['total_mb'])" 2>/dev/null)
    ram_used=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['ram']['used_mb'])" 2>/dev/null)
    ram_avail=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['ram']['available_mb'])" 2>/dev/null)
    swap_used=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['ram']['swap_used_mb'])" 2>/dev/null)
    echo -e "    RAM: ${ram_used:-?}/${ram_total:-?}MB (${ram_avail:-?}MB free)  Swap: ${swap_used:-0}MB"

    # Disks
    echo -e "\n${BOLD}  Disks${RESET}"
    python3 -c "
import json, sys
snap = json.loads(sys.argv[1])
for d in snap.get('disks', []):
    pct = d.get('use_pct', '?')
    color = '\033[0;32m'
    if pct.isdigit():
        if int(pct) >= 95: color = '\033[0;31m'
        elif int(pct) >= 85: color = '\033[1;33m'
    smart = d.get('smart', 'unknown')
    wear = d.get('wear', '')
    extra = f'  SMART: {smart}' if smart != 'unknown' else ''
    if wear: extra += f'  Wear: {wear}%'
    print(f'    {d[\"mount\"]}: {color}{pct}%\033[0m used ({d[\"dev\"]}){extra}')
" "$snapshot" 2>/dev/null

    # Network
    echo -e "\n${BOLD}  Network${RESET}"
    python3 -c "
import json, sys
snap = json.loads(sys.argv[1])
for n in snap.get('network', []):
    loss = n.get('loss_pct', '?')
    lat = n.get('latency_ms', '?')
    color = '\033[0;32m'
    if loss and loss not in ('', '?'):
        if float(loss) > 5: color = '\033[0;31m'
        elif float(loss) > 2: color = '\033[1;33m'
    print(f'    {n[\"server\"]}: {color}{lat}ms{chr(27)}[0m latency, {loss}% loss')
" "$snapshot" 2>/dev/null

    # Battery
    local bat_present
    bat_present=$(echo "$snapshot" | python3 -c "import json,sys;print(json.load(sys.stdin)['battery'].get('present',False))" 2>/dev/null)
    if [[ "$bat_present" == "True" ]]; then
        echo -e "\n${BOLD}  Battery${RESET}"
        python3 -c "
import json, sys
snap = json.loads(sys.argv[1])
b = snap['battery']
print(f'    Status: {b[\"status\"]}  Charge: {b[\"capacity_pct\"]}%  Health: {b.get(\"health_pct\",\"?\")}%  Cycles: {b.get(\"cycle_count\",\"?\")}')
" "$snapshot" 2>/dev/null
    fi

    # Anomaly check
    echo -e "\n${BOLD}  Anomaly Check${RESET}"
    local anomalies
    anomalies=$(check_anomalies "$snapshot" 2>/dev/null)
    if [[ -n "$anomalies" ]]; then
        echo "$anomalies"
    else
        echo -e "    ${GREEN}All readings within normal range${RESET}"
    fi

    # Baseline status
    echo ""
    if [[ -f "$BASELINE_FILE" ]]; then
        local bl_date
        bl_date=$(python3 -c "import json;print(json.load(open('${BASELINE_FILE}'))['created'])" 2>/dev/null || echo "unknown")
        echo -e "${DIM}  Baseline from: ${bl_date}${RESET}"
    else
        echo -e "${DIM}  No baseline yet. Run '${APP_NAME} baseline' to create one.${RESET}"
    fi
}

cmd_monitor() {
    init_dirs
    echo -e "${BOLD}${CYAN}Hardware Scout — Live Monitor${RESET}  ${DIM}(Ctrl+C to exit)${RESET}\n"
    while true; do
        clear
        echo -e "${BOLD}${CYAN}Hardware Scout — Live Monitor${RESET}  ${DIM}$(date '+%H:%M:%S')  (Ctrl+C to exit)${RESET}\n"
        local snapshot
        snapshot=$(collect_snapshot)
        local today
        today=$(date '+%Y-%m-%d')
        echo "$snapshot" >> "${HISTORY_DIR}/${today}.jsonl"

        python3 -c "
import json, sys
s = json.loads(sys.argv[1])
g, c, r = s['gpu'], s['cpu'], s['ram']

def bar(pct, width=20):
    if not pct or pct in ('', 'unknown'): return '[' + '?' * width + ']'
    p = min(float(pct), 100)
    filled = int(p / 100 * width)
    color = '\033[0;32m'
    if p > 80: color = '\033[0;31m'
    elif p > 60: color = '\033[1;33m'
    return f'{color}[{\"#\" * filled}{\".\" * (width - filled)}]\033[0m {p:.0f}%'

cpu_pct = c.get('usage_pct', '')
ram_pct = round(float(r['used_mb'])/float(r['total_mb'])*100, 1) if r['total_mb'] else 0
print(f'  CPU  {bar(cpu_pct)}  {c.get(\"temp\",\"?\")}C @ {c.get(\"freq_mhz\",\"?\")}MHz')
print(f'  RAM  {bar(ram_pct)}  {r[\"used_mb\"]}/{r[\"total_mb\"]}MB')
if g['type'] != 'none':
    gpu_pct = ''
    if g.get('vram_mb'):
        try:
            total = 0
            import subprocess
            if g['type'] == 'nvidia':
                out = subprocess.check_output(['nvidia-smi','--query-gpu=memory.total','--format=csv,noheader,nounits'], text=True)
                total = float(out.strip())
            if total > 0:
                gpu_pct = str(round(float(g['vram_mb'])/total*100,1))
        except: pass
    print(f'  GPU  Temp: {g.get(\"temp\",\"?\")}C  Clock: {g.get(\"clock\",\"?\")}MHz  VRAM: {g.get(\"vram_mb\",\"?\")}MB  Fan: {g.get(\"fan\",\"?\")}%')
print(f'  Swap {r.get(\"swap_used_mb\",\"0\")}MB used')
" "$snapshot" 2>/dev/null

        echo ""
        check_anomalies "$snapshot" 2>/dev/null || true
        sleep 3
    done
}

cmd_report() {
    init_dirs
    echo -e "${BOLD}${CYAN}Generating Hardware Health Report...${RESET}\n"

    local report_file="${REPORT_DIR}/report-$(date '+%Y-%m-%d').txt"
    local history_files
    history_files=$(find "$HISTORY_DIR" -name '*.jsonl' -mtime -7 2>/dev/null | sort)

    {
        echo "═══════════════════════════════════════════════════"
        echo "  24HG Forge — Hardware Health Report"
        echo "  Generated: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "═══════════════════════════════════════════════════"
        echo ""

        if [[ -n "$history_files" ]]; then
            python3 -c "
import json, sys, statistics, glob, os

data_dir = '${HISTORY_DIR}'
files = sorted(glob.glob(os.path.join(data_dir, '*.jsonl')))[-7:]
samples = []
for f in files:
    with open(f) as fh:
        for line in fh:
            line = line.strip()
            if line:
                try: samples.append(json.loads(line))
                except: pass

if not samples:
    print('  No historical data available.')
    sys.exit()

print(f'  Data points: {len(samples)} over {len(files)} day(s)')
print()

def safe_stats(label, vals):
    fl = [float(v) for v in vals if v not in ('', None, 'unknown')]
    if not fl: return
    mn, mx, avg = min(fl), max(fl), statistics.mean(fl)
    print(f'  {label:.<30} avg: {avg:>7.1f}  min: {mn:>7.1f}  max: {mx:>7.1f}')

print('  TEMPERATURE')
safe_stats('GPU Temp (C)', [s['gpu']['temp'] for s in samples])
safe_stats('CPU Temp (C)', [s['cpu']['temp'] for s in samples])
print()
print('  PERFORMANCE')
safe_stats('CPU Usage (%)', [s['cpu']['usage_pct'] for s in samples])
safe_stats('CPU Freq (MHz)', [s['cpu']['freq_mhz'] for s in samples])
safe_stats('GPU Clock (MHz)', [s['gpu']['clock'] for s in samples])
print()
print('  MEMORY')
safe_stats('RAM Used (MB)', [s['ram']['used_mb'] for s in samples])
safe_stats('Swap Used (MB)', [s['ram']['swap_used_mb'] for s in samples])
safe_stats('GPU VRAM (MB)', [s['gpu']['vram_mb'] for s in samples])
print()

# Alert summary
print('  RECENT ALERTS (last 7 days)')
try:
    count = {'WARNING': 0, 'CRITICAL': 0}
    with open('${ALERTS_FILE}') as af:
        for line in af:
            parts = line.strip().split('|')
            if len(parts) >= 2 and parts[1] in count:
                count[parts[1]] += 1
    print(f'    Warnings: {count[\"WARNING\"]}  Critical: {count[\"CRITICAL\"]}')
except:
    print('    No alerts recorded.')
" 2>/dev/null
        else
            echo "  No historical data found. Run 'forge-hw-scout status' periodically to collect data."
        fi

        echo ""
        echo "  CURRENT SNAPSHOT"
        echo "  ────────────────"
        local snap
        snap=$(collect_snapshot)
        python3 -c "
import json, sys
s = json.loads(sys.argv[1])
g, c, r = s['gpu'], s['cpu'], s['ram']
print(f'  GPU: {g[\"type\"]}  {g[\"temp\"]}C  {g[\"clock\"]}MHz  VRAM:{g[\"vram_mb\"]}MB  Fan:{g[\"fan\"]}%')
print(f'  CPU: {c[\"temp\"]}C  {c[\"freq_mhz\"]}MHz  {c[\"usage_pct\"]}%')
print(f'  RAM: {r[\"used_mb\"]}/{r[\"total_mb\"]}MB  Swap:{r[\"swap_used_mb\"]}MB')
for d in s.get('disks', []):
    print(f'  Disk {d[\"mount\"]}: {d[\"use_pct\"]}%  SMART:{d[\"smart\"]}')
for n in s.get('network', []):
    print(f'  Net {n[\"server\"]}: {n[\"latency_ms\"]}ms  Loss:{n[\"loss_pct\"]}%')
b = s.get('battery', {})
if b.get('present'):
    print(f'  Battery: {b[\"status\"]}  {b[\"capacity_pct\"]}%  Health:{b.get(\"health_pct\",\"?\")}%  Cycles:{b.get(\"cycle_count\",\"?\")}')
" "$snap" 2>/dev/null

        echo ""
        echo "═══════════════════════════════════════════════════"
    } | tee "$report_file"

    echo -e "\n${GREEN}Report saved to ${report_file}${RESET}"
}

cmd_alerts() {
    init_dirs
    echo -e "${BOLD}${CYAN}Recent Alerts${RESET}\n"
    if [[ ! -s "$ALERTS_FILE" ]]; then
        echo -e "  ${GREEN}No alerts recorded.${RESET}"
        return
    fi
    tail -50 "$ALERTS_FILE" | while IFS='|' read -r ts sev comp msg; do
        local color="$YELLOW"
        [[ "$sev" == "CRITICAL" ]] && color="$RED"
        echo -e "  ${DIM}${ts}${RESET}  ${color}${sev}${RESET}  ${BOLD}${comp}${RESET}: ${msg}"
    done
}

cmd_daemon() {
    init_dirs
    if [[ -f "$PID_FILE" ]]; then
        local old_pid
        old_pid=$(cat "$PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            echo -e "${YELLOW}Daemon already running (PID ${old_pid}). Stop with: kill ${old_pid}${RESET}"
            return 1
        fi
        rm -f "$PID_FILE"
    fi

    echo -e "${CYAN}Starting Hardware Scout daemon (interval: ${DAEMON_INTERVAL}s)...${RESET}"

    (
        echo $$ > "$PID_FILE"
        trap 'rm -f "$PID_FILE"; exit 0' SIGTERM SIGINT

        # Capture baseline if none exists
        if [[ ! -f "$BASELINE_FILE" ]]; then
            local samples=()
            for _ in 1 2 3 4 5; do
                samples+=("$(collect_snapshot)")
                sleep 5
            done
            python3 -c "
import json, statistics, sys
samples = [json.loads(s) for s in sys.argv[1:]]
def safe_floats(vals):
    return [float(v) for v in vals if v not in ('', None, 'unknown')]
def stats(vals):
    fl = safe_floats(vals)
    if not fl: return {'mean':0,'stddev':0,'min':0,'max':0}
    m = statistics.mean(fl)
    s = statistics.pstdev(fl) if len(fl)>1 else 0
    return {'mean':round(m,2),'stddev':round(s,2),'min':round(min(fl),2),'max':round(max(fl),2)}
baseline = {
    'created': samples[0]['timestamp'], 'sample_count': len(samples),
    'gpu_temp': stats([s['gpu']['temp'] for s in samples]),
    'gpu_clock': stats([s['gpu']['clock'] for s in samples]),
    'gpu_vram': stats([s['gpu']['vram_mb'] for s in samples]),
    'gpu_fan': stats([s['gpu']['fan'] for s in samples]),
    'cpu_temp': stats([s['cpu']['temp'] for s in samples]),
    'cpu_freq': stats([s['cpu']['freq_mhz'] for s in samples]),
    'cpu_usage': stats([s['cpu']['usage_pct'] for s in samples]),
    'ram_used': stats([s['ram']['used_mb'] for s in samples]),
    'swap_used': stats([s['ram']['swap_used_mb'] for s in samples]),
}
with open('${BASELINE_FILE}','w') as f:
    json.dump(baseline, f, indent=2)
" "${samples[@]}" 2>/dev/null
        fi

        while true; do
            local snapshot
            snapshot=$(collect_snapshot)
            local today
            today=$(date '+%Y-%m-%d')
            echo "$snapshot" >> "${HISTORY_DIR}/${today}.jsonl"
            check_anomalies "$snapshot" >/dev/null 2>&1
            sleep "$DAEMON_INTERVAL"
        done
    ) &
    disown

    echo -e "${GREEN}Daemon started (PID $(cat "$PID_FILE")).${RESET}"
    echo -e "${DIM}Stop with: kill $(cat "$PID_FILE")${RESET}"
}

cmd_history() {
    init_dirs
    local component="${1:-all}"
    echo -e "${BOLD}${CYAN}Hardware History — ${component}${RESET}\n"

    local history_files
    history_files=$(find "$HISTORY_DIR" -name '*.jsonl' 2>/dev/null | sort | tail -7)
    if [[ -z "$history_files" ]]; then
        echo -e "  ${DIM}No history data yet. Run 'forge-hw-scout status' to start collecting.${RESET}"
        return
    fi

    python3 -c "
import json, sys, os

component = sys.argv[1]
files = sorted(sys.argv[2:])

for filepath in files:
    day = os.path.basename(filepath).replace('.jsonl','')
    samples = []
    with open(filepath) as f:
        for line in f:
            line = line.strip()
            if line:
                try: samples.append(json.loads(line))
                except: pass
    if not samples: continue

    def avg(vals):
        fl = [float(v) for v in vals if v not in ('', None, 'unknown')]
        return round(sum(fl)/len(fl), 1) if fl else '?'

    def mn(vals):
        fl = [float(v) for v in vals if v not in ('', None, 'unknown')]
        return round(min(fl), 1) if fl else '?'

    def mx(vals):
        fl = [float(v) for v in vals if v not in ('', None, 'unknown')]
        return round(max(fl), 1) if fl else '?'

    print(f'  \033[1m{day}\033[0m  ({len(samples)} samples)')
    if component in ('all', 'gpu'):
        print(f'    GPU  temp: {avg([s[\"gpu\"][\"temp\"] for s in samples])}C (max {mx([s[\"gpu\"][\"temp\"] for s in samples])})  fan: {avg([s[\"gpu\"][\"fan\"] for s in samples])}%')
    if component in ('all', 'cpu'):
        print(f'    CPU  temp: {avg([s[\"cpu\"][\"temp\"] for s in samples])}C (max {mx([s[\"cpu\"][\"temp\"] for s in samples])})  usage: {avg([s[\"cpu\"][\"usage_pct\"] for s in samples])}%')
    if component in ('all', 'ram', 'memory'):
        print(f'    RAM  used: {avg([s[\"ram\"][\"used_mb\"] for s in samples])}MB  swap: {avg([s[\"ram\"][\"swap_used_mb\"] for s in samples])}MB')
    if component in ('all', 'network', 'net'):
        for i, n in enumerate(samples[0].get('network', [])):
            lats = [s['network'][i]['latency_ms'] for s in samples if i < len(s.get('network', []))]
            print(f'    Net  {n[\"server\"]}: avg {avg(lats)}ms')
    print()
" "$component" $history_files 2>/dev/null
}

# ─── Usage ────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${BOLD}${CYAN}forge-hw-scout${RESET} — Hardware Scout for 24HG Forge

${BOLD}Usage:${RESET}
  forge-hw-scout <command> [args]

${BOLD}Commands:${RESET}
  ${GREEN}status${RESET}              Current hardware health overview
  ${GREEN}monitor${RESET}             Start live monitoring dashboard
  ${GREEN}baseline${RESET}            Capture/update baseline readings
  ${GREEN}report${RESET}              Generate hardware health report
  ${GREEN}alerts${RESET}              Show recent alerts
  ${GREEN}daemon${RESET}              Run as background monitor
  ${GREEN}history${RESET} [component] Show historical data (gpu/cpu/ram/net/all)

${BOLD}Examples:${RESET}
  forge-hw-scout status          # Quick health check
  forge-hw-scout baseline        # Learn normal behavior
  forge-hw-scout daemon          # Start background monitoring
  forge-hw-scout history gpu     # GPU temperature history

${BOLD}Data:${RESET} ~/.local/share/forge/hw-scout/
EOF
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        status)         cmd_status ;;
        monitor)        cmd_monitor ;;
        baseline)       cmd_baseline ;;
        report)         cmd_report ;;
        alerts)         cmd_alerts ;;
        daemon)         cmd_daemon ;;
        history)        cmd_history "$@" ;;
        -h|--help|help) usage ;;
        "")             usage ;;
        *)              echo -e "${RED}Unknown command: ${cmd}${RESET}\n"; usage; exit 1 ;;
    esac
}

main "$@"
