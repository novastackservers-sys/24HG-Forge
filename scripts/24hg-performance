#!/bin/bash
# 24HG Performance Profile Switcher
# Usage: 24hg-performance [gaming|balanced|powersave|status]

set -euo pipefail

ACTION="${1:-status}"

case "$ACTION" in
    gaming)
        echo "Switching to Gaming mode..."

        # CPU governor
        if command -v powerprofilesctl &>/dev/null; then
            powerprofilesctl set performance
        elif [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]; then
            for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
                echo performance > "$gov" 2>/dev/null || true
            done
        fi

        # GPU (NVIDIA)
        if command -v nvidia-smi &>/dev/null; then
            nvidia-smi -pm 1 2>/dev/null || true
            nvidia-smi --power-limit=300 2>/dev/null || true  # Max TDP
        fi

        # GPU (AMD)
        for card in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
            [ -f "$card" ] && echo high > "$card" 2>/dev/null || true
        done

        # Disable compositing for less latency
        if command -v qdbus &>/dev/null; then
            qdbus org.kde.KWin /Compositor suspend 2>/dev/null || true
        fi

        # Start GameMode daemon
        gamemoded -r 2>/dev/null || true

        # Optimize input (flat mouse accel, fast keyboard)
        /usr/bin/24hg-input gaming 2>/dev/null || true

        # Activate network guard
        /usr/bin/24hg-netguard start 2>/dev/null || true

        # Switch to low-latency audio
        /usr/bin/24hg-audio gaming 2>/dev/null || true

        echo "Gaming mode active. CPU: performance, GPU: max, compositor: suspended"
        echo "  + Input: raw/flat mouse, fast keyboard"
        echo "  + Network: low-latency mode, gaming DNS"
        echo "  + Audio: 5ms buffer"
        echo "Run '24hg-performance balanced' when done gaming."
        ;;

    balanced)
        echo "Switching to Balanced mode..."

        if command -v powerprofilesctl &>/dev/null; then
            powerprofilesctl set balanced
        elif [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]; then
            for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
                echo schedutil > "$gov" 2>/dev/null || true
            done
        fi

        for card in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
            [ -f "$card" ] && echo auto > "$card" 2>/dev/null || true
        done

        # Resume compositing
        if command -v qdbus &>/dev/null; then
            qdbus org.kde.KWin /Compositor resume 2>/dev/null || true
        fi

        # Restore desktop input
        /usr/bin/24hg-input desktop 2>/dev/null || true

        # Restore network
        /usr/bin/24hg-netguard stop 2>/dev/null || true

        # Restore balanced audio
        /usr/bin/24hg-audio desktop 2>/dev/null || true

        echo "Balanced mode active."
        ;;

    powersave)
        echo "Switching to Power Save mode..."

        if command -v powerprofilesctl &>/dev/null; then
            powerprofilesctl set power-saver
        elif [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]; then
            for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
                echo powersave > "$gov" 2>/dev/null || true
            done
        fi

        for card in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
            [ -f "$card" ] && echo low > "$card" 2>/dev/null || true
        done

        echo "Power save mode active."
        ;;

    status)
        echo "=== 24HG Performance Status ==="

        # Power profile
        if command -v powerprofilesctl &>/dev/null; then
            echo "Power Profile: $(powerprofilesctl get)"
        fi

        # CPU governor
        GOV=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "unknown")
        echo "CPU Governor: $GOV"

        # CPU frequency
        if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq ]; then
            FREQ=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq)
            echo "CPU Frequency: $((FREQ / 1000)) MHz"
        fi

        # GPU
        if command -v nvidia-smi &>/dev/null; then
            echo "GPU: $(nvidia-smi --query-gpu=name,clocks.gr,clocks.mem,power.draw --format=csv,noheader 2>/dev/null || echo 'NVIDIA (query failed)')"
        fi
        for card in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
            [ -f "$card" ] && echo "AMD GPU Performance: $(cat $card)"
        done

        # GameMode
        echo "GameMode: $(gamemoded -s 2>/dev/null || echo 'not running')"

        # Temperatures
        if command -v sensors &>/dev/null; then
            echo ""
            echo "Temperatures:"
            sensors 2>/dev/null | grep -E "^(Core|edge|junction|Tctl)" | head -5 || true
        fi
        ;;

    *)
        echo "Usage: 24hg-performance [gaming|balanced|powersave|status]"
        echo ""
        echo "  gaming    — Max performance (CPU perf governor, GPU max clocks)"
        echo "  balanced  — Default balanced mode"
        echo "  powersave — Minimum power usage"
        echo "  status    — Show current performance state"
        exit 1
        ;;
esac
