#!/usr/bin/env python3
"""
HubOS Server Status — Live A2S query daemon for 24HG game servers
Queries all servers via Source Engine A2S protocol, caches results,
and sends desktop notifications when servers get populated.
"""

import json
import os
import socket
import struct
import sys
import time
import subprocess
import signal

SERVERS_JSON = "/usr/share/hubos/servers.json"
CACHE_DIR = os.path.expanduser("~/.cache/hubos")
CACHE_FILE = os.path.join(CACHE_DIR, "server-status.json")
POLL_INTERVAL = 60  # seconds
NOTIFY_THRESHOLD = 5  # notify when a server hits this many players
A2S_TIMEOUT = 2  # seconds per query

# Track notifications to avoid spam
notified = set()

running = True
def handle_signal(sig, frame):
    global running
    running = False

signal.signal(signal.SIGINT, handle_signal)
signal.signal(signal.SIGTERM, handle_signal)


def a2s_info(ip, port):
    """Query a Source Engine server using A2S_INFO protocol."""
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.settimeout(A2S_TIMEOUT)
    try:
        # A2S_INFO request: 4x FF + 'T' + "Source Engine Query\0"
        request = b'\xFF\xFF\xFF\xFF\x54Source Engine Query\x00'
        sock.sendto(request, (ip, port))
        data, _ = sock.recvfrom(4096)

        if len(data) < 6:
            return None

        # Check for challenge response (0x41)
        if data[4] == 0x41 and len(data) >= 9:
            challenge = data[5:9]
            request = b'\xFF\xFF\xFF\xFF\x54Source Engine Query\x00' + challenge
            sock.sendto(request, (ip, port))
            data, _ = sock.recvfrom(4096)

        if data[4] != 0x49:  # 'I' = A2S_INFO response
            return None

        # Parse A2S_INFO response
        idx = 5
        # Protocol
        protocol = data[idx]
        idx += 1
        # Server name (null-terminated string)
        end = data.index(b'\x00', idx)
        name = data[idx:end].decode('utf-8', errors='replace')
        idx = end + 1
        # Map
        end = data.index(b'\x00', idx)
        map_name = data[idx:end].decode('utf-8', errors='replace')
        idx = end + 1
        # Folder
        end = data.index(b'\x00', idx)
        idx = end + 1
        # Game
        end = data.index(b'\x00', idx)
        game = data[idx:end].decode('utf-8', errors='replace')
        idx = end + 1
        # Steam App ID (short)
        idx += 2
        # Players, max players, bots
        players = data[idx]
        idx += 1
        max_players = data[idx]
        idx += 1
        bots = data[idx]

        return {
            "name": name,
            "map": map_name,
            "game": game,
            "players": players,
            "max_players": max_players,
            "bots": bots,
            "online": True,
            "queried_at": int(time.time())
        }
    except (socket.timeout, ConnectionRefusedError, OSError, struct.error, ValueError, IndexError):
        return None
    finally:
        sock.close()


def send_notification(title, body, urgency="normal"):
    """Send a desktop notification."""
    try:
        subprocess.Popen([
            "notify-send",
            "-a", "24HG",
            "-i", "hubos-logo",
            "-u", urgency,
            title, body
        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except FileNotFoundError:
        pass


def load_servers():
    """Load server list from centralized JSON."""
    try:
        with open(SERVERS_JSON) as f:
            return json.load(f)
    except Exception:
        return {"servers": [], "game_labels": {}}


def query_all():
    """Query all servers and return status dict."""
    data = load_servers()
    labels = data.get("game_labels", {})
    results = []
    total_players = 0
    total_online = 0

    for srv in data.get("servers", []):
        ip = srv["ip"]
        port = srv["port"]
        game = srv["game"]
        name = srv["name"]
        game_label = labels.get(game, game.upper())

        info = a2s_info(ip, port)
        entry = {
            "name": name,
            "game": game,
            "game_label": game_label,
            "ip": ip,
            "port": port,
            "tags": srv.get("tags", []),
        }

        if info:
            entry.update({
                "online": True,
                "players": info["players"],
                "max_players": info["max_players"],
                "bots": info["bots"],
                "map": info["map"],
                "server_name": info["name"],
            })
            real_players = info["players"] - info["bots"]
            total_players += real_players
            total_online += 1

            # Notification for populated servers
            key = f"{ip}:{port}"
            if real_players >= NOTIFY_THRESHOLD and key not in notified:
                send_notification(
                    f"{game_label} — {name}",
                    f"{real_players} players on {info['map']}! Click to join.",
                )
                notified.add(key)
            elif real_players < NOTIFY_THRESHOLD and key in notified:
                notified.discard(key)
        else:
            entry.update({
                "online": False,
                "players": 0,
                "max_players": 0,
                "bots": 0,
                "map": "",
                "server_name": "",
            })

        results.append(entry)

    return {
        "queried_at": int(time.time()),
        "total_online": total_online,
        "total_players": total_players,
        "servers": results,
    }


def main():
    os.makedirs(CACHE_DIR, exist_ok=True)

    if len(sys.argv) > 1 and sys.argv[1] == "--once":
        # Single query mode (for CLI)
        status = query_all()
        with open(CACHE_FILE, 'w') as f:
            json.dump(status, f, indent=2)
        # Print summary
        print(f"24HG Servers: {status['total_online']} online, {status['total_players']} players")
        print()
        for srv in sorted(status["servers"], key=lambda s: s["players"], reverse=True):
            if not srv["online"]:
                state = "OFFLINE"
            elif srv["players"] == 0:
                state = "Empty"
            else:
                real = srv["players"] - srv["bots"]
                state = f"{real}/{srv['max_players']} on {srv['map']}"
            print(f"  {srv['game_label']:25s} {srv['name']:20s} {state}")
        return

    # Daemon mode
    print(f"HubOS Server Status daemon started (polling every {POLL_INTERVAL}s)")
    while running:
        try:
            status = query_all()
            with open(CACHE_FILE, 'w') as f:
                json.dump(status, f, indent=2)
        except Exception as e:
            print(f"Query error: {e}", file=sys.stderr)

        # Sleep in small increments so we can respond to signals
        for _ in range(POLL_INTERVAL):
            if not running:
                break
            time.sleep(1)


if __name__ == "__main__":
    main()
