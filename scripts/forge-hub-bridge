#!/usr/bin/env python3
"""
HubOS Hub Bridge — Deep integration between HubOS desktop and the 24HG Hub
Connects to hub.24hgaming.com API, delivers desktop notifications for:
  - Direct messages
  - @mentions in chat
  - Friend activity (online/offline)
  - Clan messages
  - Tournament alerts
  - System notifications
Also feeds unread counts and online friends to the system tray.

Runs as a user systemd service. Requires a stored auth token from hub login.
"""

import json
import os
import signal
import subprocess
import sys
import time
import urllib.request
import urllib.error

# ── Configuration ──
API_URL = "https://api.24hgaming.com"
HUB_URL = "https://hub.24hgaming.com"
CONFIG_DIR = os.path.expanduser("~/.config/hubos")
TOKEN_FILE = os.path.join(CONFIG_DIR, "hub-token")
CACHE_DIR = os.path.expanduser("~/.cache/hubos")
STATE_FILE = os.path.join(CACHE_DIR, "hub-state.json")
POLL_INTERVAL = 15  # seconds between API polls
FRIENDS_INTERVAL = 60  # seconds between friend status checks

os.makedirs(CONFIG_DIR, exist_ok=True)
os.makedirs(CACHE_DIR, exist_ok=True)

running = True
last_notification_id = 0
last_dm_check = 0
known_online_friends = set()


def handle_signal(sig, frame):
    global running
    running = False

signal.signal(signal.SIGINT, handle_signal)
signal.signal(signal.SIGTERM, handle_signal)


def load_token():
    """Load stored auth token."""
    if os.path.exists(TOKEN_FILE):
        with open(TOKEN_FILE) as f:
            token = f.read().strip()
            if token:
                return token
    return None


def save_token(token):
    """Save auth token securely."""
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(TOKEN_FILE, 'w') as f:
        f.write(token)
    os.chmod(TOKEN_FILE, 0o600)


def api_get(endpoint, token):
    """Make authenticated GET request to hub API."""
    url = f"{API_URL}{endpoint}"
    req = urllib.request.Request(url, headers={
        "Authorization": f"Bearer {token}",
        "Accept": "application/json",
    })
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        if e.code == 401:
            return {"error": "unauthorized"}
        return {"error": str(e)}
    except Exception as e:
        return {"error": str(e)}


def notify(title, body, icon="hubos-logo", urgency="normal", action_url=None):
    """Send desktop notification."""
    cmd = [
        "notify-send",
        "-a", "24HG Hub",
        "-i", icon,
        "-u", urgency,
        title, body,
    ]
    if action_url:
        cmd.extend(["--action", f"default=Open"])
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
        if action_url and result.stdout.strip() == "default":
            subprocess.Popen(["xdg-open", action_url])
    except Exception:
        pass


def update_state(data):
    """Write state to cache file for tray to read."""
    try:
        with open(STATE_FILE, 'w') as f:
            json.dump(data, f, indent=2)
    except Exception:
        pass


def load_state():
    """Load previous state."""
    try:
        with open(STATE_FILE) as f:
            return json.load(f)
    except Exception:
        return {}


def check_notifications(token):
    """Poll for new notifications and send desktop alerts."""
    global last_notification_id

    data = api_get("/notifications?limit=10", token)
    if "error" in data:
        return

    notifications = data.get("notifications", [])
    if not notifications:
        return

    # Get unread count
    unread = api_get("/notifications/unread-count", token)
    unread_count = unread.get("count", 0) if "error" not in unread else 0

    # Process new notifications (ones we haven't seen)
    for notif in reversed(notifications):
        nid = notif.get("id", 0)
        if nid <= last_notification_id:
            continue
        if notif.get("read"):
            continue

        last_notification_id = nid

        title = notif.get("title", "24HG Hub")
        body = notif.get("body", "")
        icon_emoji = notif.get("icon", "")
        link = notif.get("link", "")
        ntype = notif.get("type", "system")

        # Map notification type to urgency
        urgency = "normal"
        if ntype in ("mention", "dm"):
            urgency = "normal"
        elif ntype == "system" and "outage" in title.lower():
            urgency = "critical"

        # Build notification
        display_title = f"{icon_emoji} {title}" if icon_emoji else title
        action_url = f"{HUB_URL}{link}" if link else None

        notify(display_title, body, urgency=urgency, action_url=action_url)

    return unread_count


def check_dms(token):
    """Check for new DMs."""
    data = api_get("/chat/dms", token)
    if "error" in data:
        return

    conversations = data.get("conversations", [])
    unread_dms = 0

    for conv in conversations:
        # Check if conversation has unread messages
        last_msg = conv.get("last_message")
        if last_msg and not conv.get("read"):
            unread_dms += 1

    return unread_dms


def check_friends(token):
    """Check friend online status and notify on changes."""
    global known_online_friends

    data = api_get("/friends", token)
    if "error" in data:
        return 0

    friends = data.get("friends", [])
    currently_online = set()
    online_count = 0

    for friend in friends:
        username = friend.get("username", "")
        last_seen = friend.get("last_seen", "")

        # Consider friend "online" if last seen within 5 minutes
        if last_seen:
            try:
                from datetime import datetime, timezone
                seen_time = datetime.fromisoformat(last_seen.replace('Z', '+00:00'))
                now = datetime.now(timezone.utc)
                if (now - seen_time).total_seconds() < 300:
                    currently_online.add(username)
                    online_count += 1
            except Exception:
                pass

    # Detect newly online friends
    new_online = currently_online - known_online_friends
    for username in new_online:
        notify(
            f"{username} is online",
            "Your friend just came online on 24HG Hub",
            urgency="low",
            action_url=f"{HUB_URL}/profile/{username}"
        )

    known_online_friends = currently_online
    return online_count


def check_user_info(token):
    """Get current user info."""
    data = api_get("/users/me", token)
    if "error" in data:
        return None
    return data.get("user", {})


def login_prompt():
    """Show a login dialog to get hub credentials."""
    try:
        # Try zenity for graphical login
        result = subprocess.run([
            "zenity", "--forms",
            "--title=24HG Hub Login",
            "--text=Login to connect HubOS to your 24HG account",
            "--add-entry=Username or Email",
            "--add-password=Password",
        ], capture_output=True, text=True, timeout=120)

        if result.returncode != 0:
            return None, None

        parts = result.stdout.strip().split("|")
        if len(parts) >= 2:
            return parts[0], parts[1]
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return None, None


def do_login(username, password):
    """Authenticate with the hub API."""
    data = json.dumps({"username": username, "password": password}).encode()
    req = urllib.request.Request(
        f"{API_URL}/auth/login",
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST"
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read())
            return result.get("token")
    except Exception as e:
        notify("Login Failed", str(e), urgency="critical")
        return None


def main():
    global last_notification_id

    print("HubOS Hub Bridge starting...")

    # Load or get token
    token = load_token()

    if not token:
        # Try interactive login
        print("No auth token found. Prompting for login...")
        username, password = login_prompt()
        if username and password:
            token = do_login(username, password)
            if token:
                save_token(token)
                notify("24HG Connected", f"Logged in as {username}. Hub notifications active.")
            else:
                print("Login failed. Run 'hubos-hub-bridge login' to try again.")
                sys.exit(1)
        else:
            print("No credentials provided. Hub bridge inactive.")
            print("Run 'hubos-hub-bridge login' to connect your account.")
            sys.exit(0)

    # Verify token
    user = check_user_info(token)
    if not user:
        print("Token expired or invalid. Run 'hubos-hub-bridge login' to re-authenticate.")
        os.remove(TOKEN_FILE) if os.path.exists(TOKEN_FILE) else None
        sys.exit(1)

    username = user.get("username", "unknown")
    print(f"Connected to 24HG Hub as: {username}")

    # Initialize last notification ID from state
    state = load_state()
    last_notification_id = state.get("last_notification_id", 0)

    # Main polling loop
    friend_timer = 0
    while running:
        try:
            # Check notifications every cycle
            unread_count = check_notifications(token) or 0

            # Check DMs
            unread_dms = check_dms(token) or 0

            # Check friends periodically
            friend_timer += POLL_INTERVAL
            online_friends = state.get("online_friends", 0)
            if friend_timer >= FRIENDS_INTERVAL:
                online_friends = check_friends(token) or 0
                friend_timer = 0

            # Update state for tray
            state = {
                "connected": True,
                "username": username,
                "unread_notifications": unread_count,
                "unread_dms": unread_dms,
                "online_friends": online_friends,
                "last_notification_id": last_notification_id,
                "updated_at": int(time.time()),
            }
            update_state(state)

        except Exception as e:
            print(f"Bridge error: {e}", file=sys.stderr)
            update_state({"connected": False, "error": str(e), "updated_at": int(time.time())})

        # Sleep in small increments for signal handling
        for _ in range(POLL_INTERVAL):
            if not running:
                break
            time.sleep(1)

    # Cleanup
    update_state({"connected": False, "updated_at": int(time.time())})
    print("Hub Bridge stopped.")


def cmd_login():
    """Interactive login command."""
    username, password = login_prompt()
    if not username:
        # Fallback to terminal input
        import getpass
        username = input("24HG Username or Email: ")
        password = getpass.getpass("Password: ")

    if username and password:
        token = do_login(username, password)
        if token:
            save_token(token)
            user = check_user_info(token)
            name = user.get("username", username) if user else username
            print(f"Logged in as {name}. Token saved.")
            notify("24HG Connected", f"Logged in as {name}. Hub notifications active.")
            # Restart the bridge service
            subprocess.run(["systemctl", "--user", "restart", "hubos-hub-bridge"], capture_output=True)
        else:
            print("Login failed. Check your credentials.")
    else:
        print("Cancelled.")


def cmd_status():
    """Show bridge status."""
    state = load_state()
    token = load_token()

    print("=== HubOS Hub Bridge ===")
    if state.get("connected"):
        print(f"Status: Connected as {state.get('username', '?')}")
        print(f"Unread notifications: {state.get('unread_notifications', 0)}")
        print(f"Unread DMs: {state.get('unread_dms', 0)}")
        print(f"Friends online: {state.get('online_friends', 0)}")
        updated = state.get("updated_at", 0)
        if updated:
            age = int(time.time()) - updated
            print(f"Last update: {age}s ago")
    elif token:
        print("Status: Token saved but bridge not running")
        print("Start with: systemctl --user start hubos-hub-bridge")
    else:
        print("Status: Not connected")
        print("Login with: hubos-hub-bridge login")


def cmd_logout():
    """Remove stored token."""
    if os.path.exists(TOKEN_FILE):
        os.remove(TOKEN_FILE)
    subprocess.run(["systemctl", "--user", "stop", "hubos-hub-bridge"], capture_output=True)
    update_state({"connected": False, "updated_at": int(time.time())})
    print("Logged out. Hub bridge stopped.")
    notify("24HG Disconnected", "Hub notifications disabled.")


if __name__ == "__main__":
    if len(sys.argv) > 1:
        cmd = sys.argv[1]
        if cmd == "login":
            cmd_login()
        elif cmd == "logout":
            cmd_logout()
        elif cmd == "status":
            cmd_status()
        elif cmd == "daemon":
            main()
        else:
            print("HubOS Hub Bridge — Connect your desktop to 24HG Hub")
            print("Usage: hubos-hub-bridge [login|logout|status|daemon]")
            print()
            print("  login   — Login to your 24HG account")
            print("  logout  — Disconnect and remove token")
            print("  status  — Show connection status")
            print("  daemon  — Run bridge daemon (used by systemd)")
    else:
        # Default: run daemon
        main()
