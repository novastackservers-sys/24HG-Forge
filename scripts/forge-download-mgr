#!/usr/bin/env bash
set -euo pipefail
# 24HG Forge Download Manager — Intelligent bandwidth and download scheduling for gaming
#
# Automatically pauses downloads when gaming, resumes when you stop.
# Manages Steam, Flatpak, rpm-ostree, and browser downloads with
# Linux traffic control for bandwidth prioritization.

# ==============================================================================
# Constants & Configuration
# ==============================================================================

readonly VERSION="1.0.0"
readonly APP_NAME="forge-download-mgr"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge"
readonly CONFIG_FILE="$CONFIG_DIR/download-mgr.json"
readonly STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/forge"
readonly STATE_FILE="$STATE_DIR/download-mgr.state"
readonly LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/forge/logs"
readonly LOG_FILE="$LOG_DIR/download-mgr.log"
readonly SYSTEMD_USER_DIR="$HOME/.config/systemd/user"

# Steam paths (native + Flatpak)
readonly STEAM_NATIVE_LOG="$HOME/.local/share/Steam/logs/content_log.txt"
readonly STEAM_FLATPAK_LOG="$HOME/.var/app/com.valvesoftware.Steam/.local/share/Steam/logs/content_log.txt"

# Traffic control defaults
readonly TC_HANDLE="1:"
readonly TC_CLASS_GAME="1:10"
readonly TC_CLASS_DEFAULT="1:30"
readonly TC_RATE_MAX="1000mbit"

# Common game port ranges
readonly GAME_PORTS_STEAM="27000:27100"
readonly GAME_PORTS_GENERIC_1="7777:7800"
readonly GAME_PORTS_MINECRAFT="25565"
readonly GAME_PORTS_GENERIC_2="30000:30100"
readonly GAME_PORTS_VALHEIM="2456:2458"
readonly GAME_PORTS_FACTORIO="34197"

# Known game process names for auto-detection
readonly GAME_PROCESSES=(
    "gamescope" "mangohud" "wine" "wineserver" "proton"
    "steam_app_" "reaper" "pressure-vessel"
    "factorio" "valheim" "minecraft" "java"
    "cs2" "dota2" "tf2" "hl2_linux"
)

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly MAGENTA='\033[0;35m'
readonly WHITE='\033[1;37m'
readonly DIM='\033[2m'
readonly BOLD='\033[1m'
readonly RESET='\033[0m'

# Bar chart characters
readonly BAR_FULL="█"
readonly BAR_MED="▓"
readonly BAR_LOW="░"

# ==============================================================================
# Utility Functions
# ==============================================================================

log() {
    local level="$1"; shift
    local msg="$*"
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    mkdir -p "$LOG_DIR"
    echo "[$ts] [$level] $msg" >> "$LOG_FILE" 2>/dev/null || true
}

info()    { echo -e "${GREEN}●${RESET} $*"; }
warn()    { echo -e "${YELLOW}●${RESET} $*"; }
error()   { echo -e "${RED}●${RESET} $*" >&2; }
header()  { echo -e "\n${BOLD}${CYAN}$*${RESET}"; }
dim()     { echo -e "${DIM}$*${RESET}"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }

notify() {
    local summary="$1"
    local body="${2:-}"
    if command -v notify-send &>/dev/null; then
        notify-send -a "24HG Forge Download Manager" "$summary" "$body" -i "network-transmit" 2>/dev/null || true
    fi
}

ensure_dirs() {
    mkdir -p "$CONFIG_DIR" "$STATE_DIR" "$LOG_DIR" "$SYSTEMD_USER_DIR"
}

# ==============================================================================
# Configuration Management
# ==============================================================================

default_config() {
    cat <<'JSONEOF'
{
    "auto_pause_on_game": true,
    "bandwidth_limit_gaming_mbps": 1,
    "auto_resume_delay_seconds": 30,
    "schedule_type": "none",
    "schedule_download_start": "02:00",
    "schedule_download_end": "07:00",
    "schedule_gaming_start": "18:00",
    "schedule_gaming_end": "23:00",
    "gaming_mode": "auto"
}
JSONEOF
}

load_config() {
    ensure_dirs
    if [[ ! -f "$CONFIG_FILE" ]]; then
        default_config > "$CONFIG_FILE"
    fi
}

get_config() {
    local key="$1"
    local default="${2:-}"
    load_config
    local val
    if command -v jq &>/dev/null; then
        val="$(jq -r ".$key // empty" "$CONFIG_FILE" 2>/dev/null)" || val=""
    else
        # Fallback: crude JSON parsing
        val="$(grep -o "\"$key\"[[:space:]]*:[[:space:]]*[^,}]*" "$CONFIG_FILE" 2>/dev/null \
            | head -1 | sed 's/.*:[[:space:]]*//' | tr -d '"' | tr -d ' ')" || val=""
    fi
    if [[ -z "$val" || "$val" == "null" ]]; then
        echo "$default"
    else
        echo "$val"
    fi
}

set_config() {
    local key="$1"
    local value="$2"
    load_config
    if command -v jq &>/dev/null; then
        local tmp
        tmp="$(mktemp)"
        # Detect booleans and numbers
        case "$value" in
            true|false)
                jq ".$key = $value" "$CONFIG_FILE" > "$tmp" ;;
            [0-9]|[0-9][0-9]|[0-9][0-9][0-9]|[0-9][0-9][0-9][0-9])
                jq ".$key = $value" "$CONFIG_FILE" > "$tmp" ;;
            *)
                jq ".$key = \"$value\"" "$CONFIG_FILE" > "$tmp" ;;
        esac
        mv "$tmp" "$CONFIG_FILE"
    else
        # Fallback: rewrite config (crude but functional)
        warn "jq not installed — settings may not persist correctly. Install jq for full functionality."
    fi
    log "INFO" "Config set: $key=$value"
}

# ==============================================================================
# State Management
# ==============================================================================

get_state() {
    local key="$1"
    local default="${2:-}"
    if [[ -f "$STATE_FILE" ]]; then
        local val
        val="$(grep "^${key}=" "$STATE_FILE" 2>/dev/null | tail -1 | cut -d= -f2-)" || val=""
        if [[ -n "$val" ]]; then
            echo "$val"
            return
        fi
    fi
    echo "$default"
}

set_state() {
    local key="$1"
    local value="$2"
    ensure_dirs
    if [[ -f "$STATE_FILE" ]]; then
        local tmp
        tmp="$(mktemp)"
        grep -v "^${key}=" "$STATE_FILE" > "$tmp" 2>/dev/null || true
        echo "${key}=${value}" >> "$tmp"
        mv "$tmp" "$STATE_FILE"
    else
        echo "${key}=${value}" > "$STATE_FILE"
    fi
}

# ==============================================================================
# Network Interface Detection
# ==============================================================================

detect_interface() {
    local iface
    # Get the default route interface
    iface="$(ip route get 8.8.8.8 2>/dev/null | grep -oP 'dev \K\S+' | head -1)" || true
    if [[ -z "$iface" ]]; then
        # Fallback: first non-loopback interface that is UP
        iface="$(ip -o link show up 2>/dev/null | grep -v "lo:" | head -1 | awk -F': ' '{print $2}')" || true
    fi
    if [[ -z "$iface" ]]; then
        error "Could not detect network interface"
        return 1
    fi
    echo "$iface"
}

detect_interface_type() {
    local iface="$1"
    if [[ "$iface" == wl* ]]; then
        echo "wireless"
    elif [[ "$iface" == tun* || "$iface" == wg* ]]; then
        echo "vpn"
    elif [[ "$iface" == eth* || "$iface" == en* ]]; then
        echo "wired"
    else
        echo "unknown"
    fi
}

get_bandwidth_usage() {
    local iface
    iface="$(detect_interface 2>/dev/null)" || iface=""
    if [[ -z "$iface" ]]; then
        echo "0 0"
        return
    fi

    # Read RX/TX bytes, wait 1 second, read again
    local rx1 tx1 rx2 tx2
    rx1="$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null)" || rx1=0
    tx1="$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null)" || tx1=0
    sleep 1
    rx2="$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null)" || rx2=0
    tx2="$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null)" || tx2=0

    local rx_rate tx_rate
    rx_rate=$(( (rx2 - rx1) * 8 / 1000 ))  # kbps
    tx_rate=$(( (tx2 - tx1) * 8 / 1000 ))  # kbps
    echo "$rx_rate $tx_rate"
}

format_bandwidth() {
    local kbps="$1"
    if (( kbps >= 1000000 )); then
        printf "%.1f Gbps" "$(echo "scale=1; $kbps / 1000000" | bc 2>/dev/null || echo "0")"
    elif (( kbps >= 1000 )); then
        printf "%.1f Mbps" "$(echo "scale=1; $kbps / 1000" | bc 2>/dev/null || echo "0")"
    else
        printf "%d Kbps" "$kbps"
    fi
}

bandwidth_bar() {
    local kbps="$1"
    local max_kbps="${2:-100000}"  # Default 100 Mbps scale
    local width=30
    local filled
    if (( max_kbps <= 0 )); then
        filled=0
    else
        filled=$(( kbps * width / max_kbps ))
    fi
    (( filled > width )) && filled=$width

    local bar=""
    local color="$GREEN"
    if (( kbps > max_kbps * 80 / 100 )); then
        color="$RED"
    elif (( kbps > max_kbps * 50 / 100 )); then
        color="$YELLOW"
    fi

    local i
    for (( i = 0; i < filled; i++ )); do
        bar+="$BAR_FULL"
    done
    for (( i = filled; i < width; i++ )); do
        bar+="$BAR_LOW"
    done
    echo -e "${color}${bar}${RESET}"
}

# ==============================================================================
# Download Detection
# ==============================================================================

is_steam_downloading() {
    # Check Steam content log for recent download activity (within last 60 seconds)
    local log_file=""
    if [[ -f "$STEAM_NATIVE_LOG" ]]; then
        log_file="$STEAM_NATIVE_LOG"
    elif [[ -f "$STEAM_FLATPAK_LOG" ]]; then
        log_file="$STEAM_FLATPAK_LOG"
    fi

    if [[ -n "$log_file" ]]; then
        local mod_time now
        mod_time="$(stat -c %Y "$log_file" 2>/dev/null)" || mod_time=0
        now="$(date +%s)"
        if (( now - mod_time < 60 )); then
            # Log was modified recently — check for download keywords
            if tail -20 "$log_file" 2>/dev/null | grep -qiE 'download|update|validating|staging|preallocating'; then
                return 0
            fi
        fi
    fi

    # Check for active Steam download processes
    if pgrep -f "steamwebhelper.*download" &>/dev/null; then
        return 0
    fi

    return 1
}

is_flatpak_updating() {
    pgrep -f "flatpak.*update\|flatpak.*install" &>/dev/null
}

is_rpmostree_running() {
    pgrep -f "rpm-ostree" &>/dev/null
}

get_rpmostree_status() {
    if command -v rpm-ostree &>/dev/null; then
        local status
        status="$(rpm-ostree status 2>/dev/null | head -5)" || status=""
        if echo "$status" | grep -qi "downloading\|fetching"; then
            echo "downloading"
        elif echo "$status" | grep -qi "staging\|applying"; then
            echo "staging"
        elif is_rpmostree_running; then
            echo "running"
        else
            echo "idle"
        fi
    else
        echo "n/a"
    fi
}

is_browser_downloading() {
    # Detect active browser downloads by checking for .part/.crdownload files
    local found=false
    local dirs=("$HOME/Downloads")

    for dir in "${dirs[@]}"; do
        if [[ -d "$dir" ]]; then
            # Firefox .part files, Chrome .crdownload files
            if find "$dir" -maxdepth 1 \( -name "*.part" -o -name "*.crdownload" \) -newer <(date -d '5 minutes ago' '+%Y%m%d%H%M' 2>/dev/null || echo "") -print -quit 2>/dev/null | grep -q .; then
                found=true
                break
            fi
            # Simpler check: recently modified partial download files
            local partials
            partials="$(find "$dir" -maxdepth 1 \( -name "*.part" -o -name "*.crdownload" \) -mmin -5 2>/dev/null | head -5)" || true
            if [[ -n "$partials" ]]; then
                found=true
                break
            fi
        fi
    done

    $found
}

is_game_running() {
    for proc in "${GAME_PROCESSES[@]}"; do
        if pgrep -f "$proc" &>/dev/null; then
            # Exclude Steam client itself (we want actual games)
            if [[ "$proc" == "steam_app_" ]]; then
                return 0
            fi
            # For wine/proton, make sure it is not just Steam
            if [[ "$proc" == "wine" || "$proc" == "wineserver" || "$proc" == "proton" ]]; then
                return 0
            fi
            if [[ "$proc" == "gamescope" || "$proc" == "pressure-vessel" || "$proc" == "reaper" ]]; then
                return 0
            fi
        fi
    done

    # Check if gamemode is active (Feral GameMode)
    if command -v gamemoded &>/dev/null && gamemoded -s 2>/dev/null | grep -q "active"; then
        return 0
    fi

    return 1
}

# ==============================================================================
# Traffic Control
# ==============================================================================

tc_is_active() {
    local iface
    iface="$(detect_interface 2>/dev/null)" || return 1
    tc qdisc show dev "$iface" 2>/dev/null | grep -q "htb" 2>/dev/null
}

tc_setup() {
    local limit_mbps="$1"
    local iface
    iface="$(detect_interface)" || { error "No network interface found"; return 1; }

    # Remove existing qdisc if present
    tc_teardown 2>/dev/null || true

    log "INFO" "Setting up tc on $iface with ${limit_mbps}Mbps background limit"

    # Root HTB qdisc
    sudo tc qdisc add dev "$iface" root handle "$TC_HANDLE" htb default 30 2>/dev/null || {
        error "Failed to create tc qdisc (need sudo/polkit)"
        error "Run with: sudo $APP_NAME bandwidth limit $limit_mbps"
        return 1
    }

    # High priority class for game traffic
    sudo tc class add dev "$iface" parent "$TC_HANDLE" classid "$TC_CLASS_GAME" \
        htb rate 100mbit ceil "$TC_RATE_MAX" prio 1

    # Low priority class for background downloads
    sudo tc class add dev "$iface" parent "$TC_HANDLE" classid "$TC_CLASS_DEFAULT" \
        htb rate "${limit_mbps}mbit" ceil "${limit_mbps}mbit" prio 7

    # Add SFQ to both classes for fairness
    sudo tc qdisc add dev "$iface" parent "$TC_CLASS_GAME" handle 10: sfq perturb 10
    sudo tc qdisc add dev "$iface" parent "$TC_CLASS_DEFAULT" handle 30: sfq perturb 10

    # Classify game traffic by destination port ranges
    # Steam game servers: 27000-27100
    sudo tc filter add dev "$iface" protocol ip parent "$TC_HANDLE" prio 1 u32 \
        match ip dport 27000 0xff00 flowid "$TC_CLASS_GAME" 2>/dev/null || true

    # Generic game ports: 7777-7800
    sudo tc filter add dev "$iface" protocol ip parent "$TC_HANDLE" prio 1 u32 \
        match ip dport 7777 0xffe0 flowid "$TC_CLASS_GAME" 2>/dev/null || true

    # Minecraft: 25565
    sudo tc filter add dev "$iface" protocol ip parent "$TC_HANDLE" prio 1 u32 \
        match ip dport 25565 0xffff flowid "$TC_CLASS_GAME" 2>/dev/null || true

    # Generic game ports: 30000-30100
    sudo tc filter add dev "$iface" protocol ip parent "$TC_HANDLE" prio 1 u32 \
        match ip dport 30000 0xff00 flowid "$TC_CLASS_GAME" 2>/dev/null || true

    # Valheim: 2456-2458
    sudo tc filter add dev "$iface" protocol ip parent "$TC_HANDLE" prio 1 u32 \
        match ip dport 2456 0xfffc flowid "$TC_CLASS_GAME" 2>/dev/null || true

    # Factorio: 34197
    sudo tc filter add dev "$iface" protocol ip parent "$TC_HANDLE" prio 1 u32 \
        match ip dport 34197 0xffff flowid "$TC_CLASS_GAME" 2>/dev/null || true

    # Source port ranges (for game client outbound)
    sudo tc filter add dev "$iface" protocol ip parent "$TC_HANDLE" prio 1 u32 \
        match ip sport 27000 0xff00 flowid "$TC_CLASS_GAME" 2>/dev/null || true

    set_state "tc_active" "true"
    set_state "tc_limit_mbps" "$limit_mbps"
    set_state "tc_interface" "$iface"
    success "Traffic control active: background limited to ${limit_mbps} Mbps on $iface"
}

tc_teardown() {
    local iface
    iface="$(get_state "tc_interface" "")"
    if [[ -z "$iface" ]]; then
        iface="$(detect_interface 2>/dev/null)" || return 0
    fi

    if tc qdisc show dev "$iface" 2>/dev/null | grep -q "htb"; then
        sudo tc qdisc del dev "$iface" root 2>/dev/null || true
        log "INFO" "Removed tc rules on $iface"
    fi

    set_state "tc_active" "false"
    set_state "tc_limit_mbps" ""
}

# ==============================================================================
# Command: status
# ==============================================================================

cmd_status() {
    header "24HG Forge Download Manager — Status"
    echo ""

    # Gaming mode
    local gm_state
    gm_state="$(get_state "gaming_mode_active" "false")"
    local gm_auto
    gm_auto="$(get_config "gaming_mode" "auto")"
    if [[ "$gm_state" == "true" ]]; then
        echo -e "  ${RED}${BOLD}GAMING MODE ACTIVE${RESET}  ${DIM}(downloads paused)${RESET}"
    else
        echo -e "  ${GREEN}Gaming mode:${RESET} inactive  ${DIM}(mode: $gm_auto)${RESET}"
    fi

    # Game detection
    if is_game_running; then
        echo -e "  ${MAGENTA}Game detected:${RESET} running"
    else
        echo -e "  ${DIM}No game detected${RESET}"
    fi
    echo ""

    # Downloads section
    header "Downloads"
    echo ""

    # Steam
    echo -n "  Steam:       "
    if is_steam_downloading; then
        echo -e "${YELLOW}Downloading${RESET}"
    elif pgrep -x "steam" &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
        echo -e "${GREEN}Running${RESET} ${DIM}(no active downloads)${RESET}"
    else
        echo -e "${DIM}Not running${RESET}"
    fi

    # Flatpak
    echo -n "  Flatpak:     "
    if is_flatpak_updating; then
        echo -e "${YELLOW}Updating${RESET}"
    else
        echo -e "${DIM}Idle${RESET}"
    fi

    # rpm-ostree
    echo -n "  System:      "
    local ros_status
    ros_status="$(get_rpmostree_status)"
    case "$ros_status" in
        downloading) echo -e "${YELLOW}Downloading updates${RESET}" ;;
        staging)     echo -e "${YELLOW}Staging updates${RESET}" ;;
        running)     echo -e "${YELLOW}Active${RESET}" ;;
        idle)        echo -e "${DIM}Idle${RESET}" ;;
        n/a)         echo -e "${DIM}N/A (not Fedora Atomic)${RESET}" ;;
    esac

    # Browser
    echo -n "  Browser:     "
    if is_browser_downloading; then
        echo -e "${YELLOW}Active downloads detected${RESET}"
    else
        echo -e "${DIM}No active downloads${RESET}"
    fi
    echo ""

    # Bandwidth section
    header "Bandwidth"
    echo ""

    local iface iface_type
    iface="$(detect_interface 2>/dev/null)" || iface="none"
    iface_type="$(detect_interface_type "$iface" 2>/dev/null)" || iface_type="unknown"
    echo -e "  Interface:   ${WHITE}$iface${RESET} ${DIM}($iface_type)${RESET}"

    # TC status
    if tc_is_active; then
        local limit
        limit="$(get_state "tc_limit_mbps" "?")"
        echo -e "  TC Shaping:  ${YELLOW}Active${RESET} ${DIM}(background: ${limit} Mbps)${RESET}"
    else
        echo -e "  TC Shaping:  ${DIM}Inactive${RESET}"
    fi

    echo ""
    echo -e "  ${DIM}Measuring bandwidth (1 second)...${RESET}"
    local bw_data rx_kbps tx_kbps
    bw_data="$(get_bandwidth_usage)"
    rx_kbps="$(echo "$bw_data" | awk '{print $1}')"
    tx_kbps="$(echo "$bw_data" | awk '{print $2}')"

    local rx_fmt tx_fmt
    rx_fmt="$(format_bandwidth "$rx_kbps")"
    tx_fmt="$(format_bandwidth "$tx_kbps")"

    # Move cursor up one line to overwrite the "measuring" message
    echo -en "\033[1A\033[2K"
    echo -e "  Download:    $(bandwidth_bar "$rx_kbps" 100000) $rx_fmt"
    echo -e "  Upload:      $(bandwidth_bar "$tx_kbps" 100000) $tx_fmt"
    echo ""

    # Schedule
    local sched_type
    sched_type="$(get_config "schedule_type" "none")"
    if [[ "$sched_type" != "none" ]]; then
        header "Schedule"
        echo ""
        if [[ "$sched_type" == "download-hours" ]]; then
            local ds de
            ds="$(get_config "schedule_download_start" "02:00")"
            de="$(get_config "schedule_download_end" "07:00")"
            echo -e "  Download window: ${GREEN}$ds — $de${RESET}"
        elif [[ "$sched_type" == "gaming-hours" ]]; then
            local gs ge
            gs="$(get_config "schedule_gaming_start" "18:00")"
            ge="$(get_config "schedule_gaming_end" "23:00")"
            echo -e "  Gaming hours (auto-pause): ${YELLOW}$gs — $ge${RESET}"
        fi
        echo ""
    fi

    # Paused state
    local paused
    paused="$(get_state "manually_paused" "false")"
    if [[ "$paused" == "true" ]]; then
        echo -e "  ${RED}${BOLD}Downloads are manually paused${RESET}"
        echo -e "  ${DIM}Run '$APP_NAME resume' to resume${RESET}"
        echo ""
    fi
}

# ==============================================================================
# Command: pause
# ==============================================================================

cmd_pause() {
    header "Pausing all downloads..."
    echo ""
    local errors=0

    # Steam
    echo -n "  Steam downloads: "
    if pgrep -x "steam" &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
        xdg-open "steam://command/PauseDownloads" 2>/dev/null && \
            echo -e "${GREEN}paused${RESET}" || { echo -e "${YELLOW}failed (Steam URL handler)${RESET}"; (( errors++ )) || true; }
    else
        echo -e "${DIM}Steam not running${RESET}"
    fi

    # Flatpak
    echo -n "  Flatpak:         "
    if is_flatpak_updating; then
        pkill -f "flatpak.*update" 2>/dev/null || true
        pkill -f "flatpak.*install" 2>/dev/null || true
        echo -e "${GREEN}stopped${RESET}"
    fi
    # Stop the portal service to prevent background updates
    systemctl --user stop flatpak-portal.service 2>/dev/null && \
        echo -e "${GREEN}portal stopped${RESET}" || echo -e "${DIM}portal already stopped${RESET}"

    # rpm-ostree
    echo -n "  rpm-ostree:      "
    if is_rpmostree_running; then
        pkill rpm-ostree 2>/dev/null && \
            echo -e "${GREEN}stopped (will resume cleanly)${RESET}" || echo -e "${YELLOW}failed to stop${RESET}"
    else
        echo -e "${DIM}not running${RESET}"
    fi

    # Bandwidth limit
    echo -n "  Bandwidth:       "
    local limit
    limit="$(get_config "bandwidth_limit_gaming_mbps" "1")"
    if tc_setup "$limit" 2>/dev/null; then
        echo -e "${GREEN}limited to ${limit} Mbps${RESET}"
    else
        echo -e "${YELLOW}tc failed (may need sudo)${RESET}"
    fi

    set_state "manually_paused" "true"
    set_state "pause_time" "$(date +%s)"
    log "INFO" "All downloads paused"
    echo ""
    success "All downloads paused"
    notify "Downloads Paused" "All downloads have been paused"
}

# ==============================================================================
# Command: resume
# ==============================================================================

cmd_resume() {
    header "Resuming all downloads..."
    echo ""

    # Steam
    echo -n "  Steam downloads: "
    if pgrep -x "steam" &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
        xdg-open "steam://command/ResumeDownloads" 2>/dev/null && \
            echo -e "${GREEN}resumed${RESET}" || echo -e "${YELLOW}failed${RESET}"
    else
        echo -e "${DIM}Steam not running${RESET}"
    fi

    # Flatpak
    echo -n "  Flatpak:         "
    systemctl --user start flatpak-portal.service 2>/dev/null && \
        echo -e "${GREEN}portal started${RESET}" || echo -e "${DIM}already running${RESET}"

    # Remove TC rules
    echo -n "  Bandwidth:       "
    tc_teardown 2>/dev/null
    echo -e "${GREEN}limits removed${RESET}"

    set_state "manually_paused" "false"
    set_state "gaming_mode_active" "false"
    log "INFO" "All downloads resumed"
    echo ""
    success "All downloads resumed"
    notify "Downloads Resumed" "All downloads have been resumed"
}

# ==============================================================================
# Command: schedule
# ==============================================================================

generate_systemd_timer() {
    local name="$1"
    local on_calendar="$2"
    local exec_cmd="$3"
    local description="$4"

    # Service file
    cat > "$SYSTEMD_USER_DIR/forge-dlmgr-${name}.service" <<EOF
[Unit]
Description=24HG Forge Download Manager — $description

[Service]
Type=oneshot
ExecStart=$exec_cmd
EOF

    # Timer file
    cat > "$SYSTEMD_USER_DIR/forge-dlmgr-${name}.timer" <<EOF
[Unit]
Description=24HG Forge Download Manager — $description Timer

[Timer]
OnCalendar=$on_calendar
Persistent=true

[Install]
WantedBy=timers.target
EOF

    systemctl --user daemon-reload 2>/dev/null || true
    systemctl --user enable --now "forge-dlmgr-${name}.timer" 2>/dev/null || true
}

remove_systemd_timers() {
    for timer in "$SYSTEMD_USER_DIR"/forge-dlmgr-*.timer; do
        [[ -f "$timer" ]] || continue
        local unit
        unit="$(basename "$timer")"
        systemctl --user disable --now "$unit" 2>/dev/null || true
    done
    rm -f "$SYSTEMD_USER_DIR"/forge-dlmgr-*.timer "$SYSTEMD_USER_DIR"/forge-dlmgr-*.service
    systemctl --user daemon-reload 2>/dev/null || true
}

cmd_schedule() {
    local subcmd="${1:-show}"
    shift || true

    case "$subcmd" in
        set)
            local arg1="${1:-}"
            local arg2="${2:-}"

            if [[ -z "$arg1" ]]; then
                error "Usage: $APP_NAME schedule set <HH:MM-HH:MM>"
                error "       $APP_NAME schedule set gaming-hours <HH:MM-HH:MM>"
                return 1
            fi

            if [[ "$arg1" == "gaming-hours" ]]; then
                if [[ -z "$arg2" || ! "$arg2" =~ ^[0-9]{2}:[0-9]{2}-[0-9]{2}:[0-9]{2}$ ]]; then
                    error "Usage: $APP_NAME schedule set gaming-hours HH:MM-HH:MM"
                    return 1
                fi
                local gs ge
                gs="${arg2%%-*}"
                ge="${arg2##*-}"
                set_config "schedule_type" "gaming-hours"
                set_config "schedule_gaming_start" "$gs"
                set_config "schedule_gaming_end" "$ge"

                # Get the path to this script
                local self_path
                self_path="$(readlink -f "$0")"

                remove_systemd_timers
                generate_systemd_timer "pause-gaming" "*-*-* ${gs}:00" \
                    "$self_path pause" "Pause downloads for gaming hours"
                generate_systemd_timer "resume-gaming" "*-*-* ${ge}:00" \
                    "$self_path resume" "Resume downloads after gaming hours"

                success "Gaming hours schedule set: pause at $gs, resume at $ge"
                info "Systemd timers created in $SYSTEMD_USER_DIR/"

            elif [[ "$arg1" =~ ^[0-9]{2}:[0-9]{2}-[0-9]{2}:[0-9]{2}$ ]]; then
                local ds de
                ds="${arg1%%-*}"
                de="${arg1##*-}"
                set_config "schedule_type" "download-hours"
                set_config "schedule_download_start" "$ds"
                set_config "schedule_download_end" "$de"

                local self_path
                self_path="$(readlink -f "$0")"

                remove_systemd_timers
                generate_systemd_timer "resume-dl" "*-*-* ${ds}:00" \
                    "$self_path resume" "Resume downloads (scheduled window)"
                generate_systemd_timer "pause-dl" "*-*-* ${de}:00" \
                    "$self_path pause" "Pause downloads (end of window)"

                success "Download schedule set: downloads allowed $ds — $de"
                info "Systemd timers created in $SYSTEMD_USER_DIR/"

            else
                error "Invalid time format. Use HH:MM-HH:MM (e.g., 02:00-07:00)"
                return 1
            fi
            ;;

        show)
            header "Download Schedule"
            echo ""
            local sched_type
            sched_type="$(get_config "schedule_type" "none")"

            case "$sched_type" in
                none)
                    dim "  No schedule configured"
                    dim "  Use '$APP_NAME schedule set HH:MM-HH:MM' to set download hours"
                    dim "  Use '$APP_NAME schedule set gaming-hours HH:MM-HH:MM' to auto-pause during gaming"
                    ;;
                download-hours)
                    local ds de
                    ds="$(get_config "schedule_download_start" "02:00")"
                    de="$(get_config "schedule_download_end" "07:00")"
                    echo -e "  Type:    ${CYAN}Download window${RESET}"
                    echo -e "  Window:  ${GREEN}$ds — $de${RESET}"
                    echo -e "  ${DIM}Downloads will only run between these hours${RESET}"
                    ;;
                gaming-hours)
                    local gs ge
                    gs="$(get_config "schedule_gaming_start" "18:00")"
                    ge="$(get_config "schedule_gaming_end" "23:00")"
                    echo -e "  Type:    ${CYAN}Gaming hours${RESET}"
                    echo -e "  Pause:   ${YELLOW}$gs — $ge${RESET}"
                    echo -e "  ${DIM}Downloads auto-pause during gaming hours${RESET}"
                    ;;
            esac
            echo ""

            # Show active timers
            local timers
            timers="$(systemctl --user list-timers 'forge-dlmgr-*' --no-pager 2>/dev/null)" || timers=""
            if [[ -n "$timers" ]] && echo "$timers" | grep -q "forge-dlmgr"; then
                echo -e "  ${BOLD}Active timers:${RESET}"
                echo "$timers" | grep "forge-dlmgr" | while read -r line; do
                    echo -e "    ${DIM}$line${RESET}"
                done
                echo ""
            fi
            ;;

        clear)
            remove_systemd_timers
            set_config "schedule_type" "none"
            success "Schedule cleared. All timers removed."
            ;;

        *)
            error "Unknown schedule command: $subcmd"
            error "Usage: $APP_NAME schedule {set|show|clear}"
            return 1
            ;;
    esac
}

# ==============================================================================
# Command: bandwidth
# ==============================================================================

cmd_bandwidth() {
    local mode="${1:-}"

    case "$mode" in
        gaming)
            header "Setting gaming bandwidth profile"
            echo ""
            local limit
            limit="$(get_config "bandwidth_limit_gaming_mbps" "1")"
            tc_setup "$limit"
            ;;
        full)
            header "Removing bandwidth limits"
            echo ""
            tc_teardown
            success "All bandwidth limits removed"
            ;;
        limit)
            local mbps="${2:-}"
            if [[ -z "$mbps" || ! "$mbps" =~ ^[0-9]+$ ]]; then
                error "Usage: $APP_NAME bandwidth limit <Mbps>"
                error "Example: $APP_NAME bandwidth limit 5"
                return 1
            fi
            header "Setting bandwidth limit: ${mbps} Mbps"
            echo ""
            tc_setup "$mbps"
            ;;
        "")
            # Show current bandwidth state
            header "Bandwidth Configuration"
            echo ""
            local iface iface_type
            iface="$(detect_interface 2>/dev/null)" || iface="none"
            iface_type="$(detect_interface_type "$iface" 2>/dev/null)" || iface_type="unknown"

            echo -e "  Interface:     ${WHITE}$iface${RESET} ${DIM}($iface_type)${RESET}"

            if tc_is_active; then
                local limit
                limit="$(get_state "tc_limit_mbps" "?")"
                echo -e "  TC Shaping:    ${YELLOW}Active${RESET}"
                echo -e "  Background:    ${WHITE}${limit} Mbps${RESET} max"
                echo -e "  Game traffic:  ${GREEN}High priority${RESET}"
            else
                echo -e "  TC Shaping:    ${DIM}Inactive (no limits)${RESET}"
            fi

            echo ""
            echo -e "  ${DIM}Measuring current bandwidth (1 second)...${RESET}"
            local bw_data rx_kbps tx_kbps
            bw_data="$(get_bandwidth_usage)"
            rx_kbps="$(echo "$bw_data" | awk '{print $1}')"
            tx_kbps="$(echo "$bw_data" | awk '{print $2}')"

            echo -en "\033[1A\033[2K"
            echo -e "  Download:      $(bandwidth_bar "$rx_kbps" 100000) $(format_bandwidth "$rx_kbps")"
            echo -e "  Upload:        $(bandwidth_bar "$tx_kbps" 100000) $(format_bandwidth "$tx_kbps")"

            echo ""
            dim "  Usage: $APP_NAME bandwidth {gaming|full|limit <Mbps>}"
            ;;
        *)
            error "Unknown bandwidth mode: $mode"
            error "Usage: $APP_NAME bandwidth {gaming|full|limit <Mbps>}"
            return 1
            ;;
    esac
}

# ==============================================================================
# Command: gaming-mode
# ==============================================================================

gaming_mode_activate() {
    log "INFO" "Gaming mode activated"
    set_state "gaming_mode_active" "true"
    set_state "gaming_mode_time" "$(date +%s)"

    # Pause Steam downloads silently
    if pgrep -x "steam" &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
        xdg-open "steam://command/PauseDownloads" 2>/dev/null || true
    fi

    # Stop Flatpak background updates
    pkill -f "flatpak.*update" 2>/dev/null || true
    systemctl --user stop flatpak-portal.service 2>/dev/null || true

    # Stop rpm-ostree if running
    if is_rpmostree_running; then
        pkill rpm-ostree 2>/dev/null || true
    fi

    # Disable rpm-ostree auto-updates temporarily
    if command -v rpm-ostree &>/dev/null; then
        sudo systemctl stop rpm-ostreed-automatic.timer 2>/dev/null || true
    fi

    # Set bandwidth limits
    local limit
    limit="$(get_config "bandwidth_limit_gaming_mbps" "1")"
    tc_setup "$limit" 2>/dev/null || true

    notify "Gaming Mode ON" "Downloads paused, background limited to ${limit} Mbps"
}

gaming_mode_deactivate() {
    local delay
    delay="$(get_config "auto_resume_delay_seconds" "30")"

    log "INFO" "Gaming mode deactivating (delay: ${delay}s)"

    if (( delay > 0 )); then
        # Wait before resuming (game might restart)
        (
            sleep "$delay"
            # Check if a game started again during the delay
            if is_game_running; then
                log "INFO" "Game detected during resume delay — staying in gaming mode"
                exit 0
            fi

            set_state "gaming_mode_active" "false"

            # Resume Steam
            if pgrep -x "steam" &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
                xdg-open "steam://command/ResumeDownloads" 2>/dev/null || true
            fi

            # Resume Flatpak
            systemctl --user start flatpak-portal.service 2>/dev/null || true

            # Re-enable rpm-ostree auto-updates
            if command -v rpm-ostree &>/dev/null; then
                sudo systemctl start rpm-ostreed-automatic.timer 2>/dev/null || true
            fi

            # Remove TC limits
            tc_teardown 2>/dev/null || true

            notify "Gaming Mode OFF" "Downloads resumed"
            log "INFO" "Gaming mode deactivated, downloads resumed"
        ) &
        disown
    else
        set_state "gaming_mode_active" "false"
        # Immediate resume
        if pgrep -x "steam" &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
            xdg-open "steam://command/ResumeDownloads" 2>/dev/null || true
        fi
        systemctl --user start flatpak-portal.service 2>/dev/null || true
        if command -v rpm-ostree &>/dev/null; then
            sudo systemctl start rpm-ostreed-automatic.timer 2>/dev/null || true
        fi
        tc_teardown 2>/dev/null || true
        notify "Gaming Mode OFF" "Downloads resumed"
    fi
}

gaming_mode_auto_loop() {
    info "Auto gaming mode — monitoring for game processes..."
    dim "Press Ctrl+C to stop"
    echo ""

    local was_gaming=false

    while true; do
        if is_game_running; then
            if [[ "$was_gaming" == "false" ]]; then
                info "Game detected — activating gaming mode"
                gaming_mode_activate
                was_gaming=true
            fi
        else
            if [[ "$was_gaming" == "true" ]]; then
                local delay
                delay="$(get_config "auto_resume_delay_seconds" "30")"
                info "Game exited — resuming downloads in ${delay}s"
                gaming_mode_deactivate
                was_gaming=false
            fi
        fi
        sleep 5
    done
}

cmd_gaming_mode() {
    local mode="${1:-}"

    case "$mode" in
        on)
            header "Gaming Mode — ON"
            echo ""
            gaming_mode_activate
            success "Gaming mode activated"
            echo ""
            echo -e "  ${DIM}Downloads paused, game traffic prioritized${RESET}"
            echo -e "  ${DIM}Run '$APP_NAME gaming-mode off' to restore${RESET}"
            ;;
        off)
            header "Gaming Mode — OFF"
            echo ""
            set_state "gaming_mode_active" "false"

            # Resume everything immediately
            if pgrep -x "steam" &>/dev/null || pgrep -f "steamwebhelper" &>/dev/null; then
                xdg-open "steam://command/ResumeDownloads" 2>/dev/null || true
            fi
            systemctl --user start flatpak-portal.service 2>/dev/null || true
            if command -v rpm-ostree &>/dev/null; then
                sudo systemctl start rpm-ostreed-automatic.timer 2>/dev/null || true
            fi
            tc_teardown 2>/dev/null || true

            success "Gaming mode deactivated — downloads resumed"
            notify "Gaming Mode OFF" "Downloads resumed"
            ;;
        auto)
            header "Gaming Mode — Auto Detection"
            echo ""
            set_config "gaming_mode" "auto"
            gaming_mode_auto_loop
            ;;
        "")
            # Show current state
            local gm_state
            gm_state="$(get_state "gaming_mode_active" "false")"
            local gm_setting
            gm_setting="$(get_config "gaming_mode" "auto")"

            header "Gaming Mode"
            echo ""
            echo -e "  Status:    $(if [[ "$gm_state" == "true" ]]; then echo -e "${RED}${BOLD}ACTIVE${RESET}"; else echo -e "${GREEN}Inactive${RESET}"; fi)"
            echo -e "  Setting:   ${WHITE}$gm_setting${RESET}"

            if is_game_running; then
                echo -e "  Game:      ${MAGENTA}Detected${RESET}"
            else
                echo -e "  Game:      ${DIM}None detected${RESET}"
            fi

            echo ""
            dim "  Usage: $APP_NAME gaming-mode {on|off|auto}"
            dim ""
            dim "  on   — Manually activate gaming optimizations"
            dim "  off  — Manually deactivate and resume downloads"
            dim "  auto — Auto-detect games and toggle (runs in foreground)"
            ;;
        *)
            error "Unknown gaming-mode option: $mode"
            error "Usage: $APP_NAME gaming-mode {on|off|auto}"
            return 1
            ;;
    esac
}

# ==============================================================================
# Command: settings
# ==============================================================================

cmd_settings() {
    local subcmd="${1:-show}"
    shift || true

    case "$subcmd" in
        show)
            header "Download Manager Settings"
            echo ""
            load_config
            echo -e "  Auto-pause on game:      ${WHITE}$(get_config "auto_pause_on_game" "true")${RESET}"
            echo -e "  Bandwidth limit (gaming): ${WHITE}$(get_config "bandwidth_limit_gaming_mbps" "1") Mbps${RESET}"
            echo -e "  Resume delay after game:  ${WHITE}$(get_config "auto_resume_delay_seconds" "30")s${RESET}"
            echo -e "  Schedule type:            ${WHITE}$(get_config "schedule_type" "none")${RESET}"
            echo -e "  Gaming mode:              ${WHITE}$(get_config "gaming_mode" "auto")${RESET}"

            local stype
            stype="$(get_config "schedule_type" "none")"
            if [[ "$stype" == "download-hours" ]]; then
                echo -e "  Download window:          ${WHITE}$(get_config "schedule_download_start" "02:00") — $(get_config "schedule_download_end" "07:00")${RESET}"
            elif [[ "$stype" == "gaming-hours" ]]; then
                echo -e "  Gaming hours:             ${WHITE}$(get_config "schedule_gaming_start" "18:00") — $(get_config "schedule_gaming_end" "23:00")${RESET}"
            fi

            echo ""
            echo -e "  ${DIM}Config file: $CONFIG_FILE${RESET}"
            echo -e "  ${DIM}State file:  $STATE_FILE${RESET}"
            echo -e "  ${DIM}Log file:    $LOG_FILE${RESET}"
            echo ""
            dim "  Editable settings:"
            dim "    $APP_NAME settings auto-pause {yes|no}"
            dim "    $APP_NAME settings bandwidth-limit <Mbps>"
            dim "    $APP_NAME settings resume-delay <seconds>"
            ;;

        auto-pause)
            local val="${1:-}"
            case "$val" in
                yes|true|on|1)
                    set_config "auto_pause_on_game" "true"
                    success "Auto-pause on game launch: enabled"
                    ;;
                no|false|off|0)
                    set_config "auto_pause_on_game" "false"
                    success "Auto-pause on game launch: disabled"
                    ;;
                *)
                    error "Usage: $APP_NAME settings auto-pause {yes|no}"
                    return 1
                    ;;
            esac
            ;;

        bandwidth-limit)
            local val="${1:-}"
            if [[ -z "$val" || ! "$val" =~ ^[0-9]+$ ]]; then
                error "Usage: $APP_NAME settings bandwidth-limit <Mbps>"
                return 1
            fi
            set_config "bandwidth_limit_gaming_mbps" "$val"
            success "Gaming bandwidth limit set to ${val} Mbps"
            ;;

        resume-delay)
            local val="${1:-}"
            if [[ -z "$val" || ! "$val" =~ ^[0-9]+$ ]]; then
                error "Usage: $APP_NAME settings resume-delay <seconds>"
                return 1
            fi
            set_config "auto_resume_delay_seconds" "$val"
            success "Resume delay set to ${val} seconds"
            ;;

        *)
            error "Unknown setting: $subcmd"
            error "Usage: $APP_NAME settings {show|auto-pause|bandwidth-limit|resume-delay}"
            return 1
            ;;
    esac
}

# ==============================================================================
# Help
# ==============================================================================

cmd_help() {
    echo -e "${BOLD}${CYAN}24HG Forge Download Manager${RESET} v${VERSION}"
    echo -e "${DIM}Intelligent bandwidth and download scheduling for gaming${RESET}"
    echo ""
    echo -e "${BOLD}Usage:${RESET} $APP_NAME <command> [options]"
    echo ""
    echo -e "${BOLD}Commands:${RESET}"
    echo -e "  ${WHITE}status${RESET}            Show current download activity and bandwidth"
    echo -e "  ${WHITE}pause${RESET}             Pause all downloads immediately"
    echo -e "  ${WHITE}resume${RESET}            Resume all downloads"
    echo -e "  ${WHITE}schedule${RESET}          Manage download scheduling"
    echo -e "    ${DIM}set HH:MM-HH:MM${RESET}          Set download window"
    echo -e "    ${DIM}set gaming-hours HH:MM-HH:MM${RESET}  Auto-pause during hours"
    echo -e "    ${DIM}show${RESET}                      Show current schedule"
    echo -e "    ${DIM}clear${RESET}                     Remove all schedules"
    echo -e "  ${WHITE}bandwidth${RESET}         Control bandwidth allocation"
    echo -e "    ${DIM}gaming${RESET}                    Limit background to gaming preset"
    echo -e "    ${DIM}full${RESET}                      Remove all limits"
    echo -e "    ${DIM}limit <Mbps>${RESET}              Set custom background limit"
    echo -e "  ${WHITE}gaming-mode${RESET}       Toggle gaming bandwidth mode"
    echo -e "    ${DIM}on${RESET}                        Activate all gaming optimizations"
    echo -e "    ${DIM}off${RESET}                       Restore everything"
    echo -e "    ${DIM}auto${RESET}                      Auto-detect games (foreground)"
    echo -e "  ${WHITE}settings${RESET}          Configure defaults"
    echo -e "    ${DIM}show${RESET}                      Show all settings"
    echo -e "    ${DIM}auto-pause yes|no${RESET}         Toggle auto-pause on game launch"
    echo -e "    ${DIM}bandwidth-limit <Mbps>${RESET}    Default gaming bandwidth limit"
    echo -e "    ${DIM}resume-delay <seconds>${RESET}    Delay before resuming after game exits"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo -e "  ${DIM}$APP_NAME status${RESET}"
    echo -e "  ${DIM}$APP_NAME pause${RESET}"
    echo -e "  ${DIM}$APP_NAME schedule set 02:00-07:00${RESET}"
    echo -e "  ${DIM}$APP_NAME schedule set gaming-hours 18:00-23:00${RESET}"
    echo -e "  ${DIM}$APP_NAME bandwidth limit 5${RESET}"
    echo -e "  ${DIM}$APP_NAME gaming-mode auto${RESET}"
    echo ""
    echo -e "${DIM}Traffic control (tc) commands require root. The script will use${RESET}"
    echo -e "${DIM}sudo when needed. Basic pause/resume works without root.${RESET}"
    echo ""
    echo -e "${DIM}Config: $CONFIG_FILE${RESET}"
}

# ==============================================================================
# Main Entry Point
# ==============================================================================

main() {
    local cmd="${1:-help}"
    shift || true

    # Ensure config/state directories exist
    ensure_dirs

    case "$cmd" in
        status)       cmd_status "$@" ;;
        pause)        cmd_pause "$@" ;;
        resume)       cmd_resume "$@" ;;
        schedule)     cmd_schedule "$@" ;;
        bandwidth)    cmd_bandwidth "$@" ;;
        gaming-mode)  cmd_gaming_mode "$@" ;;
        settings)     cmd_settings "$@" ;;
        help|--help|-h)  cmd_help ;;
        version|--version|-v)
            echo "$APP_NAME v$VERSION"
            ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
