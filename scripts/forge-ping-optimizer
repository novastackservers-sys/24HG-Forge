#!/bin/bash
# 24HG Forge Ping Optimizer — Find the fastest servers and optimize your network for gaming
set -euo pipefail

# ── Paths ──
SERVERS_JSON="/usr/share/forge/servers.json"
SERVERS_API="https://hub.24hgaming.com/api/servers/list"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge"
CONFIG_FILE="$CONFIG_DIR/ping-optimizer.conf"
SYSCTL_CONF="/etc/sysctl.d/99-forge-network-gaming.conf"
BACKUP_DIR="$CONFIG_DIR/ping-optimizer-backup"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/forge"
LOG_TAG="forge-ping"

# ── Defaults ──
FAVORITE_SERVERS=""
MONITOR_SERVER=""
AUTO_OPTIMIZE="no"

# ── Colors ──
RED='\033[1;31m'
ORANGE='\033[1;33m'
YELLOW='\033[0;33m'
GREEN='\033[1;32m'
CYAN='\033[1;36m'
BLUE='\033[1;34m'
MAGENTA='\033[1;35m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Unicode blocks for bar graph ──
BLOCK_FULL='█'
BLOCK_7='▉'
BLOCK_6='▊'
BLOCK_5='▋'
BLOCK_4='▌'
BLOCK_3='▍'
BLOCK_2='▎'
BLOCK_1='▏'

# ── Init ──
mkdir -p "$CONFIG_DIR" "$CACHE_DIR"

log() {
    logger -t "$LOG_TAG" "$*" 2>/dev/null || true
}

# Load config
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

save_config() {
    cat > "$CONFIG_FILE" <<EOF
FAVORITE_SERVERS=$FAVORITE_SERVERS
MONITOR_SERVER=$MONITOR_SERVER
AUTO_OPTIMIZE=$AUTO_OPTIMIZE
EOF
}

# Ensure config exists
if [[ ! -f "$CONFIG_FILE" ]]; then
    save_config
fi
load_config

# ── Server List ──
get_servers() {
    local filter="${1:-}"
    local json=""

    if [[ -f "$SERVERS_JSON" ]]; then
        json=$(cat "$SERVERS_JSON")
    elif command -v curl &>/dev/null; then
        echo -e "${DIM}Fetching server list from hub...${RESET}" >&2
        json=$(curl -sf --connect-timeout 5 "$SERVERS_API" 2>/dev/null || echo "")
        if [[ -n "$json" ]]; then
            mkdir -p "$CACHE_DIR"
            echo "$json" > "$CACHE_DIR/servers.json"
        fi
    fi

    # Fall back to cached copy
    if [[ -z "$json" ]] && [[ -f "$CACHE_DIR/servers.json" ]]; then
        json=$(cat "$CACHE_DIR/servers.json")
    fi

    # Fall back to built-in server list
    if [[ -z "$json" ]] || ! echo "$json" | jq empty 2>/dev/null; then
        json=$(builtin_servers)
    fi

    if [[ -n "$filter" ]]; then
        echo "$json" | jq -r --arg g "$filter" \
            '.[] | select(.game | ascii_downcase | contains($g | ascii_downcase))' 2>/dev/null | jq -s '.'
    else
        echo "$json"
    fi
}

