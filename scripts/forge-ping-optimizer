# ── Ping Helpers ──

# Ping a single IP, output: avg min max loss
ping_host() {
    local ip="$1"
    local count="${2:-3}"
    local timeout="${3:-2}"
    local result

    result=$(ping -c "$count" -W "$timeout" -q "$ip" 2>/dev/null) || {
        echo "timeout 0 0 100"
        return
    }

    local stats
    stats=$(echo "$result" | tail -1)
    local loss
    loss=$(echo "$result" | grep -oP '\d+(?=% packet loss)' || echo "100")

    if [[ "$loss" == "100" ]]; then
        echo "timeout 0 0 100"
        return
    fi

    # rtt min/avg/max/mdev = 12.345/13.456/14.567/0.123 ms
    local avg min max
    avg=$(echo "$stats" | grep -oP '[\d.]+/\K[\d.]+(?=/)' | head -1 || echo "0")
    min=$(echo "$stats" | grep -oP '= \K[\d.]+' || echo "0")
    max=$(echo "$stats" | grep -oP '[\d.]+/[\d.]+/\K[\d.]+' || echo "0")

    echo "$avg $min $max $loss"
}

# Color for ping value
ping_color() {
    local ms="${1%.*}"
    ms="${ms:-999}"
    if [[ "$ms" -lt 30 ]]; then
        echo -n "$GREEN"
    elif [[ "$ms" -lt 60 ]]; then
        echo -n "$YELLOW"
    elif [[ "$ms" -lt 100 ]]; then
        echo -n "$ORANGE"
    else
        echo -n "$RED"
    fi
}

# Format ping value with color
fmt_ping() {
    local val="$1"
    if [[ "$val" == "timeout" ]]; then
        echo -e "${RED}TIMEOUT${RESET}"
        return
    fi
    local color
    color=$(ping_color "$val")
    printf "${color}%7s ms${RESET}" "$val"
}

# Calculate jitter from min/max
calc_jitter() {
    local min="$1" max="$2"
    if [[ "$min" == "0" ]] || [[ "$max" == "0" ]]; then
        echo "N/A"
        return
    fi
    awk "BEGIN { printf \"%.1f\", ($max - $min) }" 2>/dev/null || echo "N/A"
}

# ── Test Command ──
cmd_test() {
    local filter="${1:-}"
    local servers

    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║           24HG Forge Ping Optimizer — Test              ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"

    if [[ -n "$filter" ]]; then
        echo -e "  ${DIM}Testing ${WHITE}${filter}${DIM} servers...${RESET}\n"
    else
        echo -e "  ${DIM}Testing all 24HG servers...${RESET}\n"
    fi

    servers=$(get_servers "$filter")
    local count
    count=$(echo "$servers" | jq 'length' 2>/dev/null || echo 0)

    if [[ "$count" -eq 0 ]]; then
        echo -e "  ${RED}No servers found${filter:+ for game '$filter'}.${RESET}"
        echo -e "  ${DIM}Available games: cs2, rust, tf2, css, cs16, fivem${RESET}"
        return 1
    fi

    log "Testing $count servers${filter:+ (filter: $filter)}"

    # Collect unique IPs to avoid duplicate pings
    local -A ip_results
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    # Extract unique IPs
    local ips
    ips=$(echo "$servers" | jq -r '.[].ip' 2>/dev/null | sort -u)

    echo -e "  ${DIM}Pinging ${count} servers...${RESET}\n"

    # Ping all unique IPs in parallel
    local pids=()
    for ip in $ips; do
        (
            result=$(ping_host "$ip" 5 2)
            echo "$result" > "$tmpdir/$ip"
        ) &
        pids+=($!)
    done

    # Wait for all pings
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Print table header
    printf "  ${BOLD}${WHITE}%-6s │ %-35s │ %-18s │ %9s │ %8s │ %s${RESET}\n" \
        "Game" "Server Name" "Address" "Ping" "Jitter" "Status"
    printf "  ${DIM}──────┼─────────────────────────────────────┼────────────────────┼───────────┼──────────┼────────${RESET}\n"

    # Build results array for sorting
    local -a result_lines=()
    local i=0
    while [[ $i -lt $count ]]; do
        local name game ip port
        name=$(echo "$servers" | jq -r ".[$i].name" 2>/dev/null)
        game=$(echo "$servers" | jq -r ".[$i].game" 2>/dev/null)
        ip=$(echo "$servers" | jq -r ".[$i].ip" 2>/dev/null)
        port=$(echo "$servers" | jq -r ".[$i].port // \"\"" 2>/dev/null)

        local ping_data avg min max loss
        if [[ -f "$tmpdir/$ip" ]]; then
            read -r avg min max loss < "$tmpdir/$ip"
        else
            avg="timeout" min="0" max="0" loss="100"
        fi

        local jitter status addr
        jitter=$(calc_jitter "$min" "$max")
        addr="$ip${port:+:$port}"

        if [[ "$avg" == "timeout" ]]; then
            status="${RED}DOWN${RESET}"
            avg_sort="9999"
        else
            status="${GREEN}  OK${RESET}"
            avg_sort="$avg"
        fi

        # Truncate name if too long
        if [[ ${#name} -gt 35 ]]; then
            name="${name:0:32}..."
        fi

        # Store with sort key
        result_lines+=("$avg_sort|$game|$name|$addr|$avg|$jitter|$status")
        ((i++))
    done

    # Sort by ping (numeric)
    IFS=$'\n' sorted=($(printf '%s\n' "${result_lines[@]}" | sort -t'|' -k1 -n))
    unset IFS

    for line in "${sorted[@]}"; do
        IFS='|' read -r _sort game name addr avg jitter status <<< "$line"
        local ping_display
        ping_display=$(fmt_ping "$avg")
        local jitter_display
        if [[ "$jitter" == "N/A" ]]; then
            jitter_display="${DIM}   N/A${RESET}"
        else
            local jcolor
            jcolor=$(ping_color "$jitter")
            jitter_display="${jcolor}$(printf '%5s ms' "$jitter")${RESET}"
        fi

        printf "  ${CYAN}%-6s${RESET} │ %-35s │ ${DIM}%-18s${RESET} │ %b │ %b │ %b\n" \
            "$game" "$name" "$addr" "$ping_display" "$jitter_display" "$status"
    done

    echo ""
    log "Ping test complete: $count servers tested"

    # Summary
    local ok_count=0 down_count=0 best_ping="9999" best_name=""
    for line in "${sorted[@]}"; do
        IFS='|' read -r _sort game name addr avg jitter status <<< "$line"
        if [[ "$avg" != "timeout" ]]; then
            ((ok_count++))
            if awk "BEGIN { exit !($avg < $best_ping) }"; then
                best_ping="$avg"
                best_name="$name"
            fi
        else
            ((down_count++))
        fi
    done

    echo -e "  ${BOLD}Summary:${RESET} ${GREEN}${ok_count} online${RESET}, ${RED}${down_count} unreachable${RESET}"
    if [[ "$best_name" != "" ]]; then
        echo -e "  ${BOLD}Fastest:${RESET} ${GREEN}${best_name}${RESET} — $(fmt_ping "$best_ping")"
    fi
    echo ""

    rm -rf "$tmpdir"
    trap - EXIT
}

# ── Optimize Command ──
cmd_optimize() {
    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║        24HG Forge Ping Optimizer — Optimize             ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"

    if [[ $EUID -ne 0 ]] && ! sudo -n true 2>/dev/null; then
        echo -e "  ${YELLOW}This command requires sudo to apply network optimizations.${RESET}\n"
    fi

    # Backup current settings
    echo -e "  ${BLUE}[1/6]${RESET} Backing up current network settings..."
    mkdir -p "$BACKUP_DIR"
    local backup_file="$BACKUP_DIR/sysctl-backup-$(date +%Y%m%d-%H%M%S).conf"

    {
        echo "# Forge Ping Optimizer backup — $(date)"
        for key in \
            net.core.default_qdisc \
            net.ipv4.tcp_congestion_control \
            net.ipv4.tcp_slow_start_after_idle \
            net.core.rmem_max \
            net.core.wmem_max \
            net.core.rmem_default \
            net.core.wmem_default \
            net.ipv4.tcp_timestamps \
            net.ipv4.tcp_keepalive_time \
            net.ipv4.tcp_keepalive_intvl \
            net.ipv4.tcp_keepalive_probes \
            net.ipv4.tcp_fastopen \
            net.ipv4.tcp_mtu_probing \
            net.ipv4.tcp_low_latency; do
            val=$(sysctl -n "$key" 2>/dev/null || echo "N/A")
            echo "$key = $val"
        done
    } > "$backup_file"
    echo -e "  ${GREEN}✓${RESET} Saved to ${DIM}$backup_file${RESET}"
    log "Backup saved to $backup_file"

    # Apply TCP BBR
    echo -e "  ${BLUE}[2/6]${RESET} Enabling TCP BBR congestion control..."
    sudo tee "$SYSCTL_CONF" > /dev/null <<'SYSCTL'
# 24HG Forge Ping Optimizer — Gaming Network Optimizations
# Applied by forge-ping-optimizer optimize
# To revert: forge-ping-optimizer reset

# TCP BBR congestion control (better throughput + lower latency)
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr

# Disable slow start after idle (keeps connections fast)
net.ipv4.tcp_slow_start_after_idle = 0

# Larger socket buffers for high-bandwidth game assets
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.core.rmem_default = 1048576
net.core.wmem_default = 1048576
net.ipv4.tcp_rmem = 4096 1048576 16777216
net.ipv4.tcp_wmem = 4096 1048576 16777216

# Disable TCP timestamps (minor latency reduction)
net.ipv4.tcp_timestamps = 0

# Shorter TCP keepalive (detect dead connections faster)
net.ipv4.tcp_keepalive_time = 60
net.ipv4.tcp_keepalive_intvl = 10
net.ipv4.tcp_keepalive_probes = 6

# TCP Fast Open (fewer round trips on reconnect)
net.ipv4.tcp_fastopen = 3

# Enable MTU probing (avoids fragmentation)
net.ipv4.tcp_mtu_probing = 1

# Low-latency mode
net.ipv4.tcp_low_latency = 1
SYSCTL
    echo -e "  ${GREEN}✓${RESET} Wrote ${DIM}$SYSCTL_CONF${RESET}"

    # Apply sysctls
    echo -e "  ${BLUE}[3/6]${RESET} Applying sysctl settings..."
    sudo sysctl --system > /dev/null 2>&1
    echo -e "  ${GREEN}✓${RESET} All sysctl values applied"

    # Check IPv6 latency vs IPv4
    echo -e "  ${BLUE}[4/6]${RESET} Comparing IPv4 vs IPv6 latency..."
    local ipv4_ping=999 ipv6_ping=999
    local test_host="steamcommunity.com"

    # Get IPv4 ping
    local v4_result
    v4_result=$(ping -4 -c 3 -W 2 -q "$test_host" 2>/dev/null) && {
        ipv4_ping=$(echo "$v4_result" | tail -1 | grep -oP '[\d.]+/\K[\d.]+(?=/)' | head -1 || echo "999")
    }

    # Get IPv6 ping
    local v6_result
    v6_result=$(ping -6 -c 3 -W 2 -q "$test_host" 2>/dev/null) && {
        ipv6_ping=$(echo "$v6_result" | tail -1 | grep -oP '[\d.]+/\K[\d.]+(?=/)' | head -1 || echo "999")
    }

    if [[ "$ipv6_ping" != "999" ]] && [[ "$ipv4_ping" != "999" ]]; then
        if awk "BEGIN { exit !($ipv6_ping > $ipv4_ping * 1.2) }"; then
            echo -e "  ${YELLOW}⚠${RESET}  IPv6 is ${ORANGE}${ipv6_ping}ms${RESET} vs IPv4 ${GREEN}${ipv4_ping}ms${RESET} — disabling IPv6 for lower latency"
            sudo sysctl -qw net.ipv6.conf.all.disable_ipv6=1 2>/dev/null || true
            sudo sysctl -qw net.ipv6.conf.default.disable_ipv6=1 2>/dev/null || true
            echo "net.ipv6.conf.all.disable_ipv6 = 1" | sudo tee -a "$SYSCTL_CONF" > /dev/null
            echo "net.ipv6.conf.default.disable_ipv6 = 1" | sudo tee -a "$SYSCTL_CONF" > /dev/null
            log "Disabled IPv6 (added ${ipv6_ping}ms vs IPv4 ${ipv4_ping}ms)"
        else
            echo -e "  ${GREEN}✓${RESET} IPv6 latency OK (${ipv6_ping}ms vs IPv4 ${ipv4_ping}ms) — keeping enabled"
        fi
    elif [[ "$ipv6_ping" == "999" ]]; then
        echo -e "  ${DIM}  IPv6 not available — skipped${RESET}"
    else
        echo -e "  ${DIM}  Could not compare — skipped${RESET}"
    fi

    # Find optimal MTU
    echo -e "  ${BLUE}[5/6]${RESET} Discovering optimal MTU..."
    local optimal_mtu
    optimal_mtu=$(find_optimal_mtu "91.99.37.118")
    if [[ -n "$optimal_mtu" ]] && [[ "$optimal_mtu" != "0" ]]; then
        echo -e "  ${GREEN}✓${RESET} Optimal MTU: ${WHITE}${optimal_mtu}${RESET}"
        local iface
        iface=$(ip route show default 2>/dev/null | awk '/default/{print $5; exit}')
        if [[ -n "$iface" ]]; then
            sudo ip link set dev "$iface" mtu "$optimal_mtu" 2>/dev/null || true
            echo -e "  ${GREEN}✓${RESET} Set MTU ${WHITE}${optimal_mtu}${RESET} on ${DIM}${iface}${RESET}"
        fi
    else
        echo -e "  ${DIM}  MTU discovery failed — keeping default${RESET}"
    fi

    # Done
    echo -e "  ${BLUE}[6/6]${RESET} Verifying optimizations..."
    local cc
    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo "unknown")
    local qdisc
    qdisc=$(sysctl -n net.core.default_qdisc 2>/dev/null || echo "unknown")
    echo -e "  ${GREEN}✓${RESET} Congestion control: ${WHITE}${cc}${RESET}"
    echo -e "  ${GREEN}✓${RESET} Queue discipline: ${WHITE}${qdisc}${RESET}"

    echo ""
    echo -e "  ${GREEN}${BOLD}Optimization complete!${RESET}"
    echo -e "  ${DIM}Changes persist across reboots via $SYSCTL_CONF${RESET}"
    echo -e "  ${DIM}Run 'forge-ping-optimizer reset' to revert all changes.${RESET}"
    echo ""

    log "Network optimizations applied"
}

# ── Monitor Command ──
cmd_monitor() {
    local target="${1:-}"

    # If no target, pick the first server or use MONITOR_SERVER from config
    if [[ -z "$target" ]] && [[ -n "$MONITOR_SERVER" ]]; then
        target="$MONITOR_SERVER"
    fi

    if [[ -z "$target" ]]; then
        # Pick first server IP from list
        local servers
        servers=$(get_servers "")
        target=$(echo "$servers" | jq -r '.[0].ip // empty' 2>/dev/null || echo "")
        if [[ -z "$target" ]]; then
            target="91.99.37.118"
        fi
    fi

    local server_name="$target"
    # Try to resolve name from server list
    local servers
    servers=$(get_servers "")
    local resolved
    resolved=$(echo "$servers" | jq -r --arg ip "$target" '.[] | select(.ip == $ip) | .name' 2>/dev/null | head -1)
    if [[ -n "$resolved" ]]; then
        server_name="$resolved"
    fi

    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║         24HG Forge Ping Optimizer — Monitor             ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"
    echo -e "  ${DIM}Monitoring:${RESET} ${WHITE}${server_name}${RESET} ${DIM}(${target})${RESET}"
    echo -e "  ${DIM}Press Ctrl+C to stop${RESET}\n"

    log "Starting monitor for $target"

    local -a history=()
    local max_width=50
    local max_ping=0

    trap "tput cnorm; echo; echo -e '  ${DIM}Monitor stopped.${RESET}'; exit 0" INT TERM

    tput civis  # Hide cursor

    while true; do
        local result avg min max loss
        read -r avg min max loss <<< "$(ping_host "$target" 1 2)"

        local timestamp
        timestamp=$(date +%H:%M:%S)

        if [[ "$avg" == "timeout" ]]; then
            history+=("timeout")
        else
            history+=("$avg")
            local int_avg="${avg%.*}"
            int_avg="${int_avg:-0}"
            if [[ "$int_avg" -gt "$max_ping" ]]; then
                max_ping="$int_avg"
            fi
        fi

        # Keep only last max_width entries
        if [[ ${#history[@]} -gt $max_width ]]; then
            history=("${history[@]:1}")
        fi

        # Set scale for bar graph
        local scale=$max_ping
        if [[ "$scale" -lt 30 ]]; then scale=30; fi
        if [[ "$scale" -lt 1 ]]; then scale=100; fi

        # Move cursor up to redraw (after first iteration)
        local lines_to_clear=$((${#history[@]} > 10 ? 10 : ${#history[@]}))
        # Actually, let's do a compact single-line bar + stats

        # Clear previous output (3 lines: bar + stats + blank)
        if [[ ${#history[@]} -gt 1 ]]; then
            tput cuu 3 2>/dev/null || true
            tput el 2>/dev/null || true
        fi

        # Draw bar graph (horizontal, last 50 samples)
        printf "  "
        for val in "${history[@]}"; do
            if [[ "$val" == "timeout" ]]; then
                printf "${RED}╳${RESET}"
            else
                local int_val="${val%.*}"
                int_val="${int_val:-0}"
                local color
                color=$(ping_color "$val")
                # Map value to block character height (8 levels)
                local bar_height
                bar_height=$((int_val * 8 / scale))
                if [[ "$bar_height" -lt 1 ]]; then bar_height=1; fi
                if [[ "$bar_height" -ge 8 ]]; then
                    printf "${color}${BLOCK_FULL}${RESET}"
                elif [[ "$bar_height" -ge 7 ]]; then
                    printf "${color}${BLOCK_7}${RESET}"
                elif [[ "$bar_height" -ge 6 ]]; then
                    printf "${color}${BLOCK_6}${RESET}"
                elif [[ "$bar_height" -ge 5 ]]; then
                    printf "${color}${BLOCK_5}${RESET}"
                elif [[ "$bar_height" -ge 4 ]]; then
                    printf "${color}${BLOCK_4}${RESET}"
                elif [[ "$bar_height" -ge 3 ]]; then
                    printf "${color}${BLOCK_3}${RESET}"
                elif [[ "$bar_height" -ge 2 ]]; then
                    printf "${color}${BLOCK_2}${RESET}"
                else
                    printf "${color}${BLOCK_1}${RESET}"
                fi
            fi
        done
        echo ""

        # Stats line
        if [[ "$avg" == "timeout" ]]; then
            printf "  ${RED}TIMEOUT${RESET}  ${DIM}%s${RESET}  ${DIM}loss: %s%%${RESET}\n" "$timestamp" "$loss"
        else
            local jitter
            jitter=$(calc_jitter "$min" "$max")
            printf "  $(fmt_ping "$avg")  ${DIM}%s${RESET}  ${DIM}min:${RESET}%s  ${DIM}max:${RESET}%s  ${DIM}jitter:${RESET}%s  ${DIM}loss:${RESET}%s%%\n" \
                "$timestamp" "$min" "$max" "$jitter" "$loss"
        fi
        echo ""

        sleep 2
    done
}

# ── DNS Command ──
cmd_dns() {
    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║          24HG Forge Ping Optimizer — DNS Test           ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"

    if ! command -v dig &>/dev/null; then
        echo -e "  ${RED}Error:${RESET} 'dig' not found. Install bind-utils or dnsutils."
        return 1
    fi

    local -a dns_servers=("1.1.1.1" "8.8.8.8" "9.9.9.9" "208.67.222.222")
    local -a dns_names=("Cloudflare" "Google" "Quad9" "OpenDNS")
    local -a test_domains=("steamcommunity.com" "epicgames.com" "rust.facepunch.com" "valve.net" "cdn.cloudflare.steamstatic.com")

    echo -e "  ${DIM}Testing DNS servers against gaming domains...${RESET}\n"

    # Header
    printf "  ${BOLD}${WHITE}%-14s" "Domain"
    for name in "${dns_names[@]}"; do
        printf " │ %12s" "$name"
    done
    echo -e "${RESET}"

    printf "  ${DIM}──────────────"
    for _ in "${dns_names[@]}"; do
        printf "─┼─────────────"
    done
    echo -e "${RESET}"

    local -a totals=()
    for i in "${!dns_servers[@]}"; do
        totals[$i]=0
    done

    for domain in "${test_domains[@]}"; do
        local display_domain="$domain"
        if [[ ${#display_domain} -gt 13 ]]; then
            display_domain="${display_domain:0:10}..."
        fi
        printf "  %-14s" "$display_domain"

        for i in "${!dns_servers[@]}"; do
            local dns="${dns_servers[$i]}"
            local time_ms

            # Time the DNS query
            local start end
            start=$(date +%s%N)
            dig "@$dns" "$domain" +short +time=2 +tries=1 > /dev/null 2>&1
            end=$(date +%s%N)

            time_ms=$(( (end - start) / 1000000 ))

            local color
            color=$(ping_color "$time_ms")
            printf " │ ${color}%9s ms${RESET}" "$time_ms"

            totals[$i]=$(( ${totals[$i]} + time_ms ))
        done
        echo ""
    done

    # Average row
    local num_domains=${#test_domains[@]}
    printf "\n  ${BOLD}%-14s" "Average"
    local best_avg=99999 best_idx=0
    for i in "${!dns_servers[@]}"; do
        local avg_ms=$(( ${totals[$i]} / num_domains ))
        if [[ $avg_ms -lt $best_avg ]]; then
            best_avg=$avg_ms
            best_idx=$i
        fi
        local color
        color=$(ping_color "$avg_ms")
        printf " │ ${color}%9s ms${RESET}" "$avg_ms"
    done
    echo -e "${RESET}"

    echo ""
    echo -e "  ${GREEN}${BOLD}Recommended:${RESET} ${WHITE}${dns_names[$best_idx]}${RESET} (${dns_servers[$best_idx]}) — average ${GREEN}${best_avg}ms${RESET}"
    echo ""
    echo -e "  ${DIM}To apply: sudo resolvectl dns \$(ip route show default | awk '/default/{print \$5}') ${dns_servers[$best_idx]}${RESET}"
    echo ""

    log "DNS test complete — recommended: ${dns_names[$best_idx]} (${dns_servers[$best_idx]})"
}

# ── MTU Discovery ──
find_optimal_mtu() {
    local target="${1:-91.99.37.118}"
    local low=1200 high=1500 optimal=1500

    while [[ $low -le $high ]]; do
        local mid=$(( (low + high) / 2 ))
        # Subtract 28 bytes for IP + ICMP headers
        local payload=$(( mid - 28 ))

        if ping -M do -c 1 -W 2 -s "$payload" "$target" > /dev/null 2>&1; then
            optimal=$mid
            low=$(( mid + 1 ))
        else
            high=$(( mid - 1 ))
        fi
    done

    echo "$optimal"
}

cmd_mtu() {
    local target="${1:-91.99.37.118}"

    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║        24HG Forge Ping Optimizer — MTU Discovery        ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"

    echo -e "  ${DIM}Finding optimal MTU to ${WHITE}${target}${DIM}...${RESET}\n"

    local low=1200 high=1500 optimal=1500 step=0

    while [[ $low -le $high ]]; do
        local mid=$(( (low + high) / 2 ))
        local payload=$(( mid - 28 ))
        ((step++))

        printf "  ${DIM}[%2d]${RESET} Testing MTU ${WHITE}%d${RESET} (payload %d)... " "$step" "$mid" "$payload"

        if ping -M do -c 1 -W 2 -s "$payload" "$target" > /dev/null 2>&1; then
            echo -e "${GREEN}OK${RESET}"
            optimal=$mid
            low=$(( mid + 1 ))
        else
            echo -e "${RED}Fragmented${RESET}"
            high=$(( mid - 1 ))
        fi
    done

    echo ""
    echo -e "  ${GREEN}${BOLD}Optimal MTU:${RESET} ${WHITE}${optimal}${RESET}"
    echo ""

    local current_iface
    current_iface=$(ip route show default 2>/dev/null | awk '/default/{print $5; exit}')
    if [[ -n "$current_iface" ]]; then
        local current_mtu
        current_mtu=$(ip link show "$current_iface" 2>/dev/null | grep -oP 'mtu \K\d+' || echo "unknown")
        echo -e "  ${DIM}Current MTU on ${current_iface}: ${current_mtu}${RESET}"
        if [[ "$current_mtu" != "$optimal" ]]; then
            echo -e "  ${DIM}Apply with: sudo ip link set dev ${current_iface} mtu ${optimal}${RESET}"
        else
            echo -e "  ${GREEN}✓${RESET} Already using optimal MTU"
        fi
    fi
    echo ""

    log "MTU discovery complete: optimal=$optimal"
}

# ── Status Command ──
cmd_status() {
    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║        24HG Forge Ping Optimizer — Status               ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"

    local iface
    iface=$(ip route show default 2>/dev/null | awk '/default/{print $5; exit}')

    echo -e "  ${BOLD}Interface:${RESET}       ${WHITE}${iface:-unknown}${RESET}"

    if [[ -n "$iface" ]]; then
        local mtu
        mtu=$(ip link show "$iface" 2>/dev/null | grep -oP 'mtu \K\d+' || echo "unknown")
        echo -e "  ${BOLD}MTU:${RESET}             ${WHITE}${mtu}${RESET}"
    fi

    # Sysctl values
    local cc qdisc slowstart rmem wmem timestamps keepalive fastopen mtu_probe lowlat
    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo "unknown")
    qdisc=$(sysctl -n net.core.default_qdisc 2>/dev/null || echo "unknown")
    slowstart=$(sysctl -n net.ipv4.tcp_slow_start_after_idle 2>/dev/null || echo "unknown")
    rmem=$(sysctl -n net.core.rmem_max 2>/dev/null || echo "unknown")
    wmem=$(sysctl -n net.core.wmem_max 2>/dev/null || echo "unknown")
    timestamps=$(sysctl -n net.ipv4.tcp_timestamps 2>/dev/null || echo "unknown")
    keepalive=$(sysctl -n net.ipv4.tcp_keepalive_time 2>/dev/null || echo "unknown")
    fastopen=$(sysctl -n net.ipv4.tcp_fastopen 2>/dev/null || echo "unknown")
    mtu_probe=$(sysctl -n net.ipv4.tcp_mtu_probing 2>/dev/null || echo "unknown")
    lowlat=$(sysctl -n net.ipv4.tcp_low_latency 2>/dev/null || echo "unknown")

    echo ""
    echo -e "  ${BOLD}Network Stack:${RESET}"

    # Show each setting with optimized/default indicator
    show_setting() {
        local label="$1" value="$2" optimal="$3"
        if [[ "$value" == "$optimal" ]]; then
            printf "    ${GREEN}✓${RESET} %-28s ${WHITE}%s${RESET} ${GREEN}(optimized)${RESET}\n" "$label" "$value"
        else
            printf "    ${DIM}○${RESET} %-28s ${WHITE}%s${RESET} ${DIM}(default)${RESET}\n" "$label" "$value"
        fi
    }

    show_setting "Congestion control:" "$cc" "bbr"
    show_setting "Queue discipline:" "$qdisc" "fq"
    show_setting "Slow start after idle:" "$slowstart" "0"
    show_setting "Receive buffer max:" "$rmem" "16777216"
    show_setting "Send buffer max:" "$wmem" "16777216"
    show_setting "TCP timestamps:" "$timestamps" "0"
    show_setting "TCP keepalive time:" "$keepalive" "60"
    show_setting "TCP Fast Open:" "$fastopen" "3"
    show_setting "MTU probing:" "$mtu_probe" "1"
    show_setting "Low latency:" "$lowlat" "1"

    echo ""

    # Check if our sysctl conf exists
    if [[ -f "$SYSCTL_CONF" ]]; then
        echo -e "  ${GREEN}✓${RESET} Forge config active: ${DIM}$SYSCTL_CONF${RESET}"
    else
        echo -e "  ${DIM}○ No Forge config found${RESET} — run ${WHITE}forge-ping-optimizer optimize${RESET}"
    fi

    # Check for backup
    if [[ -d "$BACKUP_DIR" ]]; then
        local latest_backup
        latest_backup=$(ls -t "$BACKUP_DIR"/sysctl-backup-*.conf 2>/dev/null | head -1)
        if [[ -n "$latest_backup" ]]; then
            echo -e "  ${GREEN}✓${RESET} Backup available: ${DIM}$latest_backup${RESET}"
        fi
    fi

    # IPv6 status
    local ipv6_disabled
    ipv6_disabled=$(sysctl -n net.ipv6.conf.all.disable_ipv6 2>/dev/null || echo "0")
    if [[ "$ipv6_disabled" == "1" ]]; then
        echo -e "  ${YELLOW}⚠${RESET}  IPv6 disabled (by optimizer)"
    else
        echo -e "  ${DIM}○ IPv6 enabled${RESET}"
    fi

    echo ""
}

# ── Reset Command ──
cmd_reset() {
    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║          24HG Forge Ping Optimizer — Reset              ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"

    if [[ ! -f "$SYSCTL_CONF" ]]; then
        echo -e "  ${DIM}No optimizations found to revert.${RESET}"
        echo ""
        return 0
    fi

    echo -e "  ${YELLOW}Reverting network optimizations...${RESET}\n"

    # Find latest backup
    local latest_backup=""
    if [[ -d "$BACKUP_DIR" ]]; then
        latest_backup=$(ls -t "$BACKUP_DIR"/sysctl-backup-*.conf 2>/dev/null | head -1)
    fi

    # Remove our sysctl conf
    echo -e "  ${BLUE}[1/3]${RESET} Removing ${DIM}$SYSCTL_CONF${RESET}..."
    sudo rm -f "$SYSCTL_CONF"
    echo -e "  ${GREEN}✓${RESET} Removed"

    # Restore backup values
    if [[ -n "$latest_backup" ]] && [[ -f "$latest_backup" ]]; then
        echo -e "  ${BLUE}[2/3]${RESET} Restoring values from backup..."
        while IFS='=' read -r key value; do
            # Skip comments and empty lines
            [[ "$key" =~ ^#.*$ ]] && continue
            [[ -z "$key" ]] && continue
            key=$(echo "$key" | xargs)
            value=$(echo "$value" | xargs)
            [[ "$value" == "N/A" ]] && continue
            sudo sysctl -qw "$key=$value" 2>/dev/null || true
        done < "$latest_backup"
        echo -e "  ${GREEN}✓${RESET} Original settings restored"
    else
        echo -e "  ${BLUE}[2/3]${RESET} No backup found — applying system defaults..."
        sudo sysctl --system > /dev/null 2>&1
        echo -e "  ${GREEN}✓${RESET} System defaults reloaded"
    fi

    # Re-enable IPv6 if we disabled it
    echo -e "  ${BLUE}[3/3]${RESET} Re-enabling IPv6..."
    sudo sysctl -qw net.ipv6.conf.all.disable_ipv6=0 2>/dev/null || true
    sudo sysctl -qw net.ipv6.conf.default.disable_ipv6=0 2>/dev/null || true
    echo -e "  ${GREEN}✓${RESET} IPv6 re-enabled"

    echo ""
    echo -e "  ${GREEN}${BOLD}All optimizations reverted.${RESET}"
    echo ""

    log "Network optimizations reverted"
}

# ── Usage ──
usage() {
    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════════════╗"
    echo "  ║              24HG Forge Ping Optimizer                  ║"
    echo "  ╚══════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"
    echo -e "  ${BOLD}Usage:${RESET} forge-ping-optimizer ${WHITE}<command>${RESET} [args]"
    echo ""
    echo -e "  ${BOLD}Commands:${RESET}"
    echo -e "    ${WHITE}test${RESET} [game]       Ping all servers (or filter by game: cs2, rust, tf2...)"
    echo -e "    ${WHITE}optimize${RESET}          Apply network optimizations for gaming"
    echo -e "    ${WHITE}monitor${RESET} [ip]      Live ping monitor with colored bars (updates every 2s)"
    echo -e "    ${WHITE}dns${RESET}               Test DNS servers and find the fastest"
    echo -e "    ${WHITE}mtu${RESET} [ip]          Find optimal MTU for your connection"
    echo -e "    ${WHITE}status${RESET}            Show current network optimization status"
    echo -e "    ${WHITE}reset${RESET}             Revert all network changes"
    echo ""
    echo -e "  ${BOLD}Examples:${RESET}"
    echo -e "    ${DIM}forge-ping-optimizer test${RESET}            # Test all servers"
    echo -e "    ${DIM}forge-ping-optimizer test cs2${RESET}        # Test only CS2 servers"
    echo -e "    ${DIM}forge-ping-optimizer monitor${RESET}         # Live ping graph"
    echo -e "    ${DIM}forge-ping-optimizer optimize${RESET}        # Apply all optimizations"
    echo ""
    echo -e "  ${DIM}Config: $CONFIG_FILE${RESET}"
    echo ""
}

# ── Main ──
main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        test)       cmd_test "$@" ;;
        optimize)   cmd_optimize "$@" ;;
        monitor)    cmd_monitor "$@" ;;
        dns)        cmd_dns "$@" ;;
        mtu)        cmd_mtu "$@" ;;
        status)     cmd_status "$@" ;;
        reset)      cmd_reset "$@" ;;
        -h|--help|help|"")
            usage ;;
        *)
            echo -e "${RED}Unknown command: ${cmd}${RESET}" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
