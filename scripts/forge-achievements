#!/usr/bin/env python3
"""
24HG Forge Achievements — OS-level gamification that rewards exploration and engagement.

Tracks milestones, unlocks achievements, awards points, and syncs with the 24HG Hub.
Designed to run periodically via systemd timer and on-demand by the user.

Commands:
  check              Scan system state and unlock earned achievements
  list               Show all achievements with locked/unlocked status
  status             Summary: unlocked count, points, streaks
  unlock <id>        Manually unlock an achievement (for Hub-triggered unlocks)
  reset              Reset all achievement progress (with confirmation)
  help               Show this help text

Data: ~/.local/share/forge/achievements.json
"""

import json
import os
import sys
import time
import glob
import subprocess
import urllib.request
import urllib.error
from datetime import datetime, date, timedelta
from pathlib import Path

# ── Configuration ──

DATA_DIR = os.path.expanduser("~/.local/share/forge")
DATA_FILE = os.path.join(DATA_DIR, "achievements.json")
GAME_TIMER_FILE = os.path.join(DATA_DIR, "game-timer.json")
BENCHMARK_FILE = os.path.join(DATA_DIR, "benchmark.json")
HUB_TOKEN_FILE = os.path.expanduser("~/.config/forge/hub-token")
HUB_API_URL = "https://api.24hgaming.com/activity/achievements"

# ── Colors ──

class C:
    BOLD   = "\033[1m"
    DIM    = "\033[2m"
    RED    = "\033[31m"
    GREEN  = "\033[32m"
    YELLOW = "\033[33m"
    BLUE   = "\033[34m"
    MAGENTA= "\033[35m"
    CYAN   = "\033[36m"
    WHITE  = "\033[37m"
    GOLD   = "\033[38;5;220m"
    ORANGE = "\033[38;5;208m"
    RESET  = "\033[0m"

    @staticmethod
    def strip():
        """Disable colors when not a TTY."""
        if not sys.stdout.isatty():
            for attr in ("BOLD", "DIM", "RED", "GREEN", "YELLOW", "BLUE",
                         "MAGENTA", "CYAN", "WHITE", "GOLD", "ORANGE", "RESET"):
                setattr(C, attr, "")


# ── Achievement Definitions ──

