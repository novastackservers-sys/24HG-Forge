#!/usr/bin/env bash
set -euo pipefail
# 24HG Mirror Manager — Community mirror selection and management

###############################################################################
# Constants & Paths
###############################################################################
readonly VERSION="1.0.0"
readonly APP_NAME="24hg-mirror"
readonly CONFIG_DIR="${HOME}/.config/24hg"
readonly MIRROR_CONF="${CONFIG_DIR}/mirror.conf"
readonly CACHE_DIR="${HOME}/.cache/24hg/mirrors"
readonly CACHE_TTL=3600  # 1 hour cache lifetime
readonly API_BASE="https://os.24hgaming.com/api"
readonly MIRROR_LIST_URL="${API_BASE}/mirrors"
readonly TEST_FILE_PATH="/test/1mb.bin"
readonly TEST_FILE_SIZE=1048576  # 1MB
readonly LATENCY_TIMEOUT=5
readonly DOWNLOAD_TIMEOUT=30
readonly MAX_MIRRORS=50

###############################################################################
# Colors & Formatting
###############################################################################
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    MAGENTA='\033[0;35m'
    BOLD='\033[1m'
    DIM='\033[2m'
    RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA='' BOLD='' DIM='' RESET=''
fi

###############################################################################
# Helpers
###############################################################################

log_info()    { echo -e "${BLUE}[INFO]${RESET} $*"; }
log_ok()      { echo -e "${GREEN}[OK]${RESET} $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${RESET} $*"; }
log_err()     { echo -e "${RED}[ERROR]${RESET} $*" >&2; }
log_header()  { echo -e "\n${BOLD}${CYAN}$*${RESET}"; }
log_dim()     { echo -e "${DIM}$*${RESET}"; }

die() { log_err "$@"; exit 1; }

ensure_dirs() {
    mkdir -p "$CONFIG_DIR" "$CACHE_DIR"
}

spinner() {
    local pid=$1 msg=$2
    local frames=('.' '..' '...' '....')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${DIM}%s%s${RESET}" "$msg" "${frames[$((i % 4))]}"
        sleep 0.3
        ((i++))
    done
    printf "\r\033[K"
}

human_bytes() {
    local bytes=$1
    if (( bytes >= 1073741824 )); then
        printf "%.1f GB" "$(echo "scale=1; $bytes/1073741824" | bc)"
    elif (( bytes >= 1048576 )); then
        printf "%.1f MB" "$(echo "scale=1; $bytes/1048576" | bc)"
    elif (( bytes >= 1024 )); then
        printf "%.1f KB" "$(echo "scale=1; $bytes/1024" | bc)"
    else
        printf "%d B" "$bytes"
    fi
}

human_speed() {
    local bps=$1
    if (( bps >= 1048576 )); then
        printf "%.1f MB/s" "$(echo "scale=1; $bps/1048576" | bc)"
    elif (( bps >= 1024 )); then
        printf "%.1f KB/s" "$(echo "scale=1; $bps/1024" | bc)"
    else
        printf "%d B/s" "$bps"
    fi
}

bar_graph() {
    local value=$1 max=$2 width=${3:-20}
    local filled=$(( value * width / max ))
    (( filled > width )) && filled=$width
    (( filled < 0 )) && filled=0
    local empty=$(( width - filled ))
    local color="$GREEN"
    if (( value * 100 / max < 33 )); then
        color="$RED"
    elif (( value * 100 / max < 66 )); then
        color="$YELLOW"
    fi
    printf "${color}"
    printf '%0.s█' $(seq 1 "$filled" 2>/dev/null) || true
    printf "${DIM}"
    printf '%0.s░' $(seq 1 "$empty" 2>/dev/null) || true
    printf "${RESET}"
}

country_flag() {
    local code="${1^^}"
    if [[ ${#code} -eq 2 ]]; then
        local c1=$(( $(printf '%d' "'${code:0:1}") - 65 + 127462 ))
        local c2=$(( $(printf '%d' "'${code:1:1}") - 65 + 127462 ))
        printf "\\U$(printf '%x' "$c1")\\U$(printf '%x' "$c2")"
    else
        printf "  "
    fi
}

###############################################################################
# Mirror List Fetching & Caching
###############################################################################

cache_file() {
    echo "${CACHE_DIR}/mirrors.json"
}

cache_is_valid() {
    local cf
    cf="$(cache_file)"
    [[ -f "$cf" ]] || return 1
    local mtime now age
    mtime=$(stat -c %Y "$cf" 2>/dev/null || echo 0)
    now=$(date +%s)
    age=$(( now - mtime ))
    (( age < CACHE_TTL ))
}

fetch_mirror_list() {
    local force="${1:-false}"
    local cf
    cf="$(cache_file)"

    if [[ "$force" != "true" ]] && cache_is_valid; then
        cat "$cf"
        return 0
    fi

    log_dim "  Fetching mirror list from API..."
    local tmpfile
    tmpfile=$(mktemp)

    if ! curl -fsSL --connect-timeout 10 --max-time 20 \
         -H "Accept: application/json" \
         "$MIRROR_LIST_URL" -o "$tmpfile" 2>/dev/null; then

        rm -f "$tmpfile"
        if [[ -f "$cf" ]]; then
            log_warn "API unreachable, using cached mirror list"
            cat "$cf"
            return 0
        fi
        die "Cannot fetch mirror list and no cache available"
    fi

    # Validate JSON
    if ! command -v jq &>/dev/null; then
        # If jq not available, trust the response
        mv "$tmpfile" "$cf"
        cat "$cf"
        return 0
    fi

    if ! jq empty "$tmpfile" 2>/dev/null; then
        rm -f "$tmpfile"
        if [[ -f "$cf" ]]; then
            log_warn "Invalid API response, using cached mirror list"
            cat "$cf"
            return 0
        fi
        die "Invalid mirror list response and no cache available"
    fi

    mv "$tmpfile" "$cf"
    cat "$cf"
}

parse_mirrors() {
    local json="$1"
    if command -v jq &>/dev/null; then
        echo "$json" | jq -r '.mirrors[] | "\(.url)|\(.name)|\(.country)|\(.sponsor)|\(.status)"'
    else
        # Fallback: basic grep/sed parsing
        echo "$json" | grep -oP '"url"\s*:\s*"[^"]*"' | sed 's/.*"url"\s*:\s*"\([^"]*\)"/\1/'
    fi
}

get_mirror_count() {
    local json="$1"
    if command -v jq &>/dev/null; then
        echo "$json" | jq '.mirrors | length'
    else
        echo "$json" | grep -c '"url"' || echo "0"
    fi
}

###############################################################################
# Mirror Testing
###############################################################################

test_latency() {
    local url="$1"
    local start end elapsed
    start=$(date +%s%N)
    if curl -fsSL --head --connect-timeout "$LATENCY_TIMEOUT" \
         --max-time "$LATENCY_TIMEOUT" "$url" &>/dev/null; then
        end=$(date +%s%N)
        elapsed=$(( (end - start) / 1000000 ))
        echo "$elapsed"
    else
        echo "-1"
    fi
}

test_throughput() {
    local url="$1"
    local test_url="${url%/}${TEST_FILE_PATH}"
    local tmpfile
    tmpfile=$(mktemp)

    local start end elapsed bytes_received speed
    start=$(date +%s%N)
    if curl -fsSL --connect-timeout 5 --max-time "$DOWNLOAD_TIMEOUT" \
         "$test_url" -o "$tmpfile" 2>/dev/null; then
        end=$(date +%s%N)
        elapsed=$(( (end - start) / 1000000 ))
        bytes_received=$(stat -c %s "$tmpfile" 2>/dev/null || echo 0)
        rm -f "$tmpfile"

        if (( elapsed > 0 && bytes_received > 0 )); then
            speed=$(( bytes_received * 1000 / elapsed ))
            echo "$speed"
        else
            echo "-1"
        fi
    else
        rm -f "$tmpfile"
        echo "-1"
    fi
}

test_single_mirror() {
    local url="$1" name="$2" country="$3" do_throughput="${4:-false}"

    local flag
    flag=$(country_flag "$country")

    printf "  Testing ${flag} %-30s " "$name"

    # Latency test
    local latency
    latency=$(test_latency "$url")

    if (( latency < 0 )); then
        echo -e "${RED}OFFLINE${RESET}"
        echo "$url|$name|$country|-1|-1" >> "${CACHE_DIR}/test_results.tmp"
        return 1
    fi

    printf "${GREEN}%4dms${RESET} " "$latency"

    # Throughput test
    if [[ "$do_throughput" == "true" ]]; then
        local speed
        speed=$(test_throughput "$url")
        if (( speed > 0 )); then
            printf "$(human_speed "$speed") "
            printf " "
            bar_graph "$speed" 52428800 15  # max 50 MB/s
            echo ""
            echo "$url|$name|$country|$latency|$speed" >> "${CACHE_DIR}/test_results.tmp"
        else
            echo -e "${YELLOW}no test file${RESET}"
            echo "$url|$name|$country|$latency|0" >> "${CACHE_DIR}/test_results.tmp"
        fi
    else
        echo ""
        echo "$url|$name|$country|$latency|0" >> "${CACHE_DIR}/test_results.tmp"
    fi

    return 0
}

###############################################################################
# Configuration
###############################################################################

load_config() {
    if [[ -f "$MIRROR_CONF" ]]; then
        # shellcheck source=/dev/null
        source "$MIRROR_CONF"
    fi
}

save_config() {
    local mirror_url="$1"
    local mirror_name="${2:-Custom}"
    local mirror_country="${3:-}"

    mkdir -p "$(dirname "$MIRROR_CONF")"
    cat > "$MIRROR_CONF" <<CONF
# 24HG Mirror Configuration
# Generated by 24hg-mirror on $(date -Iseconds)
# Edit manually or use: 24hg-mirror set <url>

HG24_MIRROR_URL="${mirror_url}"
HG24_MIRROR_NAME="${mirror_name}"
HG24_MIRROR_COUNTRY="${mirror_country}"
HG24_MIRROR_SET_DATE="$(date -Iseconds)"
CONF
    log_ok "Mirror saved to ${MIRROR_CONF}"
}

get_current_mirror() {
    load_config
    echo "${HG24_MIRROR_URL:-https://os.24hgaming.com}"
}

get_current_mirror_name() {
    load_config
    echo "${HG24_MIRROR_NAME:-Official (CDN)}"
}

###############################################################################
# Commands
###############################################################################

cmd_list() {
    log_header "24HG — Available Mirrors"
    echo ""

    local json
    json=$(fetch_mirror_list "${1:-false}")
    local count
    count=$(get_mirror_count "$json")

    log_info "Found ${BOLD}${count}${RESET} mirrors"

    local current
    current=$(get_current_mirror)

    echo ""
    printf "  ${BOLD}%-3s %-32s %-10s %-20s %s${RESET}\n" "" "Mirror" "Country" "Sponsor" "Status"
    echo "  $(printf '%0.s─' {1..90})"

    if command -v jq &>/dev/null; then
        echo "$json" | jq -r '.mirrors[] | "\(.url)|\(.name)|\(.country)|\(.sponsor // "-")|\(.status // "unknown")"' | \
        while IFS='|' read -r url name country sponsor status; do
            local flag
            flag=$(country_flag "$country")
            local marker=" "
            if [[ "$url" == "$current" ]]; then
                marker="${GREEN}*${RESET}"
            fi

            local status_color="$GREEN"
            case "$status" in
                active|online|up)   status_color="$GREEN" ;;
                degraded|slow)      status_color="$YELLOW" ;;
                offline|down|error) status_color="$RED" ;;
                *)                  status_color="$DIM" ;;
            esac

            printf "  %b ${flag} %-30s %-10s %-20s ${status_color}%s${RESET}\n" \
                "$marker" "$name" "$country" "$sponsor" "$status"
        done
    else
        log_warn "Install jq for formatted output"
        echo "$json"
    fi

    echo ""
    log_dim "  * = currently selected mirror"
    log_dim "  Use '24hg-mirror test' for speed testing"
    log_dim "  Use '24hg-mirror set <url>' to change mirror"
}

cmd_test() {
    log_header "24HG — Mirror Speed Test"
    echo ""

    local do_throughput="false"
    if [[ "${1:-}" == "--full" || "${1:-}" == "-f" ]]; then
        do_throughput="true"
        log_info "Full test mode: latency + throughput"
    else
        log_info "Quick test mode: latency only (use --full for throughput)"
    fi

    local json
    json=$(fetch_mirror_list "true")
    echo ""

    # Clear previous results
    rm -f "${CACHE_DIR}/test_results.tmp"
    touch "${CACHE_DIR}/test_results.tmp"

    local online=0 offline=0

    if command -v jq &>/dev/null; then
        while IFS='|' read -r url name country _sponsor _status; do
            if test_single_mirror "$url" "$name" "$country" "$do_throughput"; then
                ((online++))
            else
                ((offline++))
            fi
        done < <(echo "$json" | jq -r '.mirrors[] | "\(.url)|\(.name)|\(.country)|\(.sponsor // "-")|\(.status // "unknown")"')
    else
        die "jq is required for mirror testing"
    fi

    echo ""
    log_info "Results: ${GREEN}${online} online${RESET}, ${RED}${offline} offline${RESET}"

    # Sort and display rankings
    if [[ -s "${CACHE_DIR}/test_results.tmp" ]]; then
        echo ""
        log_header "Rankings (by latency)"
        echo ""
        printf "  ${BOLD}%-4s %-32s %8s" "Rank" "Mirror" "Latency"
        if [[ "$do_throughput" == "true" ]]; then
            printf " %12s" "Speed"
        fi
        echo -e "${RESET}"
        echo "  $(printf '%0.s─' {1..60})"

        local rank=0
        sort -t'|' -k4 -n "${CACHE_DIR}/test_results.tmp" | \
        while IFS='|' read -r url name country latency speed; do
            (( latency < 0 )) && continue
            ((rank++))

            local flag
            flag=$(country_flag "$country")

            local lat_color="$GREEN"
            if (( latency > 500 )); then
                lat_color="$RED"
            elif (( latency > 200 )); then
                lat_color="$YELLOW"
            fi

            printf "  ${BOLD}#%-3d${RESET} ${flag} %-28s ${lat_color}%5dms${RESET}" \
                "$rank" "$name" "$latency"

            if [[ "$do_throughput" == "true" ]] && (( speed > 0 )); then
                printf " %12s" "$(human_speed "$speed")"
            fi
            echo ""
        done

        # Save results for auto command
        cp "${CACHE_DIR}/test_results.tmp" "${CACHE_DIR}/last_test.dat"
    fi
}

cmd_set() {
    local mirror_url="${1:-}"

    if [[ -z "$mirror_url" ]]; then
        die "Usage: 24hg-mirror set <mirror-url>"
    fi

    # Validate URL format
    if [[ ! "$mirror_url" =~ ^https?:// ]]; then
        die "Invalid URL: must start with http:// or https://"
    fi

    # Remove trailing slash
    mirror_url="${mirror_url%/}"

    log_info "Testing mirror connectivity..."
    local latency
    latency=$(test_latency "$mirror_url")

    if (( latency < 0 )); then
        log_warn "Mirror appears to be offline or unreachable"
        read -rp "Set it anyway? [y/N] " confirm
        if [[ "${confirm,,}" != "y" ]]; then
            log_info "Cancelled"
            return 1
        fi
    else
        log_ok "Mirror responded in ${latency}ms"
    fi

    # Try to find mirror name from list
    local name="Custom" country=""
    local json
    if json=$(fetch_mirror_list 2>/dev/null); then
        if command -v jq &>/dev/null; then
            local match
            match=$(echo "$json" | jq -r --arg url "$mirror_url" \
                '.mirrors[] | select(.url == $url) | "\(.name)|\(.country)"' 2>/dev/null || true)
            if [[ -n "$match" ]]; then
                IFS='|' read -r name country <<< "$match"
            fi
        fi
    fi

    save_config "$mirror_url" "$name" "$country"
    log_ok "Mirror set to: ${BOLD}${name}${RESET} (${mirror_url})"
}

cmd_auto() {
    log_header "24HG — Auto-Select Fastest Mirror"
    echo ""

    local results_file="${CACHE_DIR}/last_test.dat"

    # Check for recent test results
    local need_test="true"
    if [[ -f "$results_file" ]]; then
        local mtime now age
        mtime=$(stat -c %Y "$results_file" 2>/dev/null || echo 0)
        now=$(date +%s)
        age=$(( now - mtime ))
        if (( age < 300 )); then  # 5 minutes
            log_info "Using recent test results ($(( age ))s ago)"
            need_test="false"
        fi
    fi

    if [[ "$need_test" == "true" ]]; then
        log_info "Running speed test first..."
        echo ""

        local json
        json=$(fetch_mirror_list "true")

        rm -f "${CACHE_DIR}/test_results.tmp"
        touch "${CACHE_DIR}/test_results.tmp"

        if command -v jq &>/dev/null; then
            while IFS='|' read -r url name country _sponsor _status; do
                test_single_mirror "$url" "$name" "$country" "false" || true
            done < <(echo "$json" | jq -r '.mirrors[] | "\(.url)|\(.name)|\(.country)|\(.sponsor // "-")|\(.status // "unknown")"')
        else
            die "jq is required for auto-selection"
        fi

        cp "${CACHE_DIR}/test_results.tmp" "$results_file"
    fi

    # Find fastest online mirror
    local best_url="" best_name="" best_country="" best_latency=999999

    while IFS='|' read -r url name country latency _speed; do
        (( latency < 0 )) && continue
        if (( latency < best_latency )); then
            best_url="$url"
            best_name="$name"
            best_country="$country"
            best_latency="$latency"
        fi
    done < "$results_file"

    if [[ -z "$best_url" ]]; then
        die "No online mirrors found"
    fi

    echo ""
    local flag
    flag=$(country_flag "$best_country")
    log_ok "Fastest mirror: ${flag} ${BOLD}${best_name}${RESET} (${best_latency}ms)"

    save_config "$best_url" "$best_name" "$best_country"
}

cmd_status() {
    log_header "24HG — Mirror Status"
    echo ""

    load_config

    local current_url="${HG24_MIRROR_URL:-https://os.24hgaming.com}"
    local current_name="${HG24_MIRROR_NAME:-Official (CDN)}"
    local current_country="${HG24_MIRROR_COUNTRY:-}"
    local set_date="${HG24_MIRROR_SET_DATE:-never}"

    local flag=""
    if [[ -n "$current_country" ]]; then
        flag="$(country_flag "$current_country") "
    fi

    echo -e "  ${BOLD}Current Mirror${RESET}"
    echo -e "  Name:     ${flag}${BOLD}${current_name}${RESET}"
    echo -e "  URL:      ${current_url}"
    echo -e "  Set:      ${set_date}"
    echo -e "  Config:   ${MIRROR_CONF}"
    echo ""

    # Test current mirror
    echo -e "  ${BOLD}Health Check${RESET}"
    printf "  Connectivity: "
    local latency
    latency=$(test_latency "$current_url")
    if (( latency < 0 )); then
        echo -e "${RED}OFFLINE${RESET}"
    elif (( latency > 500 )); then
        echo -e "${YELLOW}SLOW (${latency}ms)${RESET}"
    else
        echo -e "${GREEN}OK (${latency}ms)${RESET}"
    fi

    # Check for ISO availability
    printf "  ISO endpoint: "
    local iso_check
    if curl -fsSL --head --connect-timeout 5 --max-time 10 \
         "${current_url}/iso/" &>/dev/null; then
        echo -e "${GREEN}Available${RESET}"
    else
        echo -e "${YELLOW}Not verified${RESET}"
    fi

    # Last test results
    local results_file="${CACHE_DIR}/last_test.dat"
    if [[ -f "$results_file" ]]; then
        local mtime
        mtime=$(stat -c %Y "$results_file" 2>/dev/null || echo 0)
        local age=$(( $(date +%s) - mtime ))
        echo ""
        echo -e "  ${BOLD}Last Speed Test${RESET}"
        echo -e "  Run:      $(date -d "@$mtime" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo 'unknown')"
        echo -e "  Age:      $(( age / 60 )) minutes ago"
        local total online
        total=$(wc -l < "$results_file")
        online=$(awk -F'|' '$4 >= 0' "$results_file" | wc -l)
        echo -e "  Mirrors:  ${online}/${total} online"
    fi

    # Cache info
    local cf
    cf="$(cache_file)"
    if [[ -f "$cf" ]]; then
        echo ""
        echo -e "  ${BOLD}Cache${RESET}"
        echo -e "  File:     ${cf}"
        echo -e "  Age:      $(( ($(date +%s) - $(stat -c %Y "$cf")) / 60 )) minutes"
        if cache_is_valid; then
            echo -e "  Status:   ${GREEN}Valid${RESET}"
        else
            echo -e "  Status:   ${YELLOW}Expired${RESET}"
        fi
    fi
}

cmd_host() {
    log_header "24HG — Host a Community Mirror"
    echo ""
    cat <<'INSTRUCTIONS'
  Thank you for considering hosting a 24HG mirror!

  Requirements:
  ─────────────
  - At least 50 GB of free disk space
  - HTTPS-capable web server (nginx, caddy, apache)
  - Reliable connection with reasonable bandwidth
  - Ability to sync at least every 6 hours

  Setup Steps:
  ────────────

  1. Install rsync (if not already available):
     sudo apt install rsync   # Debian/Ubuntu
     sudo dnf install rsync   # Fedora

  2. Create the mirror directory:
     sudo mkdir -p /var/www/24hg-mirror
     sudo chown $USER:$USER /var/www/24hg-mirror

  3. Initial sync from the official server:
     rsync -avz --progress \
       rsync://mirror.24hgaming.com/24hg/ \
       /var/www/24hg-mirror/

  4. Set up a cron job to sync every 6 hours:
     0 */6 * * * rsync -avz --delete \
       rsync://mirror.24hgaming.com/24hg/ \
       /var/www/24hg-mirror/ \
       >> /var/log/24hg-mirror-sync.log 2>&1

  5. Configure your web server to serve the directory.

     Nginx example:
     ┌─────────────────────────────────────────────────────┐
     │ server {                                            │
     │     listen 443 ssl;                                 │
     │     server_name mirror.example.com;                 │
     │                                                     │
     │     root /var/www/24hg-mirror;                     │
     │     autoindex on;                                   │
     │                                                     │
     │     location /test/ {                               │
     │         # 1MB test file for speed testing           │
     │         alias /var/www/24hg-mirror/test/;          │
     │     }                                               │
     │ }                                                   │
     └─────────────────────────────────────────────────────┘

     Caddy example:
     ┌─────────────────────────────────────────────────────┐
     │ mirror.example.com {                                │
     │     root * /var/www/24hg-mirror                    │
     │     file_server browse                              │
     │ }                                                   │
     └─────────────────────────────────────────────────────┘

  6. Create the test file for speed testing:
     mkdir -p /var/www/24hg-mirror/test
     dd if=/dev/urandom of=/var/www/24hg-mirror/test/1mb.bin \
       bs=1M count=1

  7. Register your mirror with us:
     - Open an issue at https://github.com/24hgaming/24hg-os/issues
     - Or email mirrors@24hgaming.com
     - Or message in #24hg-mirrors on Discord

     Include:
       - Mirror URL (https://mirror.example.com)
       - Country / region
       - Bandwidth capacity
       - Your contact info
       - Sponsor name (optional, shown on mirror list)

  Mirror Health:
  ──────────────
  - Our automated checker pings mirrors every 6 hours
  - Mirrors must respond within 10 seconds
  - ISO checksums are verified against the official release
  - Mirrors that fail 3 consecutive checks are temporarily delisted
  - You will be notified via your registered contact method

  Directory Structure:
  ────────────────────
  /24hg-mirror/
  ├── iso/
  │   ├── 24hg-desktop-v1.0.0.iso
  │   ├── 24hg-nvidia-v1.0.0.iso
  │   ├── SHA256SUMS
  │   └── SHA256SUMS.sig
  ├── test/
  │   └── 1mb.bin
  └── metadata/
      ├── latest.json
      └── releases.json

INSTRUCTIONS
    echo ""
    log_info "Questions? Join us on Discord: ${BOLD}discord.gg/ymfEjH6EJN${RESET}"
}

###############################################################################
# Usage
###############################################################################

usage() {
    cat <<EOF
${BOLD}24HG Mirror Manager${RESET} v${VERSION}

${BOLD}Usage:${RESET}
    24hg-mirror <command> [options]

${BOLD}Commands:${RESET}
    list             Show all available mirrors
    test [--full]    Test all mirrors (--full includes throughput)
    set <url>        Set preferred mirror URL
    auto             Auto-select fastest mirror
    host             Instructions for hosting a community mirror
    status           Show current mirror and health info

${BOLD}Options:${RESET}
    -h, --help       Show this help message
    -v, --version    Show version

${BOLD}Configuration:${RESET}
    Mirror preference: ${MIRROR_CONF}
    Cache directory:   ${CACHE_DIR}

${BOLD}Examples:${RESET}
    24hg-mirror list                          # Show all mirrors
    24hg-mirror test --full                   # Full speed test
    24hg-mirror auto                          # Pick fastest mirror
    24hg-mirror set https://mirror.eu.example # Use specific mirror
    24hg-mirror status                        # Check current setup

${BOLD}How mirrors work:${RESET}
    24hg-update and the download page use your selected mirror to
    fetch ISO images and OCI updates. The official CDN is used by
    default. Community mirrors can be faster depending on your location.

EOF
}

###############################################################################
# Main
###############################################################################

main() {
    ensure_dirs

    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        list)       cmd_list "$@" ;;
        test)       cmd_test "$@" ;;
        set)        cmd_set "$@" ;;
        auto)       cmd_auto "$@" ;;
        host)       cmd_host "$@" ;;
        status)     cmd_status "$@" ;;
        -h|--help)  usage ;;
        -v|--version) echo "24hg-mirror v${VERSION}" ;;
        "")         usage ;;
        *)          die "Unknown command: ${cmd}\nRun '24hg-mirror --help' for usage" ;;
    esac
}

main "$@"
