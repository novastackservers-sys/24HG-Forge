# ─── Color Helpers ───────────────────────────────────────────────────────────

class C:
    """ANSI color codes."""
    RESET   = "\033[0m"
    BOLD    = "\033[1m"
    DIM     = "\033[2m"
    RED     = "\033[91m"
    GREEN   = "\033[92m"
    YELLOW  = "\033[93m"
    BLUE    = "\033[94m"
    MAGENTA = "\033[95m"
    CYAN    = "\033[96m"
    WHITE   = "\033[97m"
    GRAY    = "\033[90m"
    BG_RED    = "\033[41m"
    BG_GREEN  = "\033[42m"
    BG_YELLOW = "\033[43m"
    BG_BLUE   = "\033[44m"

    @staticmethod
    def enabled():
        return sys.stdout.isatty()

def c(text, *codes):
    """Colorize text if stdout is a tty."""
    if not C.enabled():
        return text
    return "".join(codes) + str(text) + C.RESET

def verdict_color(verdict):
    """Return colored verdict string."""
    v = verdict.upper()
    if v == "WORKS":
        return c(f" {v} ", C.BOLD, C.BG_GREEN, C.WHITE)
    elif v == "WORKS WITH TWEAKS":
        return c(f" {v} ", C.BOLD, C.BG_YELLOW, C.WHITE)
    elif v == "PROBLEMATIC":
        return c(f" {v} ", C.BOLD, C.BG_YELLOW, C.RED)
    elif v == "BLOCKED":
        return c(f" {v} ", C.BOLD, C.BG_RED, C.WHITE)
    else:
        return c(f" {v} ", C.BOLD, C.DIM)

def rating_color(rating):
    """Color a ProtonDB rating."""
    r = (rating or "unknown").lower()
    colors = {
        "platinum": C.CYAN,
        "gold": C.YELLOW,
        "silver": C.WHITE,
        "bronze": C.RED,
        "borked": C.RED,
        "native": C.GREEN,
    }
    return c(rating or "Unknown", C.BOLD, colors.get(r, C.DIM))

