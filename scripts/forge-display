#!/bin/bash
# hubos-display — Multi-monitor and display settings manager for HubOS
# Manages gaming/desktop display modes, VRR, HDR, profiles, and per-monitor settings.
# Auto-detects Wayland vs X11 and uses appropriate tools.

set -euo pipefail

PROFILE_DIR="$HOME/.config/hubos/display-profiles"
mkdir -p "$PROFILE_DIR"

# ---------------------------------------------------------------------------
# Session detection
# ---------------------------------------------------------------------------

detect_session() {
    if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        echo "wayland"
    elif [[ "${XDG_SESSION_TYPE:-}" == "x11" ]] || [[ -n "${DISPLAY:-}" ]]; then
        echo "x11"
    else
        echo "unknown"
    fi
}

SESSION_TYPE="$(detect_session)"

# Detect which Wayland tool is available
detect_wayland_tool() {
    if command -v kscreen-doctor &>/dev/null; then
        echo "kscreen-doctor"
    elif command -v wlr-randr &>/dev/null; then
        echo "wlr-randr"
    else
        echo "none"
    fi
}

# ---------------------------------------------------------------------------
# Color helpers
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

info()  { echo -e "${CYAN}[info]${RESET} $*"; }
ok()    { echo -e "${GREEN}[ok]${RESET} $*"; }
warn()  { echo -e "${YELLOW}[warn]${RESET} $*"; }
err()   { echo -e "${RED}[error]${RESET} $*" >&2; }

# ---------------------------------------------------------------------------
# Monitor detection helpers
# ---------------------------------------------------------------------------

# Parse xrandr output into structured monitor info
detect_monitors_x11() {
    local monitors=()
    local current=""
    local connected_re="^([A-Za-z0-9_-]+) connected"
    local mode_re="^[[:space:]]+([0-9]+x[0-9]+)[[:space:]]+(.*)"

    while IFS= read -r line; do
        if [[ "$line" =~ $connected_re ]]; then
            current="${BASH_REMATCH[1]}"
            local conn_type="Unknown"
            if [[ "$current" == DP-* || "$current" == DisplayPort-* ]]; then
                conn_type="DP"
            elif [[ "$current" == HDMI-* ]]; then
                conn_type="HDMI"
            elif [[ "$current" == DVI-* ]]; then
                conn_type="DVI"
            elif [[ "$current" == VGA-* ]]; then
                conn_type="VGA"
            elif [[ "$current" == eDP-* ]]; then
                conn_type="eDP"
            fi

            # Check VRR capability
            local vrr_capable="No"
            if xrandr --prop 2>/dev/null | grep -A 30 "^${current} connected" | grep -qi "vrr_capable.*1\|freesync.*1\|adaptive.sync.*1"; then
                vrr_capable="Yes"
            fi

            # Check HDR capability
            local hdr_capable="No"
            if xrandr --prop 2>/dev/null | grep -A 50 "^${current} connected" | grep -qi "hdr.*supported\|HDR_OUTPUT_METADATA\|Colorspace.*BT2020"; then
                hdr_capable="Yes"
            fi

            monitors+=("${current}|${conn_type}|${vrr_capable}|${hdr_capable}")
        fi
    done < <(xrandr 2>/dev/null)

    # Now get active resolution and refresh for each monitor
    for i in "${!monitors[@]}"; do
        local name="${monitors[$i]%%|*}"
        local rest="${monitors[$i]#*|}"
        local res="N/A"
        local rate="N/A"

        # Find the active mode (has * after it)
        local active_line
        active_line=$(xrandr 2>/dev/null | sed -n "/^${name} connected/,/^[A-Za-z]/p" | grep '\*' | head -1)
        if [[ -n "$active_line" ]]; then
            res=$(echo "$active_line" | awk '{print $1}')
            # Extract the refresh rate marked with *
            rate=$(echo "$active_line" | grep -oP '[0-9]+\.[0-9]+(?=\*)')
            if [[ -z "$rate" ]]; then
                rate=$(echo "$active_line" | grep -oP '[0-9]+\.[0-9]+' | head -1)
            fi
            rate="${rate%.*}"  # Round to integer
        fi

        monitors[$i]="${name}|${res}|${rate}Hz|${rest}"
    done

    printf '%s\n' "${monitors[@]}"
}

# Parse kscreen-doctor or wlr-randr output
detect_monitors_wayland() {
    local tool
    tool="$(detect_wayland_tool)"

    if [[ "$tool" == "kscreen-doctor" ]]; then
        detect_monitors_kscreen
    elif [[ "$tool" == "wlr-randr" ]]; then
        detect_monitors_wlr
    else
        err "No Wayland display tool found. Install kscreen-doctor or wlr-randr."
        return 1
    fi
}

detect_monitors_kscreen() {
    local output
    output="$(kscreen-doctor -o 2>/dev/null)" || { err "kscreen-doctor failed"; return 1; }

    local current_name="" current_enabled="" current_res="" current_rate=""

    while IFS= read -r line; do
        # Output lines like: "Output: 1 DP-1 enabled"
        if [[ "$line" =~ ^Output:[[:space:]]+[0-9]+[[:space:]]+([A-Za-z0-9_-]+)[[:space:]]+(enabled|disabled) ]]; then
            # Print previous monitor if we have one
            if [[ -n "$current_name" ]]; then
                _emit_wayland_monitor "$current_name" "$current_res" "$current_rate"
            fi
            current_name="${BASH_REMATCH[1]}"
            current_enabled="${BASH_REMATCH[2]}"
            current_res="N/A"
            current_rate="N/A"
        fi

        # Mode line like: "    2560x1440@144 *"
        if [[ "$line" =~ ([0-9]+x[0-9]+)@([0-9]+) ]] && [[ "$line" == *"*"* ]]; then
            current_res="${BASH_REMATCH[1]}"
            current_rate="${BASH_REMATCH[2]}"
        fi
    done <<< "$output"

    # Emit last monitor
    if [[ -n "$current_name" ]]; then
        _emit_wayland_monitor "$current_name" "$current_res" "$current_rate"
    fi
}

detect_monitors_wlr() {
    local output
    output="$(wlr-randr 2>/dev/null)" || { err "wlr-randr failed"; return 1; }

    local current_name="" current_res="" current_rate=""

    while IFS= read -r line; do
        # Output name line like: "DP-1 "Digital Display" (DP-1)"
        if [[ "$line" =~ ^([A-Za-z0-9_-]+)[[:space:]] ]] && [[ ! "$line" =~ ^[[:space:]] ]]; then
            if [[ -n "$current_name" ]]; then
                _emit_wayland_monitor "$current_name" "$current_res" "$current_rate"
            fi
            current_name="${BASH_REMATCH[1]}"
            current_res="N/A"
            current_rate="N/A"
        fi

        # Current mode line: "    2560x1440 px, 143.998001 Hz (preferred, current)"
        if [[ "$line" =~ ([0-9]+x[0-9]+)[[:space:]]px,[[:space:]]([0-9]+)\.[0-9]+[[:space:]]Hz ]] && [[ "$line" == *"current"* ]]; then
            current_res="${BASH_REMATCH[1]}"
            current_rate="${BASH_REMATCH[2]}"
        fi
    done <<< "$output"

    if [[ -n "$current_name" ]]; then
        _emit_wayland_monitor "$current_name" "$current_res" "$current_rate"
    fi
}

_emit_wayland_monitor() {
    local name="$1" res="$2" rate="$3"
    local conn_type="Unknown"
    if [[ "$name" == DP-* || "$name" == DisplayPort-* ]]; then
        conn_type="DP"
    elif [[ "$name" == HDMI-* || "$name" == HDMI-A-* ]]; then
        conn_type="HDMI"
    elif [[ "$name" == DVI-* ]]; then
        conn_type="DVI"
    elif [[ "$name" == VGA-* ]]; then
        conn_type="VGA"
    elif [[ "$name" == eDP-* ]]; then
        conn_type="eDP"
    fi

    # VRR and HDR detection on Wayland is limited; check KWin settings
    local vrr_capable="Unknown"
    local hdr_capable="Unknown"

    echo "${name}|${res}|${rate}Hz|${conn_type}|${vrr_capable}|${hdr_capable}"
}

# Get list of monitor names
get_monitor_names() {
    if [[ "$SESSION_TYPE" == "x11" ]]; then
        xrandr 2>/dev/null | grep ' connected' | awk '{print $1}'
    else
        local tool
        tool="$(detect_wayland_tool)"
        if [[ "$tool" == "kscreen-doctor" ]]; then
            kscreen-doctor -o 2>/dev/null | grep -oP '(?<=Output:\s+\d\s)[A-Za-z0-9_-]+'
        elif [[ "$tool" == "wlr-randr" ]]; then
            wlr-randr 2>/dev/null | grep -oP '^[A-Za-z0-9_-]+(?=\s)'
        fi
    fi
}

# Get max refresh rate for a monitor
get_max_refresh_x11() {
    local monitor="$1"
    xrandr 2>/dev/null | sed -n "/^${monitor} connected/,/^[A-Za-z]/p" \
        | grep -oP '[0-9]+\.[0-9]+' | sort -rn | head -1 | cut -d. -f1
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_detect() {
    info "Detecting displays (session: ${SESSION_TYPE})..."
    echo ""

    local monitors=()

    if [[ "$SESSION_TYPE" == "x11" ]]; then
        mapfile -t monitors < <(detect_monitors_x11)
    elif [[ "$SESSION_TYPE" == "wayland" ]]; then
        mapfile -t monitors < <(detect_monitors_wayland)
    else
        err "Cannot determine session type. Set XDG_SESSION_TYPE or ensure DISPLAY/WAYLAND_DISPLAY is set."
        return 1
    fi

    if [[ ${#monitors[@]} -eq 0 ]]; then
        warn "No connected monitors detected."
        return 1
    fi

    # Print table header
    printf "${BOLD}%-16s %-14s %-10s %-8s %-10s %-10s${RESET}\n" \
        "MONITOR" "RESOLUTION" "REFRESH" "TYPE" "VRR" "HDR"
    printf '%.0s-' {1..70}
    echo ""

    for mon in "${monitors[@]}"; do
        IFS='|' read -r name res rate conn vrr hdr <<< "$mon"
        printf "%-16s %-14s %-10s %-8s %-10s %-10s\n" \
            "$name" "$res" "$rate" "$conn" "$vrr" "$hdr"
    done

    echo ""
    info "Total: ${#monitors[@]} monitor(s) detected"
}

cmd_gaming() {
    local target_monitor="${1:-}"
    info "Switching to gaming mode..."

    # If no monitor specified, pick the first connected one
    if [[ -z "$target_monitor" ]]; then
        target_monitor="$(get_monitor_names | head -1)"
        if [[ -z "$target_monitor" ]]; then
            err "No monitors detected."
            return 1
        fi
        info "Auto-selected monitor: ${target_monitor}"
    fi

    local all_monitors
    mapfile -t all_monitors < <(get_monitor_names)

    if [[ "$SESSION_TYPE" == "x11" ]]; then
        # Set max refresh rate on game monitor
        local max_rate
        max_rate="$(get_max_refresh_x11 "$target_monitor")"
        if [[ -n "$max_rate" ]]; then
            info "Setting ${target_monitor} to max refresh rate: ${max_rate}Hz"
            xrandr --output "$target_monitor" --rate "$max_rate" 2>/dev/null || warn "Failed to set refresh rate"
        fi

        # Set as primary
        info "Setting ${target_monitor} as primary"
        xrandr --output "$target_monitor" --primary 2>/dev/null || true

        # Disable other monitors to reduce GPU load
        if [[ ${#all_monitors[@]} -gt 1 ]]; then
            for mon in "${all_monitors[@]}"; do
                if [[ "$mon" != "$target_monitor" ]]; then
                    info "Disabling secondary monitor: ${mon}"
                    xrandr --output "$mon" --off 2>/dev/null || true
                fi
            done
        fi

        # Enable VRR if supported
        if xrandr --prop 2>/dev/null | grep -A 30 "^${target_monitor} connected" | grep -qi "vrr_capable\|freesync\|adaptive.sync"; then
            info "Enabling VRR on ${target_monitor}"
            xrandr --output "$target_monitor" --set "vrr_capable" 1 2>/dev/null || true
        fi

    elif [[ "$SESSION_TYPE" == "wayland" ]]; then
        local tool
        tool="$(detect_wayland_tool)"

        if [[ "$tool" == "kscreen-doctor" ]]; then
            # Use kscreen-doctor to configure
            info "Configuring ${target_monitor} for gaming via kscreen-doctor"

            # Disable other outputs
            if [[ ${#all_monitors[@]} -gt 1 ]]; then
                for mon in "${all_monitors[@]}"; do
                    if [[ "$mon" != "$target_monitor" ]]; then
                        info "Disabling secondary monitor: ${mon}"
                        kscreen-doctor output."${mon}".disable 2>/dev/null || true
                    fi
                done
            fi

        elif [[ "$tool" == "wlr-randr" ]]; then
            info "Configuring ${target_monitor} for gaming via wlr-randr"

            if [[ ${#all_monitors[@]} -gt 1 ]]; then
                for mon in "${all_monitors[@]}"; do
                    if [[ "$mon" != "$target_monitor" ]]; then
                        info "Disabling secondary monitor: ${mon}"
                        wlr-randr --output "$mon" --off 2>/dev/null || true
                    fi
                done
            fi
        fi

        # Enable VRR via KWin config
        _set_vrr_wayland "on"
    fi

    # Disable KWin compositor (reduces input lag)
    _disable_compositor

    ok "Gaming mode active on ${target_monitor}"
}

cmd_desktop() {
    info "Restoring desktop mode..."

    if [[ "$SESSION_TYPE" == "x11" ]]; then
        # Re-enable all monitors with auto config
        info "Re-enabling all monitors"
        xrandr --auto 2>/dev/null || true

    elif [[ "$SESSION_TYPE" == "wayland" ]]; then
        local tool
        tool="$(detect_wayland_tool)"
        local all_monitors
        mapfile -t all_monitors < <(get_monitor_names)

        if [[ "$tool" == "kscreen-doctor" ]]; then
            for mon in "${all_monitors[@]}"; do
                info "Enabling monitor: ${mon}"
                kscreen-doctor output."${mon}".enable 2>/dev/null || true
            done
        elif [[ "$tool" == "wlr-randr" ]]; then
            for mon in "${all_monitors[@]}"; do
                info "Enabling monitor: ${mon}"
                wlr-randr --output "$mon" --on 2>/dev/null || true
            done
        fi
    fi

    # Re-enable compositor
    _enable_compositor

    ok "Desktop mode restored — all monitors active"
}

cmd_refresh() {
    local monitor="${1:-}"
    local rate="${2:-}"

    if [[ -z "$monitor" || -z "$rate" ]]; then
        err "Usage: hubos-display refresh <monitor> <rate>"
        err "Example: hubos-display refresh DP-1 144"
        return 1
    fi

    info "Setting ${monitor} refresh rate to ${rate}Hz..."

    if [[ "$SESSION_TYPE" == "x11" ]]; then
        xrandr --output "$monitor" --rate "$rate" 2>/dev/null
    elif [[ "$SESSION_TYPE" == "wayland" ]]; then
        local tool
        tool="$(detect_wayland_tool)"
        if [[ "$tool" == "kscreen-doctor" ]]; then
            # kscreen-doctor uses output.NAME.mode.INDEX or output.NAME.mode.WxH@R
            kscreen-doctor output."${monitor}".mode."*@${rate}" 2>/dev/null || \
                warn "Could not set refresh rate via kscreen-doctor. Try specifying full mode."
        elif [[ "$tool" == "wlr-randr" ]]; then
            # Get current resolution first
            local current_res
            current_res="$(wlr-randr 2>/dev/null | sed -n "/^${monitor}/,/^[A-Za-z]/p" \
                | grep 'current' | grep -oP '[0-9]+x[0-9]+' | head -1)"
            if [[ -n "$current_res" ]]; then
                wlr-randr --output "$monitor" --mode "${current_res}@${rate}Hz" 2>/dev/null
            else
                wlr-randr --output "$monitor" --custom-mode "${rate}" 2>/dev/null || \
                    warn "Could not set refresh rate via wlr-randr."
            fi
        fi
    fi

    ok "Refresh rate set to ${rate}Hz on ${monitor}"
}

cmd_resolution() {
    local monitor="${1:-}"
    local res="${2:-}"

    if [[ -z "$monitor" || -z "$res" ]]; then
        err "Usage: hubos-display resolution <monitor> <resolution>"
        err "Example: hubos-display resolution DP-1 2560x1440"
        return 1
    fi

    info "Setting ${monitor} resolution to ${res}..."

    if [[ "$SESSION_TYPE" == "x11" ]]; then
        xrandr --output "$monitor" --mode "$res" 2>/dev/null
    elif [[ "$SESSION_TYPE" == "wayland" ]]; then
        local tool
        tool="$(detect_wayland_tool)"
        if [[ "$tool" == "kscreen-doctor" ]]; then
            kscreen-doctor output."${monitor}".mode."${res}" 2>/dev/null || \
                warn "Could not set resolution via kscreen-doctor."
        elif [[ "$tool" == "wlr-randr" ]]; then
            wlr-randr --output "$monitor" --mode "$res" 2>/dev/null || \
                warn "Could not set resolution via wlr-randr."
        fi
    fi

    ok "Resolution set to ${res} on ${monitor}"
}

cmd_vrr() {
    local state="${1:-}"

    if [[ -z "$state" ]] || [[ "$state" != "on" && "$state" != "off" ]]; then
        err "Usage: hubos-display vrr <on|off>"
        return 1
    fi

    info "Setting VRR to ${state}..."

    if [[ "$SESSION_TYPE" == "x11" ]]; then
        local value=1
        [[ "$state" == "off" ]] && value=0

        local monitors
        mapfile -t monitors < <(get_monitor_names)
        for mon in "${monitors[@]}"; do
            xrandr --output "$mon" --set "vrr_capable" "$value" 2>/dev/null || true
            # Also try the FreeSync property name
            xrandr --output "$mon" --set "freesync" "$value" 2>/dev/null || true
        done
    elif [[ "$SESSION_TYPE" == "wayland" ]]; then
        _set_vrr_wayland "$state"
    fi

    ok "VRR set to ${state}"
}

_set_vrr_wayland() {
    local state="$1"
    # KWin VRR setting: 0=Never, 1=Always, 2=Automatic
    local value=0
    if [[ "$state" == "on" ]]; then
        value=1
    fi

    if command -v kwriteconfig6 &>/dev/null; then
        kwriteconfig6 --file kwinrc --group Compositing --key AllowTearing true 2>/dev/null || true
        if [[ "$state" == "on" ]]; then
            kwriteconfig6 --file kwinrc --group Compositing --key LatencyPolicy Low 2>/dev/null || true
        fi
        # Signal KWin to reload config
        if command -v dbus-send &>/dev/null; then
            dbus-send --type=signal --dest=org.kde.KWin /Compositor org.kde.kwin.Compositing.reinit 2>/dev/null || true
        fi
    elif command -v kwriteconfig5 &>/dev/null; then
        kwriteconfig5 --file kwinrc --group Compositing --key AllowTearing true 2>/dev/null || true
        if command -v dbus-send &>/dev/null; then
            dbus-send --type=signal --dest=org.kde.KWin /Compositor org.kde.kwin.Compositing.reinit 2>/dev/null || true
        fi
    else
        warn "kwriteconfig not found — cannot set VRR via KWin config"
    fi
}

cmd_hdr() {
    local state="${1:-}"

    if [[ -z "$state" ]] || [[ "$state" != "on" && "$state" != "off" ]]; then
        err "Usage: hubos-display hdr <on|off>"
        return 1
    fi

    info "Setting HDR to ${state}..."

    # NVIDIA warning
    if lspci 2>/dev/null | grep -qi nvidia; then
        warn "NVIDIA GPU detected. HDR support may have issues with proprietary drivers."
        warn "Ensure driver version 545+ for best Wayland HDR support."
    fi

    local enabled="false"
    [[ "$state" == "on" ]] && enabled="true"

    # KDE HDR settings via kwriteconfig
    if command -v kwriteconfig6 &>/dev/null; then
        kwriteconfig6 --file kwinrc --group Compositing --key AllowHDR "$enabled" 2>/dev/null || true
        kwriteconfig6 --file kwinrc --group Compositing --key WideGamut "$enabled" 2>/dev/null || true

        # Signal KWin to reload
        if command -v dbus-send &>/dev/null; then
            dbus-send --type=signal --dest=org.kde.KWin /Compositor org.kde.kwin.Compositing.reinit 2>/dev/null || true
        fi
    elif command -v kwriteconfig5 &>/dev/null; then
        warn "KDE 5 detected — HDR support is limited. Upgrade to Plasma 6 recommended."
    else
        warn "kwriteconfig not found — cannot configure KDE HDR settings"
    fi

    # Set environment variable for DXVK HDR (used by Proton/Wine games)
    local env_file="$HOME/.config/hubos/display-env.sh"
    mkdir -p "$(dirname "$env_file")"

    if [[ "$state" == "on" ]]; then
        info "Setting DXVK_HDR=1 in ${env_file}"
        # Update or add DXVK_HDR
        if [[ -f "$env_file" ]] && grep -q '^export DXVK_HDR=' "$env_file"; then
            sed -i 's/^export DXVK_HDR=.*/export DXVK_HDR=1/' "$env_file"
        else
            echo 'export DXVK_HDR=1' >> "$env_file"
        fi
        export DXVK_HDR=1
    else
        info "Unsetting DXVK_HDR in ${env_file}"
        if [[ -f "$env_file" ]]; then
            sed -i '/^export DXVK_HDR=/d' "$env_file"
        fi
        unset DXVK_HDR 2>/dev/null || true
    fi

    ok "HDR set to ${state}"
    if [[ "$state" == "on" ]]; then
        info "Note: Source ${env_file} in your shell profile for DXVK_HDR to persist."
        info "Games launched via Steam/Lutris will pick up DXVK_HDR=1 automatically if the env is set."
    fi
}

cmd_profile() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        err "Usage: hubos-display profile <name>"
        return 1
    fi

    local profile_file="${PROFILE_DIR}/${name}.json"
    if [[ ! -f "$profile_file" ]]; then
        err "Profile '${name}' not found."
        info "Available profiles:"
        cmd_list
        return 1
    fi

    info "Loading display profile: ${name}"

    # Read the profile JSON and apply settings
    if ! command -v jq &>/dev/null; then
        err "jq is required to parse profiles. Install it with: sudo pacman -S jq"
        return 1
    fi

    local monitor_count
    monitor_count="$(jq '.monitors | length' "$profile_file")"

    for ((i = 0; i < monitor_count; i++)); do
        local mon_name mon_res mon_rate mon_enabled
        mon_name="$(jq -r ".monitors[$i].name" "$profile_file")"
        mon_res="$(jq -r ".monitors[$i].resolution" "$profile_file")"
        mon_rate="$(jq -r ".monitors[$i].refresh_rate" "$profile_file")"
        mon_enabled="$(jq -r ".monitors[$i].enabled" "$profile_file")"

        if [[ "$mon_enabled" == "false" ]]; then
            info "Disabling ${mon_name}"
            if [[ "$SESSION_TYPE" == "x11" ]]; then
                xrandr --output "$mon_name" --off 2>/dev/null || true
            elif [[ "$SESSION_TYPE" == "wayland" ]]; then
                local tool
                tool="$(detect_wayland_tool)"
                if [[ "$tool" == "kscreen-doctor" ]]; then
                    kscreen-doctor output."${mon_name}".disable 2>/dev/null || true
                elif [[ "$tool" == "wlr-randr" ]]; then
                    wlr-randr --output "$mon_name" --off 2>/dev/null || true
                fi
            fi
            continue
        fi

        info "Configuring ${mon_name}: ${mon_res} @ ${mon_rate}Hz"

        if [[ "$SESSION_TYPE" == "x11" ]]; then
            xrandr --output "$mon_name" --mode "$mon_res" --rate "$mon_rate" 2>/dev/null || \
                warn "Failed to configure ${mon_name}"
        elif [[ "$SESSION_TYPE" == "wayland" ]]; then
            local tool
            tool="$(detect_wayland_tool)"
            if [[ "$tool" == "kscreen-doctor" ]]; then
                kscreen-doctor output."${mon_name}".enable \
                    output."${mon_name}".mode."${mon_res}@${mon_rate}" 2>/dev/null || \
                    warn "Failed to configure ${mon_name}"
            elif [[ "$tool" == "wlr-randr" ]]; then
                wlr-randr --output "$mon_name" --on --mode "${mon_res}@${mon_rate}Hz" 2>/dev/null || \
                    warn "Failed to configure ${mon_name}"
            fi
        fi
    done

    # Apply VRR/HDR settings from profile
    local vrr_state hdr_state compositor_state
    vrr_state="$(jq -r '.vrr // "unchanged"' "$profile_file")"
    hdr_state="$(jq -r '.hdr // "unchanged"' "$profile_file")"
    compositor_state="$(jq -r '.compositor // "unchanged"' "$profile_file")"

    if [[ "$vrr_state" != "unchanged" && "$vrr_state" != "null" ]]; then
        cmd_vrr "$vrr_state"
    fi
    if [[ "$hdr_state" != "unchanged" && "$hdr_state" != "null" ]]; then
        cmd_hdr "$hdr_state"
    fi
    if [[ "$compositor_state" == "off" ]]; then
        _disable_compositor
    elif [[ "$compositor_state" == "on" ]]; then
        _enable_compositor
    fi

    ok "Profile '${name}' loaded"
}

cmd_save() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        err "Usage: hubos-display save <name>"
        return 1
    fi

    if ! command -v jq &>/dev/null; then
        err "jq is required to save profiles. Install it with: sudo pacman -S jq"
        return 1
    fi

    info "Saving current display configuration as '${name}'..."

    local monitors_json="[]"

    if [[ "$SESSION_TYPE" == "x11" ]]; then
        local monitors
        mapfile -t monitors < <(detect_monitors_x11)
        for mon in "${monitors[@]}"; do
            IFS='|' read -r m_name m_res m_rate m_conn m_vrr m_hdr <<< "$mon"
            m_rate="${m_rate%Hz}"  # Strip Hz suffix
            monitors_json="$(echo "$monitors_json" | jq \
                --arg name "$m_name" \
                --arg res "$m_res" \
                --arg rate "$m_rate" \
                --arg conn "$m_conn" \
                '. + [{"name": $name, "resolution": $res, "refresh_rate": $rate, "connection": $conn, "enabled": true}]')"
        done
    elif [[ "$SESSION_TYPE" == "wayland" ]]; then
        local monitors
        mapfile -t monitors < <(detect_monitors_wayland)
        for mon in "${monitors[@]}"; do
            IFS='|' read -r m_name m_res m_rate m_conn m_vrr m_hdr <<< "$mon"
            m_rate="${m_rate%Hz}"
            monitors_json="$(echo "$monitors_json" | jq \
                --arg name "$m_name" \
                --arg res "$m_res" \
                --arg rate "$m_rate" \
                --arg conn "$m_conn" \
                '. + [{"name": $name, "resolution": $res, "refresh_rate": $rate, "connection": $conn, "enabled": true}]')"
        done
    fi

    # Detect current VRR/HDR/compositor state
    local vrr_state="off" hdr_state="off" compositor_state="on"

    if [[ "$SESSION_TYPE" == "wayland" ]] && command -v kreadconfig6 &>/dev/null; then
        local allow_tearing
        allow_tearing="$(kreadconfig6 --file kwinrc --group Compositing --key AllowTearing 2>/dev/null || echo "false")"
        [[ "$allow_tearing" == "true" ]] && vrr_state="on"

        local allow_hdr
        allow_hdr="$(kreadconfig6 --file kwinrc --group Compositing --key AllowHDR 2>/dev/null || echo "false")"
        [[ "$allow_hdr" == "true" ]] && hdr_state="on"
    fi

    # Check compositor status
    if command -v dbus-send &>/dev/null; then
        local comp_active
        comp_active="$(dbus-send --print-reply --dest=org.kde.KWin /Compositor \
            org.freedesktop.DBus.Properties.Get string:org.kde.kwin.Compositing string:active \
            2>/dev/null | grep -oP '(?<=boolean )\w+' || echo "true")"
        [[ "$comp_active" == "false" ]] && compositor_state="off"
    fi

    local profile_file="${PROFILE_DIR}/${name}.json"
    jq -n \
        --arg name "$name" \
        --arg session "$SESSION_TYPE" \
        --arg vrr "$vrr_state" \
        --arg hdr "$hdr_state" \
        --arg comp "$compositor_state" \
        --arg date "$(date -Iseconds)" \
        --argjson monitors "$monitors_json" \
        '{
            "profile_name": $name,
            "session_type": $session,
            "saved_at": $date,
            "monitors": $monitors,
            "vrr": $vrr,
            "hdr": $hdr,
            "compositor": $comp
        }' > "$profile_file"

    ok "Profile saved to ${profile_file}"
}

cmd_list() {
    info "Saved display profiles:"
    echo ""

    local found=0
    for f in "${PROFILE_DIR}"/*.json; do
        [[ -f "$f" ]] || continue
        found=1
        local pname
        pname="$(basename "$f" .json)"

        if command -v jq &>/dev/null; then
            local date monitors_count
            date="$(jq -r '.saved_at // "unknown"' "$f" | cut -dT -f1)"
            monitors_count="$(jq '.monitors | length' "$f" 2>/dev/null || echo "?")"
            printf "  ${BOLD}%-20s${RESET} ${DIM}(%s monitors, saved %s)${RESET}\n" \
                "$pname" "$monitors_count" "$date"
        else
            printf "  ${BOLD}%s${RESET}\n" "$pname"
        fi
    done

    if [[ $found -eq 0 ]]; then
        echo "  (none)"
        echo ""
        info "Save one with: hubos-display save <name>"
    fi
}

cmd_status() {
    echo -e "${BOLD}HubOS Display Status${RESET}"
    echo -e "${DIM}Session: ${SESSION_TYPE}${RESET}"
    echo ""

    # Show monitors
    cmd_detect

    echo ""

    # VRR status
    local vrr_status="Unknown"
    if [[ "$SESSION_TYPE" == "wayland" ]] && command -v kreadconfig6 &>/dev/null; then
        local allow_tearing
        allow_tearing="$(kreadconfig6 --file kwinrc --group Compositing --key AllowTearing 2>/dev/null || echo "false")"
        if [[ "$allow_tearing" == "true" ]]; then
            vrr_status="${GREEN}Enabled${RESET}"
        else
            vrr_status="${RED}Disabled${RESET}"
        fi
    elif [[ "$SESSION_TYPE" == "x11" ]]; then
        if xrandr --prop 2>/dev/null | grep -qi "vrr_capable.*1\|freesync.*enabled"; then
            vrr_status="${GREEN}Enabled${RESET}"
        else
            vrr_status="${RED}Disabled${RESET}"
        fi
    fi

    # HDR status
    local hdr_status="Unknown"
    if [[ "$SESSION_TYPE" == "wayland" ]] && command -v kreadconfig6 &>/dev/null; then
        local allow_hdr
        allow_hdr="$(kreadconfig6 --file kwinrc --group Compositing --key AllowHDR 2>/dev/null || echo "false")"
        if [[ "$allow_hdr" == "true" ]]; then
            hdr_status="${GREEN}Enabled${RESET}"
        else
            hdr_status="${RED}Disabled${RESET}"
        fi
    elif [[ "$SESSION_TYPE" == "x11" ]]; then
        hdr_status="${YELLOW}Not supported on X11${RESET}"
    fi

    # Compositor status
    local comp_status="Unknown"
    if command -v dbus-send &>/dev/null; then
        local comp_active
        comp_active="$(dbus-send --print-reply --dest=org.kde.KWin /Compositor \
            org.freedesktop.DBus.Properties.Get string:org.kde.kwin.Compositing string:active \
            2>/dev/null | grep -oP '(?<=boolean )\w+' || echo "unknown")"
        if [[ "$comp_active" == "true" ]]; then
            comp_status="${GREEN}Active${RESET}"
        elif [[ "$comp_active" == "false" ]]; then
            comp_status="${YELLOW}Disabled (gaming mode)${RESET}"
        fi
    fi

    # DXVK HDR env
    local dxvk_hdr="${DXVK_HDR:-not set}"

    printf "  ${BOLD}%-20s${RESET} %b\n" "VRR:" "$vrr_status"
    printf "  ${BOLD}%-20s${RESET} %b\n" "HDR:" "$hdr_status"
    printf "  ${BOLD}%-20s${RESET} %b\n" "Compositor:" "$comp_status"
    printf "  ${BOLD}%-20s${RESET} %s\n" "DXVK_HDR:" "$dxvk_hdr"

    # GPU info
    echo ""
    if command -v lspci &>/dev/null; then
        local gpu
        gpu="$(lspci 2>/dev/null | grep -i 'vga\|3d\|display' | head -3)"
        if [[ -n "$gpu" ]]; then
            echo -e "  ${BOLD}GPU:${RESET}"
            while IFS= read -r line; do
                echo "    $line"
            done <<< "$gpu"
        fi
    fi
}

# ---------------------------------------------------------------------------
# Compositor helpers
# ---------------------------------------------------------------------------

_disable_compositor() {
    info "Disabling KWin compositor (reduces input lag)"
    if command -v dbus-send &>/dev/null; then
        dbus-send --type=method_call --dest=org.kde.KWin \
            /Compositor org.kde.kwin.Compositing.suspend 2>/dev/null || true
    fi
    if command -v qdbus6 &>/dev/null; then
        qdbus6 org.kde.KWin /Compositor suspend 2>/dev/null || true
    elif command -v qdbus &>/dev/null; then
        qdbus org.kde.KWin /Compositor suspend 2>/dev/null || true
    fi
}

_enable_compositor() {
    info "Re-enabling KWin compositor"
    if command -v dbus-send &>/dev/null; then
        dbus-send --type=method_call --dest=org.kde.KWin \
            /Compositor org.kde.kwin.Compositing.resume 2>/dev/null || true
    fi
    if command -v qdbus6 &>/dev/null; then
        qdbus6 org.kde.KWin /Compositor resume 2>/dev/null || true
    elif command -v qdbus &>/dev/null; then
        qdbus org.kde.KWin /Compositor resume 2>/dev/null || true
    fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<'USAGE'
hubos-display — Multi-monitor and display manager for HubOS

Usage:
  hubos-display <command> [options]

Commands:
  detect                       Detect and list all connected monitors
  gaming [monitor]             Optimize display for gaming (max refresh, VRR, disable secondaries)
  desktop                      Restore all monitors to normal desktop mode
  refresh <monitor> <rate>     Set refresh rate (e.g., hubos-display refresh DP-1 144)
  resolution <monitor> <res>   Set resolution (e.g., hubos-display resolution DP-1 2560x1440)
  vrr <on|off>                 Toggle Variable Refresh Rate (FreeSync/G-Sync)
  hdr <on|off>                 Toggle HDR output
  profile <name>               Load a saved display profile
  save <name>                  Save current display config as a named profile
  list                         List saved display profiles
  status                       Show current display configuration and status

Profiles are stored in: ~/.config/hubos/display-profiles/

Auto-detects session type (X11/Wayland) and uses appropriate tools:
  X11:     xrandr
  Wayland: kscreen-doctor (KDE) or wlr-randr (wlroots)

Examples:
  hubos-display detect
  hubos-display gaming DP-1
  hubos-display save my-gaming-setup
  hubos-display profile my-gaming-setup
  hubos-display vrr on
  hubos-display hdr on
USAGE
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    local command="${1:-}"
    shift 2>/dev/null || true

    case "$command" in
        detect)         cmd_detect "$@" ;;
        gaming)         cmd_gaming "$@" ;;
        desktop)        cmd_desktop "$@" ;;
        refresh)        cmd_refresh "$@" ;;
        resolution)     cmd_resolution "$@" ;;
        vrr)            cmd_vrr "$@" ;;
        hdr)            cmd_hdr "$@" ;;
        profile)        cmd_profile "$@" ;;
        save)           cmd_save "$@" ;;
        list)           cmd_list "$@" ;;
        status)         cmd_status "$@" ;;
        help|--help|-h) usage ;;
        "")
            usage
            return 1
            ;;
        *)
            err "Unknown command: ${command}"
            echo ""
            usage
            return 1
            ;;
    esac
}

main "$@"
