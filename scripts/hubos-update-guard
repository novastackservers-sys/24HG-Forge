#!/usr/bin/env bash
set -euo pipefail
# HubOS Update Guard — Protect gaming performance across system updates

###############################################################################
# Constants & Paths
###############################################################################
readonly VERSION="1.0.0"
readonly APP_NAME="hubos-update-guard"
readonly DATA_DIR="${HOME}/.local/share/hubos/update-guard"
readonly SNAPSHOT_DIR="${DATA_DIR}/snapshots"
readonly HISTORY_FILE="${DATA_DIR}/history.json"
readonly BENCHMARK_DURATION=10
readonly BENCHMARK_REGRESSION_THRESHOLD=10

###############################################################################
# Colors & Formatting
###############################################################################
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' RESET=''
fi

###############################################################################
# Helpers
###############################################################################
info()  { echo -e "${BLUE}ℹ${RESET} $*"; }
ok()    { echo -e "${GREEN}✓${RESET} $*"; }
warn()  { echo -e "${YELLOW}⚠${RESET} $*"; }
err()   { echo -e "${RED}✗${RESET} $*" >&2; }
die()   { err "$@"; exit 1; }

separator() {
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
}

ensure_dirs() {
    mkdir -p "$SNAPSHOT_DIR"
    [[ -f "$HISTORY_FILE" ]] || echo '[]' > "$HISTORY_FILE"
}

generate_snapshot_id() {
    date +"%Y%m%d-%H%M%S"
}

notify_desktop() {
    local title="$1" body="$2" icon="${3:-dialog-information}"
    if command -v notify-send &>/dev/null; then
        notify-send -a "$APP_NAME" -i "$icon" "$title" "$body" 2>/dev/null || true
    fi
}

json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

###############################################################################
# Version Detection Functions
###############################################################################
get_kernel_version() {
    uname -r 2>/dev/null || echo "unknown"
}

get_nvidia_version() {
    if command -v nvidia-smi &>/dev/null; then
        nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1 || echo "not-installed"
    else
        echo "not-installed"
    fi
}

get_mesa_version() {
    if command -v glxinfo &>/dev/null; then
        glxinfo 2>/dev/null | grep "OpenGL version" | sed 's/.*Mesa //' | awk '{print $1}' || echo "unknown"
    else
        echo "unknown"
    fi
}

get_vulkan_version() {
    if command -v vulkaninfo &>/dev/null; then
        vulkaninfo --summary 2>/dev/null | grep "apiVersion" | head -1 | awk '{print $NF}' || echo "unknown"
    else
        echo "unknown"
    fi
}

get_vulkan_driver() {
    if command -v vulkaninfo &>/dev/null; then
        vulkaninfo --summary 2>/dev/null | grep "driverName" | head -1 | awk '{print $NF}' || echo "unknown"
    else
        echo "unknown"
    fi
}

get_proton_versions() {
    local compat_dir="${HOME}/.steam/steam/compatibilitytools.d"
    local proton_list="[]"
    if [[ -d "$compat_dir" ]]; then
        local entries=()
        while IFS= read -r -d '' d; do
            entries+=("\"$(basename "$d")\"")
        done < <(find "$compat_dir" -maxdepth 1 -mindepth 1 -type d -print0 2>/dev/null)
        if [[ ${#entries[@]} -gt 0 ]]; then
            local joined
            joined=$(IFS=,; echo "${entries[*]}")
            proton_list="[${joined}]"
        fi
    fi
    echo "$proton_list"
}

get_dxvk_version() {
    local compat_dir="${HOME}/.steam/steam/compatibilitytools.d"
    if [[ -d "$compat_dir" ]]; then
        local latest
        latest=$(find "$compat_dir" -name "d3d11.dll" -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1)
        if [[ -n "${latest:-}" ]]; then
            local proton_dir
            proton_dir=$(dirname "$(dirname "$latest")")
            if [[ -f "${proton_dir}/version" ]]; then
                grep -i dxvk "${proton_dir}/version" 2>/dev/null | awk '{print $NF}' || echo "unknown"
                return
            fi
        fi
    fi
    echo "unknown"
}

get_pipewire_version() {
    if command -v pipewire &>/dev/null; then
        pipewire --version 2>/dev/null | tail -1 | awk '{print $NF}' || echo "unknown"
    else
        echo "unknown"
    fi
}

get_plasma_version() {
    if command -v plasmashell &>/dev/null; then
        plasmashell --version 2>/dev/null | awk '{print $NF}' || echo "unknown"
    else
        echo "not-installed"
    fi
}

get_gamescope_version() {
    if command -v gamescope &>/dev/null; then
        gamescope --version 2>/dev/null | awk '{print $NF}' || echo "installed"
    else
        echo "not-installed"
    fi
}

get_mangohud_version() {
    if command -v mangohud &>/dev/null; then
        mangohud --version 2>/dev/null | awk '{print $NF}' || echo "installed"
    else
        echo "not-installed"
    fi
}

get_deployment_hash() {
    if command -v rpm-ostree &>/dev/null; then
        rpm-ostree status --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
deploys = data.get('deployments', [])
for d in deploys:
    if d.get('booted', False):
        print(d.get('checksum', 'unknown')[:12])
        break
" 2>/dev/null || echo "unknown"
    else
        echo "not-atomic"
    fi
}

get_layered_packages() {
    if command -v rpm-ostree &>/dev/null; then
        rpm-ostree status --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
deploys = data.get('deployments', [])
for d in deploys:
    if d.get('booted', False):
        pkgs = d.get('requested-packages', []) + d.get('requested-local-packages', [])
        print(json.dumps(pkgs))
        break
" 2>/dev/null || echo "[]"
    else
        echo "[]"
    fi
}

get_gpu_driver_loaded() {
    if lsmod 2>/dev/null | grep -q "^nvidia"; then
        echo "nvidia"
    elif lsmod 2>/dev/null | grep -q "^amdgpu"; then
        echo "amdgpu"
    elif lsmod 2>/dev/null | grep -q "^i915"; then
        echo "i915"
    elif lsmod 2>/dev/null | grep -q "^xe"; then
        echo "xe"
    else
        echo "unknown"
    fi
}

###############################################################################
# Benchmark
###############################################################################
run_benchmark() {
    local score=0
    local vk_score=0
    local cpu_score=0

    # Vulkan benchmark: vkcube frame count in BENCHMARK_DURATION seconds
    if command -v vkcube &>/dev/null; then
        info "Running Vulkan benchmark (${BENCHMARK_DURATION}s)..."
        local vk_output
        vk_output=$(timeout "${BENCHMARK_DURATION}" vkcube 2>&1 || true)
        vk_score=$(echo "$vk_output" | grep -oP '\d+ frames' | tail -1 | awk '{print $1}' || echo "0")
        [[ -z "$vk_score" || "$vk_score" == "0" ]] && vk_score=500  # fallback estimate
    else
        warn "vkcube not found — skipping Vulkan benchmark"
        vk_score=0
    fi

    # CPU benchmark: hash operations in BENCHMARK_DURATION seconds
    info "Running CPU benchmark (${BENCHMARK_DURATION}s)..."
    cpu_score=$(timeout "${BENCHMARK_DURATION}" bash -c '
        count=0
        end=$((SECONDS + '"${BENCHMARK_DURATION}"'))
        while [[ $SECONDS -lt $end ]]; do
            echo "hubos-bench-$count" | sha256sum > /dev/null
            ((count++))
        done
        echo "$count"
    ' 2>/dev/null || echo "0")

    # Combined score (weighted: 60% GPU, 40% CPU normalized)
    local cpu_normalized=$(( cpu_score / 100 ))
    score=$(( (vk_score * 6 + cpu_normalized * 4) / 10 ))
    [[ "$score" -eq 0 ]] && score=1

    echo "$score"
}

###############################################################################
# Snapshot
###############################################################################
cmd_snapshot() {
    ensure_dirs
    local sid
    sid=$(generate_snapshot_id)

    echo -e "${BOLD}HubOS Update Guard — Taking Snapshot${RESET}"
    separator

    info "Snapshot ID: ${CYAN}${sid}${RESET}"
    echo ""

    info "Gathering system information..."
    local kernel mesa nvidia vulkan vulkan_driver proton dxvk pipewire plasma
    local gamescope mangohud deployment layered gpu_driver

    kernel=$(get_kernel_version)
    echo -e "  Kernel:       ${kernel}"

    nvidia=$(get_nvidia_version)
    echo -e "  NVIDIA:       ${nvidia}"

    mesa=$(get_mesa_version)
    echo -e "  Mesa:         ${mesa}"

    vulkan=$(get_vulkan_version)
    vulkan_driver=$(get_vulkan_driver)
    echo -e "  Vulkan:       ${vulkan} (${vulkan_driver})"

    proton=$(get_proton_versions)
    local proton_count
    proton_count=$(echo "$proton" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
    echo -e "  Proton:       ${proton_count} versions installed"

    dxvk=$(get_dxvk_version)
    echo -e "  DXVK:         ${dxvk}"

    pipewire=$(get_pipewire_version)
    echo -e "  PipeWire:     ${pipewire}"

    plasma=$(get_plasma_version)
    echo -e "  Plasma:       ${plasma}"

    gamescope=$(get_gamescope_version)
    echo -e "  gamescope:    ${gamescope}"

    mangohud=$(get_mangohud_version)
    echo -e "  MangoHud:     ${mangohud}"

    deployment=$(get_deployment_hash)
    echo -e "  Deployment:   ${deployment}"

    gpu_driver=$(get_gpu_driver_loaded)
    echo -e "  GPU module:   ${gpu_driver}"

    layered=$(get_layered_packages)
    local layered_count
    layered_count=$(echo "$layered" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
    echo -e "  Layered pkgs: ${layered_count}"

    echo ""

    # Run benchmark
    local bench_score
    bench_score=$(run_benchmark)
    echo -e "  ${BOLD}Benchmark score: ${CYAN}${bench_score}${RESET}"
    echo ""

    # Write JSON snapshot
    local snap_file="${SNAPSHOT_DIR}/${sid}.json"
    local timestamp
    timestamp=$(date -Iseconds)

    cat > "$snap_file" <<SNAPEOF
{
  "id": "${sid}",
  "timestamp": "${timestamp}",
  "kernel": "$(json_escape "$kernel")",
  "nvidia_driver": "$(json_escape "$nvidia")",
  "mesa": "$(json_escape "$mesa")",
  "vulkan_version": "$(json_escape "$vulkan")",
  "vulkan_driver": "$(json_escape "$vulkan_driver")",
  "proton_versions": ${proton},
  "dxvk": "$(json_escape "$dxvk")",
  "pipewire": "$(json_escape "$pipewire")",
  "plasma": "$(json_escape "$plasma")",
  "gamescope": "$(json_escape "$gamescope")",
  "mangohud": "$(json_escape "$mangohud")",
  "deployment_hash": "$(json_escape "$deployment")",
  "gpu_module": "$(json_escape "$gpu_driver")",
  "layered_packages": ${layered},
  "benchmark_score": ${bench_score}
}
SNAPEOF

    # Append to history
    python3 -c "
import json, sys
hist_path = '${HISTORY_FILE}'
with open(hist_path, 'r') as f:
    hist = json.load(f)
entry = {
    'snapshot_id': '${sid}',
    'timestamp': '${timestamp}',
    'action': 'snapshot',
    'benchmark_score': ${bench_score}
}
hist.append(entry)
with open(hist_path, 'w') as f:
    json.dump(hist, f, indent=2)
"

    separator
    ok "Snapshot saved: ${snap_file}"
    echo ""
}

###############################################################################
# Check — Compare current state to last snapshot
###############################################################################
get_latest_snapshot() {
    local latest
    latest=$(ls -1t "${SNAPSHOT_DIR}"/*.json 2>/dev/null | head -1)
    echo "${latest:-}"
}

compare_field() {
    local label="$1" old_val="$2" new_val="$3" critical="${4:-false}"

    if [[ "$old_val" == "$new_val" ]]; then
        echo -e "  ${GREEN}●${RESET} ${label}: ${old_val}  ${DIM}(unchanged)${RESET}"
    else
        # Detect downgrade vs upgrade heuristically
        local color="$YELLOW"
        local tag="updated"
        if [[ "$new_val" == "not-installed" || "$new_val" == "unknown" ]]; then
            color="$RED"
            tag="removed/broken"
        fi
        echo -e "  ${color}●${RESET} ${label}: ${old_val} → ${BOLD}${new_val}${RESET}  ${color}(${tag})${RESET}"
        if [[ "$critical" == "true" ]]; then
            echo -e "    ${YELLOW}↳ Gaming-critical component changed${RESET}"
        fi
    fi
}

cmd_check() {
    ensure_dirs
    local snap_file
    snap_file=$(get_latest_snapshot)
    [[ -z "$snap_file" ]] && die "No snapshots found. Run '${APP_NAME} snapshot' first."

    echo -e "${BOLD}HubOS Update Guard — Change Check${RESET}"
    separator

    local snap_id
    snap_id=$(python3 -c "import json; print(json.load(open('${snap_file}'))['id'])")
    local snap_ts
    snap_ts=$(python3 -c "import json; print(json.load(open('${snap_file}'))['timestamp'])")
    info "Comparing against snapshot: ${CYAN}${snap_id}${RESET} (${snap_ts})"
    echo ""

    # Read old values
    local old_kernel old_nvidia old_mesa old_vulkan old_pipewire old_plasma
    local old_gamescope old_mangohud old_deployment old_bench
    old_kernel=$(python3 -c "import json; print(json.load(open('${snap_file}'))['kernel'])")
    old_nvidia=$(python3 -c "import json; print(json.load(open('${snap_file}'))['nvidia_driver'])")
    old_mesa=$(python3 -c "import json; print(json.load(open('${snap_file}'))['mesa'])")
    old_vulkan=$(python3 -c "import json; print(json.load(open('${snap_file}'))['vulkan_version'])")
    old_pipewire=$(python3 -c "import json; print(json.load(open('${snap_file}'))['pipewire'])")
    old_plasma=$(python3 -c "import json; print(json.load(open('${snap_file}'))['plasma'])")
    old_gamescope=$(python3 -c "import json; print(json.load(open('${snap_file}'))['gamescope'])")
    old_mangohud=$(python3 -c "import json; print(json.load(open('${snap_file}'))['mangohud'])")
    old_deployment=$(python3 -c "import json; print(json.load(open('${snap_file}'))['deployment_hash'])")
    old_bench=$(python3 -c "import json; print(json.load(open('${snap_file}'))['benchmark_score'])")

    # Get current values
    local cur_kernel cur_nvidia cur_mesa cur_vulkan cur_pipewire cur_plasma
    local cur_gamescope cur_mangohud cur_deployment
    cur_kernel=$(get_kernel_version)
    cur_nvidia=$(get_nvidia_version)
    cur_mesa=$(get_mesa_version)
    cur_vulkan=$(get_vulkan_version)
    cur_pipewire=$(get_pipewire_version)
    cur_plasma=$(get_plasma_version)
    cur_gamescope=$(get_gamescope_version)
    cur_mangohud=$(get_mangohud_version)
    cur_deployment=$(get_deployment_hash)

    echo -e "${BOLD}Gaming Stack Comparison:${RESET}"
    compare_field "Kernel        " "$old_kernel" "$cur_kernel" true
    compare_field "NVIDIA Driver " "$old_nvidia" "$cur_nvidia" true
    compare_field "Mesa          " "$old_mesa" "$cur_mesa" true
    compare_field "Vulkan        " "$old_vulkan" "$cur_vulkan" true
    compare_field "PipeWire      " "$old_pipewire" "$cur_pipewire" false
    compare_field "Plasma        " "$old_plasma" "$cur_plasma" false
    compare_field "gamescope     " "$old_gamescope" "$cur_gamescope" false
    compare_field "MangoHud      " "$old_mangohud" "$cur_mangohud" false
    compare_field "Deployment    " "$old_deployment" "$cur_deployment" false

    echo ""

    # Run quick benchmark and compare
    info "Running benchmark to compare performance..."
    local cur_bench
    cur_bench=$(run_benchmark)

    if [[ "$old_bench" -gt 0 ]]; then
        local diff_pct
        diff_pct=$(python3 -c "
old = ${old_bench}
new = ${cur_bench}
pct = ((new - old) / old) * 100
print(f'{pct:+.1f}')
")
        local diff_abs
        diff_abs=$(python3 -c "print(abs(${cur_bench} - ${old_bench}))")
        local regression
        regression=$(python3 -c "print('yes' if (${old_bench} - ${cur_bench}) / ${old_bench} * 100 > ${BENCHMARK_REGRESSION_THRESHOLD} else 'no')")

        echo ""
        echo -e "${BOLD}Benchmark:${RESET}"
        if [[ "$regression" == "yes" ]]; then
            echo -e "  ${RED}●${RESET} Score: ${old_bench} → ${cur_bench} (${diff_pct}%)  ${RED}REGRESSION DETECTED${RESET}"
            warn "Benchmark score dropped more than ${BENCHMARK_REGRESSION_THRESHOLD}%!"
            warn "Gaming performance may be degraded."
        else
            local bench_color="$GREEN"
            echo "$diff_pct" | grep -q "^-" && bench_color="$YELLOW"
            echo -e "  ${bench_color}●${RESET} Score: ${old_bench} → ${cur_bench} (${diff_pct}%)"
        fi
    fi

    separator
    echo ""
}

###############################################################################
# Pre-Update — Run before applying an update
###############################################################################
cmd_pre_update() {
    local auto_mode="${1:-false}"
    ensure_dirs

    echo -e "${BOLD}HubOS Update Guard — Pre-Update Check${RESET}"
    separator
    echo ""

    # Take a snapshot first
    info "Taking pre-update snapshot..."
    cmd_snapshot

    # Check pending update
    echo -e "${BOLD}Pending Update Analysis:${RESET}"
    separator

    if ! command -v rpm-ostree &>/dev/null; then
        warn "rpm-ostree not found — cannot analyze pending update"
        return 0
    fi

    # Show current vs pending deployments
    local status_output
    status_output=$(rpm-ostree status 2>/dev/null || echo "")

    if [[ -z "$status_output" ]]; then
        warn "Could not read rpm-ostree status"
        return 0
    fi

    echo "$status_output"
    echo ""

    # Check for risky changes by looking at pending deployment
    local pending_info
    pending_info=$(rpm-ostree status --json 2>/dev/null || echo "{}")

    local warnings=()

    # Parse for kernel changes
    local pending_kernel
    pending_kernel=$(echo "$pending_info" | python3 -c "
import sys, json
data = json.load(sys.stdin)
deploys = data.get('deployments', [])
for d in deploys:
    if not d.get('booted', False):
        version = d.get('version', '')
        print(version)
        break
" 2>/dev/null || echo "")

    local current_kernel
    current_kernel=$(get_kernel_version)

    # Extract major version for comparison
    local cur_major cur_minor
    cur_major=$(echo "$current_kernel" | cut -d. -f1)
    cur_minor=$(echo "$current_kernel" | cut -d. -f2)

    if [[ -n "$pending_kernel" ]]; then
        info "Pending deployment version: ${pending_kernel}"
    fi

    # Check diff of packages if available
    local diff_output
    diff_output=$(rpm-ostree db diff 2>/dev/null || echo "")

    if [[ -n "$diff_output" ]]; then
        echo ""
        echo -e "${BOLD}Package Changes:${RESET}"
        echo "$diff_output" | head -50

        # Check for risky package updates
        if echo "$diff_output" | grep -qi "kernel"; then
            warnings+=("Kernel version change detected — GPU drivers may need rebuilding")
        fi
        if echo "$diff_output" | grep -qi "mesa"; then
            local old_mesa_pkg new_mesa_pkg
            old_mesa_pkg=$(echo "$diff_output" | grep -i "mesa" | grep "^-" | head -1 || true)
            new_mesa_pkg=$(echo "$diff_output" | grep -i "mesa" | grep "^+" | head -1 || true)
            warnings+=("Mesa update: ${old_mesa_pkg:-unknown} → ${new_mesa_pkg:-unknown}")
        fi
        if echo "$diff_output" | grep -qi "nvidia"; then
            warnings+=("NVIDIA driver change — may require reboot and module rebuild")
        fi
        if echo "$diff_output" | grep -qi "pipewire"; then
            warnings+=("PipeWire update — audio configuration may need adjustment")
        fi
    fi

    echo ""

    # Show warnings
    if [[ ${#warnings[@]} -gt 0 ]]; then
        echo -e "${YELLOW}${BOLD}Advisories:${RESET}"
        for w in "${warnings[@]}"; do
            echo -e "  ${YELLOW}⚠${RESET} ${w}"
        done
        echo ""
    fi

    # If auto mode, don't ask
    if [[ "$auto_mode" == "true" || "$auto_mode" == "--auto" ]]; then
        info "Auto mode — proceeding with update"
        return 0
    fi

    # Ask user
    echo -ne "${BOLD}Proceed with update? [Y/n]${RESET} "
    read -r answer
    case "${answer:-Y}" in
        [Yy]*|"")
            ok "Proceeding with update..."
            return 0
            ;;
        *)
            info "Update cancelled."
            exit 0
            ;;
    esac
}

###############################################################################
# Post-Update — Run after reboot with new update
###############################################################################
cmd_post_update() {
    ensure_dirs

    echo -e "${BOLD}HubOS Update Guard — Post-Update Health Check${RESET}"
    separator
    echo ""

    # Find the pre-update snapshot (most recent)
    local snap_file
    snap_file=$(get_latest_snapshot)
    if [[ -z "$snap_file" ]]; then
        warn "No pre-update snapshot found. Running health check without comparison."
    fi

    local issues=()
    local report_lines=()

    # Read old values if snapshot exists
    local old_kernel="" old_nvidia="" old_mesa="" old_vulkan="" old_bench="0"
    if [[ -n "$snap_file" ]]; then
        old_kernel=$(python3 -c "import json; print(json.load(open('${snap_file}'))['kernel'])")
        old_nvidia=$(python3 -c "import json; print(json.load(open('${snap_file}'))['nvidia_driver'])")
        old_mesa=$(python3 -c "import json; print(json.load(open('${snap_file}'))['mesa'])")
        old_vulkan=$(python3 -c "import json; print(json.load(open('${snap_file}'))['vulkan_version'])")
        old_bench=$(python3 -c "import json; print(json.load(open('${snap_file}'))['benchmark_score'])")
    fi

    # Get current values
    local cur_kernel cur_nvidia cur_mesa

    cur_kernel=$(get_kernel_version)
    cur_nvidia=$(get_nvidia_version)
    cur_mesa=$(get_mesa_version)

    # Version comparison lines
    if [[ -n "$old_kernel" && "$old_kernel" != "$cur_kernel" ]]; then
        report_lines+=("Kernel:     ${old_kernel} → ${cur_kernel}  ${GREEN}✓${RESET}")
    else
        report_lines+=("Kernel:     ${cur_kernel}  ${DIM}(unchanged)${RESET}")
    fi

    if [[ -n "$old_mesa" && "$old_mesa" != "$cur_mesa" ]]; then
        report_lines+=("Mesa:       ${old_mesa} → ${cur_mesa}  ${GREEN}✓${RESET}")
    else
        report_lines+=("Mesa:       ${cur_mesa}  ${DIM}(unchanged)${RESET}")
    fi

    if [[ -n "$old_nvidia" && "$old_nvidia" != "$cur_nvidia" ]]; then
        report_lines+=("NVIDIA:     ${old_nvidia} → ${cur_nvidia}  ${GREEN}✓${RESET}")
    else
        report_lines+=("NVIDIA:     ${cur_nvidia}  ${DIM}(unchanged)${RESET}")
    fi

    # Health checks
    echo -e "${BOLD}Running health checks...${RESET}"
    echo ""

    # Vulkan check
    local vulkan_ok="false"
    if command -v vulkaninfo &>/dev/null && vulkaninfo --summary &>/dev/null; then
        vulkan_ok="true"
        report_lines+=("Vulkan:     Working  ${GREEN}✓${RESET}")
    else
        report_lines+=("Vulkan:     ${RED}FAILED${RESET}  ${RED}✗${RESET}")
        issues+=("Vulkan is not working — 3D games will not run")
    fi

    # GPU driver check
    local gpu_mod
    gpu_mod=$(get_gpu_driver_loaded)
    if [[ "$gpu_mod" != "unknown" ]]; then
        report_lines+=("GPU Driver: ${gpu_mod} loaded  ${GREEN}✓${RESET}")
    else
        report_lines+=("GPU Driver: ${RED}NOT LOADED${RESET}  ${RED}✗${RESET}")
        issues+=("No GPU driver module loaded — graphics may be broken")
    fi

    # Audio check (PipeWire)
    if pgrep -x pipewire &>/dev/null; then
        report_lines+=("Audio:      PipeWire running  ${GREEN}✓${RESET}")
    else
        report_lines+=("Audio:      ${RED}PipeWire not running${RESET}  ${RED}✗${RESET}")
        issues+=("PipeWire is not running — no audio")
    fi

    # Compositor check (KWin)
    if pgrep -x kwin_wayland &>/dev/null || pgrep -x kwin_x11 &>/dev/null; then
        report_lines+=("Compositor: KWin running  ${GREEN}✓${RESET}")
    else
        report_lines+=("Compositor: ${YELLOW}KWin not detected${RESET}  ${YELLOW}~${RESET}")
    fi

    # Steam check
    if command -v steam &>/dev/null; then
        report_lines+=("Steam:      Installed  ${GREEN}✓${RESET}")
    else
        report_lines+=("Steam:      ${RED}Not found${RESET}  ${RED}✗${RESET}")
        issues+=("Steam is not installed or not in PATH")
    fi

    # Benchmark
    info "Running benchmark..."
    local cur_bench
    cur_bench=$(run_benchmark)

    if [[ "$old_bench" -gt 0 ]]; then
        local bench_pct
        bench_pct=$(python3 -c "
old = ${old_bench}
new = ${cur_bench}
pct = ((new - old) / old) * 100
print(f'{pct:+.1f}')
")
        local regression
        regression=$(python3 -c "print('yes' if (${old_bench} - ${cur_bench}) / ${old_bench} * 100 > ${BENCHMARK_REGRESSION_THRESHOLD} else 'no')")

        if [[ "$regression" == "yes" ]]; then
            report_lines+=("Benchmark:  Score ${old_bench} → ${cur_bench} (${bench_pct}%)  ${RED}✗${RESET}")
            issues+=("Benchmark score dropped more than ${BENCHMARK_REGRESSION_THRESHOLD}% — possible performance regression")
        else
            report_lines+=("Benchmark:  Score ${old_bench} → ${cur_bench} (${bench_pct}%)  ${GREEN}✓${RESET}")
        fi
    else
        report_lines+=("Benchmark:  Score ${cur_bench}  ${DIM}(no baseline)${RESET}")
    fi

    # Take post-update snapshot
    info "Saving post-update snapshot..."
    local post_sid
    post_sid=$(generate_snapshot_id)
    local post_snap="${SNAPSHOT_DIR}/${post_sid}.json"
    local timestamp
    timestamp=$(date -Iseconds)

    cat > "$post_snap" <<SNAPEOF
{
  "id": "${post_sid}",
  "timestamp": "${timestamp}",
  "kernel": "$(json_escape "$cur_kernel")",
  "nvidia_driver": "$(json_escape "$cur_nvidia")",
  "mesa": "$(json_escape "$cur_mesa")",
  "vulkan_version": "$(json_escape "$(get_vulkan_version)")",
  "vulkan_driver": "$(json_escape "$(get_vulkan_driver)")",
  "proton_versions": $(get_proton_versions),
  "dxvk": "$(json_escape "$(get_dxvk_version)")",
  "pipewire": "$(json_escape "$(get_pipewire_version)")",
  "plasma": "$(json_escape "$(get_plasma_version)")",
  "gamescope": "$(json_escape "$(get_gamescope_version)")",
  "mangohud": "$(json_escape "$(get_mangohud_version)")",
  "deployment_hash": "$(json_escape "$(get_deployment_hash)")",
  "gpu_module": "$(json_escape "$gpu_mod")",
  "layered_packages": $(get_layered_packages),
  "benchmark_score": ${cur_bench},
  "post_update": true
}
SNAPEOF

    # Update history
    local hist_action="post-update"
    [[ ${#issues[@]} -gt 0 ]] && hist_action="post-update-issues"

    python3 -c "
import json
hist_path = '${HISTORY_FILE}'
with open(hist_path, 'r') as f:
    hist = json.load(f)
entry = {
    'snapshot_id': '${post_sid}',
    'timestamp': '${timestamp}',
    'action': '${hist_action}',
    'benchmark_score': ${cur_bench},
    'issues': ${#issues[@]}
}
hist.append(entry)
with open(hist_path, 'w') as f:
    json.dump(hist, f, indent=2)
"

    # Print report
    echo ""
    echo -e "${BOLD}Update Health Check${RESET}"
    separator
    for line in "${report_lines[@]}"; do
        echo -e "  ${line}"
    done
    separator

    if [[ ${#issues[@]} -eq 0 ]]; then
        echo ""
        echo -e "  ${GREEN}${BOLD}All clear! Gaming should work fine.${RESET}"
        notify_desktop "Update Health Check" "All clear! Gaming should work fine." "dialog-positive"
    else
        echo ""
        echo -e "  ${RED}${BOLD}Problems detected:${RESET}"
        for issue in "${issues[@]}"; do
            echo -e "  ${RED}✗${RESET} ${issue}"
        done
        echo ""
        warn "Run '${APP_NAME} rollback' to go back to the previous version."
        notify_desktop "Update Health Check — Issues Found" "Problems detected after update. Run hubos-update-guard rollback to revert." "dialog-warning"
    fi
    echo ""
}

###############################################################################
# Rollback
###############################################################################
cmd_rollback() {
    echo -e "${BOLD}HubOS Update Guard — Rollback${RESET}"
    separator
    echo ""

    if ! command -v rpm-ostree &>/dev/null; then
        die "rpm-ostree not found. Rollback requires Fedora Atomic (rpm-ostree)."
    fi

    # Show current deployments
    info "Current deployments:"
    echo ""
    rpm-ostree status 2>/dev/null || true
    echo ""

    # Parse deployments
    local deploy_count
    deploy_count=$(rpm-ostree status --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
print(len(data.get('deployments', [])))
" 2>/dev/null || echo "0")

    if [[ "$deploy_count" -lt 2 ]]; then
        die "No previous deployment to rollback to."
    fi

    # Show what will change
    local booted_version pending_version
    booted_version=$(rpm-ostree status --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
for d in data.get('deployments', []):
    if d.get('booted', False):
        print(d.get('version', d.get('checksum', 'unknown')[:12]))
        break
" 2>/dev/null || echo "unknown")

    pending_version=$(rpm-ostree status --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
for d in data.get('deployments', []):
    if not d.get('booted', False):
        print(d.get('version', d.get('checksum', 'unknown')[:12]))
        break
" 2>/dev/null || echo "unknown")

    echo -e "${BOLD}Rollback plan:${RESET}"
    echo -e "  Current: ${RED}${booted_version}${RESET}"
    echo -e "  Target:  ${GREEN}${pending_version}${RESET}"
    echo ""

    # Confirm
    echo -ne "${BOLD}Proceed with rollback? [y/N]${RESET} "
    read -r answer
    case "${answer}" in
        [Yy]*)
            info "Rolling back..."
            rpm-ostree rollback

            # Record in history
            python3 -c "
import json
from datetime import datetime
hist_path = '${HISTORY_FILE}'
with open(hist_path, 'r') as f:
    hist = json.load(f)
entry = {
    'timestamp': datetime.now().isoformat(),
    'action': 'rollback',
    'from_version': '${booted_version}',
    'to_version': '${pending_version}'
}
hist.append(entry)
with open(hist_path, 'w') as f:
    json.dump(hist, f, indent=2)
" 2>/dev/null || true

            echo ""
            ok "Rollback staged. A reboot is required."
            echo ""
            echo -ne "${BOLD}Reboot now? [y/N]${RESET} "
            read -r reboot_answer
            case "${reboot_answer}" in
                [Yy]*)
                    info "Rebooting..."
                    systemctl reboot
                    ;;
                *)
                    info "Reboot when ready: ${BOLD}systemctl reboot${RESET}"
                    ;;
            esac
            ;;
        *)
            info "Rollback cancelled."
            ;;
    esac
}

###############################################################################
# History
###############################################################################
cmd_history() {
    ensure_dirs

    echo -e "${BOLD}HubOS Update Guard — Update History${RESET}"
    separator
    echo ""

    if [[ ! -f "$HISTORY_FILE" ]]; then
        info "No history yet."
        return 0
    fi

    python3 -c "
import json
from datetime import datetime

hist_path = '${HISTORY_FILE}'
with open(hist_path, 'r') as f:
    hist = json.load(f)

if not hist:
    print('  No history entries yet.')
    exit(0)

# Colors (ANSI)
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
RED = '\033[0;31m'
CYAN = '\033[0;36m'
BOLD = '\033[1m'
DIM = '\033[2m'
RESET = '\033[0m'

prev_score = None
for entry in hist:
    ts = entry.get('timestamp', 'unknown')
    action = entry.get('action', 'unknown')
    score = entry.get('benchmark_score', None)
    issues = entry.get('issues', 0)

    # Parse timestamp for display
    try:
        dt = datetime.fromisoformat(ts)
        date_str = dt.strftime('%B %d, %Y %H:%M')
    except:
        date_str = ts

    # Action icon and color
    if action == 'snapshot':
        icon = f'{CYAN}📸{RESET}'
        desc = 'Snapshot taken'
    elif action == 'post-update':
        icon = f'{GREEN}✓{RESET}'
        desc = 'Post-update check — all clear'
    elif action == 'post-update-issues':
        icon = f'{RED}✗{RESET}'
        desc = f'Post-update check — {issues} issue(s) found'
    elif action == 'rollback':
        from_v = entry.get('from_version', '?')
        to_v = entry.get('to_version', '?')
        icon = f'{YELLOW}↩{RESET}'
        desc = f'Rolled back {from_v} → {to_v}'
    else:
        icon = f'{DIM}·{RESET}'
        desc = action

    line = f'  {icon} {BOLD}{date_str}{RESET}  {desc}'

    # Benchmark trend
    if score is not None:
        if prev_score is not None and prev_score > 0:
            pct = ((score - prev_score) / prev_score) * 100
            if pct < -10:
                line += f'  {RED}Score: {score} ({pct:+.1f}%) ▼{RESET}'
            elif pct < 0:
                line += f'  {YELLOW}Score: {score} ({pct:+.1f}%){RESET}'
            else:
                line += f'  {GREEN}Score: {score} ({pct:+.1f}%){RESET}'
        else:
            line += f'  {DIM}Score: {score}{RESET}'
        prev_score = score

    print(line)

print()

# Benchmark trend summary
scores = [e['benchmark_score'] for e in hist if 'benchmark_score' in e]
if len(scores) >= 2:
    trend = scores[-1] - scores[0]
    trend_pct = (trend / scores[0]) * 100 if scores[0] > 0 else 0
    if trend_pct >= 0:
        print(f'  {GREEN}Benchmark trend: {trend_pct:+.1f}% overall{RESET}')
    else:
        print(f'  {RED}Benchmark trend: {trend_pct:+.1f}% overall{RESET}')
"

    separator
    echo ""
}

###############################################################################
# Status
###############################################################################
cmd_status() {
    ensure_dirs

    echo -e "${BOLD}HubOS Update Guard — Gaming Stack Status${RESET}"
    separator
    echo ""

    # All versions
    echo -e "${BOLD}Component Versions:${RESET}"
    echo -e "  Kernel:       $(get_kernel_version)"
    echo -e "  NVIDIA:       $(get_nvidia_version)"
    echo -e "  Mesa:         $(get_mesa_version)"
    echo -e "  Vulkan:       $(get_vulkan_version) ($(get_vulkan_driver))"
    echo -e "  PipeWire:     $(get_pipewire_version)"
    echo -e "  Plasma:       $(get_plasma_version)"
    echo -e "  gamescope:    $(get_gamescope_version)"
    echo -e "  MangoHud:     $(get_mangohud_version)"
    echo -e "  GPU module:   $(get_gpu_driver_loaded)"
    echo -e "  Deployment:   $(get_deployment_hash)"

    local proton
    proton=$(get_proton_versions)
    local proton_count
    proton_count=$(echo "$proton" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
    echo -e "  Proton:       ${proton_count} versions"
    echo -e "  DXVK:         $(get_dxvk_version)"

    local layered
    layered=$(get_layered_packages)
    local layered_count
    layered_count=$(echo "$layered" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
    echo -e "  Layered pkgs: ${layered_count}"
    echo ""

    # Last snapshot
    local snap_file
    snap_file=$(get_latest_snapshot)
    if [[ -n "$snap_file" ]]; then
        local snap_ts
        snap_ts=$(python3 -c "import json; print(json.load(open('${snap_file}'))['timestamp'])" 2>/dev/null || echo "unknown")
        echo -e "${BOLD}Last Snapshot:${RESET} ${snap_ts}"
    else
        echo -e "${BOLD}Last Snapshot:${RESET} ${DIM}none${RESET}"
    fi

    # Pending updates
    echo ""
    echo -e "${BOLD}Pending Updates:${RESET}"
    if command -v rpm-ostree &>/dev/null; then
        local pending
        pending=$(rpm-ostree status --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
deploys = data.get('deployments', [])
has_pending = False
for d in deploys:
    if not d.get('booted', False) and not d.get('pinned', False):
        ver = d.get('version', d.get('checksum', 'unknown')[:12])
        print(f'  Pending: {ver}')
        has_pending = True
        break
if not has_pending:
    print('  No pending updates')
" 2>/dev/null || echo "  Could not check")
        echo -e "$pending"
    else
        echo -e "  ${DIM}rpm-ostree not available${RESET}"
    fi

    # Deployment health
    echo ""
    echo -e "${BOLD}Deployment Health:${RESET}"
    local health_score=0
    local health_max=6
    local health_items=()

    # Check Vulkan
    if command -v vulkaninfo &>/dev/null && vulkaninfo --summary &>/dev/null 2>&1; then
        health_items+=("${GREEN}✓${RESET} Vulkan")
        ((health_score++))
    else
        health_items+=("${RED}✗${RESET} Vulkan")
    fi

    # Check GPU driver
    local gpu
    gpu=$(get_gpu_driver_loaded)
    if [[ "$gpu" != "unknown" ]]; then
        health_items+=("${GREEN}✓${RESET} GPU driver (${gpu})")
        ((health_score++))
    else
        health_items+=("${RED}✗${RESET} GPU driver")
    fi

    # Check PipeWire
    if pgrep -x pipewire &>/dev/null; then
        health_items+=("${GREEN}✓${RESET} Audio (PipeWire)")
        ((health_score++))
    else
        health_items+=("${RED}✗${RESET} Audio")
    fi

    # Check compositor
    if pgrep -x kwin_wayland &>/dev/null || pgrep -x kwin_x11 &>/dev/null; then
        health_items+=("${GREEN}✓${RESET} Compositor (KWin)")
        ((health_score++))
    else
        health_items+=("${YELLOW}~${RESET} Compositor")
    fi

    # Check Steam
    if command -v steam &>/dev/null; then
        health_items+=("${GREEN}✓${RESET} Steam")
        ((health_score++))
    else
        health_items+=("${RED}✗${RESET} Steam")
    fi

    # Check gamescope
    if command -v gamescope &>/dev/null; then
        health_items+=("${GREEN}✓${RESET} gamescope")
        ((health_score++))
    else
        health_items+=("${YELLOW}~${RESET} gamescope")
    fi

    for item in "${health_items[@]}"; do
        echo -e "  ${item}"
    done

    echo ""

    # Overall score
    local readiness_pct=$(( health_score * 100 / health_max ))
    local readiness_color="$GREEN"
    [[ $readiness_pct -lt 80 ]] && readiness_color="$YELLOW"
    [[ $readiness_pct -lt 50 ]] && readiness_color="$RED"

    echo -e "${BOLD}Gaming Readiness:${RESET} ${readiness_color}${readiness_pct}%${RESET} (${health_score}/${health_max})"
    separator
    echo ""
}

###############################################################################
# Usage
###############################################################################
usage() {
    cat <<USAGE
${BOLD}HubOS Update Guard${RESET} v${VERSION}
Protect gaming performance across system updates.

${BOLD}Usage:${RESET}
  ${APP_NAME} <command> [options]

${BOLD}Commands:${RESET}
  snapshot        Save current gaming stack state
  check           Compare current state to last snapshot
  pre-update      Run before applying an update
  post-update     Run after reboot with new update
  rollback        Rollback to previous deployment
  history         Show update history with gaming health
  status          Current gaming stack status

${BOLD}Options:${RESET}
  --auto          Non-interactive mode (for pre-update)
  --help, -h      Show this help

${BOLD}Examples:${RESET}
  ${APP_NAME} snapshot              # Save current state
  ${APP_NAME} pre-update            # Check before updating
  ${APP_NAME} post-update           # Verify after reboot
  ${APP_NAME} rollback              # Go back if broken
  ${APP_NAME} check                 # See what changed
  ${APP_NAME} status                # Full stack overview

${BOLD}Integration:${RESET}
  Auto-update hook: hubos-update-guard-hook.sh
  Runs pre-update automatically before system updates.
USAGE
}

###############################################################################
# Main
###############################################################################
main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        snapshot)
            cmd_snapshot
            ;;
        check)
            cmd_check
            ;;
        pre-update)
            local auto_flag="${1:-false}"
            cmd_pre_update "$auto_flag"
            ;;
        post-update)
            cmd_post_update
            ;;
        rollback)
            cmd_rollback
            ;;
        history)
            cmd_history
            ;;
        status)
            cmd_status
            ;;
        --help|-h|help)
            usage
            ;;
        "")
            usage
            exit 1
            ;;
        *)
            err "Unknown command: ${cmd}"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
