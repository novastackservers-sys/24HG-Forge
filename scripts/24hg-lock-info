#!/usr/bin/env python3
"""
24hg-lock-info - Generate lock screen info overlay for 24HG.

Reads cached server status and hub state, outputs a formatted text block
suitable for rendering on the KDE lock screen or other overlay surfaces.
"""

import json
import os
import random
import sys
from datetime import datetime
from pathlib import Path

CACHE_DIR = Path.home() / ".cache" / "24hg"
SERVER_STATUS_FILE = CACHE_DIR / "server-status.json"
HUB_STATE_FILE = CACHE_DIR / "hub-state.json"

TIPS = [
    "Press Super+G to toggle Gaming Mode for max performance.",
    "Use 24hg-proton-fix if a game won't launch through Steam.",
    "Right-click the desktop for quick access to server status.",
    "Check 24hg-achievements to see your gaming milestones.",
    "Use 24hg-benchmark to test your system after driver updates.",
    "Join the 24HG Discord for community events and giveaways.",
    "24hg-diag creates a full system report for troubleshooting.",
    "Flatpak apps auto-update in the background. No action needed.",
    "Use 24hg-game-timer to track your playtime across all games.",
    "The 24HG Hub shows live player counts for every server.",
    "Toggle performance profiles with 24hg-performance.",
    "Screenshots are saved to ~/Pictures/Screenshots by default.",
    "Press Ctrl+Alt+T to open a terminal anywhere.",
    "Server status updates every 60 seconds in the background.",
]


def load_json(path: Path) -> dict | None:
    """Load a JSON file, returning None if missing or invalid."""
    try:
        with open(path, "r") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError, PermissionError):
        return None


def format_server_summary(status: dict | None) -> list[str]:
    """Format server status into display lines."""
    lines = []

    if not status or "servers" not in status:
        lines.append("Server status unavailable")
        return lines

    servers = status["servers"]
    total_players = sum(s.get("players", 0) for s in servers)
    online_servers = sum(1 for s in servers if s.get("online", False))
    total_servers = len(servers)

    lines.append(f"{total_players} players on {online_servers}/{total_servers} servers")

    # Top 3 most populated
    populated = sorted(servers, key=lambda s: s.get("players", 0), reverse=True)
    top = [s for s in populated[:3] if s.get("players", 0) > 0]

    if top:
        lines.append("")
        for s in top:
            name = s.get("name", "Unknown")
            players = s.get("players", 0)
            max_players = s.get("max_players", "?")
            lines.append(f"  {name}: {players}/{max_players}")

    return lines


def format_hub_info(hub: dict | None) -> list[str]:
    """Format hub state into display lines."""
    lines = []

    if not hub:
        return lines

    username = hub.get("username", "")
    unread = hub.get("unread", 0)

    if username:
        parts = [f"Hub: {username}"]
        if unread > 0:
            parts.append(f"{unread} unread")
        lines.append("  ".join(parts))

    return lines


def main():
    now = datetime.now()

    # Time and date
    time_str = now.strftime("%H:%M")
    date_str = now.strftime("%A, %B %-d")

    server_status = load_json(SERVER_STATUS_FILE)
    hub_state = load_json(HUB_STATE_FILE)

    tip = random.choice(TIPS)

    # Build output
    output = []
    output.append(time_str)
    output.append(date_str)
    output.append("")

    output.extend(format_server_summary(server_status))
    output.append("")

    hub_lines = format_hub_info(hub_state)
    if hub_lines:
        output.extend(hub_lines)
        output.append("")

    output.append(f"Tip: {tip}")

    print("\n".join(output))


if __name__ == "__main__":
    main()
