#!/usr/bin/env bash
# 24HG Dual-Boot Helper
# Dual-boot management for Windows+24HG (Bazzite/Fedora Atomic) systems
# Handles UEFI and Legacy BIOS, ostree/BLS GRUB setups, shared game storage,
# time sync fixes, BitLocker safety, and quick cross-OS rebooting.
#
# Usage: 24hg-dualboot [--gui] <command> [args]
# Commands: status, detect, quick-reboot, fix-grub, shared-games, time-fix, bitlocker-check

set -euo pipefail

# ── Global Configuration ─────────────────────────────────────────────────────

readonly VERSION="1.0.0"
readonly SCRIPT_NAME="24hg-dualboot"
readonly WINDOWS_MOUNT="/mnt/windows"
readonly SHARED_MOUNT="/mnt/games"
readonly GRUB_DEFAULT="/etc/default/grub"
readonly GRUB_OSTREE_CFG="/boot/loader/entries"
readonly FSTAB="/etc/fstab"

GUI_MODE=false
POSITIONAL_ARGS=()

# ── Colors & Formatting ──────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Disable colors if not a terminal
if [[ ! -t 1 ]]; then
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA='' BOLD='' DIM='' NC=''
fi

# ── Logging Helpers ───────────────────────────────────────────────────────────

info()    { echo -e "${BLUE}[INFO]${NC}    $*"; }
ok()      { echo -e "${GREEN}[OK]${NC}      $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}    $*"; }
err()     { echo -e "${RED}[ERROR]${NC}   $*"; }
header()  { echo -e "\n${BOLD}${CYAN}── $* ──${NC}"; }
detail()  { echo -e "  ${DIM}$*${NC}"; }
bullet()  { echo -e "  ${MAGENTA}*${NC} $*"; }

# ── GUI Helpers (zenity) ─────────────────────────────────────────────────────

gui_available() {
    $GUI_MODE && command -v zenity &>/dev/null
}

gui_info() {
    if gui_available; then
        zenity --info --title="24HG Dual-Boot" --text="$*" --width=400 2>/dev/null &
    fi
}

gui_warn() {
    if gui_available; then
        zenity --warning --title="24HG Dual-Boot" --text="$*" --width=400 2>/dev/null
    fi
}

gui_error() {
    if gui_available; then
        zenity --error --title="24HG Dual-Boot" --text="$*" --width=400 2>/dev/null
    fi
}

gui_confirm() {
    if gui_available; then
        zenity --question --title="24HG Dual-Boot" --text="$*" --width=400 2>/dev/null
        return $?
    else
        local response
        read -rp "$* [y/N] " response
        [[ "$response" =~ ^[Yy]$ ]]
    fi
}

gui_select() {
    local title="$1"; shift
    if gui_available; then
        zenity --list --title="$title" --column="Option" "$@" --width=500 --height=400 2>/dev/null
    fi
}

gui_notify() {
    local summary="$1"
    local body="${2:-}"
    if command -v notify-send &>/dev/null; then
        notify-send -i system-reboot "$summary" "$body" 2>/dev/null || true
    fi
}

# ── Privilege Handling ────────────────────────────────────────────────────────

require_sudo() {
    local reason="${1:-This operation requires root privileges.}"
    if [[ $EUID -ne 0 ]]; then
        warn "Requesting sudo: $reason"
        if gui_available; then
            if ! pkexec --disable-internal-agent echo "Authorized" &>/dev/null; then
                gui_error "Root access denied. Cannot proceed."
                exit 1
            fi
        fi
        err "This command must be run with sudo."
        info "Reason: $reason"
        echo ""
        info "Usage: sudo $SCRIPT_NAME ${POSITIONAL_ARGS[*]:-}"
        exit 1
    fi
}

# ── System Detection Helpers ──────────────────────────────────────────────────

is_efi() {
    [[ -d /sys/firmware/efi ]]
}

is_ostree() {
    [[ -f /run/ostree-booted ]] || rpm-ostree status &>/dev/null 2>&1
}

is_bazzite() {
    if [[ -f /etc/os-release ]]; then
        grep -qi "bazzite" /etc/os-release 2>/dev/null && return 0
    fi
    if is_ostree && rpm-ostree status 2>/dev/null | grep -qi "bazzite"; then
        return 0
    fi
    return 1
}

find_grub_mkconfig() {
    if command -v grub2-mkconfig &>/dev/null; then
        echo "grub2-mkconfig"
    elif command -v grub-mkconfig &>/dev/null; then
        echo "grub-mkconfig"
    else
        err "grub-mkconfig not found. Is GRUB installed?"
        return 1
    fi
}

find_grub_cfg() {
    # Bazzite/Fedora Atomic uses specific paths
    for path in \
        /boot/grub2/grub.cfg \
        /boot/efi/EFI/fedora/grub.cfg \
        /boot/efi/EFI/BOOT/grub.cfg \
        /boot/grub/grub.cfg; do
        if [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    # Derive from mkconfig location
    local mkconfig
    mkconfig=$(find_grub_mkconfig 2>/dev/null || echo "")
    if [[ "$mkconfig" == "grub2-mkconfig" ]]; then
        echo "/boot/grub2/grub.cfg"
    else
        echo "/boot/grub/grub.cfg"
    fi
}

find_grub_reboot() {
    if command -v grub2-reboot &>/dev/null; then
        echo "grub2-reboot"
    elif command -v grub-reboot &>/dev/null; then
        echo "grub-reboot"
    else
        return 1
    fi
}

find_grub_set_default() {
    if command -v grub2-set-default &>/dev/null; then
        echo "grub2-set-default"
    elif command -v grub-set-default &>/dev/null; then
        echo "grub-set-default"
    else
        return 1
    fi
}

# ── Partition & Windows Helpers ───────────────────────────────────────────────

# Mount a partition temporarily, run a callback, unmount
with_temp_mount() {
    local dev="$1"
    local callback="$2"
    local tmpdir
    tmpdir=$(mktemp -d "/tmp/24hg-dualboot.XXXXXX")

    local mounted=false
    if mount -t ntfs3 -o ro,noexec "$dev" "$tmpdir" 2>/dev/null; then
        mounted=true
    elif mount -t ntfs-3g -o ro,noexec "$dev" "$tmpdir" 2>/dev/null; then
        mounted=true
    fi

    if $mounted; then
        $callback "$tmpdir" "$dev"
        umount "$tmpdir" 2>/dev/null || true
    fi
    rmdir "$tmpdir" 2>/dev/null || true
    $mounted
}

_check_win_callback() {
    [[ -d "$1/Windows/System32" ]]
}

is_windows_partition() {
    local dev="$1"
    with_temp_mount "$dev" _check_win_callback 2>/dev/null
}

get_windows_version() {
    local mountpoint="$1"
    if [[ -d "$mountpoint/Windows/SystemApps/Microsoft.Windows.StartMenuExperienceHost_cw5n1h2txyewy" ]]; then
        echo "Windows 11"
    elif [[ -d "$mountpoint/Windows/SystemApps/MicrosoftWindows.Client.CBS_cw5n1h2txyewy" ]]; then
        echo "Windows 11"
    elif [[ -d "$mountpoint/Windows/SystemApps/Microsoft.Windows.Cortana_cw5n1h2txyewy" ]]; then
        echo "Windows 10"
    elif [[ -d "$mountpoint/Windows/SystemApps" ]]; then
        echo "Windows 10/11"
    elif [[ -f "$mountpoint/Windows/explorer.exe" ]]; then
        echo "Windows (pre-10)"
    else
        echo "Windows (unknown version)"
    fi
}

get_partition_info() {
    local dev="$1"
    local size fstype label uuid
    size=$(lsblk -ndo SIZE "$dev" 2>/dev/null || echo "?")
    fstype=$(blkid -o value -s TYPE "$dev" 2>/dev/null || echo "?")
    label=$(blkid -o value -s LABEL "$dev" 2>/dev/null || echo "")
    uuid=$(blkid -o value -s UUID "$dev" 2>/dev/null || echo "")
    echo "$size|$fstype|$label|$uuid"
}

is_mounted() {
    local dev="$1"
    findmnt -n "$dev" &>/dev/null 2>&1
}

get_mount_target() {
    local dev="$1"
    findmnt -n -o TARGET "$dev" 2>/dev/null | head -1
}

# Get GRUB menu entries (handles both traditional and BLS/ostree)
get_grub_entries() {
    local grub_cfg
    grub_cfg=$(find_grub_cfg 2>/dev/null || echo "")

    # First try BLS entries (Bazzite/Fedora Atomic)
    if [[ -d "$GRUB_OSTREE_CFG" ]]; then
        local idx=0
        for entry_file in "$GRUB_OSTREE_CFG"/*.conf; do
            [[ -f "$entry_file" ]] || continue
            local title
            title=$(grep "^title " "$entry_file" 2>/dev/null | sed 's/^title //' || echo "$(basename "$entry_file")")
            echo "$idx|bls|$title"
            ((idx++))
        done
    fi

    # Then check traditional grub.cfg menuentry lines
    if [[ -f "$grub_cfg" ]]; then
        local idx=0
        while IFS= read -r entry; do
            echo "$idx|grub|$entry"
            ((idx++))
        done < <(grep -oP "(?<=menuentry ['\"]).*?(?=['\"])" "$grub_cfg" 2>/dev/null || true)
    fi
}

find_windows_grub_entry() {
    local entry_id=""
    while IFS='|' read -r idx type title; do
        if echo "$title" | grep -qi "windows"; then
            echo "$idx|$type|$title"
            return 0
        fi
    done < <(get_grub_entries)
    return 1
}

find_linux_grub_entry() {
    local entry_id=""
    while IFS='|' read -r idx type title; do
        if echo "$title" | grep -qi "24hg\|bazzite\|fedora\|linux\|gnu"; then
            echo "$idx|$type|$title"
            return 0
        fi
    done < <(get_grub_entries)
    # Default to first entry
    get_grub_entries | head -1
}

_check_hib_callback() {
    if [[ -f "$1/hiberfil.sys" ]]; then
        local size
        size=$(stat -c%s "$1/hiberfil.sys" 2>/dev/null || echo 0)
        [[ "$size" -gt 0 ]]
    else
        return 1
    fi
}

check_hibernation() {
    local dev="$1"
    with_temp_mount "$dev" _check_hib_callback 2>/dev/null
}

is_bitlocker() {
    local dev="$1"
    local blkid_out
    blkid_out=$(blkid "$dev" 2>/dev/null || true)
    if echo "$blkid_out" | grep -qi "BitLocker"; then
        return 0
    fi
    # Also check raw signature: BitLocker volumes start with -FVE-FS-
    if dd if="$dev" bs=1 count=16 skip=3 2>/dev/null | grep -q "FVE-FS" 2>/dev/null; then
        return 0
    fi
    return 1
}

# ── Command: status ───────────────────────────────────────────────────────────

cmd_status() {
    header "Dual-Boot Overview"

    # Boot mode
    echo ""
    if is_efi; then
        info "Boot mode:   ${BOLD}UEFI${NC}"
    else
        info "Boot mode:   ${BOLD}Legacy BIOS${NC}"
    fi
    if is_ostree; then
        info "System type: ${BOLD}ostree (Fedora Atomic / Bazzite)${NC}"
    else
        info "System type: ${BOLD}Traditional${NC}"
    fi
    if is_bazzite; then
        info "Distro:      ${BOLD}Bazzite (24HG base)${NC}"
    fi

    # GRUB / Boot entries
    header "Boot Menu Entries"
    local entry_count=0
    local seen_types=""
    while IFS='|' read -r idx type title; do
        [[ -z "$title" ]] && continue
        local marker=""
        if echo "$title" | grep -qi "windows"; then
            marker=" ${YELLOW}<-- Windows${NC}"
        elif echo "$title" | grep -qi "24hg\|bazzite\|fedora\|linux"; then
            marker=" ${GREEN}<-- Linux${NC}"
        fi
        echo -e "  ${DIM}[$type:$idx]${NC} $title$marker"
        ((entry_count++))
        seen_types="$seen_types $type"
    done < <(get_grub_entries)

    if [[ $entry_count -eq 0 ]]; then
        warn "No boot entries found. GRUB may need repair."
    fi

    # Default and timeout
    echo ""
    if [[ -f "$GRUB_DEFAULT" ]]; then
        local grub_default grub_timeout grub_style
        grub_default=$(grep "^GRUB_DEFAULT=" "$GRUB_DEFAULT" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "0")
        grub_timeout=$(grep "^GRUB_TIMEOUT=" "$GRUB_DEFAULT" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "5")
        grub_style=$(grep "^GRUB_TIMEOUT_STYLE=" "$GRUB_DEFAULT" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "menu")
        info "Default boot:  ${BOLD}$grub_default${NC}"
        info "Timeout:       ${BOLD}${grub_timeout}s${NC} (style: $grub_style)"

        local os_prober_state
        if grep -q "^GRUB_DISABLE_OS_PROBER=false" "$GRUB_DEFAULT" 2>/dev/null; then
            os_prober_state="${GREEN}enabled${NC}"
        elif grep -q "^GRUB_DISABLE_OS_PROBER=true" "$GRUB_DEFAULT" 2>/dev/null; then
            os_prober_state="${RED}disabled${NC}"
        else
            os_prober_state="${YELLOW}not set (distro default)${NC}"
        fi
        info "os-prober:     $os_prober_state"
    fi

    # Windows partition info
    header "Windows Partitions"
    local win_found=false
    while IFS= read -r line; do
        local dev
        dev="/dev/$(echo "$line" | awk '{print $1}')"
        local fstype
        fstype=$(echo "$line" | awk '{print $3}')
        [[ "$fstype" != "ntfs" && "$fstype" != "ntfs3" ]] && continue

        local pinfo version
        pinfo=$(get_partition_info "$dev")
        local p_size p_fs p_label p_uuid
        IFS='|' read -r p_size p_fs p_label p_uuid <<< "$pinfo"

        # Try to detect if it is a Windows OS partition
        local tmpdir
        tmpdir=$(mktemp -d "/tmp/24hg-db-stat.XXXXXX")
        local is_win=false
        if mount -t ntfs3 -o ro,noexec "$dev" "$tmpdir" 2>/dev/null || \
           mount -t ntfs-3g -o ro,noexec "$dev" "$tmpdir" 2>/dev/null; then
            if [[ -d "$tmpdir/Windows/System32" ]]; then
                is_win=true
                version=$(get_windows_version "$tmpdir")
            fi
            umount "$tmpdir" 2>/dev/null || true
        fi
        rmdir "$tmpdir" 2>/dev/null || true

        if $is_win; then
            win_found=true
            local mount_status="not mounted"
            if is_mounted "$dev"; then
                mount_status="mounted at $(get_mount_target "$dev")"
            fi
            echo -e "  ${CYAN}$dev${NC}  ${BOLD}$version${NC}"
            echo -e "    Size: $p_size | FS: $p_fs | Label: ${p_label:-none} | $mount_status"
            if check_hibernation "$dev" 2>/dev/null; then
                echo -e "    ${YELLOW}Warning: Fast Startup / hibernation detected${NC}"
            fi
            if is_bitlocker "$dev" 2>/dev/null; then
                echo -e "    ${RED}Warning: BitLocker encryption detected${NC}"
            fi
        fi
    done < <(lsblk -rno NAME,MAJ:MIN,FSTYPE,TYPE 2>/dev/null | awk '$4=="part"')

    if ! $win_found; then
        info "No Windows OS partitions detected."
    fi

    # EFI partition contents
    if is_efi; then
        header "EFI System Partition"
        local efi_mount=""
        for p in /boot/efi /efi; do
            if mountpoint -q "$p" 2>/dev/null; then
                efi_mount="$p"
                break
            fi
        done
        if [[ -n "$efi_mount" ]]; then
            info "Mounted at: $efi_mount"
            if [[ -d "$efi_mount/EFI" ]]; then
                echo "  Contents:"
                for entry_dir in "$efi_mount/EFI"/*/; do
                    [[ -d "$entry_dir" ]] || continue
                    local dirname
                    dirname=$(basename "$entry_dir")
                    local marker=""
                    case "${dirname,,}" in
                        microsoft) marker=" ${YELLOW}(Windows Boot Manager)${NC}" ;;
                        fedora|24hg|bazzite) marker=" ${GREEN}(Linux)${NC}" ;;
                        boot) marker=" ${DIM}(fallback)${NC}" ;;
                    esac
                    echo -e "    ${CYAN}$dirname/${NC}$marker"
                done
            fi
        else
            warn "EFI partition not mounted at expected locations."
        fi

        if command -v efibootmgr &>/dev/null; then
            echo ""
            info "EFI boot entries:"
            efibootmgr 2>/dev/null | grep -E "^Boot[0-9A-Fa-f]" | while IFS= read -r line; do
                echo "    $line"
            done
            local boot_order
            boot_order=$(efibootmgr 2>/dev/null | grep "^BootOrder:" || true)
            [[ -n "$boot_order" ]] && echo "    $boot_order"
            local boot_next
            boot_next=$(efibootmgr 2>/dev/null | grep "^BootNext:" || true)
            if [[ -n "$boot_next" ]]; then
                echo -e "    ${YELLOW}$boot_next${NC}"
            fi
        fi
    fi

    # Shared NTFS/exFAT partitions
    header "Shared Partitions (NTFS/exFAT)"
    local shared_found=false
    while IFS= read -r line; do
        local dev
        dev="/dev/$(echo "$line" | awk '{print $1}')"
        local size fstype
        size=$(echo "$line" | awk '{print $2}')
        fstype=$(echo "$line" | awk '{print $3}')
        [[ "$fstype" != "ntfs" && "$fstype" != "ntfs3" && "$fstype" != "exfat" ]] && continue

        # Skip small partitions (likely EFI/recovery)
        local size_bytes
        size_bytes=$(blockdev --getsize64 "$dev" 2>/dev/null || echo 0)
        [[ "$size_bytes" -lt 1073741824 ]] && continue  # Skip < 1GB

        local label
        label=$(blkid -o value -s LABEL "$dev" 2>/dev/null || echo "")
        local mount_status="not mounted"
        if is_mounted "$dev"; then
            mount_status="mounted at $(get_mount_target "$dev")"
        fi
        shared_found=true
        echo -e "  ${CYAN}$dev${NC}  $size  $fstype  ${label:+($label)  }$mount_status"
    done < <(lsblk -rno NAME,SIZE,FSTYPE,TYPE 2>/dev/null | awk '$4=="part"')

    if ! $shared_found; then
        info "No shared NTFS/exFAT partitions found."
    fi

    # Shared games mount
    echo ""
    if mountpoint -q "$SHARED_MOUNT" 2>/dev/null; then
        local shared_dev shared_info
        shared_dev=$(findmnt -n -o SOURCE "$SHARED_MOUNT" 2>/dev/null || echo "unknown")
        shared_info=$(df -h "$SHARED_MOUNT" 2>/dev/null | awk 'NR==2 {printf "Size: %s, Used: %s, Free: %s (%s)", $2, $3, $4, $5}')
        ok "Shared games: $SHARED_MOUNT ($shared_dev)"
        detail "$shared_info"
    elif grep -q "$SHARED_MOUNT" "$FSTAB" 2>/dev/null; then
        warn "Shared games configured in fstab but not mounted."
        info "Run: sudo mount $SHARED_MOUNT"
    else
        info "Shared games not configured. Run: $SCRIPT_NAME shared-games"
    fi
}

# ── Command: detect ───────────────────────────────────────────────────────────

cmd_detect() {
    header "Detecting Windows Installations"

    # Scan all NTFS partitions
    info "Scanning partitions for Windows..."
    echo ""
    local win_count=0

    while IFS= read -r line; do
        local dev
        dev="/dev/$(echo "$line" | awk '{print $1}')"
        local fstype
        fstype=$(echo "$line" | awk '{print $3}')
        [[ "$fstype" != "ntfs" && "$fstype" != "ntfs3" ]] && continue

        local tmpdir
        tmpdir=$(mktemp -d "/tmp/24hg-db-det.XXXXXX")
        local found_win=false
        local version="Unknown"

        if mount -t ntfs3 -o ro,noexec "$dev" "$tmpdir" 2>/dev/null || \
           mount -t ntfs-3g -o ro,noexec "$dev" "$tmpdir" 2>/dev/null; then
            if [[ -d "$tmpdir/Windows/System32" ]]; then
                found_win=true
                version=$(get_windows_version "$tmpdir")

                # Try to read build number
                local build_info=""
                if [[ -f "$tmpdir/Windows/System32/ntoskrnl.exe" ]]; then
                    build_info="(ntoskrnl.exe present)"
                fi
            fi
            umount "$tmpdir" 2>/dev/null || true
        fi
        rmdir "$tmpdir" 2>/dev/null || true

        if $found_win; then
            ((win_count++))
            local pinfo
            pinfo=$(get_partition_info "$dev")
            local p_size p_fs p_label p_uuid
            IFS='|' read -r p_size p_fs p_label p_uuid <<< "$pinfo"

            ok "${BOLD}$version${NC} found on ${CYAN}$dev${NC}"
            detail "Size: $p_size | Filesystem: $p_fs | Label: ${p_label:-none}"
            detail "UUID: ${p_uuid:-unknown}"

            # Check for issues
            if check_hibernation "$dev" 2>/dev/null; then
                warn "  Hibernation/Fast Startup detected on $dev"
                detail "  Fix in Windows: powercfg /h off"
            fi
            if is_bitlocker "$dev" 2>/dev/null; then
                warn "  BitLocker encryption detected on $dev"
                detail "  Run: $SCRIPT_NAME bitlocker-check for guidance"
            fi
            echo ""
        fi
    done < <(lsblk -rno NAME,MAJ:MIN,FSTYPE,TYPE 2>/dev/null | awk '$4=="part"')

    if [[ $win_count -eq 0 ]]; then
        warn "No Windows installations found on any partition."
        echo ""
        info "Possible reasons:"
        detail "- Windows is on a separate physical disk not detected"
        detail "- Windows partition uses a non-standard layout"
        detail "- Partition is BitLocker-encrypted and unreadable"
    else
        ok "Found $win_count Windows installation(s)."
    fi

    # Check EFI boot entries
    echo ""
    if is_efi; then
        header "EFI Boot Entries"
        if command -v efibootmgr &>/dev/null; then
            local win_efi
            win_efi=$(efibootmgr -v 2>/dev/null | grep -i "windows" || true)
            if [[ -n "$win_efi" ]]; then
                ok "Windows EFI boot entry found:"
                echo "$win_efi" | sed 's/^/    /'
            else
                warn "No Windows EFI boot entry found."
                info "Windows may have been installed in Legacy/CSM mode."
            fi
            echo ""
            info "All EFI entries:"
            efibootmgr 2>/dev/null | grep -E "^Boot[0-9A-Fa-f]" | sed 's/^/    /'
        else
            warn "efibootmgr not installed."
            info "Install: sudo dnf install efibootmgr"
        fi
    else
        info "System boots in Legacy BIOS mode (no EFI entries)."
    fi

    # Run os-prober if available
    echo ""
    header "os-prober Results"
    if command -v os-prober &>/dev/null; then
        info "Running os-prober (may take a moment)..."
        local prober_out
        if [[ $EUID -eq 0 ]]; then
            prober_out=$(os-prober 2>/dev/null || true)
        else
            prober_out=$(sudo os-prober 2>/dev/null || true)
        fi
        if [[ -n "$prober_out" ]]; then
            ok "os-prober detected:"
            echo "$prober_out" | while IFS=: read -r part name boot_type; do
                echo -e "    ${CYAN}$part${NC} -- $name ($boot_type)"
            done
        else
            warn "os-prober found no other operating systems."
        fi
    else
        warn "os-prober is not installed. Auto-detection of boot entries limited."
        info "Install: sudo dnf install os-prober"
    fi

    # GRUB status
    echo ""
    header "GRUB Configuration"
    local grub_cfg
    grub_cfg=$(find_grub_cfg 2>/dev/null || echo "")
    if [[ -f "$grub_cfg" ]]; then
        local grub_win
        grub_win=$(grep -ci "windows" "$grub_cfg" 2>/dev/null || echo "0")
        if [[ "$grub_win" -gt 0 ]]; then
            ok "GRUB config ($grub_cfg) contains Windows entries."
        else
            warn "GRUB config has no Windows entries."
            info "Run: sudo $SCRIPT_NAME fix-grub"
        fi
    else
        warn "GRUB config not found at expected locations."
    fi

    if is_ostree; then
        info "This is an ostree system. BLS entries in $GRUB_OSTREE_CFG/ are also checked."
    fi
}

# ── Command: quick-reboot ────────────────────────────────────────────────────

cmd_quick_reboot() {
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        err "Usage: $SCRIPT_NAME quick-reboot <windows|24hg>"
        echo ""
        info "Examples:"
        detail "$SCRIPT_NAME quick-reboot windows   -- Reboot into Windows (one-time)"
        detail "$SCRIPT_NAME quick-reboot 24hg     -- Ensure next boot is 24HG"
        exit 1
    fi

    case "${target,,}" in
        windows|win) _quick_reboot_windows ;;
        24hg|linux) _quick_reboot_24hg ;;
        *)
            err "Unknown target: $target"
            info "Valid targets: windows, 24hg"
            exit 1
            ;;
    esac
}

_quick_reboot_windows() {
    require_sudo "Setting next boot to Windows and rebooting."

    header "Quick Reboot to Windows"

    local method="" entry_info=""

    # Method 1: EFI BootNext (preferred on UEFI systems)
    if is_efi && command -v efibootmgr &>/dev/null; then
        local win_efi_num
        win_efi_num=$(efibootmgr 2>/dev/null | grep -i "windows" | grep -oP 'Boot\K[0-9A-Fa-f]+' | head -1 || true)
        if [[ -n "$win_efi_num" ]]; then
            method="efi"
            entry_info="EFI Boot$win_efi_num (Windows Boot Manager)"
            info "Found Windows via EFI: Boot$win_efi_num"
        fi
    fi

    # Method 2: GRUB one-shot reboot
    if [[ -z "$method" ]]; then
        local win_entry
        win_entry=$(find_windows_grub_entry 2>/dev/null || true)
        if [[ -n "$win_entry" ]]; then
            local win_idx win_type win_title
            IFS='|' read -r win_idx win_type win_title <<< "$win_entry"
            method="grub"
            entry_info="GRUB entry #$win_idx: $win_title"
            info "Found Windows via GRUB: $win_title (index $win_idx)"
        fi
    fi

    if [[ -z "$method" ]]; then
        err "Cannot find a Windows boot entry."
        info "Run '$SCRIPT_NAME detect' to scan for Windows."
        info "Run 'sudo $SCRIPT_NAME fix-grub' to repair boot entries."
        if gui_available; then
            gui_error "Cannot find Windows boot entry.\n\nRun '24hg-dualboot detect' to scan."
        fi
        exit 1
    fi

    # Confirmation
    echo ""
    echo -e "${BOLD}${YELLOW}This will reboot your computer into Windows.${NC}"
    echo -e "  Target: ${CYAN}$entry_info${NC}"
    echo -e "  Method: $method"
    echo ""

    if ! gui_confirm "Reboot into Windows now?"; then
        info "Cancelled."
        exit 0
    fi

    # Set next boot
    if [[ "$method" == "efi" ]]; then
        local win_num
        win_num=$(efibootmgr 2>/dev/null | grep -i "windows" | grep -oP 'Boot\K[0-9A-Fa-f]+' | head -1)
        info "Setting EFI BootNext to $win_num..."
        efibootmgr --bootnext "$win_num" >/dev/null
        ok "EFI BootNext set to Windows (one-time)."
    elif [[ "$method" == "grub" ]]; then
        local win_idx
        win_idx=$(echo "$entry_info" | grep -oP '#\K[0-9]+')
        local grub_reboot_cmd
        grub_reboot_cmd=$(find_grub_reboot 2>/dev/null || true)
        if [[ -n "$grub_reboot_cmd" ]]; then
            info "Setting GRUB one-shot boot to entry $win_idx..."
            $grub_reboot_cmd "$win_idx"
            ok "GRUB set to boot Windows once."
        else
            err "grub-reboot / grub2-reboot command not found."
            exit 1
        fi
    fi

    # Countdown with notification
    echo ""
    gui_notify "Rebooting to Windows" "System will reboot in 5 seconds..."
    for i in 5 4 3 2 1; do
        echo -e "  Rebooting in ${BOLD}$i${NC}..."
        sleep 1
    done

    ok "Rebooting now."
    systemctl reboot
}

_quick_reboot_24hg() {
    require_sudo "Resetting next boot target to 24HG."

    header "Ensuring Next Boot is 24HG"

    # Clear any EFI BootNext pointing to Windows
    if is_efi && command -v efibootmgr &>/dev/null; then
        local bootnext
        bootnext=$(efibootmgr 2>/dev/null | grep "^BootNext:" | awk '{print $2}' || true)
        if [[ -n "$bootnext" ]]; then
            local next_name
            next_name=$(efibootmgr 2>/dev/null | grep "Boot${bootnext}" || true)
            info "Clearing BootNext: $next_name"
            efibootmgr --delete-bootnext >/dev/null 2>&1 || true
            ok "Cleared EFI BootNext."
        else
            ok "No EFI BootNext was set."
        fi
    fi

    # Reset GRUB default to Linux
    local grub_set_cmd
    grub_set_cmd=$(find_grub_set_default 2>/dev/null || true)
    if [[ -n "$grub_set_cmd" ]]; then
        local linux_entry
        linux_entry=$(find_linux_grub_entry 2>/dev/null || true)
        if [[ -n "$linux_entry" ]]; then
            local linux_idx
            IFS='|' read -r linux_idx _ _ <<< "$linux_entry"
            $grub_set_cmd "$linux_idx"
            ok "GRUB default set to entry #$linux_idx (24HG/Linux)."
        else
            $grub_set_cmd 0
            ok "GRUB default set to entry #0."
        fi
    fi

    ok "Next boot will be 24HG."
    gui_notify "Boot Target Reset" "Next boot will be 24HG/Linux."
}

# ── Command: fix-grub ─────────────────────────────────────────────────────────

cmd_fix_grub() {
    require_sudo "Regenerating GRUB configuration requires root."

    header "Fixing GRUB Boot Loader"

    local mkconfig grub_cfg
    mkconfig=$(find_grub_mkconfig 2>/dev/null || true)
    grub_cfg=$(find_grub_cfg 2>/dev/null || echo "")

    if [[ -z "$mkconfig" ]]; then
        err "Cannot find grub-mkconfig or grub2-mkconfig."
        exit 1
    fi

    info "GRUB config command: $mkconfig"
    info "GRUB config file:    $grub_cfg"
    if is_ostree; then
        info "ostree system detected. Will handle BLS entries."
    fi
    echo ""

    # Step 1: Enable os-prober
    header "Step 1: Enable os-prober"
    if [[ -f "$GRUB_DEFAULT" ]]; then
        local changed=false
        if grep -q "^GRUB_DISABLE_OS_PROBER=" "$GRUB_DEFAULT"; then
            local current
            current=$(grep "^GRUB_DISABLE_OS_PROBER=" "$GRUB_DEFAULT" | cut -d= -f2)
            if [[ "$current" != "false" ]]; then
                sed -i 's/^GRUB_DISABLE_OS_PROBER=.*/GRUB_DISABLE_OS_PROBER=false/' "$GRUB_DEFAULT"
                changed=true
            fi
        else
            echo "GRUB_DISABLE_OS_PROBER=false" >> "$GRUB_DEFAULT"
            changed=true
        fi
        if $changed; then
            ok "os-prober enabled in $GRUB_DEFAULT"
        else
            ok "os-prober was already enabled."
        fi
    else
        warn "$GRUB_DEFAULT not found. Cannot configure os-prober."
    fi

    # Step 2: Set sensible defaults for dual-boot
    header "Step 2: Configure GRUB Defaults"
    if [[ -f "$GRUB_DEFAULT" ]]; then
        # Ensure menu is visible
        if grep -q "^GRUB_TIMEOUT_STYLE=" "$GRUB_DEFAULT"; then
            sed -i 's/^GRUB_TIMEOUT_STYLE=.*/GRUB_TIMEOUT_STYLE=menu/' "$GRUB_DEFAULT"
        else
            echo "GRUB_TIMEOUT_STYLE=menu" >> "$GRUB_DEFAULT"
        fi

        # Set timeout to 5s if currently 0 or hidden
        local current_timeout
        current_timeout=$(grep "^GRUB_TIMEOUT=" "$GRUB_DEFAULT" 2>/dev/null | cut -d= -f2 || echo "0")
        if [[ "$current_timeout" == "0" || "$current_timeout" == "-1" ]]; then
            if grep -q "^GRUB_TIMEOUT=" "$GRUB_DEFAULT"; then
                sed -i 's/^GRUB_TIMEOUT=.*/GRUB_TIMEOUT=5/' "$GRUB_DEFAULT"
            else
                echo "GRUB_TIMEOUT=5" >> "$GRUB_DEFAULT"
            fi
            ok "Timeout set to 5 seconds (was $current_timeout)."
        else
            ok "Timeout is ${current_timeout}s (keeping as-is)."
        fi

        # Enable saved default (remember last-booted OS)
        if ! grep -q "^GRUB_DEFAULT=saved" "$GRUB_DEFAULT"; then
            if grep -q "^GRUB_DEFAULT=" "$GRUB_DEFAULT"; then
                sed -i 's/^GRUB_DEFAULT=.*/GRUB_DEFAULT=saved/' "$GRUB_DEFAULT"
            else
                echo "GRUB_DEFAULT=saved" >> "$GRUB_DEFAULT"
            fi
        fi
        if ! grep -q "^GRUB_SAVEDEFAULT=true" "$GRUB_DEFAULT"; then
            if grep -q "^GRUB_SAVEDEFAULT=" "$GRUB_DEFAULT"; then
                sed -i 's/^GRUB_SAVEDEFAULT=.*/GRUB_SAVEDEFAULT=true/' "$GRUB_DEFAULT"
            else
                echo "GRUB_SAVEDEFAULT=true" >> "$GRUB_DEFAULT"
            fi
        fi
        ok "GRUB will remember last-booted OS."
    fi

    # Step 3: Run os-prober
    header "Step 3: Detect Other Operating Systems"
    if command -v os-prober &>/dev/null; then
        info "Running os-prober..."
        local prober_out
        prober_out=$(os-prober 2>&1 || true)
        if [[ -n "$prober_out" ]]; then
            ok "os-prober found:"
            echo "$prober_out" | sed 's/^/    /'
        else
            warn "os-prober found nothing. Will check for manual entry."
        fi
    else
        warn "os-prober not installed."
        info "Install: sudo dnf install os-prober"
    fi

    # Step 4: Regenerate GRUB config (handles ostree correctly)
    header "Step 4: Regenerate GRUB Configuration"
    if is_ostree; then
        info "ostree system: using $mkconfig with ostree-aware paths..."
        # On Bazzite/Fedora Atomic, grub2-mkconfig handles BLS entries automatically
        # but we may need to run it differently
        if $mkconfig -o "$grub_cfg" 2>&1; then
            ok "GRUB config regenerated (ostree-aware)."
        else
            warn "grub2-mkconfig had warnings. Checking if config is usable..."
            if [[ -f "$grub_cfg" ]] && [[ -s "$grub_cfg" ]]; then
                ok "Config file exists and is non-empty. Likely OK."
            else
                err "GRUB config is missing or empty after regeneration."
                exit 1
            fi
        fi
    else
        info "Regenerating $grub_cfg..."
        if $mkconfig -o "$grub_cfg" 2>&1; then
            ok "GRUB config regenerated."
        else
            err "Failed to regenerate GRUB config."
            exit 1
        fi
    fi

    # Step 5: Verify Windows entry
    header "Step 5: Verify"
    local win_in_grub=false
    if [[ -f "$grub_cfg" ]] && grep -qi "windows" "$grub_cfg" 2>/dev/null; then
        win_in_grub=true
    fi
    # Also check BLS entries
    if [[ -d "$GRUB_OSTREE_CFG" ]]; then
        if grep -rqi "windows" "$GRUB_OSTREE_CFG/" 2>/dev/null; then
            win_in_grub=true
        fi
    fi

    if $win_in_grub; then
        ok "Windows boot entry is present in GRUB."
    else
        warn "Windows entry still not found in GRUB."
        echo ""
        info "Attempting to add a manual Windows entry..."

        # Try to find Windows EFI bootloader
        local win_efi_path=""
        local efi_uuid=""
        for efi_mount in /boot/efi /efi; do
            if [[ -f "$efi_mount/EFI/Microsoft/Boot/bootmgfw.efi" ]]; then
                win_efi_path="$efi_mount/EFI/Microsoft/Boot/bootmgfw.efi"
                local efi_dev
                efi_dev=$(findmnt -n -o SOURCE "$efi_mount" 2>/dev/null || true)
                if [[ -n "$efi_dev" ]]; then
                    efi_uuid=$(blkid -o value -s UUID "$efi_dev" 2>/dev/null || true)
                fi
                break
            fi
        done

        if [[ -n "$win_efi_path" && -n "$efi_uuid" ]]; then
            info "Found Windows bootloader: $win_efi_path"
            info "EFI partition UUID: $efi_uuid"

            local custom_entry="/etc/grub.d/40_custom_windows"
            if [[ ! -f "$custom_entry" ]]; then
                cat > "$custom_entry" << GRUBEOF
#!/bin/sh
exec tail -n +3 \$0
menuentry "Windows Boot Manager" --class windows --class os {
    search --fs-uuid --set=root $efi_uuid
    chainloader /EFI/Microsoft/Boot/bootmgfw.efi
}
GRUBEOF
                chmod +x "$custom_entry"
                ok "Created custom GRUB entry: $custom_entry"

                info "Re-running grub-mkconfig..."
                $mkconfig -o "$grub_cfg" 2>&1 || true

                if grep -qi "windows" "$grub_cfg" 2>/dev/null; then
                    ok "Windows entry now present in GRUB."
                else
                    warn "Entry created but may need a reboot to take effect."
                fi
            else
                info "Custom entry already exists at $custom_entry"
            fi
        else
            warn "Could not find Windows bootloader on EFI partition."
            echo ""
            info "Manual fix: Create /etc/grub.d/40_custom_windows with:"
            echo '    #!/bin/sh'
            echo '    exec tail -n +3 $0'
            echo '    menuentry "Windows Boot Manager" --class windows --class os {'
            echo '        search --fs-uuid --set=root <YOUR-EFI-UUID>'
            echo '        chainloader /EFI/Microsoft/Boot/bootmgfw.efi'
            echo '    }'
            echo ""
            info "Then run: sudo $mkconfig -o $grub_cfg"
        fi
    fi

    echo ""
    ok "GRUB fix complete."
    gui_notify "GRUB Fixed" "GRUB configuration has been regenerated."
}

# ── Command: shared-games ────────────────────────────────────────────────────

cmd_shared_games() {
    local subcmd="${1:-}"

    case "$subcmd" in
        setup)   _shared_games_setup ;;
        list)    _shared_games_list ;;
        status)  _shared_games_status ;;
        "")      _shared_games_status ;;
        *)
            err "Unknown subcommand: $subcmd"
            info "Usage: $SCRIPT_NAME shared-games [setup|list|status]"
            exit 1
            ;;
    esac
}

_shared_games_status() {
    header "Shared Game Storage"

    if mountpoint -q "$SHARED_MOUNT" 2>/dev/null; then
        local src
        src=$(findmnt -n -o SOURCE "$SHARED_MOUNT" 2>/dev/null || echo "unknown")
        local fstype
        fstype=$(findmnt -n -o FSTYPE "$SHARED_MOUNT" 2>/dev/null || echo "unknown")
        ok "Shared games partition mounted: $SHARED_MOUNT"
        detail "Source: $src | Filesystem: $fstype"
        echo ""
        df -h "$SHARED_MOUNT" 2>/dev/null | tail -1 | awk '{printf "  Size: %s | Used: %s | Free: %s (%s used)\n", $2, $3, $4, $5}'

        # Check for Steam library
        if [[ -d "$SHARED_MOUNT/SteamLibrary/steamapps" ]]; then
            echo ""
            ok "Steam library found at $SHARED_MOUNT/SteamLibrary/"
            local game_count
            game_count=$(find "$SHARED_MOUNT/SteamLibrary/steamapps" -maxdepth 1 -name "appmanifest_*.acf" 2>/dev/null | wc -l)
            detail "$game_count game(s) installed on shared storage."
        fi

        # Check Steam symlink
        _check_steam_symlink

        # NTFS warning
        if [[ "$fstype" == "ntfs" || "$fstype" == "ntfs3" || "$fstype" == "ntfs-3g" || "$fstype" == "fuseblk" ]]; then
            echo ""
            warn "${BOLD}NTFS Permission Notice:${NC}"
            detail "Some Proton/Wine games may have issues with NTFS file permissions."
            detail "If a game fails to launch from shared storage, try installing it locally."
            detail "Linux-native games should always be on ext4/btrfs."
        fi
    else
        info "No shared game storage mounted at $SHARED_MOUNT"
        echo ""
        _detect_candidate_partitions
        echo ""
        info "To set up shared storage: sudo $SCRIPT_NAME shared-games setup"
    fi
}

_detect_candidate_partitions() {
    info "Available NTFS/exFAT partitions for sharing:"
    local found=false
    while IFS= read -r line; do
        local dev
        dev="/dev/$(echo "$line" | awk '{print $1}')"
        local size fstype
        size=$(echo "$line" | awk '{print $2}')
        fstype=$(echo "$line" | awk '{print $3}')
        [[ "$fstype" != "ntfs" && "$fstype" != "ntfs3" && "$fstype" != "exfat" ]] && continue

        # Skip small partitions
        local size_bytes
        size_bytes=$(blockdev --getsize64 "$dev" 2>/dev/null || echo 0)
        [[ "$size_bytes" -lt 5368709120 ]] && continue  # Skip < 5GB

        local label
        label=$(blkid -o value -s LABEL "$dev" 2>/dev/null || echo "")

        # Check if this is a Windows OS partition (skip it)
        local is_win_os=false
        local tmpdir
        tmpdir=$(mktemp -d "/tmp/24hg-db-sg.XXXXXX")
        if mount -t ntfs3 -o ro,noexec "$dev" "$tmpdir" 2>/dev/null || \
           mount -t ntfs-3g -o ro,noexec "$dev" "$tmpdir" 2>/dev/null; then
            [[ -d "$tmpdir/Windows/System32" ]] && is_win_os=true
            umount "$tmpdir" 2>/dev/null || true
        fi
        rmdir "$tmpdir" 2>/dev/null || true
        $is_win_os && continue

        found=true
        echo -e "  ${CYAN}$dev${NC}  $size  $fstype  ${label:+($label)}"
    done < <(lsblk -rno NAME,SIZE,FSTYPE,TYPE 2>/dev/null | awk '$4=="part"')

    if ! $found; then
        detail "None found. Consider creating an NTFS or exFAT partition."
    fi
}

_shared_games_setup() {
    require_sudo "Setting up shared game storage requires root."

    header "Setting Up Shared Game Storage"

    # Detect candidates
    info "Scanning for suitable partitions..."
    echo ""

    local -a candidates=()
    local idx=0

    while IFS= read -r line; do
        local dev
        dev="/dev/$(echo "$line" | awk '{print $1}')"
        local size fstype
        size=$(echo "$line" | awk '{print $2}')
        fstype=$(echo "$line" | awk '{print $3}')
        [[ "$fstype" != "ntfs" && "$fstype" != "ntfs3" && "$fstype" != "exfat" ]] && continue

        local size_bytes
        size_bytes=$(blockdev --getsize64 "$dev" 2>/dev/null || echo 0)
        [[ "$size_bytes" -lt 5368709120 ]] && continue

        # Skip Windows OS partition
        local is_win_os=false
        local tmpdir
        tmpdir=$(mktemp -d "/tmp/24hg-db-setup.XXXXXX")
        if mount -t ntfs3 -o ro,noexec "$dev" "$tmpdir" 2>/dev/null || \
           mount -t ntfs-3g -o ro,noexec "$dev" "$tmpdir" 2>/dev/null; then
            [[ -d "$tmpdir/Windows/System32" ]] && is_win_os=true
            umount "$tmpdir" 2>/dev/null || true
        fi
        rmdir "$tmpdir" 2>/dev/null || true
        $is_win_os && continue

        local label
        label=$(blkid -o value -s LABEL "$dev" 2>/dev/null || echo "")
        ((idx++))
        candidates+=("$dev")
        echo -e "  ${BOLD}$idx)${NC} $dev -- $size, $fstype${label:+ ($label)}"
    done < <(lsblk -rno NAME,SIZE,FSTYPE,TYPE 2>/dev/null | awk '$4=="part"')

    if [[ ${#candidates[@]} -eq 0 ]]; then
        warn "No suitable partitions found (need NTFS or exFAT, at least 5GB)."
        echo ""
        info "To create a shared partition:"
        detail "1. Use GParted or fdisk to create an NTFS or exFAT partition"
        detail "2. Format from Windows for best compatibility"
        detail "3. Re-run this command"
        exit 0
    fi

    echo ""
    local choice
    if gui_available; then
        local -a zen_args=()
        for i in "${!candidates[@]}"; do
            zen_args+=("$((i+1))" "${candidates[$i]}")
        done
        choice=$(zenity --list --title="Select Shared Games Partition" \
            --column="No." --column="Partition" "${zen_args[@]}" --width=400 --height=300 2>/dev/null || true)
        [[ -z "$choice" ]] && { info "Cancelled."; exit 0; }
    else
        read -rp "Select partition (1-$idx), or 'q' to quit: " choice
        [[ "$choice" == "q" ]] && exit 0
    fi

    if ! [[ "$choice" =~ ^[0-9]+$ ]] || [[ "$choice" -lt 1 || "$choice" -gt "$idx" ]]; then
        err "Invalid selection."
        exit 1
    fi

    local selected="${candidates[$((choice-1))]}"
    local sel_fstype
    sel_fstype=$(blkid -o value -s TYPE "$selected" 2>/dev/null || echo "ntfs")
    local sel_uuid
    sel_uuid=$(blkid -o value -s UUID "$selected" 2>/dev/null || echo "")

    info "Selected: $selected ($sel_fstype)"
    echo ""

    # Create mount point
    mkdir -p "$SHARED_MOUNT"

    # Determine filesystem driver and mount options
    local fs_driver="$sel_fstype"
    local mount_opts=""
    case "$sel_fstype" in
        ntfs|ntfs3)
            if grep -q ntfs3 /proc/filesystems 2>/dev/null; then
                fs_driver="ntfs3"
                mount_opts="defaults,noatime,uid=1000,gid=1000,dmask=022,fmask=133,iocharset=utf8"
            else
                fs_driver="ntfs-3g"
                mount_opts="defaults,noatime,big_writes,uid=1000,gid=1000,dmask=022,fmask=133"
            fi
            ;;
        exfat)
            mount_opts="defaults,noatime,uid=1000,gid=1000,dmask=022,fmask=133"
            ;;
    esac

    # Add fstab entry
    local fstab_id
    if [[ -n "$sel_uuid" ]]; then
        fstab_id="UUID=$sel_uuid"
    else
        fstab_id="$selected"
    fi

    if grep -q "$SHARED_MOUNT" "$FSTAB" 2>/dev/null; then
        warn "Existing fstab entry for $SHARED_MOUNT found."
        if gui_confirm "Replace existing fstab entry for $SHARED_MOUNT?"; then
            sed -i "\|$SHARED_MOUNT|d" "$FSTAB"
        else
            info "Keeping existing entry."
        fi
    fi

    if ! grep -q "$SHARED_MOUNT" "$FSTAB" 2>/dev/null; then
        local fstab_line="$fstab_id  $SHARED_MOUNT  $fs_driver  $mount_opts,nofail  0  0"
        echo "$fstab_line" >> "$FSTAB"
        ok "Added fstab entry (with nofail for safe boot):"
        detail "$fstab_line"
    fi

    # Mount now
    echo ""
    if mountpoint -q "$SHARED_MOUNT" 2>/dev/null; then
        warn "$SHARED_MOUNT is already mounted. Remounting..."
        umount "$SHARED_MOUNT" 2>/dev/null || true
    fi

    if mount "$SHARED_MOUNT" 2>/dev/null; then
        ok "Mounted $selected at $SHARED_MOUNT"
    else
        warn "Could not mount partition. It may be hibernated or in use."
        info "Try after disabling Windows Fast Startup: powercfg /h off"
        info "Then: sudo mount $SHARED_MOUNT"
    fi

    # Create Steam library structure
    if mountpoint -q "$SHARED_MOUNT" 2>/dev/null; then
        mkdir -p "$SHARED_MOUNT/SteamLibrary/steamapps"
        ok "Created Steam library: $SHARED_MOUNT/SteamLibrary/"

        # Create symlink for Steam
        _create_steam_symlink
    fi

    echo ""
    header "Shared Games Setup Complete"
    echo ""
    echo -e "  Mount point:    ${CYAN}$SHARED_MOUNT${NC}"
    echo -e "  Steam library:  ${CYAN}$SHARED_MOUNT/SteamLibrary/${NC}"
    echo ""
    info "Add the library in Steam:"
    detail "Steam > Settings > Storage > + (Add Drive) > $SHARED_MOUNT/SteamLibrary"
    echo ""

    if [[ "$fs_driver" == "ntfs3" || "$fs_driver" == "ntfs-3g" ]]; then
        warn "${BOLD}NTFS Compatibility Notes:${NC}"
        detail "- Most Proton games work fine on NTFS shared drives"
        detail "- Some games with strict file permission checks may fail"
        detail "- Proton prefixes (compatdata) should stay on ext4/btrfs"
        detail "- If a game crashes, try moving it to local storage"
    fi

    gui_notify "Shared Games Ready" "Shared game storage mounted at $SHARED_MOUNT"
}

_shared_games_list() {
    header "Games on Shared vs Local Storage"

    # Find Steam directories
    local -a steam_dirs=()
    for pattern in \
        /home/*/.local/share/Steam \
        /home/*/.var/app/com.valvesoftware.Steam/.local/share/Steam \
        /home/*/.steam/steam; do
        for d in $pattern; do
            [[ -d "$d/steamapps" ]] && steam_dirs+=("$d")
        done
    done

    if [[ ${#steam_dirs[@]} -eq 0 ]]; then
        warn "No Steam installation found."
        return
    fi

    for steam_dir in "${steam_dirs[@]}"; do
        echo ""
        info "Steam directory: $steam_dir"

        # Read libraryfolders.vdf to find all library paths
        local libfolders="$steam_dir/steamapps/libraryfolders.vdf"
        if [[ -f "$libfolders" ]]; then
            local -a lib_paths=()
            while IFS= read -r line; do
                local lpath
                lpath=$(echo "$line" | grep -oP '"path"\s+"\K[^"]+' || true)
                [[ -n "$lpath" ]] && lib_paths+=("$lpath")
            done < "$libfolders"

            for lib_path in "${lib_paths[@]}"; do
                local apps_dir="$lib_path/steamapps"
                [[ -d "$apps_dir" ]] || continue

                local location_type="local"
                if echo "$lib_path" | grep -q "$SHARED_MOUNT"; then
                    location_type="shared"
                fi

                local game_count
                game_count=$(find "$apps_dir" -maxdepth 1 -name "appmanifest_*.acf" 2>/dev/null | wc -l)

                if [[ "$location_type" == "shared" ]]; then
                    echo -e "  ${YELLOW}[SHARED]${NC} $lib_path -- $game_count game(s)"
                else
                    echo -e "  ${GREEN}[LOCAL]${NC}  $lib_path -- $game_count game(s)"
                fi

                # List games
                for manifest in "$apps_dir"/appmanifest_*.acf; do
                    [[ -f "$manifest" ]] || continue
                    local name
                    name=$(grep -oP '"name"\s+"\K[^"]+' "$manifest" 2>/dev/null || echo "Unknown")
                    local appid
                    appid=$(grep -oP '"appid"\s+"\K[^"]+' "$manifest" 2>/dev/null || echo "?")
                    detail "  [$appid] $name"
                done
            done
        fi
    done
}

_create_steam_symlink() {
    # Find Steam directory for symlink
    local steam_dir=""
    for pattern in \
        /home/*/.local/share/Steam \
        /home/*/.var/app/com.valvesoftware.Steam/.local/share/Steam; do
        for d in $pattern; do
            [[ -d "$d" ]] && steam_dir="$d" && break 2
        done
    done

    if [[ -n "$steam_dir" ]]; then
        info "Found Steam at: $steam_dir"
        # Steam manages its own library folders, so we just inform the user
        detail "Add $SHARED_MOUNT/SteamLibrary as a library folder in Steam settings."
    fi
}

_check_steam_symlink() {
    local steam_dir=""
    for pattern in \
        /home/*/.local/share/Steam \
        /home/*/.var/app/com.valvesoftware.Steam/.local/share/Steam; do
        for d in $pattern; do
            if [[ -d "$d/steamapps" ]]; then
                steam_dir="$d"
                break 2
            fi
        done
    done

    if [[ -n "$steam_dir" ]]; then
        local libfolders="$steam_dir/steamapps/libraryfolders.vdf"
        if [[ -f "$libfolders" ]] && grep -q "$SHARED_MOUNT" "$libfolders" 2>/dev/null; then
            ok "Steam recognizes $SHARED_MOUNT as a library folder."
        else
            info "Steam has not added $SHARED_MOUNT as a library yet."
            detail "Add in Steam: Settings > Storage > + > $SHARED_MOUNT/SteamLibrary"
        fi
    fi
}

# ── Command: time-fix ─────────────────────────────────────────────────────────

cmd_time_fix() {
    header "Windows/Linux Time Desync Fix"

    echo ""
    info "${BOLD}The Problem:${NC}"
    detail "Windows assumes the hardware clock (RTC) stores local time."
    detail "Linux (by default) assumes the hardware clock stores UTC."
    detail "When dual-booting, each OS misinterprets the other's clock setting,"
    detail "causing the time to jump forward or backward when switching OSes."
    echo ""

    # Detect current state
    local rtc_local
    rtc_local=$(timedatectl show --property=LocalRTC --value 2>/dev/null || echo "unknown")
    local rtc_time
    rtc_time=$(timedatectl show --property=RTCTimeUSec --value 2>/dev/null | cut -d' ' -f1-2 || echo "unknown")
    local sys_time
    sys_time=$(date "+%Y-%m-%d %H:%M:%S %Z")
    local timezone
    timezone=$(timedatectl show --property=Timezone --value 2>/dev/null || echo "unknown")
    local ntp_active
    ntp_active=$(timedatectl show --property=NTPSynchronized --value 2>/dev/null || echo "unknown")

    header "Current State"
    info "System time:     $sys_time"
    info "Timezone:        $timezone"
    info "NTP synced:      $ntp_active"
    info "RTC in local:    $rtc_local"

    if [[ "$rtc_local" == "yes" ]]; then
        echo ""
        warn "Hardware clock is set to LOCAL time (Windows-compatible mode)."
        detail "This works but is not recommended. NTP may have issues."
    elif [[ "$rtc_local" == "no" ]]; then
        echo ""
        ok "Hardware clock is set to UTC (Linux standard)."
        detail "Windows will show wrong time unless patched (see below)."
    fi

    echo ""
    header "Fix Options"
    echo ""
    echo -e "  ${BOLD}1)${NC} Fix Windows to use UTC ${GREEN}(Recommended)${NC}"
    detail "   Keep Linux at UTC. Apply a registry fix for Windows."
    detail "   Best practice: both OSes agree on UTC hardware clock."
    echo ""
    echo -e "  ${BOLD}2)${NC} Set Linux to use local time"
    detail "   Make Linux match Windows convention (local time in RTC)."
    detail "   Easier but can cause NTP issues on Linux."
    echo ""
    echo -e "  ${BOLD}3)${NC} Just show me the fix commands"
    echo ""

    local choice
    if gui_available; then
        choice=$(zenity --list --title="Time Fix" --radiolist \
            --column="" --column="Option" --column="Description" \
            TRUE "1" "Fix Windows to use UTC (recommended)" \
            FALSE "2" "Set Linux to use local time" \
            FALSE "3" "Show fix commands only" \
            --width=500 --height=300 2>/dev/null || echo "3")
    else
        read -rp "Select option (1/2/3): " choice
    fi

    case "$choice" in
        1) _time_fix_utc ;;
        2) _time_fix_localtime ;;
        3) _time_fix_show_commands ;;
        *)
            info "No changes made."
            ;;
    esac
}

_time_fix_utc() {
    require_sudo "Changing RTC settings requires root."

    header "Applying UTC Fix"

    # Ensure Linux uses UTC
    info "Setting Linux hardware clock to UTC..."
    timedatectl set-local-rtc 0
    ok "Linux RTC set to UTC."

    # Sync hardware clock
    info "Syncing hardware clock..."
    hwclock --systohc --utc 2>/dev/null || true
    ok "Hardware clock synchronized."

    # Generate Windows registry fix
    local reg_file="/tmp/24hg-time-fix-windows.reg"
    cat > "$reg_file" << 'REGEOF'
Windows Registry Editor Version 5.00

; 24HG Time Fix: Tell Windows to use UTC for hardware clock
; Import this file in Windows (double-click) then reboot

[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Control\TimeZoneInformation]
"RealTimeIsUniversal"=dword:00000001
REGEOF

    ok "Generated Windows registry fix: $reg_file"
    echo ""
    info "To complete the fix:"
    detail "1. Copy $reg_file to a USB drive or shared partition"
    detail "2. Boot into Windows"
    detail "3. Double-click the .reg file and accept the prompt"
    detail "4. Reboot Windows"
    echo ""
    info "After applying, both OSes will agree on UTC hardware clock."

    # Try to copy to shared mount if available
    if mountpoint -q "$SHARED_MOUNT" 2>/dev/null; then
        cp "$reg_file" "$SHARED_MOUNT/24hg-time-fix-windows.reg" 2>/dev/null && \
            ok "Also copied to $SHARED_MOUNT/24hg-time-fix-windows.reg"
    fi

    gui_notify "Time Fix Applied" "Linux set to UTC. Apply the .reg file in Windows to complete."
}

_time_fix_localtime() {
    require_sudo "Changing RTC settings requires root."

    header "Setting Linux to Local Time"

    warn "This is the simpler fix but not recommended long-term."
    detail "NTP synchronization may behave unexpectedly."
    echo ""

    info "Setting hardware clock to local time..."
    timedatectl set-local-rtc 1 --adjust-system-clock
    ok "Linux RTC set to local time."

    info "Syncing hardware clock..."
    hwclock --systohc --localtime 2>/dev/null || true
    ok "Hardware clock synchronized."

    echo ""
    ok "Time fix applied. Both OSes now use local time in hardware clock."
    warn "If you see NTP warnings, consider switching to the UTC fix instead."

    gui_notify "Time Fix Applied" "Linux set to local time to match Windows."
}

_time_fix_show_commands() {
    header "Manual Fix Commands"

    echo ""
    echo -e "${BOLD}Option A: Fix Windows to use UTC (recommended)${NC}"
    echo ""
    echo "  On Linux:"
    echo -e "    ${CYAN}sudo timedatectl set-local-rtc 0${NC}"
    echo -e "    ${CYAN}sudo hwclock --systohc --utc${NC}"
    echo ""
    echo "  On Windows (run as Administrator in CMD or PowerShell):"
    echo -e "    ${CYAN}reg add \"HKLM\\SYSTEM\\CurrentControlSet\\Control\\TimeZoneInformation\" /v RealTimeIsUniversal /t REG_DWORD /d 1 /f${NC}"
    echo ""
    echo "  Or create a .reg file with:"
    echo '    [HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Control\TimeZoneInformation]'
    echo '    "RealTimeIsUniversal"=dword:00000001'
    echo ""
    echo -e "${BOLD}Option B: Set Linux to use local time${NC}"
    echo ""
    echo "  On Linux:"
    echo -e "    ${CYAN}sudo timedatectl set-local-rtc 1 --adjust-system-clock${NC}"
    echo -e "    ${CYAN}sudo hwclock --systohc --localtime${NC}"
    echo ""
    echo "  (No changes needed on Windows side.)"
    echo ""
    echo -e "${BOLD}Verify with:${NC}"
    echo -e "    ${CYAN}timedatectl${NC}"
}

# ── Command: bitlocker-check ──────────────────────────────────────────────────

cmd_bitlocker_check() {
    header "BitLocker Safety Check"

    echo ""
    info "Scanning partitions for BitLocker encryption..."
    echo ""

    local bl_found=false
    while IFS= read -r line; do
        local dev
        dev="/dev/$(echo "$line" | awk '{print $1}')"
        local size fstype
        size=$(echo "$line" | awk '{print $2}')
        fstype=$(echo "$line" | awk '{print $3}')

        local bl_detected=false

        # Check blkid for BitLocker marker
        local blkid_out
        blkid_out=$(blkid "$dev" 2>/dev/null || true)
        if echo "$blkid_out" | grep -qi "BitLocker"; then
            bl_detected=true
        fi

        # Check raw bytes for FVE-FS signature
        if ! $bl_detected; then
            if dd if="$dev" bs=1 count=16 skip=3 2>/dev/null | grep -q "FVE-FS" 2>/dev/null; then
                bl_detected=true
            fi
        fi

        if $bl_detected; then
            bl_found=true
            local label
            label=$(blkid -o value -s LABEL "$dev" 2>/dev/null || echo "")
            echo -e "  ${RED}BITLOCKER${NC}  ${CYAN}$dev${NC}  $size  ${label:+($label)}"
        fi
    done < <(lsblk -rno NAME,SIZE,FSTYPE,TYPE 2>/dev/null | awk '$4=="part"')

    if ! $bl_found; then
        ok "No BitLocker-encrypted partitions detected."
        echo ""
        info "Your partitions appear unencrypted. Safe to proceed with dual-boot changes."
        return
    fi

    # BitLocker found — show warnings and guidance
    echo ""
    header "IMPORTANT: BitLocker Warnings"
    echo ""
    echo -e "  ${RED}${BOLD}BitLocker encryption was detected on one or more partitions.${NC}"
    echo ""
    warn "${BOLD}DO NOT do the following without preparing first:${NC}"
    echo -e "  ${RED}x${NC} Resize the encrypted partition (will lock you out)"
    echo -e "  ${RED}x${NC} Modify the EFI/boot partition (may trigger recovery)"
    echo -e "  ${RED}x${NC} Change BIOS/UEFI settings (Secure Boot, TPM) without key"
    echo -e "  ${RED}x${NC} Update BIOS/UEFI firmware without suspending BitLocker"
    echo -e "  ${RED}x${NC} Run grub-install to EFI without suspending BitLocker"
    echo ""

    header "Recovery Key Status"
    echo ""
    warn "You MUST have your BitLocker recovery key before making system changes."
    echo ""
    info "Where to find your recovery key:"
    detail "1. Microsoft Account: https://account.microsoft.com/devices/recoverykey"
    detail "2. Saved file: Check USB drives for 'BitLocker Recovery Key *.txt'"
    detail "3. Active Directory: Ask your IT admin (domain-joined PCs)"
    detail "4. Azure AD: https://portal.azure.com > Devices > BitLocker keys"
    detail "5. Printout: Check physical records"
    echo ""

    header "How to Check in Windows"
    echo ""
    info "Before making dual-boot changes, do this in Windows:"
    echo ""
    echo "  1. Open CMD as Administrator"
    echo -e "  2. Run: ${CYAN}manage-bde -status${NC}"
    echo "  3. Note the Protection Status and Key Protectors"
    echo ""
    echo "  To suspend BitLocker temporarily (allows ONE reboot without key):"
    echo -e "     ${CYAN}manage-bde -protectors -disable C:${NC}"
    echo ""
    echo "  To export recovery key:"
    echo -e "     ${CYAN}manage-bde -protectors -get C:${NC}"
    echo "     Save the Numerical Password (48-digit recovery key)"
    echo ""

    header "Safe Dual-Boot Steps with BitLocker"
    echo ""
    info "Recommended approach:"
    detail "1. In Windows: Suspend BitLocker (manage-bde -protectors -disable C:)"
    detail "2. Save your recovery key somewhere accessible"
    detail "3. Install 24HG / modify boot entries"
    detail "4. Boot Windows first to let BitLocker re-seal with new boot config"
    detail "5. Re-enable BitLocker if it was suspended"
    echo ""

    warn "If BitLocker triggers recovery mode:"
    detail "Enter your 48-digit recovery key at the prompt."
    detail "Windows will then re-seal BitLocker with the current boot config."
    echo ""

    # Check if dislocker is available
    if command -v dislocker &>/dev/null; then
        ok "dislocker is installed (can mount BitLocker volumes from Linux)."
    else
        info "dislocker not installed. For accessing BitLocker drives from Linux:"
        detail "sudo dnf install dislocker  (or apt install dislocker)"
    fi

    gui_notify "BitLocker Detected" "BitLocker-encrypted partitions found. Check recovery key before modifying boot."
}

# ── Usage / Help ──────────────────────────────────────────────────────────────

usage() {
    echo -e "${BOLD}24HG Dual-Boot Helper${NC}  v$VERSION"
    echo ""
    echo "Manage dual-boot setups between Windows and 24HG (Bazzite/Fedora Atomic)."
    echo "Handles UEFI and Legacy BIOS, ostree GRUB, shared game storage, and more."
    echo ""
    echo -e "${BOLD}Usage:${NC} $SCRIPT_NAME [--gui] <command> [args]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo "  status                    Show dual-boot overview (boot entries, partitions, mounts)"
    echo "  detect                    Detect Windows installations and boot entries"
    echo "  quick-reboot <target>     Reboot into Windows or 24HG"
    echo "      quick-reboot windows  Set GRUB/EFI to boot Windows once, then reboot"
    echo "      quick-reboot 24hg    Reset default boot to 24HG"
    echo "  fix-grub                  Fix GRUB: enable os-prober, add Windows, set timeout"
    echo "  shared-games [sub]        Manage shared game storage between OSes"
    echo "      shared-games          Show shared storage status"
    echo "      shared-games setup    Mount and configure a shared partition"
    echo "      shared-games list     Show games on shared vs local storage"
    echo "  time-fix                  Fix the Windows/Linux clock desync issue"
    echo "  bitlocker-check           Check for BitLocker and provide safety guidance"
    echo ""
    echo -e "${BOLD}Options:${NC}"
    echo "  --gui                     Use zenity dialogs for prompts and notifications"
    echo "  -h, --help                Show this help"
    echo "  -v, --version             Show version"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  $SCRIPT_NAME status                    # Check dual-boot health"
    echo "  $SCRIPT_NAME detect                    # Find Windows installations"
    echo "  sudo $SCRIPT_NAME quick-reboot windows # Reboot into Windows"
    echo "  sudo $SCRIPT_NAME fix-grub             # Fix missing Windows in GRUB"
    echo "  sudo $SCRIPT_NAME shared-games setup   # Set up shared game drive"
    echo "  $SCRIPT_NAME time-fix                  # Fix clock desync"
    echo "  $SCRIPT_NAME bitlocker-check           # Check BitLocker safety"
    echo "  $SCRIPT_NAME --gui quick-reboot windows  # GUI mode"
    echo ""
    echo -e "${BOLD}Notes:${NC}"
    echo "  - Commands that modify system config require sudo (script will prompt)"
    echo "  - Works with both UEFI and Legacy BIOS systems"
    echo "  - Handles Bazzite/Fedora Atomic ostree GRUB and BLS boot entries"
    echo "  - Desktop notifications sent on reboot countdown"
}

# ── Argument Parsing ──────────────────────────────────────────────────────────

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --gui)
                GUI_MODE=true
                if ! command -v zenity &>/dev/null; then
                    warn "zenity not found. GUI mode disabled."
                    warn "Install: sudo dnf install zenity"
                    GUI_MODE=false
                fi
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "$SCRIPT_NAME v$VERSION"
                exit 0
                ;;
            -*)
                err "Unknown option: $1"
                echo ""
                usage
                exit 1
                ;;
            *)
                POSITIONAL_ARGS+=("$1")
                shift
                ;;
        esac
    done
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    parse_args "$@"

    local command="${POSITIONAL_ARGS[0]:-}"
    local subargs=("${POSITIONAL_ARGS[@]:1}")

    case "$command" in
        status)
            cmd_status
            ;;
        detect)
            cmd_detect
            ;;
        quick-reboot)
            cmd_quick_reboot "${subargs[@]+"${subargs[0]}"}"
            ;;
        fix-grub)
            cmd_fix_grub
            ;;
        shared-games)
            cmd_shared_games "${subargs[@]+"${subargs[0]}"}"
            ;;
        time-fix)
            cmd_time_fix
            ;;
        bitlocker-check)
            cmd_bitlocker_check
            ;;
        "")
            usage
            ;;
        *)
            err "Unknown command: $command"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
