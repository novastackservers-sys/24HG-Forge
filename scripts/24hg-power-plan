#!/usr/bin/env bash
# 24hg-power-plan — Laptop-aware power management for 24HG
# Three gaming-optimized power modes with auto-switching, per-game overrides,
# and battery life estimation.
set -euo pipefail

CONFIG_DIR="${HOME}/.config/24hg/power-plan"
CONFIG_FILE="${CONFIG_DIR}/config.json"
OVERRIDES_FILE="${CONFIG_DIR}/overrides.json"
HISTORY_FILE="${CONFIG_DIR}/power-history.json"
DAEMON_PID_FILE="${CONFIG_DIR}/daemon.pid"
VERSION="1.0.0"

# ── Helpers ──────────────────────────────────────────────────────────────────

log()   { echo -e "\e[1;34m[24hg-power-plan]\e[0m $*"; }
warn()  { echo -e "\e[1;33m[warn]\e[0m $*" >&2; }
err()   { echo -e "\e[1;31m[error]\e[0m $*" >&2; exit 1; }

ensure_config() {
    mkdir -p "$CONFIG_DIR"
    [[ -f "$CONFIG_FILE" ]] || cat > "$CONFIG_FILE" <<'JSON'
{
  "current_mode": "balanced",
  "auto_switch": true,
  "thermal_target_c": 90,
  "battery_fps_cap": 30,
  "balanced_fps_cap": 60,
  "performance_fps_cap": 0,
  "battery_brightness_pct": 30,
  "balanced_brightness_pct": 70,
  "performance_brightness_pct": 100
}
JSON
    [[ -f "$OVERRIDES_FILE" ]] || echo '{}' > "$OVERRIDES_FILE"
    [[ -f "$HISTORY_FILE" ]]   || echo '{}' > "$HISTORY_FILE"
}

cfg_get() { python3 -c "import json,sys;d=json.load(open('$CONFIG_FILE'));print(d.get('$1','$2'))" 2>/dev/null || echo "$2"; }
cfg_set() {
    python3 -c "
import json
with open('$CONFIG_FILE','r') as f: d=json.load(f)
d['$1']=$2
with open('$CONFIG_FILE','w') as f: json.dump(d,f,indent=2)
"
}

is_on_ac() {
    for supply in /sys/class/power_supply/AC* /sys/class/power_supply/ACAD*; do
        [[ -f "$supply/online" ]] && [[ "$(cat "$supply/online" 2>/dev/null)" == "1" ]] && return 0
    done
    return 1
}

battery_pct() {
    for bat in /sys/class/power_supply/BAT*; do
        [[ -f "$bat/capacity" ]] && cat "$bat/capacity" && return
    done
    echo "N/A"
}

battery_watts() {
    for bat in /sys/class/power_supply/BAT*; do
        if [[ -f "$bat/power_now" ]]; then
            awk '{printf "%.1f", $1/1000000}' "$bat/power_now" && return
        elif [[ -f "$bat/current_now" ]] && [[ -f "$bat/voltage_now" ]]; then
            paste "$bat/current_now" "$bat/voltage_now" | awk '{printf "%.1f", ($1*$2)/1000000000000}' && return
        fi
    done
    echo "0"
}

battery_energy_wh() {
    for bat in /sys/class/power_supply/BAT*; do
        if [[ -f "$bat/energy_now" ]]; then
            awk '{printf "%.1f", $1/1000000}' "$bat/energy_now" && return
        elif [[ -f "$bat/charge_now" ]] && [[ -f "$bat/voltage_now" ]]; then
            paste "$bat/charge_now" "$bat/voltage_now" | awk '{printf "%.1f", ($1*$2)/1000000000000}' && return
        fi
    done
    echo "0"
}

# ── CPU Governor ─────────────────────────────────────────────────────────────

set_cpu_governor() {
    local gov="$1"
    log "Setting CPU governor: $gov"
    if command -v cpupower &>/dev/null; then
        sudo cpupower frequency-set -g "$gov" 2>/dev/null || true
    else
        for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
            [[ -f "$cpu" ]] && echo "$gov" | sudo tee "$cpu" >/dev/null 2>&1 || true
        done
    fi
}

get_cpu_governor() {
    cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "unknown"
}

# ── GPU Control ──────────────────────────────────────────────────────────────

detect_gpu() {
    if [[ -d /sys/class/drm/card0/device/vendor ]]; then
        local vendor
        vendor=$(cat /sys/class/drm/card0/device/vendor 2>/dev/null || echo "")
        case "$vendor" in
            0x10de) echo "nvidia" ;;
            0x1002) echo "amd" ;;
            0x8086) echo "intel" ;;
            *)      echo "unknown" ;;
        esac
    elif command -v nvidia-smi &>/dev/null; then
        echo "nvidia"
    elif [[ -d /sys/class/drm/card0/device ]] && lspci 2>/dev/null | grep -qi amd; then
        echo "amd"
    else
        echo "unknown"
    fi
}

set_gpu_power() {
    local mode="$1"
    local gpu
    gpu=$(detect_gpu)

    case "$gpu" in
        nvidia)
            log "Setting NVIDIA GPU power: $mode"
            case "$mode" in
                battery)
                    nvidia-settings -a "[gpu:0]/GPUPowerMizerMode=0" 2>/dev/null || true  # Adaptive
                    nvidia-smi -pl 60 2>/dev/null || true
                    ;;
                balanced)
                    nvidia-settings -a "[gpu:0]/GPUPowerMizerMode=0" 2>/dev/null || true
                    nvidia-smi -pl 120 2>/dev/null || true
                    ;;
                performance)
                    nvidia-settings -a "[gpu:0]/GPUPowerMizerMode=1" 2>/dev/null || true  # Max perf
                    nvidia-smi -pl 300 2>/dev/null || true
                    ;;
            esac
            ;;
        amd)
            log "Setting AMD GPU power: $mode"
            local card
            for card in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
                [[ -f "$card" ]] || continue
                case "$mode" in
                    battery)     echo "low"  | sudo tee "$card" >/dev/null 2>&1 || true ;;
                    balanced)    echo "auto" | sudo tee "$card" >/dev/null 2>&1 || true ;;
                    performance) echo "high" | sudo tee "$card" >/dev/null 2>&1 || true ;;
                esac
            done
            ;;
        intel)
            log "Setting Intel GPU power: $mode"
            local gt_freq="/sys/class/drm/card0/gt_boost_freq_mhz"
            local gt_min="/sys/class/drm/card0/gt_min_freq_mhz"
            local gt_max="/sys/class/drm/card0/gt_max_freq_mhz"
            if [[ -f "$gt_max" ]]; then
                local max_freq min_freq
                max_freq=$(cat /sys/class/drm/card0/gt_RP0_freq_mhz 2>/dev/null || echo "1200")
                min_freq=$(cat /sys/class/drm/card0/gt_RPn_freq_mhz 2>/dev/null || echo "300")
                case "$mode" in
                    battery)     echo "$min_freq" | sudo tee "$gt_freq" >/dev/null 2>&1 || true ;;
                    balanced)    echo "$max_freq" | sudo tee "$gt_freq" >/dev/null 2>&1 || true ;;
                    performance) echo "$max_freq" | sudo tee "$gt_freq" >/dev/null 2>&1 || true ;;
                esac
            fi
            ;;
        *)
            warn "GPU vendor not detected; skipping GPU power control"
            ;;
    esac
}

# ── Display Control ──────────────────────────────────────────────────────────

set_brightness() {
    local pct="$1"
    if command -v brightnessctl &>/dev/null; then
        brightnessctl set "${pct}%" 2>/dev/null || true
    elif [[ -f /sys/class/backlight/*/brightness ]]; then
        for bl in /sys/class/backlight/*/; do
            [[ -f "${bl}max_brightness" ]] || continue
            local max val
            max=$(cat "${bl}max_brightness")
            val=$(( max * pct / 100 ))
            echo "$val" | sudo tee "${bl}brightness" >/dev/null 2>&1 || true
        done
    fi
}

get_brightness() {
    if command -v brightnessctl &>/dev/null; then
        brightnessctl -m 2>/dev/null | awk -F, '{gsub(/%/,"",$4); print $4}'
        return
    fi
    for bl in /sys/class/backlight/*/; do
        if [[ -f "${bl}brightness" ]] && [[ -f "${bl}max_brightness" ]]; then
            local cur max
            cur=$(cat "${bl}brightness")
            max=$(cat "${bl}max_brightness")
            echo $(( cur * 100 / max ))
            return
        fi
    done
    echo "N/A"
}

set_refresh_rate() {
    local mode="$1"
    if command -v xrandr &>/dev/null && [[ -n "${DISPLAY:-}" ]]; then
        local output rate
        output=$(xrandr --current 2>/dev/null | awk '/ connected/{print $1; exit}')
        [[ -z "$output" ]] && return
        case "$mode" in
            battery)     rate="60" ;;
            balanced)    rate="60" ;;
            performance) rate="" ;;  # highest available
        esac
        if [[ -n "$rate" ]]; then
            xrandr --output "$output" --rate "$rate" 2>/dev/null || true
        else
            local max_rate
            max_rate=$(xrandr 2>/dev/null | grep -A1 "^$output" | tail -1 | grep -oP '[\d.]+(?=\*|\s)' | sort -rn | head -1)
            [[ -n "$max_rate" ]] && xrandr --output "$output" --rate "$max_rate" 2>/dev/null || true
        fi
    fi
}

set_hdr() {
    local enable="$1"
    if command -v gamescope &>/dev/null; then
        log "HDR $([ "$enable" = "1" ] && echo "enabled" || echo "disabled") (via gamescope flag)"
    fi
    # KDE/GNOME HDR toggles
    if command -v kscreen-doctor &>/dev/null; then
        local val=$([ "$enable" = "1" ] && echo "true" || echo "false")
        kscreen-doctor output.1.hdr.enable="$val" 2>/dev/null || true
    fi
}

# ── Thermal Control ─────────────────────────────────────────────────────────

set_thermal_target() {
    local mode="$1"
    local target
    case "$mode" in
        battery)     target=75 ;;
        balanced)    target=$(cfg_get thermal_target_c 90) ;;
        performance) target=100 ;;
    esac
    log "Thermal target: ${target}C"

    # Intel thermald / RAPL
    if [[ -d /sys/devices/virtual/thermal/ ]]; then
        for tz in /sys/devices/virtual/thermal/thermal_zone*/trip_point_*_temp; do
            [[ -f "$tz" ]] || continue
            echo $(( target * 1000 )) | sudo tee "$tz" >/dev/null 2>&1 || true
        done
    fi
    # NVIDIA thermal
    if command -v nvidia-smi &>/dev/null; then
        nvidia-smi -tcc "$target" 2>/dev/null || true
    fi
}

# ── FPS Cap (via MangoHud env) ───────────────────────────────────────────────

set_fps_cap() {
    local mode="$1"
    local cap
    case "$mode" in
        battery)     cap=$(cfg_get battery_fps_cap 30) ;;
        balanced)    cap=$(cfg_get balanced_fps_cap 60) ;;
        performance) cap=$(cfg_get performance_fps_cap 0) ;;
    esac
    local mangohud_conf="${HOME}/.config/MangoHud/MangoHud.conf"
    if [[ -f "$mangohud_conf" ]]; then
        if [[ "$cap" == "0" ]]; then
            sed -i 's/^fps_limit=.*/fps_limit=0/' "$mangohud_conf" 2>/dev/null || true
        else
            if grep -q '^fps_limit=' "$mangohud_conf" 2>/dev/null; then
                sed -i "s/^fps_limit=.*/fps_limit=$cap/" "$mangohud_conf"
            else
                echo "fps_limit=$cap" >> "$mangohud_conf"
            fi
        fi
        log "FPS cap: $([ "$cap" = "0" ] && echo "uncapped" || echo "$cap")"
    fi
}

# ── Mode Switching ───────────────────────────────────────────────────────────

apply_mode() {
    local mode="$1"
    log "Applying power plan: $mode"

    case "$mode" in
        battery)
            set_cpu_governor "powersave"
            set_gpu_power "battery"
            set_brightness "$(cfg_get battery_brightness_pct 30)"
            set_refresh_rate "battery"
            set_hdr "0"
            set_thermal_target "battery"
            set_fps_cap "battery"
            ;;
        balanced)
            set_cpu_governor "schedutil"
            set_gpu_power "balanced"
            set_brightness "$(cfg_get balanced_brightness_pct 70)"
            set_refresh_rate "balanced"
            set_hdr "0"
            set_thermal_target "balanced"
            set_fps_cap "balanced"
            ;;
        performance)
            set_cpu_governor "performance"
            set_gpu_power "performance"
            set_brightness "$(cfg_get performance_brightness_pct 100)"
            set_refresh_rate "performance"
            set_hdr "1"
            set_thermal_target "performance"
            set_fps_cap "performance"
            ;;
        *)
            err "Unknown mode: $mode (use battery, balanced, or performance)"
            ;;
    esac

    cfg_set "current_mode" "\"$mode\""
    notify_desktop "$mode"
    log "Power plan set to: $mode"
}

notify_desktop() {
    local mode="$1"
    local icon summary
    case "$mode" in
        battery)     icon="battery-low"      ; summary="Battery Saver" ;;
        balanced)    icon="battery-good"      ; summary="Balanced" ;;
        performance) icon="battery-full-charged" ; summary="Performance" ;;
    esac
    if command -v notify-send &>/dev/null; then
        notify-send -i "$icon" "24HG Power Plan" "Switched to $summary mode" 2>/dev/null || true
    fi
}

# ── Auto-Switch Logic ────────────────────────────────────────────────────────

auto_switch_check() {
    local auto
    auto=$(cfg_get auto_switch true)
    [[ "$auto" != "true" ]] && return

    if is_on_ac; then
        local cur
        cur=$(cfg_get current_mode balanced)
        if [[ "$cur" == "battery" ]]; then
            log "AC connected — switching to balanced"
            apply_mode "balanced"
        fi
    else
        local cur
        cur=$(cfg_get current_mode balanced)
        if [[ "$cur" != "battery" ]]; then
            log "On battery — switching to battery saver"
            apply_mode "battery"
        fi
    fi
}

# ── Per-Game Override ────────────────────────────────────────────────────────

get_game_override() {
    local appid="$1"
    python3 -c "
import json
d = json.load(open('$OVERRIDES_FILE'))
print(d.get('$appid', ''))
" 2>/dev/null
}

set_game_override() {
    local appid="$1" mode="$2"
    [[ "$mode" =~ ^(battery|balanced|performance|clear)$ ]] || err "Invalid mode: $mode"
    python3 -c "
import json
with open('$OVERRIDES_FILE','r') as f: d=json.load(f)
if '$mode' == 'clear':
    d.pop('$appid', None)
else:
    d['$appid'] = '$mode'
with open('$OVERRIDES_FILE','w') as f: json.dump(d,f,indent=2)
"
    if [[ "$mode" == "clear" ]]; then
        log "Cleared override for appid $appid"
    else
        log "Set override for appid $appid -> $mode"
    fi
}

# ── Battery Estimation ───────────────────────────────────────────────────────

record_power_sample() {
    local game="${1:-idle}"
    local watts
    watts=$(battery_watts)
    [[ "$watts" == "0" ]] && return
    python3 -c "
import json, time
with open('$HISTORY_FILE','r') as f: d=json.load(f)
key = '$game'
if key not in d: d[key] = []
d[key].append({'watts': float('$watts'), 'ts': int(time.time())})
d[key] = d[key][-50:]  # keep last 50 samples
with open('$HISTORY_FILE','w') as f: json.dump(d,f,indent=2)
"
}

estimate_battery_life() {
    local game="${1:-idle}"
    local energy_wh avg_watts
    energy_wh=$(battery_energy_wh)

    avg_watts=$(python3 -c "
import json, sys
d = json.load(open('$HISTORY_FILE'))
samples = d.get('$game', [])
if not samples:
    samples = d.get('idle', [])
if not samples:
    print('0')
    sys.exit()
avg = sum(s['watts'] for s in samples) / len(s for s in samples if True)
print(f'{avg:.1f}')
" 2>/dev/null || echo "0")

    if [[ "$avg_watts" == "0" ]] || [[ "$energy_wh" == "0" ]]; then
        # Fallback: estimate from current draw
        avg_watts=$(battery_watts)
        [[ "$avg_watts" == "0" ]] && { echo "No power data available. Run games on battery to collect samples."; return; }
    fi

    local hours
    hours=$(awk "BEGIN {if ($avg_watts > 0) printf \"%.1f\", $energy_wh / $avg_watts; else print \"N/A\"}")
    local mins
    mins=$(awk "BEGIN {if ($avg_watts > 0) printf \"%d\", ($energy_wh / $avg_watts) * 60; else print 0}")

    echo "Game:            $game"
    echo "Avg power draw:  ${avg_watts}W"
    echo "Battery left:    ${energy_wh}Wh"
    echo "Estimated time:  ${hours}h (~${mins} minutes)"
}

# ── Daemon ───────────────────────────────────────────────────────────────────

daemon_run() {
    if [[ -f "$DAEMON_PID_FILE" ]]; then
        local old_pid
        old_pid=$(cat "$DAEMON_PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            err "Daemon already running (PID $old_pid). Kill it first or remove $DAEMON_PID_FILE"
        fi
    fi

    echo $$ > "$DAEMON_PID_FILE"
    trap 'rm -f "$DAEMON_PID_FILE"; exit 0' EXIT INT TERM

    log "Daemon started (PID $$), polling every 10s"
    local last_ac=""
    while true; do
        local ac_now
        ac_now=$(is_on_ac && echo "ac" || echo "battery")

        if [[ "$ac_now" != "$last_ac" ]] && [[ -n "$last_ac" ]]; then
            log "Power source changed: $last_ac -> $ac_now"
            auto_switch_check
        fi
        last_ac="$ac_now"

        # Record idle power sample
        record_power_sample "idle"

        sleep 10
    done
}

# ── Status ───────────────────────────────────────────────────────────────────

show_status() {
    local mode ac_status bat_pct brightness governor gpu watts
    mode=$(cfg_get current_mode balanced)
    bat_pct=$(battery_pct)
    watts=$(battery_watts)
    governor=$(get_cpu_governor)
    brightness=$(get_brightness)
    gpu=$(detect_gpu)

    if is_on_ac; then
        ac_status="\e[1;32mAC Connected\e[0m"
    else
        ac_status="\e[1;33mOn Battery\e[0m"
    fi

    local auto
    auto=$(cfg_get auto_switch true)
    local daemon_status="stopped"
    if [[ -f "$DAEMON_PID_FILE" ]] && kill -0 "$(cat "$DAEMON_PID_FILE")" 2>/dev/null; then
        daemon_status="running (PID $(cat "$DAEMON_PID_FILE"))"
    fi

    echo ""
    echo -e "  \e[1;36m24HG Power Plan v${VERSION}\e[0m"
    echo -e "  ──────────────────────────────────"
    echo -e "  Mode:         \e[1m${mode}\e[0m"
    echo -e "  Power:        ${ac_status}"
    echo -e "  Battery:      ${bat_pct}% (${watts}W draw)"
    echo -e "  CPU Governor: ${governor}"
    echo -e "  GPU:          ${gpu}"
    echo -e "  Brightness:   ${brightness}%"
    echo -e "  Auto-switch:  ${auto}"
    echo -e "  Daemon:       ${daemon_status}"
    echo ""

    # Estimated remaining time
    if ! is_on_ac && [[ "$watts" != "0" ]]; then
        local energy_wh hours
        energy_wh=$(battery_energy_wh)
        hours=$(awk "BEGIN {if ($watts > 0) printf \"%.1f\", $energy_wh / $watts; else print \"N/A\"}")
        echo -e "  \e[1;33mEstimated remaining: ${hours}h\e[0m"
        echo ""
    fi
}

# ── Status Bar (one-line for waybar/polybar) ─────────────────────────────────

status_bar() {
    local mode bat_pct watts
    mode=$(cfg_get current_mode balanced)
    bat_pct=$(battery_pct)
    watts=$(battery_watts)

    local icon
    case "$mode" in
        battery)     icon="BAT" ;;
        balanced)    icon="BAL" ;;
        performance) icon="MAX" ;;
    esac

    local time_str=""
    if ! is_on_ac && [[ "$watts" != "0" ]]; then
        local energy_wh hours
        energy_wh=$(battery_energy_wh)
        hours=$(awk "BEGIN {if ($watts > 0) printf \"%.1f\", $energy_wh / $watts; else print \"?\"}")
        time_str=" ${hours}h"
    fi

    echo "[${icon}] ${bat_pct}% ${watts}W${time_str}"
}

# ── Usage ────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
24HG Power Plan v${VERSION} — Laptop-aware gaming power management

Usage: 24hg-power-plan <command> [args]

Commands:
  status                Show current power plan and battery info
  bar                   One-line status for waybar/polybar
  battery               Switch to Battery mode (30fps, powersave, dim)
  balanced              Switch to Balanced mode (60fps, schedutil, medium)
  performance           Switch to Performance mode (uncapped, max everything)
  auto [on|off]         Toggle auto-switching on AC changes
  estimate [game]       Estimate battery life for a game
  override <appid> <mode>  Set per-game override (battery/balanced/performance/clear)
  daemon                Run as daemon for auto-switching
  help                  Show this help

Config: ${CONFIG_DIR}/
EOF
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
    ensure_config

    local cmd="${1:-status}"
    shift 2>/dev/null || true

    case "$cmd" in
        status)
            show_status
            ;;
        bar|statusbar)
            status_bar
            ;;
        battery)
            apply_mode "battery"
            ;;
        balanced)
            apply_mode "balanced"
            ;;
        performance)
            apply_mode "performance"
            ;;
        auto)
            local toggle="${1:-}"
            case "$toggle" in
                on)  cfg_set "auto_switch" "true"  ; log "Auto-switch enabled" ;;
                off) cfg_set "auto_switch" "false" ; log "Auto-switch disabled" ;;
                *)   echo "Auto-switch: $(cfg_get auto_switch true)" ;;
            esac
            ;;
        estimate)
            estimate_battery_life "${1:-idle}"
            ;;
        override)
            local appid="${1:-}" mode="${2:-}"
            [[ -z "$appid" ]] && err "Usage: 24hg-power-plan override <appid> <mode>"
            [[ -z "$mode" ]]  && { echo "Override for $appid: $(get_game_override "$appid")"; exit 0; }
            set_game_override "$appid" "$mode"
            ;;
        daemon)
            daemon_run
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            err "Unknown command: $cmd (try '24hg-power-plan help')"
            ;;
    esac
}

main "$@"
