#!/usr/bin/env bash
# 24hg-quick-resume — Quick Resume for 24HG Linux
# Saves and restores full desktop state across reboots.
# Like Xbox Quick Resume, but for the whole desktop.
set -euo pipefail

APP_NAME="24hg-quick-resume"
VERSION="1.0.0"
RESUME_DIR="${HOME}/.config/24hg/quick-resume"
MAX_SLOTS=3
AUTO_SLOT="__autosave__"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

log()  { echo -e "${GREEN}[Quick Resume]${NC} $*"; }
warn() { echo -e "${YELLOW}[Quick Resume]${NC} $*"; }
err()  { echo -e "${RED}[Quick Resume]${NC} $*" >&2; }

# ─── Helpers ──────────────────────────────────────────────────────────────────

ensure_dirs() {
    mkdir -p "${RESUME_DIR}/sessions"
}

slot_dir() {
    echo "${RESUME_DIR}/sessions/${1}"
}

timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

# Prefer kdotool (Wayland-native), fall back to xdotool/wmctrl
get_window_tool() {
    if command -v kdotool &>/dev/null; then
        echo "kdotool"
    elif command -v xdotool &>/dev/null; then
        echo "xdotool"
    else
        echo "none"
    fi
}

has_wmctrl() { command -v wmctrl &>/dev/null; }
has_qdbus()  { command -v qdbus &>/dev/null || command -v qdbus6 &>/dev/null; }

qdbus_cmd() {
    if command -v qdbus6 &>/dev/null; then
        qdbus6 "$@"
    elif command -v qdbus &>/dev/null; then
        qdbus "$@"
    fi
}

# ─── Session Capture ─────────────────────────────────────────────────────────

capture_running_apps() {
    local out="$1/apps.json"
    local entries=()

    # Get graphical apps via wmctrl or kdotool
    if has_wmctrl; then
        while IFS= read -r line; do
            local wid hex_id desktop title class_name cmd_line pid_val
            hex_id=$(echo "$line" | awk '{print $1}')
            desktop=$(echo "$line" | awk '{print $2}')
            pid_val=$(echo "$line" | awk '{print $3}')
            class_name=$(echo "$line" | awk '{print $4}')
            title=$(echo "$line" | awk '{for(i=5;i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/ *$//')

            # Get geometry
            local geom=""
            if [[ "$(get_window_tool)" == "xdotool" ]]; then
                geom=$(xdotool getwindowgeometry --shell "$hex_id" 2>/dev/null || true)
            fi
            local x=0 y=0 w=0 h=0
            if [[ -n "$geom" ]]; then
                x=$(echo "$geom" | grep '^X=' | cut -d= -f2)
                y=$(echo "$geom" | grep '^Y=' | cut -d= -f2)
                w=$(echo "$geom" | grep '^WIDTH=' | cut -d= -f2)
                h=$(echo "$geom" | grep '^HEIGHT=' | cut -d= -f2)
            fi

            # Resolve command from /proc
            cmd_line=""
            if [[ -d "/proc/${pid_val}" ]]; then
                cmd_line=$(tr '\0' ' ' < "/proc/${pid_val}/cmdline" 2>/dev/null | sed 's/ *$//' || true)
            fi

            entries+=("{\"wid\":\"${hex_id}\",\"desktop\":${desktop},\"pid\":${pid_val},\"class\":\"${class_name}\",\"title\":$(echo "$title" | python3 -c 'import json,sys;print(json.dumps(sys.stdin.read().strip()))' 2>/dev/null || echo '""'),\"cmd\":$(echo "$cmd_line" | python3 -c 'import json,sys;print(json.dumps(sys.stdin.read().strip()))' 2>/dev/null || echo '""'),\"x\":${x:-0},\"y\":${y:-0},\"w\":${w:-0},\"h\":${h:-0}}")
        done < <(wmctrl -l -p -x 2>/dev/null | grep -v '^\s*$')
    fi

    # Write JSON array
    {
        echo "["
        local first=true
        for e in "${entries[@]}"; do
            $first || echo ","
            echo "  $e"
            first=false
        done
        echo "]"
    } > "$out"
    log "Captured ${#entries[@]} windows"
}

capture_game_state() {
    local out="$1/games.json"
    local games=()

    # Check for common game launchers / running games
    for proc in steam gamescope lutris heroic bottles; do
        if pgrep -x "$proc" &>/dev/null; then
            local pid
            pid=$(pgrep -x "$proc" | head -1)
            local display_env=""
            display_env=$(tr '\0' '\n' < "/proc/${pid}/environ" 2>/dev/null | grep '^DISPLAY=' | cut -d= -f2 || true)
            games+=("{\"process\":\"${proc}\",\"pid\":${pid},\"display\":\"${display_env}\"}")
        fi
    done

    # Detect any Steam game via steam_app_ in /proc
    for pid_dir in /proc/[0-9]*/environ; do
        local app_id=""
        app_id=$(tr '\0' '\n' < "$pid_dir" 2>/dev/null | grep '^SteamAppId=' | cut -d= -f2 || true)
        if [[ -n "$app_id" && "$app_id" != "0" ]]; then
            local gpid
            gpid=$(echo "$pid_dir" | grep -o '[0-9]*')
            games+=("{\"type\":\"steam_app\",\"app_id\":\"${app_id}\",\"pid\":${gpid}}")
        fi
    done 2>/dev/null

    printf '[%s]\n' "$(IFS=,; echo "${games[*]}")" > "$out"
    log "Captured ${#games[@]} game processes"
}

capture_browser_state() {
    local out="$1/browsers.json"
    local browsers=()

    for browser in firefox chromium google-chrome brave-browser vivaldi microsoft-edge; do
        if pgrep -f "${browser}" &>/dev/null; then
            browsers+=("{\"name\":\"${browser}\",\"running\":true}")
        fi
    done

    printf '[%s]\n' "$(IFS=,; echo "${browsers[*]}")" > "$out"
    log "Captured ${#browsers[@]} browsers (they restore sessions natively)"
}

capture_terminal_state() {
    local out="$1/terminals.json"
    local terms=()

    # Find terminal emulators and their working directories
    for term in konsole gnome-terminal alacritty kitty wezterm foot xterm; do
        while IFS= read -r pid; do
            [[ -z "$pid" ]] && continue
            local cwd=""
            cwd=$(readlink -f "/proc/${pid}/cwd" 2>/dev/null || true)
            [[ -z "$cwd" ]] && continue

            # For konsole, try to get profile via qdbus
            local profile=""
            if [[ "$term" == "konsole" ]] && has_qdbus; then
                profile=$(qdbus_cmd org.kde.konsole-"${pid}" /Sessions/1 profile 2>/dev/null || true)
            fi

            terms+=("{\"emulator\":\"${term}\",\"pid\":${pid},\"cwd\":\"${cwd}\",\"profile\":\"${profile}\"}")
        done < <(pgrep -x "$term" 2>/dev/null)
    done

    printf '[%s]\n' "$(IFS=,; echo "${terms[*]}")" > "$out"
    log "Captured ${#terms[@]} terminal sessions"
}

capture_audio_state() {
    local out="$1/audio.json"

    if ! command -v pactl &>/dev/null && ! command -v wpctl &>/dev/null; then
        echo '{}' > "$out"
        warn "No audio control tool found (pactl/wpctl)"
        return
    fi

    local vol="" muted="" default_sink=""

    # Prefer WirePlumber (24HG default), fall back to PulseAudio
    if command -v wpctl &>/dev/null; then
        vol=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{print $2}' || echo "0")
        muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -c MUTED || echo "0")
        default_sink=$(wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep 'node.name' | head -1 | awk -F'"' '{print $2}' || true)
    elif command -v pactl &>/dev/null; then
        default_sink=$(pactl get-default-sink 2>/dev/null || true)
        vol=$(pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null | grep -oP '\d+%' | head -1 || echo "0%")
        muted=$(pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null | grep -c 'yes' || echo "0")
    fi

    cat > "$out" <<EOJSON
{
  "default_sink": "${default_sink}",
  "volume": "${vol}",
  "muted": ${muted},
  "tool": "$(command -v wpctl &>/dev/null && echo wpctl || echo pactl)"
}
EOJSON
    log "Captured audio state (sink=${default_sink}, vol=${vol})"
}

capture_workspace_state() {
    local out="$1/workspace.json"
    local current=0 count=1

    if has_qdbus; then
        count=$(qdbus_cmd org.kde.KWin /VirtualDesktopManager desktopCount 2>/dev/null || echo 1)
        current=$(qdbus_cmd org.kde.KWin /VirtualDesktopManager currentDesktop 2>/dev/null || echo 0)
    elif has_wmctrl; then
        current=$(wmctrl -d 2>/dev/null | grep '\*' | awk '{print $1}' || echo 0)
        count=$(wmctrl -d 2>/dev/null | wc -l || echo 1)
    fi

    cat > "$out" <<EOJSON
{
  "current_desktop": ${current},
  "desktop_count": ${count}
}
EOJSON
    log "Captured workspace state (desktop ${current}/${count})"
}

# ─── Session Restore ─────────────────────────────────────────────────────────

restore_audio() {
    local dir="$1"
    [[ -f "${dir}/audio.json" ]] || return 0

    local tool vol muted default_sink
    tool=$(python3 -c "import json;d=json.load(open('${dir}/audio.json'));print(d.get('tool',''))" 2>/dev/null || true)
    vol=$(python3 -c "import json;d=json.load(open('${dir}/audio.json'));print(d.get('volume',''))" 2>/dev/null || true)
    muted=$(python3 -c "import json;d=json.load(open('${dir}/audio.json'));print(d.get('muted',0))" 2>/dev/null || true)
    default_sink=$(python3 -c "import json;d=json.load(open('${dir}/audio.json'));print(d.get('default_sink',''))" 2>/dev/null || true)

    if [[ "$tool" == *"wpctl"* ]] && command -v wpctl &>/dev/null; then
        [[ -n "$vol" ]] && wpctl set-volume @DEFAULT_AUDIO_SINK@ "$vol" 2>/dev/null || true
        [[ "$muted" == "1" ]] && wpctl set-mute @DEFAULT_AUDIO_SINK@ 1 2>/dev/null || true
    elif command -v pactl &>/dev/null; then
        [[ -n "$default_sink" ]] && pactl set-default-sink "$default_sink" 2>/dev/null || true
        [[ -n "$vol" ]] && pactl set-sink-volume @DEFAULT_SINK@ "$vol" 2>/dev/null || true
        [[ "$muted" == "1" ]] && pactl set-sink-mute @DEFAULT_SINK@ 1 2>/dev/null || true
    fi
    log "Restored audio state"
}

restore_workspace() {
    local dir="$1"
    [[ -f "${dir}/workspace.json" ]] || return 0

    local current
    current=$(python3 -c "import json;d=json.load(open('${dir}/workspace.json'));print(d.get('current_desktop',0))" 2>/dev/null || true)

    if has_qdbus && [[ -n "$current" ]]; then
        qdbus_cmd org.kde.KWin /VirtualDesktopManager setCurrent "$current" 2>/dev/null || true
    elif has_wmctrl && [[ -n "$current" ]]; then
        wmctrl -s "$current" 2>/dev/null || true
    fi
    log "Restored workspace ${current}"
}

restore_terminals() {
    local dir="$1"
    [[ -f "${dir}/terminals.json" ]] || return 0

    python3 -c "
import json, subprocess, os
terms = json.load(open('${dir}/terminals.json'))
for t in terms:
    emu = t.get('emulator','')
    cwd = t.get('cwd', os.environ.get('HOME', '/'))
    if not os.path.isdir(cwd):
        cwd = os.environ.get('HOME', '/')
    if emu == 'konsole':
        profile = t.get('profile', '')
        cmd = ['konsole', '--workdir', cwd]
        if profile:
            cmd += ['--profile', profile]
        subprocess.Popen(cmd, start_new_session=True)
    elif emu in ('alacritty', 'kitty', 'wezterm', 'foot'):
        subprocess.Popen([emu, '--working-directory', cwd], start_new_session=True)
    elif emu == 'gnome-terminal':
        subprocess.Popen(['gnome-terminal', '--working-directory=' + cwd], start_new_session=True)
" 2>/dev/null || warn "Some terminals failed to restore"
    log "Restored terminal sessions"
}

restore_browsers() {
    local dir="$1"
    [[ -f "${dir}/browsers.json" ]] || return 0

    python3 -c "
import json, subprocess, shutil
browsers = json.load(open('${dir}/browsers.json'))
for b in browsers:
    name = b.get('name','')
    if not b.get('running', False):
        continue
    exe = shutil.which(name)
    if exe:
        # Browsers restore their own session on relaunch
        subprocess.Popen([exe], start_new_session=True)
" 2>/dev/null || warn "Some browsers failed to launch"
    log "Relaunched browsers (they restore tabs natively)"
}

restore_apps() {
    local dir="$1"
    [[ -f "${dir}/apps.json" ]] || return 0

    # Skip well-known apps restored by other functions
    local skip_classes="konsole|alacritty|kitty|wezterm|foot|gnome-terminal|xterm"
    skip_classes+="|firefox|chromium|google-chrome|brave-browser|vivaldi|microsoft-edge"
    skip_classes+="|steam|gamescope|lutris|heroic|bottles|plasmashell|kwin|krunner"

    python3 -c "
import json, subprocess, re, time

skip = re.compile(r'(${skip_classes})', re.I)
apps = json.load(open('${dir}/apps.json'))
launched = set()

for app in apps:
    cls = app.get('class', '')
    cmd = app.get('cmd', '')
    if not cmd or skip.search(cls) or skip.search(cmd):
        continue
    # Use the executable name (first arg) as dedup key
    exe = cmd.split()[0].split('/')[-1]
    if exe in launched:
        continue
    launched.add(exe)
    try:
        subprocess.Popen(cmd.split(), start_new_session=True)
    except Exception:
        pass
" 2>/dev/null || warn "Some apps failed to restore"

    # After apps launch, try to restore window geometry
    sleep 3
    restore_window_geometry "$dir"
    log "Restored applications"
}

restore_window_geometry() {
    local dir="$1"
    [[ -f "${dir}/apps.json" ]] || return 0
    has_wmctrl || return 0

    python3 -c "
import json, subprocess

apps = json.load(open('${dir}/apps.json'))
# Get current windows
result = subprocess.run(['wmctrl', '-l', '-x'], capture_output=True, text=True)
current = {}
for line in result.stdout.strip().split('\n'):
    parts = line.split()
    if len(parts) >= 4:
        current[parts[3].lower()] = parts[0]  # class -> wid

for app in apps:
    cls = app.get('class', '').lower()
    x, y, w, h = app.get('x',0), app.get('y',0), app.get('w',0), app.get('h',0)
    desktop = app.get('desktop', 0)
    if cls in current and w > 0 and h > 0:
        wid = current[cls]
        subprocess.run(['wmctrl', '-i', '-r', wid, '-t', str(desktop)], capture_output=True)
        subprocess.run(['wmctrl', '-i', '-r', wid, '-e', f'0,{x},{y},{w},{h}'], capture_output=True)
" 2>/dev/null || true
}

restore_games() {
    local dir="$1"
    [[ -f "${dir}/games.json" ]] || return 0

    python3 -c "
import json, subprocess, shutil

games = json.load(open('${dir}/games.json'))
launched = set()
for g in games:
    if g.get('type') == 'steam_app':
        app_id = g.get('app_id', '')
        if app_id and app_id not in launched and shutil.which('steam'):
            subprocess.Popen(['steam', f'steam://rungameid/{app_id}'], start_new_session=True)
            launched.add(app_id)
    else:
        proc = g.get('process', '')
        if proc and proc not in launched and shutil.which(proc):
            subprocess.Popen([proc], start_new_session=True)
            launched.add(proc)
" 2>/dev/null || warn "Some games failed to restore"
    log "Restored game sessions"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_save() {
    local name="${1:-default}"
    ensure_dirs

    # Enforce slot limit (excluding autosave)
    local user_slots
    user_slots=$(find "${RESUME_DIR}/sessions" -mindepth 1 -maxdepth 1 -type d \
        ! -name "${AUTO_SLOT}" 2>/dev/null | wc -l)
    if [[ "$name" != "${AUTO_SLOT}" && ! -d "$(slot_dir "$name")" && "$user_slots" -ge "$MAX_SLOTS" ]]; then
        err "Maximum ${MAX_SLOTS} session slots reached. Delete one first."
        cmd_list
        return 1
    fi

    local dir
    dir=$(slot_dir "$name")
    rm -rf "$dir"
    mkdir -p "$dir"

    log "Saving session '${name}'..."
    capture_running_apps "$dir"
    capture_game_state "$dir"
    capture_browser_state "$dir"
    capture_terminal_state "$dir"
    capture_audio_state "$dir"
    capture_workspace_state "$dir"

    # Metadata
    cat > "${dir}/meta.json" <<EOJSON
{
  "name": "${name}",
  "timestamp": "$(timestamp)",
  "hostname": "$(hostname)",
  "user": "${USER}",
  "version": "${VERSION}"
}
EOJSON

    log "${BOLD}Session '${name}' saved successfully${NC}"
}

cmd_restore() {
    local name="${1:-default}"
    local dir
    dir=$(slot_dir "$name")

    if [[ ! -d "$dir" ]]; then
        err "Session '${name}' not found."
        cmd_list
        return 1
    fi

    local ts
    ts=$(python3 -c "import json;print(json.load(open('${dir}/meta.json')).get('timestamp','unknown'))" 2>/dev/null || echo "unknown")
    log "Restoring session '${name}' (saved ${ts})..."

    restore_audio "$dir"
    restore_workspace "$dir"
    restore_terminals "$dir"
    restore_browsers "$dir"
    restore_games "$dir"
    restore_apps "$dir"

    log "${BOLD}Session '${name}' restored${NC}"
}

cmd_list() {
    ensure_dirs
    echo -e "${BOLD}Saved Quick Resume Sessions${NC}"
    echo "──────────────────────────────────────"

    local found=false
    for dir in "${RESUME_DIR}/sessions"/*/; do
        [[ -d "$dir" ]] || continue
        found=true
        local name meta_file ts
        name=$(basename "$dir")
        meta_file="${dir}meta.json"

        if [[ -f "$meta_file" ]]; then
            ts=$(python3 -c "import json;print(json.load(open('${meta_file}')).get('timestamp','?'))" 2>/dev/null || echo "?")
        else
            ts="?"
        fi

        local label="$name"
        [[ "$name" == "${AUTO_SLOT}" ]] && label="autosave (before shutdown)"

        local app_count=0
        [[ -f "${dir}apps.json" ]] && app_count=$(python3 -c "import json;print(len(json.load(open('${dir}apps.json'))))" 2>/dev/null || echo 0)

        printf "  ${BLUE}%-20s${NC}  %s  (%s windows)\n" "$label" "$ts" "$app_count"
    done

    if ! $found; then
        echo "  (no saved sessions)"
    fi
    echo ""
    echo "Slots used: $(find "${RESUME_DIR}/sessions" -mindepth 1 -maxdepth 1 -type d ! -name "${AUTO_SLOT}" 2>/dev/null | wc -l)/${MAX_SLOTS}"
}

cmd_delete() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "Usage: ${APP_NAME} delete <name>"
        return 1
    fi

    local dir
    dir=$(slot_dir "$name")
    if [[ ! -d "$dir" ]]; then
        err "Session '${name}' not found."
        return 1
    fi

    rm -rf "$dir"
    log "Deleted session '${name}'"
}

cmd_auto_save() {
    log "Auto-saving session before shutdown..."
    cmd_save "${AUTO_SLOT}"
}

cmd_auto_restore() {
    local dir
    dir=$(slot_dir "${AUTO_SLOT}")
    if [[ ! -d "$dir" ]]; then
        log "No auto-save found, skipping restore."
        return 0
    fi

    log "Auto-restoring session from last shutdown..."
    cmd_restore "${AUTO_SLOT}"

    # Clean up autosave after successful restore
    rm -rf "$dir"
    log "Cleaned up autosave slot"
}

cmd_help() {
    cat <<EOF
${BOLD}${APP_NAME} v${VERSION}${NC} — Quick Resume for 24HG Linux

Save and restore your full desktop state across reboots.

${BOLD}USAGE${NC}
    ${APP_NAME} <command> [options]

${BOLD}COMMANDS${NC}
    save [name]       Save current session (default name: "default")
    restore [name]    Restore a saved session
    list              List all saved sessions
    delete <name>     Delete a saved session
    auto-save         Save session before shutdown (for systemd/autostart)
    auto-restore      Restore session at login (for autostart)
    help              Show this help

${BOLD}WHAT GETS SAVED${NC}
    - Running applications and their window positions
    - Workspace/virtual desktop assignments
    - Active games (Steam app IDs, launchers)
    - Open browsers (they restore tabs natively on relaunch)
    - Terminal sessions with working directories
    - Audio volume, output device, mute state

${BOLD}EXAMPLES${NC}
    ${APP_NAME} save work        Save current state as "work"
    ${APP_NAME} save gaming      Save current state as "gaming"
    ${APP_NAME} restore work     Restore the "work" session
    ${APP_NAME} list             Show all saved sessions

${BOLD}AUTO SETUP${NC}
    Add to shutdown:   systemd service calling "${APP_NAME} auto-save"
    Add to login:      XDG autostart calling "${APP_NAME} auto-restore"

${BOLD}SESSION SLOTS${NC}
    Up to ${MAX_SLOTS} named sessions + 1 autosave slot.
    Stored in: ${RESUME_DIR}/sessions/
EOF
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        save)         cmd_save "$@" ;;
        restore)      cmd_restore "$@" ;;
        list|ls)      cmd_list ;;
        delete|rm)    cmd_delete "$@" ;;
        auto-save)    cmd_auto_save ;;
        auto-restore) cmd_auto_restore ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) echo "${APP_NAME} v${VERSION}" ;;
        *)
            err "Unknown command: ${cmd}"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
