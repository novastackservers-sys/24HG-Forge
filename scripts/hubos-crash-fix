#!/usr/bin/env bash
# HubOS Game Crash Diagnosis & Auto-Fix Tool
# Analyzes Steam/Proton crash logs, system journals, and common failure modes.
# Supports both Flatpak and native Steam installations on Bazzite/Fedora Atomic.
#
# Usage: hubos-crash-fix <command> [game] [options]
#   diagnose <appid|name>  — Analyze why a game crashed
#   fix <appid|name>       — Auto-fix common crash issues
#   log <appid|name>       — Show recent crash logs, formatted and filtered
#   report                 — Generate full crash report for sharing
#   watch                  — Monitor for crashes in real-time, auto-diagnose
#
# Options:
#   --gui                  — Use zenity dialogs for GUI mode
#   --verbose              — Extra detail in output
#   --no-color             — Disable colored output
#   -h, --help             — Show this help

set -euo pipefail

# ─── Constants & Globals ─────────────────────────────────────────────────────

readonly VERSION="2.0.0"
readonly PROG_NAME="hubos-crash-fix"

STEAM_FLATPAK="${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam"
STEAM_NATIVE="${HOME}/.local/share/Steam"
STEAM_DIR=""

GUI_MODE=false
VERBOSE=false
NO_COLOR=false

# Severity colors (may be disabled via --no-color)
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Diagnosis scoring
declare -A CAUSE_SCORES=()
declare -a ISSUES=()
declare -a FIXES_APPLIED=()

# ─── Utility Functions ───────────────────────────────────────────────────────

disable_colors() {
    RED="" YELLOW="" GREEN="" CYAN="" MAGENTA="" BOLD="" DIM="" NC=""
}

log_crit()    { echo -e "  ${RED}[CRITICAL]${NC} $1"; }
log_warn()    { echo -e "  ${YELLOW}[WARNING]${NC}  $1"; }
log_info()    { echo -e "  ${CYAN}[INFO]${NC}     $1"; }
log_ok()      { echo -e "  ${GREEN}[OK]${NC}       $1"; }
log_debug()   { $VERBOSE && echo -e "  ${DIM}[DEBUG]    $1${NC}" || true; }
log_fix()     { echo -e "  ${MAGENTA}[FIX]${NC}      $1"; FIXES_APPLIED+=("$1"); }

header() {
    echo ""
    echo -e "${BOLD}━━━ $1 ━━━${NC}"
}

subheader() {
    echo -e "  ${BOLD}── $1${NC}"
}

separator() {
    echo -e "${DIM}────────────────────────────────────────────────────${NC}"
}

score_cause() {
    local cause="$1"
    local points="$2"
    local current="${CAUSE_SCORES[$cause]:-0}"
    CAUSE_SCORES[$cause]=$(( current + points ))
}

record_issue() {
    ISSUES+=("$1")
}

confirm_action() {
    local prompt="$1"
    if $GUI_MODE; then
        zenity --question --title="$PROG_NAME" --text="$prompt" 2>/dev/null
        return $?
    fi
    echo -en "  ${YELLOW}$prompt [y/N]:${NC} "
    local reply
    read -r reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

notify_user() {
    local title="$1"
    local body="$2"
    if command -v notify-send &>/dev/null; then
        notify-send -a "$PROG_NAME" -i dialog-warning "$title" "$body" 2>/dev/null || true
    fi
}

gui_info() {
    local title="$1"
    local text="$2"
    if $GUI_MODE && command -v zenity &>/dev/null; then
        zenity --info --title="$title" --text="$text" --width=500 2>/dev/null || true
    fi
}

gui_select() {
    local title="$1"
    shift
    if $GUI_MODE && command -v zenity &>/dev/null; then
        zenity --list --title="$title" --column="Option" "$@" --width=400 --height=300 2>/dev/null
        return $?
    fi
    return 1
}

die() {
    echo -e "${RED}Error:${NC} $1" >&2
    exit 1
}

require_cmd() {
    command -v "$1" &>/dev/null || die "Required command '$1' not found. Install it first."
}

# ─── Steam Directory Detection ──────────────────────────────────────────────

detect_steam_dir() {
    if [[ -d "$STEAM_FLATPAK" ]]; then
        STEAM_DIR="$STEAM_FLATPAK"
        log_debug "Using Flatpak Steam at $STEAM_DIR"
    elif [[ -d "$STEAM_NATIVE" ]]; then
        STEAM_DIR="$STEAM_NATIVE"
        log_debug "Using native Steam at $STEAM_DIR"
    else
        die "No Steam installation found. Checked:\n  $STEAM_FLATPAK\n  $STEAM_NATIVE"
    fi
}

is_flatpak_steam() {
    [[ "$STEAM_DIR" == "$STEAM_FLATPAK" ]]
}

# ─── Game / AppID Resolution ────────────────────────────────────────────────

resolve_game() {
    local input="$1"
    local appid=""
    local game_name=""

    # If purely numeric, treat as AppID directly
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        appid="$input"
        game_name=$(find_game_name_by_appid "$appid")
        [[ -z "$game_name" ]] && game_name="AppID $appid"
    else
        # Search appmanifest files for a name match
        local result
        result=$(search_appmanifest_by_name "$input")
        if [[ -n "$result" ]]; then
            appid="${result%%|*}"
            game_name="${result#*|}"
        else
            die "Could not find a game matching '$input'. Try using the Steam AppID instead."
        fi
    fi

    echo "${appid}|${game_name}"
}

find_game_name_by_appid() {
    local appid="$1"
    local manifest
    for lib_dir in $(get_library_folders); do
        manifest="${lib_dir}/steamapps/appmanifest_${appid}.acf"
        if [[ -f "$manifest" ]]; then
            sed -n 's/.*"name"\s*"\(.*\)"/\1/p' "$manifest" | head -1
            return 0
        fi
    done
    echo ""
}

search_appmanifest_by_name() {
    local query="$1"
    local query_lower
    query_lower=$(echo "$query" | tr '[:upper:]' '[:lower:]')

    for lib_dir in $(get_library_folders); do
        local manifests_dir="${lib_dir}/steamapps"
        [[ -d "$manifests_dir" ]] || continue
        for manifest in "$manifests_dir"/appmanifest_*.acf; do
            [[ -f "$manifest" ]] || continue
            local name
            name=$(sed -n 's/.*"name"\s*"\(.*\)"/\1/p' "$manifest" | head -1)
            local name_lower
            name_lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')
            if [[ "$name_lower" == *"$query_lower"* ]]; then
                local aid
                aid=$(sed -n 's/.*"appid"\s*"\(.*\)"/\1/p' "$manifest" | head -1)
                echo "${aid}|${name}"
                return 0
            fi
        done
    done
    echo ""
}

get_library_folders() {
    echo "$STEAM_DIR"
    local vdf="${STEAM_DIR}/steamapps/libraryfolders.vdf"
    if [[ -f "$vdf" ]]; then
        sed -n 's/.*"path"\s*"\(.*\)"/\1/p' "$vdf" 2>/dev/null
    fi
}

get_compatdata_dir() {
    local appid="$1"
    for lib_dir in $(get_library_folders); do
        local cdir="${lib_dir}/steamapps/compatdata/${appid}"
        if [[ -d "$cdir" ]]; then
            echo "$cdir"
            return 0
        fi
    done
    echo "${STEAM_DIR}/steamapps/compatdata/${appid}"
}

get_shader_cache_dir() {
    local appid="$1"
    for lib_dir in $(get_library_folders); do
        local sdir="${lib_dir}/steamapps/shadercache/${appid}"
        if [[ -d "$sdir" ]]; then
            echo "$sdir"
            return 0
        fi
    done
    echo "${STEAM_DIR}/steamapps/shadercache/${appid}"
}

# ─── Diagnosis Engine ────────────────────────────────────────────────────────

check_oom_killer() {
    local appid="$1"
    local game_name="$2"
    subheader "OOM Killer Check"

    local oom_lines
    oom_lines=$(dmesg 2>/dev/null | grep -i "oom-kill\|out of memory\|killed process" | tail -20) || true

    if [[ -n "$oom_lines" ]]; then
        local recent
        recent=$(echo "$oom_lines" | tail -5)
        log_crit "OOM killer activity detected in kernel log"
        echo "$recent" | while IFS= read -r line; do
            echo -e "    ${DIM}${line}${NC}"
        done
        score_cause "oom" 40
        record_issue "OOM killer terminated process — system ran out of memory"

        # Check if it's game-related
        if echo "$oom_lines" | grep -qi "wine\|proton\|pressure-vessel\|reaper\|steam"; then
            score_cause "oom" 30
            log_crit "OOM kill appears to target a Steam/Proton process"
        fi
    else
        log_ok "No OOM kills detected in kernel log"
    fi

    # Check current memory pressure
    local mem_avail
    mem_avail=$(awk '/MemAvailable/ {print $2}' /proc/meminfo 2>/dev/null) || mem_avail=0
    local mem_total
    mem_total=$(awk '/MemTotal/ {print $2}' /proc/meminfo 2>/dev/null) || mem_total=1
    local mem_pct=$(( (mem_total - mem_avail) * 100 / mem_total ))

    if (( mem_pct > 90 )); then
        log_warn "Memory usage is very high: ${mem_pct}% used"
        score_cause "oom" 15
    elif (( mem_pct > 75 )); then
        log_info "Memory usage is elevated: ${mem_pct}% used"
        score_cause "oom" 5
    else
        log_ok "Memory usage normal: ${mem_pct}% used"
    fi

    # Check swap
    local swap_total
    swap_total=$(awk '/SwapTotal/ {print $2}' /proc/meminfo 2>/dev/null) || swap_total=0
    if (( swap_total < 1048576 )); then
        log_warn "Swap space is low ($(( swap_total / 1024 )) MB) — games may crash under memory pressure"
        score_cause "oom" 10
    fi

    # Check vm.max_map_count
    local mmc
    mmc=$(cat /proc/sys/vm/max_map_count 2>/dev/null) || mmc=0
    if (( mmc < 1048576 )); then
        log_warn "vm.max_map_count=$mmc (should be >=1048576 for many games)"
        score_cause "oom" 10
        record_issue "vm.max_map_count too low ($mmc) — some games need 1048576+"
    else
        log_ok "vm.max_map_count=$mmc (adequate)"
    fi
}

check_gpu_errors() {
    local appid="$1"
    subheader "GPU Error Check"

    # NVIDIA Xid errors
    local xid_errors
    xid_errors=$(dmesg 2>/dev/null | grep -i "NVRM\|Xid\|nvidia" | grep -i "error\|fault\|hang\|reset\|Xid" | tail -10) || true

    if [[ -n "$xid_errors" ]]; then
        log_crit "NVIDIA GPU errors detected (Xid/fault)"
        echo "$xid_errors" | tail -5 | while IFS= read -r line; do
            echo -e "    ${DIM}${line}${NC}"
        done
        score_cause "nvidia_crash" 45
        record_issue "NVIDIA Xid or GPU fault errors in dmesg"

        # Specific Xid decoding
        if echo "$xid_errors" | grep -q "Xid.*31"; then
            log_crit "Xid 31: GPU memory page fault — likely driver bug or hardware issue"
            score_cause "nvidia_crash" 20
        fi
        if echo "$xid_errors" | grep -q "Xid.*79"; then
            log_crit "Xid 79: GPU fallen off the bus — possible hardware/power issue"
            score_cause "nvidia_crash" 25
        fi
        if echo "$xid_errors" | grep -q "Xid.*13"; then
            log_warn "Xid 13: GR copy error — often a driver or VRAM issue"
            score_cause "nvidia_crash" 10
        fi
    else
        log_ok "No NVIDIA Xid errors in kernel log"
    fi

    # AMD GPU resets
    local amd_errors
    amd_errors=$(dmesg 2>/dev/null | grep -i "amdgpu\|radeon" | grep -i "hang\|reset\|error\|timeout\|fence" | tail -10) || true

    if [[ -n "$amd_errors" ]]; then
        log_crit "AMD GPU errors detected (hang/reset)"
        echo "$amd_errors" | tail -5 | while IFS= read -r line; do
            echo -e "    ${DIM}${line}${NC}"
        done
        score_cause "gpu_hang" 45
        record_issue "AMD GPU hang or reset detected in dmesg"

        if echo "$amd_errors" | grep -qi "ring.*gfx.*timeout\|job timeout"; then
            log_crit "GPU job timeout — likely shader compilation stall or driver issue"
            score_cause "gpu_hang" 15
        fi
    else
        log_ok "No AMD GPU errors in kernel log"
    fi

    # Vulkan device lost
    local vk_lost
    vk_lost=$(journalctl --user --since "1 hour ago" --no-pager 2>/dev/null | grep -i "VK_ERROR_DEVICE_LOST\|vulkan.*device.*lost\|device lost" | tail -5) || true

    if [[ -n "$vk_lost" ]]; then
        log_crit "Vulkan VK_ERROR_DEVICE_LOST detected in journal"
        score_cause "vulkan_device_lost" 50
        record_issue "Vulkan device lost — GPU crashed during rendering"
    fi

    # Check for mesa errors
    local mesa_err
    mesa_err=$(journalctl --user --since "1 hour ago" --no-pager 2>/dev/null | grep -i "mesa\|radv\|anv\|iris" | grep -i "error\|fail\|assert" | tail -5) || true

    if [[ -n "$mesa_err" ]]; then
        log_warn "Mesa/Vulkan driver errors in journal"
        echo "$mesa_err" | tail -3 | while IFS= read -r line; do
            echo -e "    ${DIM}${line}${NC}"
        done
        score_cause "gpu_hang" 10
    fi
}

check_proton_logs() {
    local appid="$1"
    subheader "Proton / Wine Logs"

    local compatdata
    compatdata=$(get_compatdata_dir "$appid")

    # Check proton crash dumps
    local crash_dir="${compatdata}/crash_dumps"
    if [[ -d "$crash_dir" ]]; then
        local dump_count
        dump_count=$(find "$crash_dir" -type f -name "*.dmp" -mtime -1 2>/dev/null | wc -l) || dump_count=0
        if (( dump_count > 0 )); then
            log_warn "$dump_count crash dump(s) found in last 24 hours"
            find "$crash_dir" -type f -name "*.dmp" -mtime -1 -printf "    %T+ %f\n" 2>/dev/null | sort -r | head -5
            score_cause "proton_crash" 25
            record_issue "$dump_count recent crash dumps in compatdata"
        else
            log_ok "No recent crash dumps"
        fi
    else
        log_debug "No crash_dumps directory for AppID $appid"
    fi

    # Check /tmp/proton_* logs
    local proton_logs
    proton_logs=$(ls -1t /tmp/proton_${appid}* 2>/dev/null | head -3) || true
    if [[ -z "$proton_logs" ]]; then
        proton_logs=$(ls -1t /tmp/proton_* 2>/dev/null | head -3) || true
    fi

    if [[ -n "$proton_logs" ]]; then
        log_info "Proton log files found in /tmp:"
        echo "$proton_logs" | while IFS= read -r plog; do
            [[ -f "$plog" ]] || continue
            echo -e "    ${DIM}${plog}${NC}"

            # Scan for errors
            local err_lines
            err_lines=$(grep -i "err\|fail\|crash\|abort\|fatal\|unhandled\|exception\|missing" "$plog" 2>/dev/null | tail -10) || true
            if [[ -n "$err_lines" ]]; then
                score_cause "proton_crash" 15
                echo "$err_lines" | tail -5 | while IFS= read -r el; do
                    echo -e "      ${RED}${el}${NC}"
                done
            fi
        done
    fi

    # Check prefix integrity
    if [[ -d "$compatdata" ]]; then
        local pfx="${compatdata}/pfx"
        if [[ -d "$pfx" ]]; then
            # Check for corrupted system.reg
            if [[ -f "${pfx}/system.reg" ]]; then
                local reg_size
                reg_size=$(stat -c%s "${pfx}/system.reg" 2>/dev/null) || reg_size=0
                if (( reg_size < 1000 )); then
                    log_crit "Proton prefix system.reg is suspiciously small (${reg_size} bytes) — likely corrupted"
                    score_cause "prefix_corruption" 50
                    record_issue "Proton prefix appears corrupted (tiny system.reg)"
                else
                    log_ok "Proton prefix exists and looks intact"
                fi
            fi

            # Check for .crash files
            local crash_files
            crash_files=$(find "$pfx" -name "*.crash" -o -name "crash.log" -o -name "error.log" 2>/dev/null | head -5) || true
            if [[ -n "$crash_files" ]]; then
                log_warn "Crash/error files found inside prefix:"
                echo "$crash_files" | while IFS= read -r cf; do
                    echo -e "    ${DIM}${cf}${NC}"
                done
                score_cause "proton_crash" 10
            fi
        else
            log_warn "Proton prefix directory missing for AppID $appid"
            score_cause "prefix_corruption" 20
        fi
    else
        log_info "No compatdata directory found for AppID $appid"
    fi
}

check_missing_libs() {
    local appid="$1"
    subheader "Missing Libraries Check"

    local compatdata
    compatdata=$(get_compatdata_dir "$appid")

    # Scan recent journal for missing DLL / .so messages
    local missing
    missing=$(journalctl --user --since "2 hours ago" --no-pager 2>/dev/null \
        | grep -i "cannot open shared\|not found.*\.dll\|missing.*\.dll\|err:module\|err:wineboot\|vcruntime\|msvcp\|d3d.*\.dll\|msvc" \
        | tail -20) || true

    if [[ -n "$missing" ]]; then
        log_warn "Missing library references detected in journal:"
        echo "$missing" | tail -8 | while IFS= read -r ml; do
            echo -e "    ${DIM}${ml}${NC}"
        done
        score_cause "missing_libs" 35
        record_issue "Missing libraries/DLLs referenced in logs"

        # Detect specific missing runtimes
        if echo "$missing" | grep -qi "vcruntime\|msvcp\|vcredist"; then
            score_cause "missing_libs" 15
            record_issue "Visual C++ runtime appears missing (vcredist)"
        fi
        if echo "$missing" | grep -qi "d3dx\|d3dcompiler\|xinput"; then
            score_cause "missing_libs" 10
            record_issue "DirectX components appear missing (d3dx/xinput)"
        fi
        if echo "$missing" | grep -qi "dotnet\|mscoree\|clr"; then
            score_cause "missing_libs" 10
            record_issue ".NET Framework appears missing"
        fi
    else
        log_ok "No missing library errors found in recent journal"
    fi

    # Check proton log for dll load failures
    local plog
    for plog in /tmp/proton_${appid}* /tmp/proton_*; do
        [[ -f "$plog" ]] || continue
        local dll_err
        dll_err=$(grep -i "err:module.*could not load\|err:module.*not found\|failed to load" "$plog" 2>/dev/null | tail -5) || true
        if [[ -n "$dll_err" ]]; then
            log_warn "DLL load failures in Proton log ($plog):"
            echo "$dll_err" | while IFS= read -r de; do
                echo -e "    ${DIM}${de}${NC}"
            done
            score_cause "missing_libs" 20
            break
        fi
    done
}

check_shader_issues() {
    local appid="$1"
    subheader "Shader Cache / Compilation"

    local shader_dir
    shader_dir=$(get_shader_cache_dir "$appid")

    if [[ -d "$shader_dir" ]]; then
        local cache_size
        cache_size=$(du -sm "$shader_dir" 2>/dev/null | awk '{print $1}') || cache_size=0
        log_info "Shader cache size: ${cache_size} MB"

        if (( cache_size > 2048 )); then
            log_warn "Shader cache is very large (${cache_size} MB) — may cause stalls"
            score_cause "shader_issue" 15
            record_issue "Oversized shader cache (${cache_size} MB)"
        fi

        # Check for stale or empty pipeline caches
        local empty_caches
        empty_caches=$(find "$shader_dir" -type f -empty 2>/dev/null | wc -l) || empty_caches=0
        if (( empty_caches > 10 )); then
            log_warn "$empty_caches empty shader cache files — may indicate compilation failures"
            score_cause "shader_issue" 20
            record_issue "Multiple empty shader cache files found"
        fi
    else
        log_info "No shader cache directory for AppID $appid"
    fi

    # Look for shader timeout/compilation errors in journal
    local shader_err
    shader_err=$(journalctl --user --since "2 hours ago" --no-pager 2>/dev/null \
        | grep -i "shader.*compil\|pipeline.*timeout\|shader.*timeout\|fossilize\|pipeline cache" \
        | grep -i "error\|fail\|timeout\|crash" | tail -5) || true

    if [[ -n "$shader_err" ]]; then
        log_warn "Shader compilation errors in journal"
        echo "$shader_err" | while IFS= read -r se; do
            echo -e "    ${DIM}${se}${NC}"
        done
        score_cause "shader_issue" 25
        record_issue "Shader compilation errors or timeouts detected"
    else
        log_ok "No shader compilation errors in journal"
    fi
}

check_disk_space() {
    local appid="$1"
    subheader "Disk Space"

    local steam_mount
    steam_mount=$(df -P "$STEAM_DIR" 2>/dev/null | awk 'NR==2 {print $6}') || steam_mount="/"
    local avail_mb
    avail_mb=$(df -BM -P "$STEAM_DIR" 2>/dev/null | awk 'NR==2 {gsub("M",""); print $4}') || avail_mb=999999
    local use_pct
    use_pct=$(df -P "$STEAM_DIR" 2>/dev/null | awk 'NR==2 {print $5}') || use_pct="0%"

    if (( avail_mb < 1024 )); then
        log_crit "Very low disk space: ${avail_mb} MB free on $steam_mount (${use_pct} used)"
        score_cause "disk_full" 50
        record_issue "Less than 1 GB free on Steam partition"
    elif (( avail_mb < 5120 )); then
        log_warn "Low disk space: ${avail_mb} MB free on $steam_mount (${use_pct} used)"
        score_cause "disk_full" 20
        record_issue "Less than 5 GB free on Steam partition"
    else
        log_ok "Disk space OK: ${avail_mb} MB free on $steam_mount (${use_pct} used)"
    fi

    # Check /tmp
    local tmp_avail
    tmp_avail=$(df -BM -P /tmp 2>/dev/null | awk 'NR==2 {gsub("M",""); print $4}') || tmp_avail=999999
    if (( tmp_avail < 512 )); then
        log_warn "/tmp has only ${tmp_avail} MB free — Proton may fail to extract"
        score_cause "disk_full" 15
    fi
}

check_journal_errors() {
    local appid="$1"
    subheader "Recent System Journal Errors"

    local recent_errors
    recent_errors=$(journalctl --user --since "30 min ago" --priority=err --no-pager 2>/dev/null | tail -15) || true

    if [[ -n "$recent_errors" ]]; then
        local err_count
        err_count=$(echo "$recent_errors" | wc -l)
        log_warn "$err_count error-level entries in user journal (last 30min)"
        $VERBOSE && echo "$recent_errors" | tail -8 | while IFS= read -r je; do
            echo -e "    ${DIM}${je}${NC}"
        done

        # Specific patterns
        if echo "$recent_errors" | grep -qi "segfault\|sigsegv\|SIGABRT"; then
            log_crit "Segfault or abort signal detected"
            score_cause "proton_crash" 30
            record_issue "Process crash (segfault/abort) in journal"
        fi
        if echo "$recent_errors" | grep -qi "pressure-vessel\|steam-runtime"; then
            log_warn "Steam runtime / pressure-vessel errors detected"
            score_cause "proton_crash" 10
        fi
    else
        log_ok "No recent error-level entries in user journal"
    fi

    # System-level (dmesg for hardware/kernel issues)
    local hw_errors
    hw_errors=$(dmesg 2>/dev/null | grep -i "hardware error\|MCE\|thermal.*critical\|CPU.*throttl" | tail -5) || true
    if [[ -n "$hw_errors" ]]; then
        log_warn "Hardware/thermal errors in dmesg:"
        echo "$hw_errors" | while IFS= read -r he; do
            echo -e "    ${DIM}${he}${NC}"
        done
        score_cause "hardware_issue" 20
        record_issue "Hardware or thermal errors in kernel log"
    fi
}

present_diagnosis() {
    local game_name="$1"
    header "Diagnosis Results for ${game_name}"

    if [[ ${#CAUSE_SCORES[@]} -eq 0 ]]; then
        log_ok "No clear crash cause detected. The game may have exited normally or the logs have rotated."
        return
    fi

    # Sort causes by score descending, show top 3
    echo -e "  ${BOLD}Top suspected causes:${NC}"
    echo ""

    local rank=1
    while IFS= read -r entry; do
        [[ -z "$entry" ]] && continue
        local score="${entry%%|*}"
        local cause="${entry#*|}"
        local severity="${GREEN}LOW${NC}"
        if (( score >= 40 )); then
            severity="${RED}HIGH${NC}"
        elif (( score >= 20 )); then
            severity="${YELLOW}MEDIUM${NC}"
        fi

        local desc
        desc=$(describe_cause "$cause")
        echo -e "  ${BOLD}#${rank}${NC} [score: ${score}] [${severity}] ${desc}"
        suggest_for_cause "$cause"
        echo ""
        rank=$(( rank + 1 ))
        (( rank > 3 )) && break
    done < <(
        for cause in "${!CAUSE_SCORES[@]}"; do
            echo "${CAUSE_SCORES[$cause]}|${cause}"
        done | sort -t'|' -k1 -rn
    )

    if [[ ${#ISSUES[@]} -gt 0 ]]; then
        separator
        echo -e "  ${BOLD}All issues found:${NC}"
        for issue in "${ISSUES[@]}"; do
            echo -e "    - ${issue}"
        done
    fi
}

describe_cause() {
    case "$1" in
        oom)                   echo "Out of Memory — system killed the game process" ;;
        nvidia_crash)          echo "NVIDIA GPU crash — Xid error or driver fault" ;;
        gpu_hang)              echo "GPU hang/reset — graphics driver stall or timeout" ;;
        vulkan_device_lost)    echo "Vulkan device lost — GPU crashed during rendering" ;;
        proton_crash)          echo "Proton/Wine crash — compatibility layer failure" ;;
        prefix_corruption)     echo "Proton prefix corruption — game config damaged" ;;
        missing_libs)          echo "Missing libraries — required DLLs/runtimes not installed" ;;
        shader_issue)          echo "Shader compilation failure — cache corrupt or timeout" ;;
        disk_full)             echo "Disk space exhaustion — not enough room for game data" ;;
        hardware_issue)        echo "Hardware error — thermal throttling, MCE, or memory fault" ;;
        *)                     echo "Unknown cause: $1" ;;
    esac
}

suggest_for_cause() {
    case "$1" in
        oom)
            echo -e "    ${DIM}-> Run: hubos-crash-fix fix <game>  (will enable zram, set max_map_count)${NC}"
            echo -e "    ${DIM}-> Consider closing background apps or adding swap${NC}"
            ;;
        nvidia_crash)
            echo -e "    ${DIM}-> Check driver: nvidia-smi${NC}"
            echo -e "    ${DIM}-> Run: hubos-crash-fix fix <game>  (will check and suggest driver update)${NC}"
            echo -e "    ${DIM}-> Try rolling back the NVIDIA driver if recently updated${NC}"
            ;;
        gpu_hang)
            echo -e "    ${DIM}-> Check: vulkaninfo --summary${NC}"
            echo -e "    ${DIM}-> Try clearing shader cache: hubos-crash-fix fix <game>${NC}"
            echo -e "    ${DIM}-> AMD users: try RADV_PERFTEST=gpl or different mesa version${NC}"
            ;;
        vulkan_device_lost)
            echo -e "    ${DIM}-> Usually GPU overheating or driver bug${NC}"
            echo -e "    ${DIM}-> Check GPU temps, try underclocking, or update drivers${NC}"
            ;;
        proton_crash)
            echo -e "    ${DIM}-> Try a different Proton version (GE-Proton or official)${NC}"
            echo -e "    ${DIM}-> Run: hubos-crash-fix fix <game>  (can reset prefix)${NC}"
            ;;
        prefix_corruption)
            echo -e "    ${DIM}-> Run: hubos-crash-fix fix <game>  (will backup and delete prefix)${NC}"
            echo -e "    ${DIM}-> Steam will recreate the prefix on next launch${NC}"
            ;;
        missing_libs)
            echo -e "    ${DIM}-> Run: hubos-crash-fix fix <game>  (will install via protontricks)${NC}"
            echo -e "    ${DIM}-> Manual: protontricks <appid> vcredist2019 dotnet48 d3dx9${NC}"
            ;;
        shader_issue)
            echo -e "    ${DIM}-> Run: hubos-crash-fix fix <game>  (will clear shader cache)${NC}"
            echo -e "    ${DIM}-> Steam will recompile shaders on next launch${NC}"
            ;;
        disk_full)
            echo -e "    ${DIM}-> Run: hubos-crash-fix fix <game>  (will clean caches and old prefixes)${NC}"
            echo -e "    ${DIM}-> Remove unused games or move to another drive${NC}"
            ;;
        hardware_issue)
            echo -e "    ${DIM}-> Check temps: sensors / nvidia-smi${NC}"
            echo -e "    ${DIM}-> Run memtest86+ if RAM errors suspected${NC}"
            ;;
    esac
}

# ─── Fix Engine ──────────────────────────────────────────────────────────────

cmd_fix() {
    local appid="$1"
    local game_name="$2"

    header "Auto-Fix for ${game_name} (AppID: ${appid})"

    # First do a quick diagnosis to know what to fix
    echo -e "  ${CYAN}Running quick diagnosis...${NC}"
    echo ""
    run_diagnosis_checks "$appid" "$game_name"

    # Determine top cause
    local top_cause=""
    local top_score=0
    for cause in "${!CAUSE_SCORES[@]}"; do
        if (( CAUSE_SCORES[$cause] > top_score )); then
            top_score=${CAUSE_SCORES[$cause]}
            top_cause="$cause"
        fi
    done

    separator
    header "Applying Fixes"

    local any_fix=false

    # Always check and fix vm.max_map_count
    fix_max_map_count && any_fix=true

    # Apply targeted fixes based on diagnosis
    case "$top_cause" in
        oom)
            fix_oom "$appid" && any_fix=true
            ;;
        nvidia_crash)
            fix_nvidia "$appid" && any_fix=true
            ;;
        gpu_hang|vulkan_device_lost)
            fix_vulkan "$appid" && any_fix=true
            fix_shader_cache "$appid" && any_fix=true
            ;;
        proton_crash|prefix_corruption)
            fix_prefix "$appid" "$game_name" && any_fix=true
            ;;
        missing_libs)
            fix_missing_libs "$appid" && any_fix=true
            ;;
        shader_issue)
            fix_shader_cache "$appid" && any_fix=true
            ;;
        disk_full)
            fix_disk_space "$appid" && any_fix=true
            ;;
        *)
            # If no clear cause, offer common fixes
            log_info "No dominant issue detected — applying common fixes"
            fix_shader_cache "$appid" && any_fix=true
            fix_missing_libs "$appid" && any_fix=true
            ;;
    esac

    separator
    if [[ ${#FIXES_APPLIED[@]} -gt 0 ]]; then
        echo -e "  ${GREEN}${BOLD}Fixes applied:${NC}"
        for fix in "${FIXES_APPLIED[@]}"; do
            echo -e "    ${GREEN}+${NC} $fix"
        done
    else
        echo -e "  ${YELLOW}No fixes were applied.${NC}"
    fi
    echo ""
}

fix_max_map_count() {
    local current
    current=$(cat /proc/sys/vm/max_map_count 2>/dev/null) || current=0
    if (( current < 1048576 )); then
        log_info "vm.max_map_count is $current (needs 1048576)"
        if confirm_action "Set vm.max_map_count=1048576? (requires sudo)"; then
            if sudo sysctl -w vm.max_map_count=1048576 &>/dev/null; then
                log_fix "Set vm.max_map_count=1048576 (session)"
                # Persist
                if [[ -d /etc/sysctl.d ]]; then
                    echo "vm.max_map_count=1048576" | sudo tee /etc/sysctl.d/99-hubos-games.conf &>/dev/null
                    log_fix "Persisted vm.max_map_count in /etc/sysctl.d/99-hubos-games.conf"
                fi
                return 0
            else
                log_warn "Failed to set vm.max_map_count (sudo may have been denied)"
                return 1
            fi
        fi
    else
        log_ok "vm.max_map_count already set to $current"
    fi
    return 1
}

fix_oom() {
    local appid="$1"
    subheader "OOM Fixes"

    # Check for zram
    if ! lsmod 2>/dev/null | grep -q zram; then
        log_info "zram module not loaded — zram can help prevent OOM crashes"
        if confirm_action "Enable zram swap (compressed RAM swap)?"; then
            if sudo modprobe zram &>/dev/null; then
                # Try systemd-zram-generator or manual setup
                if command -v zramctl &>/dev/null; then
                    local mem_kb
                    mem_kb=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
                    local zram_size=$(( mem_kb / 2 ))k  # 50% of RAM
                    sudo zramctl /dev/zram0 --algorithm zstd --size "${zram_size}" &>/dev/null || true
                    sudo mkswap /dev/zram0 &>/dev/null || true
                    sudo swapon -p 100 /dev/zram0 &>/dev/null || true
                    log_fix "Enabled zram swap ($(( mem_kb / 2048 )) MB, zstd compression)"
                else
                    log_warn "zramctl not available — install systemd-zram-generator for persistent zram"
                fi
            else
                log_warn "Could not load zram module"
            fi
        fi
    else
        log_ok "zram already loaded"
    fi

    # Suggest killing heavy background processes
    log_info "Top memory consumers:"
    ps aux --sort=-%mem 2>/dev/null | head -6 | tail -5 | while IFS= read -r proc; do
        echo -e "    ${DIM}${proc}${NC}"
    done

    return 0
}

fix_nvidia() {
    local appid="$1"
    subheader "NVIDIA Driver Check"

    if command -v nvidia-smi &>/dev/null; then
        local driver_ver
        driver_ver=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1) || driver_ver="unknown"
        local gpu_name
        gpu_name=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1) || gpu_name="unknown"
        local gpu_temp
        gpu_temp=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader 2>/dev/null | head -1) || gpu_temp="?"

        log_info "GPU: $gpu_name | Driver: $driver_ver | Temp: ${gpu_temp}C"

        if [[ "$gpu_temp" != "?" ]] && (( gpu_temp > 90 )); then
            log_crit "GPU temperature is ${gpu_temp}C — thermal throttling likely causing crashes"
            record_issue "GPU overheating at ${gpu_temp}C"
        fi

        # Check for known problematic driver versions
        log_info "If crashes persist, try:"
        echo -e "    ${DIM}-> sudo dnf install akmod-nvidia-${driver_ver}  (reinstall current)${NC}"
        echo -e "    ${DIM}-> Or switch to a different driver branch in Software Center${NC}"

        # Clear NVIDIA shader cache
        local nv_cache="${HOME}/.cache/nvidia/GLCache"
        if [[ -d "$nv_cache" ]]; then
            local nv_size
            nv_size=$(du -sm "$nv_cache" 2>/dev/null | awk '{print $1}') || nv_size=0
            if (( nv_size > 500 )) && confirm_action "Clear NVIDIA GL shader cache (${nv_size} MB)?"; then
                rm -rf "$nv_cache"
                log_fix "Cleared NVIDIA GL shader cache (${nv_size} MB)"
            fi
        fi
    else
        log_info "nvidia-smi not found — NVIDIA driver may not be installed"
        log_info "Install with: sudo dnf install akmod-nvidia xorg-x11-drv-nvidia-cuda"
    fi

    return 0
}

fix_vulkan() {
    local appid="$1"
    subheader "Vulkan Health Check"

    if command -v vulkaninfo &>/dev/null; then
        local vk_summary
        vk_summary=$(vulkaninfo --summary 2>/dev/null | head -20) || true
        if [[ -z "$vk_summary" ]]; then
            log_crit "vulkaninfo returned no data — Vulkan may be broken"
            log_info "Try: sudo dnf install vulkan-loader mesa-vulkan-drivers"
            record_issue "Vulkan not functional"
        else
            log_ok "Vulkan is functional"
            local vk_driver
            vk_driver=$(echo "$vk_summary" | grep -i "driverName\|driverInfo" | head -2)
            echo "$vk_driver" | while IFS= read -r vd; do
                echo -e "    ${DIM}${vd}${NC}"
            done
        fi
    else
        log_warn "vulkaninfo not installed"
        if confirm_action "Install vulkan-tools?"; then
            sudo dnf install -y vulkan-tools &>/dev/null && log_fix "Installed vulkan-tools"
        fi
    fi

    return 0
}

fix_missing_libs() {
    local appid="$1"
    subheader "Installing Common Runtimes"

    local protontricks_cmd=""
    if command -v protontricks &>/dev/null; then
        protontricks_cmd="protontricks"
    elif command -v flatpak &>/dev/null && flatpak list 2>/dev/null | grep -q protontricks; then
        protontricks_cmd="flatpak run com.github.Matoking.protontricks"
    fi

    if [[ -z "$protontricks_cmd" ]]; then
        log_warn "protontricks not found"
        if confirm_action "Install protontricks via Flatpak?"; then
            flatpak install -y flathub com.github.Matoking.protontricks &>/dev/null && {
                protontricks_cmd="flatpak run com.github.Matoking.protontricks"
                log_fix "Installed protontricks via Flatpak"
            }
        fi
        [[ -z "$protontricks_cmd" ]] && return 1
    fi

    local runtimes=("vcredist2019" "dotnet48" "d3dx9" "d3dcompiler_47" "xact")
    echo -e "  Available runtimes to install:"
    local i=1
    for rt in "${runtimes[@]}"; do
        echo -e "    ${i}) ${rt}"
        i=$(( i + 1 ))
    done
    echo -e "    a) All of the above"

    echo -en "  ${CYAN}Select (1-${#runtimes[@]}, a for all, or n to skip): ${NC}"
    local choice
    read -r choice

    if [[ "$choice" == "a" ]]; then
        for rt in "${runtimes[@]}"; do
            log_info "Installing $rt for AppID $appid..."
            if $protontricks_cmd "$appid" "$rt" &>/dev/null; then
                log_fix "Installed $rt via protontricks"
            else
                log_warn "Failed to install $rt"
            fi
        done
    elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#runtimes[@]} )); then
        local rt="${runtimes[$((choice - 1))]}"
        log_info "Installing $rt for AppID $appid..."
        if $protontricks_cmd "$appid" "$rt" &>/dev/null; then
            log_fix "Installed $rt via protontricks"
        else
            log_warn "Failed to install $rt"
        fi
    else
        log_info "Skipped runtime installation"
    fi

    return 0
}

fix_prefix() {
    local appid="$1"
    local game_name="$2"
    subheader "Proton Prefix Reset"

    local compatdata
    compatdata=$(get_compatdata_dir "$appid")

    if [[ ! -d "$compatdata" ]]; then
        log_info "No compatdata directory exists — nothing to reset"
        return 1
    fi

    local pfx_size
    pfx_size=$(du -sm "$compatdata" 2>/dev/null | awk '{print $1}') || pfx_size=0
    log_info "Proton prefix size: ${pfx_size} MB"
    log_warn "This will delete the Proton prefix. Steam will recreate it on next launch."
    log_warn "Game saves stored in the prefix WILL BE LOST (check Steam Cloud first)."

    if confirm_action "Backup and delete prefix for ${game_name}? (${pfx_size} MB)"; then
        local backup_dir="${HOME}/.local/share/hubos/crash-fix/backups"
        mkdir -p "$backup_dir"
        local backup_name="prefix_${appid}_$(date +%Y%m%d_%H%M%S).tar.zst"
        local backup_path="${backup_dir}/${backup_name}"

        log_info "Backing up prefix to ${backup_path}..."
        if tar -I zstd -cf "$backup_path" -C "$(dirname "$compatdata")" "$(basename "$compatdata")" 2>/dev/null; then
            log_fix "Backed up prefix to ${backup_path}"
            rm -rf "$compatdata"
            log_fix "Deleted Proton prefix for AppID $appid — Steam will recreate on launch"
        else
            log_warn "Backup failed — prefix NOT deleted for safety"
            return 1
        fi
    fi

    return 0
}

fix_shader_cache() {
    local appid="$1"
    subheader "Shader Cache Cleanup"

    local shader_dir
    shader_dir=$(get_shader_cache_dir "$appid")

    if [[ -d "$shader_dir" ]]; then
        local cache_size
        cache_size=$(du -sm "$shader_dir" 2>/dev/null | awk '{print $1}') || cache_size=0
        if confirm_action "Clear shader cache for this game? (${cache_size} MB, will be rebuilt on launch)"; then
            rm -rf "$shader_dir"
            log_fix "Cleared shader cache (${cache_size} MB) for AppID $appid"
            return 0
        fi
    else
        log_info "No shader cache found for this game"
    fi

    # Also check mesa shader cache
    local mesa_cache="${HOME}/.cache/mesa_shader_cache"
    if [[ -d "$mesa_cache" ]]; then
        local mesa_size
        mesa_size=$(du -sm "$mesa_cache" 2>/dev/null | awk '{print $1}') || mesa_size=0
        if (( mesa_size > 200 )) && confirm_action "Clear Mesa shader cache? (${mesa_size} MB)"; then
            rm -rf "$mesa_cache"
            log_fix "Cleared Mesa shader cache (${mesa_size} MB)"
        fi
    fi

    # DXVK state cache
    local compatdata
    compatdata=$(get_compatdata_dir "$appid")
    if [[ -d "$compatdata" ]]; then
        local dxvk_caches
        dxvk_caches=$(find "$compatdata" -name "*.dxvk-cache" 2>/dev/null) || true
        if [[ -n "$dxvk_caches" ]]; then
            local dc_size
            dc_size=$(echo "$dxvk_caches" | xargs du -scm 2>/dev/null | tail -1 | awk '{print $1}') || dc_size=0
            if confirm_action "Clear DXVK state cache(s)? (${dc_size} MB)"; then
                echo "$dxvk_caches" | xargs rm -f 2>/dev/null
                log_fix "Cleared DXVK state cache(s)"
            fi
        fi
    fi

    return 0
}

fix_disk_space() {
    local appid="$1"
    subheader "Disk Space Cleanup"

    log_info "Disk usage overview:"
    df -h "$STEAM_DIR" /tmp "${HOME}" 2>/dev/null | while IFS= read -r dline; do
        echo -e "    ${DIM}${dline}${NC}"
    done
    echo ""

    # Offer to clean all shader caches
    local total_shader=0
    for lib_dir in $(get_library_folders); do
        local sc="${lib_dir}/steamapps/shadercache"
        if [[ -d "$sc" ]]; then
            local sz
            sz=$(du -sm "$sc" 2>/dev/null | awk '{print $1}') || sz=0
            total_shader=$(( total_shader + sz ))
        fi
    done

    if (( total_shader > 100 )); then
        if confirm_action "Clear ALL shader caches? (${total_shader} MB total — games will recompile on launch)"; then
            for lib_dir in $(get_library_folders); do
                local sc="${lib_dir}/steamapps/shadercache"
                [[ -d "$sc" ]] && rm -rf "$sc"
            done
            log_fix "Cleared all shader caches (${total_shader} MB)"
        fi
    fi

    # Check for orphaned compatdata
    log_info "Checking for orphaned Proton prefixes (no matching game installed)..."
    local orphan_size=0
    local orphan_count=0
    for lib_dir in $(get_library_folders); do
        local cd_dir="${lib_dir}/steamapps/compatdata"
        [[ -d "$cd_dir" ]] || continue
        for prefix_dir in "$cd_dir"/*/; do
            [[ -d "$prefix_dir" ]] || continue
            local prefix_appid
            prefix_appid=$(basename "$prefix_dir")
            [[ "$prefix_appid" =~ ^[0-9]+$ ]] || continue
            local manifest="${lib_dir}/steamapps/appmanifest_${prefix_appid}.acf"
            if [[ ! -f "$manifest" ]]; then
                local psz
                psz=$(du -sm "$prefix_dir" 2>/dev/null | awk '{print $1}') || psz=0
                orphan_size=$(( orphan_size + psz ))
                orphan_count=$(( orphan_count + 1 ))
                $VERBOSE && echo -e "    ${DIM}Orphan: AppID $prefix_appid (${psz} MB)${NC}"
            fi
        done
    done

    if (( orphan_count > 0 )); then
        log_info "Found $orphan_count orphaned prefix(es) totaling ${orphan_size} MB"
        if confirm_action "Delete orphaned prefixes? (${orphan_size} MB)"; then
            for lib_dir in $(get_library_folders); do
                local cd_dir="${lib_dir}/steamapps/compatdata"
                [[ -d "$cd_dir" ]] || continue
                for prefix_dir in "$cd_dir"/*/; do
                    [[ -d "$prefix_dir" ]] || continue
                    local prefix_appid
                    prefix_appid=$(basename "$prefix_dir")
                    [[ "$prefix_appid" =~ ^[0-9]+$ ]] || continue
                    local manifest="${lib_dir}/steamapps/appmanifest_${prefix_appid}.acf"
                    if [[ ! -f "$manifest" ]]; then
                        rm -rf "$prefix_dir"
                    fi
                done
            done
            log_fix "Deleted $orphan_count orphaned prefixes (${orphan_size} MB)"
        fi
    else
        log_ok "No orphaned prefixes found"
    fi

    return 0
}

# ─── Diagnosis Runner ────────────────────────────────────────────────────────

run_diagnosis_checks() {
    local appid="$1"
    local game_name="$2"

    check_oom_killer "$appid" "$game_name"
    check_gpu_errors "$appid"
    check_proton_logs "$appid"
    check_missing_libs "$appid"
    check_shader_issues "$appid"
    check_disk_space "$appid"
    check_journal_errors "$appid"
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_diagnose() {
    local appid="$1"
    local game_name="$2"

    header "Diagnosing Crash for: ${game_name} (AppID: ${appid})"
    echo ""

    run_diagnosis_checks "$appid" "$game_name"

    separator
    present_diagnosis "$game_name"

    if $GUI_MODE; then
        local summary="Diagnosis for ${game_name}\n\n"
        if [[ ${#ISSUES[@]} -gt 0 ]]; then
            for issue in "${ISSUES[@]}"; do
                summary+="- ${issue}\n"
            done
        else
            summary+="No issues found."
        fi
        gui_info "Crash Diagnosis" "$summary"
    fi
}

cmd_log() {
    local appid="$1"
    local game_name="$2"

    header "Recent Crash Logs for: ${game_name} (AppID: ${appid})"
    echo ""

    local found_any=false

    # Crash dumps
    local compatdata
    compatdata=$(get_compatdata_dir "$appid")
    local crash_dir="${compatdata}/crash_dumps"

    if [[ -d "$crash_dir" ]]; then
        local dumps
        dumps=$(find "$crash_dir" -type f \( -name "*.dmp" -o -name "*.log" -o -name "*.txt" \) -mtime -7 2>/dev/null | sort -r | head -10) || true
        if [[ -n "$dumps" ]]; then
            subheader "Crash Dumps (last 7 days)"
            echo "$dumps" | while IFS= read -r dump; do
                local dsize
                dsize=$(stat -c%s "$dump" 2>/dev/null) || dsize=0
                local ddate
                ddate=$(stat -c%y "$dump" 2>/dev/null | cut -d. -f1) || ddate="?"
                echo -e "  ${YELLOW}${ddate}${NC}  $(basename "$dump")  (${dsize} bytes)"

                # If it's a text log, show last few lines
                if [[ "$dump" == *.log || "$dump" == *.txt ]]; then
                    tail -5 "$dump" 2>/dev/null | while IFS= read -r ll; do
                        echo -e "    ${DIM}${ll}${NC}"
                    done
                fi
            done
            found_any=true
        fi
    fi

    # Proton logs in /tmp
    subheader "Proton Logs (/tmp)"
    local plogs
    plogs=$(ls -1t /tmp/proton_${appid}* /tmp/proton_crashreport* 2>/dev/null | head -5) || true

    if [[ -n "$plogs" ]]; then
        echo "$plogs" | while IFS= read -r plog; do
            [[ -f "$plog" ]] || continue
            echo -e "  ${CYAN}$(basename "$plog")${NC}  $(stat -c%y "$plog" 2>/dev/null | cut -d. -f1)"

            # Show error lines
            grep -i "err\|fail\|crash\|fatal\|abort\|exception" "$plog" 2>/dev/null | tail -8 | while IFS= read -r el; do
                echo -e "    ${RED}${el}${NC}"
            done
            echo ""
        done
        found_any=true
    else
        log_info "No Proton log files found for this game"
    fi

    # Systemd journal entries (game/proton related)
    subheader "Journal Entries (last 2 hours)"
    local journal_out
    journal_out=$(journalctl --user --since "2 hours ago" --no-pager 2>/dev/null \
        | grep -i "steam\|proton\|wine\|pressure-vessel\|${appid}\|${game_name}" \
        | grep -i "err\|warn\|fail\|crash\|fatal\|abort" \
        | tail -20) || true

    if [[ -n "$journal_out" ]]; then
        echo "$journal_out" | while IFS= read -r jl; do
            # Color-code by severity
            if echo "$jl" | grep -qi "err\|fatal\|crash\|abort"; then
                echo -e "  ${RED}${jl}${NC}"
            else
                echo -e "  ${YELLOW}${jl}${NC}"
            fi
        done
        found_any=true
    else
        log_info "No relevant journal entries found"
    fi

    # dmesg for this timeframe
    subheader "Kernel Messages (GPU/OOM)"
    local dmesg_out
    dmesg_out=$(dmesg 2>/dev/null | grep -i "oom\|gpu\|nvidia\|amdgpu\|radeon\|hang\|reset\|segfault" | tail -10) || true

    if [[ -n "$dmesg_out" ]]; then
        echo "$dmesg_out" | while IFS= read -r dl; do
            echo -e "  ${MAGENTA}${dl}${NC}"
        done
        found_any=true
    else
        log_info "No relevant kernel messages"
    fi

    $found_any || echo -e "\n  ${YELLOW}No crash logs found. The game may not have crashed recently, or logs have been rotated.${NC}"
}

cmd_report() {
    header "Generating Full Crash Report"

    local report_dir="${HOME}/.local/share/hubos/crash-fix/reports"
    mkdir -p "$report_dir"
    local report_file="${report_dir}/crash-report_$(date +%Y%m%d_%H%M%S).txt"

    {
        echo "===== HubOS Crash Report ====="
        echo "Generated: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
        echo "Hostname:  $(hostname)"
        echo ""

        echo "--- System Info ---"
        echo "OS:     $(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '"')"
        echo "Kernel: $(uname -r)"
        echo "Arch:   $(uname -m)"
        echo ""

        echo "--- CPU ---"
        grep "model name" /proc/cpuinfo 2>/dev/null | head -1 | sed 's/.*: //'
        echo "Cores: $(nproc 2>/dev/null || echo '?')"
        echo ""

        echo "--- Memory ---"
        free -h 2>/dev/null || echo "(free not available)"
        echo ""
        echo "vm.max_map_count: $(cat /proc/sys/vm/max_map_count 2>/dev/null)"
        echo ""

        echo "--- GPU ---"
        if command -v nvidia-smi &>/dev/null; then
            echo "[NVIDIA]"
            nvidia-smi --query-gpu=name,driver_version,memory.total,memory.used,temperature.gpu --format=csv 2>/dev/null
        fi
        if command -v vulkaninfo &>/dev/null; then
            echo "[Vulkan]"
            vulkaninfo --summary 2>&1 | head -30
        fi
        lspci 2>/dev/null | grep -i "vga\|3d\|display" || true
        echo ""

        echo "--- Disk ---"
        df -h "$STEAM_DIR" /tmp "${HOME}" 2>/dev/null
        echo ""

        echo "--- Steam ---"
        echo "Steam dir: $STEAM_DIR"
        echo "Flatpak: $(is_flatpak_steam && echo 'yes' || echo 'no')"
        local game_count
        game_count=$(ls "$STEAM_DIR"/steamapps/appmanifest_*.acf 2>/dev/null | wc -l) || game_count=0
        echo "Installed games: $game_count"
        echo ""

        echo "--- Proton Versions ---"
        ls -1d "$STEAM_DIR"/steamapps/common/Proton* 2>/dev/null | while IFS= read -r pd; do
            basename "$pd"
        done
        ls -1d "$STEAM_DIR"/compatibilitytools.d/*proton* "$STEAM_DIR"/compatibilitytools.d/*Proton* "$STEAM_DIR"/compatibilitytools.d/*GE* 2>/dev/null | while IFS= read -r pd; do
            echo "(custom) $(basename "$pd")"
        done
        echo ""

        echo "--- Recent OOM Events ---"
        dmesg 2>/dev/null | grep -i "oom-kill\|out of memory" | tail -10
        echo ""

        echo "--- Recent GPU Errors ---"
        dmesg 2>/dev/null | grep -i "nvidia\|amdgpu\|radeon\|gpu" | grep -i "error\|fault\|hang\|reset\|Xid" | tail -15
        echo ""

        echo "--- Recent Journal Errors (user, 1 hour) ---"
        journalctl --user --since "1 hour ago" --priority=err --no-pager 2>/dev/null | tail -30
        echo ""

        echo "--- Proton Logs in /tmp ---"
        ls -lt /tmp/proton_* 2>/dev/null | head -10
        echo ""

        echo "===== End of Report ====="
    } > "$report_file"

    local report_size
    report_size=$(wc -c < "$report_file")
    log_ok "Report saved to: ${report_file} (${report_size} bytes)"
    echo ""
    echo -e "  Share this file in your Discord support channel."
    echo -e "  ${DIM}You can also paste the contents: cat ${report_file} | wl-copy${NC}"

    if $GUI_MODE; then
        gui_info "Crash Report Generated" "Report saved to:\n${report_file}\n\nSize: ${report_size} bytes\n\nShare this in Discord for support."
    fi
}

cmd_watch() {
    header "Real-Time Crash Monitor"
    echo -e "  Watching for game crashes... Press ${BOLD}Ctrl+C${NC} to stop."
    echo ""

    local last_check
    last_check=$(date +%s)

    # Track known crash dumps to avoid re-alerting
    declare -A known_dumps=()

    # Preload existing dumps
    for lib_dir in $(get_library_folders); do
        local cd_base="${lib_dir}/steamapps/compatdata"
        [[ -d "$cd_base" ]] || continue
        while IFS= read -r dump; do
            known_dumps["$dump"]=1
        done < <(find "$cd_base" -path "*/crash_dumps/*.dmp" 2>/dev/null)
    done

    trap 'echo -e "\n  ${CYAN}Crash monitor stopped.${NC}"; exit 0' INT TERM

    while true; do
        sleep 5

        local now
        now=$(date +%s)
        local since_sec=$(( now - last_check ))

        # Check for new crash dumps
        for lib_dir in $(get_library_folders); do
            local cd_base="${lib_dir}/steamapps/compatdata"
            [[ -d "$cd_base" ]] || continue
            while IFS= read -r dump; do
                if [[ -z "${known_dumps[$dump]:-}" ]]; then
                    known_dumps["$dump"]=1
                    local crash_appid
                    crash_appid=$(echo "$dump" | grep -oP 'compatdata/\K[0-9]+')
                    local crash_name
                    crash_name=$(find_game_name_by_appid "$crash_appid")
                    [[ -z "$crash_name" ]] && crash_name="AppID $crash_appid"

                    echo ""
                    echo -e "  ${RED}${BOLD}[CRASH DETECTED]${NC} ${crash_name} (${crash_appid})"
                    echo -e "  ${DIM}Dump: ${dump}${NC}"
                    echo -e "  ${DIM}Time: $(date '+%Y-%m-%d %H:%M:%S')${NC}"

                    notify_user "Game Crash Detected" "${crash_name} has crashed. Run: hubos-crash-fix diagnose ${crash_appid}"

                    # Auto-diagnose
                    echo ""
                    echo -e "  ${CYAN}Running auto-diagnosis...${NC}"
                    CAUSE_SCORES=()
                    ISSUES=()
                    run_diagnosis_checks "$crash_appid" "$crash_name"
                    present_diagnosis "$crash_name"
                    separator
                    echo -e "  Monitoring resumed..."
                fi
            done < <(find "$cd_base" -path "*/crash_dumps/*.dmp" -newer /proc/$$ 2>/dev/null)
        done

        # Check dmesg for new OOM kills
        local new_oom
        new_oom=$(dmesg 2>/dev/null | tail -20 | grep -i "oom-kill\|killed process" | grep -i "steam\|wine\|proton\|pressure-vessel\|reaper" 2>/dev/null) || true
        if [[ -n "$new_oom" ]]; then
            # Simple dedup: only alert if we haven't seen it in last 60s
            local oom_hash
            oom_hash=$(echo "$new_oom" | md5sum | awk '{print $1}')
            if [[ -z "${known_dumps[oom_$oom_hash]:-}" ]]; then
                known_dumps["oom_$oom_hash"]=1
                echo ""
                echo -e "  ${RED}${BOLD}[OOM KILL]${NC} A game process was killed by OOM killer"
                echo -e "  ${DIM}$(echo "$new_oom" | tail -1)${NC}"
                notify_user "OOM Kill Detected" "A game process was killed due to out of memory."
            fi
        fi

        # Check for GPU errors
        local new_gpu
        new_gpu=$(dmesg 2>/dev/null | tail -20 | grep -i "Xid\|gpu.*hang\|gpu.*reset\|amdgpu.*error\|device lost" 2>/dev/null) || true
        if [[ -n "$new_gpu" ]]; then
            local gpu_hash
            gpu_hash=$(echo "$new_gpu" | md5sum | awk '{print $1}')
            if [[ -z "${known_dumps[gpu_$gpu_hash]:-}" ]]; then
                known_dumps["gpu_$gpu_hash"]=1
                echo ""
                echo -e "  ${RED}${BOLD}[GPU ERROR]${NC} GPU error detected"
                echo -e "  ${DIM}$(echo "$new_gpu" | tail -1)${NC}"
                notify_user "GPU Error" "GPU hang or error detected — a game may crash."
            fi
        fi

        last_check=$now
    done
}

# ─── Help / Usage ────────────────────────────────────────────────────────────

usage() {
    cat <<HELPTEXT
${BOLD}HubOS Game Crash Diagnosis & Auto-Fix Tool${NC}  v${VERSION}

${BOLD}USAGE:${NC}
    $PROG_NAME <command> [game] [options]

${BOLD}COMMANDS:${NC}
    diagnose <game>    Analyze why a game crashed (checks logs, dmesg, GPU errors)
    fix <game>         Auto-fix common crash causes (OOM, libs, prefix, shaders)
    log <game>         Show recent crash logs for a game, formatted and filtered
    report             Generate a full crash report for sharing in Discord
    watch              Monitor for crashes in real-time with auto-diagnosis

${BOLD}GAME ARGUMENT:${NC}
    Steam AppID (e.g., 730) or game name (e.g., "Counter-Strike").
    Names are matched against installed appmanifest files.

${BOLD}OPTIONS:${NC}
    --gui              Use zenity dialogs for graphical prompts
    --verbose          Show extra diagnostic detail
    --no-color         Disable colored output
    -h, --help         Show this help message
    -v, --version      Show version

${BOLD}EXAMPLES:${NC}
    $PROG_NAME diagnose 1245620
    $PROG_NAME diagnose "Elden Ring"
    $PROG_NAME fix 730
    $PROG_NAME log "Cyberpunk"
    $PROG_NAME report
    $PROG_NAME watch --gui

${BOLD}DETECTED ISSUES:${NC}
    OOM kills, GPU hangs/resets, NVIDIA Xid errors, Vulkan device lost,
    Proton prefix corruption, missing DLLs/runtimes, shader cache corruption,
    disk space exhaustion, thermal throttling, segfaults.

${BOLD}NOTES:${NC}
    Supports both Flatpak Steam and native Steam installations.
    Some fixes require sudo (e.g., vm.max_map_count, zram).
    Prefix reset will backup before deleting (compressed with zstd).
HELPTEXT
}

# ─── Main Entry Point ────────────────────────────────────────────────────────

main() {
    local cmd=""
    local game_arg=""
    local positional=()

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --gui)       GUI_MODE=true; shift ;;
            --verbose)   VERBOSE=true; shift ;;
            --no-color)  NO_COLOR=true; shift ;;
            -h|--help)   usage; exit 0 ;;
            -v|--version) echo "$PROG_NAME v${VERSION}"; exit 0 ;;
            -*)          die "Unknown option: $1 (use --help for usage)" ;;
            *)           positional+=("$1"); shift ;;
        esac
    done

    $NO_COLOR && disable_colors

    # Extract command and game argument
    if [[ ${#positional[@]} -ge 1 ]]; then
        cmd="${positional[0]}"
    fi
    if [[ ${#positional[@]} -ge 2 ]]; then
        game_arg="${positional[*]:1}"
    fi

    [[ -z "$cmd" ]] && { usage; exit 0; }

    # GUI mode: if no command given, show picker
    if $GUI_MODE && [[ -z "$cmd" ]] && command -v zenity &>/dev/null; then
        cmd=$(gui_select "HubOS Crash Fix" "diagnose" "fix" "log" "report" "watch") || exit 0
    fi

    # Detect Steam directory
    detect_steam_dir

    # Dispatch
    case "$cmd" in
        diagnose)
            [[ -z "$game_arg" ]] && die "Usage: $PROG_NAME diagnose <appid|game-name>"
            local resolved
            resolved=$(resolve_game "$game_arg")
            local appid="${resolved%%|*}"
            local game_name="${resolved#*|}"
            cmd_diagnose "$appid" "$game_name"
            ;;
        fix)
            [[ -z "$game_arg" ]] && die "Usage: $PROG_NAME fix <appid|game-name>"
            local resolved
            resolved=$(resolve_game "$game_arg")
            local appid="${resolved%%|*}"
            local game_name="${resolved#*|}"
            cmd_fix "$appid" "$game_name"
            ;;
        log)
            [[ -z "$game_arg" ]] && die "Usage: $PROG_NAME log <appid|game-name>"
            local resolved
            resolved=$(resolve_game "$game_arg")
            local appid="${resolved%%|*}"
            local game_name="${resolved#*|}"
            cmd_log "$appid" "$game_name"
            ;;
        report)
            cmd_report
            ;;
        watch)
            cmd_watch
            ;;
        *)
            die "Unknown command: $cmd (use --help for usage)"
            ;;
    esac
}

main "$@"
