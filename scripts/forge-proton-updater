#!/bin/bash
# =============================================================================
# HubOS Proton-GE Updater — Automatically keep Proton-GE up to date
# Manages GloriousEggroll's Proton-GE custom builds for Steam on Linux.
# Usage: hubos-proton-updater {check|update|list|set-default|cleanup|auto} [options]
# =============================================================================

set -euo pipefail

VERSION="1.0.0"
GITHUB_API="https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/latest"
CACHE_DIR="${HOME}/.cache/hubos"
CACHE_FILE="${CACHE_DIR}/proton-ge-latest.json"
CACHE_MAX_AGE=3600  # seconds before cache is considered stale
KEEP_VERSIONS=2     # number of old versions to keep during cleanup
SILENT=false

# Steam compatibility tools directories (checked in order)
STEAM_COMPAT_DIRS=(
    "${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam/compatibilitytools.d"
    "${HOME}/.local/share/Steam/compatibilitytools.d"
    "${HOME}/.steam/steam/compatibilitytools.d"
)

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log_info()  { [[ "$SILENT" == true ]] && return; echo -e "${BLUE}[INFO]${NC} $*"; }
log_ok()    { [[ "$SILENT" == true ]] && return; echo -e "${GREEN}[OK]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }
log_step()  { [[ "$SILENT" == true ]] && return; echo -e "${CYAN}::${NC} $*"; }

notify() {
    # Desktop notification — silent failure if notify-send unavailable
    local title="$1"
    local body="${2:-}"
    if command -v notify-send &>/dev/null; then
        notify-send --app-name="HubOS Proton Updater" --icon=steam "$title" "$body" 2>/dev/null || true
    fi
}

# Parse JSON — uses jq if available, falls back to python3
json_get() {
    local json="$1"
    local key="$2"
    if command -v jq &>/dev/null; then
        echo "$json" | jq -r "$key" 2>/dev/null
    elif command -v python3 &>/dev/null; then
        echo "$json" | python3 -c "
import sys, json
data = json.load(sys.stdin)
keys = '''$key'''.strip('.')
# Handle simple jq-style paths like .tag_name, .assets[].name
import re
obj = data
for part in re.split(r'\.(?![^\[]*\])', keys):
    if not part:
        continue
    m = re.match(r'(\w+)\[\]\.(\w+)', part)
    if m:
        arr_key, sub_key = m.groups()
        result = [item[sub_key] for item in obj[arr_key]]
        print('\n'.join(str(r) for r in result))
        sys.exit(0)
    m2 = re.match(r'(\w+)\[(\d+)\]', part)
    if m2:
        obj = obj[m2.group(1)][int(m2.group(2))]
    else:
        obj = obj[part]
print(obj)
" 2>/dev/null
    else
        log_error "Neither jq nor python3 found. Cannot parse JSON."
        return 1
    fi
}

# JSON array iteration helper
json_array_get() {
    local json="$1"
    local query="$2"
    if command -v jq &>/dev/null; then
        echo "$json" | jq -r "$query" 2>/dev/null
    elif command -v python3 &>/dev/null; then
        echo "$json" | python3 -c "
import sys, json, re
data = json.load(sys.stdin)
query = '''$query'''
# Handle: .assets[] | select(.name | endswith(\"sha512sum\")) | .browser_download_url
if 'select' in query:
    m = re.search(r'\.(\w+)\[\].*endswith\(\"([^\"]+)\"\).*\.(\w+)$', query)
    if m:
        arr, suffix, field = m.groups()
        for item in data[arr]:
            if item.get('name', '').endswith(suffix):
                print(item[field])
                break
else:
    # Simple array field extraction
    m = re.search(r'\.(\w+)\[\]\.(\w+)', query)
    if m:
        arr, field = m.groups()
        for item in data[arr]:
            print(item[field])
" 2>/dev/null
    fi
}

# Detect the active Steam compatibility tools directory
detect_compat_dir() {
    for dir in "${STEAM_COMPAT_DIRS[@]}"; do
        if [[ -d "$dir" ]]; then
            echo "$dir"
            return 0
        fi
    done
    # No existing directory found — try to create one based on Steam install
    for dir in "${STEAM_COMPAT_DIRS[@]}"; do
        local parent
        parent="$(dirname "$dir")"
        if [[ -d "$parent" ]]; then
            mkdir -p "$dir"
            echo "$dir"
            return 0
        fi
    done
    return 1
}

# Human-readable size
human_size() {
    local bytes="$1"
    if (( bytes >= 1073741824 )); then
        printf "%.1f GiB" "$(echo "scale=1; $bytes / 1073741824" | bc 2>/dev/null || python3 -c "print(f'{$bytes/1073741824:.1f}')")"
    elif (( bytes >= 1048576 )); then
        printf "%.1f MiB" "$(echo "scale=1; $bytes / 1048576" | bc 2>/dev/null || python3 -c "print(f'{$bytes/1048576:.1f}')")"
    elif (( bytes >= 1024 )); then
        printf "%.1f KiB" "$(echo "scale=1; $bytes / 1024" | bc 2>/dev/null || python3 -c "print(f'{$bytes/1024:.1f}')")"
    else
        echo "${bytes} B"
    fi
}

dir_size_bytes() {
    du -sb "$1" 2>/dev/null | awk '{print $1}'
}

# ---------------------------------------------------------------------------
# Cache management
# ---------------------------------------------------------------------------

ensure_cache_dir() {
    mkdir -p "$CACHE_DIR"
}

cache_is_fresh() {
    [[ -f "$CACHE_FILE" ]] || return 1
    local now file_age age
    now=$(date +%s)
    file_age=$(stat -c %Y "$CACHE_FILE" 2>/dev/null || stat -f %m "$CACHE_FILE" 2>/dev/null || echo 0)
    age=$(( now - file_age ))
    (( age < CACHE_MAX_AGE ))
}

# ---------------------------------------------------------------------------
# GitHub API
# ---------------------------------------------------------------------------

fetch_latest_release() {
    ensure_cache_dir

    if cache_is_fresh; then
        cat "$CACHE_FILE"
        return 0
    fi

    log_step "Querying GitHub for latest Proton-GE release..."

    local http_code response tmp
    tmp=$(mktemp)

    http_code=$(curl -sS -w "%{http_code}" -o "$tmp" \
        -H "Accept: application/vnd.github+json" \
        "$GITHUB_API" 2>/dev/null) || {
        rm -f "$tmp"
        log_error "Network error — could not reach GitHub. Check your internet connection."
        return 1
    }

    if [[ "$http_code" == "403" ]]; then
        rm -f "$tmp"
        if [[ -f "$CACHE_FILE" ]]; then
            log_warn "GitHub API rate limit hit. Using cached data."
            cat "$CACHE_FILE"
            return 0
        fi
        log_error "GitHub API rate limit exceeded and no cached data available."
        log_error "Try again later or set GITHUB_TOKEN environment variable."
        return 1
    fi

    if [[ "$http_code" != "200" ]]; then
        rm -f "$tmp"
        log_error "GitHub API returned HTTP $http_code."
        if [[ -f "$CACHE_FILE" ]]; then
            log_warn "Falling back to cached data."
            cat "$CACHE_FILE"
            return 0
        fi
        return 1
    fi

    response=$(cat "$tmp")
    rm -f "$tmp"

    # Validate we got valid JSON with a tag_name
    local tag
    tag=$(json_get "$response" ".tag_name" 2>/dev/null) || true
    if [[ -z "$tag" || "$tag" == "null" ]]; then
        log_error "Unexpected API response — no tag_name found."
        return 1
    fi

    echo "$response" > "$CACHE_FILE"
    echo "$response"
}

# ---------------------------------------------------------------------------
# Installed versions
# ---------------------------------------------------------------------------

get_installed_ge_versions() {
    local compat_dir
    compat_dir=$(detect_compat_dir 2>/dev/null) || return 0
    # Proton-GE directories typically match: GE-Proton*, Proton-*-GE-*
    for d in "$compat_dir"/GE-Proton* "$compat_dir"/Proton-*GE*; do
        [[ -d "$d" ]] || continue
        basename "$d"
    done | sort -V
}

get_installed_valve_versions() {
    # Valve Proton lives under Steam's common directory
    local steam_dirs=(
        "${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/common"
        "${HOME}/.local/share/Steam/steamapps/common"
        "${HOME}/.steam/steam/steamapps/common"
    )
    for base in "${steam_dirs[@]}"; do
        [[ -d "$base" ]] || continue
        for d in "$base"/Proton\ *; do
            [[ -d "$d" ]] || continue
            basename "$d"
        done
    done | sort -V | uniq
}

latest_installed_ge() {
    get_installed_ge_versions | tail -1
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_check() {
    local release tag latest_installed
    release=$(fetch_latest_release) || return 1
    tag=$(json_get "$release" ".tag_name")

    log_info "Latest Proton-GE release: ${BOLD}${tag}${NC}"

    latest_installed=$(latest_installed_ge)

    if [[ -z "$latest_installed" ]]; then
        log_warn "No Proton-GE versions currently installed."
        echo -e "${GREEN}Update available:${NC} ${BOLD}${tag}${NC}"
        return 0
    fi

    log_info "Latest installed: ${BOLD}${latest_installed}${NC}"

    if [[ "$latest_installed" == "$tag" ]]; then
        log_ok "Already up to date."
        return 0
    fi

    echo -e "${GREEN}Update available:${NC} ${latest_installed} -> ${BOLD}${tag}${NC}"
    return 0
}

cmd_update() {
    local release tag compat_dir
    release=$(fetch_latest_release) || return 1
    tag=$(json_get "$release" ".tag_name")

    # Check if already installed
    local latest_installed
    latest_installed=$(latest_installed_ge)
    if [[ "$latest_installed" == "$tag" ]]; then
        log_ok "${tag} is already installed."
        return 0
    fi

    # Detect install directory
    compat_dir=$(detect_compat_dir) || {
        log_error "Could not find or create Steam compatibilitytools.d directory."
        log_error "Checked:"
        for d in "${STEAM_COMPAT_DIRS[@]}"; do
            log_error "  $d"
        done
        return 1
    }

    log_info "Installing ${BOLD}${tag}${NC} to ${compat_dir}"

    # Find the tarball URL (ends in .tar.gz)
    local tarball_url
    tarball_url=$(json_array_get "$release" '.assets[] | select(.name | endswith(".tar.gz")) | .browser_download_url')

    if [[ -z "$tarball_url" ]]; then
        log_error "Could not find .tar.gz asset in the release."
        return 1
    fi

    # Find the sha512sum URL if available
    local sha512_url
    sha512_url=$(json_array_get "$release" '.assets[] | select(.name | endswith("sha512sum")) | .browser_download_url')

    local tmpdir
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT

    local tarball="${tmpdir}/${tag}.tar.gz"

    # Download tarball with progress
    log_step "Downloading ${tag}..."
    if ! curl -L --progress-bar -o "$tarball" "$tarball_url"; then
        log_error "Download failed."
        return 1
    fi

    # Verify checksum if available
    if [[ -n "$sha512_url" ]]; then
        log_step "Downloading checksum..."
        local sha512_file="${tmpdir}/sha512sum"
        if curl -sL -o "$sha512_file" "$sha512_url"; then
            log_step "Verifying integrity (SHA-512)..."
            local expected_hash actual_hash
            expected_hash=$(awk '{print $1}' "$sha512_file")
            actual_hash=$(sha512sum "$tarball" | awk '{print $1}')
            if [[ "$expected_hash" != "$actual_hash" ]]; then
                log_error "Checksum verification FAILED."
                log_error "Expected: $expected_hash"
                log_error "Got:      $actual_hash"
                log_error "The download may be corrupted. Aborting."
                return 1
            fi
            log_ok "Checksum verified."
        else
            log_warn "Could not download checksum file. Skipping verification."
        fi
    else
        log_warn "No sha512sum asset found in release. Skipping verification."
    fi

    # Check disk space (rough estimate: tarball * 3 for extraction)
    local tarball_size avail_bytes
    tarball_size=$(stat -c %s "$tarball" 2>/dev/null || stat -f %z "$tarball" 2>/dev/null || echo 0)
    avail_bytes=$(df --output=avail -B1 "$compat_dir" 2>/dev/null | tail -1 | tr -d ' ')
    local needed=$(( tarball_size * 3 ))

    if [[ -n "$avail_bytes" ]] && (( avail_bytes < needed )); then
        log_error "Insufficient disk space."
        log_error "Need approximately $(human_size $needed), available: $(human_size "$avail_bytes")"
        log_error "Run 'hubos-proton-updater cleanup' to free space."
        return 1
    fi

    # Extract
    log_step "Extracting to ${compat_dir}..."
    if ! tar -xzf "$tarball" -C "$compat_dir"; then
        log_error "Extraction failed."
        return 1
    fi

    # Verify installation
    if [[ -d "${compat_dir}/${tag}" ]]; then
        local install_size
        install_size=$(human_size "$(dir_size_bytes "${compat_dir}/${tag}")")
        log_ok "Successfully installed ${BOLD}${tag}${NC} (${install_size})"
        notify "Proton-GE Updated" "${tag} installed successfully (${install_size})"
    else
        # Some releases extract to a slightly different directory name
        local extracted
        extracted=$(ls -1td "$compat_dir"/GE-Proton* 2>/dev/null | head -1)
        if [[ -n "$extracted" ]]; then
            local install_size
            install_size=$(human_size "$(dir_size_bytes "$extracted")")
            log_ok "Successfully installed ${BOLD}$(basename "$extracted")${NC} (${install_size})"
            notify "Proton-GE Updated" "$(basename "$extracted") installed successfully (${install_size})"
        else
            log_warn "Extraction completed but could not verify installed directory."
        fi
    fi

    echo ""
    log_info "Restart Steam for the new version to appear in compatibility settings."
    return 0
}

cmd_list() {
    local compat_dir
    compat_dir=$(detect_compat_dir 2>/dev/null) || {
        log_error "Could not find Steam compatibilitytools.d directory."
        return 1
    }

    echo -e "${BOLD}Proton-GE versions:${NC}"
    echo -e "${DIM}Directory: ${compat_dir}${NC}"
    echo ""

    local ge_versions=()
    while IFS= read -r v; do
        [[ -n "$v" ]] && ge_versions+=("$v")
    done < <(get_installed_ge_versions)

    if [[ ${#ge_versions[@]} -eq 0 ]]; then
        echo "  (none installed)"
    else
        local latest="${ge_versions[-1]}"
        for v in "${ge_versions[@]}"; do
            local size_bytes size_human marker=""
            size_bytes=$(dir_size_bytes "${compat_dir}/${v}")
            size_human=$(human_size "${size_bytes:-0}")
            if [[ "$v" == "$latest" ]]; then
                marker=" ${GREEN}(latest)${NC}"
            fi
            printf "  ${CYAN}%-30s${NC} %10s%b\n" "$v" "$size_human" "$marker"
        done
    fi

    echo ""
    echo -e "${BOLD}Valve Proton versions:${NC}"
    echo ""

    local valve_versions=()
    while IFS= read -r v; do
        [[ -n "$v" ]] && valve_versions+=("$v")
    done < <(get_installed_valve_versions)

    if [[ ${#valve_versions[@]} -eq 0 ]]; then
        echo "  (none found)"
    else
        for v in "${valve_versions[@]}"; do
            printf "  ${DIM}%-30s${NC} %s\n" "$v" "(managed by Steam)"
        done
    fi

    echo ""

    # Total disk usage
    local total=0
    for v in "${ge_versions[@]}"; do
        local s
        s=$(dir_size_bytes "${compat_dir}/${v}")
        total=$(( total + ${s:-0} ))
    done
    echo -e "Total Proton-GE disk usage: ${BOLD}$(human_size $total)${NC}"
}

cmd_set_default() {
    local version="${1:-}"

    if [[ -z "$version" ]]; then
        log_error "Usage: hubos-proton-updater set-default <version>"
        echo ""
        echo "Available Proton-GE versions:"
        get_installed_ge_versions | while read -r v; do echo "  $v"; done
        return 1
    fi

    # Verify the version exists
    local compat_dir
    compat_dir=$(detect_compat_dir 2>/dev/null) || {
        log_error "Could not find Steam compatibilitytools.d directory."
        return 1
    }

    if [[ ! -d "${compat_dir}/${version}" ]]; then
        log_error "Version '${version}' not found in ${compat_dir}."
        echo "Installed versions:"
        get_installed_ge_versions | while read -r v; do echo "  $v"; done
        return 1
    fi

    echo -e "${BOLD}Setting the default Proton version is done through Steam:${NC}"
    echo ""
    echo "  ${CYAN}Global default:${NC}"
    echo "    1. Open Steam -> Settings -> Compatibility"
    echo "    2. Check 'Enable Steam Play for all other titles'"
    echo "    3. Select '${version}' from the dropdown"
    echo ""
    echo "  ${CYAN}Per-game override:${NC}"
    echo "    1. Right-click the game in your Library -> Properties"
    echo "    2. Go to the Compatibility tab"
    echo "    3. Check 'Force the use of a specific Steam Play compatibility tool'"
    echo "    4. Select '${version}' from the dropdown"
    echo ""
    echo -e "${DIM}Note: Restart Steam if the version does not appear in the list.${NC}"
}

cmd_cleanup() {
    local keep="${1:-$KEEP_VERSIONS}"
    local compat_dir

    compat_dir=$(detect_compat_dir 2>/dev/null) || {
        log_error "Could not find Steam compatibilitytools.d directory."
        return 1
    }

    local ge_versions=()
    while IFS= read -r v; do
        [[ -n "$v" ]] && ge_versions+=("$v")
    done < <(get_installed_ge_versions)

    local total=${#ge_versions[@]}

    if (( total <= keep )); then
        log_ok "Nothing to clean up. ${total} version(s) installed, keeping ${keep}."
        return 0
    fi

    local remove_count=$(( total - keep ))
    local to_remove=("${ge_versions[@]:0:$remove_count}")
    local total_freed=0

    echo -e "${BOLD}The following Proton-GE versions will be removed:${NC}"
    echo ""

    for v in "${to_remove[@]}"; do
        local size_bytes size_human
        size_bytes=$(dir_size_bytes "${compat_dir}/${v}")
        size_human=$(human_size "${size_bytes:-0}")
        total_freed=$(( total_freed + ${size_bytes:-0} ))
        printf "  ${RED}%-30s${NC} %10s\n" "$v" "$size_human"
    done

    echo ""
    echo -e "Space to be freed: ${BOLD}$(human_size $total_freed)${NC}"
    echo -e "Versions to keep:  ${GREEN}${ge_versions[*]:$remove_count}${NC}"
    echo ""

    if [[ "$SILENT" == true ]]; then
        # Auto mode — proceed without confirmation
        :
    else
        read -rp "Proceed with removal? [y/N] " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            log_info "Cancelled."
            return 0
        fi
    fi

    for v in "${to_remove[@]}"; do
        log_step "Removing ${v}..."
        rm -rf "${compat_dir:?}/${v}"
    done

    log_ok "Removed ${remove_count} version(s), freed $(human_size $total_freed)."
}

cmd_auto() {
    SILENT=true

    local release tag
    release=$(fetch_latest_release) || return 1
    tag=$(json_get "$release" ".tag_name")

    local latest_installed
    latest_installed=$(latest_installed_ge)

    if [[ "$latest_installed" == "$tag" ]]; then
        # Already up to date — exit silently
        return 0
    fi

    # New version available — download and install
    SILENT=false
    log_info "New Proton-GE version available: ${tag}"
    SILENT=true

    # Temporarily disable silent for update progress
    cmd_update

    # Run cleanup to keep things tidy
    cmd_cleanup "$KEEP_VERSIONS"
}

cmd_help() {
    cat <<HELP
${BOLD}hubos-proton-updater${NC} v${VERSION} — Proton-GE version manager for HubOS

${BOLD}USAGE${NC}
    hubos-proton-updater <command> [options]

${BOLD}COMMANDS${NC}
    ${CYAN}check${NC}                   Check for new Proton-GE releases
    ${CYAN}update${NC}                  Download and install the latest Proton-GE
    ${CYAN}list${NC}                    Show all installed Proton versions with disk usage
    ${CYAN}set-default${NC} <version>   Show instructions for setting default Proton in Steam
    ${CYAN}cleanup${NC} [N]             Remove old Proton-GE versions, keeping latest N (default: 2)
    ${CYAN}auto${NC}                    Unattended check + update (for systemd timers)
    ${CYAN}help${NC}                    Show this help message

${BOLD}OPTIONS${NC}
    --silent                Suppress non-essential output
    --keep <N>              Number of versions to keep during cleanup (default: 2)

${BOLD}ENVIRONMENT${NC}
    GITHUB_TOKEN            GitHub personal access token (avoids API rate limits)

${BOLD}EXAMPLES${NC}
    hubos-proton-updater check
    hubos-proton-updater update
    hubos-proton-updater list
    hubos-proton-updater cleanup 3
    hubos-proton-updater set-default GE-Proton9-20

${BOLD}SYSTEMD TIMER${NC}
    To run automatically, create a user timer:

    ~/.config/systemd/user/proton-ge-update.service:
        [Unit]
        Description=Update Proton-GE
        [Service]
        Type=oneshot
        ExecStart=/usr/bin/hubos-proton-updater auto

    ~/.config/systemd/user/proton-ge-update.timer:
        [Unit]
        Description=Check for Proton-GE updates daily
        [Timer]
        OnCalendar=daily
        Persistent=true
        [Install]
        WantedBy=timers.target

    Enable with: systemctl --user enable --now proton-ge-update.timer

${BOLD}FILES${NC}
    ~/.cache/hubos/proton-ge-latest.json    Cached release info from GitHub

HELP
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    local command="${1:-help}"
    shift || true

    # Parse global flags
    local positional=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --silent)
                SILENT=true
                shift
                ;;
            --keep)
                KEEP_VERSIONS="${2:-2}"
                shift 2
                ;;
            -h|--help)
                cmd_help
                return 0
                ;;
            *)
                positional+=("$1")
                shift
                ;;
        esac
    done

    # Add GITHUB_TOKEN to curl if set
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        GITHUB_API_AUTH=(-H "Authorization: Bearer ${GITHUB_TOKEN}")
    fi

    case "$command" in
        check)
            cmd_check "${positional[@]+"${positional[@]}"}"
            ;;
        update|install)
            cmd_update "${positional[@]+"${positional[@]}"}"
            ;;
        list|ls)
            cmd_list "${positional[@]+"${positional[@]}"}"
            ;;
        set-default|default)
            cmd_set_default "${positional[@]+"${positional[@]}"}"
            ;;
        cleanup|clean|purge)
            cmd_cleanup "${positional[@]+"${positional[@]}"}"
            ;;
        auto)
            cmd_auto "${positional[@]+"${positional[@]}"}"
            ;;
        help|-h|--help)
            cmd_help
            ;;
        version|--version|-v)
            echo "hubos-proton-updater v${VERSION}"
            ;;
        *)
            log_error "Unknown command: ${command}"
            echo ""
            cmd_help
            return 1
            ;;
    esac
}

main "$@"
