#!/bin/bash
set -euo pipefail
# 24HG Forge Retro — RetroArch emulator suite management for the Forge distro

# ─── Colors & Formatting ──────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'
PURPLE='\033[0;35m'; CYAN='\033[0;36m'; WHITE='\033[1;37m'; ORANGE='\033[0;33m'
MAGENTA='\033[0;35m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# System-specific colors
CLR_NES="$RED"
CLR_SNES="$PURPLE"
CLR_N64="$GREEN"
CLR_GB="$YELLOW"
CLR_GBA="$BLUE"
CLR_GENESIS="$CYAN"
CLR_SMS="$CYAN"
CLR_GG="$CYAN"
CLR_PS1="$WHITE"
CLR_PSP="$MAGENTA"
CLR_DS="$BLUE"
CLR_ARCADE="$ORANGE"
CLR_ATARI="$RED"
CLR_DOS="$YELLOW"

# ─── Paths & Config ───────────────────────────────────────────────────────────
FORGE_DIR="${HOME}/.config/forge"
RETRO_DIR="${HOME}/Games/Retro"
RETRO_CONF="${FORGE_DIR}/retro.conf"
RETROARCH_CFG="${HOME}/.var/app/org.libretro.RetroArch/config/retroarch/retroarch.cfg"
RETROARCH_CORES="${HOME}/.var/app/org.libretro.RetroArch/config/retroarch/cores"
RETROARCH_OVERRIDES="${HOME}/.var/app/org.libretro.RetroArch/config/retroarch/config"
RETROARCH_PLAYLISTS="${HOME}/.var/app/org.libretro.RetroArch/config/retroarch/playlists"
SCREENSHOTS_DIR="${HOME}/Pictures/Screenshots/Retro"
HISTORY_FILE="${FORGE_DIR}/play-history.json"
GAME_CACHE="${FORGE_DIR}/retro-cache.json"

CORE_URL="https://buildbot.libretro.com/nightly/linux/x86_64/latest"
VERSION="2.0.0"

# ─── System Definitions ──────────────────────────────────────────────────────
# Each system: display name, libretro core, ROM directory, file extensions,
# display color, and shader type.

declare -A SYSTEM_DIRS=(
    [NES]="NES" [SNES]="SNES" [GameBoy]="GameBoy" [GBA]="GBA" [N64]="N64"
    [Genesis]="Genesis" [MasterSystem]="MasterSystem" [GameGear]="GameGear"
    [PS1]="PS1" [PSP]="PSP" [DS]="DS" [Arcade]="Arcade"
    [Atari2600]="Atari2600" [DOS]="DOS"
)

declare -A SYSTEM_CORES=(
    [NES]="mesen_libretro"
    [SNES]="snes9x_libretro"
    [GameBoy]="gambatte_libretro"
    [GBA]="mgba_libretro"
    [N64]="mupen64plus_next_libretro"
    [Genesis]="genesis_plus_gx_libretro"
    [MasterSystem]="genesis_plus_gx_libretro"
    [GameGear]="genesis_plus_gx_libretro"
    [PS1]="pcsx_rearmed_libretro"
    [PSP]="ppsspp_libretro"
    [DS]="desmume_libretro"
    [Arcade]="fbneo_libretro"
    [Atari2600]="stella_libretro"
    [DOS]="dosbox_pure_libretro"
)

declare -A SYSTEM_EXTENSIONS=(
    [NES]="nes"
    [SNES]="smc sfc"
    [GameBoy]="gb gbc"
    [GBA]="gba"
    [N64]="z64 n64"
    [Genesis]="md gen"
    [MasterSystem]="sms"
    [GameGear]="gg"
    [PS1]="bin cue iso"
    [PSP]="iso cso"
    [DS]="nds"
    [Arcade]="zip"
    [Atari2600]="a26"
    [DOS]="exe bat"
)

declare -A SYSTEM_COLORS=(
    [NES]="$CLR_NES" [SNES]="$CLR_SNES" [GameBoy]="$CLR_GB" [GBA]="$CLR_GBA"
    [N64]="$CLR_N64" [Genesis]="$CLR_GENESIS" [MasterSystem]="$CLR_SMS"
    [GameGear]="$CLR_GG" [PS1]="$CLR_PS1" [PSP]="$CLR_PSP" [DS]="$CLR_DS"
    [Arcade]="$CLR_ARCADE" [Atari2600]="$CLR_ATARI" [DOS]="$CLR_DOS"
)

declare -A SYSTEM_SHADER=(
    [NES]="crt" [SNES]="crt" [GameBoy]="crt" [GBA]="crt"
    [N64]="upscale" [Genesis]="crt" [MasterSystem]="crt" [GameGear]="crt"
    [PS1]="upscale" [PSP]="upscale" [DS]="upscale"
    [Arcade]="crt" [Atari2600]="crt" [DOS]="none"
)

# Friendly names for display
declare -A SYSTEM_LABELS=(
    [NES]="Nintendo Entertainment System"
    [SNES]="Super Nintendo"
    [GameBoy]="Game Boy / Game Boy Color"
    [GBA]="Game Boy Advance"
    [N64]="Nintendo 64"
    [Genesis]="Sega Genesis / Mega Drive"
    [MasterSystem]="Sega Master System"
    [GameGear]="Sega Game Gear"
    [PS1]="PlayStation 1"
    [PSP]="PlayStation Portable"
    [DS]="Nintendo DS"
    [Arcade]="Arcade (FinalBurn Neo)"
    [Atari2600]="Atari 2600"
    [DOS]="MS-DOS"
)

# Ordered list for consistent iteration
SYSTEM_ORDER=(NES SNES GameBoy GBA N64 Genesis MasterSystem GameGear PS1 PSP DS Arcade Atari2600 DOS)

# ─── Helpers ──────────────────────────────────────────────────────────────────
log() { logger -t forge-retro "$*" 2>/dev/null || true; }

header() {
    echo -e "\n${BOLD}${BLUE}+==============================================================+${RESET}"
    echo -e "${BOLD}${BLUE}|${RESET}  ${BOLD}24HG Forge Retro${RESET}  ${DIM}v${VERSION}${RESET}                                   ${BOLD}${BLUE}|${RESET}"
    echo -e "${BOLD}${BLUE}|${RESET}  ${DIM}RetroArch emulator suite for 24HG Forge${RESET}                   ${BOLD}${BLUE}|${RESET}"
    echo -e "${BOLD}${BLUE}+==============================================================+${RESET}\n"
}

info()    { echo -e "  ${CYAN}[i]${RESET} $*"; }
success() { echo -e "  ${GREEN}[+]${RESET} $*"; }
warn()    { echo -e "  ${YELLOW}[!]${RESET} $*"; }
error()   { echo -e "  ${RED}[x]${RESET} $*" >&2; }
step()    { echo -e "  ${BOLD}${WHITE}-->  $*${RESET}"; }

system_header() {
    local sys="$1"
    local color="${SYSTEM_COLORS[$sys]:-$WHITE}"
    local label="${SYSTEM_LABELS[$sys]:-$sys}"
    echo -e "\n  ${color}${BOLD}--- ${label} (${sys}) ---${RESET}"
}

divider() {
    echo -e "  ${DIM}$(printf '%.0s-' {1..60})${RESET}"
}

# ─── Initialization ──────────────────────────────────────────────────────────
init_forge() {
    mkdir -p "$FORGE_DIR"
    [[ -f "$HISTORY_FILE" ]] || echo '[]' > "$HISTORY_FILE"
    [[ -f "$GAME_CACHE" ]] || echo '{}' > "$GAME_CACHE"
    if [[ ! -f "$RETRO_CONF" ]]; then
        cat > "$RETRO_CONF" <<'CONF'
# Forge Retro configuration
RETROARCH_FLATPAK=yes
SHADERS=yes
CRT_FILTER=yes
AUTO_DETECT_CORE=yes
TRACK_PLAYTIME=yes
VIDEO_DRIVER=vulkan
CONF
    fi
    # shellcheck source=/dev/null
    source "$RETRO_CONF"
    log "Initialized forge-retro"
}

# ─── RetroArch Detection ─────────────────────────────────────────────────────
is_retroarch_installed() {
    flatpak list --app 2>/dev/null | grep -qi "retroarch" && return 0
    command -v retroarch &>/dev/null && return 0
    return 1
}

run_retroarch() {
    if flatpak list --app 2>/dev/null | grep -qi "retroarch"; then
        flatpak run org.libretro.RetroArch "$@"
    elif command -v retroarch &>/dev/null; then
        retroarch "$@"
    else
        error "RetroArch not found. Run: forge-retro setup"
        return 1
    fi
}

# ─── System Detection from ROM Extension ─────────────────────────────────────
detect_system_for_file() {
    local file="$1"
    local ext="${file##*.}"
    ext="${ext,,}"

    case "$ext" in
        nes)                echo "NES" ;;
        sfc|smc)            echo "SNES" ;;
        gb|gbc)             echo "GameBoy" ;;
        gba)                echo "GBA" ;;
        z64|n64)            echo "N64" ;;
        md|gen)             echo "Genesis" ;;
        sms)                echo "MasterSystem" ;;
        gg)                 echo "GameGear" ;;
        nds)                echo "DS" ;;
        a26)                echo "Atari2600" ;;
        exe|bat)            echo "DOS" ;;
        cso)                echo "PSP" ;;
        cue)
            # .cue is almost always PS1 in retro context
            local parent
            parent="$(basename "$(dirname "$file")")"
            case "$parent" in
                PSP*|psp*) echo "PSP" ;;
                *)         echo "PS1" ;;
            esac
            ;;
        iso)
            # .iso could be PS1 or PSP; use parent directory as hint
            local parent
            parent="$(basename "$(dirname "$file")")"
            case "$parent" in
                PSP*|psp*)               echo "PSP" ;;
                PS1*|ps1*|PSX*|psx*)     echo "PS1" ;;
                *)                       echo "PS1" ;; # default disc image to PS1
            esac
            ;;
        bin)
            # .bin could be PS1 or Genesis; check parent directory
            local parent
            parent="$(basename "$(dirname "$file")")"
            case "$parent" in
                Genesis*|genesis*|MD*|md*|"Mega Drive"*) echo "Genesis" ;;
                *)                                        echo "PS1" ;;
            esac
            ;;
        zip)                echo "Arcade" ;;
        *)                  echo "" ;;
    esac
}

# ─── Core Management ─────────────────────────────────────────────────────────
get_core_for_system() {
    local sys="$1"
    local core="${SYSTEM_CORES[$sys]:-}"
    if [[ -z "$core" ]]; then
        echo ""
        return 1
    fi
    echo "$core"
}

is_core_installed() {
    local core="$1"
    local core_path="${RETROARCH_CORES}/${core}.so"
    [[ -f "$core_path" ]]
}

download_core() {
    local core="$1"
    local core_zip="${core}.so.zip"
    local dest="${RETROARCH_CORES}/${core}.so"

    if [[ -f "$dest" ]]; then
        return 0
    fi

    if curl -sSfL "${CORE_URL}/${core_zip}" -o "/tmp/${core_zip}" 2>/dev/null; then
        if unzip -o -q "/tmp/${core_zip}" -d "$RETROARCH_CORES" 2>/dev/null; then
            rm -f "/tmp/${core_zip}"
            return 0
        fi
        rm -f "/tmp/${core_zip}"
    fi
    return 1
}

# ─── Play History ─────────────────────────────────────────────────────────────
record_play() {
    local game="$1" system="$2" duration="${3:-0}"
    command -v jq &>/dev/null || return 0
    [[ -f "$HISTORY_FILE" ]] || echo '[]' > "$HISTORY_FILE"

    local entry
    entry=$(jq -n \
        --arg game "$game" \
        --arg source "RetroArch" \
        --arg system "$system" \
        --arg timestamp "$(date -Iseconds)" \
        --argjson duration "$duration" \
        '{game: $game, source: $source, system: $system, timestamp: $timestamp, duration: $duration}')
    local tmp="${HISTORY_FILE}.tmp"
    jq ". + [$entry]" "$HISTORY_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$HISTORY_FILE"
    log "Recorded play session: $game ($system) ${duration}s"
}

# ─── Game Cache (for forge-launch integration) ───────────────────────────────
update_retro_cache() {
    command -v jq &>/dev/null || return 0
    local cache_entries="[]"

    for sys in "${SYSTEM_ORDER[@]}"; do
        local dir="${RETRO_DIR}/${SYSTEM_DIRS[$sys]}"
        [[ -d "$dir" ]] || continue
        local exts="${SYSTEM_EXTENSIONS[$sys]}"
        for ext in $exts; do
            while IFS= read -r -d '' rom; do
                local name
                name="$(basename "$rom")"
                name="${name%.*}"
                cache_entries=$(echo "$cache_entries" | jq \
                    --arg name "$name" \
                    --arg path "$rom" \
                    --arg system "$sys" \
                    --arg source "RetroArch" \
                    '. + [{name: $name, path: $path, system: $system, source: $source}]')
            done < <(find "$dir" -maxdepth 2 -iname "*.${ext}" -print0 2>/dev/null)
        done
    done

    echo "$cache_entries" | jq '.' > "$GAME_CACHE"
    log "Updated retro game cache: $(echo "$cache_entries" | jq length) games"
}

# ─── Playlist Generation ─────────────────────────────────────────────────────
generate_playlist() {
    local sys="$1"
    shift
    local roms=("$@")
    local core
    core=$(get_core_for_system "$sys")
    local core_path="${RETROARCH_CORES}/${core}.so"
    local playlist_file="${RETROARCH_PLAYLISTS}/${sys}.lpl"

    mkdir -p "$RETROARCH_PLAYLISTS"

    if command -v jq &>/dev/null; then
        local items="[]"
        for rom in "${roms[@]}"; do
            local name
            name="$(basename "$rom")"
            name="${name%.*}"
            items=$(echo "$items" | jq \
                --arg path "$rom" \
                --arg label "$name" \
                --arg core_path "$core_path" \
                --arg core_name "$core" \
                --arg db_name "$sys" \
                '. + [{
                    path: $path,
                    label: $label,
                    core_path: $core_path,
                    core_name: $core_name,
                    crc32: "DETECT",
                    db_name: $db_name
                }]')
        done
        jq -n --argjson items "$items" \
            '{version: "1.5", default_core_path: "", default_core_name: "", label_display_mode: 0, right_thumbnail_mode: 0, left_thumbnail_mode: 0, sort_mode: 0, items: $items}' \
            > "$playlist_file"
    else
        # Fallback: legacy text playlist format
        > "$playlist_file"
        for rom in "${roms[@]}"; do
            local name
            name="$(basename "$rom")"
            name="${name%.*}"
            cat >> "$playlist_file" <<ENTRY
${rom}
${name}
${core_path}
${core}
DETECT
${sys}.lpl
ENTRY
        done
    fi
    log "Generated playlist for $sys: ${#roms[@]} entries"
}

# ─── Per-System Config Overrides ──────────────────────────────────────────────
apply_system_override() {
    local sys="$1"
    local quiet="${2:-}"
    local core="${SYSTEM_CORES[$sys]}"
    local override_dir="${RETROARCH_OVERRIDES}/${core}"
    mkdir -p "$override_dir"

    local override_file="${override_dir}/${core}.cfg"
    local shader_type="${SYSTEM_SHADER[$sys]:-none}"

    case "$shader_type" in
        crt)
            cat > "$override_file" <<'OVERRIDE'
video_shader_enable = "true"
video_shader = "shaders_slang/crt/crt-lottes.slangp"
video_scale_integer = "true"
video_smooth = "false"
OVERRIDE
            ;;
        upscale)
            cat > "$override_file" <<'OVERRIDE'
video_shader_enable = "false"
video_scale_integer = "false"
video_smooth = "true"
OVERRIDE
            # Write core-specific options for upscaled systems
            local core_opts="${override_dir}/${core}.opt"
            case "$sys" in
                N64)
                    cat > "$core_opts" <<'COREOPT'
mupen64plus-43screensize = "640x480"
mupen64plus-EnableNativeResolution = "True"
mupen64plus-Framerate = "Original"
COREOPT
                    ;;
                PS1)
                    cat > "$core_opts" <<'COREOPT'
pcsx_rearmed_neon_enhancement_enable = "enabled"
pcsx_rearmed_neon_enhancement_no_main = "enabled"
COREOPT
                    ;;
                PSP)
                    cat > "$core_opts" <<'COREOPT'
ppsspp_internal_resolution = "3x"
ppsspp_texture_scaling_level = "2"
ppsspp_texture_filtering = "Linear"
COREOPT
                    ;;
                DS)
                    cat > "$core_opts" <<'COREOPT'
desmume_internal_resolution = "2x"
desmume_screens_layout = "top/bottom"
COREOPT
                    ;;
            esac
            ;;
        none)
            cat > "$override_file" <<'OVERRIDE'
video_shader_enable = "false"
video_scale_integer = "false"
video_smooth = "false"
OVERRIDE
            ;;
    esac

    [[ -z "$quiet" ]] && success "Applied ${sys} override (shader: ${shader_type})"
    log "Applied override for $sys ($shader_type)"
}

# ─── Normalize System Name ────────────────────────────────────────────────────
normalize_system() {
    local input="${1,,}"
    case "$input" in
        nes|"nintendo entertainment system")       echo "NES" ;;
        snes|"super nintendo"|"super nes")         echo "SNES" ;;
        gb|gbc|gameboy|"game boy"|"game boy color") echo "GameBoy" ;;
        gba|"game boy advance")                    echo "GBA" ;;
        n64|"nintendo 64"|nintendo64)              echo "N64" ;;
        genesis|megadrive|"mega drive"|md|"sega genesis") echo "Genesis" ;;
        sms|mastersystem|"master system"|"sega master system") echo "MasterSystem" ;;
        gg|gamegear|"game gear"|"sega game gear")  echo "GameGear" ;;
        ps1|psx|playstation|"playstation 1")       echo "PS1" ;;
        psp|"playstation portable")                echo "PSP" ;;
        ds|nds|"nintendo ds")                      echo "DS" ;;
        arcade|mame|fbn|fbneo|"final burn"|"finalburn neo") echo "Arcade" ;;
        atari|atari2600|"atari 2600"|a26)          echo "Atari2600" ;;
        dos|msdos|"ms-dos"|dosbox)                 echo "DOS" ;;
        *)                                         echo "" ;;
    esac
}

# ─── Command: list ────────────────────────────────────────────────────────────
cmd_list() {
    header
    step "ROM Library"
    echo

    local grand_total=0
    local found_any=false

    for sys in "${SYSTEM_ORDER[@]}"; do
        local dir="${RETRO_DIR}/${SYSTEM_DIRS[$sys]}"
        local color="${SYSTEM_COLORS[$sys]}"
        [[ -d "$dir" ]] || continue

        local roms=()
        local exts="${SYSTEM_EXTENSIONS[$sys]}"
        for ext in $exts; do
            while IFS= read -r -d '' rom; do
                roms+=("$rom")
            done < <(find "$dir" -maxdepth 2 -iname "*.${ext}" -print0 2>/dev/null)
        done

        (( ${#roms[@]} == 0 )) && continue
        found_any=true

        system_header "$sys"
        for rom in "${roms[@]}"; do
            local name
            name="$(basename "$rom")"
            name="${name%.*}"
            local size
            size=$(du -h "$rom" 2>/dev/null | cut -f1)
            printf "    ${color}*${RESET} %-45s ${DIM}%s${RESET}\n" "$name" "$size"
        done
        echo -e "    ${DIM}${#roms[@]} ROM(s)${RESET}"
        ((grand_total += ${#roms[@]}))
    done

    echo
    if $found_any; then
        success "Total: ${grand_total} ROM(s) across all systems"
        echo
        echo -e "  ${DIM}Play a ROM: forge-retro play <name>${RESET}"
    else
        warn "No ROMs found."
        echo -e "  ${DIM}Place ROM files in: ${RETRO_DIR}/<System>/${RESET}"
        echo -e "  ${DIM}Then run: forge-retro scan${RESET}"
    fi
    echo
    hub_tip
}

# ─── Command: setup ──────────────────────────────────────────────────────────
cmd_setup() {
    local target_sys="${1:-}"

    header
    if [[ -n "$target_sys" ]]; then
        # Setup a single system
        local sys
        sys=$(normalize_system "$target_sys")
        if [[ -z "$sys" ]]; then
            error "Unknown system: ${target_sys}"
            echo -e "  ${DIM}Available systems:${RESET}"
            print_system_list
            return 1
        fi
        cmd_setup_single "$sys"
    else
        # Full setup: all systems
        cmd_setup_all
    fi
}

cmd_setup_single() {
    local sys="$1"
    local color="${SYSTEM_COLORS[$sys]}"
    local core="${SYSTEM_CORES[$sys]}"
    local label="${SYSTEM_LABELS[$sys]}"

    step "Setting up ${label}..."
    echo

    # Ensure RetroArch is installed
    if ! is_retroarch_installed; then
        info "RetroArch not found. Installing via Flatpak..."
        if ! install_retroarch; then
            return 1
        fi
    else
        success "RetroArch is installed"
    fi

    # Create ROM directory
    local rom_dir="${RETRO_DIR}/${SYSTEM_DIRS[$sys]}"
    mkdir -p "$rom_dir" "${RETRO_DIR}/BIOS" "${RETRO_DIR}/Saves"
    mkdir -p "$RETROARCH_CORES" "$RETROARCH_OVERRIDES" "$RETROARCH_PLAYLISTS"
    mkdir -p "$SCREENSHOTS_DIR"
    success "ROM directory: ${rom_dir}/"

    # Download the core
    echo -ne "  ${CYAN}[i]${RESET} Downloading core: ${core} ... "
    if is_core_installed "$core"; then
        echo -e "${DIM}already installed${RESET}"
    elif download_core "$core"; then
        echo -e "${GREEN}OK${RESET}"
        log "Installed core: $core for $sys"
    else
        echo -e "${RED}failed${RESET}"
        error "Could not download core: ${core}"
        error "You may need to install it manually via RetroArch's Online Updater."
        log "Failed to install core: $core for $sys"
    fi

    # Apply per-system config override
    apply_system_override "$sys" quiet
    success "Config override applied (shader: ${SYSTEM_SHADER[$sys]:-none})"

    echo
    echo -e "  ${BOLD}${GREEN}${sys} setup complete!${RESET}"
    echo
    echo -e "  ${DIM}Place your ${label} ROMs in:${RESET}"
    echo -e "  ${rom_dir}/"
    echo -e "  ${DIM}Accepted extensions: ${SYSTEM_EXTENSIONS[$sys]}${RESET}"
    echo
    bios_hint "$sys"
    log "Setup completed for $sys"
}

cmd_setup_all() {
    step "Setting up RetroArch retro gaming suite..."
    echo

    # Install RetroArch via Flatpak
    if is_retroarch_installed; then
        success "RetroArch is already installed"
    else
        info "Installing RetroArch via Flatpak..."
        if ! install_retroarch; then
            return 1
        fi
    fi

    # Create ROM directory structure
    info "Creating ROM directory structure..."
    for sys in "${SYSTEM_ORDER[@]}"; do
        mkdir -p "${RETRO_DIR}/${SYSTEM_DIRS[$sys]}"
    done
    mkdir -p "${RETRO_DIR}/BIOS" "${RETRO_DIR}/Saves"
    mkdir -p "$SCREENSHOTS_DIR"
    mkdir -p "$RETROARCH_CORES" "$RETROARCH_OVERRIDES" "$RETROARCH_PLAYLISTS"
    success "Created ${RETRO_DIR}/ with ${#SYSTEM_ORDER[@]} system directories"

    # Download and install cores
    info "Downloading emulator cores..."
    echo

    local installed=0 failed=0 skipped=0
    local seen_cores=()

    for sys in "${SYSTEM_ORDER[@]}"; do
        local core="${SYSTEM_CORES[$sys]}"
        local color="${SYSTEM_COLORS[$sys]}"

        # Skip duplicate cores (Genesis/MasterSystem/GameGear all share genesis_plus_gx)
        local already_done=false
        for seen in "${seen_cores[@]+"${seen_cores[@]}"}"; do
            if [[ "$seen" == "$core" ]]; then
                already_done=true
                break
            fi
        done
        if $already_done; then
            echo -e "    ${color}${sys}${RESET}: ${core} ${DIM}(shared core, already handled)${RESET}"
            ((skipped++))
            continue
        fi
        seen_cores+=("$core")

        if is_core_installed "$core"; then
            echo -e "    ${color}${sys}${RESET}: ${core} ${DIM}(already installed)${RESET}"
            ((installed++))
            continue
        fi

        echo -ne "    ${color}${sys}${RESET}: ${core} ... "
        if download_core "$core"; then
            echo -e "${GREEN}OK${RESET}"
            ((installed++))
            log "Installed core: $core for $sys"
        else
            echo -e "${RED}failed${RESET}"
            ((failed++))
            log "Failed to install core: $core for $sys"
        fi
    done

    echo
    success "Cores: ${installed} installed, ${failed} failed, ${skipped} shared"

    # Generate optimal RetroArch config
    info "Generating optimal RetroArch configuration..."
    cmd_generate_config
    success "RetroArch configured with optimal settings"

    # Apply per-system overrides
    info "Applying per-system overrides..."
    for sys in "${SYSTEM_ORDER[@]}"; do
        apply_system_override "$sys" quiet
    done
    success "System overrides applied for all ${#SYSTEM_ORDER[@]} systems"

    echo
    echo -e "  ${BOLD}${GREEN}Setup complete!${RESET}"
    echo
    echo -e "  ${DIM}ROM directories:${RESET}  ${RETRO_DIR}/"
    echo -e "  ${DIM}BIOS files:${RESET}       ${RETRO_DIR}/BIOS/"
    echo -e "  ${DIM}Saves:${RESET}            ${RETRO_DIR}/Saves/"
    echo -e "  ${DIM}Screenshots:${RESET}      ${SCREENSHOTS_DIR}/"
    echo
    echo -e "  ${BOLD}Supported systems:${RESET}"
    for sys in "${SYSTEM_ORDER[@]}"; do
        local color="${SYSTEM_COLORS[$sys]}"
        local label="${SYSTEM_LABELS[$sys]}"
        printf "    ${color}%-14s${RESET} %s\n" "$sys" "$label"
    done
    echo
    echo -e "  ${DIM}Next steps:${RESET}"
    echo -e "    1. Place your ROMs in the appropriate system folders"
    echo -e "    2. Run ${CYAN}forge-retro scan${RESET} to build playlists"
    echo -e "    3. Run ${CYAN}forge-retro play <rom>${RESET} to start playing"
    echo
    hub_tip
    log "Full setup completed successfully"
}

install_retroarch() {
    if flatpak install -y flathub org.libretro.RetroArch 2>&1; then
        success "RetroArch installed via Flatpak"
        log "RetroArch installed via Flatpak"
        return 0
    else
        error "Failed to install RetroArch."
        error "Ensure Flatpak is configured:"
        echo -e "  ${DIM}flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo${RESET}"
        log "RetroArch installation failed"
        return 1
    fi
}

bios_hint() {
    local sys="$1"
    case "$sys" in
        PS1)
            echo -e "  ${YELLOW}[!]${RESET} PS1 requires BIOS files. Place these in ${RETRO_DIR}/BIOS/:"
            echo -e "      ${DIM}scph5500.bin (Japan)  scph5501.bin (NA)  scph5502.bin (EU)${RESET}"
            echo
            ;;
        DS)
            echo -e "  ${YELLOW}[!]${RESET} DS requires BIOS/firmware. Place these in ${RETRO_DIR}/BIOS/:"
            echo -e "      ${DIM}bios7.bin  bios9.bin  firmware.bin${RESET}"
            echo
            ;;
        GBA)
            echo -e "  ${YELLOW}[!]${RESET} GBA BIOS is optional but recommended. Place in ${RETRO_DIR}/BIOS/:"
            echo -e "      ${DIM}gba_bios.bin${RESET}"
            echo
            ;;
    esac
}

# ─── Command: play ────────────────────────────────────────────────────────────
cmd_play() {
    local rom_query="${1:-}"
    if [[ -z "$rom_query" ]]; then
        error "Usage: forge-retro play <rom>"
        echo -e "  ${DIM}Specify a ROM file path or a partial name to search for.${RESET}"
        echo -e "  ${DIM}Examples:${RESET}"
        echo -e "    ${DIM}forge-retro play \"Super Mario\"${RESET}"
        echo -e "    ${DIM}forge-retro play ~/Games/Retro/NES/mario.nes${RESET}"
        return 1
    fi

    # If it's a direct file path, use it
    local rom_path=""
    if [[ -f "$rom_query" ]]; then
        rom_path="$rom_query"
    else
        # Search for ROM by partial name across all system directories
        local matches=()
        local find_args=()

        # Build find patterns for all known extensions
        local all_exts=(nes smc sfc gb gbc gba z64 n64 md gen sms gg bin cue iso cso nds zip a26 exe bat)
        for ext in "${all_exts[@]}"; do
            if (( ${#find_args[@]} > 0 )); then
                find_args+=("-o")
            fi
            find_args+=("-iname" "*.${ext}")
        done

        while IFS= read -r -d '' f; do
            local base
            base="$(basename "$f")"
            if [[ "${base,,}" == *"${rom_query,,}"* ]]; then
                matches+=("$f")
            fi
        done < <(find "$RETRO_DIR" -maxdepth 3 -type f \( "${find_args[@]}" \) -print0 2>/dev/null)

        if (( ${#matches[@]} == 0 )); then
            error "No ROM found matching: ${rom_query}"
            echo -e "  ${DIM}Run 'forge-retro list' to see available ROMs.${RESET}"
            echo -e "  ${DIM}Run 'forge-retro scan' to refresh the ROM library.${RESET}"
            return 1
        elif (( ${#matches[@]} == 1 )); then
            rom_path="${matches[0]}"
        else
            # Multiple matches: let the user choose
            echo -e "\n  ${YELLOW}Multiple matches found:${RESET}\n"
            local i=1
            for m in "${matches[@]}"; do
                local sys
                sys=$(detect_system_for_file "$m")
                local color="${SYSTEM_COLORS[$sys]:-$WHITE}"
                printf "    ${BOLD}%2d)${RESET} ${color}[%-12s]${RESET} %s\n" "$i" "$sys" "$(basename "$m")"
                ((i++))
            done
            echo
            echo -ne "  Select ROM [1-${#matches[@]}]: "
            local choice
            read -r choice
            if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#matches[@]} )); then
                rom_path="${matches[$((choice - 1))]}"
            else
                error "Invalid selection."
                return 1
            fi
        fi
    fi

    # Detect system from file extension
    local system
    system=$(detect_system_for_file "$rom_path")
    if [[ -z "$system" ]]; then
        error "Cannot detect system for: $(basename "$rom_path")"
        error "Unrecognized file extension."
        return 1
    fi

    # Resolve core
    local core
    core=$(get_core_for_system "$system")
    if [[ -z "$core" ]]; then
        error "No core configured for system: ${system}"
        return 1
    fi

    local core_path="${RETROARCH_CORES}/${core}.so"
    if [[ ! -f "$core_path" ]]; then
        warn "Core ${core} not found at ${core_path}"
        warn "Attempting to download..."
        if download_core "$core"; then
            success "Core downloaded successfully."
        else
            error "Failed to download core. Run 'forge-retro setup ${system}' first."
            return 1
        fi
    fi

    local rom_name
    rom_name="$(basename "$rom_path")"
    rom_name="${rom_name%.*}"
    local color="${SYSTEM_COLORS[$system]}"

    header
    echo -e "  ${color}${BOLD}${system}${RESET} ${DIM}|${RESET} ${BOLD}${rom_name}${RESET}"
    echo -e "  ${DIM}Core: ${core}${RESET}"
    echo -e "  ${DIM}File: ${rom_path}${RESET}"
    echo

    info "Launching RetroArch..."
    echo -e "  ${DIM}Hotkeys: F2=Save State  F4=Load State  F8=Screenshot  Esc=Quit${RESET}"
    echo
    log "Launching: $rom_name ($system) with core $core"

    local start_time
    start_time=$(date +%s)

    run_retroarch -L "$core_path" "$rom_path" 2>/dev/null || true

    local end_time
    end_time=$(date +%s)
    local duration=$(( end_time - start_time ))

    # Record playtime to history
    record_play "$rom_name" "$system" "$duration"

    local mins=$(( duration / 60 ))
    local secs=$(( duration % 60 ))
    echo
    success "Session ended. Played ${rom_name} for ${mins}m ${secs}s."
    echo
    hub_tip
    log "Session ended: $rom_name ($system) ${duration}s"
}

# ─── Command: scan ────────────────────────────────────────────────────────────
cmd_scan() {
    header
    step "Scanning for ROMs..."
    echo

    local total=0

    printf "  ${BOLD}%-14s %-8s %s${RESET}\n" "System" "ROMs" "Directory"
    divider

    for sys in "${SYSTEM_ORDER[@]}"; do
        local dir="${RETRO_DIR}/${SYSTEM_DIRS[$sys]}"
        local color="${SYSTEM_COLORS[$sys]}"
        local count=0
        local rom_list=()

        if [[ -d "$dir" ]]; then
            local exts="${SYSTEM_EXTENSIONS[$sys]}"
            for ext in $exts; do
                while IFS= read -r -d '' rom; do
                    rom_list+=("$rom")
                    ((count++))
                done < <(find "$dir" -maxdepth 2 -iname "*.${ext}" -print0 2>/dev/null)
            done
        fi

        local count_display
        if ((count > 0)); then
            count_display="${GREEN}${count}${RESET}"
        else
            count_display="${DIM}0${RESET}"
        fi

        printf "  ${color}%-14s${RESET} %b       ${DIM}%s/${RESET}\n" "$sys" "$count_display" "${SYSTEM_DIRS[$sys]}"

        # Generate playlist if ROMs found
        if ((count > 0)); then
            generate_playlist "$sys" "${rom_list[@]}"
        fi

        ((total += count))
    done

    echo
    divider
    echo

    if ((total > 0)); then
        success "Total ROMs found: ${total}"
        success "Playlists updated in ${RETROARCH_PLAYLISTS}/"

        # Update game cache for forge-launch integration
        update_retro_cache
        info "Games registered for forge-launch integration"
    else
        warn "No ROMs found."
        echo
        echo -e "  ${DIM}Place ROM files in the system directories under:${RESET}"
        echo -e "  ${RETRO_DIR}/"
        echo
        echo -e "  ${BOLD}Expected file types per system:${RESET}"
        for sys in "${SYSTEM_ORDER[@]}"; do
            local color="${SYSTEM_COLORS[$sys]}"
            printf "    ${color}%-14s${RESET} ${DIM}.%s${RESET}\n" "$sys" "$(echo "${SYSTEM_EXTENSIONS[$sys]}" | sed 's/ / ./g')"
        done
    fi
    echo
    log "Scan complete: $total ROMs found"
}

# ─── Command: cores ──────────────────────────────────────────────────────────
cmd_cores() {
    header
    step "Emulator Cores"
    echo

    printf "  ${BOLD}%-14s %-30s %-12s %s${RESET}\n" "System" "Core" "Status" "Shader"
    divider

    for sys in "${SYSTEM_ORDER[@]}"; do
        local core="${SYSTEM_CORES[$sys]}"
        local color="${SYSTEM_COLORS[$sys]}"
        local shader="${SYSTEM_SHADER[$sys]:-none}"
        local status

        if is_core_installed "$core"; then
            status="${GREEN}installed${RESET}"
        else
            status="${RED}missing${RESET}"
        fi

        printf "  ${color}%-14s${RESET} %-30s %b    ${DIM}%s${RESET}\n" "$sys" "$core" "$status" "$shader"
    done

    echo
    local total_cores=0
    if [[ -d "$RETROARCH_CORES" ]]; then
        total_cores=$(find "$RETROARCH_CORES" -name "*.so" 2>/dev/null | wc -l)
    fi
    info "Total core files in library: ${total_cores}"
    echo
    echo -e "  ${DIM}Install missing cores: forge-retro setup${RESET}"
    echo -e "  ${DIM}Or install a specific system: forge-retro setup <system>${RESET}"
    echo
}

# ─── Command: update ─────────────────────────────────────────────────────────
cmd_update() {
    header
    step "Updating RetroArch and cores..."
    echo

    # Update RetroArch itself
    if flatpak list --app 2>/dev/null | grep -qi "retroarch"; then
        info "Updating RetroArch Flatpak..."
        if flatpak update -y org.libretro.RetroArch 2>&1; then
            success "RetroArch updated"
        else
            warn "RetroArch update failed (may already be latest)"
        fi
    elif command -v retroarch &>/dev/null; then
        info "RetroArch installed natively; update via your package manager."
    else
        error "RetroArch not found. Run: forge-retro setup"
        return 1
    fi

    echo

    # Re-download all cores to get latest nightly builds
    info "Updating emulator cores..."
    echo

    local updated=0 failed=0
    local seen_cores=()

    for sys in "${SYSTEM_ORDER[@]}"; do
        local core="${SYSTEM_CORES[$sys]}"
        local color="${SYSTEM_COLORS[$sys]}"

        # Skip duplicate cores
        local already_done=false
        for seen in "${seen_cores[@]+"${seen_cores[@]}"}"; do
            [[ "$seen" == "$core" ]] && already_done=true && break
        done
        $already_done && continue
        seen_cores+=("$core")

        local core_zip="${core}.so.zip"
        echo -ne "    ${color}${sys}${RESET}: ${core} ... "

        # Remove old core to force re-download
        rm -f "${RETROARCH_CORES}/${core}.so"

        if download_core "$core"; then
            echo -e "${GREEN}updated${RESET}"
            ((updated++))
        else
            echo -e "${RED}failed${RESET}"
            ((failed++))
        fi
    done

    echo
    success "Cores updated: ${updated}, failed: ${failed}"
    echo
    log "Update complete: $updated cores updated, $failed failed"
}

# ─── Command: config ─────────────────────────────────────────────────────────
cmd_config() {
    local action="${1:-show}"

    header
    step "RetroArch Configuration"
    echo

    case "$action" in
        show)
            cmd_config_show
            ;;
        video)
            cmd_config_video
            ;;
        shader|shaders)
            cmd_config_shaders
            ;;
        controls|controller|input)
            cmd_config_controls
            ;;
        reset)
            cmd_config_reset
            ;;
        *)
            # Might be a system name; try to apply system override
            local sys
            sys=$(normalize_system "$action")
            if [[ -n "$sys" ]]; then
                cmd_config_system "$sys"
            else
                error "Unknown config option: ${action}"
                echo
                echo -e "  ${BOLD}Usage:${RESET} forge-retro config [option]"
                echo
                echo -e "  ${BOLD}Options:${RESET}"
                echo -e "    ${CYAN}show${RESET}         Show current configuration"
                echo -e "    ${CYAN}video${RESET}        Show/change video driver settings"
                echo -e "    ${CYAN}shaders${RESET}      Show shader preset info"
                echo -e "    ${CYAN}controls${RESET}     Show controller mapping hints"
                echo -e "    ${CYAN}reset${RESET}        Reset to default configuration"
                echo -e "    ${CYAN}<system>${RESET}     Show/apply config for a specific system"
                echo
                return 1
            fi
            ;;
    esac
}

cmd_config_show() {
    echo -e "  ${BOLD}RetroArch Config File:${RESET}"
    echo -e "  ${DIM}${RETROARCH_CFG}${RESET}"
    echo

    if [[ -f "$RETROARCH_CFG" ]]; then
        # Extract key settings
        echo -e "  ${BOLD}Current Settings:${RESET}"
        divider

        local video_driver audio_driver video_fullscreen video_vsync menu_driver
        video_driver=$(grep -oP 'video_driver\s*=\s*"\K[^"]+' "$RETROARCH_CFG" 2>/dev/null || echo "unknown")
        audio_driver=$(grep -oP 'audio_driver\s*=\s*"\K[^"]+' "$RETROARCH_CFG" 2>/dev/null || echo "unknown")
        video_fullscreen=$(grep -oP 'video_fullscreen\s*=\s*"\K[^"]+' "$RETROARCH_CFG" 2>/dev/null || echo "unknown")
        video_vsync=$(grep -oP 'video_vsync\s*=\s*"\K[^"]+' "$RETROARCH_CFG" 2>/dev/null || echo "unknown")
        menu_driver=$(grep -oP 'menu_driver\s*=\s*"\K[^"]+' "$RETROARCH_CFG" 2>/dev/null || echo "unknown")

        printf "    %-20s %s\n" "Video Driver:" "$video_driver"
        printf "    %-20s %s\n" "Audio Driver:" "$audio_driver"
        printf "    %-20s %s\n" "Fullscreen:" "$video_fullscreen"
        printf "    %-20s %s\n" "VSync:" "$video_vsync"
        printf "    %-20s %s\n" "Menu Driver:" "$menu_driver"
        echo
        divider
    else
        warn "RetroArch config not found. Run 'forge-retro setup' first."
    fi

    echo
    echo -e "  ${BOLD}Forge Retro Config:${RESET}"
    echo -e "  ${DIM}${RETRO_CONF}${RESET}"
    echo

    if [[ -f "$RETRO_CONF" ]]; then
        while IFS= read -r line; do
            [[ "$line" =~ ^#.*$ ]] && continue
            [[ -z "$line" ]] && continue
            echo -e "    ${DIM}${line}${RESET}"
        done < "$RETRO_CONF"
    else
        warn "Forge retro config not found."
    fi
    echo

    echo -e "  ${BOLD}Per-System Overrides:${RESET}"
    echo
    for sys in "${SYSTEM_ORDER[@]}"; do
        local core="${SYSTEM_CORES[$sys]}"
        local color="${SYSTEM_COLORS[$sys]}"
        local override_file="${RETROARCH_OVERRIDES}/${core}/${core}.cfg"
        local status
        if [[ -f "$override_file" ]]; then
            status="${GREEN}active${RESET}"
        else
            status="${DIM}none${RESET}"
        fi
        printf "    ${color}%-14s${RESET} %b\n" "$sys" "$status"
    done
    echo
}

cmd_config_video() {
    echo -e "  ${BOLD}Video Driver Options:${RESET}"
    echo
    echo -e "    ${CYAN}vulkan${RESET}  ${DIM}(recommended)${RESET} Best performance on modern GPUs"
    echo -e "    ${CYAN}gl${RESET}      OpenGL fallback, wide compatibility"
    echo -e "    ${CYAN}glcore${RESET}  OpenGL Core profile, shader support"
    echo
    echo -e "  ${DIM}Current driver can be changed in:${RESET}"
    echo -e "  ${DIM}${RETROARCH_CFG}${RESET}"
    echo -e "  ${DIM}Look for: video_driver = \"...\"${RESET}"
    echo
    echo -e "  ${DIM}Or change via RetroArch menu:${RESET}"
    echo -e "  ${DIM}Settings > Drivers > Video${RESET}"
    echo
}

cmd_config_shaders() {
    echo -e "  ${BOLD}Shader Presets by System:${RESET}"
    echo
    printf "    ${BOLD}%-14s %-10s %s${RESET}\n" "System" "Type" "Description"
    divider
    for sys in "${SYSTEM_ORDER[@]}"; do
        local color="${SYSTEM_COLORS[$sys]}"
        local shader="${SYSTEM_SHADER[$sys]:-none}"
        local desc
        case "$shader" in
            crt)     desc="CRT scanline filter (crt-lottes)" ;;
            upscale) desc="Internal resolution upscaling" ;;
            none)    desc="No shader applied" ;;
        esac
        printf "    ${color}%-14s${RESET} %-10s ${DIM}%s${RESET}\n" "$sys" "$shader" "$desc"
    done
    echo
    echo -e "  ${DIM}Shaders can be customized per-system via:${RESET}"
    echo -e "  ${DIM}${RETROARCH_OVERRIDES}/<core>/<core>.cfg${RESET}"
    echo
}

cmd_config_controls() {
    echo -e "  ${BOLD}Default Keyboard Mapping:${RESET}"
    echo
    echo -e "    ${BOLD}D-Pad:${RESET}        W / A / S / D"
    echo -e "    ${BOLD}A Button:${RESET}     X"
    echo -e "    ${BOLD}B Button:${RESET}     Z"
    echo -e "    ${BOLD}X Button:${RESET}     C"
    echo -e "    ${BOLD}Y Button:${RESET}     V"
    echo -e "    ${BOLD}Start:${RESET}        Enter"
    echo -e "    ${BOLD}Select:${RESET}       Right Shift"
    echo -e "    ${BOLD}L Shoulder:${RESET}   Q"
    echo -e "    ${BOLD}R Shoulder:${RESET}   E"
    echo
    echo -e "  ${BOLD}Hotkeys:${RESET}"
    echo
    echo -e "    ${CYAN}F2${RESET}            Save State"
    echo -e "    ${CYAN}F4${RESET}            Load State"
    echo -e "    ${CYAN}F8${RESET}            Screenshot"
    echo -e "    ${CYAN}F${RESET}             Toggle Fullscreen"
    echo -e "    ${CYAN}Space${RESET}         Fast Forward"
    echo -e "    ${CYAN}R${RESET}             Rewind"
    echo -e "    ${CYAN}Escape${RESET}        Quit"
    echo
    echo -e "  ${BOLD}Controller Support:${RESET}"
    echo
    echo -e "    ${GREEN}Xbox${RESET}          Auto-detected, native mapping"
    echo -e "    ${BLUE}PlayStation${RESET}    Auto-detected (DualShock/DualSense)"
    echo -e "    ${RED}Switch Pro${RESET}     Auto-detected"
    echo -e "    ${YELLOW}8BitDo${RESET}        Auto-detected in most modes"
    echo -e "    ${DIM}Generic USB${RESET}    Auto-detected via udev"
    echo
    echo -e "  ${DIM}Controller remapping: RetroArch menu > Settings > Input${RESET}"
    echo
}

cmd_config_reset() {
    info "Resetting RetroArch configuration to Forge defaults..."
    cmd_generate_config
    for sys in "${SYSTEM_ORDER[@]}"; do
        apply_system_override "$sys" quiet
    done
    success "Configuration reset to Forge defaults."
    echo
    log "Configuration reset"
}

cmd_config_system() {
    local sys="$1"
    local color="${SYSTEM_COLORS[$sys]}"
    local core="${SYSTEM_CORES[$sys]}"
    local label="${SYSTEM_LABELS[$sys]}"
    local shader="${SYSTEM_SHADER[$sys]:-none}"

    echo -e "  ${color}${BOLD}${label} (${sys})${RESET}"
    divider
    echo
    printf "    %-18s %s\n" "Core:" "$core"
    printf "    %-18s %s\n" "Shader:" "$shader"
    printf "    %-18s %s\n" "ROM Directory:" "${RETRO_DIR}/${SYSTEM_DIRS[$sys]}/"
    printf "    %-18s .%s\n" "Extensions:" "$(echo "${SYSTEM_EXTENSIONS[$sys]}" | sed 's/ / ./g')"
    echo

    local override_file="${RETROARCH_OVERRIDES}/${core}/${core}.cfg"
    if [[ -f "$override_file" ]]; then
        echo -e "  ${BOLD}Active Override:${RESET}"
        echo -e "  ${DIM}${override_file}${RESET}"
        echo
        while IFS= read -r line; do
            echo -e "    ${DIM}${line}${RESET}"
        done < "$override_file"
    else
        echo -e "  ${DIM}No override file found.${RESET}"
    fi
    echo

    local core_opts="${RETROARCH_OVERRIDES}/${core}/${core}.opt"
    if [[ -f "$core_opts" ]]; then
        echo -e "  ${BOLD}Core Options:${RESET}"
        echo -e "  ${DIM}${core_opts}${RESET}"
        echo
        while IFS= read -r line; do
            echo -e "    ${DIM}${line}${RESET}"
        done < "$core_opts"
        echo
    fi

    bios_hint "$sys"

    echo -e "  ${DIM}Re-apply default override: forge-retro setup ${sys}${RESET}"
    echo
}

# ─── RetroArch Global Config Generation ──────────────────────────────────────
cmd_generate_config() {
    # Detect audio driver
    local audio_driver="pulse"
    if pgrep -x pipewire &>/dev/null; then
        audio_driver="pipewire"
    fi

    local cfg_dir
    cfg_dir="$(dirname "$RETROARCH_CFG")"
    mkdir -p "$cfg_dir"

    cat > "$RETROARCH_CFG" <<RCFG
# 24HG Forge Retro — RetroArch Configuration
# Generated: $(date -Iseconds)
# Do not edit manually; use 'forge-retro config' or regenerate with 'forge-retro config reset'

# ─── Video ────────────────────────────────────────────────────────────────────
video_driver = "vulkan"
video_vsync = "true"
video_scale_integer = "true"
video_shader_enable = "true"
video_fullscreen = "true"
video_windowed_fullscreen = "true"
video_smooth = "false"
video_aspect_ratio_auto = "true"
video_msg_pos_x = 0.02
video_msg_pos_y = 0.02
video_font_size = 14

# ─── Audio ────────────────────────────────────────────────────────────────────
audio_driver = "${audio_driver}"
audio_out_rate = "48000"
audio_latency = "64"
audio_enable = "true"
audio_sync = "true"

# ─── Input ────────────────────────────────────────────────────────────────────
input_autodetect_enable = "true"
input_joypad_driver = "udev"
input_player1_up = "w"
input_player1_down = "s"
input_player1_left = "a"
input_player1_right = "d"
input_player1_a = "x"
input_player1_b = "z"
input_player1_x = "c"
input_player1_y = "v"
input_player1_start = "return"
input_player1_select = "rshift"
input_player1_l = "q"
input_player1_r = "e"
input_enable_hotkey = "nul"
input_exit_emulator = "escape"
input_save_state = "f2"
input_load_state = "f4"
input_toggle_fullscreen = "f"
input_toggle_fast_forward = "space"
input_rewind = "r"
input_screenshot = "f8"

# ─── Directories ──────────────────────────────────────────────────────────────
system_directory = "${RETRO_DIR}/BIOS"
savefile_directory = "${RETRO_DIR}/Saves"
savestate_directory = "${RETRO_DIR}/Saves"
screenshot_directory = "${SCREENSHOTS_DIR}"
content_directory = "${RETRO_DIR}"
playlist_directory = "${RETROARCH_PLAYLISTS}"
rgui_browser_directory = "${RETRO_DIR}"
core_directory = "${RETROARCH_CORES}"

# ─── Save Management ─────────────────────────────────────────────────────────
savestate_auto_save = "true"
savestate_auto_load = "true"
sort_savefiles_enable = "true"
sort_savestates_enable = "true"
save_file_compression = "true"

# ─── Misc ─────────────────────────────────────────────────────────────────────
rewind_enable = "true"
rewind_granularity = "4"
fastforward_ratio = "3.0"
pause_nonactive = "true"
menu_driver = "ozone"
menu_show_online_updater = "true"
quit_press_twice = "true"
RCFG
    log "Generated retroarch.cfg"
}

# ─── 24HG Hub Tip ────────────────────────────────────────────────────────────
hub_tip() {
    echo -e "  ${DIM}Tip: Share your retro gaming screenshots to the 24HG Hub gallery!${RESET}"
    echo -e "  ${DIM}Screenshots are saved to: ${SCREENSHOTS_DIR}/${RESET}"
    echo -e "  ${DIM}Upload with: forge-gallery upload <screenshot>${RESET}"
    echo
}

# ─── Print System List ────────────────────────────────────────────────────────
print_system_list() {
    for sys in "${SYSTEM_ORDER[@]}"; do
        local color="${SYSTEM_COLORS[$sys]}"
        local label="${SYSTEM_LABELS[$sys]}"
        printf "    ${color}%-14s${RESET} ${DIM}%s${RESET}\n" "$sys" "$label"
    done
}

# ─── Usage / Help ─────────────────────────────────────────────────────────────
usage() {
    header
    echo -e "  ${BOLD}Usage:${RESET} forge-retro <command> [args]"
    echo
    echo -e "  ${BOLD}Commands:${RESET}"
    echo -e "    ${CYAN}list${RESET}                  List all ROMs organized by system"
    echo -e "    ${CYAN}setup${RESET} [system]         Install RetroArch, cores, and create ROM dirs"
    echo -e "    ${CYAN}play${RESET} <rom>             Launch a ROM with auto-detected core"
    echo -e "    ${CYAN}scan${RESET}                   Scan ~/Games/Retro/ for ROMs, show counts"
    echo -e "    ${CYAN}cores${RESET}                  List all emulator cores and their status"
    echo -e "    ${CYAN}update${RESET}                 Update RetroArch and re-download latest cores"
    echo -e "    ${CYAN}config${RESET} [option]        Show/edit RetroArch configuration"
    echo
    echo -e "  ${BOLD}Config Options:${RESET}"
    echo -e "    ${CYAN}config show${RESET}            Display current settings"
    echo -e "    ${CYAN}config video${RESET}           Video driver info"
    echo -e "    ${CYAN}config shaders${RESET}         Shader preset info per system"
    echo -e "    ${CYAN}config controls${RESET}        Controller mapping hints"
    echo -e "    ${CYAN}config reset${RESET}           Reset to Forge defaults"
    echo -e "    ${CYAN}config${RESET} <system>        Show config for a specific system"
    echo
    echo -e "  ${BOLD}Supported Systems (${#SYSTEM_ORDER[@]}):${RESET}"
    echo
    for sys in "${SYSTEM_ORDER[@]}"; do
        local color="${SYSTEM_COLORS[$sys]}"
        local core="${SYSTEM_CORES[$sys]}"
        local exts="${SYSTEM_EXTENSIONS[$sys]}"
        printf "    ${color}%-14s${RESET} %-30s ${DIM}.%s${RESET}\n" "$sys" "$core" "$(echo "$exts" | sed 's/ / ./g')"
    done
    echo
    echo -e "  ${BOLD}Examples:${RESET}"
    echo -e "    ${DIM}forge-retro setup${RESET}                  Full setup (all systems)"
    echo -e "    ${DIM}forge-retro setup NES${RESET}              Setup only NES emulation"
    echo -e "    ${DIM}forge-retro scan${RESET}                   Scan and build playlists"
    echo -e "    ${DIM}forge-retro play \"Super Mario\"${RESET}      Play a game by name"
    echo -e "    ${DIM}forge-retro play ~/Games/Retro/NES/smb.nes${RESET}"
    echo -e "    ${DIM}forge-retro cores${RESET}                  Check installed cores"
    echo -e "    ${DIM}forge-retro update${RESET}                 Update everything"
    echo -e "    ${DIM}forge-retro config shaders${RESET}         View shader presets"
    echo -e "    ${DIM}forge-retro config PS1${RESET}             View PS1-specific config"
    echo
    echo -e "  ${BOLD}Directories:${RESET}"
    echo -e "    ROMs:          ${RETRO_DIR}/"
    echo -e "    BIOS:          ${RETRO_DIR}/BIOS/"
    echo -e "    Saves:         ${RETRO_DIR}/Saves/"
    echo -e "    Screenshots:   ${SCREENSHOTS_DIR}/"
    echo
    echo -e "  ${BOLD}ROM Extension Reference:${RESET}"
    echo -e "    ${DIM}.nes .smc .sfc .gb .gbc .gba .z64 .n64${RESET}"
    echo -e "    ${DIM}.md .gen .sms .gg .bin .cue .iso .cso${RESET}"
    echo -e "    ${DIM}.nds .zip .a26 .exe .bat${RESET}"
    echo
    hub_tip
}

# ─── Main ─────────────────────────────────────────────────────────────────────
main() {
    init_forge

    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        list)         cmd_list "$@" ;;
        setup)        cmd_setup "$@" ;;
        play)         cmd_play "$@" ;;
        scan)         cmd_scan "$@" ;;
        cores)        cmd_cores "$@" ;;
        update)       cmd_update "$@" ;;
        config)       cmd_config "$@" ;;
        help|--help|-h) usage ;;
        "")           usage ;;
        *)
            error "Unknown command: ${cmd}"
            echo
            usage
            return 1
            ;;
    esac
}

main "$@"
