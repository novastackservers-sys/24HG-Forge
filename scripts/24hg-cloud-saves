# ─── Save Path Resolution ───────────────────────────────────────────────────

resolve_save_path() {
    local game="$1"
    local save_rel="${GAME_SAVE_PATHS[$game]:-}"
    [[ -z "$save_rel" ]] && return 1

    # If path starts with compatdata, check Steam roots
    if [[ "$save_rel" == compatdata/* ]]; then
        local candidates=(
            "${STEAM_ROOT}/steamapps/${save_rel}"
            "${STEAM_FLATPAK}/steamapps/${save_rel}"
        )
        # Also check additional Steam library folders
        for lib in $(parse_steam_libraries); do
            candidates+=("${lib}/steamapps/${save_rel}")
        done
        for c in "${candidates[@]}"; do
            if [[ -d "$c" ]]; then
                echo "$c"
                return 0
            fi
        done
        return 1
    fi

    # Relative to home
    local full="${HOME}/${save_rel}"
    if [[ -d "$full" ]]; then
        echo "$full"
        return 0
    fi
    return 1
}

parse_steam_libraries() {
    local vdf="${STEAM_ROOT}/steamapps/libraryfolders.vdf"
    [[ -f "$vdf" ]] || vdf="${STEAM_FLATPAK}/steamapps/libraryfolders.vdf"
    [[ -f "$vdf" ]] || return 0

    python3 -c "
import re, sys
with open('$vdf') as f:
    text = f.read()
for m in re.finditer(r'\"path\"\s+\"([^\"]+)\"', text):
    p = m.group(1)
    if p != '${STEAM_ROOT}' and p != '${STEAM_FLATPAK}':
        print(p)
" 2>/dev/null || true
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_add() {
    local game="${1:-}" path="${2:-}"

    if [[ -z "$game" ]]; then
        err "Usage: 24hg-cloud-saves add <game> [path]"
        echo ""
        dim "If no path given, uses built-in save location database."
        dim "Game IDs: $(echo "${!GAME_DISPLAY_NAME[@]}" | tr ' ' ', ' | fold -s -w 70 | head -5)"
        return 1
    fi

    if [[ -z "$path" ]]; then
        # Try the built-in database
        if path=$(resolve_save_path "$game"); then
            info "Auto-detected save path for ${GAME_DISPLAY_NAME[$game]:-$game}"
            dim "$path"
        else
            err "Could not auto-detect save path for '$game'."
            dim "Specify the path manually: 24hg-cloud-saves add $game /path/to/saves"
            [[ -n "${GAME_DISPLAY_NAME[$game]:-}" ]] && dim "Expected: ${HOME}/${GAME_SAVE_PATHS[$game]:-unknown}"
            return 1
        fi
    else
        # Expand ~ and validate
        path="${path/#\~/$HOME}"
        if [[ ! -d "$path" ]]; then
            err "Directory not found: $path"
            return 1
        fi
    fi

    set_tracked "$game" "$path"
    ok "Now tracking ${BOLD}${GAME_DISPLAY_NAME[$game]:-$game}${RESET}"
    dim "Path: $path"
    dim "Run ${BOLD}24hg-cloud-saves sync${RESET} to upload saves now."
}

cmd_remove() {
    local game="${1:-}"
    if [[ -z "$game" ]]; then
        err "Usage: 24hg-cloud-saves remove <game>"
        return 1
    fi

    unset_tracked "$game"
    ok "Stopped tracking ${BOLD}${GAME_DISPLAY_NAME[$game]:-$game}${RESET}"
    dim "Cloud saves are kept. Use the Hub dashboard to delete them."
}

cmd_list() {
    ensure_config
    echo ""
    printf "${BOLD}${CYAN}${ICON_CLOUD} 24HG Cloud Saves — Tracked Games${RESET}\n"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    local count=0
    while IFS=$'\t' read -r game path last_sync; do
        [[ -z "$game" ]] && continue
        count=$((count + 1))
        local display="${GAME_DISPLAY_NAME[$game]:-$game}"
        local status_icon status_text

        if [[ ! -d "$path" ]]; then
            status_icon="${RED}${ICON_FAIL}${RESET}"
            status_text="${RED}path missing${RESET}"
        elif (( last_sync == 0 )); then
            status_icon="${YELLOW}${ICON_WARN}${RESET}"
            status_text="${YELLOW}never synced${RESET}"
        else
            status_icon="${GREEN}${ICON_OK}${RESET}"
            status_text="${GREEN}synced $(relative_time "$last_sync")${RESET}"
        fi

        printf "  ${status_icon} ${BOLD}%-35s${RESET} %b\n" "$display" "$status_text"
        printf "    ${DIM}%s${RESET}\n" "$path"
    done < <(get_tracked)

    if (( count == 0 )); then
        dim "No games tracked yet."
        dim "Run ${BOLD}24hg-cloud-saves scan${RESET} to auto-detect games,"
        dim "or ${BOLD}24hg-cloud-saves add <game>${RESET} to add one manually."
    fi
    echo ""
    printf "  ${DIM}%d game(s) tracked${RESET}\n" "$count"
    echo ""
}

cmd_sync() {
    ensure_config
    local token
    token=$(get_token)

    echo ""
    printf "${BOLD}${CYAN}${ICON_SYNC} Syncing Cloud Saves...${RESET}\n"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    local synced=0 failed=0 skipped=0

    while IFS=$'\t' read -r game path last_sync; do
        [[ -z "$game" ]] && continue
        local display="${GAME_DISPLAY_NAME[$game]:-$game}"

        if [[ ! -d "$path" ]]; then
            printf "  ${RED}${ICON_FAIL}${RESET} ${BOLD}%s${RESET} — path missing, skipping\n" "$display"
            skipped=$((skipped + 1))
            continue
        fi

        printf "  ${CYAN}${ICON_SYNC}${RESET} ${BOLD}%s${RESET} " "$display"

        # Get local save modification time
        local local_mtime
        local_mtime=$(find "$path" -type f -printf '%T@\n' 2>/dev/null | sort -rn | head -1 | cut -d. -f1)
        local_mtime="${local_mtime:-0}"

        # Check cloud status
        local cloud_info
        cloud_info=$(api_call GET "/info/$game" 2>/dev/null) || cloud_info="{}"
        local cloud_mtime
        cloud_mtime=$(echo "$cloud_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('last_modified',0))" 2>/dev/null || echo 0)

        if (( local_mtime == 0 && cloud_mtime == 0 )); then
            printf "— ${DIM}no saves found${RESET}\n"
            skipped=$((skipped + 1))
            continue
        fi

        # Conflict detection
        if (( local_mtime > last_sync && cloud_mtime > last_sync && last_sync > 0 )); then
            printf "\n"
            warn "  ${YELLOW}Conflict detected!${RESET} Both local and cloud saves changed since last sync."
            dim "    Local:  $(date -d "@$local_mtime" '+%Y-%m-%d %H:%M:%S')"
            dim "    Cloud:  $(date -d "@$cloud_mtime" '+%Y-%m-%d %H:%M:%S')"

            local conflict_mode
            conflict_mode=$(read_config | python3 -c "import sys,json; print(json.load(sys.stdin).get('conflict_mode','prompt'))" 2>/dev/null || echo prompt)

            if [[ "$conflict_mode" == "prompt" ]]; then
                printf "    ${BOLD}Keep (l)ocal, (c)loud, or (s)kip? ${RESET}"
                read -r -n1 choice
                echo ""
                case "$choice" in
                    l|L) sync_upload "$game" "$path" "$display" && synced=$((synced + 1)) || failed=$((failed + 1)) ;;
                    c|C) sync_download "$game" "$path" "$display" && synced=$((synced + 1)) || failed=$((failed + 1)) ;;
                    *)   printf "    ${DIM}Skipped${RESET}\n"; skipped=$((skipped + 1)) ;;
                esac
            elif [[ "$conflict_mode" == "local" ]]; then
                sync_upload "$game" "$path" "$display" && synced=$((synced + 1)) || failed=$((failed + 1))
            elif [[ "$conflict_mode" == "cloud" ]]; then
                sync_download "$game" "$path" "$display" && synced=$((synced + 1)) || failed=$((failed + 1))
            fi
            continue
        fi

        # Normal sync: upload if local is newer, download if cloud is newer
        if (( local_mtime >= cloud_mtime )); then
            sync_upload "$game" "$path" "$display" && synced=$((synced + 1)) || failed=$((failed + 1))
        else
            sync_download "$game" "$path" "$display" && synced=$((synced + 1)) || failed=$((failed + 1))
        fi

    done < <(get_tracked)

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    printf "  ${GREEN}${ICON_OK} %d synced${RESET}  " "$synced"
    (( failed > 0 )) && printf "${RED}${ICON_FAIL} %d failed${RESET}  " "$failed"
    (( skipped > 0 )) && printf "${DIM}%d skipped${RESET}  " "$skipped"
    echo ""
    echo ""

    if (( synced > 0 )); then
        notify "Cloud Saves Synced" "$synced game(s) synchronized successfully." "cloud-done"
    fi
    if (( failed > 0 )); then
        notify "Cloud Save Errors" "$failed game(s) failed to sync." "dialog-warning"
    fi
}

sync_upload() {
    local game="$1" path="$2" display="$3"
    local archive="${CACHE_DIR}/${game}-$(date +%s).tar.gz"
    local meta="${CACHE_DIR}/${game}-meta.json"

    # Create metadata
    cat > "$meta" <<EOF
{
  "game": "$game",
  "display_name": "$display",
  "machine_id": "$MACHINE_ID",
  "hostname": "$(hostname)",
  "timestamp": $(date +%s),
  "timestamp_human": "$(date -Iseconds)"
}
EOF

    # Create archive
    if ! tar czf "$archive" -C "$(dirname "$path")" "$(basename "$path")" -C "$CACHE_DIR" "$(basename "$meta")" 2>/dev/null; then
        printf "— ${RED}archive failed${RESET}\n"
        rm -f "$archive" "$meta"
        return 1
    fi

    local size
    size=$(stat -c%s "$archive" 2>/dev/null || echo 0)
    printf "— uploading $(human_size "$size")... "

    if api_call POST "/upload" \
        -F "game=$game" \
        -F "machine_id=$MACHINE_ID" \
        -F "save=@$archive" > /dev/null 2>&1; then
        printf "${GREEN}done${RESET}\n"
        update_last_sync "$game"
        rm -f "$archive" "$meta"
        return 0
    else
        printf "${RED}failed${RESET}\n"
        rm -f "$archive" "$meta"
        return 1
    fi
}

sync_download() {
    local game="$1" path="$2" display="$3"
    local archive="${CACHE_DIR}/${game}-download.tar.gz"

    printf "— downloading... "

    if api_call GET "/download/$game" -o "$archive" 2>/dev/null; then
        # Backup local saves before overwriting
        local backup_dir="${CACHE_DIR}/backups/${game}/$(date +%Y%m%d_%H%M%S)"
        mkdir -p "$backup_dir"
        if [[ -d "$path" ]]; then
            cp -a "$path" "${backup_dir}/" 2>/dev/null || true
        fi

        # Extract
        mkdir -p "$path"
        if tar xzf "$archive" -C "$(dirname "$path")" 2>/dev/null; then
            printf "${GREEN}done${RESET}\n"
            update_last_sync "$game"
            rm -f "$archive"
            return 0
        else
            printf "${RED}extract failed${RESET}\n"
            rm -f "$archive"
            return 1
        fi
    else
        printf "${RED}download failed${RESET}\n"
        rm -f "$archive"
        return 1
    fi
}

cmd_restore() {
    local game="${1:-}" timestamp="${2:-}"

    if [[ -z "$game" ]]; then
        err "Usage: 24hg-cloud-saves restore <game> [timestamp]"
        return 1
    fi

    local display="${GAME_DISPLAY_NAME[$game]:-$game}"

    echo ""
    printf "${BOLD}${MAGENTA}${ICON_CLOCK} Restoring saves for %s${RESET}\n" "$display"
    echo ""

    # Get save path from tracking
    local path=""
    while IFS=$'\t' read -r g p _; do
        [[ "$g" == "$game" ]] && path="$p"
    done < <(get_tracked)

    if [[ -z "$path" ]]; then
        err "'$game' is not tracked. Add it first with: 24hg-cloud-saves add $game"
        return 1
    fi

    local endpoint="/download/$game"
    [[ -n "$timestamp" ]] && endpoint="/download/$game?timestamp=$timestamp"

    local archive="${CACHE_DIR}/${game}-restore.tar.gz"

    info "Downloading save from cloud..."
    if ! api_call GET "$endpoint" -o "$archive" 2>/dev/null; then
        err "Failed to download save from cloud."
        rm -f "$archive"
        return 1
    fi

    # Backup current local saves
    local backup_dir="${CACHE_DIR}/backups/${game}/pre-restore-$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$backup_dir"
    if [[ -d "$path" ]]; then
        info "Backing up current local saves..."
        cp -a "$path" "${backup_dir}/"
        dim "Backup at: $backup_dir"
    fi

    # Extract
    info "Extracting cloud save..."
    mkdir -p "$path"
    if tar xzf "$archive" -C "$(dirname "$path")" 2>/dev/null; then
        ok "Saves restored for ${BOLD}$display${RESET}"
        update_last_sync "$game"
        notify "Saves Restored" "$display saves have been restored from cloud." "document-revert"
    else
        err "Failed to extract save archive."
        warn "Local backup available at: $backup_dir"
    fi
    rm -f "$archive"
}

cmd_history() {
    local game="${1:-}"

    if [[ -z "$game" ]]; then
        err "Usage: 24hg-cloud-saves history <game>"
        return 1
    fi

    local display="${GAME_DISPLAY_NAME[$game]:-$game}"

    echo ""
    printf "${BOLD}${CYAN}${ICON_CLOCK} Backup History — %s${RESET}\n" "$display"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    local response
    if ! response=$(api_call GET "/history/$game" 2>/dev/null); then
        err "Failed to fetch history from cloud."
        return 1
    fi

    python3 -c "
import json, sys
from datetime import datetime

data = json.loads('''$response''')
entries = data.get('history', [])

if not entries:
    print('  No backups found for this game.')
    sys.exit(0)

for i, entry in enumerate(entries):
    ts = entry.get('timestamp', 0)
    size = entry.get('size', 0)
    machine = entry.get('hostname', entry.get('machine_id', 'unknown'))
    dt = datetime.fromtimestamp(ts).strftime('%Y-%m-%d %H:%M:%S')

    # Format size
    if size >= 1073741824:
        sz = f'{size/1073741824:.1f} GB'
    elif size >= 1048576:
        sz = f'{size/1048576:.1f} MB'
    elif size >= 1024:
        sz = f'{size/1024:.1f} KB'
    else:
        sz = f'{size} B'

    marker = ' ← latest' if i == 0 else ''
    print(f'  \033[36m{dt}\033[0m  {sz:>10}  from \033[2m{machine}\033[0m{marker}')
    print(f'    \033[2mRestore: 24hg-cloud-saves restore $game {ts}\033[0m')
    print()

print(f'  {len(entries)} backup(s) total')
" 2>/dev/null || err "Failed to parse history response."

    echo ""
}

cmd_scan() {
    echo ""
    printf "${BOLD}${CYAN}${ICON_GAME} Scanning for game saves...${RESET}\n"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    local found=0 already=0

    # Get currently tracked games
    local tracked_games=""
    while IFS=$'\t' read -r g _ _; do
        tracked_games+="$g "
    done < <(get_tracked)

    for game in "${!GAME_SAVE_PATHS[@]}"; do
        local path
        if path=$(resolve_save_path "$game"); then
            found=$((found + 1))
            local display="${GAME_DISPLAY_NAME[$game]:-$game}"

            # Count save files
            local file_count
            file_count=$(find "$path" -type f 2>/dev/null | wc -l)
            local dir_size
            dir_size=$(du -sb "$path" 2>/dev/null | cut -f1)
            dir_size="${dir_size:-0}"

            if [[ "$tracked_games" == *"$game "* ]]; then
                printf "  ${GREEN}${ICON_OK}${RESET} ${BOLD}%-35s${RESET} ${DIM}(already tracked)${RESET}\n" "$display"
                already=$((already + 1))
            else
                printf "  ${YELLOW}${ICON_ARROW}${RESET} ${BOLD}%-35s${RESET} %d files, %s\n" "$display" "$file_count" "$(human_size "$dir_size")"
                dim "    $path"
            fi
        fi
    done

    # Also scan for Lutris games
    local lutris_conf="${HOME}/.config/lutris/games"
    if [[ -d "$lutris_conf" ]]; then
        local lutris_count
        lutris_count=$(ls "$lutris_conf"/*.yml 2>/dev/null | wc -l)
        if (( lutris_count > 0 )); then
            printf "\n  ${DIM}Found %d Lutris games (use 'add <game> <path>' to track manually)${RESET}\n" "$lutris_count"
        fi
    fi

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    printf "  ${GREEN}%d${RESET} games found" "$found"
    (( already > 0 )) && printf ", ${DIM}%d already tracked${RESET}" "$already"
    echo ""

    if (( found > already )); then
        echo ""
        printf "  ${BOLD}Add all untracked games? [y/N]${RESET} "
        read -r -n1 ans
        echo ""
        if [[ "$ans" =~ ^[Yy]$ ]]; then
            for game in "${!GAME_SAVE_PATHS[@]}"; do
                [[ "$tracked_games" == *"$game "* ]] && continue
                local path
                if path=$(resolve_save_path "$game"); then
                    set_tracked "$game" "$path"
                    printf "  ${GREEN}${ICON_OK}${RESET} Added %s\n" "${GAME_DISPLAY_NAME[$game]:-$game}"
                fi
            done
            ok "All detected games are now tracked."
        fi
    fi
    echo ""
}

cmd_watch() {
    # Check for inotifywait
    if ! command -v inotifywait &>/dev/null; then
        err "inotifywait not found. Install inotify-tools:"
        dim "  sudo dnf install inotify-tools"
        dim "  sudo apt install inotify-tools"
        return 1
    fi

    # Check if already running
    if [[ -f "$PID_FILE" ]]; then
        local old_pid
        old_pid=$(cat "$PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            warn "Watch daemon already running (PID $old_pid)."
            dim "Stop it with: kill $old_pid"
            return 1
        else
            rm -f "$PID_FILE"
        fi
    fi

    echo ""
    printf "${BOLD}${CYAN}${ICON_SYNC} Starting Cloud Save Watch Daemon${RESET}\n"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Collect paths to watch
    local watch_paths=()
    local watch_games=()

    while IFS=$'\t' read -r game path _; do
        [[ -z "$game" ]] && continue
        if [[ -d "$path" ]]; then
            watch_paths+=("$path")
            watch_games+=("$game")
            printf "  ${GREEN}${ICON_OK}${RESET} Watching: %s\n" "${GAME_DISPLAY_NAME[$game]:-$game}"
            dim "    $path"
        fi
    done < <(get_tracked)

    if [[ ${#watch_paths[@]} -eq 0 ]]; then
        err "No tracked games with valid paths to watch."
        return 1
    fi

    echo ""
    info "Daemon starting in background. PID file: $PID_FILE"
    dim "Stop with: kill \$(cat $PID_FILE)"
    echo ""

    # Fork to background
    (
        echo $$ > "$PID_FILE"
        log "Watch daemon started (PID $$), monitoring ${#watch_paths[@]} game(s)"

        cleanup() {
            rm -f "$PID_FILE"
            log "Watch daemon stopped"
            exit 0
        }
        trap cleanup SIGTERM SIGINT

        declare -A pending_sync

        while true; do
            # Use inotifywait with a timeout to allow checking pending syncs
            local changed_path=""
            changed_path=$(inotifywait -r -q --timeout 5 \
                --event modify,create,delete,moved_to \
                --format '%w' \
                "${watch_paths[@]}" 2>/dev/null) || true

            local now
            now=$(date +%s)

            # If a change was detected, mark the game for pending sync
            if [[ -n "$changed_path" ]]; then
                for i in "${!watch_paths[@]}"; do
                    if [[ "$changed_path" == "${watch_paths[$i]}"* ]]; then
                        pending_sync[${watch_games[$i]}]=$now
                        log "Change detected in ${watch_games[$i]}: $changed_path"
                        break
                    fi
                done
            fi

            # Process pending syncs (debounce: wait DEBOUNCE_SECS after last change)
            for game in "${!pending_sync[@]}"; do
                local last_change=${pending_sync[$game]}
                if (( now - last_change >= DEBOUNCE_SECS )); then
                    log "Debounce complete for $game, syncing..."

                    local path=""
                    while IFS=$'\t' read -r g p _; do
                        [[ "$g" == "$game" ]] && path="$p"
                    done < <(get_tracked)

                    local display="${GAME_DISPLAY_NAME[$game]:-$game}"
                    if sync_upload "$game" "$path" "$display" > /dev/null 2>&1; then
                        log "Auto-sync complete for $game"
                        notify "Save Auto-Synced" "$display saves uploaded to cloud." "cloud-done"
                    else
                        log "Auto-sync failed for $game"
                        notify "Auto-Sync Failed" "Failed to sync $display saves." "dialog-warning"
                    fi
                    unset 'pending_sync[$game]'
                fi
            done
        done
    ) &

    disown
    info "Daemon running with PID $(cat "$PID_FILE")"
}

cmd_status() {
    ensure_config

    echo ""
    printf "${BOLD}${CYAN}${ICON_CLOUD} 24HG Cloud Saves — Status${RESET}\n"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Machine info
    printf "  ${BOLD}Machine:${RESET}     %s (%s)\n" "$(hostname)" "${MACHINE_ID:0:12}..."
    printf "  ${BOLD}Config:${RESET}      %s\n" "$CONFIG_FILE"

    # Auth check
    if [[ -f "$TOKEN_FILE" ]]; then
        printf "  ${BOLD}Auth:${RESET}        ${GREEN}authenticated${RESET}\n"
    else
        printf "  ${BOLD}Auth:${RESET}        ${RED}not logged in${RESET}\n"
    fi

    # Watch daemon
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        printf "  ${BOLD}Watch:${RESET}       ${GREEN}running${RESET} (PID $(cat "$PID_FILE"))\n"
    else
        printf "  ${BOLD}Watch:${RESET}       ${DIM}not running${RESET}\n"
    fi

    echo ""

    # Cloud storage usage
    printf "  ${BOLD}Cloud Storage:${RESET}\n"
    local usage_info
    if usage_info=$(api_call GET "/usage" 2>/dev/null); then
        local used total pct
        used=$(echo "$usage_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('used_bytes',0))" 2>/dev/null || echo 0)
        total=$(echo "$usage_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('total_bytes',1073741824))" 2>/dev/null || echo 1073741824)
        pct=$(( used * 100 / total ))

        local bar_width=30
        local bar_filled=$(( pct * bar_width / 100 ))
        local bar_empty=$(( bar_width - bar_filled ))
        local bar_color="$GREEN"
        (( pct > 70 )) && bar_color="$YELLOW"
        (( pct > 90 )) && bar_color="$RED"

        printf "    ${bar_color}["
        printf "%0.s█" $(seq 1 "$bar_filled" 2>/dev/null) || true
        printf "%0.s░" $(seq 1 "$bar_empty" 2>/dev/null) || true
        printf "]${RESET} %s of %s (%d%%)\n" "$(human_size "$used")" "$(human_size "$total")" "$pct"

        printf "    ${DIM}Using %s of %s cloud storage${RESET}\n" "$(human_size "$used")" "$(human_size "$total")"
    else
        printf "    ${DIM}Could not fetch storage info (check auth)${RESET}\n"
    fi

    echo ""

    # Local cache size
    local cache_size=0
    if [[ -d "$CACHE_DIR" ]]; then
        cache_size=$(du -sb "$CACHE_DIR" 2>/dev/null | cut -f1)
        cache_size="${cache_size:-0}"
    fi
    printf "  ${BOLD}Local Cache:${RESET} %s at %s\n" "$(human_size "$cache_size")" "$CACHE_DIR"

    echo ""

    # Game summary
    local tracked=0 synced=0 stale=0 missing=0
    while IFS=$'\t' read -r game path last_sync; do
        [[ -z "$game" ]] && continue
        tracked=$((tracked + 1))
        if [[ ! -d "$path" ]]; then
            missing=$((missing + 1))
        elif (( last_sync > 0 )); then
            local now
            now=$(date +%s)
            if (( now - last_sync > 86400 )); then
                stale=$((stale + 1))
            else
                synced=$((synced + 1))
            fi
        fi
    done < <(get_tracked)

    printf "  ${BOLD}Games:${RESET}       %d tracked" "$tracked"
    (( synced > 0 )) && printf ", ${GREEN}%d synced${RESET}" "$synced"
    (( stale > 0 )) && printf ", ${YELLOW}%d stale${RESET}" "$stale"
    (( missing > 0 )) && printf ", ${RED}%d missing paths${RESET}" "$missing"
    echo ""
    echo ""
}

# ─── Usage / Help ────────────────────────────────────────────────────────────

usage() {
    cat <<EOF

${BOLD}${CYAN}${ICON_CLOUD} 24HG Cloud Saves${RESET} ${DIM}v${VERSION}${RESET}
${DIM}Sync game saves across all your 24HG machines${RESET}

${BOLD}USAGE${RESET}
    24hg-cloud-saves <command> [args]

${BOLD}COMMANDS${RESET}
    ${GREEN}sync${RESET}                        Sync all tracked game saves (upload new, download missing)
    ${GREEN}add${RESET} <game> [path]            Add a game's save directory to tracking
    ${GREEN}remove${RESET} <game>                Stop tracking a game
    ${GREEN}list${RESET}                         Show all tracked games and sync status
    ${GREEN}restore${RESET} <game> [timestamp]   Restore saves from cloud (optional specific backup)
    ${GREEN}history${RESET} <game>               Show backup history for a game
    ${GREEN}scan${RESET}                         Auto-detect installed games and their save locations
    ${GREEN}watch${RESET}                        Start daemon that watches save dirs and auto-syncs
    ${GREEN}status${RESET}                       Show sync status and storage usage

${BOLD}EXAMPLES${RESET}
    ${DIM}# Scan for games and start tracking${RESET}
    24hg-cloud-saves scan

    ${DIM}# Add Minecraft saves manually${RESET}
    24hg-cloud-saves add minecraft

    ${DIM}# Add a custom game with explicit path${RESET}
    24hg-cloud-saves add my-game ~/Games/MyGame/saves

    ${DIM}# Sync everything${RESET}
    24hg-cloud-saves sync

    ${DIM}# Start background auto-sync daemon${RESET}
    24hg-cloud-saves watch

    ${DIM}# Restore Skyrim saves from a specific point${RESET}
    24hg-cloud-saves history skyrim-se
    24hg-cloud-saves restore skyrim-se 1710000000

${BOLD}SUPPORTED GAMES (built-in)${RESET}
$(printf "    %-25s %s\n" "ID" "Game"
  printf "    %-25s %s\n" "---" "----"
  for g in $(echo "${!GAME_DISPLAY_NAME[@]}" | tr ' ' '\n' | sort); do
    printf "    %-25s %s\n" "$g" "${GAME_DISPLAY_NAME[$g]}"
  done)

${BOLD}CONFIG${RESET}
    ${DIM}$CONFIG_FILE${RESET}

${BOLD}AUTH${RESET}
    Requires hub login: ${BOLD}24hg-hub login${RESET}

EOF
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        sync)       cmd_sync "$@" ;;
        add)        cmd_add "$@" ;;
        remove)     cmd_remove "$@" ;;
        list)       cmd_list "$@" ;;
        restore)    cmd_restore "$@" ;;
        history)    cmd_history "$@" ;;
        scan)       cmd_scan "$@" ;;
        watch)      cmd_watch "$@" ;;
        status)     cmd_status "$@" ;;
        help|--help|-h)  usage ;;
        version|--version|-v)  echo "24hg-cloud-saves v${VERSION}" ;;
        *)
            err "Unknown command: $cmd"
            usage
            exit 1
            ;;
    esac
}

main "$@"
