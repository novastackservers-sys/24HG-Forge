#!/bin/bash
# 24HG Cloud Saves — Sync game saves across all your 24HG machines
set -euo pipefail

# ─── Constants ───────────────────────────────────────────────────────────────

VERSION="1.0.0"
CONFIG_DIR="${HOME}/.config/24hg"
CONFIG_FILE="${CONFIG_DIR}/cloud-saves.json"
TOKEN_FILE="${CONFIG_DIR}/hub-token"
CACHE_DIR="${HOME}/.cache/24hg/cloud-saves"
PID_FILE="/tmp/24hg-cloud-saves.pid"
HUB_URL="https://hub.24hgaming.com"
API_BASE="${HUB_URL}/api/cloud-saves"
MACHINE_ID="$(cat /etc/machine-id 2>/dev/null || hostname)"
DEBOUNCE_SECS=10
LOG_TAG="24hg-cloud-saves"

STEAM_ROOT="${HOME}/.local/share/Steam"
STEAM_FLATPAK="${HOME}/.var/app/com.valvesoftware.Steam/data/Steam"

# ─── Colors ──────────────────────────────────────────────────────────────────

RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
MAGENTA="\033[35m"
CYAN="\033[36m"
WHITE="\033[97m"
BOLD="\033[1m"
DIM="\033[2m"
RESET="\033[0m"

ICON_SYNC="⟳"
ICON_OK="✔"
ICON_FAIL="✘"
ICON_ARROW="→"
ICON_CLOUD="☁"
ICON_GAME="🎮"
ICON_WARN="⚠"
ICON_CLOCK="⏱"

# ─── Helpers ─────────────────────────────────────────────────────────────────

log()  { logger -t "$LOG_TAG" "$*"; }
info() { printf "${CYAN}${BOLD}%s${RESET} %s\n" "$ICON_CLOUD" "$*"; log "INFO: $*"; }
ok()   { printf "${GREEN}${BOLD}%s${RESET} %s\n" "$ICON_OK" "$*"; log "OK: $*"; }
warn() { printf "${YELLOW}${BOLD}%s${RESET} %s\n" "$ICON_WARN" "$*"; log "WARN: $*"; }
err()  { printf "${RED}${BOLD}%s${RESET} %s\n" "$ICON_FAIL" "$*" >&2; log "ERROR: $*"; }
dim()  { printf "${DIM}  %s${RESET}\n" "$*"; }

progress_bar() {
    local current=$1 total=$2 width=30
    local pct=$(( current * 100 / total ))
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    printf "\r  ${CYAN}["
    printf "%0.s█" $(seq 1 "$filled" 2>/dev/null) || true
    printf "%0.s░" $(seq 1 "$empty" 2>/dev/null) || true
    printf "]${RESET} %3d%%" "$pct"
    [[ $current -eq $total ]] && echo
}

notify() {
    local title="$1" body="$2" icon="${3:-dialog-information}"
    if command -v notify-send &>/dev/null; then
        notify-send -a "24HG Cloud Saves" -i "$icon" "$title" "$body" 2>/dev/null || true
    fi
}

human_size() {
    local bytes=$1
    if (( bytes >= 1073741824 )); then
        printf "%.1f GB" "$(echo "scale=1; $bytes / 1073741824" | bc)"
    elif (( bytes >= 1048576 )); then
        printf "%.1f MB" "$(echo "scale=1; $bytes / 1048576" | bc)"
    elif (( bytes >= 1024 )); then
        printf "%.1f KB" "$(echo "scale=1; $bytes / 1024" | bc)"
    else
        printf "%d B" "$bytes"
    fi
}

relative_time() {
    local ts=$1
    local now
    now=$(date +%s)
    local diff=$(( now - ts ))
    if (( diff < 60 )); then echo "just now"
    elif (( diff < 3600 )); then echo "$(( diff / 60 ))m ago"
    elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h ago"
    elif (( diff < 604800 )); then echo "$(( diff / 86400 ))d ago"
    else echo "$(date -d "@$ts" '+%Y-%m-%d')"
    fi
}

# ─── Auth ────────────────────────────────────────────────────────────────────

get_token() {
    if [[ ! -f "$TOKEN_FILE" ]]; then
        err "Not logged in. Run ${BOLD}24hg-hub login${RESET}${RED} first to authenticate."
        exit 1
    fi
    cat "$TOKEN_FILE"
}

api_call() {
    local method="$1" endpoint="$2"
    shift 2
    local token
    token=$(get_token)
    curl -sf -X "$method" \
        -H "Authorization: Bearer $token" \
        -H "X-Machine-ID: $MACHINE_ID" \
        "$@" \
        "${API_BASE}${endpoint}"
}

# ─── Config ──────────────────────────────────────────────────────────────────

ensure_config() {
    mkdir -p "$CONFIG_DIR" "$CACHE_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" <<'CONF'
{
  "tracked_games": {},
  "sync_on_launch": true,
  "auto_detect": true,
  "max_local_backups": 3,
  "conflict_mode": "prompt"
}
CONF
        log "Created default config at $CONFIG_FILE"
    fi
}

read_config() {
    ensure_config
    cat "$CONFIG_FILE"
}

write_config() {
    local data="$1"
    echo "$data" | python3 -c "import sys, json; json.dump(json.load(sys.stdin), open('$CONFIG_FILE','w'), indent=2)"
}

get_tracked() {
    read_config | python3 -c "
import sys, json
data = json.load(sys.stdin)
for game, info in data.get('tracked_games', {}).items():
    path = info if isinstance(info, str) else info.get('path', '')
    last = info.get('last_sync', 0) if isinstance(info, dict) else 0
    print(f'{game}\t{path}\t{last}')
" 2>/dev/null || true
}

set_tracked() {
    local game="$1" path="$2"
    python3 -c "
import json, time
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
cfg.setdefault('tracked_games', {})
cfg['tracked_games']['$game'] = {
    'path': '$path',
    'last_sync': 0,
    'added': int(time.time()),
    'machine': '$(hostname)'
}
with open('$CONFIG_FILE', 'w') as f:
    json.dump(cfg, f, indent=2)
"
}

unset_tracked() {
    local game="$1"
    python3 -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
cfg.get('tracked_games', {}).pop('$game', None)
with open('$CONFIG_FILE', 'w') as f:
    json.dump(cfg, f, indent=2)
"
}

update_last_sync() {
    local game="$1"
    python3 -c "
import json, time
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
g = cfg.get('tracked_games', {}).get('$game')
if g and isinstance(g, dict):
    g['last_sync'] = int(time.time())
with open('$CONFIG_FILE', 'w') as f:
    json.dump(cfg, f, indent=2)
"
}

