#!/usr/bin/env bash
# 24hg-driver-mgr — GPU Driver Manager for 24HG Linux
# Detects GPU hardware, manages drivers via rpm-ostree, reports Vulkan/OpenGL status.
set -euo pipefail

VERSION="1.0.0"
CONFIG_DIR="${HOME}/.config/24hg/driver-mgr"
STATE_FILE="${CONFIG_DIR}/state.json"
LOG_FILE="${CONFIG_DIR}/driver-mgr.log"

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# ── Helpers ─────────────────────────────────────────────────────────────────
msg()  { printf "${GREEN}●${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}●${RESET} %s\n" "$*"; }
err()  { printf "${RED}●${RESET} %s\n" "$*" >&2; }
hdr()  { printf "\n${BOLD}${CYAN}── %s ──${RESET}\n" "$*"; }
kv()   { printf "  ${DIM}%-22s${RESET} %s\n" "$1" "$2"; }

log_action() {
    mkdir -p "$CONFIG_DIR"
    printf '%s  %s\n' "$(date -Iseconds)" "$*" >> "$LOG_FILE"
}

save_state() {
    mkdir -p "$CONFIG_DIR"
    cat > "$STATE_FILE" <<EOJSON
{
  "last_action": "$1",
  "timestamp": "$(date -Iseconds)",
  "gpu_vendor": "${GPU_VENDOR:-unknown}",
  "driver": "${2:-unknown}"
}
EOJSON
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        err "This operation requires root. Re-run with sudo."
        exit 1
    fi
}

cmd_exists() { command -v "$1" &>/dev/null; }

# ── GPU Detection ───────────────────────────────────────────────────────────
GPU_VENDOR=""
GPU_MODEL=""
GPU_PCI_ID=""

detect_gpu() {
    local vga_line
    vga_line=$(lspci -nn 2>/dev/null | grep -iE 'vga|3d|display' | head -1) || true

    if [[ -z "$vga_line" ]]; then
        err "No GPU detected via lspci."
        return 1
    fi

    GPU_PCI_ID=$(echo "$vga_line" | grep -oP '\[\h*\K[0-9a-f]{4}:[0-9a-f]{4}' | head -1)
    GPU_MODEL=$(echo "$vga_line" | sed 's/^[^ ]* //')

    if echo "$vga_line" | grep -qi 'nvidia'; then
        GPU_VENDOR="nvidia"
    elif echo "$vga_line" | grep -qiE 'amd|ati|radeon'; then
        GPU_VENDOR="amd"
    elif echo "$vga_line" | grep -qi 'intel'; then
        GPU_VENDOR="intel"
    else
        GPU_VENDOR="unknown"
    fi
}

# ── Driver Info Collectors ──────────────────────────────────────────────────
get_nvidia_version() {
    if [[ -f /proc/driver/nvidia/version ]]; then
        grep -oP 'Module\s+\K[0-9.]+' /proc/driver/nvidia/version 2>/dev/null || echo "unknown"
    elif cmd_exists nvidia-smi; then
        nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null || echo "unknown"
    elif lsmod | grep -q '^nvidia '; then
        modinfo nvidia 2>/dev/null | awk '/^version:/{print $2}' || echo "loaded (version unknown)"
    elif lsmod | grep -q '^nouveau '; then
        echo "nouveau (open-source)"
    else
        echo "none loaded"
    fi
}

get_mesa_version() {
    if cmd_exists glxinfo; then
        glxinfo 2>/dev/null | grep -oP 'Mesa\s+\K[0-9.]+' | head -1 || echo "unknown"
    else
        rpm -q mesa-dri-drivers 2>/dev/null | sed 's/mesa-dri-drivers-//' || echo "unknown"
    fi
}

get_opengl_version() {
    if cmd_exists glxinfo; then
        glxinfo 2>/dev/null | awk -F': ' '/OpenGL version/{print $2}' | head -1 || echo "unknown"
    else
        echo "glxinfo not available"
    fi
}

get_vulkan_driver() {
    if cmd_exists vulkaninfo; then
        vulkaninfo --summary 2>/dev/null | awk -F'= ' '/driverName/{print $2}' | head -1 || echo "unknown"
    else
        echo "vulkaninfo not available"
    fi
}

get_vulkan_version() {
    if cmd_exists vulkaninfo; then
        vulkaninfo --summary 2>/dev/null | awk -F'= ' '/apiVersion/{print $2}' | head -1 || echo "unknown"
    else
        echo "unknown"
    fi
}

get_kernel_module() {
    if [[ "$GPU_VENDOR" == "nvidia" ]]; then
        if lsmod 2>/dev/null | grep -q '^nvidia '; then
            echo "nvidia"
        elif lsmod 2>/dev/null | grep -q '^nouveau '; then
            echo "nouveau"
        else
            echo "none"
        fi
    elif [[ "$GPU_VENDOR" == "amd" ]]; then
        if lsmod 2>/dev/null | grep -q '^amdgpu '; then
            echo "amdgpu"
        elif lsmod 2>/dev/null | grep -q '^radeon '; then
            echo "radeon"
        else
            echo "none"
        fi
    elif [[ "$GPU_VENDOR" == "intel" ]]; then
        if lsmod 2>/dev/null | grep -q '^i915 '; then
            echo "i915"
        elif lsmod 2>/dev/null | grep -q '^xe '; then
            echo "xe"
        else
            echo "none"
        fi
    else
        echo "unknown"
    fi
}

# ── DXVK / VKD3D ───────────────────────────────────────────────────────────
get_dxvk_version() {
    local ver
    ver=$(rpm -q dxvk 2>/dev/null) && { echo "$ver" | sed 's/dxvk-//'; return; }
    # Check flatpak Steam's bundled DXVK
    local steam_dxvk
    steam_dxvk=$(find ~/.steam/steam/compatibilitytools.d/ \
        ~/.local/share/Steam/compatibilitytools.d/ \
        /usr/share/steam/compatibilitytools.d/ \
        -maxdepth 3 -name 'd3d11.dll' 2>/dev/null | head -1)
    if [[ -n "$steam_dxvk" ]]; then
        echo "bundled (Proton)"
    else
        echo "not found"
    fi
}

get_vkd3d_version() {
    rpm -q vkd3d-proton 2>/dev/null | sed 's/vkd3d-proton-//' && return
    rpm -q vkd3d 2>/dev/null | sed 's/vkd3d-//' && return
    echo "not found"
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_status() {
    detect_gpu
    hdr "GPU Hardware"
    kv "Vendor:" "$GPU_VENDOR"
    kv "Model:" "$GPU_MODEL"
    kv "PCI ID:" "${GPU_PCI_ID:-unknown}"
    kv "Kernel module:" "$(get_kernel_module)"

    hdr "Driver"
    if [[ "$GPU_VENDOR" == "nvidia" ]]; then
        kv "NVIDIA driver:" "$(get_nvidia_version)"
    fi
    kv "Mesa version:" "$(get_mesa_version)"
    kv "OpenGL:" "$(get_opengl_version)"

    hdr "Vulkan"
    kv "Vulkan driver:" "$(get_vulkan_driver)"
    kv "Vulkan API:" "$(get_vulkan_version)"

    hdr "Compatibility Layers"
    kv "DXVK:" "$(get_dxvk_version)"
    kv "VKD3D-Proton:" "$(get_vkd3d_version)"

    # Mesa-git COPR status
    local mesa_git="disabled"
    if rpm-ostree status 2>/dev/null | grep -q 'mesa-git'; then
        mesa_git="enabled"
    fi
    kv "Mesa-git COPR:" "$mesa_git"
}

cmd_detect() {
    detect_gpu
    hdr "GPU Detection"
    kv "Detected:" "$GPU_MODEL"
    kv "Vendor:" "$GPU_VENDOR"

    echo ""
    case "$GPU_VENDOR" in
        nvidia)
            msg "Recommended: Install proprietary NVIDIA driver for best performance."
            echo "  Run: ${BOLD}24hg-driver-mgr switch latest${RESET}"
            echo "  Or for nouveau: ${BOLD}24hg-driver-mgr switch nouveau${RESET}"
            ;;
        amd)
            msg "AMD GPUs use the Mesa RADV Vulkan driver (included by default)."
            echo "  For bleeding-edge Mesa: ${BOLD}24hg-driver-mgr mesa-git enable${RESET}"
            ;;
        intel)
            msg "Intel GPUs use the Mesa ANV Vulkan driver (included by default)."
            echo "  For bleeding-edge Mesa: ${BOLD}24hg-driver-mgr mesa-git enable${RESET}"
            ;;
        *)
            warn "Unknown GPU vendor. Check lspci output manually."
            ;;
    esac
}

cmd_switch() {
    require_root
    detect_gpu
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        err "Usage: 24hg-driver-mgr switch <version|nouveau|latest>"
        err "Examples:"
        err "  24hg-driver-mgr switch 550      # NVIDIA 550.xx branch"
        err "  24hg-driver-mgr switch latest    # Latest available NVIDIA driver"
        err "  24hg-driver-mgr switch nouveau   # Open-source fallback"
        exit 1
    fi

    if [[ "$GPU_VENDOR" != "nvidia" ]]; then
        warn "Driver switching is primarily for NVIDIA GPUs."
        warn "AMD/Intel use Mesa — try '24hg-driver-mgr mesa-git enable' instead."
        exit 1
    fi

    hdr "Switching NVIDIA Driver"

    case "$target" in
        nouveau)
            msg "Removing proprietary NVIDIA drivers and falling back to nouveau..."
            log_action "switch nouveau"
            rpm-ostree override reset --all 2>/dev/null || true
            local nvidia_pkgs
            nvidia_pkgs=$(rpm -qa 2>/dev/null | grep -i 'nvidia' | grep -v 'nvidia-gpu-firmware' || true)
            if [[ -n "$nvidia_pkgs" ]]; then
                # shellcheck disable=SC2086
                rpm-ostree uninstall $nvidia_pkgs 2>/dev/null || true
            fi
            save_state "switch" "nouveau"
            msg "Nouveau driver will be active after reboot."
            warn "Reboot required: systemctl reboot"
            ;;
        latest)
            msg "Installing latest NVIDIA driver from RPM Fusion..."
            log_action "switch latest"
            rpm-ostree install --idempotent \
                akmod-nvidia xorg-x11-drv-nvidia \
                xorg-x11-drv-nvidia-cuda \
                nvidia-vaapi-driver 2>&1 | tail -5
            save_state "switch" "nvidia-latest"
            msg "Latest NVIDIA driver staged."
            warn "Reboot required: systemctl reboot"
            ;;
        *)
            # Attempt to install a specific branch (e.g., 550, 545, 535)
            local branch="$target"
            msg "Installing NVIDIA driver branch ${branch}..."
            log_action "switch nvidia-${branch}"

            # Remove existing NVIDIA packages first
            local existing
            existing=$(rpm -qa 2>/dev/null | grep -i 'akmod-nvidia' || true)
            if [[ -n "$existing" ]]; then
                rpm-ostree uninstall $existing 2>/dev/null || true
            fi

            # Try branch-specific package
            if rpm-ostree install --idempotent \
                "akmod-nvidia-${branch}xx" \
                "xorg-x11-drv-nvidia-${branch}xx" 2>&1 | tail -5; then
                save_state "switch" "nvidia-${branch}"
                msg "NVIDIA ${branch} branch driver staged."
            else
                err "Branch ${branch} not found in repos. Available branches:"
                rpm-ostree search akmod-nvidia 2>/dev/null | grep akmod || \
                    warn "Run 'rpm-ostree search akmod-nvidia' to list available packages."
                exit 1
            fi
            warn "Reboot required: systemctl reboot"
            ;;
    esac
}

cmd_mesa_git() {
    require_root
    local action="${1:-}"

    if [[ -z "$action" ]]; then
        err "Usage: 24hg-driver-mgr mesa-git [enable|disable]"
        exit 1
    fi

    local copr_repo="che/mesa-git"

    case "$action" in
        enable)
            hdr "Enabling Mesa-git COPR"
            msg "Adding COPR repo: ${copr_repo}..."
            log_action "mesa-git enable"

            # Create repo file for rpm-ostree
            local repo_url="https://copr.fedorainfracloud.org/coprs/${copr_repo}/repo/fedora-\$releasever/che-mesa-git-fedora-\$releasever.repo"
            local repo_file="/etc/yum.repos.d/_copr-${copr_repo//\//-}.repo"

            curl -fsSL "$repo_url" -o "$repo_file" 2>/dev/null || {
                err "Failed to fetch COPR repo file."
                exit 1
            }

            msg "Upgrading Mesa packages to git builds..."
            rpm-ostree override replace --experimental \
                --from repo=copr:copr.fedorainfracloud.org:che:mesa-git \
                mesa-dri-drivers mesa-libGL mesa-libEGL mesa-vulkan-drivers \
                mesa-libgbm mesa-libglapi 2>&1 | tail -5 || {
                    warn "Override failed — trying rpm-ostree upgrade with new repo..."
                    rpm-ostree upgrade 2>&1 | tail -5
                }
            save_state "mesa-git" "enabled"
            msg "Mesa-git builds staged."
            warn "Reboot required: systemctl reboot"
            ;;
        disable)
            hdr "Disabling Mesa-git COPR"
            msg "Resetting Mesa packages to stock..."
            log_action "mesa-git disable"
            rpm-ostree override reset \
                mesa-dri-drivers mesa-libGL mesa-libEGL mesa-vulkan-drivers \
                mesa-libgbm mesa-libglapi 2>/dev/null || true
            rm -f /etc/yum.repos.d/_copr-che-mesa-git.repo 2>/dev/null || true
            save_state "mesa-git" "disabled"
            msg "Mesa reset to stock versions."
            warn "Reboot required: systemctl reboot"
            ;;
        *)
            err "Unknown action: $action (use enable or disable)"
            exit 1
            ;;
    esac
}

cmd_vulkan() {
    detect_gpu
    hdr "Vulkan Information"

    if ! cmd_exists vulkaninfo; then
        err "vulkaninfo not found. Install: rpm-ostree install vulkan-tools"
        exit 1
    fi

    local summary
    summary=$(vulkaninfo --summary 2>/dev/null) || {
        err "vulkaninfo failed — no Vulkan-capable driver loaded?"
        exit 1
    }

    # Device info
    local dev_name dev_type api_ver driver_name driver_ver
    dev_name=$(echo "$summary" | awk -F'= ' '/deviceName/{print $2}' | head -1)
    dev_type=$(echo "$summary" | awk -F'= ' '/deviceType/{print $2}' | head -1)
    api_ver=$(echo "$summary" | awk -F'= ' '/apiVersion/{print $2}' | head -1)
    driver_name=$(echo "$summary" | awk -F'= ' '/driverName/{print $2}' | head -1)
    driver_ver=$(echo "$summary" | awk -F'= ' '/driverInfo/{print $2}' | head -1)

    kv "Device:" "${dev_name:-unknown}"
    kv "Type:" "${dev_type:-unknown}"
    kv "Vulkan API:" "${api_ver:-unknown}"
    kv "Driver:" "${driver_name:-unknown}"
    kv "Driver version:" "${driver_ver:-unknown}"

    # Extension count
    hdr "Vulkan Extensions"
    local ext_count
    ext_count=$(vulkaninfo 2>/dev/null | grep -c 'VK_' || echo "0")
    kv "Total extensions:" "$ext_count"

    # Key gaming extensions
    echo ""
    msg "Key gaming extensions:"
    local -a check_exts=(
        "VK_KHR_ray_tracing_pipeline"
        "VK_KHR_acceleration_structure"
        "VK_KHR_dynamic_rendering"
        "VK_EXT_mesh_shader"
        "VK_KHR_synchronization2"
        "VK_EXT_descriptor_indexing"
        "VK_KHR_shader_float16_int8"
        "VK_EXT_memory_budget"
        "VK_KHR_present_wait"
        "VK_EXT_hdr_metadata"
    )
    local full_info
    full_info=$(vulkaninfo 2>/dev/null)
    for ext in "${check_exts[@]}"; do
        if echo "$full_info" | grep -q "$ext"; then
            printf "  ${GREEN}✓${RESET} %s\n" "$ext"
        else
            printf "  ${DIM}✗ %s${RESET}\n" "$ext"
        fi
    done
}

cmd_health() {
    detect_gpu
    hdr "Driver Health Check"
    local issues=0

    # Kernel module
    local kmod
    kmod=$(get_kernel_module)
    if [[ "$kmod" == "none" || "$kmod" == "unknown" ]]; then
        printf "  ${RED}✗${RESET} Kernel module: not loaded\n"
        ((issues++))
    else
        printf "  ${GREEN}✓${RESET} Kernel module: %s\n" "$kmod"
    fi

    # OpenGL
    if cmd_exists glxinfo; then
        local gl_renderer
        gl_renderer=$(glxinfo 2>/dev/null | awk -F': ' '/OpenGL renderer/{print $2}' | head -1)
        if [[ -n "$gl_renderer" && "$gl_renderer" != *"llvmpipe"* && "$gl_renderer" != *"softpipe"* ]]; then
            printf "  ${GREEN}✓${RESET} OpenGL renderer: %s\n" "$gl_renderer"
        elif [[ "$gl_renderer" == *"llvmpipe"* || "$gl_renderer" == *"softpipe"* ]]; then
            printf "  ${YELLOW}!${RESET} OpenGL renderer: %s (software — no GPU acceleration)\n" "$gl_renderer"
            ((issues++))
        else
            printf "  ${RED}✗${RESET} OpenGL: failed to query\n"
            ((issues++))
        fi
    else
        printf "  ${YELLOW}!${RESET} glxinfo not available (install mesa-demos)\n"
        ((issues++))
    fi

    # Vulkan
    if cmd_exists vulkaninfo; then
        if vulkaninfo --summary &>/dev/null; then
            local vk_dev
            vk_dev=$(vulkaninfo --summary 2>/dev/null | awk -F'= ' '/deviceName/{print $2}' | head -1)
            printf "  ${GREEN}✓${RESET} Vulkan device: %s\n" "${vk_dev:-detected}"
        else
            printf "  ${RED}✗${RESET} Vulkan: vulkaninfo failed\n"
            ((issues++))
        fi
    else
        printf "  ${YELLOW}!${RESET} vulkaninfo not available (install vulkan-tools)\n"
        ((issues++))
    fi

    # VA-API (hardware video decode)
    if cmd_exists vainfo; then
        if vainfo &>/dev/null; then
            local va_drv
            va_drv=$(vainfo 2>/dev/null | awk -F': ' '/Driver version/{print $2}' | head -1)
            printf "  ${GREEN}✓${RESET} VA-API: %s\n" "${va_drv:-working}"
        else
            printf "  ${YELLOW}!${RESET} VA-API: vainfo returned errors\n"
            ((issues++))
        fi
    else
        printf "  ${DIM}  VA-API: vainfo not installed (optional)${RESET}\n"
    fi

    # NVIDIA-specific checks
    if [[ "$GPU_VENDOR" == "nvidia" ]]; then
        if cmd_exists nvidia-smi; then
            if nvidia-smi &>/dev/null; then
                local gpu_temp gpu_util
                gpu_temp=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader 2>/dev/null || echo "?")
                gpu_util=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader 2>/dev/null || echo "?")
                printf "  ${GREEN}✓${RESET} nvidia-smi: working (temp: %s°C, util: %s)\n" "$gpu_temp" "$gpu_util"
            else
                printf "  ${RED}✗${RESET} nvidia-smi: command failed\n"
                ((issues++))
            fi
        fi
    fi

    # DRM device node
    if [[ -e /dev/dri/card0 ]]; then
        printf "  ${GREEN}✓${RESET} DRM device: /dev/dri/card0 present\n"
    else
        printf "  ${RED}✗${RESET} DRM device: /dev/dri/card0 missing\n"
        ((issues++))
    fi

    # Render node
    if [[ -e /dev/dri/renderD128 ]]; then
        printf "  ${GREEN}✓${RESET} Render node: /dev/dri/renderD128 present\n"
    else
        printf "  ${YELLOW}!${RESET} Render node: /dev/dri/renderD128 missing\n"
        ((issues++))
    fi

    echo ""
    if [[ $issues -eq 0 ]]; then
        msg "All checks passed — driver stack looks healthy."
    else
        warn "${issues} issue(s) found. Run '24hg-driver-mgr detect' for recommendations."
    fi
}

cmd_rollback() {
    require_root
    hdr "Driver Rollback"

    if [[ -f "$STATE_FILE" ]]; then
        msg "Last recorded action:"
        cat "$STATE_FILE" | sed 's/^/  /'
        echo ""
    fi

    msg "Rolling back to previous rpm-ostree deployment..."
    log_action "rollback"
    rpm-ostree rollback 2>&1 | tail -5
    save_state "rollback" "previous-deployment"
    msg "Rollback staged."
    warn "Reboot required: systemctl reboot"
}

cmd_update() {
    require_root
    detect_gpu
    hdr "Updating Drivers"

    case "$GPU_VENDOR" in
        nvidia)
            msg "Updating NVIDIA driver packages..."
            log_action "update nvidia"
            rpm-ostree upgrade --allow-downgrade 2>&1 | tail -10
            # Rebuild kmod if needed
            if rpm -q akmod-nvidia &>/dev/null; then
                msg "Triggering kmod rebuild..."
                akmods --force 2>/dev/null || true
            fi
            save_state "update" "nvidia"
            ;;
        amd|intel)
            msg "Updating Mesa and kernel (drivers are in-tree)..."
            log_action "update mesa"
            rpm-ostree upgrade 2>&1 | tail -10
            save_state "update" "mesa"
            ;;
        *)
            msg "Updating system packages..."
            log_action "update generic"
            rpm-ostree upgrade 2>&1 | tail -10
            save_state "update" "generic"
            ;;
    esac

    msg "Update staged."
    warn "Reboot required to apply: systemctl reboot"
}

# ── Main ────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
${BOLD}24hg-driver-mgr${RESET} v${VERSION} — GPU Driver Manager for 24HG

${BOLD}Usage:${RESET}
  24hg-driver-mgr <command> [args]

${BOLD}Commands:${RESET}
  status              Show current GPU and driver information
  detect              Detect GPU and recommend a driver
  switch <target>     Switch driver (latest, nouveau, or branch number)
  mesa-git <on|off>   Enable/disable bleeding-edge Mesa via COPR
  vulkan              Show Vulkan device capabilities and extensions
  health              Run driver health check
  rollback            Undo last driver change (rpm-ostree rollback)
  update              Update to latest available driver

${BOLD}Examples:${RESET}
  24hg-driver-mgr status
  24hg-driver-mgr switch latest
  24hg-driver-mgr switch nouveau
  24hg-driver-mgr mesa-git enable
  24hg-driver-mgr health

${DIM}Config: ${CONFIG_DIR}${RESET}
EOF
}

main() {
    mkdir -p "$CONFIG_DIR"

    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        status)         cmd_status "$@" ;;
        detect)         cmd_detect "$@" ;;
        switch)         cmd_switch "$@" ;;
        mesa-git)       cmd_mesa_git "$@" ;;
        vulkan)         cmd_vulkan "$@" ;;
        health)         cmd_health "$@" ;;
        rollback)       cmd_rollback "$@" ;;
        update)         cmd_update "$@" ;;
        -v|--version)   echo "24hg-driver-mgr v${VERSION}" ;;
        -h|--help|"")   usage ;;
        *)
            err "Unknown command: $cmd"
            usage
            exit 1
            ;;
    esac
}

main "$@"
