#!/usr/bin/env bash
# 24hg-perf-profiles — Per-game performance profiles for 24HG
# Saves and restores complete system performance settings per game.
# Profiles stored in ~/.config/24hg/perf-profiles/
#
# Profile components:
#   CPU governor, GPU clocks (nvidia/amd), compositor toggle,
#   resolution, refresh rate, gamemode, MangoHud config, env vars
#
# Auto-detection: Monitors /proc for SteamAppId / Heroic game env vars
# to automatically apply and restore profiles on game launch/exit.
set -euo pipefail

PROFILES_DIR="${HOME}/.config/24hg/perf-profiles"
ASSIGNMENTS="${PROFILES_DIR}/.assignments"
SNAPSHOT="${PROFILES_DIR}/.desktop-snapshot"
ACTIVE="${PROFILES_DIR}/.active"
DAEMON_PID="${XDG_RUNTIME_DIR:-/tmp}/24hg-perf-daemon.pid"
MH_DIR="${HOME}/.config/MangoHud"
VERSION="1.0.0"

mkdir -p "$PROFILES_DIR" "$MH_DIR"
touch "$ASSIGNMENTS"

RED='\033[0;31m'; GRN='\033[0;32m'; YEL='\033[1;33m'
CYN='\033[0;36m'; BLD='\033[1m'; RST='\033[0m'
info() { echo -e "${GRN}[24hg-perf]${RST} $*"; }
warn() { echo -e "${YEL}[24hg-perf]${RST} $*"; }
die()  { echo -e "${RED}[24hg-perf]${RST} $*" >&2; exit 1; }

ppath()  { echo "${PROFILES_DIR}/${1}.profile"; }
pexist() { [[ -f "$(ppath "$1")" ]]; }
rfield() { grep -m1 "^${2}=" "$1" 2>/dev/null | cut -d= -f2-; }
vname()  { [[ "$1" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Invalid name '$1'. Use alphanumeric/dash/underscore."; }

# ── GPU detection ────────────────────────────────────────────────────
detect_gpu() {
    if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null; then
        echo nvidia
    elif [[ -d /sys/class/drm/card0/device ]] && grep -qi amd /sys/class/drm/card0/device/vendor 2>/dev/null; then
        echo amd
    elif [[ -d /sys/class/drm/card0/device ]]; then
        echo intel
    else echo unknown; fi
}

# ── Built-in templates ───────────────────────────────────────────────
gen_template() {
    local label="$1" gov="$2" gpow="$3" gclk="$4" comp="$5" res="$6" rr="$7" gm="$8" mhc="$9" env="${10}"
    echo "# 24HG Performance Profile - ${label}"
    echo "cpu_governor=${gov}"; echo "gpu_power=${gpow}"; echo "gpu_clock_offset=${gclk}"
    echo "compositor=${comp}"; echo "resolution=${res}"; echo "refresh_rate=${rr}"
    echo "gamemode=${gm}"; echo "mangohud=on"; echo "mangohud_config=${mhc}"; echo "env_vars=${env}"
}

tpl_competitive() { gen_template Competitive performance high 100 off 1920x1080 highest on \
    "fps,frametime,cpu_temp,gpu_temp" "DXVK_ASYNC=1,RADV_PERFTEST=gpl,__GL_THREADED_OPTIMIZATIONS=1"; }
tpl_quality() { gen_template Quality performance high 0 on native native on \
    "fps,frametime,gpu_temp,cpu_temp,ram,vram" "DXVK_ASYNC=1,ENABLE_VKBASALT=1"; }
tpl_battery() { gen_template "Battery Saver" powersave low -200 on 1280x720 60 off \
    "fps,battery" "DXVK_ASYNC=1"; }
tpl_streaming() { gen_template Streaming performance high 0 off 1920x1080 60 on \
    "fps,frametime,cpu_temp,gpu_temp" "DXVK_ASYNC=1,OBS_USE_EGL=1,__GL_THREADED_OPTIMIZATIONS=1"; }

# ── Snapshot desktop state ───────────────────────────────────────────
snapshot_desktop() {
    {
        echo "cpu_governor=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo unknown)"
        if command -v xrandr &>/dev/null && [[ -n "${DISPLAY:-}" ]]; then
            local line; line=$(xrandr --current 2>/dev/null | grep '\*' | head -1)
            echo "resolution=$(echo "$line" | awk '{print $1}')"
            echo "refresh_rate=$(echo "$line" | awk '{gsub(/[^0-9.]/,"",$2); print $2}')"
        elif command -v wlr-randr &>/dev/null; then
            echo "resolution=$(wlr-randr 2>/dev/null | grep current | head -1 | awk '{print $1}')"
            echo "refresh_rate=$(wlr-randr 2>/dev/null | grep current | head -1 | awk '{print $3}')"
        fi
        command -v qdbus &>/dev/null && echo "compositor=$(qdbus org.kde.KWin /Compositor active 2>/dev/null || echo true)"
        echo "gpu_vendor=$(detect_gpu)"
    } > "$SNAPSHOT"
    info "Desktop state saved."
}

# ── Apply helpers ────────────────────────────────────────────────────
apply_cpu() {
    local gov="$1"; [[ -z "$gov" || "$gov" == "unknown" ]] && return
    if command -v cpupower &>/dev/null; then
        sudo cpupower frequency-set -g "$gov" &>/dev/null && info "CPU governor -> $gov" || warn "Failed to set CPU governor"
    elif [[ -w /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]]; then
        for f in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
            echo "$gov" | sudo tee "$f" &>/dev/null
        done; info "CPU governor -> $gov"
    else warn "Cannot set CPU governor (no cpupower or sysfs access)"; fi
}

apply_gpu() {
    local power="${1:-}" offset="${2:-0}" gpu; gpu=$(detect_gpu)
    case "$gpu" in
        nvidia)
            if command -v nvidia-smi &>/dev/null; then
                case "$power" in
                    high) nvidia-smi -pl "$(nvidia-smi -q -d POWER | grep 'Max Power' | grep -oP '[\d.]+' | head -1)" &>/dev/null 2>&1 || true ;;
                    low)  nvidia-smi -pl "$(nvidia-smi -q -d POWER | grep 'Min Power' | grep -oP '[\d.]+' | head -1)" &>/dev/null 2>&1 || true ;;
                esac
                [[ "$offset" != "0" ]] && command -v nvidia-settings &>/dev/null && \
                    nvidia-settings -a "GPUGraphicsClockOffset[3]=${offset}" &>/dev/null || true
                info "NVIDIA GPU: power=${power:-auto}, clock_offset=${offset}"
            fi ;;
        amd)
            local lvl; case "$power" in high) lvl=high;; low) lvl=low;; *) lvl=auto;; esac
            for c in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
                echo "$lvl" | sudo tee "$c" &>/dev/null 2>&1 || true
            done
            if [[ "$offset" != "0" ]]; then
                for c in /sys/class/drm/card*/device/pp_sclk_od; do
                    echo "$offset" | sudo tee "$c" &>/dev/null 2>&1 || true
                done
            fi
            info "AMD GPU: power=${lvl}, clock_offset=${offset}" ;;
        intel) info "Intel GPU -- no clock adjustments available." ;;
    esac
}

apply_compositor() {
    case "${1:-}" in
        off|false) command -v qdbus &>/dev/null && qdbus org.kde.KWin /Compositor suspend &>/dev/null 2>&1 || true
            info "Compositor suspended." ;;
        on|true) command -v qdbus &>/dev/null && qdbus org.kde.KWin /Compositor resume &>/dev/null 2>&1 || true
            info "Compositor resumed." ;;
    esac
}

apply_resolution() {
    local res="$1" rr="${2:-}"; [[ "$res" == "native" || -z "$res" ]] && return
    if command -v xrandr &>/dev/null && [[ -n "${DISPLAY:-}" ]]; then
        local out; out=$(xrandr --current 2>/dev/null | grep ' connected' | head -1 | awk '{print $1}')
        if [[ -n "$out" ]]; then
            local cmd=(xrandr --output "$out" --mode "$res")
            [[ -n "$rr" && "$rr" != "native" && "$rr" != "highest" ]] && cmd+=(--rate "$rr")
            "${cmd[@]}" &>/dev/null && info "Resolution -> ${res}${rr:+@${rr}Hz}" || warn "Failed to set resolution"
        fi
    elif command -v wlr-randr &>/dev/null; then
        local out; out=$(wlr-randr 2>/dev/null | head -1 | awk '{print $1}')
        [[ -n "$out" ]] && wlr-randr --output "$out" --mode "$res" &>/dev/null \
            && info "Resolution -> ${res}" || warn "Failed to set resolution (Wayland)"
    fi
}

apply_mangohud() {
    local enabled="${1:-}" cfg="${2:-}"
    [[ "$enabled" == "on" || "$enabled" == "true" ]] || return; [[ -z "$cfg" ]] && return
    local cf="${MH_DIR}/MangoHud.conf" bk="${MH_DIR}/MangoHud.conf.24hg-backup"
    [[ -f "$cf" && ! -f "$bk" ]] && cp "$cf" "$bk"
    { echo "# Generated by 24hg-perf-profiles"
      IFS=',' read -ra items <<< "$cfg"; for i in "${items[@]}"; do echo "$i"; done
    } > "$cf"; info "MangoHud config: ${cfg}"
}

apply_env() {
    local vars="${1:-}"; [[ -z "$vars" ]] && return
    { echo "# Generated by 24hg-perf-profiles"
      IFS=',' read -ra p <<< "$vars"; for v in "${p[@]}"; do echo "export ${v}"; done
    } > "${PROFILES_DIR}/.active-env"
    info "Env vars written to .active-env"
}

# ── Core: apply a profile ────────────────────────────────────────────
do_apply() {
    local name="$1"; pexist "$name" || die "Profile '$name' not found."
    local pf; pf=$(ppath "$name")
    info "Applying profile: ${BLD}${name}${RST}"
    [[ ! -f "$ACTIVE" ]] && snapshot_desktop
    apply_cpu "$(rfield "$pf" cpu_governor)"
    apply_gpu "$(rfield "$pf" gpu_power)" "$(rfield "$pf" gpu_clock_offset)"
    apply_compositor "$(rfield "$pf" compositor)"
    apply_resolution "$(rfield "$pf" resolution)" "$(rfield "$pf" refresh_rate)"
    if [[ "$(rfield "$pf" gamemode)" == "on" ]]; then
        command -v gamemoderun &>/dev/null && info "GameMode enabled." || warn "gamemoded not installed."
    fi
    apply_mangohud "$(rfield "$pf" mangohud)" "$(rfield "$pf" mangohud_config)"
    apply_env "$(rfield "$pf" env_vars)"
    echo "$name" > "$ACTIVE"; info "Profile '${name}' applied."
}

# ── Core: restore desktop defaults ───────────────────────────────────
do_restore() {
    [[ -f "$SNAPSHOT" ]] || { warn "No desktop snapshot -- nothing to restore."; return; }
    info "Restoring desktop defaults..."
    apply_cpu "$(rfield "$SNAPSHOT" cpu_governor)"
    apply_compositor "on"
    apply_resolution "$(rfield "$SNAPSHOT" resolution)" "$(rfield "$SNAPSHOT" refresh_rate)"
    apply_gpu "auto" "0"
    local bk="${MH_DIR}/MangoHud.conf.24hg-backup"
    [[ -f "$bk" ]] && { mv "$bk" "${MH_DIR}/MangoHud.conf"; info "MangoHud config restored."; }
    rm -f "$ACTIVE" "${PROFILES_DIR}/.active-env"
    info "Desktop defaults restored."
}

# ── Command: list ────────────────────────────────────────────────────
do_list() {
    echo -e "${BLD}24HG Performance Profiles${RST}"
    echo "----------------------------------------"
    local count=0
    for pf in "$PROFILES_DIR"/*.profile; do
        [[ -f "$pf" ]] || continue
        local nm; nm=$(basename "$pf" .profile); local act=""
        [[ -f "$ACTIVE" && "$(cat "$ACTIVE")" == "$nm" ]] && act=" ${GRN}(active)${RST}"
        echo -e "  ${CYN}${nm}${RST}${act}  -- CPU: $(rfield "$pf" cpu_governor), GPU: $(rfield "$pf" gpu_power)"
        count=$((count + 1))
    done
    [[ $count -eq 0 ]] && echo "  No profiles found. Create one: 24hg-perf-profiles create <name>"
    echo ""
    if [[ -s "$ASSIGNMENTS" ]]; then
        echo -e "${BLD}Game Assignments${RST}"
        echo "----------------------------------------"
        while IFS='=' read -r aid prof; do [[ -z "$aid" || "$aid" == \#* ]] && continue
            echo -e "  AppID ${CYN}${aid}${RST} -> ${prof}"
        done < "$ASSIGNMENTS"; echo ""
    fi
    echo -e "${BLD}Available Templates${RST}: competitive, quality, battery, streaming"
}

# ── Command: show ────────────────────────────────────────────────────
do_show() {
    local name="$1"; pexist "$name" || die "Profile '$name' not found."
    local pf; pf=$(ppath "$name")
    echo -e "${BLD}Profile: ${CYN}${name}${RST}"
    echo "----------------------------------------"
    for f in cpu_governor gpu_power gpu_clock_offset compositor resolution refresh_rate gamemode mangohud mangohud_config env_vars; do
        local v; v=$(rfield "$pf" "$f"); [[ -n "$v" ]] && printf "  ${BLD}%-20s${RST} %s\n" "$f" "$v"
    done
    echo ""; local hg=false
    while IFS='=' read -r aid prof; do [[ -z "$aid" || "$aid" == \#* ]] && continue
        [[ "$prof" == "$name" ]] && { $hg || { echo -e "${BLD}Assigned games:${RST}"; hg=true; }; echo "  AppID $aid"; }
    done < "$ASSIGNMENTS"
}

# ── Command: create ──────────────────────────────────────────────────
do_create() {
    local name="$1"; shift; vname "$name"
    pexist "$name" && die "Profile '$name' already exists. Use 'edit' to modify."
    local tpl=""
    for a in "$@"; do case "$a" in --template=*) tpl="${a#--template=}" ;; esac; done
    local pf; pf=$(ppath "$name")
    if [[ -n "$tpl" ]]; then
        case "$tpl" in
            competitive) tpl_competitive ;; quality) tpl_quality ;;
            battery) tpl_battery ;; streaming) tpl_streaming ;;
            *) die "Unknown template '$tpl'. Available: competitive, quality, battery, streaming" ;;
        esac > "$pf"
        info "Profile '${name}' created from template '${tpl}'."
    else
        echo -e "${BLD}Creating profile: ${CYN}${name}${RST}"
        echo "Press Enter to accept defaults in [brackets]."; echo ""
        local cg gp gc co re rr gm mh mc ev
        read -rp "  CPU governor [performance]: " cg; cg="${cg:-performance}"
        read -rp "  GPU power (high/low/auto) [high]: " gp; gp="${gp:-high}"
        read -rp "  GPU clock offset [0]: " gc; gc="${gc:-0}"
        read -rp "  Compositor (on/off) [off]: " co; co="${co:-off}"
        read -rp "  Resolution [native]: " re; re="${re:-native}"
        read -rp "  Refresh rate [native]: " rr; rr="${rr:-native}"
        read -rp "  GameMode (on/off) [on]: " gm; gm="${gm:-on}"
        read -rp "  MangoHud (on/off) [on]: " mh; mh="${mh:-on}"
        read -rp "  MangoHud config [fps,frametime,cpu_temp,gpu_temp]: " mc; mc="${mc:-fps,frametime,cpu_temp,gpu_temp}"
        read -rp "  Env vars (KEY=VAL,...) []: " ev
        { echo "# 24HG Performance Profile - ${name}"
          echo "cpu_governor=${cg}"; echo "gpu_power=${gp}"; echo "gpu_clock_offset=${gc}"
          echo "compositor=${co}"; echo "resolution=${re}"; echo "refresh_rate=${rr}"
          echo "gamemode=${gm}"; echo "mangohud=${mh}"; echo "mangohud_config=${mc}"; echo "env_vars=${ev}"
        } > "$pf"
        info "Profile '${name}' created."
    fi
}

# ── Command: edit ────────────────────────────────────────────────────
do_edit() {
    local name="$1"; pexist "$name" || die "Profile '$name' not found."
    [[ -t 0 && -t 1 ]] && { "${EDITOR:-nano}" "$(ppath "$name")"; info "Profile '${name}' updated."; } \
        || die "No interactive terminal. Edit manually: $(ppath "$name")"
}

# ── Command: assign ──────────────────────────────────────────────────
do_assign() {
    local appid="$1" name="$2"
    pexist "$name" || die "Profile '$name' not found."
    [[ "$appid" =~ ^[0-9]+$ ]] || die "AppID must be numeric."
    local tmp; tmp=$(mktemp)
    grep -v "^${appid}=" "$ASSIGNMENTS" > "$tmp" 2>/dev/null || true
    echo "${appid}=${name}" >> "$tmp"; mv "$tmp" "$ASSIGNMENTS"
    info "AppID ${appid} -> profile '${name}'"
}

# ── Command: export / import ─────────────────────────────────────────
do_export() {
    local name="$1"; pexist "$name" || die "Profile '$name' not found."
    local out="${name}.24hg-profile"
    { echo "HG24_PROFILE_EXPORT_V1"; echo "name=${name}"; echo "exported=$(date -Iseconds)"
      echo "---"; cat "$(ppath "$name")"; } > "$out"
    info "Exported to ${out}"
}

do_import() {
    local file="$1"; [[ -f "$file" ]] || die "File '$file' not found."
    [[ "$(head -1 "$file")" == "HG24_PROFILE_EXPORT_V1" ]] || die "Invalid profile export file."
    local name; name=$(grep '^name=' "$file" | head -1 | cut -d= -f2-)
    [[ -n "$name" ]] || die "Cannot determine profile name from export."
    vname "$name"
    if pexist "$name"; then
        read -rp "Profile '$name' exists. Overwrite? [y/N]: " ans
        [[ "$ans" =~ ^[Yy] ]] || { info "Import cancelled."; return; }
    fi
    sed -n '/^---$/,$ { /^---$/d; p; }' "$file" > "$(ppath "$name")"
    info "Imported profile '${name}'."
}

# ── Command: daemon (auto-apply on game launch) ──────────────────────
do_daemon() {
    info "Starting game-watch daemon (PID $$)..."
    echo $$ > "$DAEMON_PID"
    trap 'rm -f "$DAEMON_PID"; do_restore; exit 0' INT TERM
    local current=""
    while true; do
        local found=""
        while IFS='=' read -r aid prof; do
            [[ -z "$aid" || "$aid" == \#* ]] && continue
            local running=false
            for ef in /proc/[0-9]*/environ; do
                if grep -qaz "SteamAppId=${aid}" "$ef" 2>/dev/null \
                || grep -qaz "HEROIC_APP_NAME=.*${aid}" "$ef" 2>/dev/null; then
                    running=true; break
                fi
            done
            $running && { found="${aid}:${prof}"; break; }
        done < "$ASSIGNMENTS"

        if [[ -n "$found" && "$found" != "$current" ]]; then
            info "Detected AppID ${found%%:*} -- applying '${found#*:}'"
            do_apply "${found#*:}"; current="$found"
        elif [[ -z "$found" && -n "$current" ]]; then
            info "Game exited -- restoring desktop."
            do_restore; current=""
        fi
        sleep 5
    done
}

# ── Usage ────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
${BLD}24hg-perf-profiles${RST} v${VERSION} -- Per-game performance profiles

${BLD}Usage:${RST}  24hg-perf-profiles <command> [args]

${BLD}Commands:${RST}
  list                          List all profiles and assignments
  show <name>                   Show profile details
  create <name> [--template=T]  Create profile (competitive/quality/battery/streaming)
  edit <name>                   Edit profile in \$EDITOR
  apply <name>                  Manually apply a profile
  assign <appid> <profile>      Assign profile to Steam/Heroic game
  restore                       Restore desktop defaults
  export <name>                 Export profile for sharing
  import <file>                 Import a shared profile
  daemon                        Watch for game launches and auto-apply

${BLD}Templates:${RST}
  competitive   Max FPS: compositor off, high GPU clocks, performance governor
  quality       Visual quality with MangoHud overlay and vkBasalt
  battery       Power saving: low clocks, reduced resolution, powersave governor
  streaming     Balanced for game + OBS: compositor off, 60Hz lock

${BLD}Examples:${RST}
  24hg-perf-profiles create csgo --template=competitive
  24hg-perf-profiles assign 730 csgo
  24hg-perf-profiles apply csgo
  24hg-perf-profiles export csgo        # creates csgo.24hg-profile
  24hg-perf-profiles import csgo.24hg-profile
  24hg-perf-profiles daemon &           # auto-apply on game launch

${BLD}Profile storage:${RST}  ${PROFILES_DIR}/
${BLD}Active env file:${RST}  ${PROFILES_DIR}/.active-env
  Source this file in custom launch scripts for game-specific variables.
EOF
}

# ── Main dispatch ────────────────────────────────────────────────────
main() {
    local cmd="${1:-}"; shift 2>/dev/null || true
    case "$cmd" in
        list)    do_list ;;
        show)    [[ -n "${1:-}" ]] || die "Usage: show <name>"; do_show "$1" ;;
        create)  [[ -n "${1:-}" ]] || die "Usage: create <name> [--template=T]"; do_create "$@" ;;
        edit)    [[ -n "${1:-}" ]] || die "Usage: edit <name>"; do_edit "$1" ;;
        apply)   [[ -n "${1:-}" ]] || die "Usage: apply <name>"; do_apply "$1" ;;
        assign)  [[ -n "${1:-}" && -n "${2:-}" ]] || die "Usage: assign <appid> <profile>"; do_assign "$1" "$2" ;;
        restore) do_restore ;;
        export)  [[ -n "${1:-}" ]] || die "Usage: export <name>"; do_export "$1" ;;
        import)  [[ -n "${1:-}" ]] || die "Usage: import <file>"; do_import "$1" ;;
        daemon)  do_daemon ;;
        -h|--help|help|"") usage ;;
        *) die "Unknown command: $cmd. Run '24hg-perf-profiles --help' for usage." ;;
    esac
}

main "$@"
