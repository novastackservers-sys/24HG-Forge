                                 ("TRUE", "mangohud", "Performance overlay (F12 to toggle)"),
                                 ("TRUE", "gamemode", "Auto-optimize CPU/GPU when gaming"),
                                 ("TRUE", "steam-servers", "Add 24HG servers to Steam favorites"),
                                 ("TRUE", "game-configs", "Deploy optimized game configs (CS, TF2, Rust)"),
                                 ("FALSE", "compositor-off", "Disable desktop compositor during games"),
                             ],
                             ["Enable", "Setting", "Description"])

    prefs = {
        "mangohud": "mangohud" in selected,
        "gamemode": "gamemode" in selected,
        "steam_servers": "steam-servers" in selected,
        "game_configs": "game-configs" in selected,
        "compositor_off": "compositor-off" in selected,
    }
    log(f"Step 4: Gaming prefs — {prefs}")
    return prefs


def step_performance():
    """Choose default performance profile."""
    output = gui_radiolist(5, "Performance Profile",
                           "<big><b>Default Performance Profile</b></big>\n\n"
                           "Switch anytime with: <tt>24hg-performance [mode]</tt>",
                           [
                               ("FALSE", "gaming", "Maximum performance (higher power, fan noise)"),
                               ("TRUE", "balanced", "Smart auto-switching (recommended)"),
                               ("FALSE", "powersave", "Battery life priority (laptops)"),
                           ],
                           ["Select", "Profile", "Description"])
    profile = output or "balanced"
    log(f"Step 5: Performance profile — {profile}")
    return profile


def step_deploy(prefs):
    """Deploy configurations based on preferences."""
    os.makedirs(CONFIG_DIR, exist_ok=True)

    # MangoHud
    if prefs.get("mangohud"):
        env_dir = os.path.expanduser("~/.config/environment.d")
        os.makedirs(env_dir, exist_ok=True)
        with open(os.path.join(env_dir, "24hg-mangohud.conf"), "w") as f:
            f.write("MANGOHUD=1\n")

    # Compositor preference
    if prefs.get("compositor_off"):
        env_dir = os.path.expanduser("~/.config/environment.d")
        os.makedirs(env_dir, exist_ok=True)
        with open(os.path.join(env_dir, "24hg-compositor.conf"), "w") as f:
            f.write("# KWin will suspend compositing for fullscreen games\n")
            f.write("KWIN_EXPLICIT_SYNC=0\n")

    # Steam servers (wait for Steam Flatpak to be installed by first-boot service)
    if prefs.get("steam_servers"):
        for _ in range(18):
            result = subprocess.run(
                ["flatpak", "list", "--app"],
                capture_output=True, text=True, timeout=10
            )
            if "com.valvesoftware.Steam" in result.stdout:
                break
            time.sleep(10)
        subprocess.run(["/usr/lib/24hg/configure-steam-servers.sh"],
                       capture_output=True, timeout=60)

    # Game configs
    if prefs.get("game_configs") and shutil.which("bash"):
        subprocess.run(["/usr/lib/24hg/24hg-game-configs.sh"],
                       capture_output=True, timeout=30)

    log("Step 6: Deploy — configs written")


# ---------------------------------------------------------------------------
# New Steps 7-15
# ---------------------------------------------------------------------------

def step_hw_optimizer():
    """Step 7: Hardware Optimizer — scan and apply gaming tuning."""
    gui_info(7, "Hardware Optimizer",
             "<big><b>Let's tune your system for gaming</b></big>\n\n"
             "24HG will scan your hardware and suggest optimizations\n"
             "for CPU scheduling, GPU power, memory, and I/O.\n\n"
             "<i>This takes a few seconds.</i>")

    # Run scan
    rc, scan_output = gui_progress_pulse(
        7, "Hardware Optimizer", "Scanning hardware...",
        ["/usr/bin/24hg-hw-optimizer", "scan"], timeout=30)

    if not scan_output:
        scan_output = "Scan complete — no issues detected."

    # Show results and ask to apply
    accepted = gui_question(7, "Hardware Optimizer — Results",
                            f"<big><b>Scan Results</b></big>\n\n"
                            f"<tt>{scan_output[:800]}</tt>\n\n"
                            "Apply gaming optimizations automatically?",
                            ok_label="Apply Optimizations", cancel_label="Skip")

    tune_output = ""
    if accepted:
        rc2, tune_output = gui_progress_pulse(
            7, "Hardware Optimizer", "Applying optimizations...",
            ["/usr/bin/24hg-hw-optimizer", "tune", "--auto"], timeout=60)
        if not tune_output:
            tune_output = "Optimizations applied successfully."
        gui_info(7, "Hardware Optimizer — Done",
                 f"<big><b>Optimizations Applied</b></big>\n\n"
                 f"<tt>{tune_output[:800]}</tt>")
        log(f"Step 7: HW Optimizer — applied: {tune_output[:200]}")
    else:
        log("Step 7: HW Optimizer — skipped")

    return {"scanned": True, "applied": accepted, "summary": tune_output or scan_output}


def step_rig_benchmark():
    """Step 8: Rig Benchmark — quick score and optional leaderboard submit."""
    accepted = gui_question(8, "Rig Benchmark",
                            "<big><b>Let's see how your rig scores</b></big>\n\n"
                            "Run a quick benchmark to test CPU, GPU, and memory\n"
                            "performance. Results are scored on the 24HG Scale.\n\n"
                            "<i>Takes about 30 seconds.</i>",
                            ok_label="Run Benchmark", cancel_label="Skip")

    score = None
    if accepted:
        rc, output = gui_progress_pulse(
            8, "Rig Benchmark", "Benchmarking... please wait (~30s)",
            ["/usr/bin/24hg-rig-score", "quick"], timeout=90)

        # Try to parse score from output
        score_str = output.split("\n")[-1] if output else "N/A"
        score = score_str

        submit = gui_question(8, "Rig Benchmark — Results",
                              f"<big><b>Benchmark Complete</b></big>\n\n"
                              f"<b>Your Rig Score:</b> <big>{score_str}</big>\n\n"
                              "Submit to the 24HG leaderboard?\n"
                              "Your score will appear on hub.24hgaming.com/benchmarks.",
                              ok_label="Submit Score", cancel_label="Keep Private")

        if submit:
            run_cmd(["/usr/bin/24hg-rig-score", "submit"])
            log(f"Step 8: Benchmark — score={score_str}, submitted")
        else:
            log(f"Step 8: Benchmark — score={score_str}, not submitted")
    else:
        log("Step 8: Benchmark — skipped")

    return score


def step_virtual_lan():
    """Step 9: Virtual LAN — join the 24HG gaming network."""
    accepted = gui_question(9, "Virtual LAN",
                            "<big><b>Connect to the 24HG Gaming Network</b></big>\n\n"
                            "Join 24HG Virtual LAN to discover other gamers worldwide.\n\n"
                            "  <b>Discover</b> other 24HG users on your virtual network\n"
                            "  <b>Host</b> and join LAN games across the internet\n"
                            "  <b>Low overhead</b> — only discovery traffic goes through\n"
                            "     the network; game traffic goes direct (peer-to-peer)\n\n"
                            "<i>You can disconnect anytime with: 24hg-vpn leave</i>",
                            ok_label="Connect to 24HG VPN", cancel_label="Skip")

    auto_connect = False
    if accepted:
        rc, output = gui_progress_pulse(
            9, "Virtual LAN", "Connecting to 24HG Virtual LAN...",
            ["/usr/bin/24hg-vpn", "join"], timeout=30)

        auto_connect = gui_question(
            9, "Virtual LAN — Connected",
            "<big><b>Connected!</b></big>\n\n"
            f"<tt>{output[:400] if output else 'Successfully joined 24HG Virtual LAN.'}</tt>\n\n"
            "Auto-connect on login?\n"
            "<i>Recommended — uses minimal resources when idle.</i>",
            ok_label="Auto-connect on Login", cancel_label="Manual Only")

        if auto_connect:
            autostart_dir = os.path.expanduser("~/.config/autostart")
            os.makedirs(autostart_dir, exist_ok=True)
            with open(os.path.join(autostart_dir, "24hg-vpn.desktop"), "w") as f:
                f.write("[Desktop Entry]\n"
                        "Type=Application\n"
                        "Name=24HG Virtual LAN\n"
                        "Exec=/usr/bin/24hg-vpn join\n"
                        "X-GNOME-Autostart-enabled=true\n"
                        "Hidden=false\n"
                        "Comment=Connect to 24HG Virtual LAN on login\n")
            log("Step 9: Virtual LAN — connected, auto-connect enabled")
        else:
            log("Step 9: Virtual LAN — connected, manual only")
    else:
        log("Step 9: Virtual LAN — skipped")

    return {"connected": accepted, "auto_connect": auto_connect}


def step_cloud_saves():
    """Step 10: Cloud Saves — scan for games and enable sync."""
    gui_info(10, "Cloud Saves",
             "<big><b>Never lose your game saves</b></big>\n\n"
             "24HG Cloud Saves backs up your save files to\n"
             "your 24HG account automatically.\n\n"
             "<i>Scanning for installed games...</i>")

    rc, scan_output = gui_progress_pulse(
        10, "Cloud Saves", "Scanning for installed games...",
        ["/usr/bin/24hg-cloud-saves", "scan"], timeout=30)

    # Parse game list from output (one game per line expected)
    games = [g.strip() for g in scan_output.split("\n") if g.strip()] if scan_output else []

    synced_games = []
    if games:
        # Build checklist rows
        rows = [("TRUE", game, "Sync saves") for game in games]
        selected = gui_checklist(
            10, "Cloud Saves — Games Found",
            f"<big><b>{len(games)} games detected</b></big>\n\n"
            "Select which games to sync:",
            rows, ["Sync", "Game", "Action"])

        synced_games = selected

        if synced_games:
            # Enable sync for selected games
            for game in synced_games:
                run_cmd(["/usr/bin/24hg-cloud-saves", "enable", game])

            # Enable auto-sync daemon
            autostart_dir = os.path.expanduser("~/.config/autostart")
            os.makedirs(autostart_dir, exist_ok=True)
            with open(os.path.join(autostart_dir, "24hg-cloud-saves.desktop"), "w") as f:
                f.write("[Desktop Entry]\n"
                        "Type=Application\n"
                        "Name=24HG Cloud Saves\n"
                        "Exec=/usr/bin/24hg-cloud-saves daemon\n"
                        "X-GNOME-Autostart-enabled=true\n"
                        "Hidden=false\n"
                        "Comment=Auto-sync game saves to 24HG cloud\n")

            gui_info(10, "Cloud Saves — Enabled",
                     f"<big><b>Cloud Saves Active</b></big>\n\n"
                     f"Syncing <b>{len(synced_games)}</b> game(s).\n\n"
                     "Saves will sync automatically in the background.\n"
                     "Manage anytime with: <tt>24hg-cloud-saves status</tt>")
            log(f"Step 10: Cloud Saves — enabled for {synced_games}")
        else:
            log("Step 10: Cloud Saves — no games selected")
    else:
        gui_info(10, "Cloud Saves",
                 "<big><b>No games detected yet</b></big>\n\n"
                 "No installed games were found. Cloud Saves will\n"
                 "auto-detect new games as you install them.\n\n"
                 "Run manually anytime: <tt>24hg-cloud-saves scan</tt>")
        log("Step 10: Cloud Saves — no games found")

    return synced_games


def step_radio_station():
