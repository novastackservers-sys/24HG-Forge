#!/usr/bin/env python3
"""
24HG First-Boot Wizard — Full GTK4 setup experience
Steps:
  1.  Welcome + language
  2.  GPU detection & driver status
  3.  24HG account (open hub or skip)
  4.  Gaming preferences (MangoHud, GameMode, default mode)
  5.  Performance profile selection
  6.  Game config deployment
  7.  Hardware Optimizer
  8.  Rig Benchmark
  9.  Virtual LAN
  10. Cloud Saves
  11. Radio Station
  12. Game Clip Setup
  13. Overlay & Notifications
  14. Invite Friends
  15. Summary & launch
"""

import subprocess
import os
import sys
import json
import shutil
import time
import random
import string
import datetime
import logging

MARKER = os.path.expanduser("~/.config/24hg/.wizard-done")
CONFIG_DIR = os.path.expanduser("~/.config/24hg")
LOG_FILE = os.path.expanduser("~/.config/24hg/first-boot.log")
HUB_URL = "https://hub.24hgaming.com"

TOTAL_STEPS = 15
USE_ZENITY = True  # set False at runtime if zenity/DISPLAY unavailable


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def setup_logging():
    os.makedirs(CONFIG_DIR, exist_ok=True)
    logging.basicConfig(
        filename=LOG_FILE,
        level=logging.INFO,
        format="%(asctime)s  %(levelname)-8s  %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )
    logging.info("=== First-Boot Wizard started ===")


def log(msg):
    logging.info(msg)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def check_already_done():
    if os.path.exists(MARKER):
        sys.exit(0)


def run_cmd(cmd, timeout=10):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip()
    except Exception:
        return ""


def detect_gpu():
    gpus = []
    output = run_cmd(["lspci", "-nn"])
    for line in output.split("\n"):
        if any(x in line for x in ["VGA", "3D", "Display"]):
            vendor = "Unknown"
            if "NVIDIA" in line.upper():
                vendor = "NVIDIA"
            elif "AMD" in line.upper() or "ATI" in line.upper():
                vendor = "AMD"
            elif "INTEL" in line.upper():
                vendor = "Intel"
            gpus.append({"vendor": vendor, "info": line.strip()})
    return gpus or [{"vendor": "Unknown", "info": "Could not detect GPU"}]


def detect_vulkan():
    output = run_cmd(["vulkaninfo", "--summary"], timeout=5)
    if "deviceName" in output:
        for line in output.split("\n"):
            if "deviceName" in line:
                return line.split("=")[-1].strip()
    return "Not detected"


def check_steam_installed():
    return os.path.exists(os.path.expanduser(
        "~/.var/app/com.valvesoftware.Steam/.local/share/Steam"
    ))


def generate_invite_code():
    """Generate an 8-char alphanumeric invite code."""
    chars = string.ascii_uppercase + string.digits
    return "".join(random.choices(chars, k=8))


def progress_title(step_num, title):
    """Return a title string with step progress indicator."""
    return f"Step {step_num} of {TOTAL_STEPS} — {title}"


# ---------------------------------------------------------------------------
# GUI abstraction: zenity primary, terminal fallback
# ---------------------------------------------------------------------------

def zenity(args):
    """Run zenity with given args, return (returncode, stdout)."""
    try:
        r = subprocess.run(
            ["zenity"] + args,
            capture_output=True, text=True, timeout=300
        )
        return r.returncode, r.stdout.strip()
    except Exception as e:
        return 1, str(e)


def tui_info(title, text):
    """Terminal fallback for info dialogs."""
    print(f"\n{'=' * 60}")
    print(f"  {title}")
    print(f"{'=' * 60}")
    print(text.replace("<b>", "").replace("</b>", "")
              .replace("<big>", "").replace("</big>", "")
              .replace("<i>", "").replace("</i>", "")
              .replace("<tt>", "").replace("</tt>", "")
              .replace("<span foreground='#50c878'>", "")
              .replace("<span foreground='#ffcc50'>", "")
              .replace("</span>", ""))
    input("\nPress Enter to continue...")


def tui_question(title, text):
    """Terminal fallback for yes/no questions. Returns True for yes."""
    print(f"\n{'=' * 60}")
    print(f"  {title}")
    print(f"{'=' * 60}")
    print(text.replace("<b>", "").replace("</b>", "")
              .replace("<big>", "").replace("</big>", "")
              .replace("<i>", "").replace("</i>", "")
              .replace("<tt>", "").replace("</tt>", "")
              .replace("<span foreground='#50c878'>", "")
              .replace("<span foreground='#ffcc50'>", "")
              .replace("</span>", ""))
    answer = input("\n[Y]es / [N]o / [S]kip: ").strip().lower()
    return answer in ("y", "yes")


def tui_list(title, text, items, multi=False):
    """Terminal fallback for list selection. Returns list of selected items."""
    print(f"\n{'=' * 60}")
    print(f"  {title}")
    print(f"{'=' * 60}")
    print(text.replace("<b>", "").replace("</b>", "")
              .replace("<big>", "").replace("</big>", ""))
    for i, item in enumerate(items, 1):
        print(f"  {i}. {item}")
    if multi:
        sel = input("\nEnter numbers separated by commas (or Enter to skip): ").strip()
        if not sel:
            return []
        try:
            indices = [int(x.strip()) - 1 for x in sel.split(",")]
            return [items[i] for i in indices if 0 <= i < len(items)]
        except (ValueError, IndexError):
            return []
    else:
        sel = input("\nEnter number (or Enter to skip): ").strip()
        if not sel:
            return []
        try:
            idx = int(sel) - 1
            return [items[idx]] if 0 <= idx < len(items) else []
        except (ValueError, IndexError):
            return []


def gui_info(step_num, title, text, ok_label="Next"):
    """Show info dialog with step progress."""
    full_title = progress_title(step_num, title)
    if USE_ZENITY:
        zenity([
            "--info", f"--title={full_title}",
            "--width=550", "--height=380",
            f"--ok-label={ok_label}",
            f"--text={text}"
        ])
    else:
        tui_info(full_title, text)


def gui_question(step_num, title, text, ok_label="Yes", cancel_label="Skip"):
    """Show question dialog. Returns True if user accepted."""
    full_title = progress_title(step_num, title)
    if USE_ZENITY:
        rc, _ = zenity([
            "--question", f"--title={full_title}",
            "--width=500", "--height=380",
            f"--ok-label={ok_label}", f"--cancel-label={cancel_label}",
            f"--text={text}"
        ])
        return rc == 0
    else:
        return tui_question(full_title, text)


def gui_checklist(step_num, title, text, rows, col_headers):
    """Show checklist dialog. rows is list of tuples. Returns list of selected values."""
    full_title = progress_title(step_num, title)
    if USE_ZENITY:
        args = [
            "--list", f"--title={full_title}",
            "--width=550", "--height=400",
            "--checklist",
            f"--text={text}",
        ]
        for h in col_headers:
            args.extend([f"--column={h}"])
        for row in rows:
            args.extend(list(row))
        rc, output = zenity(args)
        return output.split("|") if output else []
    else:
        items = [f"{row[2]} — {row[1]}" if len(row) > 2 else row[1] for row in rows]
        return tui_list(full_title, text, items, multi=True)


def gui_radiolist(step_num, title, text, rows, col_headers):
    """Show radiolist dialog. Returns selected value string."""
    full_title = progress_title(step_num, title)
    if USE_ZENITY:
        args = [
            "--list", f"--title={full_title}",
            "--width=500", "--height=350",
            "--radiolist",
            f"--text={text}",
        ]
        for h in col_headers:
            args.extend([f"--column={h}"])
        for row in rows:
            args.extend(list(row))
        rc, output = zenity(args)
        return output or ""
    else:
        items = [f"{row[1]} — {row[2]}" for row in rows]
        sel = tui_list(full_title, text, items)
        if sel:
            return sel[0].split(" — ")[0].strip()
        return ""


def gui_progress_pulse(step_num, title, text, cmd, timeout=120):
    """Run a command with a pulsating progress bar. Returns (returncode, stdout)."""
    full_title = progress_title(step_num, title)
    if USE_ZENITY:
        proc = subprocess.Popen(
            cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
        )
        zprog = subprocess.Popen(
            ["zenity", "--progress", "--pulsate", "--auto-close",
             "--no-cancel", f"--title={full_title}", f"--text={text}",
             "--width=400"],
            stdin=subprocess.PIPE, text=True
        )
        try:
            stdout, _ = proc.communicate(timeout=timeout)
        except subprocess.TimeoutExpired:
            proc.kill()
            stdout = ""
        zprog.stdin.close()
        zprog.wait()
        return proc.returncode or 0, stdout.strip()
    else:
        print(f"\n  {text}")
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
            return r.returncode, r.stdout.strip()
        except Exception:
            return 1, ""


# ---------------------------------------------------------------------------
# Original Steps 1-6
