                             stations,
                             ["Select", "Station", "Description"])

    if selected:
        # Save preference
        os.makedirs(CONFIG_DIR, exist_ok=True)
        radio_conf = os.path.join(CONFIG_DIR, "radio.json")
        with open(radio_conf, "w") as f:
            json.dump({"default_station": selected, "autoplay": False}, f, indent=2)

        # Preview for a few seconds
        try:
            preview = subprocess.Popen(
                ["/usr/bin/24hg-radio", "play", selected],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
            gui_info(11, "Radio Station",
                     f"<big><b>Station set: {selected}</b></big>\n\n"
                     "Previewing... you should hear music now.\n\n"
                     "Controls:\n"
                     "  <tt>24hg-radio</tt>        — Toggle play/pause\n"
                     "  <tt>24hg-radio next</tt>    — Skip track\n"
                     "  <tt>24hg-radio list</tt>    — All stations")
            # Stop preview
            preview.terminate()
            preview.wait(timeout=5)
        except Exception:
            gui_info(11, "Radio Station",
                     f"<big><b>Station set: {selected}</b></big>\n\n"
                     "Your default station is saved.\n"
                     "Start it anytime with: <tt>24hg-radio</tt>")
        log(f"Step 11: Radio — selected {selected}")
    else:
        log("Step 11: Radio — skipped")

    return selected


def step_game_clip():
    """Step 12: Game Clip Setup — replay buffer and capture config."""
    gui_info(12, "Game Clip Setup",
             "<big><b>Capture epic moments</b></big>\n\n"
             "24HG Clip records the last 30 seconds of gameplay.\n"
             "Press <b>F9</b> to save a clip anytime.\n\n"
             "Clips are saved to <tt>~/Videos/Clips/</tt>\n"
             "and can be shared to the 24HG Hub.")

    enable_buffer = gui_question(
        12, "Game Clip Setup",
        "<big><b>Replay Buffer</b></big>\n\n"
        "Enable the replay buffer on login?\n\n"
        "This runs in the background with minimal overhead\n"
        "and lets you press F9 to save the last 30 seconds.\n\n"
        "<i>Uses about 200-400 MB RAM depending on quality.</i>",
        ok_label="Enable Replay Buffer", cancel_label="Skip")

    quality = "medium"
    if enable_buffer:
        # Pick quality based on hardware or user preference
        quality = gui_radiolist(
            12, "Game Clip — Quality",
            "<big><b>Clip Quality</b></big>\n\n"
            "Choose recording quality:",
            [
                ("FALSE", "high", "1080p 60fps — Best quality, uses more resources"),
                ("TRUE", "medium", "1080p 30fps — Good balance (recommended)"),
                ("FALSE", "low", "720p 30fps — Minimal resource usage"),
            ],
            ["Select", "Quality", "Description"])

        quality = quality or "medium"

        # Set up autostart
        autostart_dir = os.path.expanduser("~/.config/autostart")
        os.makedirs(autostart_dir, exist_ok=True)
        with open(os.path.join(autostart_dir, "24hg-clip.desktop"), "w") as f:
            f.write("[Desktop Entry]\n"
                    "Type=Application\n"
                    "Name=24HG Clip Replay Buffer\n"
                    f"Exec=/usr/bin/24hg-clip --daemon --quality {quality}\n"
                    "X-GNOME-Autostart-enabled=true\n"
                    "Hidden=false\n"
                    "Comment=Replay buffer for game clip capture (F9)\n")

        # Save clip config
        clip_conf = os.path.join(CONFIG_DIR, "clip.json")
        with open(clip_conf, "w") as f:
            json.dump({
                "enabled": True,
                "quality": quality,
                "keybind": "F9",
                "buffer_seconds": 30,
                "output_dir": "~/Videos/Clips/"
            }, f, indent=2)

        # Create clips directory
        clips_dir = os.path.expanduser("~/Videos/Clips")
        os.makedirs(clips_dir, exist_ok=True)

        log(f"Step 12: Game Clip — enabled, quality={quality}")
    else:
        log("Step 12: Game Clip — skipped")

    return {"enabled": enable_buffer, "quality": quality}


def step_overlay_notifications():
    """Step 13: Overlay & Notifications — in-game HUD and achievement alerts."""
    overlay_enabled = gui_question(
        13, "Overlay & Notifications",
        "<big><b>Stay connected while gaming</b></big>\n\n"
        "The 24HG Overlay shows friend activity, messages,\n"
        "and server info as a subtle in-game HUD.\n\n"
        "  <b>Friend activity</b> — see who comes online\n"
        "  <b>Messages</b> — Hub chat notifications\n"
        "  <b>Server status</b> — player counts at a glance\n\n"
        "Enable the in-game overlay?",
        ok_label="Enable Overlay", cancel_label="Skip")

    if overlay_enabled:
        autostart_dir = os.path.expanduser("~/.config/autostart")
        os.makedirs(autostart_dir, exist_ok=True)
        with open(os.path.join(autostart_dir, "24hg-overlay.desktop"), "w") as f:
            f.write("[Desktop Entry]\n"
                    "Type=Application\n"
                    "Name=24HG Overlay\n"
                    "Exec=/usr/bin/24hg-overlay\n"
                    "X-GNOME-Autostart-enabled=true\n"
                    "Hidden=false\n"
                    "Comment=In-game overlay for friend activity and notifications\n")
        log("Step 13: Overlay — enabled")
    else:
        log("Step 13: Overlay — skipped")

    # Achievement notifications — already enabled via systemd, just confirm
    gui_info(13, "Achievement Notifications",
             "<big><b>Achievement Notifications</b></big>\n\n"
             "Achievement pop-ups are <b>enabled by default</b>.\n\n"
             "When you unlock achievements in supported games,\n"
             "you'll see a notification on screen.\n\n"
             "Disable anytime in Settings or with:\n"
             "<tt>systemctl --user disable 24hg-achievements</tt>")

    log("Step 13: Achievements — confirmed enabled")
    return {"overlay": overlay_enabled, "achievements": True}


def step_invite_friends():
    """Step 14: Invite Friends — generate code, offer USB creation."""
    invite_code = generate_invite_code()

    # Check for USB drives
    usb_detected = False
    try:
        lsblk = run_cmd(["lsblk", "-J", "-o", "NAME,TRAN,SIZE,MOUNTPOINT"])
        if lsblk:
            block_info = json.loads(lsblk)
            for dev in block_info.get("blockdevices", []):
                if dev.get("tran") == "usb":
                    usb_detected = True
                    break
    except Exception:
        pass

    invite_text = (
        f"<big><b>Spread the word</b></big>\n\n"
        f"Your invite code:\n\n"
        f"  <big><b><tt>{invite_code}</tt></b></big>\n\n"
        f"Share this code with friends! When they sign up\n"
        f"with your code, you both earn:\n\n"
        f"  <b>+500</b> Hub coins\n"
        f"  <b>+1 week</b> VIP status on all game servers\n"
        f"  <b>Badge</b> — Recruiter badge on your profile\n\n"
    )

    if usb_detected:
        create_usb = gui_question(
            14, "Invite Friends",
            invite_text +
            "<span foreground='#50c878'><b>USB drive detected!</b></span>\n"
            "Want to create a bootable 24HG USB for a friend?",
            ok_label="Create Bootable USB", cancel_label="Just the Code")

        if create_usb:
            gui_progress_pulse(
                14, "Invite Friends", "Creating bootable USB... This may take a few minutes.",
                ["/usr/bin/24hg-usb-creator", "--invite-code", invite_code],
                timeout=600)
            gui_info(14, "Invite Friends",
                     "<big><b>USB Created!</b></big>\n\n"
                     f"The USB contains 24HG with your invite code\n"
                     f"<b>{invite_code}</b> pre-loaded.\n\n"
                     "Hand it to a friend and they're ready to go!")
            log(f"Step 14: Invite — code={invite_code}, USB created")
        else:
            log(f"Step 14: Invite — code={invite_code}, no USB")
    else:
        gui_info(14, "Invite Friends", invite_text +
                 "<i>Tip: Plug in a USB drive and run\n"
                 "<tt>24hg-usb-creator</tt> to make a bootable\n"
                 "24HG USB for a friend.</i>")
        log(f"Step 14: Invite — code={invite_code}, no USB detected")

    # Save invite code
    invite_file = os.path.join(CONFIG_DIR, "invite.json")
    with open(invite_file, "w") as f:
        json.dump({"code": invite_code, "created": str(datetime.datetime.now())}, f, indent=2)

    return invite_code


def step_summary(gpus, prefs, profile, hw_info, benchmark_score, lan_info,
                 cloud_games, radio_station, clip_info, overlay_info, invite_code):
    """Step 15: Final summary with quick reference card."""
    gpu_names = ", ".join(g["vendor"] for g in gpus)
    pref_list = [k for k, v in prefs.items() if v]
    pref_text = ", ".join(p.replace("_", " ").title() for p in pref_list) or "None"
    steam_status = "Installed" if check_steam_installed() else "Installing in background..."

    # Build feature summary
    features = []
    if hw_info and hw_info.get("applied"):
        features.append("Hardware optimized")
    if benchmark_score:
        features.append(f"Rig score: {benchmark_score}")
    if lan_info and lan_info.get("connected"):
        features.append("Virtual LAN connected" + (" (auto)" if lan_info.get("auto_connect") else ""))
    if cloud_games:
        features.append(f"Cloud saves: {len(cloud_games)} game(s)")
    if radio_station:
        features.append(f"Radio: {radio_station}")
    if clip_info and clip_info.get("enabled"):
        features.append(f"Replay buffer: {clip_info['quality']}")
    if overlay_info and overlay_info.get("overlay"):
        features.append("In-game overlay on")

    feature_text = "\n".join(f"  {f}" for f in features) if features else "  (defaults)"

    gui_info(15, "You're All Set!",
             "<big><b>Welcome to 24HG!</b></big>\n\n"
             f"<b>GPU:</b>         {gpu_names}\n"
             f"<b>Profile:</b>     {profile.title()}\n"
             f"<b>Settings:</b>    {pref_text}\n"
             f"<b>Steam:</b>       {steam_status}\n\n"
             f"<b>Configured:</b>\n{feature_text}\n\n"
             "<b>Quick Reference:</b>\n"
             "  <tt>F9</tt>               — Save game clip\n"
             "  <tt>F12</tt>              — Toggle performance overlay\n"
             "  <tt>24hg-radio</tt>       — Music controls\n"
             "  <tt>24hg-clip</tt>        — Clip manager\n"
             "  <tt>24hg-vpn</tt>         — Virtual LAN\n"
             "  <tt>24hg-launch</tt>      — Game launcher\n"
             "  <tt>24hg-cloud-saves</tt> — Save sync status\n"
             "  <tt>24hg-performance</tt> — Power profile\n"
             "  <tt>24hg-rescue</tt>      — System recovery\n"
             "  <tt>24hg-diag</tt>        — Diagnostics\n"
             "  <tt>Super</tt>            — App launcher\n\n"
             f"<b>Invite code:</b> <tt>{invite_code or 'N/A'}</tt>\n\n"
             "<i>Welcome to 24 Hour Gaming!</i>",
             ok_label="Start Gaming!")
    log("Step 15: Summary — wizard complete")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    check_already_done()
    setup_logging()

    global USE_ZENITY

    # Check zenity + DISPLAY availability
    if not shutil.which("zenity") or not os.environ.get("DISPLAY", os.environ.get("WAYLAND_DISPLAY")):
        USE_ZENITY = False
        log("zenity or DISPLAY not available — using terminal fallback")

    # If neither GUI nor TTY, just mark done and exit
    if not USE_ZENITY and not sys.stdin.isatty():
        os.makedirs(os.path.dirname(MARKER), exist_ok=True)
        with open(MARKER, "w") as f:
            f.write("done\n")
        log("No display and no TTY — marking done and exiting")
        sys.exit(0)

    # ---- Create ~/.24hg directories for Dolphin sidebar shortcuts ----
    hg24_home = os.path.expanduser("~/.24hg")
    for subdir in ("mods", "saves", "profiles", "backups"):
        os.makedirs(os.path.join(hg24_home, subdir), exist_ok=True)
    log("Created ~/.24hg directories (mods, saves, profiles, backups)")

    # ---- Run wizard steps ----

    # 1. Welcome
    step_welcome()

    # 2. GPU detection
    gpus = step_gpu()

    # 3. 24HG account
    step_account()

    # 4. Gaming preferences
    prefs = step_gaming_prefs()

    # 5. Performance profile
    profile = step_performance()

    # 6. Deploy configs
    step_deploy(prefs)

    # Apply performance profile
    try:
        subprocess.run(["/usr/bin/24hg-performance", profile],
                       capture_output=True, timeout=10)
    except Exception:
        pass

    # 7. Hardware Optimizer
    hw_info = step_hw_optimizer()

    # 8. Rig Benchmark
    benchmark_score = step_rig_benchmark()

    # 9. Virtual LAN
    lan_info = step_virtual_lan()

    # 10. Cloud Saves
    cloud_games = step_cloud_saves()

    # 11. Radio Station
    radio_station = step_radio_station()

    # 12. Game Clip Setup
    clip_info = step_game_clip()

    # 13. Overlay & Notifications
    overlay_info = step_overlay_notifications()

    # 14. Invite Friends
    invite_code = step_invite_friends()

    # 15. Summary
    step_summary(gpus, prefs, profile, hw_info, benchmark_score,
                 lan_info, cloud_games, radio_station, clip_info,
                 overlay_info, invite_code)

    # Save full config
    os.makedirs(CONFIG_DIR, exist_ok=True)
    config = {
        "wizard_completed": True,
        "completed_at": str(datetime.datetime.now()),
        "gpus": gpus,
        "preferences": prefs,
        "performance_profile": profile,
        "hw_optimizer": hw_info,
        "benchmark_score": benchmark_score,
        "virtual_lan": lan_info,
        "cloud_saves": cloud_games,
        "radio_station": radio_station,
        "clip_setup": clip_info,
        "overlay": overlay_info,
        "invite_code": invite_code,
    }
    with open(os.path.join(CONFIG_DIR, "config.json"), "w") as f:
        json.dump(config, f, indent=2)

    # Mark done
    os.makedirs(os.path.dirname(MARKER), exist_ok=True)
    with open(MARKER, "w") as f:
        f.write("done\n")

    log("Wizard completed successfully. Marker written.")


if __name__ == "__main__":
    main()
