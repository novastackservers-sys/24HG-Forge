def step_welcome():
    gui_info(1, "Welcome to 24HG",
             "<big><b>Welcome to 24HG</b></big>\n\n"
             "24 Hour Gaming's custom Linux distribution.\n\n"
             "This wizard will:\n\n"
             "  <b>1.</b>  Detect your hardware\n"
             "  <b>2.</b>  Connect you to the 24HG community\n"
             "  <b>3.</b>  Configure your gaming experience\n"
             "  <b>4.</b>  Optimize performance settings\n"
             "  <b>5.</b>  Set up cloud saves, replay, radio & more\n"
             "  <b>6.</b>  Benchmark your rig\n\n"
             f"<i>Takes about 3-5 minutes. ({TOTAL_STEPS} steps)</i>",
             ok_label="Let's Go!")
    log("Step 1: Welcome — shown")


def step_gpu():
    gpus = detect_gpu()
    vulkan = detect_vulkan()

    gpu_lines = []
    drivers_ok = True
    for g in gpus:
        status = "Ready"
        if g["vendor"] == "NVIDIA":
            nv = run_cmd(["nvidia-smi", "--query-gpu=driver_version", "--format=csv,noheader"])
            if nv:
                status = f"Driver {nv}"
            else:
                status = "Driver not detected — may need reboot"
                drivers_ok = False
        elif g["vendor"] == "AMD":
            status = "Mesa (open-source) — Best Linux support"
        elif g["vendor"] == "Intel":
            status = "Mesa (open-source) — Supported"
        gpu_lines.append(f"  <b>{g['vendor']}</b>: {status}")

    gpu_text = "\n".join(gpu_lines)

    gui_info(2, "Hardware Detection",
             "<big><b>GPU Detection</b></big>\n\n"
             f"{gpu_text}\n\n"
             f"Vulkan: <b>{vulkan}</b>\n\n"
             + ("<span foreground='#50c878'>All drivers are ready!</span>" if drivers_ok else
                "<span foreground='#ffcc50'>A reboot may be needed for full driver support.</span>"))

    log(f"Step 2: GPU — {[g['vendor'] for g in gpus]}, Vulkan: {vulkan}, drivers_ok={drivers_ok}")
    return gpus


def step_account():
    accepted = gui_question(3, "24HG Account",
                            "<big><b>Join the Community</b></big>\n\n"
                            "The 24HG Hub gives you access to:\n\n"
                            "  <b>88+</b> game servers across 30+ titles\n"
                            "  <b>Chat</b> and forums\n"
                            "  <b>Tournaments</b> and leaderboards\n"
                            "  <b>Voice chat</b> (LiveKit)\n"
                            "  <b>Economy</b>, clans, and factions\n\n"
                            "Login to get desktop notifications for messages,\n"
                            "friend activity, and tournament alerts.\n\n"
                            "Create an account or log in to get the full experience.",
                            ok_label="Login to Hub", cancel_label="Skip for Now")
    if accepted:
        try:
            subprocess.run(["/usr/bin/24hg-hub-bridge", "login"], timeout=120)
        except Exception:
            pass
        try:
            subprocess.Popen(["/usr/bin/24hg-hub"])
        except Exception:
            pass
        log("Step 3: Account — user chose to login")
        return True
    log("Step 3: Account — skipped")
    return False


