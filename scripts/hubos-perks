#!/usr/bin/env python3
"""
HubOS Perks Manager — Claim and manage HubOS-exclusive gaming perks

Install HubOS → Get 30 days free VIP on all 24HG servers + permanent HubOS badge.

Commands:
  claim    — Claim the HubOS welcome package (30-day VIP, badge, referral code)
  status   — Show current perks (VIP days, badge, referrals, rewards)
  badge    — Manage HubOS badge visibility and preview
  referral — Referral system (share code, enter friend's code, stats)
  rewards  — Activity-based VIP extensions (playtime, streaming, bugs, etc.)

Hub API endpoints used (for backend implementation):
  POST /api/hubos/claim-perks      — Claim welcome package
  GET  /api/hubos/perks-status     — Get current perks
  POST /api/hubos/referral/enter   — Enter referral code
  GET  /api/hubos/referral/stats   — Get referral stats
  POST /api/hubos/rewards/claim    — Claim activity reward
  GET  /api/hubos/rewards/available — List available rewards

Also runs as a systemd one-shot on first login (hubos-perks-claim.service):
  - Auto-claims perks if user is logged in
  - Reminds user to log in if not authenticated

Flags:
  --auto  — Non-interactive mode (for systemd first-boot)
  --gui   — Show zenity GUI dialogs instead of terminal output
"""

import hashlib
import json
import os
import platform
import subprocess
import sys
import urllib.error
import urllib.request
from datetime import datetime, timezone

# ── Configuration ──
API_URL = "https://api.24hgaming.com"
HUB_URL = "https://hub.24hgaming.com"
CONFIG_DIR = os.path.expanduser("~/.config/hubos")
CACHE_DIR = os.path.expanduser("~/.cache/hubos")
PERKS_FILE = os.path.join(CONFIG_DIR, "perks.json")
TOKEN_FILE = os.path.join(CONFIG_DIR, "hub-token")
STATE_FILE = os.path.join(CACHE_DIR, "hub-state.json")
HUBOS_VERSION_FILE = "/etc/hubos-release"

os.makedirs(CONFIG_DIR, exist_ok=True)
os.makedirs(CACHE_DIR, exist_ok=True)

# ── Color codes ──
RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
CYAN = "\033[36m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
MAGENTA = "\033[35m"
WHITE = "\033[37m"
BG_CYAN = "\033[46m"
BG_BLACK = "\033[40m"

# ── Box-drawing characters ──
BOX_TL = "╭"
BOX_TR = "╮"
BOX_BL = "╰"
BOX_BR = "╯"
BOX_H = "─"
BOX_V = "│"
BOX_LT = "├"
BOX_RT = "┤"

# ── Global flags ──
AUTO_MODE = "--auto" in sys.argv
GUI_MODE = "--gui" in sys.argv


# ═══════════════════════════════════════════
# Utility Functions
# ═══════════════════════════════════════════

def notify(title, body, icon="hubos-perks"):
    """Send a desktop notification via notify-send."""
    try:
        subprocess.run(
            ["notify-send", "-i", icon, "-a", "HubOS Perks", title, body],
            timeout=5, capture_output=True
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass


def zenity_info(title, text):
    """Show a zenity info dialog."""
    try:
        subprocess.run(
            ["zenity", "--info", f"--title={title}", f"--text={text}",
             "--width=450", "--height=300"],
            timeout=120, capture_output=True
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass


def zenity_list(title, columns, rows):
    """Show a zenity list dialog. Returns selected row or None."""
    cmd = ["zenity", "--list", f"--title={title}", "--width=550", "--height=400"]
    for col in columns:
        cmd.extend(["--column", col])
    for row in rows:
        cmd.extend([str(cell) for cell in row])
    try:
        result = subprocess.run(cmd, timeout=120, capture_output=True, text=True)
        return result.stdout.strip() if result.returncode == 0 else None
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return None


def zenity_question(title, text):
    """Show a zenity yes/no dialog. Returns True if Yes."""
    try:
        result = subprocess.run(
            ["zenity", "--question", f"--title={title}", f"--text={text}"],
            timeout=120, capture_output=True
        )
        return result.returncode == 0
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


def clipboard_copy(text):
    """Copy text to clipboard via wl-copy or xclip."""
    for cmd in [["wl-copy"], ["xclip", "-selection", "clipboard"]]:
        try:
            subprocess.run(cmd, input=text.encode(), timeout=5, capture_output=True)
            return True
        except (FileNotFoundError, subprocess.TimeoutExpired):
            continue
    return False


def draw_box(title, lines, width=60):
    """Draw a formatted box with title and content lines."""
    inner = width - 2
    print(f"\n  {CYAN}{BOX_TL}{BOX_H * inner}{BOX_TR}{RESET}")
    pad_title = title.center(inner)
    print(f"  {CYAN}{BOX_V}{BOLD}{BG_CYAN}{BG_BLACK}{pad_title}{RESET}{CYAN}{BOX_V}{RESET}")
    print(f"  {CYAN}{BOX_LT}{BOX_H * inner}{BOX_RT}{RESET}")
    for line in lines:
        # Strip ANSI for length calculation
        stripped = line
        for code in [RESET, BOLD, DIM, CYAN, GREEN, YELLOW, RED, MAGENTA, WHITE,
                     BG_CYAN, BG_BLACK]:
            stripped = stripped.replace(code, "")
        padding = inner - len(stripped)
        if padding < 0:
            padding = 0
        print(f"  {CYAN}{BOX_V}{RESET} {line}{' ' * (padding - 1)}{CYAN}{BOX_V}{RESET}")
    print(f"  {CYAN}{BOX_BL}{BOX_H * inner}{BOX_BR}{RESET}\n")


def load_token():
    """Load stored auth token from hub login."""
    if os.path.exists(TOKEN_FILE):
        with open(TOKEN_FILE) as f:
            token = f.read().strip()
            if token:
                return token
    return None


def load_hub_state():
    """Load hub state to get user info."""
    if os.path.exists(STATE_FILE):
        try:
            with open(STATE_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            pass
    return None


def load_perks():
    """Load cached perks state."""
    if os.path.exists(PERKS_FILE):
        try:
            with open(PERKS_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            pass
    return None


def save_perks(data):
    """Save perks state to config."""
    with open(PERKS_FILE, 'w') as f:
        json.dump(data, f, indent=2)
    os.chmod(PERKS_FILE, 0o600)


def get_hubos_version():
    """Read HubOS version from release file."""
    if os.path.exists(HUBOS_VERSION_FILE):
        try:
            with open(HUBOS_VERSION_FILE) as f:
                for line in f:
                    if line.startswith("VERSION="):
                        return line.split("=", 1)[1].strip().strip('"')
        except IOError:
            pass
    return "unknown"


def get_install_date():
    """Get OS install date from filesystem creation time."""
    for path in ["/etc/machine-id", "/var/lib/dbus/machine-id"]:
        if os.path.exists(path):
            try:
                stat = os.stat(path)
                ts = stat.st_ctime
                return datetime.fromtimestamp(ts, tz=timezone.utc).strftime("%Y-%m-%d")
            except OSError:
                continue
    return "unknown"


def generate_hardware_fingerprint():
    """
    Generate a privacy-respecting hardware fingerprint.
    Uses only generic hardware class info — NOT MAC addresses, serial numbers,
    or other uniquely identifying data.

    Components:
      - GPU vendor name (e.g. "AMD", "NVIDIA", "Intel")
      - CPU family string (e.g. "AMD Ryzen 7", "Intel Core i7")
      - Install date hash

    The result is a SHA-256 hash of these combined values, providing a
    semi-unique identifier that cannot be reversed to extract hardware details.
    """
    components = []

    # GPU vendor (generic class only)
    gpu_vendor = "unknown"
    try:
        result = subprocess.run(
            ["lspci", "-nn"],
            capture_output=True, text=True, timeout=5
        )
        for line in result.stdout.splitlines():
            if "VGA" in line or "3D controller" in line:
                lower = line.lower()
                if "nvidia" in lower:
                    gpu_vendor = "NVIDIA"
                elif "amd" in lower or "ati" in lower:
                    gpu_vendor = "AMD"
                elif "intel" in lower:
                    gpu_vendor = "Intel"
                break
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    components.append(f"gpu:{gpu_vendor}")

    # CPU family (generic)
    cpu_family = "unknown"
    try:
        with open("/proc/cpuinfo") as f:
            for line in f:
                if line.startswith("model name"):
                    full = line.split(":", 1)[1].strip()
                    # Extract family only: "AMD Ryzen 7" or "Intel Core i7"
                    parts = full.split()
                    if len(parts) >= 3:
                        cpu_family = " ".join(parts[:3])
                    elif parts:
                        cpu_family = parts[0]
                    break
    except IOError:
        pass
    components.append(f"cpu:{cpu_family}")

    # Install date
    install_date = get_install_date()
    components.append(f"installed:{install_date}")

    fingerprint_input = "|".join(components)
    return hashlib.sha256(fingerprint_input.encode()).hexdigest()[:32]


# ═══════════════════════════════════════════
# API Functions
# ═══════════════════════════════════════════

def api_request(method, endpoint, token, data=None):
    """Make an authenticated API request to the hub."""
    url = f"{API_URL}{endpoint}"
    headers = {
        "Authorization": f"Bearer {token}",
        "Accept": "application/json",
    }
    body = None
    if data is not None:
        headers["Content-Type"] = "application/json"
        body = json.dumps(data).encode()

    req = urllib.request.Request(url, data=body, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        try:
            err_body = json.loads(e.read())
        except Exception:
            err_body = {"error": str(e)}
        return {"error": err_body.get("error", str(e)), "status": e.code}
    except urllib.error.URLError as e:
        return {"error": f"Connection failed: {e.reason}", "offline": True}
    except Exception as e:
        return {"error": str(e), "offline": True}


def api_get(endpoint, token):
    """Authenticated GET request."""
    return api_request("GET", endpoint, token)


def api_post(endpoint, token, data=None):
    """Authenticated POST request."""
    return api_request("POST", endpoint, token, data)


# ═══════════════════════════════════════════
# Command: claim
# ═══════════════════════════════════════════

def cmd_claim():
    """Claim the HubOS welcome package."""
    # Check if already claimed
    perks = load_perks()
    if perks and perks.get("claimed"):
        msg = "You have already claimed your HubOS welcome package!"
        if GUI_MODE:
            zenity_info("Already Claimed", msg)
        else:
            print(f"\n  {YELLOW}{msg}{RESET}")
            print(f"  Run {CYAN}hubos-perks status{RESET} to see your perks.\n")
        return

    # Verify hub login
    token = load_token()
    hub_state = load_hub_state()
    if not token or not hub_state:
        msg = "You need to log into the 24HG Hub first."
        if AUTO_MODE:
            notify("HubOS Perks", "Log into the 24HG Hub to claim your free VIP perks!")
            print(f"  {YELLOW}Not logged in.{RESET} Log in to claim your HubOS perks.")
            print(f"  Run: {CYAN}hubos-hub-bridge login{RESET}")
            return
        if GUI_MODE:
            zenity_info("Login Required",
                        f"{msg}\n\nRun 'hubos-hub-bridge login' first,\n"
                        "then try claiming again.")
        else:
            print(f"\n  {RED}{msg}{RESET}")
            print(f"  Run: {CYAN}hubos-hub-bridge login{RESET}")
            print(f"  Then: {CYAN}hubos-perks claim{RESET}\n")
        return

    user_id = hub_state.get("user_id", hub_state.get("id", "unknown"))
    username = hub_state.get("username", "Gamer")

    if not AUTO_MODE and not GUI_MODE:
        print(f"\n  {CYAN}{BOLD}Claiming HubOS Welcome Package...{RESET}")
        print(f"  {DIM}Generating hardware fingerprint...{RESET}")

    # Build claim payload
    fingerprint = generate_hardware_fingerprint()
    hubos_version = get_hubos_version()
    install_date = get_install_date()

    payload = {
        "hub_user_id": user_id,
        "hubos_version": hubos_version,
        "hardware_fingerprint": fingerprint,
        "install_date": install_date,
    }

    if not AUTO_MODE and not GUI_MODE:
        print(f"  {DIM}Contacting 24HG Hub...{RESET}")

    result = api_post("/api/hubos/claim-perks", token, payload)

    if result.get("offline"):
        # Cache the claim attempt for retry
        pending = {
            "claimed": False,
            "pending_claim": True,
            "payload": payload,
            "timestamp": datetime.now(tz=timezone.utc).isoformat(),
        }
        save_perks(pending)
        msg = "Could not reach the hub. Your claim will be retried automatically."
        if GUI_MODE:
            zenity_info("Offline", msg)
        else:
            print(f"\n  {YELLOW}{msg}{RESET}\n")
        return

    if result.get("error"):
        msg = f"Claim failed: {result['error']}"
        if GUI_MODE:
            zenity_info("Claim Failed", msg)
        else:
            print(f"\n  {RED}{msg}{RESET}\n")
        return

    # Success — save perks state
    perks_data = {
        "claimed": True,
        "claimed_at": datetime.now(tz=timezone.utc).isoformat(),
        "username": username,
        "user_id": user_id,
        "vip_granted": result.get("vip_granted", True),
        "vip_expires": result.get("vip_expires", ""),
        "badge_granted": result.get("badge_granted", True),
        "badge_visible": True,
        "referral_code": result.get("referral_code", ""),
        "chat_color": "cyan",
        "reserved_slots": 2,
        "hubos_version": hubos_version,
        "hardware_fingerprint": fingerprint,
    }
    save_perks(perks_data)

    # Show congratulations
    referral = perks_data.get("referral_code", "???")
    vip_exp = perks_data.get("vip_expires", "???")

    if AUTO_MODE:
        notify(
            "Welcome to HubOS!",
            f"Your 30-day VIP trial is active on all 24HG servers!\n"
            f"Badge: [HubOS] | Referral: {referral}"
        )
        print(f"  {GREEN}HubOS perks claimed for {username}!{RESET}")
        return

    if GUI_MODE:
        zenity_info(
            "Welcome to HubOS!",
            f"Congratulations, {username}!\n\n"
            f"You have received:\n"
            f"  - 30-day VIP trial on ALL 24HG servers\n"
            f"  - [HubOS] badge on your hub profile + in-game\n"
            f"  - Exclusive cyan chat color\n"
            f"  - 2 reserved server slots\n"
            f"  - Referral code: {referral}\n\n"
            f"VIP expires: {vip_exp}\n\n"
            f"Share your referral code to earn bonus VIP days!"
        )
        return

    # Terminal output — full congratulations
    print(f"\n  {GREEN}{BOLD}{'=' * 56}{RESET}")
    print(f"  {GREEN}{BOLD}  CONGRATULATIONS, {username}!{RESET}")
    print(f"  {GREEN}{BOLD}  Welcome to the HubOS family!{RESET}")
    print(f"  {GREEN}{BOLD}{'=' * 56}{RESET}\n")

    draw_box("YOUR HUBOS PERKS", [
        f"{GREEN}+{RESET} {BOLD}30-day VIP trial{RESET} on ALL 24HG game servers",
        f"  {DIM}Expires: {vip_exp}{RESET}",
        "",
        f"{GREEN}+{RESET} {BOLD}[HubOS] badge{RESET} on hub profile and in-game",
        f"  {DIM}Visible to all players{RESET}",
        "",
        f"{GREEN}+{RESET} {BOLD}Exclusive chat color{RESET}: {CYAN}cyan{RESET}",
        f"  {DIM}Matching the HubOS theme{RESET}",
        "",
        f"{GREEN}+{RESET} {BOLD}2 reserved server slots{RESET}",
        f"  {DIM}Join even when servers are full{RESET}",
        "",
        f"{GREEN}+{RESET} {BOLD}Personal referral code{RESET}: {CYAN}{referral}{RESET}",
        f"  {DIM}Share with friends for +7 days VIP each{RESET}",
    ])

    print(f"  {DIM}Earn more VIP time: {CYAN}hubos-perks rewards{RESET}")
    print(f"  {DIM}Share your code:    {CYAN}hubos-perks referral share{RESET}")
    print(f"  {DIM}Check your perks:   {CYAN}hubos-perks status{RESET}\n")

    notify(
        "Welcome to HubOS!",
        f"30-day VIP activated on all 24HG servers!\n"
        f"Referral code: {referral}"
    )


# ═══════════════════════════════════════════
# Command: status
# ═══════════════════════════════════════════

def cmd_status():
    """Show current perks status."""
    perks = load_perks()
    token = load_token()

    # Try to refresh from API
    if token:
        remote = api_get("/api/hubos/perks-status", token)
        if not remote.get("error") and not remote.get("offline"):
            # Merge remote data into local
            if perks is None:
                perks = {}
            perks.update({
                "vip_granted": remote.get("vip_granted", perks.get("vip_granted")),
                "vip_expires": remote.get("vip_expires", perks.get("vip_expires")),
                "badge_granted": remote.get("badge_granted", perks.get("badge_granted")),
                "referral_code": remote.get("referral_code", perks.get("referral_code")),
                "referral_count": remote.get("referral_count", 0),
                "bonus_days": remote.get("bonus_days", 0),
                "playtime_hours": remote.get("playtime_hours", 0),
                "hub_xp": remote.get("hub_xp", 0),
            })
            save_perks(perks)

    if not perks or not perks.get("claimed"):
        if perks and perks.get("pending_claim"):
            msg = "Perks claim is pending (was offline). Will retry automatically."
            if GUI_MODE:
                zenity_info("Pending", msg)
            else:
                print(f"\n  {YELLOW}{msg}{RESET}")
                print(f"  Run {CYAN}hubos-perks claim{RESET} to retry now.\n")
        else:
            msg = "No perks claimed yet."
            if GUI_MODE:
                zenity_info("No Perks", f"{msg}\n\nRun 'hubos-perks claim' to get started!")
            else:
                print(f"\n  {YELLOW}{msg}{RESET}")
                print(f"  Run {CYAN}hubos-perks claim{RESET} to get your free VIP!\n")
        return

    # Calculate VIP days remaining
    vip_expires = perks.get("vip_expires", "")
    vip_status = f"{RED}Expired{RESET}"
    days_left = 0
    if vip_expires:
        try:
            exp_date = datetime.strptime(vip_expires, "%Y-%m-%d").replace(
                tzinfo=timezone.utc)
            now = datetime.now(tz=timezone.utc)
            delta = exp_date - now
            days_left = max(0, delta.days)
            if days_left > 0:
                if days_left > 14:
                    vip_status = f"{GREEN}{days_left} days remaining{RESET}"
                elif days_left > 3:
                    vip_status = f"{YELLOW}{days_left} days remaining{RESET}"
                else:
                    vip_status = f"{RED}{days_left} days remaining{RESET}"
            else:
                vip_status = f"{RED}Expired on {vip_expires}{RESET}"
        except ValueError:
            vip_status = f"{DIM}Unknown{RESET}"

    username = perks.get("username", "Gamer")
    badge_on = perks.get("badge_visible", True)
    referral_code = perks.get("referral_code", "N/A")
    referral_count = perks.get("referral_count", 0)
    bonus_days = perks.get("bonus_days", 0)
    reserved = perks.get("reserved_slots", 2)
    chat_color = perks.get("chat_color", "cyan")

    lines = [
        f"{BOLD}User:{RESET} {CYAN}{username}{RESET}",
        "",
        f"{BOLD}VIP Trial:{RESET}     {vip_status}",
        f"  {DIM}Expires: {vip_expires}{RESET}",
        "",
        f"{BOLD}Badge:{RESET}         {'[HubOS]' if badge_on else DIM + '[Hidden]' + RESET}"
        f"  {'(' + GREEN + 'visible' + RESET + ')' if badge_on else '(' + DIM + 'hidden' + RESET + ')'}",
        "",
        f"{BOLD}Chat Color:{RESET}    {CYAN}{chat_color}{RESET}",
        f"{BOLD}Server Slots:{RESET}  {reserved} reserved",
        "",
        f"{BOLD}Referral Code:{RESET} {CYAN}{referral_code}{RESET}",
        f"{BOLD}Friends Invited:{RESET} {referral_count}",
        f"{BOLD}Bonus Days Earned:{RESET} {GREEN}+{bonus_days}{RESET}",
    ]

    if GUI_MODE:
        plain = (
            f"User: {username}\n\n"
            f"VIP Trial: {days_left} days remaining\n"
            f"Expires: {vip_expires}\n\n"
            f"Badge: {'[HubOS] (visible)' if badge_on else '[Hidden]'}\n"
            f"Chat Color: {chat_color}\n"
            f"Server Slots: {reserved} reserved\n\n"
            f"Referral Code: {referral_code}\n"
            f"Friends Invited: {referral_count}\n"
            f"Bonus Days Earned: +{bonus_days}"
        )
        zenity_info("HubOS Perks Status", plain)
    else:
        draw_box("HUBOS PERKS STATUS", lines)


# ═══════════════════════════════════════════
# Command: badge
# ═══════════════════════════════════════════

def cmd_badge():
    """Manage HubOS badge."""
    perks = load_perks()
    if not perks or not perks.get("claimed"):
        print(f"\n  {YELLOW}No perks claimed yet.{RESET}")
        print(f"  Run {CYAN}hubos-perks claim{RESET} first.\n")
        return

    sub = sys.argv[2] if len(sys.argv) > 2 else "show"

    if sub == "toggle":
        current = perks.get("badge_visible", True)
        perks["badge_visible"] = not current
        save_perks(perks)

        # Update on server
        token = load_token()
        if token:
            api_post("/api/hubos/claim-perks", token, {
                "badge_visible": perks["badge_visible"]
            })

        state = "visible" if perks["badge_visible"] else "hidden"
        if GUI_MODE:
            zenity_info("Badge Updated", f"Your [HubOS] badge is now {state}.")
        else:
            print(f"\n  Badge is now {GREEN if perks['badge_visible'] else DIM}{state}{RESET}.\n")

    elif sub == "preview":
        badge_vis = perks.get("badge_visible", True)
        username = perks.get("username", "Gamer")
        if GUI_MODE:
            zenity_info("Badge Preview",
                        f"In-game:\n  [HubOS] {username}: gg\n\n"
                        f"Hub profile:\n  {username} [HubOS]\n\n"
                        f"Status: {'Visible' if badge_vis else 'Hidden'}")
        else:
            print(f"\n  {BOLD}Badge Preview{RESET}\n")
            print(f"  In-game chat:")
            if badge_vis:
                print(f"    {CYAN}[HubOS]{RESET} {username}: gg")
            else:
                print(f"    {username}: gg  {DIM}(badge hidden){RESET}")
            print(f"\n  Hub profile:")
            if badge_vis:
                print(f"    {username} {CYAN}[HubOS]{RESET}")
            else:
                print(f"    {username}  {DIM}(badge hidden){RESET}")
            print()

    else:  # show
        badge_vis = perks.get("badge_visible", True)
        lines = [
            f"{BOLD}HubOS Badge:{RESET} {CYAN}[HubOS]{RESET}",
            "",
            f"Status: {GREEN + 'Visible' + RESET if badge_vis else DIM + 'Hidden' + RESET}",
            f"Granted: {perks.get('claimed_at', 'Unknown')[:10]}",
            "",
            f"Commands:",
            f"  {CYAN}hubos-perks badge toggle{RESET}   Toggle visibility",
            f"  {CYAN}hubos-perks badge preview{RESET}  Preview appearance",
        ]
        if GUI_MODE:
            choice = zenity_list("HubOS Badge", ["Action", "Description"], [
                ["Toggle", f"Currently {'visible' if badge_vis else 'hidden'}"],
                ["Preview", "See how your badge looks"],
            ])
            if choice == "Toggle":
                sys.argv = [sys.argv[0], "badge", "toggle"]
                cmd_badge()
            elif choice == "Preview":
                sys.argv = [sys.argv[0], "badge", "preview"]
                cmd_badge()
        else:
            draw_box("HUBOS BADGE", lines)


# ═══════════════════════════════════════════
# Command: referral
# ═══════════════════════════════════════════

def cmd_referral():
    """Manage referral system."""
    perks = load_perks()
    if not perks or not perks.get("claimed"):
        print(f"\n  {YELLOW}No perks claimed yet.{RESET}")
        print(f"  Run {CYAN}hubos-perks claim{RESET} first.\n")
        return

    sub = sys.argv[2] if len(sys.argv) > 2 else "show"
    token = load_token()
    referral_code = perks.get("referral_code", "N/A")

    if sub == "share":
        # Copy code to clipboard and generate Discord message
        discord_msg = (
            f"Hey! I'm using **HubOS** (the gaming Linux distro) and loving it.\n"
            f"Use my referral code **{referral_code}** when you install to get "
            f"**30 days free VIP** on all 24HG servers + we both get **+7 bonus days**!\n"
            f"Download: https://hubos.24hgaming.com\n"
            f"Discord: https://discord.gg/ymfEjH6EJN"
        )

        copied = clipboard_copy(discord_msg)
        if GUI_MODE:
            zenity_info("Referral Code Shared",
                        f"Your code: {referral_code}\n\n"
                        f"{'Copied to clipboard!' if copied else 'Copy manually:'}\n\n"
                        f"{discord_msg}")
        else:
            print(f"\n  {BOLD}Your Referral Code:{RESET} {CYAN}{referral_code}{RESET}\n")
            if copied:
                print(f"  {GREEN}Discord message copied to clipboard!{RESET}")
            else:
                print(f"  {YELLOW}Could not copy to clipboard. Here's the message:{RESET}")
            print(f"\n  {DIM}--- Discord Message ---{RESET}")
            for line in discord_msg.split("\n"):
                print(f"  {line}")
            print(f"  {DIM}--- End ---{RESET}\n")

    elif sub == "enter":
        if len(sys.argv) < 4:
            if GUI_MODE:
                try:
                    result = subprocess.run(
                        ["zenity", "--entry", "--title=Enter Referral Code",
                         "--text=Enter your friend's referral code:"],
                        timeout=120, capture_output=True, text=True
                    )
                    code = result.stdout.strip() if result.returncode == 0 else None
                except (FileNotFoundError, subprocess.TimeoutExpired):
                    code = None
            else:
                print(f"\n  {RED}Usage: hubos-perks referral enter <code>{RESET}\n")
                return
        else:
            code = sys.argv[3].strip().upper()

        if not code:
            return

        if not token:
            print(f"\n  {RED}Not logged in. Log in first.{RESET}\n")
            return

        result = api_post("/api/hubos/referral/enter", token, {"code": code})
        if result.get("error"):
            msg = f"Failed: {result['error']}"
            if GUI_MODE:
                zenity_info("Referral Failed", msg)
            else:
                print(f"\n  {RED}{msg}{RESET}\n")
        else:
            bonus = result.get("bonus_days", 7)
            msg = f"Referral accepted! You and your friend each get +{bonus} days VIP."
            if GUI_MODE:
                zenity_info("Referral Accepted!", msg)
            else:
                print(f"\n  {GREEN}{msg}{RESET}\n")
            notify("Referral Bonus!", f"+{bonus} days VIP added to your account!")

    else:  # show
        # Fetch referral stats from API
        stats = {"referrals": 0, "bonus_days": 0, "recent": []}
        if token:
            remote = api_get("/api/hubos/referral/stats", token)
            if not remote.get("error") and not remote.get("offline"):
                stats = remote

        ref_count = stats.get("referrals", perks.get("referral_count", 0))
        bonus = stats.get("bonus_days", perks.get("bonus_days", 0))
        recent = stats.get("recent", [])

        lines = [
            f"{BOLD}Your Code:{RESET}      {CYAN}{referral_code}{RESET}",
            "",
            f"{BOLD}Friends Invited:{RESET} {ref_count}",
            f"{BOLD}Bonus Days:{RESET}      {GREEN}+{bonus}{RESET}",
            "",
            f"{BOLD}How It Works:{RESET}",
            f"  Share your code with friends",
            f"  They enter it during HubOS setup",
            f"  {GREEN}Both of you get +7 days VIP{RESET}",
        ]

        if recent:
            lines.append("")
            lines.append(f"{BOLD}Recent Referrals:{RESET}")
            for r in recent[:5]:
                name = r.get("username", "Someone")
                date = r.get("date", "")[:10]
                lines.append(f"  {GREEN}+{RESET} {name} {DIM}({date}){RESET}")

        lines.extend([
            "",
            f"Commands:",
            f"  {CYAN}hubos-perks referral share{RESET}        Copy & share",
            f"  {CYAN}hubos-perks referral enter <code>{RESET} Enter a code",
        ])

        if GUI_MODE:
            choice = zenity_list("Referral System", ["Action", "Description"], [
                ["Share", f"Share your code: {referral_code}"],
                ["Enter Code", "Enter a friend's referral code"],
                ["Stats", f"{ref_count} friends, +{bonus} days"],
            ])
            if choice == "Share":
                sys.argv = [sys.argv[0], "referral", "share"]
                cmd_referral()
            elif choice == "Enter Code":
                sys.argv = [sys.argv[0], "referral", "enter"]
                cmd_referral()
        else:
            draw_box("REFERRAL SYSTEM", lines)


# ═══════════════════════════════════════════
# Command: rewards
# ═══════════════════════════════════════════

REWARD_DEFINITIONS = [
    {
        "id": "playtime_10h",
        "name": "Dedicated Gamer",
        "desc": "Play 10 hours on 24HG servers",
        "bonus": 3,
        "icon": "*",
    },
    {
        "id": "referral_install",
        "name": "Friend Recruiter",
        "desc": "Invite a friend who installs HubOS",
        "bonus": 7,
        "icon": "+",
    },
    {
        "id": "twitch_stream",
        "name": "Streamer",
        "desc": "Stream on Twitch with #HubOS tag",
        "bonus": 5,
        "icon": "~",
    },
    {
        "id": "benchmark_post",
        "name": "Benchmark Hero",
        "desc": "Post a benchmark comparison",
        "bonus": 2,
        "icon": "^",
    },
    {
        "id": "bug_report_fixed",
        "name": "Bug Hunter",
        "desc": "Report a bug that gets fixed",
        "bonus": 7,
        "icon": "!",
    },
    {
        "id": "hub_xp_100",
        "name": "Hub Regular",
        "desc": "Reach 100 hub XP",
        "bonus": 1,
        "icon": "#",
    },
]


def cmd_rewards():
    """Show and claim activity-based VIP extensions."""
    perks = load_perks()
    if not perks or not perks.get("claimed"):
        print(f"\n  {YELLOW}No perks claimed yet.{RESET}")
        print(f"  Run {CYAN}hubos-perks claim{RESET} first.\n")
        return

    sub = sys.argv[2] if len(sys.argv) > 2 else "show"
    token = load_token()

    # Fetch available rewards from API
    available = {}
    earned = []
    claimable = []
    if token:
        remote = api_get("/api/hubos/rewards/available", token)
        if not remote.get("error") and not remote.get("offline"):
            available = {r["id"]: r for r in remote.get("rewards", [])}
            earned = remote.get("earned", [])
            claimable = remote.get("claimable", [])

    if sub == "claim":
        reward_id = sys.argv[3] if len(sys.argv) > 3 else None

        if not reward_id:
            if not claimable:
                msg = "No rewards available to claim right now."
                if GUI_MODE:
                    zenity_info("No Rewards", msg)
                else:
                    print(f"\n  {YELLOW}{msg}{RESET}\n")
                return

            if GUI_MODE:
                rows = []
                for rid in claimable:
                    rdef = next(
                        (r for r in REWARD_DEFINITIONS if r["id"] == rid), None)
                    if rdef:
                        rows.extend([rid, rdef["name"], f"+{rdef['bonus']} days"])
                choice = zenity_list("Claim Reward",
                                     ["ID", "Reward", "Bonus"], rows)
                if choice:
                    reward_id = choice
                else:
                    return
            else:
                print(f"\n  {BOLD}Claimable Rewards:{RESET}\n")
                for rid in claimable:
                    rdef = next(
                        (r for r in REWARD_DEFINITIONS if r["id"] == rid), None)
                    if rdef:
                        print(f"    {CYAN}{rid}{RESET} — {rdef['name']} "
                              f"({GREEN}+{rdef['bonus']} days{RESET})")
                print(f"\n  Usage: {CYAN}hubos-perks rewards claim <reward_id>{RESET}\n")
                return

        if not token:
            print(f"\n  {RED}Not logged in.{RESET}\n")
            return

        result = api_post("/api/hubos/rewards/claim", token,
                          {"reward_id": reward_id})
        if result.get("error"):
            msg = f"Failed: {result['error']}"
            if GUI_MODE:
                zenity_info("Claim Failed", msg)
            else:
                print(f"\n  {RED}{msg}{RESET}\n")
        else:
            bonus = result.get("bonus_days", 0)
            new_exp = result.get("vip_expires", "")
            msg = f"Reward claimed! +{bonus} days VIP. New expiry: {new_exp}"
            if GUI_MODE:
                zenity_info("Reward Claimed!", msg)
            else:
                print(f"\n  {GREEN}{msg}{RESET}\n")
            notify("Reward Claimed!", f"+{bonus} days VIP added!")

            # Update local perks
            if new_exp:
                perks["vip_expires"] = new_exp
                save_perks(perks)

    else:  # show
        lines = [
            f"{BOLD}Earn more VIP time with these activities:{RESET}",
            "",
        ]

        for rdef in REWARD_DEFINITIONS:
            rid = rdef["id"]
            is_earned = rid in earned
            is_claimable = rid in claimable
            remote_info = available.get(rid, {})
            progress = remote_info.get("progress", "")

            if is_earned:
                status = f"{GREEN}EARNED{RESET}"
            elif is_claimable:
                status = f"{YELLOW}CLAIM NOW{RESET}"
            else:
                status = f"{DIM}Locked{RESET}"

            line = (f" {rdef['icon']} {BOLD}{rdef['name']}{RESET} "
                    f"({GREEN}+{rdef['bonus']} days{RESET})")
            lines.append(line)
            lines.append(f"   {rdef['desc']}")
            status_line = f"   Status: {status}"
            if progress:
                status_line += f" {DIM}({progress}){RESET}"
            lines.append(status_line)
            lines.append("")

        lines.extend([
            f"{BOLD}Total Bonus Earned:{RESET} "
            f"{GREEN}+{perks.get('bonus_days', 0)} days{RESET}",
            "",
            f"Claim: {CYAN}hubos-perks rewards claim <id>{RESET}",
        ])

        if GUI_MODE:
            rows = []
            for rdef in REWARD_DEFINITIONS:
                rid = rdef["id"]
                if rid in earned:
                    st = "Earned"
                elif rid in claimable:
                    st = "CLAIM NOW"
                else:
                    st = "Locked"
                rows.extend([rdef["name"], rdef["desc"],
                             f"+{rdef['bonus']}d", st])
            choice = zenity_list("Activity Rewards",
                                 ["Reward", "Description", "Bonus", "Status"],
                                 rows)
            if choice and any(r["name"] == choice and r["id"] in claimable
                              for r in REWARD_DEFINITIONS):
                rid = next(r["id"] for r in REWARD_DEFINITIONS
                           if r["name"] == choice)
                sys.argv = [sys.argv[0], "rewards", "claim", rid]
                cmd_rewards()
        else:
            draw_box("ACTIVITY REWARDS", lines)


# ═══════════════════════════════════════════
# First-boot auto-claim logic
# ═══════════════════════════════════════════

def auto_claim():
    """
    Called by systemd one-shot on first login.
    Checks if perks already claimed; if not, attempts auto-claim.
    """
    perks = load_perks()
    if perks and perks.get("claimed"):
        # Already claimed, nothing to do
        return

    token = load_token()
    hub_state = load_hub_state()

    if token and hub_state:
        # User is logged in — auto-claim
        print("HubOS Perks: Auto-claiming welcome package...")
        cmd_claim()
    else:
        # Not logged in — send reminder
        notify(
            "Claim Your HubOS Perks!",
            "Log into the 24HG Hub to get 30 days free VIP "
            "on all game servers!\n\n"
            "Run: hubos-perks claim"
        )
        print("HubOS Perks: User not logged in. Sent reminder notification.")


# ═══════════════════════════════════════════
# Usage / Help
# ═══════════════════════════════════════════

def show_help():
    """Show usage information."""
    if GUI_MODE:
        choice = zenity_list("HubOS Perks Manager", ["Command", "Description"], [
            ["Claim", "Claim your HubOS welcome package (30-day VIP + badge)"],
            ["Status", "View your current perks and VIP time"],
            ["Badge", "Manage your [HubOS] badge"],
            ["Referral", "Share your referral code and earn bonus days"],
            ["Rewards", "View activity-based VIP extensions"],
        ])
        if choice:
            cmd_map = {
                "Claim": cmd_claim,
                "Status": cmd_status,
                "Badge": cmd_badge,
                "Referral": cmd_referral,
                "Rewards": cmd_rewards,
            }
            fn = cmd_map.get(choice)
            if fn:
                fn()
        return

    print(f"""
  {CYAN}{BOLD}HubOS Perks Manager{RESET}
  {DIM}Claim and manage HubOS-exclusive gaming perks{RESET}

  {BOLD}Usage:{RESET}  hubos-perks <command> [options]

  {BOLD}Commands:{RESET}
    {CYAN}claim{RESET}      Claim the HubOS welcome package
               {DIM}30-day VIP, [HubOS] badge, cyan chat, referral code{RESET}

    {CYAN}status{RESET}     Show current perks status
               {DIM}VIP time remaining, badge, referrals, rewards{RESET}

    {CYAN}badge{RESET}      Manage HubOS badge
               {DIM}badge show | badge toggle | badge preview{RESET}

    {CYAN}referral{RESET}   Referral system
               {DIM}referral show | referral share | referral enter <code>{RESET}

    {CYAN}rewards{RESET}    Activity-based VIP extensions
               {DIM}rewards show | rewards claim <id>{RESET}

  {BOLD}Flags:{RESET}
    {CYAN}--auto{RESET}     Non-interactive mode (for systemd first-boot)
    {CYAN}--gui{RESET}      Show zenity GUI dialogs

  {BOLD}Perks Include:{RESET}
    {GREEN}+{RESET} 30-day VIP trial on ALL 24HG game servers
    {GREEN}+{RESET} [HubOS] badge on hub profile and in-game
    {GREEN}+{RESET} Exclusive cyan chat color
    {GREEN}+{RESET} 2 reserved server slots
    {GREEN}+{RESET} Personal referral code (earn +7 days per friend)

  {BOLD}Earn More VIP:{RESET}
    Play 10 hours        {GREEN}+3 days{RESET}
    Invite a friend      {GREEN}+7 days{RESET}
    Twitch stream        {GREEN}+5 days{RESET}
    Benchmark post       {GREEN}+2 days{RESET}
    Bug report (fixed)   {GREEN}+7 days{RESET}
    100 hub XP           {GREEN}+1 day{RESET}
""")


# ═══════════════════════════════════════════
# Main
# ═══════════════════════════════════════════

def main():
    # Filter out flags to get the command
    args = [a for a in sys.argv[1:] if not a.startswith("--")]
    command = args[0] if args else None

    if AUTO_MODE and not command:
        auto_claim()
        return

    commands = {
        "claim": cmd_claim,
        "status": cmd_status,
        "badge": cmd_badge,
        "referral": cmd_referral,
        "rewards": cmd_rewards,
        "help": show_help,
    }

    if command in commands:
        commands[command]()
    elif GUI_MODE and not command:
        show_help()
    else:
        if command:
            print(f"\n  {RED}Unknown command: {command}{RESET}")
        show_help()


if __name__ == "__main__":
    main()
