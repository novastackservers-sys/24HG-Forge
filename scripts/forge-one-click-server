#!/usr/bin/env bash
# forge-one-click-server — One-click game server hosting for 24HG Forge
# Host a dedicated game server from your PC with a single command.
set -euo pipefail

VERSION="1.0.0"
DATA_DIR="${HOME}/.local/share/forge/servers"
STEAMCMD_DIR="${DATA_DIR}/.steamcmd"
CONFIG_DIR="${HOME}/.config/forge/servers"
LOG_DIR="${DATA_DIR}/logs"
BACKUP_DIR="${DATA_DIR}/backups"
RELAY_API="https://24hg.gg/api/relay"
IDLE_TIMEOUT_DEFAULT=900  # 15 minutes

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# ── Game Templates ──────────────────────────────────────────────────
declare -A GAME_APPID GAME_PORT GAME_PROTOCOL GAME_LAUNCH GAME_SAVE_DIR
declare -A GAME_DESC GAME_RAM GAME_QUERY_PORT GAME_STEAM_CONNECT

# AppIDs (dedicated server)
GAME_APPID=(
    [minecraft]="0" [valheim]="896660" [terraria]="105600"
    [cs2]="730" [tf2]="232250" [rust]="258550"
    [7dtd]="294420" [zomboid]="380870" [satisfactory]="1690800"
    [palworld]="2394010"
)
GAME_PORT=(
    [minecraft]="25565" [valheim]="2456" [terraria]="7777"
    [cs2]="27015" [tf2]="27015" [rust]="28015"
    [7dtd]="26900" [zomboid]="16261" [satisfactory]="7777"
    [palworld]="8211"
)
GAME_PROTOCOL=(
    [minecraft]="tcp" [valheim]="udp" [terraria]="tcp"
    [cs2]="udp" [tf2]="udp" [rust]="udp"
    [7dtd]="udp" [zomboid]="udp" [satisfactory]="udp"
    [palworld]="udp"
)
GAME_DESC=(
    [minecraft]="Minecraft Java Edition" [valheim]="Valheim Dedicated"
    [terraria]="Terraria Dedicated" [cs2]="Counter-Strike 2"
    [tf2]="Team Fortress 2" [rust]="Rust Dedicated"
    [7dtd]="7 Days to Die" [zomboid]="Project Zomboid"
    [satisfactory]="Satisfactory Dedicated" [palworld]="Palworld Dedicated"
)
GAME_RAM=(
    [minecraft]="2048" [valheim]="4096" [terraria]="1024"
    [cs2]="4096" [tf2]="2048" [rust]="8192"
    [7dtd]="4096" [zomboid]="4096" [satisfactory]="8192"
    [palworld]="8192"
)
GAME_STEAM_CONNECT=(
    [minecraft]="0" [valheim]="1" [terraria]="0"
    [cs2]="1" [tf2]="1" [rust]="1"
    [7dtd]="1" [zomboid]="0" [satisfactory]="0"
    [palworld]="1"
)

SUPPORTED_GAMES=("minecraft" "valheim" "terraria" "cs2" "tf2" "rust" "7dtd" "zomboid" "satisfactory" "palworld")

# ── Helpers ─────────────────────────────────────────────────────────
msg()  { echo -e "${GREEN}[forge-server]${NC} $*"; }
warn() { echo -e "${YELLOW}[forge-server]${NC} $*"; }
err()  { echo -e "${RED}[forge-server]${NC} $*" >&2; }
die()  { err "$@"; exit 1; }

ensure_dirs() {
    mkdir -p "$DATA_DIR" "$CONFIG_DIR" "$LOG_DIR" "$BACKUP_DIR"
}

valid_game() {
    local g="$1"
    for s in "${SUPPORTED_GAMES[@]}"; do [[ "$s" == "$g" ]] && return 0; done
    return 1
}

server_dir() { echo "${DATA_DIR}/${1}"; }
pid_file()   { echo "${DATA_DIR}/${1}/.server.pid"; }
log_file()   { echo "${LOG_DIR}/${1}.log"; }

is_running() {
    local pf; pf="$(pid_file "$1")"
    [[ -f "$pf" ]] && kill -0 "$(cat "$pf")" 2>/dev/null
}

get_public_ip() {
    curl -s --max-time 5 https://ifconfig.me 2>/dev/null \
        || curl -s --max-time 5 https://api.ipify.org 2>/dev/null \
        || echo "UNKNOWN"
}

# ── Port Management ─────────────────────────────────────────────────
find_available_port() {
    local base="$1" port="$base"
    while ss -tuln 2>/dev/null | grep -q ":${port} "; do
        port=$((port + 1))
        ((port > base + 100)) && die "No available port found near ${base}"
    done
    echo "$port"
}

open_firewall() {
    local port="$1" proto="$2"
    if command -v firewall-cmd &>/dev/null; then
        sudo firewall-cmd --add-port="${port}/${proto}" --permanent &>/dev/null || true
        sudo firewall-cmd --add-port="$((port+1))/${proto}" --permanent &>/dev/null || true
        sudo firewall-cmd --reload &>/dev/null || true
        msg "Firewall: opened port ${port}/${proto}"
    elif command -v ufw &>/dev/null; then
        sudo ufw allow "${port}/${proto}" &>/dev/null || true
        msg "Firewall: opened port ${port}/${proto}"
    else
        warn "No firewall manager found — open port ${port}/${proto} manually"
    fi
}

close_firewall() {
    local port="$1" proto="$2"
    if command -v firewall-cmd &>/dev/null; then
        sudo firewall-cmd --remove-port="${port}/${proto}" --permanent &>/dev/null || true
        sudo firewall-cmd --remove-port="$((port+1))/${proto}" --permanent &>/dev/null || true
        sudo firewall-cmd --reload &>/dev/null || true
    elif command -v ufw &>/dev/null; then
        sudo ufw delete allow "${port}/${proto}" &>/dev/null || true
    fi
}

# ── SteamCMD ────────────────────────────────────────────────────────
install_steamcmd() {
    [[ -x "${STEAMCMD_DIR}/steamcmd.sh" ]] && return 0
    msg "Installing SteamCMD..."
    mkdir -p "$STEAMCMD_DIR"
    curl -sqL "https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz" \
        | tar xz -C "$STEAMCMD_DIR"
    "${STEAMCMD_DIR}/steamcmd.sh" +quit &>/dev/null || true
    msg "SteamCMD installed"
}

install_game_server() {
    local game="$1" sdir; sdir="$(server_dir "$game")"
    local appid="${GAME_APPID[$game]}"

    if [[ "$game" == "minecraft" ]]; then
        install_minecraft_server "$sdir"
        return
    fi

    [[ "$appid" == "0" ]] && die "No SteamCMD app ID for $game"
    install_steamcmd
    msg "Installing ${GAME_DESC[$game]} (AppID ${appid})..."
    mkdir -p "$sdir"
    "${STEAMCMD_DIR}/steamcmd.sh" +force_install_dir "$sdir" \
        +login anonymous +app_update "$appid" validate +quit \
        2>&1 | tail -5
    msg "Server files installed at ${sdir}"
}

install_minecraft_server() {
    local sdir="$1"
    mkdir -p "$sdir"
    if [[ ! -f "${sdir}/server.jar" ]]; then
        msg "Downloading Minecraft server..."
        local manifest_url latest_url
        manifest_url=$(curl -s "https://launchermeta.mojang.com/mc/game/version_manifest.json" \
            | python3 -c "import sys,json; d=json.load(sys.stdin); print([v['url'] for v in d['versions'] if v['id']==d['latest']['release']][0])" 2>/dev/null) || true
        if [[ -n "$manifest_url" ]]; then
            latest_url=$(curl -s "$manifest_url" \
                | python3 -c "import sys,json; print(json.load(sys.stdin)['downloads']['server']['url'])" 2>/dev/null) || true
        fi
        if [[ -n "${latest_url:-}" ]]; then
            curl -sL "$latest_url" -o "${sdir}/server.jar"
        else
            die "Failed to fetch Minecraft server jar. Check network."
        fi
        echo "eula=true" > "${sdir}/eula.txt"
        cat > "${sdir}/server.properties" <<MCEOF
server-port=25565
motd=24HG Forge Server
max-players=10
enable-command-block=true
MCEOF
    fi
    msg "Minecraft server ready at ${sdir}"
}

# ── Resource Limits ─────────────────────────────────────────────────
apply_resource_limits() {
    local game="$1" pid="$2"
    local ram="${GAME_RAM[$game]}"
    local total_cores; total_cores=$(nproc)
    # Reserve at least 2 cores for the host, give the rest to server (min 1)
    local server_cores=$(( total_cores > 3 ? total_cores - 2 : 1 ))
    local cpu_list="0-$((server_cores - 1))"

    # CPU affinity
    taskset -pc "$cpu_list" "$pid" &>/dev/null || true

    # Use cgroups v2 if systemd-run is available
    if command -v systemd-run &>/dev/null; then
        local unit="forge-server-${game}"
        systemctl --user set-property "$unit" MemoryMax="${ram}M" 2>/dev/null || true
        systemctl --user set-property "$unit" CPUQuota="$((server_cores * 100))%" 2>/dev/null || true
    else
        # Fallback: nice + ionice
        renice 10 -p "$pid" &>/dev/null || true
        ionice -c 2 -n 6 -p "$pid" &>/dev/null || true
    fi
}

# ── Launch Commands ─────────────────────────────────────────────────
build_launch_cmd() {
    local game="$1" port="$2" sdir; sdir="$(server_dir "$game")"
    local ram="${GAME_RAM[$game]}"

    case "$game" in
        minecraft)
            echo "java -Xmx${ram}M -Xms512M -jar ${sdir}/server.jar nogui --port ${port}" ;;
        valheim)
            echo "${sdir}/valheim_server.x86_64 -name 'Forge Server' -port ${port} -world ForgeWorld -password forge123 -public 0" ;;
        terraria)
            echo "${sdir}/TerrariaServer.bin.x86_64 -port ${port} -maxplayers 8 -world ${sdir}/worlds/forge.wld -autocreate 3" ;;
        cs2)
            echo "${sdir}/game/bin/linuxsteamrt64/cs2 -dedicated +map de_dust2 -port ${port} +game_type 0 +game_mode 0" ;;
        tf2)
            echo "${sdir}/srcds_run -game tf +map cp_badlands -port ${port} +maxplayers 24 -norestart" ;;
        rust)
            echo "${sdir}/RustDedicated -batchmode +server.port ${port} +server.hostname 'Forge Server' +server.maxplayers 50 +server.worldsize 3000 +server.saveinterval 300" ;;
        7dtd)
            echo "${sdir}/7DaysToDieServer.x86_64 -configfile=${sdir}/serverconfig.xml -quit -batchmode -nographics -dedicated -ServerPort=${port}" ;;
        zomboid)
            echo "${sdir}/start-server.sh -servername ForgeServer -port ${port}" ;;
        satisfactory)
            echo "${sdir}/FactoryServer.sh -Port=${port} -unattended -multihome=0.0.0.0" ;;
        palworld)
            echo "${sdir}/PalServer.sh -port=${port} -useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS" ;;
        *) die "Unknown game: $game" ;;
    esac
}

# ── Auto-Shutdown Monitor ──────────────────────────────────────────
start_idle_monitor() {
    local game="$1" port="$2" timeout="${3:-$IDLE_TIMEOUT_DEFAULT}"
    local pf; pf="$(pid_file "$game")"
    (
        local idle_since; idle_since=$(date +%s)
        while [[ -f "$pf" ]] && kill -0 "$(cat "$pf")" 2>/dev/null; do
            sleep 30
            local players=0
            # Check player count via query protocols
            case "$game" in
                minecraft)
                    players=$(echo "list" | ncat -w2 127.0.0.1 "$((port))" 2>/dev/null | grep -oP '\d+(?= of)' || echo 0) ;;
                cs2|tf2|rust|valheim|7dtd|palworld)
                    # A2S_INFO query: send header, count response
                    players=$(python3 -c "
import socket, struct
s=socket.socket(socket.AF_INET,socket.SOCK_DGRAM)
s.settimeout(2)
try:
    s.sendto(b'\xff\xff\xff\xff\x54Source Engine Query\x00',('127.0.0.1',$port))
    d=s.recv(4096)
    print(d[25]) if len(d)>25 else print(0)
except: print(0)
s.close()
" 2>/dev/null || echo 0) ;;
                *) players=1 ;;  # Unknown protocol, assume active
            esac

            if (( players > 0 )); then
                idle_since=$(date +%s)
            else
                local now; now=$(date +%s)
                if (( now - idle_since >= timeout )); then
                    msg "Server ${game} idle for ${timeout}s — shutting down"
                    do_stop "$game"
                    break
                fi
            fi
        done
    ) &
    echo $! > "${DATA_DIR}/${game}/.idle_monitor.pid"
}

# ── Save & Backup ──────────────────────────────────────────────────
get_save_paths() {
    local game="$1" sdir; sdir="$(server_dir "$game")"
    case "$game" in
        minecraft)  echo "${sdir}/world" ;;
        valheim)    echo "${sdir}/.config/unity3d/IronGate/Valheim/worlds_local" ;;
        terraria)   echo "${sdir}/worlds" ;;
        rust)       echo "${sdir}/server/rust/saves" ;;
        7dtd)       echo "${sdir}/saves" ;;
        zomboid)    echo "${HOME}/Zomboid/Saves" ;;
        satisfactory) echo "${sdir}/saved" ;;
        palworld)   echo "${sdir}/Pal/Saved" ;;
        *)          echo "${sdir}/saves" ;;
    esac
}

do_save() {
    local game="$1"
    valid_game "$game" || die "Unknown game: $game"
    is_running "$game" || die "Server ${game} is not running"

    local sdir; sdir="$(server_dir "$game")"
    local save_path; save_path="$(get_save_paths "$game")"
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local backup_file="${BACKUP_DIR}/${game}_${ts}.tar.gz"

    if [[ -d "$save_path" ]]; then
        tar czf "$backup_file" -C "$(dirname "$save_path")" "$(basename "$save_path")" 2>/dev/null
        msg "Backup saved: ${backup_file}"
        # Prune old backups (keep last 10)
        ls -t "${BACKUP_DIR}/${game}_"*.tar.gz 2>/dev/null | tail -n +11 | xargs -r rm --
        msg "Kept latest 10 backups for ${game}"
    else
        warn "Save path not found: ${save_path}"
    fi
}

do_restore() {
    local game="$1" backup="${2:-}"
    valid_game "$game" || die "Unknown game: $game"
    is_running "$game" && die "Stop the server first before restoring"

    if [[ -z "$backup" ]]; then
        backup=$(ls -t "${BACKUP_DIR}/${game}_"*.tar.gz 2>/dev/null | head -1)
        [[ -z "$backup" ]] && die "No backups found for ${game}"
    fi
    [[ -f "$backup" ]] || die "Backup not found: ${backup}"

    local save_path; save_path="$(get_save_paths "$game")"
    local parent; parent="$(dirname "$save_path")"
    mkdir -p "$parent"
    tar xzf "$backup" -C "$parent" 2>/dev/null
    msg "Restored ${game} from $(basename "$backup")"
}

# ── Dynamic DNS / Invite ────────────────────────────────────────────
generate_invite_code() {
    head -c6 /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c8
}

register_relay() {
    local game="$1" port="$2" ip="$3"
    local code; code="$(generate_invite_code)"
    # Try registering with 24HG relay; silently fail if unavailable
    local result
    result=$(curl -s --max-time 5 -X POST "${RELAY_API}/register" \
        -H "Content-Type: application/json" \
        -d "{\"code\":\"${code}\",\"ip\":\"${ip}\",\"port\":${port},\"game\":\"${game}\"}" 2>/dev/null) || true

    if echo "$result" | grep -q '"ok"' 2>/dev/null; then
        echo "$code" > "${DATA_DIR}/${game}/.invite_code"
        echo "$code"
    else
        echo ""
    fi
}

do_invite() {
    local game="$1"
    valid_game "$game" || die "Unknown game: $game"

    local sdir; sdir="$(server_dir "$game")"
    [[ -d "$sdir" ]] || die "Server ${game} is not installed"

    local port_file="${sdir}/.port"
    local port; port=$(cat "$port_file" 2>/dev/null || echo "${GAME_PORT[$game]}")
    local ip; ip="$(get_public_ip)"

    echo -e "${BOLD}${CYAN}=== Invite Links for ${GAME_DESC[$game]} ===${NC}"
    echo ""

    # Steam connect link
    if [[ "${GAME_STEAM_CONNECT[$game]}" == "1" ]]; then
        echo -e "  ${GREEN}Steam:${NC}    steam://connect/${ip}:${port}"
    fi

    # Direct connect
    echo -e "  ${GREEN}Direct:${NC}   ${ip}:${port}"

    # 24HG relay
    local code=""
    if [[ -f "${sdir}/.invite_code" ]]; then
        code=$(cat "${sdir}/.invite_code")
    elif is_running "$game"; then
        code=$(register_relay "$game" "$port" "$ip")
    fi
    if [[ -n "$code" ]]; then
        echo -e "  ${GREEN}24HG:${NC}     https://24hg.gg/join/${code}"
    fi

    echo ""
    echo -e "  ${YELLOW}Tip:${NC} Share any link above with friends to connect."
    echo -e "  ${YELLOW}Note:${NC} Ensure port ${port}/${GAME_PROTOCOL[$game]} is forwarded on your router."
}

# ── Core Commands ───────────────────────────────────────────────────
do_list() {
    echo -e "${BOLD}${CYAN}=== Available Game Server Templates ===${NC}"
    echo ""
    printf "  ${BOLD}%-15s %-30s %-8s %-6s %s${NC}\n" "GAME" "DESCRIPTION" "PORT" "RAM" "STATUS"
    echo "  $(printf '%.0s─' {1..75})"
    for game in "${SUPPORTED_GAMES[@]}"; do
        local status="${RED}not installed${NC}"
        if is_running "$game"; then
            status="${GREEN}running${NC}"
        elif [[ -d "$(server_dir "$game")" ]]; then
            status="${YELLOW}stopped${NC}"
        fi
        printf "  %-15s %-30s %-8s %-6s %b\n" \
            "$game" "${GAME_DESC[$game]}" "${GAME_PORT[$game]}" "${GAME_RAM[$game]}M" "$status"
    done
    echo ""
}

do_start() {
    local game="$1"; shift
    valid_game "$game" || die "Unknown game: $game. Run 'forge-one-click-server list' to see options."

    local custom_port="" idle_timeout="$IDLE_TIMEOUT_DEFAULT" no_idle=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port=*)     custom_port="${1#*=}" ;;
            --timeout=*)  idle_timeout="${1#*=}" ;;
            --no-idle)    no_idle=1 ;;
            *) warn "Unknown option: $1" ;;
        esac; shift
    done

    is_running "$game" && die "Server ${game} is already running"

    local sdir; sdir="$(server_dir "$game")"
    if [[ ! -d "$sdir" ]] || [[ "$game" != "minecraft" && ! -f "${sdir}/.installed" ]]; then
        msg "Installing ${GAME_DESC[$game]}..."
        install_game_server "$game"
        touch "${sdir}/.installed"
    fi

    # Determine port
    local base_port="${custom_port:-${GAME_PORT[$game]}}"
    local port; port="$(find_available_port "$base_port")"
    echo "$port" > "${sdir}/.port"

    # Open firewall
    open_firewall "$port" "${GAME_PROTOCOL[$game]}"

    # Build launch command
    local cmd; cmd="$(build_launch_cmd "$game" "$port")"
    local logf; logf="$(log_file "$game")"

    msg "Starting ${GAME_DESC[$game]} on port ${port}..."

    # Launch with systemd-run for cgroup limits if available
    if command -v systemd-run &>/dev/null; then
        local ram="${GAME_RAM[$game]}"
        systemd-run --user --scope \
            --unit="forge-server-${game}" \
            -p MemoryMax="${ram}M" \
            bash -c "cd '${sdir}' && exec ${cmd}" \
            >> "$logf" 2>&1 &
        local server_pid=$!
    else
        (cd "$sdir" && exec $cmd) >> "$logf" 2>&1 &
        local server_pid=$!
        apply_resource_limits "$game" "$server_pid"
    fi

    echo "$server_pid" > "$(pid_file "$game")"

    # Wait briefly to verify it started
    sleep 2
    if ! kill -0 "$server_pid" 2>/dev/null; then
        err "Server failed to start. Check logs: $logf"
        rm -f "$(pid_file "$game")"
        return 1
    fi

    msg "${GREEN}${GAME_DESC[$game]} is running!${NC}"
    msg "Port: ${port} | PID: ${server_pid} | Log: ${logf}"

    # Auto-save every 15 minutes
    (
        while kill -0 "$server_pid" 2>/dev/null; do
            sleep 900
            do_save "$game" 2>/dev/null || true
        done
    ) &
    echo $! > "${sdir}/.autosave.pid"

    # Start idle monitor
    if (( no_idle == 0 )); then
        start_idle_monitor "$game" "$port" "$idle_timeout"
        msg "Idle shutdown: ${idle_timeout}s (disable with --no-idle)"
    fi

    # Generate invite
    local ip; ip="$(get_public_ip)"
    echo ""
    if [[ "${GAME_STEAM_CONNECT[$game]}" == "1" ]]; then
        echo -e "  ${BOLD}Connect:${NC} steam://connect/${ip}:${port}"
    else
        echo -e "  ${BOLD}Connect:${NC} ${ip}:${port}"
    fi
    register_relay "$game" "$port" "$ip" >/dev/null 2>&1 || true
}

do_stop() {
    local game="${1:-}"
    if [[ -z "$game" ]]; then
        # Stop all running servers
        local stopped=0
        for g in "${SUPPORTED_GAMES[@]}"; do
            if is_running "$g"; then
                do_stop "$g"
                stopped=$((stopped + 1))
            fi
        done
        (( stopped == 0 )) && msg "No servers running"
        return
    fi

    valid_game "$game" || die "Unknown game: $game"
    is_running "$game" || { warn "Server ${game} is not running"; return 0; }

    local pf; pf="$(pid_file "$game")"
    local pid; pid="$(cat "$pf")"
    local sdir; sdir="$(server_dir "$game")"
    local port; port=$(cat "${sdir}/.port" 2>/dev/null || echo "${GAME_PORT[$game]}")

    msg "Saving before shutdown..."
    do_save "$game" 2>/dev/null || true

    # Kill idle monitor and autosave
    for helper in .idle_monitor.pid .autosave.pid; do
        [[ -f "${sdir}/${helper}" ]] && kill "$(cat "${sdir}/${helper}")" 2>/dev/null || true
        rm -f "${sdir}/${helper}"
    done

    # Graceful shutdown
    msg "Stopping ${GAME_DESC[$game]} (PID ${pid})..."
    kill -TERM "$pid" 2>/dev/null || true
    local waited=0
    while kill -0 "$pid" 2>/dev/null && (( waited < 30 )); do
        sleep 1; waited=$((waited + 1))
    done
    kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
    rm -f "$pf"

    close_firewall "$port" "${GAME_PROTOCOL[$game]}"
    msg "${GAME_DESC[$game]} stopped"
}

do_status() {
    echo -e "${BOLD}${CYAN}=== Forge Server Status ===${NC}"
    echo ""

    local any_running=0
    for game in "${SUPPORTED_GAMES[@]}"; do
        local sdir; sdir="$(server_dir "$game")"
        [[ -d "$sdir" ]] || continue

        if is_running "$game"; then
            any_running=1
            local pid; pid="$(cat "$(pid_file "$game")")"
            local port; port=$(cat "${sdir}/.port" 2>/dev/null || echo "${GAME_PORT[$game]}")
            local cpu mem
            cpu=$(ps -p "$pid" -o %cpu= 2>/dev/null || echo "?")
            mem=$(ps -p "$pid" -o rss= 2>/dev/null || echo "0")
            mem=$(( ${mem:-0} / 1024 ))
            local uptime_s; uptime_s=$(ps -p "$pid" -o etimes= 2>/dev/null || echo "0")
            local uptime_h=$(( ${uptime_s:-0} / 3600 ))
            local uptime_m=$(( (${uptime_s:-0} % 3600) / 60 ))

            echo -e "  ${GREEN}●${NC} ${BOLD}${GAME_DESC[$game]}${NC}"
            printf "    Port: %-8s  PID: %-8s  CPU: %s%%  RAM: %sMB  Up: %dh%02dm\n" \
                "$port" "$pid" "${cpu// /}" "$mem" "$uptime_h" "$uptime_m"
        else
            echo -e "  ${RED}○${NC} ${GAME_DESC[$game]} — stopped"
        fi
    done

    (( any_running == 0 )) && echo "  No servers are currently running."
    echo ""

    # System resources
    local total_ram; total_ram=$(free -m | awk '/Mem:/{print $2}')
    local used_ram; used_ram=$(free -m | awk '/Mem:/{print $3}')
    local load; load=$(cat /proc/loadavg | cut -d' ' -f1-3)
    echo -e "  ${BOLD}System:${NC} RAM ${used_ram}/${total_ram}MB | Load: ${load} | CPUs: $(nproc)"
}

do_players() {
    local game="$1"
    valid_game "$game" || die "Unknown game: $game"
    is_running "$game" || die "Server ${game} is not running"

    local sdir; sdir="$(server_dir "$game")"
    local port; port=$(cat "${sdir}/.port" 2>/dev/null || echo "${GAME_PORT[$game]}")

    echo -e "${BOLD}${CYAN}=== Players on ${GAME_DESC[$game]} ===${NC}"
    echo ""

    # Try A2S_PLAYER query for Source/Steam servers
    python3 -c "
import socket, struct

def query_players(ip, port):
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.settimeout(3)
    try:
        # Challenge request
        s.sendto(b'\xff\xff\xff\xff\x55\xff\xff\xff\xff', (ip, port))
        data = s.recv(4096)
        if len(data) >= 9 and data[4] == 0x41:
            challenge = data[5:9]
            s.sendto(b'\xff\xff\xff\xff\x55' + challenge, (ip, port))
            data = s.recv(4096)
        if len(data) > 5 and data[4] == 0x44:
            count = data[5]
            print(f'  Players online: {count}')
            offset = 6
            for i in range(count):
                idx = data[offset]; offset += 1
                name_end = data.index(b'\x00', offset)
                name = data[offset:name_end].decode('utf-8', errors='replace')
                offset = name_end + 1
                score = struct.unpack_from('<i', data, offset)[0]; offset += 4
                duration = struct.unpack_from('<f', data, offset)[0]; offset += 4
                mins = int(duration) // 60
                print(f'  - {name:20s}  Score: {score:4d}  Time: {mins}m')
        else:
            print('  Unable to query players (server may not support A2S)')
    except Exception as e:
        print(f'  Query failed: {e}')
    finally:
        s.close()

query_players('127.0.0.1', $port)
" 2>/dev/null || echo "  Player query not available for this game type."
    echo ""
}

do_update() {
    local game="$1"
    valid_game "$game" || die "Unknown game: $game"
    is_running "$game" && die "Stop the server before updating: forge-one-click-server stop $game"

    if [[ "$game" == "minecraft" ]]; then
        local sdir; sdir="$(server_dir "$game")"
        rm -f "${sdir}/server.jar"
        install_minecraft_server "$sdir"
    else
        install_steamcmd
        local sdir; sdir="$(server_dir "$game")"
        msg "Updating ${GAME_DESC[$game]}..."
        "${STEAMCMD_DIR}/steamcmd.sh" +force_install_dir "$sdir" \
            +login anonymous +app_update "${GAME_APPID[$game]}" validate +quit \
            2>&1 | tail -5
    fi
    msg "${GAME_DESC[$game]} updated"
}

do_config() {
    local game="$1"
    valid_game "$game" || die "Unknown game: $game"
    local sdir; sdir="$(server_dir "$game")"
    [[ -d "$sdir" ]] || die "Server ${game} is not installed. Run: forge-one-click-server start $game"

    local cfg=""
    case "$game" in
        minecraft)   cfg="${sdir}/server.properties" ;;
        valheim)     cfg="${sdir}/start_server.sh" ;;
        terraria)    cfg="${sdir}/serverconfig.txt" ;;
        cs2)         cfg="${sdir}/game/csgo/cfg/server.cfg" ;;
        tf2)         cfg="${sdir}/tf/cfg/server.cfg" ;;
        rust)        cfg="${sdir}/server/rust/cfg/server.cfg" ;;
        7dtd)        cfg="${sdir}/serverconfig.xml" ;;
        zomboid)     cfg="${sdir}/Server/ForgeServer.ini" ;;
        satisfactory) cfg="${sdir}/FactoryGame/Saved/Config/LinuxServer/GameUserSettings.ini" ;;
        palworld)    cfg="${sdir}/Pal/Saved/Config/LinuxServer/PalWorldSettings.ini" ;;
    esac

    if [[ -n "$cfg" && -f "$cfg" ]]; then
        ${EDITOR:-nano} "$cfg"
    elif [[ -n "$cfg" ]]; then
        warn "Config file not found: $cfg"
        warn "Start the server once to generate default configs."
    fi
}

do_logs() {
    local game="$1"
    valid_game "$game" || die "Unknown game: $game"
    local logf; logf="$(log_file "$game")"
    if [[ -f "$logf" ]]; then
        tail -f "$logf"
    else
        die "No logs found for ${game}"
    fi
}

show_help() {
    cat <<HELPEOF
${BOLD}forge-one-click-server${NC} v${VERSION} — One-click game server hosting

${BOLD}USAGE${NC}
    forge-one-click-server <command> [options]

${BOLD}COMMANDS${NC}
    list                         List available game server templates
    start <game> [options]       Start a game server
    stop [game]                  Stop a server (or all if no game specified)
    status                       Show all servers and resource usage
    invite <game>                Generate shareable invite/connect links
    players <game>               Show connected players
    save <game>                  Force save and backup
    update <game>                Update server files
    config <game>                Edit server configuration
    logs <game>                  Tail server logs (Ctrl+C to exit)

${BOLD}START OPTIONS${NC}
    --port=PORT                  Use specific port (auto-detects if taken)
    --timeout=SECONDS            Idle shutdown timeout (default: 900)
    --no-idle                    Disable auto-shutdown on idle

${BOLD}SUPPORTED GAMES${NC}
    minecraft, valheim, terraria, cs2, tf2, rust,
    7dtd, zomboid, satisfactory, palworld

${BOLD}EXAMPLES${NC}
    forge-one-click-server start valheim
    forge-one-click-server start cs2 --port=27020
    forge-one-click-server invite rust
    forge-one-click-server stop

${BOLD}DATA LOCATION${NC}
    Server files:  ~/.local/share/forge/servers/<game>/
    Backups:       ~/.local/share/forge/servers/backups/
    Logs:          ~/.local/share/forge/servers/logs/
HELPEOF
}

# ── Main ────────────────────────────────────────────────────────────
main() {
    ensure_dirs
    local cmd="${1:-help}"; shift 2>/dev/null || true

    case "$cmd" in
        list)               do_list ;;
        start)              [[ $# -ge 1 ]] || die "Usage: forge-one-click-server start <game>"; do_start "$@" ;;
        stop)               do_stop "${1:-}" ;;
        status)             do_status ;;
        invite)             [[ $# -ge 1 ]] || die "Usage: forge-one-click-server invite <game>"; do_invite "$1" ;;
        players)            [[ $# -ge 1 ]] || die "Usage: forge-one-click-server players <game>"; do_players "$1" ;;
        save)               [[ $# -ge 1 ]] || die "Usage: forge-one-click-server save <game>"; do_save "$1" ;;
        update)             [[ $# -ge 1 ]] || die "Usage: forge-one-click-server update <game>"; do_update "$1" ;;
        config)             [[ $# -ge 1 ]] || die "Usage: forge-one-click-server config <game>"; do_config "$1" ;;
        logs)               [[ $# -ge 1 ]] || die "Usage: forge-one-click-server logs <game>"; do_logs "$1" ;;
        help|--help|-h)     show_help ;;
        version|--version)  echo "forge-one-click-server v${VERSION}" ;;
        *)                  die "Unknown command: $cmd. Run 'forge-one-click-server help'" ;;
    esac
}

main "$@"
