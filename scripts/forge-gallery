#!/bin/bash
# 24HG Forge Gallery — Auto-organize screenshots by game and share to the community
#
# Usage: forge-gallery <command> [args]
# Commands:
#   scan              Scan for screenshots and organize them by game
#   list [game]       List screenshots, optionally filtered by game
#   show <file>       Open a screenshot in the default image viewer
#   share <file>      Upload screenshot to Hub and get shareable link
#   share-album <game> Create and share a gallery album for a game
#   watch             Daemon that watches for new screenshots and auto-organizes
#   stats             Show screenshot statistics (count per game, total size, etc.)
#   cleanup           Remove duplicates and compress old screenshots

set -euo pipefail

# ── Paths & Config ──────────────────────────────────────────────────────────
GALLERY_DIR="$HOME/Pictures/24HG Gallery"
HUB_API="https://hub.24hgaming.com/api/gallery"
HUB_TOKEN_FILE="$HOME/.config/24hg/hub-token"
PID_FILE="/tmp/forge-gallery.pid"
MAX_UPLOAD_SIZE=$((5 * 1024 * 1024))  # 5MB
COMPRESS_AGE_DAYS=30
COMPRESS_QUALITY=85

# Screenshot source directories
SCREENSHOT_SOURCES=(
    "$HOME/Pictures/Screenshots"
    "$HOME/Pictures/Lutris"
    "$HOME/Pictures/Heroic"
    "$HOME/Videos/24HG Clips"
)
STEAM_SCREENSHOTS_GLOB="$HOME/.local/share/Steam/userdata/*/760/remote/*/screenshots"

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Logging ─────────────────────────────────────────────────────────────────
log() {
    logger -t forge-gallery "$*"
}

info() {
    echo -e "${CYAN}[INFO]${RESET} $*"
    log "INFO: $*"
}

success() {
    echo -e "${GREEN}[OK]${RESET} $*"
    log "OK: $*"
}

warn() {
    echo -e "${YELLOW}[WARN]${RESET} $*"
    log "WARN: $*"
}

error() {
    echo -e "${RED}[ERROR]${RESET} $*" >&2
    log "ERROR: $*"
}

# ── Steam App ID → Game Name Mapping ───────────────────────────────────────
# Common Steam app IDs; extended by scanning local appmanifests
declare -A STEAM_APPS=(
    [730]="Counter-Strike 2"
    [440]="Team Fortress 2"
    [252490]="Rust"
    [578080]="PUBG"
    [1172470]="Apex Legends"
    [570]="Dota 2"
    [304930]="Unturned"
    [346110]="ARK Survival Evolved"
    [892970]="Valheim"
    [1604030]="V Rising"
    [413150]="Stardew Valley"
    [105600]="Terraria"
    [322330]="Don't Starve Together"
    [251570]="7 Days to Die"
    [393380]="Squad"
    [1063730]="New World"
    [271590]="Grand Theft Auto V"
    [1245620]="Elden Ring"
    [1091500]="Cyberpunk 2077"
    [814380]="Sekiro"
    [374320]="Dark Souls III"
    [1174180]="Red Dead Redemption 2"
    [275850]="No Man's Sky"
    [1085660]="Destiny 2"
    [218620]="Payday 2"
    [359550]="Tom Clancy's Rainbow Six Siege"
    [236390]="War Thunder"
    [1938090]="Call of Duty"
    [1517290]="Battlefield 2042"
    [489830]="The Elder Scrolls V Skyrim SE"
    [292030]="The Witcher 3"
    [1293830]="Forza Horizon 5"
)

# ── Helpers ─────────────────────────────────────────────────────────────────
get_hub_token() {
    if [[ -f "$HUB_TOKEN_FILE" ]]; then
        cat "$HUB_TOKEN_FILE"
    else
        error "Hub token not found at $HUB_TOKEN_FILE"
        echo "Run: mkdir -p ~/.config/24hg && echo 'YOUR_TOKEN' > ~/.config/24hg/hub-token"
        return 1
    fi
}

populate_steam_apps() {
    # Scan local Steam library for appmanifest files to extend the mapping
    local steam_dir="$HOME/.local/share/Steam/steamapps"
    if [[ -d "$steam_dir" ]]; then
        while IFS= read -r manifest; do
            local appid name
            appid=$(grep -oP '"appid"\s+"\K[0-9]+' "$manifest" 2>/dev/null || true)
            name=$(grep -oP '"name"\s+"\K[^"]+' "$manifest" 2>/dev/null || true)
            if [[ -n "$appid" && -n "$name" ]]; then
                STEAM_APPS[$appid]="$name"
            fi
        done < <(find "$steam_dir" -maxdepth 1 -name 'appmanifest_*.acf' 2>/dev/null)
    fi
}

resolve_steam_game() {
    # Given a Steam screenshot path, extract app ID and resolve game name
    local filepath="$1"
    local appid
    appid=$(echo "$filepath" | grep -oP '/760/remote/\K[0-9]+' || true)
    if [[ -n "$appid" && -n "${STEAM_APPS[$appid]:-}" ]]; then
        echo "${STEAM_APPS[$appid]}"
    elif [[ -n "$appid" ]]; then
        echo "Steam Game $appid"
    else
        echo ""
    fi
}

detect_game_from_filename() {
    # Try to identify a game from the filename or path
    local filepath="$1"
    local basename
    basename=$(basename "$filepath")
    local dirpath
    dirpath=$(dirname "$filepath")

    # Lutris: directory name is often the game name
    if [[ "$dirpath" == *"/Lutris/"* ]]; then
        local game
        game=$(echo "$dirpath" | sed "s|.*Lutris/||" | cut -d'/' -f1)
        if [[ -n "$game" ]]; then
            echo "$game"
            return
        fi
    fi

    # Heroic: directory name is often the game name
    if [[ "$dirpath" == *"/Heroic/"* ]]; then
        local game
        game=$(echo "$dirpath" | sed "s|.*Heroic/||" | cut -d'/' -f1)
        if [[ -n "$game" ]]; then
            echo "$game"
            return
        fi
    fi

    # Clip thumbnails
    if [[ "$dirpath" == *"24HG Clips"* ]]; then
        echo "Clips"
        return
    fi

    # Try EXIF window title if exiftool is available
    if command -v exiftool &>/dev/null; then
        local title
        title=$(exiftool -s3 -XPTitle "$filepath" 2>/dev/null || true)
        if [[ -n "$title" ]]; then
            echo "$title"
            return
        fi
    fi

    # Filename heuristic: look for known game name substrings
    local lower_name
    lower_name=$(echo "$basename" | tr '[:upper:]' '[:lower:]')
    declare -A NAME_PATTERNS=(
        ["rust"]="Rust"
        ["csgo"]="Counter-Strike 2"
        ["cs2"]="Counter-Strike 2"
        ["tf2"]="Team Fortress 2"
        ["valheim"]="Valheim"
        ["minecraft"]="Minecraft"
        ["apex"]="Apex Legends"
        ["dota"]="Dota 2"
        ["pubg"]="PUBG"
        ["gta"]="Grand Theft Auto V"
        ["cyberpunk"]="Cyberpunk 2077"
        ["eldenring"]="Elden Ring"
        ["elden_ring"]="Elden Ring"
        ["witcher"]="The Witcher 3"
        ["skyrim"]="Skyrim"
        ["terraria"]="Terraria"
        ["stardew"]="Stardew Valley"
        ["forza"]="Forza Horizon 5"
    )

    for pattern in "${!NAME_PATTERNS[@]}"; do
        if [[ "$lower_name" == *"$pattern"* ]]; then
            echo "${NAME_PATTERNS[$pattern]}"
            return
        fi
    done

    echo ""
}

detect_game() {
    # Main game detection: tries Steam path, then filename, then fallback
    local filepath="$1"

    # Steam screenshot path detection
    if [[ "$filepath" == *"/760/remote/"* ]]; then
        local game
        game=$(resolve_steam_game "$filepath")
        if [[ -n "$game" ]]; then
            echo "$game"
            return
        fi
    fi

    # Filename / path heuristic
    local game
    game=$(detect_game_from_filename "$filepath")
    if [[ -n "$game" ]]; then
        echo "$game"
        return
    fi

    echo "Unknown"
}

is_image() {
    local file="$1"
    local ext="${file##*.}"
    ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
    case "$ext" in
        png|jpg|jpeg|bmp|webp|tiff|tif) return 0 ;;
        *) return 1 ;;
    esac
}

get_image_resolution() {
    local file="$1"
    if command -v identify &>/dev/null; then
        identify -format "%wx%h" "$file" 2>/dev/null || echo "unknown"
    elif command -v exiftool &>/dev/null; then
        local w h
        w=$(exiftool -s3 -ImageWidth "$file" 2>/dev/null || echo "?")
        h=$(exiftool -s3 -ImageHeight "$file" 2>/dev/null || echo "?")
        echo "${w}x${h}"
    else
        echo "unknown"
    fi
}

human_size() {
    local bytes="$1"
    if (( bytes >= 1073741824 )); then
        printf "%.1f GB" "$(echo "scale=1; $bytes/1073741824" | bc)"
    elif (( bytes >= 1048576 )); then
        printf "%.1f MB" "$(echo "scale=1; $bytes/1048576" | bc)"
    elif (( bytes >= 1024 )); then
        printf "%.1f KB" "$(echo "scale=1; $bytes/1024" | bc)"
    else
        printf "%d B" "$bytes"
    fi
}

sanitize_dirname() {
    # Make a string safe for use as a directory name
    echo "$1" | sed 's/[^a-zA-Z0-9 _-]//g' | sed 's/  */ /g' | sed 's/^ *//;s/ *$//'
}

collect_source_files() {
    # Gather all screenshot files from all sources
    local files=()

    for src in "${SCREENSHOT_SOURCES[@]}"; do
        if [[ -d "$src" ]]; then
            while IFS= read -r f; do
                if is_image "$f"; then
                    files+=("$f")
                fi
            done < <(find "$src" -type f 2>/dev/null)
        fi
    done

    # Steam screenshots (glob expansion)
    while IFS= read -r steam_dir; do
        if [[ -d "$steam_dir" ]]; then
            while IFS= read -r f; do
                if is_image "$f"; then
                    files+=("$f")
                fi
            done < <(find "$steam_dir" -type f 2>/dev/null)
        fi
    done < <(eval echo "$STEAM_SCREENSHOTS_GLOB" 2>/dev/null | tr ' ' '\n')

    printf '%s\n' "${files[@]}"
}

write_index_json() {
    local game_dir="$1"
    local game_name="$2"
    local index_file="$game_dir/index.json"
    local entries=()

    while IFS= read -r img; do
        [[ -z "$img" ]] && continue
        local fname fsize ftime resolution
        fname=$(basename "$img")
        fsize=$(stat -c%s "$img" 2>/dev/null || echo 0)
        ftime=$(stat -c%Y "$img" 2>/dev/null || echo 0)
        resolution=$(get_image_resolution "$img")
        entries+=("{\"filename\":\"$fname\",\"timestamp\":$ftime,\"game\":\"$game_name\",\"resolution\":\"$resolution\",\"size\":$fsize}")
    done < <(find "$game_dir" -maxdepth 1 -type f \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' -o -iname '*.bmp' \) | sort)

    local joined
    joined=$(printf ',%s' "${entries[@]}")
    joined="${joined:1}"  # remove leading comma

    echo "[${joined}]" > "$index_file"
}

compress_for_upload() {
    # Compress image if >5MB, returns path to use for upload
    local filepath="$1"
    local fsize
    fsize=$(stat -c%s "$filepath" 2>/dev/null || echo 0)

    if (( fsize > MAX_UPLOAD_SIZE )); then
        if command -v convert &>/dev/null; then
            local tmpfile
            tmpfile=$(mktemp /tmp/forge-gallery-upload-XXXXXX.jpg)
            convert "$filepath" -quality "$COMPRESS_QUALITY" -strip "$tmpfile" 2>/dev/null
            echo "$tmpfile"
            return
        fi
    fi
    echo "$filepath"
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_scan() {
    info "Scanning screenshot sources..."
    populate_steam_apps
    mkdir -p "$GALLERY_DIR"

    local total=0
    local organized=0
    local unknown_files=()

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        total=$((total + 1))

        local game
        game=$(detect_game "$filepath")
        local safe_game
        safe_game=$(sanitize_dirname "$game")

        if [[ "$safe_game" == "Unknown" ]]; then
            unknown_files+=("$filepath")
        fi

        local game_dir="$GALLERY_DIR/$safe_game"
        mkdir -p "$game_dir"

        local dest="$game_dir/$(basename "$filepath")"
        if [[ ! -e "$dest" ]]; then
            # Create symlink to avoid duplicating storage
            ln -sf "$filepath" "$dest" 2>/dev/null || cp -n "$filepath" "$dest" 2>/dev/null || true
            organized=$((organized + 1))
        fi
    done < <(collect_source_files)

    # Generate index.json for each game directory
    while IFS= read -r game_dir; do
        [[ -z "$game_dir" ]] && continue
        local gname
        gname=$(basename "$game_dir")
        write_index_json "$game_dir" "$gname"
    done < <(find "$GALLERY_DIR" -mindepth 1 -maxdepth 1 -type d | sort)

    success "Scanned $total screenshots, organized $organized new files"

    if (( ${#unknown_files[@]} > 0 )); then
        warn "${#unknown_files[@]} screenshot(s) could not be matched to a game (filed under 'Unknown')"
        echo -e "${DIM}  Run 'forge-gallery list Unknown' to see them, then move to the correct game folder${RESET}"
    fi
}

cmd_list() {
    local filter="${1:-}"

    if [[ ! -d "$GALLERY_DIR" ]]; then
        warn "Gallery not found. Run 'forge-gallery scan' first."
        return 1
    fi

    if [[ -n "$filter" ]]; then
        # List screenshots for a specific game
        local game_dir="$GALLERY_DIR/$filter"
        if [[ ! -d "$game_dir" ]]; then
            error "No gallery found for game: $filter"
            echo "Available games:"
            find "$GALLERY_DIR" -mindepth 1 -maxdepth 1 -type d -printf '  %f\n' | sort
            return 1
        fi

        echo -e "${BOLD}${CYAN}Screenshots — $filter${RESET}"
        echo ""
        printf "${BOLD}%-40s  %-12s  %-10s  %s${RESET}\n" "Filename" "Resolution" "Size" "Date"
        echo "────────────────────────────────────────────────────────────────────────────────"

        while IFS= read -r img; do
            [[ -z "$img" ]] && continue
            local fname fsize ftime resolution hsize fdate
            fname=$(basename "$img")
            fsize=$(stat -c%s "$img" 2>/dev/null || echo 0)
            ftime=$(stat -c%Y "$img" 2>/dev/null || echo 0)
            fdate=$(date -d "@$ftime" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")
            resolution=$(get_image_resolution "$img")
            hsize=$(human_size "$fsize")

            # Truncate filename if too long
            if (( ${#fname} > 38 )); then
                fname="${fname:0:35}..."
            fi

            printf "%-40s  %-12s  %-10s  %s\n" "$fname" "$resolution" "$hsize" "$fdate"
        done < <(find "$game_dir" -maxdepth 1 -type f -o -type l | grep -iE '\.(png|jpg|jpeg|webp|bmp)$' | sort)
    else
        # List all games
        echo -e "${BOLD}${CYAN}24HG Forge Gallery${RESET}"
        echo ""
        printf "${BOLD}%-30s  %-8s  %-12s  %s${RESET}\n" "Game" "Count" "Total Size" "Last Screenshot"
        echo "────────────────────────────────────────────────────────────────────────────────"

        while IFS= read -r game_dir; do
            [[ -z "$game_dir" ]] && continue
            local gname count total_size latest latest_date hsize
            gname=$(basename "$game_dir")
            count=0
            total_size=0
            latest=0

            while IFS= read -r img; do
                [[ -z "$img" ]] && continue
                count=$((count + 1))
                local fsize ftime
                fsize=$(stat -c%s "$img" 2>/dev/null || echo 0)
                ftime=$(stat -c%Y "$img" 2>/dev/null || echo 0)
                total_size=$((total_size + fsize))
                if (( ftime > latest )); then
                    latest=$ftime
                fi
            done < <(find "$game_dir" -maxdepth 1 \( -type f -o -type l \) 2>/dev/null | grep -iE '\.(png|jpg|jpeg|webp|bmp)$')

            if (( count == 0 )); then
                continue
            fi

            hsize=$(human_size "$total_size")
            if (( latest > 0 )); then
                latest_date=$(date -d "@$latest" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")
            else
                latest_date="—"
            fi

            # Truncate game name if too long
            if (( ${#gname} > 28 )); then
                gname="${gname:0:25}..."
            fi

            printf "%-30s  ${GREEN}%-8s${RESET}  %-12s  %s\n" "$gname" "$count" "$hsize" "$latest_date"
        done < <(find "$GALLERY_DIR" -mindepth 1 -maxdepth 1 -type d | sort)
    fi
}

cmd_show() {
    local file="${1:-}"
    if [[ -z "$file" ]]; then
        error "Usage: forge-gallery show <file>"
        return 1
    fi

    # If not an absolute path, search in the gallery
    if [[ "$file" != /* ]]; then
        local found
        found=$(find "$GALLERY_DIR" -name "$file" -print -quit 2>/dev/null || true)
        if [[ -n "$found" ]]; then
            file="$found"
        else
            error "File not found: $file"
            return 1
        fi
    fi

    if [[ ! -f "$file" ]]; then
        error "File not found: $file"
        return 1
    fi

    info "Opening: $file"

    # Try various image viewers
    if command -v xdg-open &>/dev/null; then
        xdg-open "$file" &
    elif command -v gwenview &>/dev/null; then
        gwenview "$file" &
    elif command -v eog &>/dev/null; then
        eog "$file" &
    elif command -v feh &>/dev/null; then
        feh "$file" &
    else
        error "No image viewer found. Install gwenview, eog, or feh."
        return 1
    fi
}

cmd_share() {
    local file="${1:-}"
    if [[ -z "$file" ]]; then
        error "Usage: forge-gallery share <file>"
        return 1
    fi

    # If not an absolute path, search in the gallery
    if [[ "$file" != /* ]]; then
        local found
        found=$(find "$GALLERY_DIR" -name "$file" -print -quit 2>/dev/null || true)
        if [[ -n "$found" ]]; then
            file="$found"
        else
            error "File not found: $file"
            return 1
        fi
    fi

    if [[ ! -f "$file" ]]; then
        error "File not found: $file"
        return 1
    fi

    local token
    token=$(get_hub_token) || return 1

    info "Preparing upload: $(basename "$file")"

    # Compress if necessary
    local upload_file
    upload_file=$(compress_for_upload "$file")
    local cleanup_tmp=false
    if [[ "$upload_file" != "$file" ]]; then
        cleanup_tmp=true
        info "Compressed for upload (original > 5MB)"
    fi

    info "Uploading to Hub..."
    local response
    response=$(curl -s -w "\n%{http_code}" \
        -X POST "$HUB_API/upload" \
        -H "Authorization: Bearer $token" \
        -F "screenshot=@$upload_file" \
        -F "filename=$(basename "$file")" \
        -F "game=$(detect_game "$file")" \
        2>/dev/null) || {
        error "Upload failed — could not connect to Hub"
        [[ "$cleanup_tmp" == true ]] && rm -f "$upload_file"
        return 1
    }

    local http_code body
    http_code=$(echo "$response" | tail -1)
    body=$(echo "$response" | sed '$d')

    [[ "$cleanup_tmp" == true ]] && rm -f "$upload_file"

    if [[ "$http_code" == "200" || "$http_code" == "201" ]]; then
        local url
        url=$(echo "$body" | grep -oP '"url"\s*:\s*"\K[^"]+' || echo "$body")
        success "Uploaded! Share link:"
        echo -e "  ${BOLD}${GREEN}$url${RESET}"
        log "Shared screenshot: $(basename "$file") -> $url"
    else
        error "Upload failed (HTTP $http_code)"
        echo "$body"
        return 1
    fi
}

cmd_share_album() {
    local game="${1:-}"
    if [[ -z "$game" ]]; then
        error "Usage: forge-gallery share-album <game>"
        return 1
    fi

    local game_dir="$GALLERY_DIR/$game"
    if [[ ! -d "$game_dir" ]]; then
        error "No gallery found for game: $game"
        return 1
    fi

    local token
    token=$(get_hub_token) || return 1

    local files=()
    while IFS= read -r img; do
        [[ -z "$img" ]] && continue
        files+=("$img")
    done < <(find "$game_dir" -maxdepth 1 \( -type f -o -type l \) 2>/dev/null | grep -iE '\.(png|jpg|jpeg|webp|bmp)$' | sort)

    if (( ${#files[@]} == 0 )); then
        warn "No screenshots found for $game"
        return 1
    fi

    info "Creating album for $game (${#files[@]} screenshots)..."

    # Build curl file arguments
    local curl_args=()
    curl_args+=(-X POST "$HUB_API/album")
    curl_args+=(-H "Authorization: Bearer $token")
    curl_args+=(-F "game=$game")
    curl_args+=(-F "title=$game Screenshots")

    local tmpfiles=()
    for img in "${files[@]}"; do
        local upload_file
        upload_file=$(compress_for_upload "$img")
        if [[ "$upload_file" != "$img" ]]; then
            tmpfiles+=("$upload_file")
        fi
        curl_args+=(-F "screenshots[]=@$upload_file")
    done

    local response
    response=$(curl -s -w "\n%{http_code}" "${curl_args[@]}" 2>/dev/null) || {
        error "Album creation failed — could not connect to Hub"
        for tmp in "${tmpfiles[@]}"; do rm -f "$tmp"; done
        return 1
    }

    local http_code body
    http_code=$(echo "$response" | tail -1)
    body=$(echo "$response" | sed '$d')

    # Clean up temp files
    for tmp in "${tmpfiles[@]}"; do rm -f "$tmp"; done

    if [[ "$http_code" == "200" || "$http_code" == "201" ]]; then
        local url
        url=$(echo "$body" | grep -oP '"url"\s*:\s*"\K[^"]+' || echo "$body")
        success "Album created! Share link:"
        echo -e "  ${BOLD}${GREEN}$url${RESET}"
        log "Shared album: $game (${#files[@]} screenshots) -> $url"
    else
        error "Album creation failed (HTTP $http_code)"
        echo "$body"
        return 1
    fi
}

cmd_watch() {
    if ! command -v inotifywait &>/dev/null; then
        error "inotifywait not found. Install inotify-tools:"
        echo "  sudo dnf install inotify-tools   # Fedora/Bazzite"
        echo "  sudo apt install inotify-tools    # Debian/Ubuntu"
        return 1
    fi

    # Check if already running
    if [[ -f "$PID_FILE" ]]; then
        local existing_pid
        existing_pid=$(cat "$PID_FILE")
        if kill -0 "$existing_pid" 2>/dev/null; then
            warn "Watch daemon already running (PID $existing_pid)"
            echo "  Stop it with: kill $existing_pid"
            return 1
        else
            rm -f "$PID_FILE"
        fi
    fi

    populate_steam_apps
    mkdir -p "$GALLERY_DIR"

    # Build list of directories to watch
    local watch_dirs=()
    for src in "${SCREENSHOT_SOURCES[@]}"; do
        if [[ -d "$src" ]]; then
            watch_dirs+=("$src")
        fi
    done
    while IFS= read -r steam_dir; do
        if [[ -d "$steam_dir" ]]; then
            watch_dirs+=("$steam_dir")
        fi
    done < <(eval echo "$STEAM_SCREENSHOTS_GLOB" 2>/dev/null | tr ' ' '\n')

    if (( ${#watch_dirs[@]} == 0 )); then
        error "No screenshot directories found to watch"
        return 1
    fi

    info "Starting watch daemon on ${#watch_dirs[@]} directories..."
    for d in "${watch_dirs[@]}"; do
        echo -e "  ${DIM}$d${RESET}"
    done

    # Write PID
    echo $$ > "$PID_FILE"
    log "Watch daemon started (PID $$)"

    trap 'rm -f "$PID_FILE"; log "Watch daemon stopped"; exit 0' INT TERM

    # Build inotifywait args
    local inotify_args=(-m -r -e create -e moved_to --format '%w%f')
    for d in "${watch_dirs[@]}"; do
        inotify_args+=("$d")
    done

    inotifywait "${inotify_args[@]}" 2>/dev/null | while IFS= read -r new_file; do
        # Small delay to let the file finish writing
        sleep 0.5

        if ! is_image "$new_file"; then
            continue
        fi

        if [[ ! -f "$new_file" ]]; then
            continue
        fi

        local game
        game=$(detect_game "$new_file")
        local safe_game
        safe_game=$(sanitize_dirname "$game")
        local game_dir="$GALLERY_DIR/$safe_game"
        mkdir -p "$game_dir"

        local dest="$game_dir/$(basename "$new_file")"
        ln -sf "$new_file" "$dest" 2>/dev/null || cp -n "$new_file" "$dest" 2>/dev/null || true

        # Update index
        write_index_json "$game_dir" "$safe_game"

        log "Auto-organized: $(basename "$new_file") -> $safe_game"

        # Desktop notification with thumbnail
        if command -v notify-send &>/dev/null; then
            notify-send -i "$new_file" \
                "Screenshot saved — $game" \
                "$(basename "$new_file")\nClick to open gallery" \
                -a "Forge Gallery" \
                --hint=string:desktop-entry:forge-gallery \
                2>/dev/null || true
        fi
    done
}

cmd_stats() {
    if [[ ! -d "$GALLERY_DIR" ]]; then
        warn "Gallery not found. Run 'forge-gallery scan' first."
        return 1
    fi

    echo -e "${BOLD}${CYAN}24HG Forge Gallery — Statistics${RESET}"
    echo ""

    local total_count=0
    local total_size=0
    local game_count=0

    printf "${BOLD}%-30s  %-8s  %-12s  %-12s  %s${RESET}\n" "Game" "Count" "Total Size" "Avg Size" "Last Screenshot"
    echo "──────────────────────────────────────────────────────────────────────────────────────"

    while IFS= read -r game_dir; do
        [[ -z "$game_dir" ]] && continue
        local gname count gsize latest avg_size
        gname=$(basename "$game_dir")
        count=0
        gsize=0
        latest=0

        while IFS= read -r img; do
            [[ -z "$img" ]] && continue
            count=$((count + 1))
            local fsize ftime
            fsize=$(stat -c%s "$img" 2>/dev/null || echo 0)
            ftime=$(stat -c%Y "$img" 2>/dev/null || echo 0)
            gsize=$((gsize + fsize))
            if (( ftime > latest )); then
                latest=$ftime
            fi
        done < <(find "$game_dir" -maxdepth 1 \( -type f -o -type l \) 2>/dev/null | grep -iE '\.(png|jpg|jpeg|webp|bmp)$')

        if (( count == 0 )); then
            continue
        fi

        game_count=$((game_count + 1))
        total_count=$((total_count + count))
        total_size=$((total_size + gsize))

        local hsize havg latest_date
        hsize=$(human_size "$gsize")
        if (( count > 0 )); then
            avg_size=$((gsize / count))
        else
            avg_size=0
        fi
        havg=$(human_size "$avg_size")

        if (( latest > 0 )); then
            latest_date=$(date -d "@$latest" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")
        else
            latest_date="—"
        fi

        if (( ${#gname} > 28 )); then
            gname="${gname:0:25}..."
        fi

        printf "%-30s  ${GREEN}%-8s${RESET}  %-12s  %-12s  %s\n" "$gname" "$count" "$hsize" "$havg" "$latest_date"
    done < <(find "$GALLERY_DIR" -mindepth 1 -maxdepth 1 -type d | sort)

    echo "──────────────────────────────────────────────────────────────────────────────────────"
    local htotal
    htotal=$(human_size "$total_size")
    printf "${BOLD}%-30s  %-8s  %-12s${RESET}\n" "TOTAL ($game_count games)" "$total_count" "$htotal"
    echo ""

    # Source directory info
    echo -e "${BOLD}Screenshot Sources:${RESET}"
    for src in "${SCREENSHOT_SOURCES[@]}"; do
        if [[ -d "$src" ]]; then
            local src_count
            src_count=$(find "$src" -type f 2>/dev/null | grep -ciE '\.(png|jpg|jpeg|webp|bmp)$' || echo 0)
            echo -e "  ${GREEN}[active]${RESET} $src ($src_count files)"
        else
            echo -e "  ${DIM}[missing]${RESET} $src"
        fi
    done

    local steam_found=0
    while IFS= read -r steam_dir; do
        if [[ -d "$steam_dir" ]]; then
            steam_found=$((steam_found + 1))
        fi
    done < <(eval echo "$STEAM_SCREENSHOTS_GLOB" 2>/dev/null | tr ' ' '\n')
    if (( steam_found > 0 )); then
        echo -e "  ${GREEN}[active]${RESET} Steam screenshot directories ($steam_found found)"
    else
        echo -e "  ${DIM}[missing]${RESET} No Steam screenshot directories found"
    fi
}

cmd_cleanup() {
    if [[ ! -d "$GALLERY_DIR" ]]; then
        warn "Gallery not found. Run 'forge-gallery scan' first."
        return 1
    fi

    echo -e "${BOLD}${CYAN}24HG Forge Gallery — Cleanup${RESET}"
    echo ""

    # ── Phase 1: Find duplicates ────────────────────────────────────────────
    info "Phase 1: Scanning for duplicate screenshots..."

    local -A hash_map
    local duplicates=0
    local dup_size=0

    while IFS= read -r img; do
        [[ -z "$img" ]] && continue
        # Resolve symlinks to get real file for hashing
        local real_file
        real_file=$(readlink -f "$img" 2>/dev/null || echo "$img")
        local hash
        hash=$(md5sum "$real_file" 2>/dev/null | cut -d' ' -f1 || continue)

        if [[ -n "${hash_map[$hash]:-}" ]]; then
            # Duplicate found — remove the gallery symlink/copy, keep the original
            local fsize
            fsize=$(stat -c%s "$img" 2>/dev/null || echo 0)
            echo -e "  ${RED}DUP${RESET} $(basename "$img") ${DIM}(same as $(basename "${hash_map[$hash]}"))${RESET}"
            rm -f "$img"
            duplicates=$((duplicates + 1))
            dup_size=$((dup_size + fsize))
        else
            hash_map[$hash]="$img"
        fi
    done < <(find "$GALLERY_DIR" -maxdepth 2 \( -type f -o -type l \) 2>/dev/null | grep -iE '\.(png|jpg|jpeg|webp|bmp)$' | sort)

    if (( duplicates > 0 )); then
        success "Removed $duplicates duplicate(s), freed $(human_size $dup_size)"
    else
        info "No duplicates found"
    fi

    # ── Phase 2: Compress old PNGs ──────────────────────────────────────────
    info "Phase 2: Compressing old PNG screenshots (>$COMPRESS_AGE_DAYS days)..."

    if ! command -v convert &>/dev/null; then
        warn "ImageMagick not found — skipping compression"
        echo "  Install with: sudo dnf install ImageMagick"
    else
        local compressed=0
        local saved_bytes=0

        while IFS= read -r img; do
            [[ -z "$img" ]] && continue
            # Only compress real files, not symlinks
            if [[ -L "$img" ]]; then
                continue
            fi

            local ext="${img##*.}"
            ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
            if [[ "$ext" != "png" ]]; then
                continue
            fi

            local original_size
            original_size=$(stat -c%s "$img" 2>/dev/null || echo 0)
            local jpg_file="${img%.png}.jpg"

            convert "$img" -quality "$COMPRESS_QUALITY" -strip "$jpg_file" 2>/dev/null || continue

            local new_size
            new_size=$(stat -c%s "$jpg_file" 2>/dev/null || echo 0)

            if (( new_size < original_size )); then
                local savings=$((original_size - new_size))
                saved_bytes=$((saved_bytes + savings))
                rm -f "$img"
                compressed=$((compressed + 1))
                echo -e "  ${GREEN}COMPRESS${RESET} $(basename "$img") -> $(basename "$jpg_file") ${DIM}(saved $(human_size $savings))${RESET}"
            else
                # JPEG is larger, keep original PNG
                rm -f "$jpg_file"
            fi
        done < <(find "$GALLERY_DIR" -maxdepth 2 -type f -iname '*.png' -mtime +"$COMPRESS_AGE_DAYS" 2>/dev/null)

        if (( compressed > 0 )); then
            success "Compressed $compressed file(s), saved $(human_size $saved_bytes)"
        else
            info "No old PNGs to compress"
        fi
    fi

    # ── Phase 3: Remove empty directories ───────────────────────────────────
    info "Phase 3: Cleaning up empty directories..."
    local removed_dirs=0
    while IFS= read -r d; do
        [[ -z "$d" ]] && continue
        # Check if directory has any image files
        local img_count
        img_count=$(find "$d" -maxdepth 1 \( -type f -o -type l \) 2>/dev/null | grep -ciE '\.(png|jpg|jpeg|webp|bmp)$' || echo 0)
        if (( img_count == 0 )); then
            rm -rf "$d"
            removed_dirs=$((removed_dirs + 1))
            echo -e "  ${DIM}Removed empty: $(basename "$d")${RESET}"
        fi
    done < <(find "$GALLERY_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)

    if (( removed_dirs > 0 )); then
        success "Removed $removed_dirs empty directories"
    fi

    # Regenerate indexes
    info "Regenerating index files..."
    while IFS= read -r game_dir; do
        [[ -z "$game_dir" ]] && continue
        local gname
        gname=$(basename "$game_dir")
        write_index_json "$game_dir" "$gname"
    done < <(find "$GALLERY_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)

    echo ""
    success "Cleanup complete"
}

usage() {
    echo -e "${BOLD}${CYAN}24HG Forge Gallery${RESET} — Auto-organize screenshots by game and share to the community"
    echo ""
    echo -e "${BOLD}Usage:${RESET} forge-gallery <command> [args]"
    echo ""
    echo -e "${BOLD}Commands:${RESET}"
    echo -e "  ${GREEN}scan${RESET}                Scan for screenshots and organize them by game"
    echo -e "  ${GREEN}list${RESET} [game]          List screenshots, optionally filtered by game"
    echo -e "  ${GREEN}show${RESET} <file>          Open a screenshot in the default image viewer"
    echo -e "  ${GREEN}share${RESET} <file>         Upload screenshot to Hub and get shareable link"
    echo -e "  ${GREEN}share-album${RESET} <game>   Create and share a gallery album for a game"
    echo -e "  ${GREEN}watch${RESET}               Daemon that watches for new screenshots and auto-organizes"
    echo -e "  ${GREEN}stats${RESET}               Show screenshot statistics"
    echo -e "  ${GREEN}cleanup${RESET}             Remove duplicates and compress old screenshots"
    echo ""
    echo -e "${BOLD}Gallery:${RESET}   ~/Pictures/24HG Gallery/"
    echo -e "${BOLD}Sources:${RESET}   KDE/Spectacle, Steam, Lutris, Heroic, 24HG Clips"
    echo ""
    echo -e "${DIM}Screenshots are organized by game into folders with symlinks to originals.${RESET}"
    echo -e "${DIM}Each game folder contains an index.json with metadata.${RESET}"
}

# ── Main ────────────────────────────────────────────────────────────────────
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    scan)        cmd_scan "$@" ;;
    list)        cmd_list "$@" ;;
    show)        cmd_show "$@" ;;
    share)       cmd_share "$@" ;;
    share-album) cmd_share_album "$@" ;;
    watch)       cmd_watch "$@" ;;
    stats)       cmd_stats "$@" ;;
    cleanup)     cmd_cleanup "$@" ;;
    help|--help|-h)
        usage ;;
    *)
        error "Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
