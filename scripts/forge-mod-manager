# Reverse lookup: lowercase game name -> app ID
declare -A GAME_NAME_TO_ID=()

# ─────────────────────────────────────────────────────────────────────
# Output Helpers
# ─────────────────────────────────────────────────────────────────────

info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
header()  { echo -e "\n${BOLD}${CYAN}── $* ──${NC}"; }
detail()  { echo -e "  ${DIM}→${NC} $*"; }

spinner() {
    local pid=$1 msg="${2:-Working...}"
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CYAN}%s${NC} %s" "${frames[i]}" "$msg"
        i=$(( (i + 1) % ${#frames[@]} ))
        sleep 0.1
    done
    printf "\r  ${GREEN}✓${NC} %s\n" "$msg"
}

progress_bar() {
    local current=$1 total=$2 width=40
    local pct=$(( current * 100 / total ))
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    printf "\r  [${GREEN}%s${DIM}%s${NC}] %3d%%" \
        "$(printf '#%.0s' $(seq 1 "$filled" 2>/dev/null) )" \
        "$(printf '-%.0s' $(seq 1 "$empty" 2>/dev/null) )" \
        "$pct"
}

# ─────────────────────────────────────────────────────────────────────
# Utility Functions
# ─────────────────────────────────────────────────────────────────────

init_name_lookup() {
    for appid in "${!GAME_MODS[@]}"; do
        local entry="${GAME_MODS[$appid]}"
        local name="${entry%%|*}"
        local lower_name
        lower_name="$(echo "$name" | tr '[:upper:]' '[:lower:]')"
        GAME_NAME_TO_ID["$lower_name"]="$appid"
    done
}

resolve_game_id() {
    local input="$1"

    # Direct app ID
    if [[ "$input" =~ ^[0-9]+$ ]] && [[ -n "${GAME_MODS[$input]:-}" ]]; then
        echo "$input"
        return 0
    fi

    # Name lookup (exact, case-insensitive)
    local lower_input
    lower_input="$(echo "$input" | tr '[:upper:]' '[:lower:]')"
    if [[ -n "${GAME_NAME_TO_ID[$lower_input]:-}" ]]; then
        echo "${GAME_NAME_TO_ID[$lower_input]}"
        return 0
    fi

    # Partial match
    for appid in "${!GAME_MODS[@]}"; do
        local entry="${GAME_MODS[$appid]}"
        local name="${entry%%|*}"
        local lower_name
        lower_name="$(echo "$name" | tr '[:upper:]' '[:lower:]')"
        if [[ "$lower_name" == *"$lower_input"* ]]; then
            echo "$appid"
            return 0
        fi
    done

    error "Unknown game: '$input'"
    echo "  Known games:"
    for appid in $(echo "${!GAME_MODS[@]}" | tr ' ' '\n' | sort -n); do
        local entry="${GAME_MODS[$appid]}"
        local name="${entry%%|*}"
        echo "    $appid  $name"
    done
    return 1
}

get_game_name() {
    local appid="$1"
    local entry="${GAME_MODS[$appid]:-}"
    [[ -z "$entry" ]] && return 1
    echo "${entry}" | cut -d'|' -f1
}

get_game_mod_dir() {
    local appid="$1"
    local entry="${GAME_MODS[$appid]:-}"
    [[ -z "$entry" ]] && return 1
    echo "${entry}" | cut -d'|' -f2
}

get_game_appdata() {
    local appid="$1"
    local entry="${GAME_MODS[$appid]:-}"
    [[ -z "$entry" ]] && return 1
    echo "${entry}" | cut -d'|' -f3
}

get_game_documents() {
    local appid="$1"
    local entry="${GAME_MODS[$appid]:-}"
    [[ -z "$entry" ]] && return 1
    echo "${entry}" | cut -d'|' -f4
}

ensure_dir() {
    if [[ ! -d "$1" ]]; then
        mkdir -p "$1"
        detail "Created: $1"
    fi
}

check_deps() {
    local missing=()
    for cmd in "$@"; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing dependencies: ${missing[*]}"
        info "Install with: sudo dnf install ${missing[*]}"
        return 1
    fi
}

copy_to_clipboard() {
    local text="$1"
    if command -v wl-copy &>/dev/null; then
        echo -n "$text" | wl-copy
        return 0
    elif command -v xclip &>/dev/null; then
        echo -n "$text" | xclip -selection clipboard
        return 0
    fi
    return 1
}

human_size() {
    local bytes="${1:-0}"
    if [[ "$bytes" -gt 1073741824 ]]; then
        echo "$(( bytes / 1073741824 )) GB"
    elif [[ "$bytes" -gt 1048576 ]]; then
        echo "$(( bytes / 1048576 )) MB"
    elif [[ "$bytes" -gt 1024 ]]; then
        echo "$(( bytes / 1024 )) KB"
    else
        echo "${bytes} B"
    fi
}

# ─────────────────────────────────────────────────────────────────────
# Steam & Proton Path Detection
# ─────────────────────────────────────────────────────────────────────

# Possible Steam root locations (native + Flatpak)
find_steam_root() {
    local candidates=(
        "${HOME}/.steam/steam"
        "${HOME}/.local/share/Steam"
        "${HOME}/.var/app/com.valvesoftware.Steam/.steam/steam"
        "${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam"
        "/run/media/mmcblk0p1/SteamLibrary"  # Steam Deck SD card
    )
    for path in "${candidates[@]}"; do
        if [[ -d "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    return 1
}

# Find all Steam library folders
find_library_folders() {
    local steam_root
    steam_root="$(find_steam_root)" || { error "Steam not found"; return 1; }

    local vdf="${steam_root}/steamapps/libraryfolders.vdf"
    if [[ ! -f "$vdf" ]]; then
        # Fallback: just the root
        echo "${steam_root}/steamapps"
        return 0
    fi

    # Parse libraryfolders.vdf for paths
    # The format has "path" entries
    while IFS= read -r line; do
        if [[ "$line" =~ \"path\"[[:space:]]+\"(.+)\" ]]; then
            local lib_path="${BASH_REMATCH[1]}"
            if [[ -d "${lib_path}/steamapps" ]]; then
                echo "${lib_path}/steamapps"
            fi
        fi
    done < "$vdf"

    # Always include primary
    if [[ -d "${steam_root}/steamapps" ]]; then
        echo "${steam_root}/steamapps"
    fi
}

# Find game install directory
find_game_install() {
    local appid="$1"
    local name
    name="$(get_game_name "$appid")" || return 1

    while IFS= read -r lib; do
        local manifest="${lib}/appmanifest_${appid}.acf"
        if [[ -f "$manifest" ]]; then
            local installdir
            installdir="$(grep -oP '"installdir"\s+"\K[^"]+' "$manifest" 2>/dev/null || true)"
            if [[ -n "$installdir" && -d "${lib}/common/${installdir}" ]]; then
                echo "${lib}/common/${installdir}"
                return 0
            fi
        fi
    done < <(find_library_folders 2>/dev/null)

    return 1
}

# Find Proton prefix (compatdata)
find_prefix() {
    local appid="$1"

    while IFS= read -r lib; do
        local pfx="${lib}/compatdata/${appid}/pfx"
        if [[ -d "$pfx" ]]; then
            echo "$pfx"
            return 0
        fi
    done < <(find_library_folders 2>/dev/null)

    return 1
}

# Full prefix root (parent of pfx/)
find_prefix_root() {
    local appid="$1"

    while IFS= read -r lib; do
        local compat="${lib}/compatdata/${appid}"
        if [[ -d "$compat" ]]; then
            echo "$compat"
            return 0
        fi
    done < <(find_library_folders 2>/dev/null)

    return 1
}

# Translate a Windows-style path to the Linux prefix path
win_to_linux() {
    local appid="$1"
    local win_path="$2"
    local pfx
    pfx="$(find_prefix "$appid")" || return 1

    # Normalize backslashes
    local normalized="${win_path//\\//}"

    # Strip drive letter
    if [[ "$normalized" =~ ^[A-Za-z]:/(.*) ]]; then
        normalized="${BASH_REMATCH[1]}"
    fi

    echo "${pfx}/drive_c/${normalized}"
}

# Check if Steam is Flatpak
is_flatpak_steam() {
    local steam_root
    steam_root="$(find_steam_root 2>/dev/null)" || return 1
    [[ "$steam_root" == *".var/app/com.valvesoftware.Steam"* ]]
}

# Get protontricks command (Flatpak-aware)
get_protontricks_cmd() {
    if command -v protontricks &>/dev/null; then
        echo "protontricks"
    elif flatpak list 2>/dev/null | grep -q "com.github.Matoking.protontricks"; then
        echo "flatpak run com.github.Matoking.protontricks"
    else
        return 1
    fi
}

# ─────────────────────────────────────────────────────────────────────
# Command: setup
# ─────────────────────────────────────────────────────────────────────

cmd_setup() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        error "Usage: $SCRIPT_NAME setup <appid|game-name>"
        echo "  Example: $SCRIPT_NAME setup 489830"
        echo "  Example: $SCRIPT_NAME setup skyrim"
        return 1
    fi

    local appid
    appid="$(resolve_game_id "$input")" || return 1
    local name
    name="$(get_game_name "$appid")"
    local safe_name="${name// /_}"

    header "Setting up modding environment for ${name} (${appid})"

    # ── Step 1: Detect prefix ──
    info "Detecting Proton prefix..."
    local pfx
    if pfx="$(find_prefix "$appid")"; then
        success "Prefix found: ${pfx}"
    else
        warn "Proton prefix not found for ${appid}"
        info "Launch the game at least once through Steam to create the prefix."
        info "Then re-run: $SCRIPT_NAME setup ${appid}"
        return 1
    fi

    local drive_c="${pfx}/drive_c"

    # ── Step 2: Detect game install ──
    info "Locating game installation..."
    local game_dir
    if game_dir="$(find_game_install "$appid")"; then
        success "Game directory: ${game_dir}"
    else
        warn "Game not found in any Steam library"
    fi

    # ── Step 3: Create mod directories ──
    header "Creating mod directories"
    local mod_base="${MOD_ROOT}/${safe_name}"

    ensure_dir "${mod_base}/downloads"
    ensure_dir "${mod_base}/staging"
    ensure_dir "${mod_base}/profiles/default"
    ensure_dir "${mod_base}/overwrite"
    ensure_dir "${mod_base}/backups"
    success "Mod directory tree: ${mod_base}/"

    # ── Step 4: Create symlinks inside prefix ──
    header "Setting up prefix symlinks"

    # Create a 24HG Forge mods folder accessible from Windows side
    local win_mods="${drive_c}/24HG Forge_Mods"
    if [[ ! -L "$win_mods" ]] && [[ ! -d "$win_mods" ]]; then
        ln -sf "${mod_base}" "${win_mods}"
        detail "Symlink: C:\\24HG Forge_Mods -> ${mod_base}"
    else
        detail "Symlink already exists: ${win_mods}"
    fi

    # Link AppData paths if defined
    local appdata_rel
    appdata_rel="$(get_game_appdata "$appid")"
    if [[ -n "$appdata_rel" ]]; then
        local appdata_full="${drive_c}/users/steamuser/${appdata_rel}"
        ensure_dir "$(dirname "$appdata_full")"
        if [[ -d "$appdata_full" ]]; then
            detail "AppData path exists: ${appdata_full}"
        fi
        # Create convenience symlink in mod base
        if [[ -d "$appdata_full" ]] && [[ ! -L "${mod_base}/game_appdata" ]]; then
            ln -sf "${appdata_full}" "${mod_base}/game_appdata"
            detail "Convenience link: ${mod_base}/game_appdata"
        fi
    fi

    # Link Documents paths if defined
    local docs_rel
    docs_rel="$(get_game_documents "$appid")"
    if [[ -n "$docs_rel" ]]; then
        local docs_full="${drive_c}/users/steamuser/${docs_rel}"
        ensure_dir "$(dirname "$docs_full")"
        if [[ -d "$docs_full" ]]; then
            detail "Documents path exists: ${docs_full}"
        fi
        if [[ -d "$docs_full" ]] && [[ ! -L "${mod_base}/game_documents" ]]; then
            ln -sf "${docs_full}" "${mod_base}/game_documents"
            detail "Convenience link: ${mod_base}/game_documents"
        fi
    fi

    # Link game mod directory
    local mod_subdir
    mod_subdir="$(get_game_mod_dir "$appid")"
    if [[ -n "$game_dir" && -n "$mod_subdir" ]]; then
        local game_mod_path="${game_dir}/${mod_subdir}"
        if [[ -d "$game_mod_path" ]] && [[ ! -L "${mod_base}/game_mod_dir" ]]; then
            ln -sf "${game_mod_path}" "${mod_base}/game_mod_dir"
            detail "Convenience link: ${mod_base}/game_mod_dir -> ${game_mod_path}"
        fi
    fi

    # ── Step 5: Configure protontricks ──
    header "Protontricks configuration"
    local ptricks
    if ptricks="$(get_protontricks_cmd)"; then
        success "protontricks available: ${ptricks}"
        info "To install Windows dependencies: ${ptricks} ${appid} --gui"
    else
        warn "protontricks not installed"
        if is_flatpak_steam 2>/dev/null; then
            info "Install: flatpak install com.github.Matoking.protontricks"
        else
            info "Install: sudo dnf install protontricks"
        fi
    fi

    # ── Step 6: Save config ──
    ensure_dir "${CONFIG_DIR}"
    local game_conf="${CONFIG_DIR}/${appid}.conf"
    cat > "$game_conf" << CONF
# 24HG Forge Mod Manager — ${name}
APPID=${appid}
GAME_NAME="${name}"
SAFE_NAME="${safe_name}"
PREFIX="${pfx}"
GAME_DIR="${game_dir:-}"
MOD_BASE="${mod_base}"
SETUP_DATE="$(date -Iseconds)"
CONF
    detail "Config saved: ${game_conf}"

    # ── Summary ──
    header "Setup complete for ${name}"
    echo ""
    echo -e "  ${BOLD}Mod downloads:${NC}  ${mod_base}/downloads/"
    echo -e "  ${BOLD}Mod staging:${NC}    ${mod_base}/staging/"
    echo -e "  ${BOLD}Profiles:${NC}       ${mod_base}/profiles/"
    echo ""
    echo -e "  ${BOLD}How to install mods:${NC}"
    echo "    1. Download .zip/.7z/.rar mod archives"
    echo "    2. Place them in: ${mod_base}/downloads/"
    echo "    3. Run: $SCRIPT_NAME deploy ${appid}"
    echo ""
    echo -e "  ${BOLD}Or use a mod manager:${NC}"
    echo "    $SCRIPT_NAME install-vortex"
    echo "    $SCRIPT_NAME install-mo2"
    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Command: find-prefix
# ─────────────────────────────────────────────────────────────────────

cmd_find_prefix() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        error "Usage: $SCRIPT_NAME find-prefix <appid|game-name>"
        return 1
    fi

    local appid
    appid="$(resolve_game_id "$input")" || return 1
    local name
    name="$(get_game_name "$appid")"

    header "Prefix paths for ${name} (${appid})"

    # Prefix root
    local prefix_root
    if prefix_root="$(find_prefix_root "$appid")"; then
        echo -e "\n  ${BOLD}Prefix root:${NC}"
        echo "    Linux:   ${prefix_root}"
        echo "    Windows: (Proton internal)"
    else
        error "Proton prefix not found. Launch the game once through Steam first."
        return 1
    fi

    local pfx="${prefix_root}/pfx"
    local drive_c="${pfx}/drive_c"

    # drive_c
    echo -e "\n  ${BOLD}Drive C:${NC}"
    echo "    Linux:   ${drive_c}"
    echo "    Windows: C:\\"

    # Game install
    echo -e "\n  ${BOLD}Game installation:${NC}"
    local game_dir
    if game_dir="$(find_game_install "$appid")"; then
        echo "    Linux:   ${game_dir}"
        # Determine the Windows-visible path inside the prefix
        # Games might be on a different library, so we check if it's inside the prefix
        echo "    Steam:   steamapps/common/..."
    else
        echo "    ${DIM}Not found — is the game installed?${NC}"
    fi

    # AppData/Local
    echo -e "\n  ${BOLD}AppData/Local:${NC}"
    local appdata_local="${drive_c}/users/steamuser/AppData/Local"
    echo "    Linux:   ${appdata_local}/"
    echo "    Windows: C:\\Users\\steamuser\\AppData\\Local\\"

    # AppData/Roaming
    echo -e "\n  ${BOLD}AppData/Roaming:${NC}"
    local appdata_roaming="${drive_c}/users/steamuser/AppData/Roaming"
    echo "    Linux:   ${appdata_roaming}/"
    echo "    Windows: C:\\Users\\steamuser\\AppData\\Roaming\\"

    # AppData/LocalLow
    echo -e "\n  ${BOLD}AppData/LocalLow:${NC}"
    local appdata_locallow="${drive_c}/users/steamuser/AppData/LocalLow"
    echo "    Linux:   ${appdata_locallow}/"
    echo "    Windows: C:\\Users\\steamuser\\AppData\\LocalLow\\"

    # My Documents
    echo -e "\n  ${BOLD}My Documents:${NC}"
    local my_docs="${drive_c}/users/steamuser/My Documents"
    echo "    Linux:   ${my_docs}/"
    echo "    Windows: C:\\Users\\steamuser\\My Documents\\"

    # Game-specific paths
    local appdata_rel
    appdata_rel="$(get_game_appdata "$appid")"
    if [[ -n "$appdata_rel" ]]; then
        echo -e "\n  ${BOLD}Game AppData (${name}):${NC}"
        local gad="${drive_c}/users/steamuser/${appdata_rel}"
        echo "    Linux:   ${gad}"
        echo "    Windows: C:\\Users\\steamuser\\${appdata_rel//\//\\}"
        if [[ -d "$gad" ]]; then
            echo -e "    ${GREEN}(exists)${NC}"
        else
            echo -e "    ${DIM}(not yet created — launch game first)${NC}"
        fi
    fi

    local docs_rel
    docs_rel="$(get_game_documents "$appid")"
    if [[ -n "$docs_rel" ]]; then
        echo -e "\n  ${BOLD}Game Documents (${name}):${NC}"
        local gd="${drive_c}/users/steamuser/${docs_rel}"
        echo "    Linux:   ${gd}"
        echo "    Windows: C:\\Users\\steamuser\\${docs_rel//\//\\}"
        if [[ -d "$gd" ]]; then
            echo -e "    ${GREEN}(exists)${NC}"
        else
            echo -e "    ${DIM}(not yet created — launch game first)${NC}"
        fi
    fi

    # Registry
    echo -e "\n  ${BOLD}Registry files:${NC}"
    for reg in system.reg user.reg userdef.reg; do
        if [[ -f "${pfx}/${reg}" ]]; then
            echo "    ${pfx}/${reg}"
        fi
    done

    # Copy prefix path to clipboard
    echo ""
    if copy_to_clipboard "${pfx}"; then
        success "Prefix path copied to clipboard"
    fi
    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Command: install-vortex
# ─────────────────────────────────────────────────────────────────────

cmd_install_vortex() {
    header "Installing Vortex Mod Manager"

    check_deps curl wine || {
        info "Checking for protontricks as alternative..."
        local ptricks
        ptricks="$(get_protontricks_cmd 2>/dev/null)" || {
            error "Need either wine or protontricks to install Vortex"
            return 1
        }
    }

    # Create Vortex directories
    ensure_dir "${VORTEX_ROOT}"
    ensure_dir "${VORTEX_ROOT}/prefix"
    ensure_dir "${VORTEX_ROOT}/downloads"

    # Download latest Vortex
    info "Fetching latest Vortex release info..."
    local releases_url="https://api.github.com/repos/Nexus-Mods/Vortex/releases/latest"
    local release_json
    release_json="$(curl -sL "$releases_url" 2>/dev/null)" || {
        error "Failed to fetch Vortex release info from GitHub"
        return 1
    }

    local download_url
    download_url="$(echo "$release_json" | grep -oP '"browser_download_url":\s*"\K[^"]+\.exe' | head -1)" || true

    if [[ -z "$download_url" ]]; then
        warn "Could not find .exe in latest release, trying manual URL"
        download_url="https://github.com/Nexus-Mods/Vortex/releases/latest/download/vortex-setup.exe"
    fi

    local installer="${VORTEX_ROOT}/downloads/vortex-setup.exe"
    if [[ ! -f "$installer" ]]; then
        info "Downloading Vortex installer..."
        curl -L --progress-bar -o "$installer" "$download_url" || {
            error "Download failed"
            return 1
        }
        success "Downloaded: ${installer}"
    else
        info "Installer already downloaded: ${installer}"
    fi

    # Setup Wine prefix
    local vortex_prefix="${VORTEX_ROOT}/prefix"
    export WINEPREFIX="${vortex_prefix}"
    export WINEARCH="win64"

    info "Initializing Wine prefix (this may take a minute)..."
    if command -v wine &>/dev/null; then
        # Initialize prefix
        wineboot --init &>/dev/null &
        spinner $! "Initializing Wine prefix"

        # Install .NET dependencies
        header "Installing dependencies"
        info "Vortex requires .NET Framework. Installing via winetricks..."
        if command -v winetricks &>/dev/null; then
            info "Installing dotnet48..."
            winetricks -q dotnet48 &>/dev/null &
            spinner $! "Installing .NET Framework 4.8 (this takes several minutes)"

            info "Installing vcrun2019..."
            winetricks -q vcrun2019 &>/dev/null &
            spinner $! "Installing VC++ Runtime 2019"
        else
            warn "winetricks not installed — you may need to install .NET manually"
            info "Install winetricks: sudo dnf install winetricks"
        fi

        # Run installer
        header "Running Vortex installer"
        info "Launching installer — follow the Windows install wizard"
        wine "$installer" &
        local inst_pid=$!
        info "Installer running (PID: ${inst_pid}). Waiting for completion..."
        wait "$inst_pid" 2>/dev/null || true
        success "Installer finished"
    else
        # Protontricks fallback
        local ptricks
        ptricks="$(get_protontricks_cmd)"
        warn "Using protontricks fallback (less reliable for Vortex)"
        info "Running: ${ptricks} --no-runtime ..."
        info "You may need to create a non-Steam game entry for Vortex"
    fi

    # Create desktop shortcut
    header "Creating desktop shortcut"
    local desktop_file="${HOME}/.local/share/applications/forge-vortex.desktop"
    local vortex_exe="${vortex_prefix}/drive_c/Program Files/Black Tree Gaming Ltd/Vortex/Vortex.exe"

    cat > "${desktop_file}" << DESKTOP
[Desktop Entry]
Name=Vortex Mod Manager (24HG Forge)
Comment=Manage game mods with Vortex via Wine
Exec=env WINEPREFIX="${vortex_prefix}" wine "${vortex_exe}"
Icon=vortex
Type=Application
Categories=Game;Utility;
StartupWMClass=vortex.exe
DESKTOP
    chmod +x "${desktop_file}"
    success "Desktop shortcut: ${desktop_file}"

    # Setup staging symlinks for known games
    header "Configuring Vortex staging"
    ensure_dir "${MOD_ROOT}"

    local drive_c="${vortex_prefix}/drive_c"
    local vortex_appdata="${drive_c}/users/steamuser/AppData/Roaming/Vortex"
    ensure_dir "${vortex_appdata}"

    # Link our mods directory so Vortex can see it
    if [[ ! -L "${drive_c}/24HG Forge_Mods" ]]; then
        ln -sf "${MOD_ROOT}" "${drive_c}/24HG Forge_Mods"
        detail "Linked mods root: C:\\24HG Forge_Mods -> ${MOD_ROOT}"
    fi

    # Summary
    header "Vortex installation complete"
    echo ""
    echo -e "  ${BOLD}Prefix:${NC}    ${vortex_prefix}"
    echo -e "  ${BOLD}Shortcut:${NC}  ${desktop_file}"
    echo -e "  ${BOLD}Mods root:${NC} ${MOD_ROOT}"
    echo ""
    echo -e "  ${BOLD}To launch:${NC} Click 'Vortex Mod Manager' in your app menu"
    echo -e "  ${BOLD}Or run:${NC}    WINEPREFIX=${vortex_prefix} wine '${vortex_exe}'"
    echo ""
    echo -e "  ${YELLOW}Note:${NC} Configure Vortex to use C:\\24HG Forge_Mods as the staging base"
    echo -e "  ${YELLOW}Note:${NC} Point game paths to C:\\24HG Forge_Mods\\[Game]\\staging"
    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Command: install-mo2
# ─────────────────────────────────────────────────────────────────────

cmd_install_mo2() {
    header "Installing Mod Organizer 2 (Portable)"

    check_deps curl 7z || check_deps curl unzip || {
        error "Need curl and either 7z or unzip"
        return 1
    }

    # Create MO2 directories
    ensure_dir "${MO2_ROOT}"
    ensure_dir "${MO2_ROOT}/downloads"
    ensure_dir "${MO2_ROOT}/prefix"

    # Download MO2 portable
    info "Fetching latest MO2 release..."
    local releases_url="https://api.github.com/repos/ModOrganizer2/modorganizer/releases/latest"
    local release_json
    release_json="$(curl -sL "$releases_url" 2>/dev/null)" || {
        error "Failed to fetch MO2 release info"
        return 1
    }

    # Look for portable archive
    local download_url
    download_url="$(echo "$release_json" | grep -oP '"browser_download_url":\s*"\K[^"]+[Pp]ortable[^"]*\.7z' | head -1)" || true

    if [[ -z "$download_url" ]]; then
        # Try .zip
        download_url="$(echo "$release_json" | grep -oP '"browser_download_url":\s*"\K[^"]+[Pp]ortable[^"]*\.zip' | head -1)" || true
    fi

    if [[ -z "$download_url" ]]; then
        # Try any archive
        download_url="$(echo "$release_json" | grep -oP '"browser_download_url":\s*"\K[^"]+\.(7z|zip)' | head -1)" || true
    fi

    if [[ -z "$download_url" ]]; then
        error "Could not find MO2 download URL"
        info "Download manually from: https://github.com/ModOrganizer2/modorganizer/releases"
        return 1
    fi

    local archive_name
    archive_name="$(basename "$download_url")"
    local archive_path="${MO2_ROOT}/downloads/${archive_name}"

    if [[ ! -f "$archive_path" ]]; then
        info "Downloading: ${archive_name}"
        curl -L --progress-bar -o "$archive_path" "$download_url" || {
            error "Download failed"
            return 1
        }
        success "Downloaded: ${archive_path}"
    else
        info "Archive already downloaded: ${archive_path}"
    fi

    # Extract
    header "Extracting MO2"
    local extract_dir="${MO2_ROOT}/app"
    ensure_dir "$extract_dir"

    if [[ "$archive_name" == *.7z ]]; then
        if command -v 7z &>/dev/null; then
            7z x -o"${extract_dir}" -aoa "$archive_path" &>/dev/null &
            spinner $! "Extracting 7z archive"
        else
            error "7z not installed. Install: sudo dnf install p7zip-plugins"
            return 1
        fi
    elif [[ "$archive_name" == *.zip ]]; then
        unzip -o -q "$archive_path" -d "$extract_dir" &
        spinner $! "Extracting zip archive"
    fi
    success "Extracted to: ${extract_dir}"

    # Setup Wine prefix for MO2
    header "Setting up Wine prefix"
    local mo2_prefix="${MO2_ROOT}/prefix"
    export WINEPREFIX="${mo2_prefix}"
    export WINEARCH="win64"

    if command -v wine &>/dev/null; then
        wineboot --init &>/dev/null &
        spinner $! "Initializing Wine prefix"
    else
        warn "wine not found — MO2 needs Wine or Proton to run"
        info "Install: sudo dnf install wine"
    fi

    # Find the MO2 executable
    local mo2_exe
    mo2_exe="$(find "${extract_dir}" -name "ModOrganizer.exe" -type f 2>/dev/null | head -1)"

    if [[ -z "$mo2_exe" ]]; then
        warn "ModOrganizer.exe not found in extracted files"
        mo2_exe="${extract_dir}/ModOrganizer.exe"
    fi

    # Configure game detection — create instance INIs
    header "Configuring game detection"
    local instances_dir="${mo2_prefix}/drive_c/users/steamuser/AppData/Local/ModOrganizer"
    ensure_dir "${instances_dir}"

    # Create a basic config that maps Steam paths
    for appid in "${!GAME_MODS[@]}"; do
        local name
        name="$(get_game_name "$appid")"
        local game_dir
        game_dir="$(find_game_install "$appid" 2>/dev/null)" || continue

        local safe_name="${name// /_}"
        local instance_dir="${instances_dir}/${safe_name}"
        ensure_dir "${instance_dir}"

        # Write a basic ModOrganizer.ini for this game
        cat > "${instance_dir}/ModOrganizer.ini" << MO2INI
[General]
gameName=${name}
selected_profile=Default
gamePath=${game_dir}

[Settings]
mod_directory=${MOD_ROOT}/${safe_name}/staging
download_directory=${MOD_ROOT}/${safe_name}/downloads
profiles_directory=${MOD_ROOT}/${safe_name}/profiles
overwrite_directory=${MOD_ROOT}/${safe_name}/overwrite
MO2INI
        detail "Configured: ${name}"
    done

    # Create symlinks inside prefix for game access
    local drive_c="${mo2_prefix}/drive_c"
    if [[ ! -L "${drive_c}/24HG Forge_Mods" ]]; then
        ln -sf "${MOD_ROOT}" "${drive_c}/24HG Forge_Mods"
        detail "Linked mods root: C:\\24HG Forge_Mods"
    fi

    # Link Steam library for game detection
    local steam_root
    if steam_root="$(find_steam_root 2>/dev/null)"; then
        if [[ ! -L "${drive_c}/Steam" ]]; then
            ln -sf "${steam_root}" "${drive_c}/Steam"
            detail "Linked Steam: C:\\Steam"
        fi
    fi

    # Create desktop shortcut
    header "Creating desktop shortcut"
    local desktop_file="${HOME}/.local/share/applications/forge-mo2.desktop"
    cat > "${desktop_file}" << DESKTOP
[Desktop Entry]
Name=Mod Organizer 2 (24HG Forge)
Comment=Manage game mods with MO2 via Wine
Exec=env WINEPREFIX="${mo2_prefix}" wine "${mo2_exe}"
Icon=mo2
Type=Application
Categories=Game;Utility;
StartupWMClass=modorganizer.exe
DESKTOP
    chmod +x "${desktop_file}"
    success "Desktop shortcut: ${desktop_file}"

    # Summary
    header "Mod Organizer 2 installation complete"
    echo ""
    echo -e "  ${BOLD}Install:${NC}   ${extract_dir}"
    echo -e "  ${BOLD}Prefix:${NC}    ${mo2_prefix}"
    echo -e "  ${BOLD}Shortcut:${NC}  ${desktop_file}"
    echo -e "  ${BOLD}Mods root:${NC} ${MOD_ROOT}"
    echo ""
    echo -e "  ${BOLD}To launch:${NC} Click 'Mod Organizer 2' in your app menu"
    echo -e "  ${BOLD}Or run:${NC}    WINEPREFIX=${mo2_prefix} wine '${mo2_exe}'"
    echo ""
    echo -e "  ${YELLOW}Tip:${NC} MO2's virtual filesystem works through Wine —"
    echo -e "       mod files stay in staging and get overlaid at runtime."
    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Command: deploy
# ─────────────────────────────────────────────────────────────────────

cmd_deploy() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        error "Usage: $SCRIPT_NAME deploy <appid|game-name>"
        return 1
    fi

    local appid
    appid="$(resolve_game_id "$input")" || return 1
    local name
    name="$(get_game_name "$appid")"
    local safe_name="${name// /_}"
    local mod_base="${MOD_ROOT}/${safe_name}"

    header "Deploying mods for ${name}"

    # Verify setup
    if [[ ! -d "$mod_base" ]]; then
        error "Modding not set up for ${name}. Run: $SCRIPT_NAME setup ${appid}"
        return 1
    fi

    # Find game directory and mod subdirectory
    local game_dir
    game_dir="$(find_game_install "$appid")" || {
        error "Game installation not found"
        return 1
    }

    local mod_subdir
    mod_subdir="$(get_game_mod_dir "$appid")"
    local target_dir="${game_dir}/${mod_subdir}"
    ensure_dir "$target_dir"

    info "Target: ${target_dir}"

    # ── Phase 1: Extract archives from downloads/ to staging/ ──
    header "Phase 1: Extracting mod archives"
    local downloads_dir="${mod_base}/downloads"
    local staging_dir="${mod_base}/staging"
    local extracted_count=0

    if [[ -d "$downloads_dir" ]]; then
        shopt -s nullglob
        for archive in "${downloads_dir}"/*.zip "${downloads_dir}"/*.7z "${downloads_dir}"/*.rar "${downloads_dir}"/*.tar.gz "${downloads_dir}"/*.tar.xz; do
            [[ -f "$archive" ]] || continue

            local basename_noext
            basename_noext="$(basename "$archive")"
            basename_noext="${basename_noext%%.*}"

            local mod_staging="${staging_dir}/${basename_noext}"
            if [[ -d "$mod_staging" ]]; then
                detail "Already extracted: ${basename_noext}"
                continue
            fi

            ensure_dir "$mod_staging"
            info "Extracting: $(basename "$archive")"

            case "$archive" in
                *.7z)
                    if command -v 7z &>/dev/null; then
                        7z x -o"${mod_staging}" "$archive" &>/dev/null
                    else
                        error "7z required for .7z archives. Install: sudo dnf install p7zip-plugins"
                        continue
                    fi
                    ;;
                *.zip)
                    unzip -o -q "$archive" -d "$mod_staging"
                    ;;
                *.rar)
                    if command -v unrar &>/dev/null; then
                        unrar x -o+ "$archive" "$mod_staging/" &>/dev/null
                    else
                        error "unrar required for .rar archives. Install: sudo dnf install unrar"
                        continue
                    fi
                    ;;
                *.tar.gz|*.tar.xz)
                    tar xf "$archive" -C "$mod_staging"
                    ;;
            esac

            success "Extracted: ${basename_noext}"
            extracted_count=$((extracted_count + 1))
        done
    fi
    info "Extracted ${extracted_count} new archive(s)"

    # ── Phase 2: Deploy staged mods ──
    header "Phase 2: Deploying to game directory"
    local deployed_count=0
    local file_count=0

    if [[ ! -d "$staging_dir" ]] || [[ -z "$(ls -A "$staging_dir" 2>/dev/null)" ]]; then
        warn "No mods in staging directory: ${staging_dir}"
        info "Place mod archives in: ${downloads_dir}/"
        info "Or extract mods directly to: ${staging_dir}/"
        return 0
    fi

    # Create backup of current mod state
    local backup_dir="${mod_base}/backups/$(date +%Y%m%d_%H%M%S)"
    ensure_dir "$backup_dir"

    # Deploy each mod from staging
    for mod_dir in "${staging_dir}"/*/; do
        [[ -d "$mod_dir" ]] || continue

        local mod_name
        mod_name="$(basename "$mod_dir")"
        info "Deploying: ${mod_name}"

        # Detect mod structure — look for common patterns
        local source_root="$mod_dir"

        # If the mod has a single subdirectory matching the mod dir name pattern, use it
        # e.g., for Skyrim, if there's a "Data" folder inside the mod
        if [[ -d "${mod_dir}/${mod_subdir}" ]]; then
            source_root="${mod_dir}/${mod_subdir}"
            detail "Found game-matching structure: ${mod_subdir}/"
        elif [[ -d "${mod_dir}/Data" ]] && [[ "$mod_subdir" == "Data" ]]; then
            source_root="${mod_dir}/Data"
            detail "Found Data/ directory in mod"
        fi

        # Count and deploy files
        local mod_files=0
        while IFS= read -r -d '' src_file; do
            local rel_path="${src_file#"${source_root}/"}"
            local dest_file="${target_dir}/${rel_path}"
            local dest_dir_part
            dest_dir_part="$(dirname "$dest_file")"

            ensure_dir "$dest_dir_part" 2>/dev/null

            # Backup existing file if present
            if [[ -f "$dest_file" ]]; then
                local backup_path="${backup_dir}/${rel_path}"
                mkdir -p "$(dirname "$backup_path")"
                cp -a "$dest_file" "$backup_path" 2>/dev/null || true
            fi

            # Create symlink instead of copy (saves disk space, easy to revert)
            ln -sf "$src_file" "$dest_file"
            mod_files=$((mod_files + 1))
        done < <(find "$source_root" -type f -print0 2>/dev/null)

        detail "Deployed ${mod_files} files"
        file_count=$((file_count + mod_files))
        deployed_count=$((deployed_count + 1))
    done

    # ── Phase 3: Handle load order (Bethesda games) ──
    header "Phase 3: Load order"
    local appdata_rel
    appdata_rel="$(get_game_appdata "$appid")"

    # Check for plugins.txt / loadorder.txt in AppData
    if [[ -n "$appdata_rel" ]]; then
        local pfx
        pfx="$(find_prefix "$appid" 2>/dev/null)" || true
        if [[ -n "$pfx" ]]; then
            local appdata_path="${pfx}/drive_c/users/steamuser/${appdata_rel}"
            local plugins_file="${appdata_path}/plugins.txt"
            local loadorder_file="${appdata_path}/loadorder.txt"

            if [[ -f "$plugins_file" ]]; then
                info "Load order file found: ${plugins_file}"
                local plugin_count
                plugin_count="$(grep -c '^[^#]' "$plugins_file" 2>/dev/null || echo 0)"
                detail "${plugin_count} plugins in load order"

                # Copy to mod base for easy editing
                cp "$plugins_file" "${mod_base}/profiles/default/plugins.txt" 2>/dev/null || true
                detail "Copied to: ${mod_base}/profiles/default/plugins.txt"
            fi

            if [[ -f "$loadorder_file" ]]; then
                cp "$loadorder_file" "${mod_base}/profiles/default/loadorder.txt" 2>/dev/null || true
                detail "Copied loadorder.txt to profile"
            fi

            # Scan for .esp/.esm/.esl files in deployed mods
            local plugin_files=()
            while IFS= read -r -d '' pf; do
                plugin_files+=("$(basename "$pf")")
            done < <(find "$target_dir" -maxdepth 1 \( -name "*.esp" -o -name "*.esm" -o -name "*.esl" \) -print0 2>/dev/null)

            if [[ ${#plugin_files[@]} -gt 0 ]]; then
                info "Found ${#plugin_files[@]} plugin file(s) in mod directory:"
                for pf in "${plugin_files[@]}"; do
                    detail "$pf"
                done
                if [[ ! -f "$plugins_file" ]]; then
                    info "Creating plugins.txt with discovered plugins..."
                    ensure_dir "$appdata_path"
                    printf "# Auto-generated by 24HG Forge Mod Manager\n" > "$plugins_file"
                    for pf in "${plugin_files[@]}"; do
                        printf "*%s\n" "$pf" >> "$plugins_file"
                    done
                    success "Created: ${plugins_file}"
                fi
            fi
        fi
    else
        detail "No load order handling needed for this game"
    fi

    # ── Phase 4: Verify ──
    header "Phase 4: Verification"
    local broken_links=0
    while IFS= read -r -d '' link; do
        if [[ -L "$link" ]] && [[ ! -e "$link" ]]; then
            warn "Broken symlink: ${link}"
            broken_links=$((broken_links + 1))
        fi
    done < <(find "$target_dir" -type l -print0 2>/dev/null)

    if [[ "$broken_links" -eq 0 ]]; then
        success "All symlinks verified"
    else
        warn "${broken_links} broken symlink(s) found"
    fi

    # Summary
    header "Deployment complete"
    echo ""
    echo -e "  ${BOLD}Mods deployed:${NC}   ${deployed_count}"
    echo -e "  ${BOLD}Files linked:${NC}    ${file_count}"
    echo -e "  ${BOLD}Target:${NC}          ${target_dir}"
    echo -e "  ${BOLD}Backup:${NC}          ${backup_dir}"
    echo ""
    echo -e "  ${YELLOW}To revert:${NC} Remove symlinks from ${target_dir}"
    echo -e "  ${YELLOW}Backup has:${NC} Original files that were overwritten"
    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Command: paths
# ─────────────────────────────────────────────────────────────────────

cmd_paths() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        error "Usage: $SCRIPT_NAME paths <appid|game-name>"
        return 1
    fi

    local appid
    appid="$(resolve_game_id "$input")" || return 1
    local name
    name="$(get_game_name "$appid")"
    local safe_name="${name// /_}"

    header "Modding paths for ${name} (${appid})"

    # Game install
    echo -e "\n${BOLD}  Game Installation${NC}"
    local game_dir
    if game_dir="$(find_game_install "$appid")"; then
        echo -e "    Linux:     ${GREEN}${game_dir}${NC}"
        echo "    Windows:   Z:\\$(echo "${game_dir}" | sed 's|/|\\|g')"
    else
        echo -e "    ${DIM}Not found${NC}"
    fi

    # Proton prefix
    local pfx=""
    local drive_c=""
    pfx="$(find_prefix "$appid" 2>/dev/null)" || true
    if [[ -n "$pfx" ]]; then
        drive_c="${pfx}/drive_c"
    fi

    # Save game location
    echo -e "\n${BOLD}  Save Games${NC}"
    local docs_rel
    docs_rel="$(get_game_documents "$appid")"
    if [[ -n "$docs_rel" && -n "$drive_c" ]]; then
        local saves_linux="${drive_c}/users/steamuser/${docs_rel}"
        echo "    Linux:     ${saves_linux}"
        echo "    Windows:   C:\\Users\\steamuser\\${docs_rel//\//\\}"
        if [[ -d "$saves_linux" ]]; then
            local save_count
            save_count="$(find "$saves_linux" -maxdepth 2 -name "*.sav" -o -name "*.save" -o -name "*.ess" -o -name "*.fos" 2>/dev/null | wc -l)"
            if [[ "$save_count" -gt 0 ]]; then
                echo -e "    ${DIM}(${save_count} save file(s) found)${NC}"
            fi
        fi
    else
        echo -e "    ${DIM}Check game-specific documentation${NC}"
    fi

    # Config/INI location
    echo -e "\n${BOLD}  Configuration / INI Files${NC}"
    if [[ -n "$docs_rel" && -n "$drive_c" ]]; then
        local config_dir="${drive_c}/users/steamuser/${docs_rel}"
        echo "    Linux:     ${config_dir}"
        echo "    Windows:   C:\\Users\\steamuser\\${docs_rel//\//\\}"
        if [[ -d "$config_dir" ]]; then
            local ini_files
            ini_files="$(find "$config_dir" -maxdepth 1 -name "*.ini" -o -name "*.cfg" -o -name "*.conf" 2>/dev/null)"
            if [[ -n "$ini_files" ]]; then
                echo -e "    ${DIM}Found config files:${NC}"
                while IFS= read -r f; do
                    echo "      $(basename "$f")"
                done <<< "$ini_files"
            fi
        fi
    fi

    # AppData location
    echo -e "\n${BOLD}  AppData${NC}"
    local appdata_rel
    appdata_rel="$(get_game_appdata "$appid")"
    if [[ -n "$appdata_rel" && -n "$drive_c" ]]; then
        local appdata_linux="${drive_c}/users/steamuser/${appdata_rel}"
        echo "    Linux:     ${appdata_linux}"
        echo "    Windows:   C:\\Users\\steamuser\\${appdata_rel//\//\\}"
    fi

    # Mod directory (native)
    echo -e "\n${BOLD}  Mod Directory (in-game)${NC}"
    local mod_subdir
    mod_subdir="$(get_game_mod_dir "$appid")"
    if [[ -n "$game_dir" && -n "$mod_subdir" ]]; then
        local mod_path="${game_dir}/${mod_subdir}"
        echo "    Linux:     ${mod_path}"
        echo "    Windows:   Z:\\$(echo "${mod_path}" | sed 's|/|\\|g')"
        if [[ -d "$mod_path" ]]; then
            local mod_count
            mod_count="$(find "$mod_path" -maxdepth 1 -mindepth 1 2>/dev/null | wc -l)"
            echo -e "    ${DIM}(${mod_count} item(s))${NC}"
        fi
    fi

    # Workshop content
    echo -e "\n${BOLD}  Workshop Content${NC}"
    while IFS= read -r lib; do
        local workshop="${lib}/workshop/content/${appid}"
        if [[ -d "$workshop" ]]; then
            echo "    Linux:     ${workshop}"
            local ws_count
            ws_count="$(find "$workshop" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)"
            echo -e "    ${DIM}(${ws_count} workshop item(s))${NC}"
        fi
    done < <(find_library_folders 2>/dev/null)

    # 24HG Forge mod staging
    echo -e "\n${BOLD}  24HG Forge Mod Manager${NC}"
    local mod_base="${MOD_ROOT}/${safe_name}"
    if [[ -d "$mod_base" ]]; then
        echo "    Downloads: ${mod_base}/downloads/"
        echo "    Staging:   ${mod_base}/staging/"
        echo "    Profiles:  ${mod_base}/profiles/"
    else
        echo -e "    ${DIM}Not set up. Run: $SCRIPT_NAME setup ${appid}${NC}"
    fi

    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Command: nexus
# ─────────────────────────────────────────────────────────────────────

cmd_nexus() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        login)    nexus_login "$@" ;;
        search)   nexus_search "$@" ;;
        download) nexus_download "$@" ;;
        handle)   nexus_handle_nxm "$@" ;;
        register) nexus_register_protocol ;;
        *)
            error "Usage: $SCRIPT_NAME nexus <login|search|download|handle|register>"
            echo ""
            echo "  login              — Authenticate with Nexus Mods API key"
            echo "  search <game> <q>  — Search mods on Nexus"
            echo "  download <url>     — Download a mod from Nexus"
            echo "  handle <nxm-url>   — Handle nxm:// protocol link"
            echo "  register           — Register nxm:// protocol handler"
            return 1
            ;;
    esac
}

nexus_get_key() {
    if [[ -f "$NEXUS_KEY_FILE" ]]; then
        cat "$NEXUS_KEY_FILE"
        return 0
    fi
    error "Nexus API key not configured. Run: $SCRIPT_NAME nexus login"
    return 1
}

nexus_login() {
    header "Nexus Mods Authentication"
    echo ""
    echo "  To get your API key:"
    echo "    1. Go to https://www.nexusmods.com/users/myaccount?tab=api+access"
    echo "    2. Under 'Personal API Key', click 'Request an API key'"
    echo "    3. Copy the key"
    echo ""

    read -rp "  Enter your Nexus API key: " api_key

    if [[ -z "$api_key" ]]; then
        error "No API key provided"
        return 1
    fi

    # Validate the key
    info "Validating API key..."
    local response
    response="$(curl -sL -w "\n%{http_code}" \
        -H "apikey: ${api_key}" \
        -H "Accept: application/json" \
        "${NEXUS_API}/users/validate.json" 2>/dev/null)"

    local http_code
    http_code="$(echo "$response" | tail -1)"
    local body
    body="$(echo "$response" | sed '$d')"

    if [[ "$http_code" != "200" ]]; then
        error "Invalid API key (HTTP ${http_code})"
        return 1
    fi

    local username
    username="$(echo "$body" | grep -oP '"name":\s*"\K[^"]+' || echo "unknown")"
    local is_premium
    is_premium="$(echo "$body" | grep -oP '"is_premium":\s*\K(true|false)' || echo "false")"

    # Save key
    ensure_dir "${CONFIG_DIR}"
    echo -n "$api_key" > "$NEXUS_KEY_FILE"
    chmod 600 "$NEXUS_KEY_FILE"

    success "Logged in as: ${username}"
    if [[ "$is_premium" == "true" ]]; then
        echo -e "  ${MAGENTA}Premium account${NC} — fast downloads enabled"
    else
        echo -e "  ${DIM}Free account — downloads may be throttled${NC}"
    fi

    # Offer to register protocol handler
    echo ""
    read -rp "  Register nxm:// protocol handler for browser downloads? [Y/n] " register
    if [[ "${register,,}" != "n" ]]; then
        nexus_register_protocol
    fi
}

nexus_search() {
    local game_input="${1:-}"
    shift || true
    local query="$*"

    if [[ -z "$game_input" || -z "$query" ]]; then
        error "Usage: $SCRIPT_NAME nexus search <game> <query>"
        echo "  Example: $SCRIPT_NAME nexus search skyrim \"better textures\""
        return 1
    fi

    local api_key
    api_key="$(nexus_get_key)" || return 1

    # Map game name to Nexus game domain
    local appid
    appid="$(resolve_game_id "$game_input" 2>/dev/null)" || true

    # Nexus uses "domain names" not app IDs. Map common ones.
    declare -A NEXUS_DOMAINS=(
        ["489830"]="skyrimspecialedition"
        ["611670"]="skyrimspecialedition"
        ["377160"]="fallout4"
        ["1151340"]="fallout76"
        ["1245620"]="eldenring"
        ["1091500"]="cyberpunk2077"
        ["292030"]="witcher3"
        ["413150"]="stardewvalley"
        ["105600"]="terraria"
        ["814380"]="sekiro"
        ["1174180"]="reddeadredemption2"
        ["271590"]="gta5"
        ["1086940"]="baldursgate3"
        ["570940"]="darksouls3"
        ["22380"]="newvegas"
        ["72850"]="skyrim"
        ["22330"]="oblivion"
        ["1716740"]="starfield"
        ["990080"]="hogwartslegacy"
        ["230410"]="warframe"
        ["281990"]="stellaris"
        ["394360"]="heartsofiron4"
        ["236850"]="europauniversalis4"
    )

    local domain=""
    if [[ -n "$appid" ]]; then
        domain="${NEXUS_DOMAINS[$appid]:-}"
    fi

    if [[ -z "$domain" ]]; then
        # Try using the game name directly as domain
        domain="$(echo "$game_input" | tr '[:upper:]' '[:lower:]' | tr -d ' ')"
    fi

    header "Searching Nexus Mods: ${domain} — \"${query}\""

    local encoded_query
    encoded_query="$(echo "$query" | sed 's/ /%20/g')"

    local response
    response="$(curl -sL \
        -H "apikey: ${api_key}" \
        -H "Accept: application/json" \
        "${NEXUS_API}/games/${domain}/mods/search.json?search=${encoded_query}" 2>/dev/null)" || {
        # Fallback: try the updated search endpoint
        response="$(curl -sL \
            -H "apikey: ${api_key}" \
            -H "Accept: application/json" \
            "${NEXUS_API}/games/${domain}/mods/updated.json?period=1m" 2>/dev/null)" || {
            error "Search failed"
            return 1
        }
    }

    # Parse results (basic JSON parsing without jq dependency)
    local count=0
    while IFS= read -r line; do
        local mod_id name author endorsements
        mod_id="$(echo "$line" | grep -oP '"mod_id":\s*\K[0-9]+' || continue)"
        name="$(echo "$line" | grep -oP '"name":\s*"\K[^"]+' || echo "Unknown")"
        author="$(echo "$line" | grep -oP '"author":\s*"\K[^"]+' || echo "Unknown")"
        endorsements="$(echo "$line" | grep -oP '"endorsement_count":\s*\K[0-9]+' || echo "0")"

        if [[ -n "$mod_id" ]]; then
            echo -e "  ${BOLD}${name}${NC}"
            echo -e "    Author: ${author} | Endorsements: ${endorsements}"
            echo -e "    URL: https://www.nexusmods.com/${domain}/mods/${mod_id}"
            echo ""
            count=$((count + 1))
        fi

        [[ "$count" -ge 10 ]] && break
    done < <(echo "$response" | grep -oP '\{[^{}]*\}')

    if [[ "$count" -eq 0 ]]; then
        warn "No results found"
        info "Try: https://www.nexusmods.com/${domain}/mods/"
    else
        info "Showing top ${count} results"
    fi
}

nexus_download() {
    local url="${1:-}"
    if [[ -z "$url" ]]; then
        error "Usage: $SCRIPT_NAME nexus download <nexus-mod-url>"
        return 1
    fi

    local api_key
    api_key="$(nexus_get_key)" || return 1

    # Parse Nexus URL: https://www.nexusmods.com/skyrimspecialedition/mods/12345
    local domain mod_id
    if [[ "$url" =~ nexusmods\.com/([^/]+)/mods/([0-9]+) ]]; then
        domain="${BASH_REMATCH[1]}"
        mod_id="${BASH_REMATCH[2]}"
    else
        error "Invalid Nexus URL format"
        info "Expected: https://www.nexusmods.com/<game>/mods/<id>"
        return 1
    fi

    header "Downloading from Nexus Mods"
    info "Game: ${domain} | Mod ID: ${mod_id}"

    # Get mod info
    local mod_info
    mod_info="$(curl -sL \
        -H "apikey: ${api_key}" \
        -H "Accept: application/json" \
        "${NEXUS_API}/games/${domain}/mods/${mod_id}.json" 2>/dev/null)"

    local mod_name
    mod_name="$(echo "$mod_info" | grep -oP '"name":\s*"\K[^"]+' || echo "mod_${mod_id}")"
    info "Mod: ${mod_name}"

    # Get files list
    local files_info
    files_info="$(curl -sL \
        -H "apikey: ${api_key}" \
        -H "Accept: application/json" \
        "${NEXUS_API}/games/${domain}/mods/${mod_id}/files.json" 2>/dev/null)"

    # Find the main file (largest or most recent)
    local file_id file_name
    file_id="$(echo "$files_info" | grep -oP '"file_id":\s*\K[0-9]+' | head -1)"
    file_name="$(echo "$files_info" | grep -oP '"file_name":\s*"\K[^"]+' | head -1)"

    if [[ -z "$file_id" ]]; then
        error "No files found for this mod"
        return 1
    fi

    info "File: ${file_name} (ID: ${file_id})"

    # Get download link
    local dl_info
    dl_info="$(curl -sL \
        -H "apikey: ${api_key}" \
        -H "Accept: application/json" \
        "${NEXUS_API}/games/${domain}/mods/${mod_id}/files/${file_id}/download_link.json" 2>/dev/null)"

    local dl_url
    dl_url="$(echo "$dl_info" | grep -oP '"URI":\s*"\K[^"]+' | head -1)"

    if [[ -z "$dl_url" ]]; then
        warn "Could not get direct download link (Premium required for API downloads)"
        info "Download manually: https://www.nexusmods.com/${domain}/mods/${mod_id}?tab=files"
        return 1
    fi

    # Determine download directory based on game domain
    local download_dir="${MOD_ROOT}/downloads"
    for appid in "${!GAME_MODS[@]}"; do
        local name
        name="$(get_game_name "$appid")"
        local safe_name="${name// /_}"
        local game_dl="${MOD_ROOT}/${safe_name}/downloads"
        if [[ -d "$game_dl" ]]; then
            # Check if domain matches
            local check_domain
            check_domain="$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr -d ' ')"
            if [[ "$domain" == *"$check_domain"* ]] || [[ "$check_domain" == *"$domain"* ]]; then
                download_dir="$game_dl"
                break
            fi
        fi
    done

    ensure_dir "$download_dir"
    local output_file="${download_dir}/${file_name}"

    info "Downloading to: ${output_file}"
    curl -L --progress-bar -o "$output_file" "$dl_url" || {
        error "Download failed"
        return 1
    }

    success "Downloaded: ${output_file}"
    info "Deploy with: $SCRIPT_NAME deploy <game>"
}

nexus_handle_nxm() {
    local nxm_url="${1:-}"
    if [[ -z "$nxm_url" ]]; then
        error "No nxm:// URL provided"
        return 1
    fi

    # Parse nxm:// URL
    # Format: nxm://skyrimspecialedition/mods/12345/files/67890?key=xxx&expires=yyy
    local domain mod_id file_id key expires
    if [[ "$nxm_url" =~ ^nxm://([^/]+)/mods/([0-9]+)/files/([0-9]+)\?key=([^&]+)\&expires=([0-9]+) ]]; then
        domain="${BASH_REMATCH[1]}"
        mod_id="${BASH_REMATCH[2]}"
        file_id="${BASH_REMATCH[3]}"
        key="${BASH_REMATCH[4]}"
        expires="${BASH_REMATCH[5]}"
    elif [[ "$nxm_url" =~ ^nxm://([^/]+)/mods/([0-9]+)/files/([0-9]+) ]]; then
        domain="${BASH_REMATCH[1]}"
        mod_id="${BASH_REMATCH[2]}"
        file_id="${BASH_REMATCH[3]}"
        key=""
        expires=""
    else
        error "Could not parse nxm:// URL: ${nxm_url}"
        return 1
    fi

    local api_key
    api_key="$(nexus_get_key)" || return 1

    info "Handling nxm:// download"
    info "Game: ${domain} | Mod: ${mod_id} | File: ${file_id}"

    # Get download link with NXM key
    local dl_params=""
    if [[ -n "$key" ]]; then
        dl_params="?key=${key}&expires=${expires}"
    fi

    local dl_info
    dl_info="$(curl -sL \
        -H "apikey: ${api_key}" \
        -H "Accept: application/json" \
        "${NEXUS_API}/games/${domain}/mods/${mod_id}/files/${file_id}/download_link.json${dl_params}" 2>/dev/null)"

    local dl_url
    dl_url="$(echo "$dl_info" | grep -oP '"URI":\s*"\K[^"]+' | head -1)"

    if [[ -z "$dl_url" ]]; then
        error "Could not get download URL"
        # Send desktop notification
        if command -v notify-send &>/dev/null; then
            notify-send "24HG Forge Mod Manager" "Download failed — Premium may be required" --icon=dialog-error
        fi
        return 1
    fi

    # Get file info for the filename
    local file_info
    file_info="$(curl -sL \
        -H "apikey: ${api_key}" \
        -H "Accept: application/json" \
        "${NEXUS_API}/games/${domain}/mods/${mod_id}/files/${file_id}.json" 2>/dev/null)"

    local file_name
    file_name="$(echo "$file_info" | grep -oP '"file_name":\s*"\K[^"]+' || echo "nexus_${domain}_${mod_id}_${file_id}.zip")"

    # Find appropriate download directory
    local download_dir="${MOD_ROOT}/downloads"
    for appid in "${!GAME_MODS[@]}"; do
        local name
        name="$(get_game_name "$appid")"
        local safe_name="${name// /_}"
        local game_dl="${MOD_ROOT}/${safe_name}/downloads"
        if [[ -d "$game_dl" ]]; then
            local check="${name// /}"
            check="${check,,}"
            if [[ "$domain" == *"$check"* ]] || [[ "$check" == *"$domain"* ]]; then
                download_dir="$game_dl"
                break
            fi
        fi
    done

    ensure_dir "$download_dir"
    local output_file="${download_dir}/${file_name}"

    # Send notification
    if command -v notify-send &>/dev/null; then
        notify-send "24HG Forge Mod Manager" "Downloading: ${file_name}" --icon=folder-download
    fi

    curl -L --progress-bar -o "$output_file" "$dl_url" || {
        error "Download failed"
        if command -v notify-send &>/dev/null; then
            notify-send "24HG Forge Mod Manager" "Download failed: ${file_name}" --icon=dialog-error
        fi
        return 1
    }

    success "Downloaded: ${output_file}"

    if command -v notify-send &>/dev/null; then
        notify-send "24HG Forge Mod Manager" "Downloaded: ${file_name}\nDeploy: forge-mod-manager deploy ${domain}" --icon=dialog-information
    fi
}

nexus_register_protocol() {
    header "Registering nxm:// protocol handler"

    # Write the .desktop file for nxm:// handling
    local handler_desktop="${HOME}/.local/share/applications/forge-nxm-handler.desktop"
    ensure_dir "$(dirname "$handler_desktop")"

    cat > "${handler_desktop}" << 'DESKTOP'
[Desktop Entry]
Name=24HG Forge Mod Download Handler
Comment=Handle nxm:// links from Nexus Mods
Exec=/usr/bin/forge-mod-manager nexus handle %u
Type=Application
NoDisplay=true
MimeType=x-scheme-handler/nxm;
Categories=Utility;
DESKTOP

    # Register with xdg
    if command -v xdg-mime &>/dev/null; then
        xdg-mime default forge-nxm-handler.desktop x-scheme-handler/nxm
        success "Registered nxm:// protocol handler"
    else
        warn "xdg-mime not available — handler desktop file written but not registered"
        info "Desktop file: ${handler_desktop}"
    fi

    # Update desktop database
    if command -v update-desktop-database &>/dev/null; then
        update-desktop-database "${HOME}/.local/share/applications/" 2>/dev/null || true
    fi

    info "Browser nxm:// links will now be handled by 24HG Forge Mod Manager"
}

# ─────────────────────────────────────────────────────────────────────
# Command: status
# ─────────────────────────────────────────────────────────────────────

cmd_status() {
    header "24HG Forge Mod Manager Status"

    # Steam detection
    echo -e "\n${BOLD}  Steam${NC}"
    local steam_root
    if steam_root="$(find_steam_root 2>/dev/null)"; then
        local steam_type="native"
        is_flatpak_steam 2>/dev/null && steam_type="Flatpak"
        echo -e "    ${GREEN}Detected${NC} (${steam_type}): ${steam_root}"

        local lib_count=0
        while IFS= read -r _lib; do
            lib_count=$((lib_count + 1))
        done < <(find_library_folders 2>/dev/null)
        echo "    Library folders: ${lib_count}"
    else
        echo -e "    ${RED}Not found${NC}"
    fi

    # Protontricks
    echo -e "\n${BOLD}  Protontricks${NC}"
    local ptricks
    if ptricks="$(get_protontricks_cmd 2>/dev/null)"; then
        echo -e "    ${GREEN}Available${NC}: ${ptricks}"
    else
        echo -e "    ${YELLOW}Not installed${NC}"
    fi

    # Mod managers
    echo -e "\n${BOLD}  Mod Managers${NC}"

    if [[ -d "${VORTEX_ROOT}" ]]; then
        echo -e "    Vortex: ${GREEN}Installed${NC} (${VORTEX_ROOT})"
        if [[ -d "${VORTEX_ROOT}/prefix" ]]; then
            local vortex_size
            vortex_size="$(du -sb "${VORTEX_ROOT}" 2>/dev/null | awk '{print $1}')"
            echo "      Size: $(human_size "${vortex_size:-0}")"
        fi
    else
        echo -e "    Vortex: ${DIM}Not installed${NC}"
    fi

    if [[ -d "${MO2_ROOT}" ]]; then
        echo -e "    MO2:    ${GREEN}Installed${NC} (${MO2_ROOT})"
        if [[ -d "${MO2_ROOT}/app" ]]; then
            local mo2_size
            mo2_size="$(du -sb "${MO2_ROOT}" 2>/dev/null | awk '{print $1}')"
            echo "      Size: $(human_size "${mo2_size:-0}")"
        fi
    else
        echo -e "    MO2:    ${DIM}Not installed${NC}"
    fi

    # Nexus integration
    echo -e "\n${BOLD}  Nexus Mods${NC}"
    if [[ -f "$NEXUS_KEY_FILE" ]]; then
        echo -e "    API key: ${GREEN}Configured${NC}"
        # Check if nxm handler is registered
        local nxm_handler
        nxm_handler="$(xdg-mime query default x-scheme-handler/nxm 2>/dev/null || echo "")"
        if [[ "$nxm_handler" == *"forge"* ]]; then
            echo -e "    nxm:// handler: ${GREEN}Registered${NC}"
        else
            echo -e "    nxm:// handler: ${YELLOW}Not registered${NC} — run: $SCRIPT_NAME nexus register"
        fi
    else
        echo -e "    API key: ${DIM}Not configured${NC} — run: $SCRIPT_NAME nexus login"
    fi

    # Games with modding setup
    echo -e "\n${BOLD}  Configured Games${NC}"
    local game_count=0
    local total_mods=0
    local total_size=0

    if [[ -d "${MOD_ROOT}" ]]; then
        for game_dir in "${MOD_ROOT}"/*/; do
            [[ -d "$game_dir" ]] || continue
            local dir_name
            dir_name="$(basename "$game_dir")"

            # Count mods in staging
            local mod_count=0
            if [[ -d "${game_dir}/staging" ]]; then
                mod_count="$(find "${game_dir}/staging" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)"
            fi

            # Count downloads
            local dl_count=0
            if [[ -d "${game_dir}/downloads" ]]; then
                dl_count="$(find "${game_dir}/downloads" -maxdepth 1 -type f 2>/dev/null | wc -l)"
            fi

            # Size
            local dir_size
            dir_size="$(du -sb "$game_dir" 2>/dev/null | awk '{print $1}')"
            dir_size="${dir_size:-0}"

            local display_name="${dir_name//_/ }"
            printf "    %-35s %3d mods  %3d downloads  %s\n" \
                "$display_name" "$mod_count" "$dl_count" "$(human_size "$dir_size")"

            game_count=$((game_count + 1))
            total_mods=$((total_mods + mod_count))
            total_size=$((total_size + dir_size))
        done
    fi

    if [[ "$game_count" -eq 0 ]]; then
        echo -e "    ${DIM}No games configured. Run: $SCRIPT_NAME setup <game>${NC}"
    else
        echo ""
        echo "    ────────────────────────────────────────────────"
        printf "    %-35s %3d mods            %s\n" "TOTAL" "$total_mods" "$(human_size "$total_size")"
    fi

    # Available tools
    echo -e "\n${BOLD}  Available Tools${NC}"
    for tool in 7z unzip unrar wine winetricks curl; do
        if command -v "$tool" &>/dev/null; then
            echo -e "    ${tool}: ${GREEN}installed${NC}"
        else
            echo -e "    ${tool}: ${YELLOW}missing${NC}"
        fi
    done

    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Help & Version
# ─────────────────────────────────────────────────────────────────────

cmd_help() {
    echo -e "${BOLD}${CYAN}24HG Forge Mod Manager${NC} v${VERSION}"
    echo "Making game modding work on Linux"
    echo ""
    echo -e "${BOLD}USAGE:${NC}"
    echo "  $SCRIPT_NAME <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo -e "  ${GREEN}setup${NC} <game>           Setup modding environment for a game"
    echo -e "  ${GREEN}find-prefix${NC} <game>      Find and show a game's Proton prefix paths"
    echo -e "  ${GREEN}install-vortex${NC}          Install Vortex Mod Manager via Wine"
    echo -e "  ${GREEN}install-mo2${NC}             Install Mod Organizer 2 (portable)"
    echo -e "  ${GREEN}deploy${NC} <game>           Deploy mods from staging to game directory"
    echo -e "  ${GREEN}paths${NC} <game>            Show all modding-relevant paths for a game"
    echo -e "  ${GREEN}nexus${NC} <subcmd>          Nexus Mods integration"
    echo -e "  ${GREEN}status${NC}                  Show modding environment status"
    echo ""
    echo -e "${BOLD}NEXUS SUBCOMMANDS:${NC}"
    echo "  nexus login              Authenticate with Nexus API key"
    echo "  nexus search <game> <q>  Search mods on Nexus"
    echo "  nexus download <url>     Download a mod from Nexus"
    echo "  nexus handle <nxm-url>   Handle nxm:// protocol link"
    echo "  nexus register           Register nxm:// protocol handler"
    echo ""
    echo -e "${BOLD}GAME IDENTIFIERS:${NC}"
    echo "  You can use Steam App IDs or game names (partial match):"
    echo "    $SCRIPT_NAME setup 489830"
    echo "    $SCRIPT_NAME setup skyrim"
    echo "    $SCRIPT_NAME setup \"fallout 4\""
    echo ""
    echo -e "${BOLD}SUPPORTED GAMES:${NC}"
    for appid in $(echo "${!GAME_MODS[@]}" | tr ' ' '\n' | sort -n); do
        local entry="${GAME_MODS[$appid]}"
        local name="${entry%%|*}"
        printf "  %-10s %s\n" "$appid" "$name"
    done
    echo ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo "  $SCRIPT_NAME setup skyrim              # Setup Skyrim SE for modding"
    echo "  $SCRIPT_NAME find-prefix 489830        # Show Skyrim prefix paths"
    echo "  $SCRIPT_NAME paths \"fallout 4\"         # Show Fallout 4 mod paths"
    echo "  $SCRIPT_NAME nexus login               # Authenticate with Nexus"
    echo "  $SCRIPT_NAME nexus search skyrim SKSE   # Search Nexus for SKSE"
    echo "  $SCRIPT_NAME deploy skyrim             # Deploy staged mods"
    echo "  $SCRIPT_NAME status                    # Show overall status"
    echo ""
    echo -e "${BOLD}DIRECTORY STRUCTURE:${NC}"
    echo "  ~/Games/Mods/<Game>/downloads/    Downloaded mod archives"
    echo "  ~/Games/Mods/<Game>/staging/      Extracted, ready-to-deploy mods"
    echo "  ~/Games/Mods/<Game>/profiles/     Mod profiles (load order, etc.)"
    echo "  ~/Games/Mods/<Game>/backups/      Pre-deployment backups"
    echo "  ~/Games/Vortex/                   Vortex installation"
    echo "  ~/Games/ModOrganizer2/            MO2 installation"
    echo ""
}

# ─────────────────────────────────────────────────────────────────────
# Main Entrypoint
# ─────────────────────────────────────────────────────────────────────

main() {
    # Initialize name lookup table
    init_name_lookup

    # Ensure config dir exists
    mkdir -p "${CONFIG_DIR}" 2>/dev/null || true

    local command="${1:-help}"
    shift || true

    case "$command" in
        setup)          cmd_setup "$@" ;;
        find-prefix)    cmd_find_prefix "$@" ;;
        install-vortex) cmd_install_vortex "$@" ;;
        install-mo2)    cmd_install_mo2 "$@" ;;
        deploy)         cmd_deploy "$@" ;;
        paths)          cmd_paths "$@" ;;
        nexus)          cmd_nexus "$@" ;;
        status)         cmd_status "$@" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) echo "${SCRIPT_NAME} v${VERSION}" ;;
        *)
            error "Unknown command: ${command}"
            echo "Run '$SCRIPT_NAME help' for usage."
            exit 1
            ;;
    esac
}

main "$@"
