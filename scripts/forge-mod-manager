#!/usr/bin/env bash
set -euo pipefail
# 24HG Forge Mod Manager — Vortex/MO2-style mod management for Linux
# Manages mods with load order, conflict detection, profiles, and Nexus integration.
# Part of 24HG Forge — a gaming-first Linux distro based on Bazzite/Fedora Atomic.

readonly VERSION="2.0.0"
readonly SCRIPT_NAME="forge-mod-manager"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge/mod-manager"
readonly DATA_DIR="${CONFIG_DIR}/data"
readonly BACKUP_DIR="${CONFIG_DIR}/backups"
readonly PROFILE_DIR="${CONFIG_DIR}/profiles"

# Colors
readonly RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m' CYAN='\033[0;36m' BOLD='\033[1m'
readonly DIM='\033[2m' NC='\033[0m'

# ─────────────────────────────────────────────────────────────────────
# Game Database — game_id => "display_name|mod_path|plugin_file|type"
# type: bethesda (plugins.txt), simple (drop-in), smapi (StardewModdingAPI)
# Paths assume Steam + Proton prefixes where applicable
# ─────────────────────────────────────────────────────────────────────
declare -A GAMES=(
    [skyrimse]="Skyrim SE|${HOME}/.steam/steam/steamapps/common/Skyrim Special Edition/Data|plugins.txt|bethesda"
    [fallout4]="Fallout 4|${HOME}/.steam/steam/steamapps/common/Fallout 4/Data|plugins.txt|bethesda"
    [cyberpunk]="Cyberpunk 2077|${HOME}/.steam/steam/steamapps/common/Cyberpunk 2077/archive/pc/mod|none|simple"
    [bg3]="Baldur's Gate 3|${HOME}/.steam/steam/steamapps/common/Baldurs Gate 3/Data|modsettings.lsx|simple"
    [witcher3]="The Witcher 3|${HOME}/.steam/steam/steamapps/common/The Witcher 3/Mods|none|simple"
    [starfield]="Starfield|${HOME}/.steam/steam/steamapps/common/Starfield/Data|plugins.txt|bethesda"
    [valheim]="Valheim|${HOME}/.steam/steam/steamapps/common/Valheim/BepInEx/plugins|none|simple"
    [minecraft]="Minecraft|${HOME}/.minecraft/mods|none|simple"
    [rimworld]="RimWorld|${HOME}/.steam/steam/steamapps/common/RimWorld/Mods|none|simple"
    [stardew]="Stardew Valley|${HOME}/.steam/steam/steamapps/common/Stardew Valley/Mods|none|smapi"
)

# ─────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────

info()  { echo -e "${GREEN}[+]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[x]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }
header(){ echo -e "\n${BOLD}${CYAN}=== $* ===${NC}\n"; }

get_game_field() {
    local game="$1" field="$2"
    local entry="${GAMES[$game]:-}"
    [[ -z "$entry" ]] && return 1
    echo "$entry" | cut -d'|' -f"$field"
}

game_name()   { get_game_field "$1" 1; }
game_path()   { get_game_field "$1" 2; }
game_plugin() { get_game_field "$1" 3; }
game_type()   { get_game_field "$1" 4; }

validate_game() {
    local game="$1"
    [[ -n "${GAMES[$game]:-}" ]] || die "Unknown game '$game'. Use: ${!GAMES[*]}"
}

mod_data_dir() { echo "${DATA_DIR}/$1"; }
mod_state_file() { echo "${DATA_DIR}/$1/state.conf"; }

ensure_dirs() {
    local game="$1"
    mkdir -p "$(mod_data_dir "$game")" "${BACKUP_DIR}/$game" "${PROFILE_DIR}/$game"
    local gp; gp="$(game_path "$game")"
    [[ -d "$gp" ]] || mkdir -p "$gp"
}

# Load mod state: associative array MOD_STATE[mod_name]=enabled|disabled
declare -A MOD_STATE=()
load_state() {
    MOD_STATE=()
    local sf; sf="$(mod_state_file "$1")"
    [[ -f "$sf" ]] || return 0
    while IFS='=' read -r name status; do
        [[ -n "$name" && "$name" != \#* ]] && MOD_STATE["$name"]="$status"
    done < "$sf"
}

save_state() {
    local game="$1" sf
    sf="$(mod_state_file "$game")"
    : > "$sf"
    for mod in "${!MOD_STATE[@]}"; do
        echo "${mod}=${MOD_STATE[$mod]}" >> "$sf"
    done
}

# File manifest for a mod (tracks which files it owns)
manifest_file() { echo "$(mod_data_dir "$1")/manifests/$2.manifest"; }

save_manifest() {
    local game="$1" mod="$2"; shift 2
    local mf; mf="$(manifest_file "$game" "$mod")"
    mkdir -p "$(dirname "$mf")"
    printf '%s\n' "$@" > "$mf"
}

load_manifest() {
    local mf; mf="$(manifest_file "$1" "$2")"
    [[ -f "$mf" ]] && cat "$mf"
}

# ─────────────────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────────────────

cmd_list() {
    local game="$1"
    validate_game "$game"
    load_state "$game"
    header "Mods for $(game_name "$game")"
    if [[ ${#MOD_STATE[@]} -eq 0 ]]; then
        echo "  No mods installed."
        return
    fi
    local idx=0
    for mod in $(echo "${!MOD_STATE[@]}" | tr ' ' '\n' | sort); do
        idx=$((idx + 1))
        local status="${MOD_STATE[$mod]}"
        local icon files_count
        if [[ "$status" == "enabled" ]]; then
            icon="${GREEN}ON ${NC}"
        else
            icon="${RED}OFF${NC}"
        fi
        files_count=$(wc -l < "$(manifest_file "$game" "$mod")" 2>/dev/null || echo "0")
        printf "  ${DIM}%3d${NC} [%b] ${BOLD}%-30s${NC} ${DIM}(%s files)${NC}\n" \
            "$idx" "$icon" "$mod" "$files_count"
    done
    echo ""
    info "Total: ${#MOD_STATE[@]} mods"
}

cmd_install() {
    local game="$1" archive="$2"
    validate_game "$game"
    ensure_dirs "$game"
    [[ -f "$archive" ]] || die "Archive not found: $archive"

    local mod_name
    mod_name="$(basename "$archive" | sed 's/\.\(zip\|7z\|rar\|tar\.gz\|tgz\)$//')"
    mod_name="${mod_name// /_}"

    load_state "$game"
    [[ -z "${MOD_STATE[$mod_name]:-}" ]] || die "Mod '$mod_name' already installed. Remove first."

    local gp; gp="$(game_path "$game")"
    local tmpdir; tmpdir="$(mktemp -d)"
    trap "rm -rf '$tmpdir'" RETURN

    header "Installing '$mod_name' for $(game_name "$game")"
    info "Extracting archive..."

    case "${archive,,}" in
        *.zip)       unzip -q "$archive" -d "$tmpdir" ;;
        *.7z)        7z x -o"$tmpdir" "$archive" > /dev/null ;;
        *.rar)       unrar x -o+ "$archive" "$tmpdir/" > /dev/null ;;
        *.tar.gz|*.tgz) tar xzf "$archive" -C "$tmpdir" ;;
        *)           die "Unsupported format. Use zip, 7z, rar, or tar.gz" ;;
    esac

    # Flatten if archive has a single top-level directory
    local src="$tmpdir"
    local entries; entries=$(find "$src" -maxdepth 1 -mindepth 1 | wc -l)
    if [[ "$entries" -eq 1 ]]; then
        local single; single=$(find "$src" -maxdepth 1 -mindepth 1)
        [[ -d "$single" ]] && src="$single"
    fi

    # Collect files and deploy
    local -a deployed=()
    while IFS= read -r -d '' file; do
        local rel="${file#$src/}"
        local dest="${gp}/${rel}"
        mkdir -p "$(dirname "$dest")"
        # Backup existing file if it's a vanilla file
        if [[ -f "$dest" ]] && [[ ! -f "${BACKUP_DIR}/${game}/${rel}" ]]; then
            mkdir -p "$(dirname "${BACKUP_DIR}/${game}/${rel}")"
            cp -p "$dest" "${BACKUP_DIR}/${game}/${rel}"
        fi
        cp -p "$file" "$dest"
        deployed+=("$rel")
    done < <(find "$src" -type f -print0)

    save_manifest "$game" "$mod_name" "${deployed[@]}"
    MOD_STATE["$mod_name"]="enabled"
    save_state "$game"

    info "Installed ${#deployed[@]} files"
    info "Mod '${mod_name}' is now ${GREEN}enabled${NC}"

    # Auto-add plugins for Bethesda games
    if [[ "$(game_type "$game")" == "bethesda" ]]; then
        for f in "${deployed[@]}"; do
            if [[ "${f,,}" =~ \.(esp|esm|esl)$ ]]; then
                _add_plugin "$game" "$(basename "$f")"
                info "Added plugin: $(basename "$f")"
            fi
        done
    fi
}

cmd_remove() {
    local game="$1" mod="$2"
    validate_game "$game"
    load_state "$game"
    [[ -n "${MOD_STATE[$mod]:-}" ]] || die "Mod '$mod' not found"

    local gp; gp="$(game_path "$game")"
    header "Removing '$mod' from $(game_name "$game")"

    # Remove deployed files, restore backups
    while IFS= read -r rel; do
        [[ -z "$rel" ]] && continue
        local dest="${gp}/${rel}"
        rm -f "$dest"
        if [[ -f "${BACKUP_DIR}/${game}/${rel}" ]]; then
            cp -p "${BACKUP_DIR}/${game}/${rel}" "$dest"
            rm -f "${BACKUP_DIR}/${game}/${rel}"
            info "Restored vanilla: $rel"
        fi
    done < <(load_manifest "$game" "$mod")

    # Remove plugins for Bethesda games
    if [[ "$(game_type "$game")" == "bethesda" ]]; then
        while IFS= read -r rel; do
            [[ "${rel,,}" =~ \.(esp|esm|esl)$ ]] && _remove_plugin "$game" "$(basename "$rel")"
        done < <(load_manifest "$game" "$mod")
    fi

    rm -f "$(manifest_file "$game" "$mod")"
    unset "MOD_STATE[$mod]"
    save_state "$game"
    info "Mod '$mod' removed"
}

cmd_toggle() {
    local action="$1" game="$2" mod="$3"
    validate_game "$game"
    load_state "$game"
    [[ -n "${MOD_STATE[$mod]:-}" ]] || die "Mod '$mod' not found"

    local gp; gp="$(game_path "$game")"

    if [[ "$action" == "enable" ]]; then
        [[ "${MOD_STATE[$mod]}" == "enabled" ]] && { info "Already enabled"; return; }
        while IFS= read -r rel; do
            [[ -z "$rel" ]] && continue
            local src="${gp}/.disabled/${mod}/${rel}"
            local dest="${gp}/${rel}"
            if [[ -f "$src" ]]; then
                mkdir -p "$(dirname "$dest")"
                mv "$src" "$dest"
            fi
        done < <(load_manifest "$game" "$mod")
        MOD_STATE["$mod"]="enabled"
        info "Mod '$mod' ${GREEN}enabled${NC}"
    else
        [[ "${MOD_STATE[$mod]}" == "disabled" ]] && { info "Already disabled"; return; }
        while IFS= read -r rel; do
            [[ -z "$rel" ]] && continue
            local src="${gp}/${rel}"
            local dest="${gp}/.disabled/${mod}/${rel}"
            if [[ -f "$src" ]]; then
                mkdir -p "$(dirname "$dest")"
                mv "$src" "$dest"
            fi
        done < <(load_manifest "$game" "$mod")
        MOD_STATE["$mod"]="disabled"
        info "Mod '$mod' ${RED}disabled${NC}"
    fi
    save_state "$game"
}

# ─────────────────────────────────────────────────────────────────────
# Load Order (Bethesda games)
# ─────────────────────────────────────────────────────────────────────

_plugins_txt() {
    local game="$1"
    # Bethesda plugins.txt lives in the Proton prefix AppData
    local pfx="${HOME}/.steam/steam/steamapps/compatdata"
    case "$game" in
        skyrimse)  echo "${pfx}/489830/pfx/drive_c/users/steamuser/AppData/Local/Skyrim Special Edition/plugins.txt" ;;
        fallout4)  echo "${pfx}/377160/pfx/drive_c/users/steamuser/AppData/Local/Fallout4/plugins.txt" ;;
        starfield) echo "${pfx}/1716740/pfx/drive_c/users/steamuser/AppData/Local/Starfield/plugins.txt" ;;
        *)         echo "${DATA_DIR}/${game}/plugins.txt" ;;
    esac
}

_add_plugin() {
    local game="$1" plugin="$2"
    local pf; pf="$(_plugins_txt "$game")"
    mkdir -p "$(dirname "$pf")"
    grep -qxF "*${plugin}" "$pf" 2>/dev/null || echo "*${plugin}" >> "$pf"
}

_remove_plugin() {
    local game="$1" plugin="$2"
    local pf; pf="$(_plugins_txt "$game")"
    [[ -f "$pf" ]] && sed -i "/^\*\?${plugin}$/d" "$pf"
}

cmd_order() {
    local game="$1"
    validate_game "$game"
    if [[ "$(game_type "$game")" != "bethesda" ]]; then
        warn "Load order only applies to Bethesda games (skyrimse, fallout4, starfield)"
        return
    fi
    local pf; pf="$(_plugins_txt "$game")"
    header "Load Order — $(game_name "$game")"
    if [[ ! -f "$pf" ]]; then
        echo "  No plugins.txt found. Install Bethesda mods first."
        return
    fi
    local idx=0
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        idx=$((idx + 1))
        local status="$GREEN" tag="active"
        if [[ "$line" != \** ]]; then
            status="$RED"; tag="inactive"
        fi
        local name="${line#\*}"
        printf "  ${DIM}%3d${NC} [%b%-8s${NC}] %s\n" "$idx" "$status" "$tag" "$name"
    done < "$pf"
    echo ""
    info "Edit directly: $pf"
    info "Prefix with * to enable, remove * to disable"
}

# ─────────────────────────────────────────────────────────────────────
# Conflict Detection
# ─────────────────────────────────────────────────────────────────────

cmd_conflicts() {
    local game="$1"
    validate_game "$game"
    load_state "$game"
    header "Conflict Check — $(game_name "$game")"

    local manifest_dir="$(mod_data_dir "$game")/manifests"
    [[ -d "$manifest_dir" ]] || { info "No mods installed."; return; }

    # Build file->mod mapping
    declare -A file_owners=()
    local conflict_found=0

    for mf in "$manifest_dir"/*.manifest; do
        [[ -f "$mf" ]] || continue
        local mod; mod="$(basename "$mf" .manifest)"
        while IFS= read -r rel; do
            [[ -z "$rel" ]] && continue
            if [[ -n "${file_owners[$rel]:-}" ]]; then
                file_owners["$rel"]="${file_owners[$rel]}, $mod"
            else
                file_owners["$rel"]="$mod"
            fi
        done < "$mf"
    done

    for file in "${!file_owners[@]}"; do
        local owners="${file_owners[$file]}"
        if [[ "$owners" == *","* ]]; then
            conflict_found=1
            echo -e "  ${RED}CONFLICT${NC} ${DIM}${file}${NC}"
            echo -e "           Owned by: ${BOLD}${owners}${NC}"
        fi
    done

    if [[ "$conflict_found" -eq 0 ]]; then
        info "No conflicts detected."
    else
        echo ""
        warn "Conflicts found! The last-installed mod wins. Reorder by reinstalling."
    fi
}

# ─────────────────────────────────────────────────────────────────────
# Profiles
# ─────────────────────────────────────────────────────────────────────

cmd_profile() {
    local game="$1" action="${2:-list}" name="${3:-}"
    validate_game "$game"
    ensure_dirs "$game"

    local pdir="${PROFILE_DIR}/${game}"

    case "$action" in
        save)
            [[ -n "$name" ]] || die "Usage: $SCRIPT_NAME profile <game> save <name>"
            local dest="${pdir}/${name}"
            mkdir -p "$dest"
            # Save state and manifests
            cp -f "$(mod_state_file "$game")" "$dest/state.conf" 2>/dev/null || true
            local mdir="$(mod_data_dir "$game")/manifests"
            [[ -d "$mdir" ]] && cp -r "$mdir" "$dest/"
            # Save plugins.txt for Bethesda
            if [[ "$(game_type "$game")" == "bethesda" ]]; then
                local pf; pf="$(_plugins_txt "$game")"
                [[ -f "$pf" ]] && cp -f "$pf" "$dest/plugins.txt"
            fi
            info "Profile '${name}' saved for $(game_name "$game")"
            ;;
        load)
            [[ -n "$name" ]] || die "Usage: $SCRIPT_NAME profile <game> load <name>"
            local src="${pdir}/${name}"
            [[ -d "$src" ]] || die "Profile '$name' not found"
            # Disable all current mods first
            load_state "$game"
            local gp; gp="$(game_path "$game")"
            for mod in "${!MOD_STATE[@]}"; do
                [[ "${MOD_STATE[$mod]}" == "enabled" ]] && cmd_toggle disable "$game" "$mod"
            done
            # Restore state and manifests
            cp -f "$src/state.conf" "$(mod_state_file "$game")" 2>/dev/null || true
            [[ -d "$src/manifests" ]] && cp -r "$src/manifests" "$(mod_data_dir "$game")/"
            # Restore plugins.txt
            if [[ "$(game_type "$game")" == "bethesda" && -f "$src/plugins.txt" ]]; then
                local pf; pf="$(_plugins_txt "$game")"
                mkdir -p "$(dirname "$pf")"
                cp -f "$src/plugins.txt" "$pf"
            fi
            # Enable mods per saved state
            load_state "$game"
            for mod in "${!MOD_STATE[@]}"; do
                if [[ "${MOD_STATE[$mod]}" == "enabled" ]]; then
                    local mdir="${gp}/.disabled/${mod}"
                    if [[ -d "$mdir" ]]; then
                        while IFS= read -r rel; do
                            [[ -z "$rel" ]] && continue
                            local dest="${gp}/${rel}"
                            mkdir -p "$(dirname "$dest")"
                            [[ -f "${mdir}/${rel}" ]] && mv "${mdir}/${rel}" "$dest"
                        done < <(load_manifest "$game" "$mod")
                    fi
                fi
            done
            info "Profile '${name}' loaded for $(game_name "$game")"
            ;;
        list)
            header "Profiles — $(game_name "$game")"
            local count=0
            for d in "$pdir"/*/; do
                [[ -d "$d" ]] || continue
                count=$((count + 1))
                local pname; pname="$(basename "$d")"
                local mod_count; mod_count=$(wc -l < "$d/state.conf" 2>/dev/null || echo 0)
                printf "  ${BOLD}%-20s${NC} ${DIM}(%s mods)${NC}\n" "$pname" "$mod_count"
            done
            [[ "$count" -eq 0 ]] && echo "  No profiles saved."
            ;;
        *) die "Unknown profile action '$action'. Use: save, load, list" ;;
    esac
}

# ─────────────────────────────────────────────────────────────────────
# Backup & Restore
# ─────────────────────────────────────────────────────────────────────

cmd_backup() {
    local game="$1"
    validate_game "$game"
    ensure_dirs "$game"
    local gp; gp="$(game_path "$game")"
    [[ -d "$gp" ]] || die "Game directory not found: $gp"

    header "Backup Vanilla Files — $(game_name "$game")"
    local bdir="${BACKUP_DIR}/${game}"
    local count=0

    while IFS= read -r -d '' file; do
        local rel="${file#$gp/}"
        local dest="${bdir}/${rel}"
        if [[ ! -f "$dest" ]]; then
            mkdir -p "$(dirname "$dest")"
            cp -p "$file" "$dest"
            count=$((count + 1))
        fi
    done < <(find "$gp" -type f -not -path '*/.disabled/*' -print0 2>/dev/null)

    info "Backed up $count new files to ${bdir}"
    info "Total backup size: $(du -sh "$bdir" 2>/dev/null | cut -f1)"
}

cmd_restore() {
    local game="$1"
    validate_game "$game"
    local gp; gp="$(game_path "$game")"
    local bdir="${BACKUP_DIR}/${game}"
    [[ -d "$bdir" ]] || die "No backup found for $(game_name "$game")"

    header "Restoring Vanilla Files — $(game_name "$game")"
    local count=0
    while IFS= read -r -d '' file; do
        local rel="${file#$bdir/}"
        cp -p "$file" "${gp}/${rel}"
        count=$((count + 1))
    done < <(find "$bdir" -type f -print0)
    info "Restored $count files"
}

# ─────────────────────────────────────────────────────────────────────
# Auto-scan for loose mods
# ─────────────────────────────────────────────────────────────────────

cmd_scan() {
    local game="$1"
    validate_game "$game"
    ensure_dirs "$game"
    load_state "$game"
    local gp; gp="$(game_path "$game")"
    [[ -d "$gp" ]] || die "Game directory not found: $gp"

    header "Scanning for untracked mods — $(game_name "$game")"

    # Gather all tracked files
    declare -A tracked=()
    local mdir="$(mod_data_dir "$game")/manifests"
    if [[ -d "$mdir" ]]; then
        for mf in "$mdir"/*.manifest; do
            [[ -f "$mf" ]] || continue
            while IFS= read -r rel; do
                [[ -n "$rel" ]] && tracked["$rel"]=1
            done < "$mf"
        done
    fi

    # Gather backup (vanilla) files
    declare -A vanilla=()
    local bdir="${BACKUP_DIR}/${game}"
    if [[ -d "$bdir" ]]; then
        while IFS= read -r -d '' file; do
            vanilla["${file#$bdir/}"]=1
        done < <(find "$bdir" -type f -print0)
    fi

    # Find untracked, non-vanilla files
    local found=0
    while IFS= read -r -d '' file; do
        local rel="${file#$gp/}"
        [[ "$rel" == .disabled/* ]] && continue
        if [[ -z "${tracked[$rel]:-}" && -z "${vanilla[$rel]:-}" ]]; then
            echo -e "  ${YELLOW}?${NC} $rel"
            found=$((found + 1))
        fi
    done < <(find "$gp" -type f -print0 2>/dev/null)

    if [[ "$found" -eq 0 ]]; then
        info "No untracked files found."
    else
        echo ""
        warn "Found $found untracked file(s). These may be manually installed mods."
    fi
}

# ─────────────────────────────────────────────────────────────────────
# Nexus Mods nxm:// Protocol Handler
# ─────────────────────────────────────────────────────────────────────

cmd_nxm_register() {
    header "Nexus Mods nxm:// Protocol Registration"
    local desktop="${HOME}/.local/share/applications/forge-nxm-handler.desktop"
    mkdir -p "$(dirname "$desktop")"
    cat > "$desktop" <<-DESK
	[Desktop Entry]
	Type=Application
	Name=Forge NXM Handler
	Exec=$(realpath "$0") nxm-handle %u
	MimeType=x-scheme-handler/nxm;
	NoDisplay=true
	Terminal=false
	DESK
    xdg-mime default forge-nxm-handler.desktop x-scheme-handler/nxm 2>/dev/null || true
    update-desktop-database "${HOME}/.local/share/applications" 2>/dev/null || true
    info "Registered nxm:// protocol handler"
    info "Click 'Download with manager' on Nexus Mods to trigger downloads"
}

cmd_nxm_handle() {
    local url="$1"
    # nxm://skyrimspecialedition/mods/12345/files/67890?key=abc&expires=123
    if [[ "$url" =~ ^nxm://([^/]+)/mods/([0-9]+)/files/([0-9]+) ]]; then
        local nx_game="${BASH_REMATCH[1]}"
        local mod_id="${BASH_REMATCH[2]}"
        local file_id="${BASH_REMATCH[3]}"
        notify-send -a "Forge Mod Manager" "Nexus Download Detected" \
            "Game: ${nx_game}\nMod ID: ${mod_id}\nFile ID: ${file_id}\n\nDownload the archive and run:\nforge-mod-manager install <game> <archive>" \
            2>/dev/null || true
        info "Nexus link parsed: game=$nx_game mod=$mod_id file=$file_id"
        info "Download the mod archive from Nexus, then install with:"
        echo "  $SCRIPT_NAME install <game> <downloaded-archive>"
    else
        warn "Unrecognized nxm:// URL format: $url"
    fi
}

# ─────────────────────────────────────────────────────────────────────
# Usage
# ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<-EOF
	${BOLD}${CYAN}Forge Mod Manager v${VERSION}${NC} — Game mod management for Linux

	${BOLD}Usage:${NC} $SCRIPT_NAME <command> [options]

	${BOLD}Commands:${NC}
	  list <game>                     List installed mods
	  install <game> <archive>        Install mod from zip/7z/rar archive
	  remove <game> <mod>             Remove an installed mod
	  enable <game> <mod>             Enable a disabled mod
	  disable <game> <mod>            Disable a mod (keeps files)
	  order <game>                    Show/edit plugin load order (Bethesda)
	  conflicts <game>                Detect file conflicts between mods
	  profile <game> [save|load|list] [name]  Manage mod profiles
	  backup <game>                   Backup vanilla game files
	  restore <game>                  Restore vanilla files from backup
	  scan <game>                     Auto-detect untracked mods
	  nxm-register                    Register nxm:// protocol handler
	  nxm-handle <url>                Handle nxm:// URL (internal)
	  games                           List supported games

	${BOLD}Supported Games:${NC}
	  skyrimse  fallout4  cyberpunk  bg3  witcher3
	  starfield valheim   minecraft  rimworld  stardew

	${BOLD}Examples:${NC}
	  $SCRIPT_NAME install skyrimse ~/Downloads/SkyUI.zip
	  $SCRIPT_NAME list skyrimse
	  $SCRIPT_NAME conflicts skyrimse
	  $SCRIPT_NAME profile skyrimse save vanilla-plus
	  $SCRIPT_NAME order skyrimse
	  $SCRIPT_NAME disable skyrimse SkyUI

	${BOLD}Data:${NC} ${CONFIG_DIR}
	EOF
}

cmd_games() {
    header "Supported Games"
    for game in $(echo "${!GAMES[@]}" | tr ' ' '\n' | sort); do
        local name; name="$(game_name "$game")"
        local gp; gp="$(game_path "$game")"
        local gtype; gtype="$(game_type "$game")"
        local status="${RED}not found${NC}"
        [[ -d "$gp" ]] && status="${GREEN}detected${NC}"
        printf "  ${BOLD}%-12s${NC} %-25s [%b] ${DIM}(%s)${NC}\n" "$game" "$name" "$status" "$gtype"
    done
}

# ─────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────

main() {
    mkdir -p "$CONFIG_DIR" "$DATA_DIR" "$BACKUP_DIR" "$PROFILE_DIR"

    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        list)         [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME list <game>"; cmd_list "$1" ;;
        install)      [[ $# -ge 2 ]] || die "Usage: $SCRIPT_NAME install <game> <archive>"; cmd_install "$1" "$2" ;;
        remove)       [[ $# -ge 2 ]] || die "Usage: $SCRIPT_NAME remove <game> <mod>"; cmd_remove "$1" "$2" ;;
        enable)       [[ $# -ge 2 ]] || die "Usage: $SCRIPT_NAME enable <game> <mod>"; cmd_toggle enable "$1" "$2" ;;
        disable)      [[ $# -ge 2 ]] || die "Usage: $SCRIPT_NAME disable <game> <mod>"; cmd_toggle disable "$1" "$2" ;;
        order)        [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME order <game>"; cmd_order "$1" ;;
        conflicts)    [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME conflicts <game>"; cmd_conflicts "$1" ;;
        profile)      [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME profile <game> [save|load|list] [name]"; cmd_profile "$@" ;;
        backup)       [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME backup <game>"; cmd_backup "$1" ;;
        restore)      [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME restore <game>"; cmd_restore "$1" ;;
        scan)         [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME scan <game>"; cmd_scan "$1" ;;
        nxm-register) cmd_nxm_register ;;
        nxm-handle)   [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME nxm-handle <url>"; cmd_nxm_handle "$1" ;;
        games)        cmd_games ;;
        help|--help|-h) usage ;;
        version|--version|-v) echo "Forge Mod Manager v${VERSION}" ;;
        *)            err "Unknown command: $cmd"; usage; exit 1 ;;
    esac
}

main "$@"
