#!/usr/bin/env bash
set -euo pipefail
# 24HG Forge Mod Manager Bridge — Making game modding work on Linux
#
# Bridges the gap between Windows mod managers (Vortex, MO2) and Linux.
# Handles Proton prefix detection, path translation, mod deployment,
# Nexus Mods integration, and nxm:// protocol handling.
#
# Part of 24HG Forge — a gaming-first Linux distro based on Bazzite/Fedora Atomic.

# ─────────────────────────────────────────────────────────────────────
# Constants & Configuration
# ─────────────────────────────────────────────────────────────────────

readonly VERSION="1.0.0"
readonly SCRIPT_NAME="forge-mod-manager"
readonly MOD_ROOT="${HOME}/Games/Mods"
readonly MO2_ROOT="${HOME}/Games/ModOrganizer2"
readonly VORTEX_ROOT="${HOME}/Games/Vortex"
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge/mod-manager"
readonly NEXUS_KEY_FILE="${CONFIG_DIR}/nexus-api-key"
readonly NEXUS_API="https://api.nexusmods.com/v1"
readonly NXM_DESKTOP="/usr/share/applications/forge-nxm-handler.desktop"

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly MAGENTA='\033[0;35m'
readonly BOLD='\033[1m'
readonly DIM='\033[2m'
readonly NC='\033[0m'

# ─────────────────────────────────────────────────────────────────────
