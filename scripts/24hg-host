    echo ""
    echo -e "  ${BOLD}REQUIREMENTS${RESET}"
    echo -e "    Container runtime: ${DIM}podman (preferred) or docker${RESET}"
    echo -e "    Port forwarding:   ${DIM}miniupnpc (auto) or manual router config${RESET}"
    echo ""
}

# ── CLI Options Parsing ─────────────────────────────────────────────────────

parse_start_options() {
    local game="$1"
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port|-p)
                [[ -n "${2:-}" ]] || die "--port requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                sed -i "s/^PORT=.*/PORT=$2/" "$config_file"
                info "Port set to $2"
                shift 2
                ;;
            --ram|-m)
                [[ -n "${2:-}" ]] || die "--ram requires a value (in MB)"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                sed -i "s/^RAM=.*/RAM=$2/" "$config_file"
                info "RAM set to ${2}MB"
                shift 2
                ;;
            --password)
                [[ -n "${2:-}" ]] || die "--password requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                sed -i "s/^PASSWORD=.*/PASSWORD=\"$2\"/" "$config_file"
                info "Password set"
                shift 2
                ;;
            --name)
                [[ -n "${2:-}" ]] || die "--name requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                sed -i "s/^SERVER_NAME=.*/SERVER_NAME=\"$2\"/" "$config_file"
                info "Server name set to: $2"
                shift 2
                ;;
            --players)
                [[ -n "${2:-}" ]] || die "--players requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                sed -i "s/^MAX_PLAYERS=.*/MAX_PLAYERS=$2/" "$config_file"
                info "Max players set to $2"
                shift 2
                ;;
            --no-announce)
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                sed -i "s/^AUTO_ANNOUNCE=.*/AUTO_ANNOUNCE=false/" "$config_file"
                sed -i "s/^HUB_REGISTER=.*/HUB_REGISTER=false/" "$config_file"
                info "Announcements disabled"
                shift
                ;;
            --no-upnp)
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                sed -i "s/^UPNP_ENABLED=.*/UPNP_ENABLED=false/" "$config_file"
                info "UPnP disabled"
                shift
                ;;
            --version|-V)
                [[ -n "${2:-}" ]] || die "--version requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                case "$game" in
                    minecraft)
                        sed -i "s/^MC_VERSION=.*/MC_VERSION=$2/" "$config_file"
                        info "Minecraft version set to $2"
                        ;;
                    *)
                        warn "--version is only supported for Minecraft"
                        ;;
                esac
                shift 2
                ;;
            --seed|-s)
                [[ -n "${2:-}" ]] || die "--seed requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                case "$game" in
                    minecraft)   sed -i "s/^MC_SEED=.*/MC_SEED=\"$2\"/" "$config_file" ;;
                    valheim)     sed -i "s/^VH_SEED=.*/VH_SEED=\"$2\"/" "$config_file" ;;
                    terraria)    sed -i "s/^TR_SEED=.*/TR_SEED=\"$2\"/" "$config_file" ;;
                    7days)       sed -i "s/^SDTD_WORLD_GEN_SEED=.*/SDTD_WORLD_GEN_SEED=\"$2\"/" "$config_file" ;;
                    *)           warn "--seed not supported for $game" ;;
                esac
                info "World seed set to: $2"
                shift 2
                ;;
            --mode)
                [[ -n "${2:-}" ]] || die "--mode requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                case "$game" in
                    minecraft)
                        sed -i "s/^MC_GAMEMODE=.*/MC_GAMEMODE=$2/" "$config_file"
                        info "Game mode set to $2"
                        ;;
                    cs2)
                        sed -i "s/^CS2_GAME_MODE=.*/CS2_GAME_MODE=$2/" "$config_file"
                        info "Game mode set to $2"
                        ;;
                    *)
                        warn "--mode not supported for $game"
                        ;;
                esac
                shift 2
                ;;
            --map)
                [[ -n "${2:-}" ]] || die "--map requires a value"
                local config_file="$CONFIG_DIR/$game/server.conf"
                init_default_config "$game"
                case "$game" in
                    cs2)
                        sed -i "s/^CS2_MAP=.*/CS2_MAP=$2/" "$config_file"
                        info "Map set to $2"
                        ;;
                    *)
                        warn "--map not supported for $game"
                        ;;
                esac
                shift 2
                ;;
            --help|-h)
                cmd_help
                exit 0
                ;;
            *)
                die "Unknown option: $1\n  Run '24hg-host start --help' for usage."
                ;;
        esac
    done
}

# ── Completions ─────────────────────────────────────────────────────────────

generate_completions() {
    local shell="${1:-bash}"
    case "$shell" in
        bash)
            cat <<'COMP'
_hg24_host() {
    local cur prev commands games
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    commands="list start stop status logs config update players announce backup restore help"
    games="minecraft minecraft-bedrock valheim terraria factorio zomboid 7days satisfactory palworld cs2"

    case "$prev" in
        24hg-host)
            COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
            ;;
        start|stop|logs|config|update|players|backup|restore)
            COMPREPLY=( $(compgen -W "$games" -- "$cur") )
            ;;
    esac
    return 0
}
complete -F _hg24_host 24hg-host
COMP
            ;;
        zsh)
            cat <<'COMP'
#compdef 24hg-host
_hg24_host() {
    local -a commands games
    commands=(list start stop status logs config update players announce backup restore help)
    games=(minecraft minecraft-bedrock valheim terraria factorio zomboid 7days satisfactory palworld cs2)

    _arguments '1:command:($commands)' '2:game:($games)'
}
_hg24_host
COMP
            ;;
    esac
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    local command="${1:-list}"
    shift 2>/dev/null || true

    # Special non-container commands
    case "$command" in
        --help|-h|help)
            cmd_help
            exit 0
            ;;
        --version)
            echo "24hg-host $HG24_VERSION"
            exit 0
            ;;
        --completions)
            generate_completions "${1:-bash}"
            exit 0
            ;;
    esac

    # All other commands need a container runtime
    detect_container_runtime

    case "$command" in
        list|ls)
            cmd_list
            ;;
        start)
            local game="${1:-}"
            shift 2>/dev/null || true
            if [[ -n "$game" ]]; then
                parse_start_options "$game" "$@"
            fi
            cmd_start "$game"
            ;;
        stop)
            cmd_stop "${1:-}"
            ;;
        status|st)
            cmd_status
            ;;
        logs|log)
            cmd_logs "${1:-}" "${2:-100}"
            ;;
        config|cfg)
            cmd_config "${1:-}"
            ;;
        update|up)
            cmd_update "${1:-}"
            ;;
        players|pl)
            cmd_players "${1:-}"
            ;;
        announce)
            cmd_announce
            ;;
        backup|bk)
            cmd_backup "${1:-}"
            ;;
        restore|rs)
            cmd_restore "${1:-}" "${2:-}"
            ;;
        *)
            die "Unknown command: $command\n  Run '24hg-host help' for usage."
            ;;
    esac
}

main "$@"
