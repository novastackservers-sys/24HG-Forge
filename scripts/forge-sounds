#!/bin/bash
#
# forge-sounds — Generate, install, and manage the 24HG Forge sound theme
# Part of 24HG Forge (24 Hour Gaming)
#
# Usage: forge-sounds {install|enable|disable|test|status|list} [args...]
#

set -euo pipefail

THEME_NAME="forge"
SYSTEM_DIR="/usr/share/sounds/${THEME_NAME}/stereo"
USER_DIR="${HOME}/.local/share/sounds/${THEME_NAME}/stereo"
USER_THEME_DIR="${HOME}/.local/share/sounds/${THEME_NAME}"
SYSTEM_THEME_DIR="/usr/share/sounds/${THEME_NAME}"
SAMPLE_RATE=44100
INDEX_THEME_CONTENT="[Sound Theme]
Name=24HG Forge
Comment=24 Hour Gaming sound theme
Inherits=freedesktop
Directories=stereo

[stereo]
OutputProfile=stereo"

# ── Sound definitions ────────────────────────────────────────────────────────
# Each entry: name|description|generation_function
declare -A SOUND_DESC=(
    [desktop-login]="Pleasant ascending 3-note chime (login)"
    [message-new-instant]="Quick double-tap notification"
    [dialog-information]="Soft single info tone"
    [dialog-warning]="Two-tone warning alert"
    [dialog-error]="Low descending error tone"
    [device-added]="Rising chirp (device/controller connected)"
    [device-removed]="Falling chirp (device disconnected)"
    [screen-capture]="Camera shutter click"
    [game-launch]="Epic ascending chord (game starting)"
    [achievement]="Triumphant 4-note fanfare"
    [complete]="Satisfying completion ding"
)

SOUND_NAMES=(
    desktop-login
    message-new-instant
    dialog-information
    dialog-warning
    dialog-error
    device-added
    device-removed
    screen-capture
    game-launch
    achievement
    complete
)

# ── Helpers ──────────────────────────────────────────────────────────────────

log_info()  { echo -e "\033[1;34m[INFO]\033[0m  $*"; }
log_ok()    { echo -e "\033[1;32m[OK]\033[0m    $*"; }
log_warn()  { echo -e "\033[1;33m[WARN]\033[0m  $*"; }
log_err()   { echo -e "\033[1;31m[ERROR]\033[0m $*"; }

require_cmd() {
    if ! command -v "$1" &>/dev/null; then
        log_err "'$1' is required but not found. Please install it."
        exit 1
    fi
}

choose_install_dir() {
    # Use system dir if running as root, otherwise user dir
    if [[ $EUID -eq 0 ]]; then
        INSTALL_DIR="$SYSTEM_DIR"
        THEME_DIR="$SYSTEM_THEME_DIR"
    else
        INSTALL_DIR="$USER_DIR"
        THEME_DIR="$USER_THEME_DIR"
    fi
}

# ── Note frequency lookup ────────────────────────────────────────────────────
# Standard tuning A4=440Hz
note_freq() {
    case "$1" in
        C4)  echo 261.63 ;;
        D4)  echo 293.66 ;;
        E4)  echo 329.63 ;;
        G4)  echo 392.00 ;;
        A4)  echo 440.00 ;;
        B4)  echo 493.88 ;;
        C5)  echo 523.25 ;;
        D5)  echo 587.33 ;;
        E5)  echo 659.25 ;;
        G5)  echo 783.99 ;;
        *)   echo "$1" ;;  # Allow raw Hz values
    esac
}

# ── Tone generation primitives ───────────────────────────────────────────────

# Generate a simple sine tone: gen_tone <freq_hz> <duration_s> <output_file> [volume 0-1]
gen_tone() {
    local freq="$1" dur="$2" out="$3" vol="${4:-0.8}"
    ffmpeg -y -loglevel error \
        -f lavfi -i "sine=frequency=${freq}:duration=${dur}:sample_rate=${SAMPLE_RATE}" \
        -af "volume=${vol},afade=t=in:d=0.01,afade=t=out:st=$(echo "${dur} - 0.03" | bc -l):d=0.03" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 \
        "${out}"
}

# Generate a tone with a longer fade out: gen_tone_fade <freq> <dur> <fade_out_dur> <output>
gen_tone_fade() {
    local freq="$1" dur="$2" fade="$3" out="$4" vol="${5:-0.8}"
    ffmpeg -y -loglevel error \
        -f lavfi -i "sine=frequency=${freq}:duration=${dur}:sample_rate=${SAMPLE_RATE}" \
        -af "volume=${vol},afade=t=in:d=0.01,afade=t=out:st=$(echo "${dur} - ${fade}" | bc -l):d=${fade}" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 \
        "${out}"
}

# Generate a frequency sweep: gen_sweep <start_hz> <end_hz> <duration_s> <output>
gen_sweep() {
    local f1="$1" f2="$2" dur="$3" out="$4" vol="${5:-0.8}"
    ffmpeg -y -loglevel error \
        -f lavfi -i "sine=frequency=${f1}:duration=${dur}:sample_rate=${SAMPLE_RATE}" \
        -af "vibrato=f=$(echo "(${f2} - ${f1}) / ${dur}" | bc -l):d=1,volume=${vol},afade=t=in:d=0.01,afade=t=out:st=$(echo "${dur} - 0.02" | bc -l):d=0.02" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 \
        "${out}"
    # Note: vibrato-based sweep is approximate; for precise sweeps we use aevalsrc below
}

# Concatenate ogg files: concat_ogg <output> <input1> <input2> ...
concat_ogg() {
    local out="$1"; shift
    local inputs=()
    local filter=""
    local i=0
    for f in "$@"; do
        inputs+=(-i "$f")
        filter+="[${i}:a]"
        ((i++))
    done
    filter+="concat=n=${i}:v=0:a=1[out]"
    ffmpeg -y -loglevel error "${inputs[@]}" -filter_complex "${filter}" -map "[out]" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 "${out}"
}

# Mix/overlay ogg files with time offsets: mix_tones <output> <"file:delay_s"> ...
mix_tones() {
    local out="$1"; shift
    local inputs=()
    local filter=""
    local i=0
    for entry in "$@"; do
        local file="${entry%%:*}"
        local delay="${entry##*:}"
        inputs+=(-i "$file")
        filter+="[${i}:a]adelay=${delay}|${delay}[a${i}];"
        ((i++))
    done
    for ((j=0; j<i; j++)); do
        filter+="[a${j}]"
    done
    filter+="amix=inputs=${i}:duration=longest:normalize=0[out]"
    ffmpeg -y -loglevel error "${inputs[@]}" -filter_complex "${filter}" -map "[out]" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 "${out}"
}

# ── Sound generators ─────────────────────────────────────────────────────────

gen_desktop_login() {
    # Pleasant ascending 3-note chime: C5-E5-G5, 0.15s each
    local dir="$1"
    local tmp="${dir}/.tmp_login"
    mkdir -p "$tmp"
    gen_tone_fade "$(note_freq C5)" 0.18 0.05 "${tmp}/n1.oga" 0.6
    gen_tone_fade "$(note_freq E5)" 0.18 0.05 "${tmp}/n2.oga" 0.7
    gen_tone_fade "$(note_freq G5)" 0.22 0.10 "${tmp}/n3.oga" 0.8
    concat_ogg "${dir}/desktop-login.oga" "${tmp}/n1.oga" "${tmp}/n2.oga" "${tmp}/n3.oga"
    rm -rf "$tmp"
}

gen_message_new_instant() {
    # Quick double-tap: 800Hz 0.05s, short pause, 1000Hz 0.05s
    local dir="$1"
    local tmp="${dir}/.tmp_msg"
    mkdir -p "$tmp"
    gen_tone 800 0.05 "${tmp}/t1.oga" 0.7
    # Generate a tiny silence for the pause
    ffmpeg -y -loglevel error \
        -f lavfi -i "anullsrc=r=${SAMPLE_RATE}:cl=mono" -t 0.06 \
        -c:a libvorbis -q:a 5 "${tmp}/pause.oga"
    gen_tone 1000 0.05 "${tmp}/t2.oga" 0.7
    concat_ogg "${dir}/message-new-instant.oga" "${tmp}/t1.oga" "${tmp}/pause.oga" "${tmp}/t2.oga"
    rm -rf "$tmp"
}

gen_dialog_information() {
    # Soft single tone: 700Hz, 0.2s with gentle fade
    local dir="$1"
    gen_tone_fade 700 0.25 0.12 "${dir}/dialog-information.oga" 0.6
}

gen_dialog_warning() {
    # Two-tone alert: 500Hz then 400Hz, 0.15s each
    local dir="$1"
    local tmp="${dir}/.tmp_warn"
    mkdir -p "$tmp"
    gen_tone 500 0.15 "${tmp}/t1.oga" 0.75
    gen_tone 400 0.15 "${tmp}/t2.oga" 0.75
    concat_ogg "${dir}/dialog-warning.oga" "${tmp}/t1.oga" "${tmp}/t2.oga"
    rm -rf "$tmp"
}

gen_dialog_error() {
    # Low descending tone: 400Hz-200Hz over 0.3s
    local dir="$1"
    ffmpeg -y -loglevel error \
        -f lavfi -i "aevalsrc='0.7*sin(2*PI*(400-200*(t/0.3))*t)':s=${SAMPLE_RATE}:d=0.3" \
        -af "afade=t=in:d=0.01,afade=t=out:st=0.2:d=0.1" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 \
        "${dir}/dialog-error.oga"
}

gen_device_added() {
    # Rising chirp: 600Hz-900Hz over 0.15s
    local dir="$1"
    ffmpeg -y -loglevel error \
        -f lavfi -i "aevalsrc='0.7*sin(2*PI*(600+300*(t/0.15))*t)':s=${SAMPLE_RATE}:d=0.15" \
        -af "afade=t=in:d=0.01,afade=t=out:st=0.10:d=0.05" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 \
        "${dir}/device-added.oga"
}

gen_device_removed() {
    # Falling chirp: 900Hz-600Hz over 0.15s
    local dir="$1"
    ffmpeg -y -loglevel error \
        -f lavfi -i "aevalsrc='0.7*sin(2*PI*(900-300*(t/0.15))*t)':s=${SAMPLE_RATE}:d=0.15" \
        -af "afade=t=in:d=0.01,afade=t=out:st=0.10:d=0.05" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 \
        "${dir}/device-removed.oga"
}

gen_screen_capture() {
    # Camera shutter click: white noise burst, 0.05s
    local dir="$1"
    ffmpeg -y -loglevel error \
        -f lavfi -i "anoisesrc=d=0.05:c=white:r=${SAMPLE_RATE}:a=0.5" \
        -af "afade=t=in:d=0.005,afade=t=out:st=0.03:d=0.02,highpass=f=2000,lowpass=f=8000" \
        -ac 1 -ar "${SAMPLE_RATE}" -c:a libvorbis -q:a 5 \
        "${dir}/screen-capture.oga"
}

gen_game_launch() {
    # Epic ascending chord: C4-E4-G4-C5, staggered entry over ~0.8s with overlap
    local dir="$1"
    local tmp="${dir}/.tmp_launch"
    mkdir -p "$tmp"
    gen_tone_fade "$(note_freq C4)" 0.80 0.30 "${tmp}/c4.oga" 0.5
    gen_tone_fade "$(note_freq E4)" 0.60 0.25 "${tmp}/e4.oga" 0.5
    gen_tone_fade "$(note_freq G4)" 0.45 0.20 "${tmp}/g4.oga" 0.55
    gen_tone_fade "$(note_freq C5)" 0.35 0.20 "${tmp}/c5.oga" 0.6
    # Mix with staggered delays (in milliseconds for adelay)
    mix_tones "${dir}/game-launch.oga" \
        "${tmp}/c4.oga:0" \
        "${tmp}/e4.oga:200" \
        "${tmp}/g4.oga:400" \
        "${tmp}/c5.oga:550"
    rm -rf "$tmp"
}

gen_achievement() {
    # Triumphant 4-note fanfare: G4-B4-D5-G5, 0.12s each staccato
    local dir="$1"
    local tmp="${dir}/.tmp_achieve"
    mkdir -p "$tmp"
    gen_tone "$(note_freq G4)" 0.10 "${tmp}/n1.oga" 0.7
    gen_tone "$(note_freq B4)" 0.10 "${tmp}/n2.oga" 0.75
    gen_tone "$(note_freq D5)" 0.10 "${tmp}/n3.oga" 0.8
    gen_tone_fade "$(note_freq G5)" 0.18 0.08 "${tmp}/n4.oga" 0.85
    # Short gaps between notes for staccato feel
    ffmpeg -y -loglevel error \
        -f lavfi -i "anullsrc=r=${SAMPLE_RATE}:cl=mono" -t 0.02 \
        -c:a libvorbis -q:a 5 "${tmp}/gap.oga"
    concat_ogg "${dir}/achievement.oga" \
        "${tmp}/n1.oga" "${tmp}/gap.oga" \
        "${tmp}/n2.oga" "${tmp}/gap.oga" \
        "${tmp}/n3.oga" "${tmp}/gap.oga" \
        "${tmp}/n4.oga"
    rm -rf "$tmp"
}

gen_complete() {
    # Satisfying completion ding: 1200Hz, 0.3s with long fade
    local dir="$1"
    gen_tone_fade 1200 0.5 0.35 "${dir}/complete.oga" 0.7
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_install() {
    require_cmd ffmpeg
    require_cmd bc
    choose_install_dir

    log_info "Installing 24HG Forge sound theme to ${INSTALL_DIR}"
    mkdir -p "${INSTALL_DIR}"

    # Write index.theme
    echo "${INDEX_THEME_CONTENT}" > "${THEME_DIR}/index.theme"
    log_ok "Wrote index.theme"

    # Generate each sound
    for name in "${SOUND_NAMES[@]}"; do
        local funcname="gen_${name//-/_}"
        log_info "Generating ${name}.oga ..."
        $funcname "${INSTALL_DIR}"
        if [[ -f "${INSTALL_DIR}/${name}.oga" ]]; then
            log_ok "${name}.oga ($(du -h "${INSTALL_DIR}/${name}.oga" | cut -f1))"
        else
            log_err "Failed to generate ${name}.oga"
        fi
    done

    echo ""
    log_ok "All sounds installed to ${INSTALL_DIR}"
    log_info "Run '$(basename "$0") enable' to activate the theme"
}

cmd_enable() {
    log_info "Enabling 24HG Forge sound theme..."

    # KDE Plasma (kwriteconfig6 or kwriteconfig5)
    local kwrite=""
    if command -v kwriteconfig6 &>/dev/null; then
        kwrite="kwriteconfig6"
    elif command -v kwriteconfig5 &>/dev/null; then
        kwrite="kwriteconfig5"
    fi

    if [[ -n "$kwrite" ]]; then
        $kwrite --file kdeglobals --group Sounds --key Theme "${THEME_NAME}"
        log_ok "KDE: Set sound theme via ${kwrite}"
    else
        log_warn "KDE: kwriteconfig not found, skipping KDE configuration"
    fi

    # GNOME / GTK fallback
    if command -v gsettings &>/dev/null; then
        gsettings set org.gnome.desktop.sound theme-name "${THEME_NAME}" 2>/dev/null && \
            log_ok "GNOME: Set sound theme via gsettings" || \
            log_warn "GNOME: gsettings schema not available (not running GNOME)"
    else
        log_warn "GNOME: gsettings not found, skipping GNOME configuration"
    fi

    echo ""
    log_ok "24HG Forge sound theme enabled"
}

cmd_disable() {
    log_info "Reverting to default freedesktop sound theme..."

    local kwrite=""
    if command -v kwriteconfig6 &>/dev/null; then
        kwrite="kwriteconfig6"
    elif command -v kwriteconfig5 &>/dev/null; then
        kwrite="kwriteconfig5"
    fi

    if [[ -n "$kwrite" ]]; then
        $kwrite --file kdeglobals --group Sounds --key Theme "freedesktop"
        log_ok "KDE: Reverted to freedesktop theme"
    else
        log_warn "KDE: kwriteconfig not found"
    fi

    if command -v gsettings &>/dev/null; then
        gsettings set org.gnome.desktop.sound theme-name "freedesktop" 2>/dev/null && \
            log_ok "GNOME: Reverted to freedesktop theme" || \
            log_warn "GNOME: gsettings schema not available"
    else
        log_warn "GNOME: gsettings not found"
    fi

    echo ""
    log_ok "Sound theme reverted to freedesktop"
}

cmd_test() {
    require_cmd paplay
    local target="${1:-all}"

    # Find where sounds are installed
    local snd_dir=""
    if [[ -d "$SYSTEM_DIR" ]]; then
        snd_dir="$SYSTEM_DIR"
    elif [[ -d "$USER_DIR" ]]; then
        snd_dir="$USER_DIR"
    else
        log_err "24HG Forge sounds not installed. Run '$(basename "$0") install' first."
        exit 1
    fi

    if [[ "$target" == "all" ]]; then
        log_info "Playing all 24HG Forge sounds from ${snd_dir}"
        echo ""
        for name in "${SOUND_NAMES[@]}"; do
            local file="${snd_dir}/${name}.oga"
            if [[ -f "$file" ]]; then
                printf "  %-28s %s\n" "${name}" "${SOUND_DESC[$name]}"
                paplay "$file" 2>/dev/null || log_warn "Could not play ${name}"
                sleep 0.3
            else
                log_warn "${name}.oga not found"
            fi
        done
    else
        local file="${snd_dir}/${target}.oga"
        if [[ -f "$file" ]]; then
            log_info "Playing: ${target} — ${SOUND_DESC[$target]:-unknown}"
            paplay "$file" 2>/dev/null || log_err "Could not play ${target}"
        else
            log_err "Sound '${target}' not found at ${file}"
            log_info "Available sounds:"
            cmd_list
            exit 1
        fi
    fi
}

cmd_status() {
    echo "24HG Forge Sound Theme Status"
    echo "========================"
    echo ""

    # Check installation
    local installed="no"
    local location=""
    if [[ -d "$SYSTEM_DIR" ]] && ls "${SYSTEM_DIR}"/*.oga &>/dev/null; then
        installed="yes (system-wide)"
        location="$SYSTEM_DIR"
    elif [[ -d "$USER_DIR" ]] && ls "${USER_DIR}"/*.oga &>/dev/null; then
        installed="yes (user)"
        location="$USER_DIR"
    fi
    echo "Installed:  ${installed}"
    if [[ -n "$location" ]]; then
        local count
        count=$(ls "${location}"/*.oga 2>/dev/null | wc -l)
        echo "Location:   ${location}"
        echo "Sounds:     ${count} / ${#SOUND_NAMES[@]}"
    fi

    echo ""

    # Check current theme setting
    echo "Current theme configuration:"

    local kread=""
    if command -v kreadconfig6 &>/dev/null; then
        kread="kreadconfig6"
    elif command -v kreadconfig5 &>/dev/null; then
        kread="kreadconfig5"
    fi

    if [[ -n "$kread" ]]; then
        local kde_theme
        kde_theme=$($kread --file kdeglobals --group Sounds --key Theme 2>/dev/null || echo "(not set)")
        echo "  KDE:    ${kde_theme}"
    else
        echo "  KDE:    (kreadconfig not available)"
    fi

    if command -v gsettings &>/dev/null; then
        local gnome_theme
        gnome_theme=$(gsettings get org.gnome.desktop.sound theme-name 2>/dev/null || echo "(not available)")
        echo "  GNOME:  ${gnome_theme}"
    else
        echo "  GNOME:  (gsettings not available)"
    fi

    echo ""

    # Dependencies
    echo "Dependencies:"
    for cmd in ffmpeg paplay bc; do
        if command -v "$cmd" &>/dev/null; then
            echo "  ${cmd}: $(command -v "$cmd")"
        else
            echo "  ${cmd}: NOT FOUND"
        fi
    done
}

cmd_list() {
    echo "24HG Forge Sound Theme — Available Sounds"
    echo "====================================="
    echo ""
    printf "  %-28s %s\n" "SOUND NAME" "DESCRIPTION"
    printf "  %-28s %s\n" "----------" "-----------"
    for name in "${SOUND_NAMES[@]}"; do
        printf "  %-28s %s\n" "${name}" "${SOUND_DESC[$name]}"
    done
    echo ""
    echo "Total: ${#SOUND_NAMES[@]} sounds"
}

cmd_usage() {
    echo "Usage: $(basename "$0") <command> [args]"
    echo ""
    echo "Commands:"
    echo "  install     Generate sound files and install the 24HG Forge theme"
    echo "  enable      Set 24HG Forge as the active sound theme"
    echo "  disable     Revert to default freedesktop sound theme"
    echo "  test [name] Play a specific sound or all sounds"
    echo "  status      Show current theme and installation info"
    echo "  list        List all available sounds with descriptions"
    echo ""
    echo "Examples:"
    echo "  $(basename "$0") install          # Generate and install all sounds"
    echo "  $(basename "$0") enable           # Activate the theme"
    echo "  $(basename "$0") test             # Play all sounds"
    echo "  $(basename "$0") test game-launch # Play a specific sound"
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
    install)  cmd_install ;;
    enable)   cmd_enable ;;
    disable)  cmd_disable ;;
    test)     cmd_test "${2:-all}" ;;
    status)   cmd_status ;;
    list)     cmd_list ;;
    -h|--help|help) cmd_usage ;;
    *)
        cmd_usage
        exit 1
        ;;
esac
