#!/bin/bash
set -euo pipefail
# 24HG Forge NAS — Network storage manager for game libraries

FORGE_VERSION="1.0"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/forge"
SHARES_CONFIG="$CONFIG_DIR/nas-shares.json"
CREDS_DIR="$CONFIG_DIR/nas-credentials"
MOUNT_BASE="/mnt/forge-nas"
SYSTEMD_USER_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
SPEED_TEST_SIZE="256M"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Logging ─────────────────────────────────────────────────────────────────

log() {
    logger -t forge-nas "$*" 2>/dev/null || true
}

die() {
    echo -e "${RED}Error:${RESET} $*" >&2
    log "ERROR: $*"
    exit 1
}

info() {
    echo -e "${CYAN}[NAS]${RESET} $*"
}

warn() {
    echo -e "${YELLOW}[NAS]${RESET} $*"
}

success() {
    echo -e "${GREEN}[NAS]${RESET} $*"
}

header() {
    echo -e "\n${BOLD}${BLUE}=== $* ===${RESET}\n"
}

# ── Prerequisites ───────────────────────────────────────────────────────────

ensure_dirs() {
    mkdir -p "$CONFIG_DIR" "$CREDS_DIR"
    chmod 700 "$CREDS_DIR"
    [[ -f "$SHARES_CONFIG" ]] || echo '{"shares":[],"auto_mount":false}' > "$SHARES_CONFIG"
}

check_deps() {
    local missing=()
    for cmd in "$@"; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing dependencies: ${missing[*]}\nInstall with: sudo dnf install ${missing[*]}"
    fi
}

require_root_or_sudo() {
    if [[ $EUID -ne 0 ]]; then
        if ! command -v sudo &>/dev/null; then
            die "This operation requires root privileges"
        fi
        SUDO="sudo"
    else
        SUDO=""
    fi
}

# ── JSON Helpers (jq wrappers) ──────────────────────────────────────────────

read_config() {
    jq -r "$1" "$SHARES_CONFIG" 2>/dev/null || echo ""
}

write_config() {
    local tmp
    tmp=$(mktemp)
    jq "$@" "$SHARES_CONFIG" > "$tmp" && mv "$tmp" "$SHARES_CONFIG"
}

share_exists() {
    local name="$1"
    [[ $(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .name' "$SHARES_CONFIG" 2>/dev/null) == "$name" ]]
}

get_share_field() {
    local name="$1" field="$2"
    jq -r --arg n "$name" --arg f "$field" '.shares[] | select(.name==$n) | .[$f]' "$SHARES_CONFIG" 2>/dev/null
}

# ── Credential Management ──────────────────────────────────────────────────

save_credentials() {
    local name="$1" username="$2" password="$3"
    local cred_file="$CREDS_DIR/${name}.cred"

    # Try keyring first (secret-tool / GNOME Keyring)
    if command -v secret-tool &>/dev/null; then
        echo -n "$password" | secret-tool store --label="Forge NAS: $name" \
            forge-nas share "$name" username "$username" 2>/dev/null && {
            echo "username=$username" > "$cred_file"
            echo "# password stored in keyring" >> "$cred_file"
            chmod 600 "$cred_file"
            info "Credentials saved to system keyring"
            return 0
        }
    fi

    # Fallback: credentials file with restricted perms
    cat > "$cred_file" <<CRED
username=$username
password=$password
CRED
    chmod 600 "$cred_file"
    info "Credentials saved to $cred_file (mode 600)"
}

load_credentials() {
    local name="$1"
    local cred_file="$CREDS_DIR/${name}.cred"

    if [[ ! -f "$cred_file" ]]; then
        return 1
    fi

    local username password
    username=$(grep '^username=' "$cred_file" | cut -d= -f2-)

    # Try keyring first
    if command -v secret-tool &>/dev/null; then
        password=$(secret-tool lookup forge-nas share "$name" username "$username" 2>/dev/null || true)
        if [[ -n "$password" ]]; then
            echo "$username" "$password"
            return 0
        fi
    fi

    # Fallback to file
    password=$(grep '^password=' "$cred_file" 2>/dev/null | cut -d= -f2- || true)
    if [[ -n "$password" ]]; then
        echo "$username" "$password"
        return 0
    fi

    return 1
}

prompt_credentials() {
    local name="$1"
    local username password

    read -rp "Username for '$name': " username
    read -rsp "Password for '$name': " password
    echo

    if [[ -n "$username" && -n "$password" ]]; then
        save_credentials "$name" "$username" "$password"
        echo "$username" "$password"
    else
        die "Credentials are required for SMB shares"
    fi
}

# ── NAS Brand Detection ────────────────────────────────────────────────────

detect_nas_brand() {
    local hostname="$1"
    local brand="Unknown"

    # Check mDNS service names for known NAS brands
    local mdns_info
    mdns_info=$(avahi-resolve -n "${hostname}.local" 2>/dev/null || true)

    # Try to identify by HTTP management pages
    for port in 5000 5001 8080 443 80; do
        local resp
        resp=$(curl -sI --connect-timeout 2 "http://${hostname}:${port}/" 2>/dev/null | head -5 || true)
        case "$resp" in
            *Synology*)   brand="Synology DSM"; break ;;
            *QNAP*)      brand="QNAP QTS"; break ;;
            *TrueNAS*|*FreeNAS*) brand="TrueNAS"; break ;;
            *openmediavault*|*OMV*) brand="OpenMediaVault"; break ;;
            *Unraid*)     brand="Unraid"; break ;;
        esac
    done

    # Fallback: check SMB server string
    if [[ "$brand" == "Unknown" ]]; then
        local smb_info
        smb_info=$(smbclient -N -L "$hostname" 2>/dev/null | head -5 || true)
        case "$smb_info" in
            *Synology*)   brand="Synology DSM" ;;
            *QNAP*)      brand="QNAP QTS" ;;
            *Samba*)      brand="Samba/Linux" ;;
            *Windows*)    brand="Windows Share" ;;
        esac
    fi

    echo "$brand"
}

# ── Network Scanning ───────────────────────────────────────────────────────

cmd_scan() {
    header "Scanning LAN for Network Storage"

    local found_any=false

    # ── SMB Discovery via Avahi ──
    info "Scanning for SMB shares (mDNS)..."
    local smb_hosts=()
    if command -v avahi-browse &>/dev/null; then
        while IFS=';' read -r _ _ _ name _ hostname addr port _; do
            [[ -z "$hostname" ]] && continue
            hostname="${hostname%.local.}"
            addr="${addr//[[:space:]]/}"
            if [[ -n "$hostname" && -n "$addr" ]]; then
                smb_hosts+=("$hostname|$addr")
                found_any=true
            fi
        done < <(avahi-browse -tpr _smb._tcp 2>/dev/null || true)
    fi

    # Deduplicate and display SMB hosts
    local seen_hosts=()
    if [[ ${#smb_hosts[@]} -gt 0 ]]; then
        echo -e "\n${BOLD}SMB/CIFS Shares:${RESET}"
        for entry in "${smb_hosts[@]}"; do
            local host="${entry%%|*}"
            local addr="${entry##*|}"

            # Skip duplicates
            local is_dup=false
            for seen in "${seen_hosts[@]:-}"; do
                [[ "$seen" == "$host" ]] && is_dup=true && break
            done
            $is_dup && continue
            seen_hosts+=("$host")

            local brand
            brand=$(detect_nas_brand "$host")
            echo -e "  ${GREEN}$host${RESET} ($addr) ${DIM}[$brand]${RESET}"

            # List available shares
            local shares
            shares=$(smbclient -N -L "$host" 2>/dev/null | grep "Disk" | awk '{print $1}' || true)
            if [[ -n "$shares" ]]; then
                while read -r share; do
                    [[ -z "$share" || "$share" == "IPC\$" || "$share" == "print\$" ]] && continue
                    echo -e "    ${CYAN}//$host/$share${RESET}"
                done <<< "$shares"
            fi
        done
    fi

    # ── NFS Discovery ──
    info "Scanning for NFS exports..."
    echo -e "\n${BOLD}NFS Exports:${RESET}"

    # Find hosts with NFS via avahi or subnet scan
    local nfs_found=false
    if command -v avahi-browse &>/dev/null; then
        while IFS=';' read -r _ _ _ name _ hostname addr port _; do
            [[ -z "$hostname" ]] && continue
            hostname="${hostname%.local.}"
            local exports
            exports=$(showmount -e "$hostname" 2>/dev/null | tail -n +2 || true)
            if [[ -n "$exports" ]]; then
                nfs_found=true
                found_any=true
                echo -e "  ${GREEN}$hostname${RESET}"
                while read -r export_line; do
                    local path access
                    path=$(echo "$export_line" | awk '{print $1}')
                    access=$(echo "$export_line" | awk '{print $2}')
                    echo -e "    ${CYAN}$hostname:$path${RESET} ${DIM}($access)${RESET}"
                done <<< "$exports"
            fi
        done < <(avahi-browse -tpr _nfs._tcp 2>/dev/null || true)
    fi

    # Also check any SMB hosts for NFS exports
    for entry in "${smb_hosts[@]:-}"; do
        [[ -z "$entry" ]] && continue
        local addr="${entry##*|}"
        local host="${entry%%|*}"
        local exports
        exports=$(showmount -e "$addr" 2>/dev/null | tail -n +2 || true)
        if [[ -n "$exports" ]]; then
            nfs_found=true
            found_any=true
            echo -e "  ${GREEN}$host${RESET} ($addr)"
            while read -r export_line; do
                local path access
                path=$(echo "$export_line" | awk '{print $1}')
                access=$(echo "$export_line" | awk '{print $2}')
                echo -e "    ${CYAN}$addr:$path${RESET} ${DIM}($access)${RESET}"
            done <<< "$exports"
        fi
    done
    $nfs_found || echo -e "  ${DIM}No NFS exports found${RESET}"

    # ── DLNA/UPnP Media Servers ──
    info "Scanning for DLNA/UPnP media servers..."
    echo -e "\n${BOLD}DLNA/UPnP Media Servers:${RESET}"
    local dlna_found=false
    if command -v gssdp-discover &>/dev/null; then
        local dlna_results
        dlna_results=$(gssdp-discover -t urn:schemas-upnp-org:device:MediaServer:1 --timeout=3 2>/dev/null || true)
        if [[ -n "$dlna_results" ]]; then
            dlna_found=true
            found_any=true
            echo "$dlna_results" | grep -i "location:" | while read -r line; do
                echo -e "  ${MAGENTA}${line##*: }${RESET}"
            done
        fi
    elif command -v avahi-browse &>/dev/null; then
        while IFS=';' read -r _ _ _ name _ hostname _ _ _; do
            [[ -z "$name" ]] && continue
            dlna_found=true
            found_any=true
            echo -e "  ${MAGENTA}$name${RESET} ${DIM}($hostname)${RESET}"
        done < <(avahi-browse -tpr _mediaserver._tcp 2>/dev/null || true)
    fi
    $dlna_found || echo -e "  ${DIM}No DLNA/UPnP servers found${RESET}"

    echo
    if $found_any; then
        info "Use ${BOLD}forge-nas add smb <host> <share>${RESET} or ${BOLD}forge-nas add nfs <host> <path>${RESET} to save a share"
    else
        warn "No network shares found. Ensure NAS is online and on the same subnet."
        echo -e "  ${DIM}Tip: You can manually add shares with 'forge-nas add smb <host> <share>'${RESET}"
    fi
}

# ── Mount / Unmount ─────────────────────────────────────────────────────────

resolve_share_name() {
    # Accept a saved share name or a raw path like //host/share or host:/path
    local input="$1"

    if share_exists "$input"; then
        echo "$input"
        return 0
    fi

    # Search by host/path match
    local match
    match=$(jq -r --arg q "$input" \
        '.shares[] | select((.host + "/" + .path) == $q or ("//" + .host + "/" + .path) == $q or (.host + ":" + .path) == $q) | .name' \
        "$SHARES_CONFIG" 2>/dev/null | head -1)

    if [[ -n "$match" ]]; then
        echo "$match"
        return 0
    fi

    return 1
}

mountpoint_for() {
    local name="$1"
    echo "${MOUNT_BASE}/${name}"
}

is_mounted() {
    local mp="$1"
    mountpoint -q "$mp" 2>/dev/null
}

cmd_mount() {
    local share_input="${1:-}"
    local custom_mp="${2:-}"

    [[ -z "$share_input" ]] && die "Usage: forge-nas mount <share-name|//host/share>"

    require_root_or_sudo
    ensure_dirs

    local name
    if ! name=$(resolve_share_name "$share_input"); then
        die "Share '$share_input' not found in config. Add it first with 'forge-nas add'"
    fi

    local type host path
    type=$(get_share_field "$name" "type")
    host=$(get_share_field "$name" "host")
    path=$(get_share_field "$name" "path")

    local mp="${custom_mp:-$(mountpoint_for "$name")}"
    $SUDO mkdir -p "$mp"

    if is_mounted "$mp"; then
        warn "Share '$name' is already mounted at $mp"
        return 0
    fi

    info "Mounting ${BOLD}$name${RESET} ($type://$host/$path) at $mp"

    case "$type" in
        smb)
            check_deps mount.cifs

            # Build credentials option
            local cred_opt=""
            local creds
            if creds=$(load_credentials "$name" 2>/dev/null); then
                local username password
                read -r username password <<< "$creds"
                local cred_file="$CREDS_DIR/${name}.cred"
                # Ensure mount-compatible credentials file
                local mount_cred
                mount_cred=$(mktemp)
                echo "username=$username" > "$mount_cred"
                echo "password=$password" >> "$mount_cred"
                chmod 600 "$mount_cred"
                cred_opt="credentials=$mount_cred"
            else
                # Prompt for credentials
                local creds_out
                creds_out=$(prompt_credentials "$name")
                local username password
                read -r username password <<< "$creds_out"
                local mount_cred
                mount_cred=$(mktemp)
                echo "username=$username" > "$mount_cred"
                echo "password=$password" >> "$mount_cred"
                chmod 600 "$mount_cred"
                cred_opt="credentials=$mount_cred"
            fi

            local mount_opts="$cred_opt,iocharset=utf8,file_mode=0775,dir_mode=0775,uid=$(id -u),gid=$(id -g),vers=3.0"
            $SUDO mount.cifs "//$host/$path" "$mp" -o "$mount_opts" || {
                # Retry with SMB2
                warn "SMB3 failed, retrying with SMB2..."
                mount_opts="${mount_opts/vers=3.0/vers=2.1}"
                $SUDO mount.cifs "//$host/$path" "$mp" -o "$mount_opts" || die "Failed to mount SMB share"
            }
            ;;

        nfs)
            check_deps mount.nfs
            local mount_opts="async,soft,timeo=10,retrans=3,rsize=1048576,wsize=1048576"
            $SUDO mount.nfs "$host:$path" "$mp" -o "$mount_opts" || die "Failed to mount NFS share"
            ;;

        *)
            die "Unknown share type: $type"
            ;;
    esac

    success "Mounted ${BOLD}$name${RESET} at $mp"

    # Update config with mount status
    write_config --arg n "$name" --arg m "$mp" \
        '(.shares[] | select(.name==$n)) |= . + {mounted: true, mountpoint: $m}'

    # Offer game library integration
    detect_game_libraries "$mp" "$name"
}

cmd_unmount() {
    local share_input="${1:-}"
    [[ -z "$share_input" ]] && die "Usage: forge-nas unmount <share-name>"

    require_root_or_sudo

    local name
    if ! name=$(resolve_share_name "$share_input"); then
        die "Share '$share_input' not found"
    fi

    local mp
    mp=$(get_share_field "$name" "mountpoint")
    [[ -z "$mp" || "$mp" == "null" ]] && mp=$(mountpoint_for "$name")

    if ! is_mounted "$mp"; then
        warn "'$name' is not currently mounted"
        return 0
    fi

    info "Unmounting ${BOLD}$name${RESET} from $mp..."
    $SUDO umount "$mp" || $SUDO umount -l "$mp" || die "Failed to unmount $mp"

    # Update config
    write_config --arg n "$name" \
        '(.shares[] | select(.name==$n)) |= . + {mounted: false}'

    success "Unmounted $name"
}

# ── List Shares ─────────────────────────────────────────────────────────────

cmd_list() {
    ensure_dirs
    header "Mounted Network Shares"

    local has_mounts=false

    # System mounts (cifs + nfs under our mount base)
    while read -r device mp fstype opts; do
        [[ "$mp" == "${MOUNT_BASE}"* ]] || continue
        has_mounts=true
        local name="${mp##*/}"
        local usage
        usage=$(df -h "$mp" 2>/dev/null | tail -1 || true)
        local size used avail pct
        read -r _ size used avail pct _ <<< "$usage"

        echo -e "  ${GREEN}$name${RESET}"
        echo -e "    Source:  ${CYAN}$device${RESET}"
        echo -e "    Mount:   $mp"
        echo -e "    Type:    $fstype"
        echo -e "    Space:   ${used:-?}/${size:-?} (${pct:-?} used, ${avail:-?} free)"
        echo
    done < <(mount | grep -E "cifs|nfs" || true)

    if ! $has_mounts; then
        echo -e "  ${DIM}No forge-nas shares currently mounted${RESET}"
        echo
    fi

    # Also show saved shares
    local saved_count
    saved_count=$(jq '.shares | length' "$SHARES_CONFIG" 2>/dev/null || echo 0)
    if [[ $saved_count -gt 0 ]]; then
        echo -e "${BOLD}Saved Shares:${RESET}"
        jq -r '.shares[] | "  \(.name) [\(.type)] \(.host)/\(.path)"' "$SHARES_CONFIG"
        echo
    fi

    local auto_mount
    auto_mount=$(read_config '.auto_mount')
    echo -e "Auto-mount: $([ "$auto_mount" = "true" ] && echo -e "${GREEN}ON${RESET}" || echo -e "${DIM}OFF${RESET}")"
}

# ── Add / Remove Shares ─────────────────────────────────────────────────────

cmd_add() {
    local type="${1:-}" host="${2:-}" path="${3:-}"

    [[ -z "$type" || -z "$host" || -z "$path" ]] && die "Usage: forge-nas add <smb|nfs> <host> <share-path>"
    [[ "$type" != "smb" && "$type" != "nfs" ]] && die "Type must be 'smb' or 'nfs'"

    ensure_dirs
    check_deps jq

    # Generate a name from host and path
    local name
    name=$(echo "${host}_${path}" | tr '/\\. ' '_' | tr -s '_' | sed 's/^_//;s/_$//')

    if share_exists "$name"; then
        warn "Share '$name' already exists. Remove it first or use a different path."
        return 1
    fi

    # Verify host is reachable
    info "Verifying host $host..."
    if ! ping -c 1 -W 2 "$host" &>/dev/null; then
        warn "Host '$host' is not responding to ping (may still work)"
    fi

    # Verify share exists
    case "$type" in
        smb)
            info "Checking SMB share //$host/$path..."
            if command -v smbclient &>/dev/null; then
                local shares
                shares=$(smbclient -N -L "$host" 2>/dev/null | grep -i "Disk" | awk '{print $1}' || true)
                if [[ -n "$shares" ]] && ! echo "$shares" | grep -qi "^${path}$"; then
                    warn "Share '$path' not found on $host. Available shares:"
                    echo "$shares" | while read -r s; do echo -e "  ${CYAN}$s${RESET}"; done
                fi
            fi
            ;;
        nfs)
            info "Checking NFS export $host:$path..."
            if command -v showmount &>/dev/null; then
                local exports
                exports=$(showmount -e "$host" 2>/dev/null | tail -n +2 | awk '{print $1}' || true)
                if [[ -n "$exports" ]] && ! echo "$exports" | grep -q "^${path}$"; then
                    warn "Export '$path' not found on $host. Available exports:"
                    echo "$exports" | while read -r e; do echo -e "  ${CYAN}$e${RESET}"; done
                fi
            fi
            ;;
    esac

    # Detect NAS brand
    local brand
    brand=$(detect_nas_brand "$host")

    # Save to config
    write_config --arg n "$name" --arg t "$type" --arg h "$host" --arg p "$path" --arg b "$brand" \
        '.shares += [{"name": $n, "type": $t, "host": $h, "path": $p, "brand": $b, "mounted": false, "added": (now | todate)}]'

    success "Added share: ${BOLD}$name${RESET} ($type://$host/$path) [$brand]"

    # Prompt for credentials if SMB
    if [[ "$type" == "smb" ]]; then
        read -rp "Save credentials for this share? (y/N): " save_creds
        if [[ "$save_creds" =~ ^[Yy] ]]; then
            prompt_credentials "$name" > /dev/null
        fi
    fi

    info "Mount with: ${BOLD}forge-nas mount $name${RESET}"
}

cmd_remove() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: forge-nas remove <share-name>"

    ensure_dirs

    if ! share_exists "$name"; then
        die "Share '$name' not found"
    fi

    # Unmount if mounted
    local mp
    mp=$(mountpoint_for "$name")
    if is_mounted "$mp"; then
        warn "Share is mounted — unmounting first"
        require_root_or_sudo
        $SUDO umount "$mp" 2>/dev/null || $SUDO umount -l "$mp" 2>/dev/null || true
    fi

    # Remove systemd units if they exist
    local unit_name
    unit_name=$(systemd-escape -p "$mp")
    rm -f "$SYSTEMD_USER_DIR/${unit_name}.mount" "$SYSTEMD_USER_DIR/${unit_name}.automount" 2>/dev/null || true
    systemctl --user daemon-reload 2>/dev/null || true

    # Remove credentials
    rm -f "$CREDS_DIR/${name}.cred" 2>/dev/null || true
    if command -v secret-tool &>/dev/null; then
        secret-tool clear forge-nas share "$name" 2>/dev/null || true
    fi

    # Remove from config
    write_config --arg n "$name" '.shares |= map(select(.name != $n))'

    success "Removed share: $name"
}

# ── Auto-mount ──────────────────────────────────────────────────────────────

cmd_auto() {
    local action="${1:-}"
    [[ -z "$action" ]] && die "Usage: forge-nas auto on|off"

    ensure_dirs

    case "$action" in
        on)
            write_config '.auto_mount = true'

            # Create systemd mount/automount units for all saved shares
            mkdir -p "$SYSTEMD_USER_DIR"

            local count=0
            while read -r share_json; do
                local name type host path
                name=$(echo "$share_json" | jq -r '.name')
                type=$(echo "$share_json" | jq -r '.type')
                host=$(echo "$share_json" | jq -r '.host')
                path=$(echo "$share_json" | jq -r '.path')
                local mp
                mp=$(mountpoint_for "$name")

                local unit_name
                unit_name=$(systemd-escape -p "$mp")

                # Generate .mount unit
                local mount_opts what
                case "$type" in
                    smb)
                        what="//$host/$path"
                        local cred_file="$CREDS_DIR/${name}.cred"
                        mount_opts="credentials=$cred_file,iocharset=utf8,file_mode=0775,dir_mode=0775,uid=$(id -u),gid=$(id -g),vers=3.0"
                        ;;
                    nfs)
                        what="$host:$path"
                        mount_opts="async,soft,timeo=10,retrans=3,rsize=1048576,wsize=1048576"
                        ;;
                esac

                cat > "$SYSTEMD_USER_DIR/${unit_name}.mount" <<UNIT
[Unit]
Description=Forge NAS: $name ($type://$host/$path)
After=network-online.target
Wants=network-online.target

[Mount]
What=$what
Where=$mp
Type=$([ "$type" = "smb" ] && echo "cifs" || echo "nfs")
Options=$mount_opts
TimeoutSec=30

[Install]
WantedBy=default.target
UNIT

                # Generate .automount unit
                cat > "$SYSTEMD_USER_DIR/${unit_name}.automount" <<UNIT
[Unit]
Description=Forge NAS automount: $name
After=network-online.target

[Automount]
Where=$mp
TimeoutIdleSec=300

[Install]
WantedBy=default.target
UNIT

                systemctl --user enable "${unit_name}.automount" 2>/dev/null || true
                ((count++))
            done < <(jq -c '.shares[]' "$SHARES_CONFIG" 2>/dev/null)

            systemctl --user daemon-reload 2>/dev/null || true
            success "Auto-mount enabled for $count share(s)"
            info "Shares will mount automatically on login or first access"
            ;;

        off)
            write_config '.auto_mount = false'

            # Disable automount units
            while read -r share_json; do
                local name
                name=$(echo "$share_json" | jq -r '.name')
                local mp
                mp=$(mountpoint_for "$name")
                local unit_name
                unit_name=$(systemd-escape -p "$mp")
                systemctl --user disable "${unit_name}.automount" 2>/dev/null || true
                rm -f "$SYSTEMD_USER_DIR/${unit_name}.mount" "$SYSTEMD_USER_DIR/${unit_name}.automount" 2>/dev/null || true
            done < <(jq -c '.shares[]' "$SHARES_CONFIG" 2>/dev/null)

            systemctl --user daemon-reload 2>/dev/null || true
            success "Auto-mount disabled"
            ;;

        *)
            die "Usage: forge-nas auto on|off"
            ;;
    esac
}

# ── Speed Test ──────────────────────────────────────────────────────────────

cmd_speed() {
    local share_input="${1:-}"
    [[ -z "$share_input" ]] && die "Usage: forge-nas speed <share-name>"

    local name
    if ! name=$(resolve_share_name "$share_input"); then
        die "Share '$share_input' not found"
    fi

    local mp
    mp=$(get_share_field "$name" "mountpoint")
    [[ -z "$mp" || "$mp" == "null" ]] && mp=$(mountpoint_for "$name")

    if ! is_mounted "$mp"; then
        die "Share '$name' is not mounted. Mount it first with 'forge-nas mount $name'"
    fi

    header "Speed Test: $name"

    local test_file="$mp/.forge-speed-test-$$"

    # Write test
    info "Testing write speed (${SPEED_TEST_SIZE})..."
    local write_result
    write_result=$(dd if=/dev/zero of="$test_file" bs=1M count=256 conv=fdatasync 2>&1 | tail -1)
    local write_speed
    write_speed=$(echo "$write_result" | grep -oP '[\d.]+ [MGKT]B/s' || echo "unknown")
    echo -e "  Write: ${BOLD}${GREEN}$write_speed${RESET}"

    # Clear cache for read test
    sync
    echo 3 | sudo tee /proc/sys/vm/drop_caches &>/dev/null 2>&1 || true

    # Read test
    info "Testing read speed (${SPEED_TEST_SIZE})..."
    local read_result
    read_result=$(dd if="$test_file" of=/dev/null bs=1M 2>&1 | tail -1)
    local read_speed
    read_speed=$(echo "$read_result" | grep -oP '[\d.]+ [MGKT]B/s' || echo "unknown")
    echo -e "  Read:  ${BOLD}${GREEN}$read_speed${RESET}"

    # Latency test
    info "Testing latency..."
    local host
    host=$(get_share_field "$name" "host")
    local latency
    latency=$(ping -c 5 -q "$host" 2>/dev/null | tail -1 | awk -F'/' '{print $5 " ms"}' || echo "unknown")
    echo -e "  Ping:  ${BOLD}$latency${RESET}"

    # Cleanup
    rm -f "$test_file" 2>/dev/null || true

    # Gaming suitability
    echo
    local ping_ms
    ping_ms=$(echo "$latency" | grep -oP '[\d.]+' || echo "999")
    if (( $(echo "$ping_ms < 2" | bc -l 2>/dev/null || echo 0) )); then
        success "Excellent for game libraries (low latency)"
    elif (( $(echo "$ping_ms < 10" | bc -l 2>/dev/null || echo 0) )); then
        info "Good for most games. Very fast-paced games may benefit from local install."
    else
        warn "High latency detected. Recommend copying games to local storage for best performance."
        echo -e "  ${DIM}Tip: Use Steam's 'Move Install' to copy specific games locally${RESET}"
    fi
}

# ── Status ──────────────────────────────────────────────────────────────────

cmd_status() {
    ensure_dirs
    header "Network Storage Status"

    local share_count
    share_count=$(jq '.shares | length' "$SHARES_CONFIG" 2>/dev/null || echo 0)

    if [[ $share_count -eq 0 ]]; then
        echo -e "  ${DIM}No shares configured${RESET}"
        echo -e "  ${DIM}Run 'forge-nas scan' to discover NAS devices${RESET}"
        return 0
    fi

    printf "  ${BOLD}%-20s %-6s %-15s %-8s %-10s %-18s %s${RESET}\n" \
        "NAME" "TYPE" "HOST" "STATUS" "HEALTH" "SPACE" "BRAND"
    echo -e "  ${DIM}$(printf '%.0s-' {1..100})${RESET}"

    while read -r share_json; do
        local name type host path brand
        name=$(echo "$share_json" | jq -r '.name')
        type=$(echo "$share_json" | jq -r '.type')
        host=$(echo "$share_json" | jq -r '.host')
        path=$(echo "$share_json" | jq -r '.path')
        brand=$(echo "$share_json" | jq -r '.brand // "Unknown"')

        local mp
        mp=$(mountpoint_for "$name")
        local status health space

        # Check if mounted
        if is_mounted "$mp"; then
            status="${GREEN}mounted${RESET}"

            # Health: check if readable
            if ls "$mp" &>/dev/null; then
                health="${GREEN}healthy${RESET}"
            else
                health="${RED}stale${RESET}"
            fi

            # Space
            local df_out
            df_out=$(df -h "$mp" 2>/dev/null | tail -1 || true)
            local used total pct
            read -r _ total used _ pct _ <<< "$df_out"
            space="${used:-?}/${total:-?} (${pct:-?})"
        else
            # Check if host is reachable
            if ping -c 1 -W 1 "$host" &>/dev/null; then
                status="${YELLOW}offline${RESET}"
                health="${CYAN}reachable${RESET}"
            else
                status="${RED}offline${RESET}"
                health="${RED}unreachable${RESET}"
            fi
            space="${DIM}n/a${RESET}"
        fi

        printf "  %-20s %-6s %-15s %-20b %-22b %-18s %s\n" \
            "$name" "$type" "$host" "$status" "$health" "$space" "$brand"
    done < <(jq -c '.shares[]' "$SHARES_CONFIG" 2>/dev/null)

    echo
    local auto_mount
    auto_mount=$(read_config '.auto_mount')
    echo -e "  Auto-mount: $([ "$auto_mount" = "true" ] && echo -e "${GREEN}ON${RESET}" || echo -e "${DIM}OFF${RESET}")"

    # Show game library info
    echo
    detect_steam_libraries_summary
}

# ── Game Library Integration ────────────────────────────────────────────────

detect_game_libraries() {
    local mp="$1" name="$2"

    # Check for Steam libraries
    local steam_lib_file="$mp/steamapps/libraryfolders.vdf"
    local steam_apps_dir="$mp/steamapps/common"

    if [[ -d "$steam_apps_dir" ]]; then
        local game_count
        game_count=$(find "$steam_apps_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)

        echo
        info "Found ${BOLD}$game_count${RESET} Steam game(s) on this share"

        if [[ $game_count -gt 0 ]]; then
            echo -e "  Games found:"
            find "$steam_apps_dir" -maxdepth 1 -mindepth 1 -type d -printf "    %f\n" 2>/dev/null | head -20
            local remaining=$((game_count - 20))
            [[ $remaining -gt 0 ]] && echo -e "    ${DIM}... and $remaining more${RESET}"
        fi

        # Offer to add as Steam library
        echo
        read -rp "Add this share as a Steam library folder? (y/N): " add_lib
        if [[ "$add_lib" =~ ^[Yy] ]]; then
            add_steam_library "$mp"
        fi
    fi

    # Check for other game launchers
    local found_games=false
    for dir in "Games" "games" "GOG Games" "Epic Games" "Lutris"; do
        if [[ -d "$mp/$dir" ]]; then
            local count
            count=$(find "$mp/$dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
            if [[ $count -gt 0 ]]; then
                found_games=true
                info "Found ${BOLD}$count${RESET} game folder(s) in $dir/"
            fi
        fi
    done

    # Network performance warning
    local host
    host=$(get_share_field "$name" "host")
    local ping_ms
    ping_ms=$(ping -c 3 -q "$host" 2>/dev/null | tail -1 | awk -F'/' '{print $5}' || echo "0")
    if [[ -n "$ping_ms" ]] && (( $(echo "$ping_ms > 5" | bc -l 2>/dev/null || echo 0) )); then
        echo
        warn "Network latency is ${ping_ms}ms — fast-paced games may stutter"
        echo -e "  ${DIM}Consider using Steam's 'Move Install Folder' for competitive games${RESET}"
    fi
}

add_steam_library() {
    local library_path="$1"
    local steam_dir="${HOME}/.local/share/Steam"
    local vdf_file="$steam_dir/steamapps/libraryfolders.vdf"

    if [[ ! -f "$vdf_file" ]]; then
        # Try flatpak Steam
        steam_dir="${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam"
        vdf_file="$steam_dir/steamapps/libraryfolders.vdf"
    fi

    if [[ ! -f "$vdf_file" ]]; then
        warn "Could not find Steam libraryfolders.vdf"
        echo -e "  ${DIM}Add the library manually: Steam > Settings > Storage > Add Drive${RESET}"
        return 1
    fi

    # Check if already added
    if grep -q "$library_path" "$vdf_file" 2>/dev/null; then
        info "This path is already in your Steam library folders"
        return 0
    fi

    # Get the next folder index
    local max_idx
    max_idx=$(grep -oP '^\s*"\K\d+' "$vdf_file" | sort -n | tail -1 || echo 0)
    local next_idx=$((max_idx + 1))

    info "Adding $library_path as Steam library folder #$next_idx"
    echo -e "  ${DIM}You may need to restart Steam for changes to take effect${RESET}"
    echo -e "  ${DIM}Or add manually: Steam > Settings > Storage > Add Drive${RESET}"

    success "Steam library path noted. Add via Steam UI for best compatibility."
}

detect_steam_libraries_summary() {
    echo -e "${BOLD}Game Libraries on Network Shares:${RESET}"

    local found_any=false
    while read -r share_json; do
        local name
        name=$(echo "$share_json" | jq -r '.name')
        local mp
        mp=$(mountpoint_for "$name")

        if ! is_mounted "$mp"; then
            continue
        fi

        local steam_apps="$mp/steamapps/common"
        if [[ -d "$steam_apps" ]]; then
            local count
            count=$(find "$steam_apps" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
            if [[ $count -gt 0 ]]; then
                found_any=true
                echo -e "  ${GREEN}$name${RESET}: $count Steam game(s)"
            fi
        fi

        for dir in "Games" "games" "GOG Games" "Epic Games"; do
            if [[ -d "$mp/$dir" ]]; then
                local count
                count=$(find "$mp/$dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
                if [[ $count -gt 0 ]]; then
                    found_any=true
                    echo -e "  ${GREEN}$name${RESET}: $count game(s) in $dir/"
                fi
            fi
        done
    done < <(jq -c '.shares[]' "$SHARES_CONFIG" 2>/dev/null)

    if ! $found_any; then
        echo -e "  ${DIM}No game libraries detected on mounted shares${RESET}"
    fi
}

# ── Usage ───────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${BOLD}24HG Forge NAS${RESET} v${FORGE_VERSION} — Network Storage Manager for Game Libraries

${BOLD}USAGE:${RESET}
    forge-nas <command> [args...]

${BOLD}COMMANDS:${RESET}
    ${GREEN}scan${RESET}                          Scan LAN for NAS devices (SMB/NFS/DLNA)
    ${GREEN}mount${RESET} <share> [mountpoint]    Mount a saved network share
    ${GREEN}unmount${RESET} <share>               Unmount a share
    ${GREEN}list${RESET}                          List mounted network shares
    ${GREEN}add${RESET} <smb|nfs> <host> <path>   Add a network share to config
    ${GREEN}remove${RESET} <name>                 Remove a saved share
    ${GREEN}auto${RESET} on|off                   Toggle auto-mount on boot
    ${GREEN}speed${RESET} <share>                 Test read/write speed of a share
    ${GREEN}status${RESET}                        Overview of all shares with health info

${BOLD}EXAMPLES:${RESET}
    forge-nas scan
    forge-nas add smb mynas media
    forge-nas add nfs 192.168.1.50 /volume1/games
    forge-nas mount mynas_media
    forge-nas speed mynas_media
    forge-nas auto on

${BOLD}MOUNT POINTS:${RESET}
    Shares mount to ${CYAN}/mnt/forge-nas/<name>/${RESET}

${BOLD}CREDENTIALS:${RESET}
    SMB credentials stored via system keyring (secret-tool) or
    ~/.config/forge/nas-credentials/ with mode 600.

${BOLD}GAME LIBRARIES:${RESET}
    After mounting, Forge detects Steam/GOG/Epic games on the share
    and offers to add it as a Steam library folder.
EOF
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        scan|"")
            check_deps avahi-browse
            cmd_scan
            ;;
        mount)
            cmd_mount "$@"
            ;;
        unmount|umount)
            cmd_unmount "$@"
            ;;
        list|ls)
            cmd_list
            ;;
        add)
            cmd_add "$@"
            ;;
        remove|rm)
            cmd_remove "$@"
            ;;
        auto)
            cmd_auto "$@"
            ;;
        speed|benchmark)
            cmd_speed "$@"
            ;;
        status)
            cmd_status
            ;;
        -h|--help|help)
            usage
            ;;
        -v|--version)
            echo "forge-nas v${FORGE_VERSION}"
            ;;
        *)
            die "Unknown command: $cmd\nRun 'forge-nas --help' for usage"
            ;;
    esac
}

main "$@"
