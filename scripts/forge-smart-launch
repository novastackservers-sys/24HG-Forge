# ---------------------------------------------------------------------------
# Logging Setup
# ---------------------------------------------------------------------------

def setup_logging() -> logging.Logger:
    """Configure logging to both file and stderr."""
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log_file = LOG_DIR / f"smart-launch-{datetime.now():%Y-%m-%d}.log"

    logger = logging.getLogger(APP_NAME)
    logger.setLevel(logging.DEBUG)

    fh = logging.FileHandler(log_file)
    fh.setLevel(logging.DEBUG)
    fh.setFormatter(logging.Formatter(
        "%(asctime)s [%(levelname)s] %(message)s", datefmt="%H:%M:%S"
    ))

    sh = logging.StreamHandler()
    sh.setLevel(logging.INFO)
    sh.setFormatter(logging.Formatter("[%(levelname)s] %(message)s"))

    logger.addHandler(fh)
    logger.addHandler(sh)
    return logger


log = setup_logging()

# ---------------------------------------------------------------------------
# Utility Helpers
# ---------------------------------------------------------------------------

def ensure_dirs() -> None:
    """Create all required directories."""
    for d in (CONFIG_DIR, STATE_DIR, LOG_DIR):
        d.mkdir(parents=True, exist_ok=True)


def load_json(path: Path, default: Any = None) -> Any:
    """Load JSON file, returning default on any error."""
    try:
        with open(path) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError, PermissionError):
        return default if default is not None else {}


def save_json(path: Path, data: Any) -> None:
    """Save data as pretty-printed JSON."""
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w") as f:
        json.dump(data, f, indent=2)


def run_cmd(cmd: List[str], check: bool = False, timeout: int = 10) -> subprocess.CompletedProcess:
    """Run a command, suppressing stderr, returning result."""
    try:
        return subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=check,
            timeout=timeout,
        )
    except (subprocess.TimeoutExpired, subprocess.CalledProcessError, FileNotFoundError) as e:
        log.debug("Command failed: %s — %s", cmd, e)
        return subprocess.CompletedProcess(cmd, 1, "", str(e))


def notify(title: str, body: str, icon: str = "input-gaming") -> None:
    """Send desktop notification via notify-send."""
    run_cmd(["notify-send", "-a", "24HG Forge", "-i", icon, title, body])


def read_proc_cmdline(pid: int) -> str:
    """Read /proc/<pid>/cmdline, returning space-joined args."""
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as f:
            return f.read().decode("utf-8", errors="replace").replace("\0", " ").strip()
    except (FileNotFoundError, PermissionError):
        return ""


def read_proc_comm(pid: int) -> str:
    """Read /proc/<pid>/comm (process name)."""
    try:
        with open(f"/proc/{pid}/comm") as f:
            return f.read().strip()
    except (FileNotFoundError, PermissionError):
        return ""


def get_proc_children(pid: int) -> List[int]:
    """Get child PIDs from /proc/<pid>/task/*/children."""
    children = []
    task_dir = Path(f"/proc/{pid}/task")
    try:
        for tid in task_dir.iterdir():
            children_file = tid / "children"
            if children_file.exists():
                data = children_file.read_text().strip()
                if data:
                    children.extend(int(c) for c in data.split())
    except (FileNotFoundError, PermissionError, ValueError):
        pass
    return children


def pid_exists(pid: int) -> bool:
    """Check if a PID is still alive."""
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


# ---------------------------------------------------------------------------
# Game Rules Manager
# ---------------------------------------------------------------------------

class GameRules:
    """Manages built-in + user-override game rules."""

    def __init__(self):
        self.overrides: Dict[str, Dict] = load_json(OVERRIDES_FILE, {})

    def get(self, appid: str) -> Optional[Dict[str, Any]]:
        """Get merged rules for an appid (builtin + overrides)."""
        base = BUILTIN_RULES.get(appid)
        if base is None:
            # Check overrides for user-added games
            override = self.overrides.get(appid)
            return dict(override) if override else None

        merged = dict(base)
        override = self.overrides.get(appid, {})
        merged.update(override)
        return merged

    def set_override(self, appid: str, key: str, value: str) -> None:
        """Set a user override for a game rule."""
        if appid not in self.overrides:
            self.overrides[appid] = {}

        # Try to parse value as JSON for booleans, lists, etc.
        try:
            parsed = json.loads(value)
        except (json.JSONDecodeError, TypeError):
            parsed = value

        self.overrides[appid][key] = parsed
        save_json(OVERRIDES_FILE, self.overrides)
        log.info("Set override: %s.%s = %s", appid, key, parsed)

    def all_rules(self) -> Dict[str, Dict[str, Any]]:
        """Return all rules (builtin merged with overrides)."""
        all_ids = set(BUILTIN_RULES.keys()) | set(self.overrides.keys())
        result = {}
        for appid in sorted(all_ids, key=lambda x: x.zfill(10)):
            rule = self.get(appid)
            if rule:
                result[appid] = rule
        return result


# ---------------------------------------------------------------------------
# Optimization Engine
# ---------------------------------------------------------------------------

class OptimizationEngine:
    """Applies and reverts per-game optimizations."""

    def __init__(self, rules: GameRules):
        self.rules = rules
        self.active_game: Optional[str] = None
        self.active_pid: Optional[int] = None
        self.active_appid: Optional[str] = None
        self.previous_state: Dict[str, Any] = {}
        self.applied_opts: List[str] = []
        self.session_start: Optional[datetime] = None

    def apply(self, appid: str, pid: Optional[int] = None) -> bool:
        """Apply all optimizations for a game."""
        rule = self.rules.get(appid)
        if rule is None:
            log.warning("No rules found for AppID %s — applying generic gaming profile", appid)
            rule = {
                "name": f"Unknown Game ({appid})",
                "performance": "gaming",
                "mangohud": "full",
                "pause_downloads": True,
                "compositor": "suspend",
                "known_fixes": [],
                "env": {},
                "priority": "normal",
            }

        game_name = rule.get("name", appid)
        log.info("=== Applying optimizations for %s (AppID: %s) ===", game_name, appid)
        self.applied_opts = []
        self.active_game = game_name
        self.active_pid = pid
        self.active_appid = appid
        self.session_start = datetime.now()

        # Save current state for rollback
        self._save_previous_state()

        # 1. Switch performance profile
        perf = rule.get("performance", "gaming")
        self._apply_performance(perf)

        # 2. Set MangoHud preset
        mangohud = rule.get("mangohud", "full")
        self._apply_mangohud(mangohud)

        # 3. Suspend compositor
        if rule.get("compositor") == "suspend":
            self._suspend_compositor()

        # 4. Pause Steam downloads
        if rule.get("pause_downloads", True):
            self._pause_downloads()

        # 5. Pause Flatpak background updates
        if rule.get("pause_downloads", True):
            self._pause_flatpak_updates()

        # 6. Set process priority
        if pid:
            priority = rule.get("priority", "normal")
            self._set_priority(pid, priority)

        # 7. Apply game-specific env vars
        env_vars = rule.get("env", {})
        self._apply_env_vars(env_vars, pid)

        # 8. Set vm.max_map_count if specified
        max_map = env_vars.get("vm.max_map_count")
        if max_map:
            self._set_max_map_count(max_map)

        # 9. Send notification
        notify(
            f"24HG Forge optimizing for {game_name}...",
            f"Profile: {perf} | HUD: {mangohud} | Priority: {rule.get('priority', 'normal')}",
            "input-gaming",
        )
        self.applied_opts.append("notification_sent")

        # Save current state
        self._save_active_state()

        log.info("=== Optimizations applied: %s ===", ", ".join(self.applied_opts))
        return True

    def revert(self) -> None:
        """Revert all applied optimizations."""
        if not self.active_game:
            log.debug("No active game to revert optimizations for")
            return

        game_name = self.active_game
        log.info("=== Reverting optimizations for %s ===", game_name)

        # Restore performance profile
        prev_perf = self.previous_state.get("performance", "balanced")
        self._apply_performance(prev_perf)

        # Resume compositor
        if "compositor_suspended" in self.applied_opts:
            self._resume_compositor()

        # Resume Steam downloads
        if "downloads_paused" in self.applied_opts:
            self._resume_downloads()

        # Resume Flatpak updates
        if "flatpak_paused" in self.applied_opts:
            self._resume_flatpak_updates()

        # Unset MangoHud
        if "MANGOHUD_CONFIG" in os.environ:
            del os.environ["MANGOHUD_CONFIG"]

        # Log session
        duration = None
        if self.session_start:
            duration = datetime.now() - self.session_start

        self._log_session(game_name, duration)

        # Trigger session summary
        self._trigger_session_summary()

        # Send notification
        duration_str = str(duration).split(".")[0] if duration else "unknown"
        notify(
            f"{game_name} session ended",
            f"Duration: {duration_str} | Settings restored",
            "dialog-information",
        )

        # Clear active state
        self.active_game = None
        self.active_pid = None
        self.active_appid = None
        self.applied_opts = []
        self.session_start = None

        # Remove state file
        if CURRENT_STATE_FILE.exists():
            CURRENT_STATE_FILE.unlink()

        log.info("=== Optimizations reverted ===")

    def _save_previous_state(self) -> None:
        """Snapshot current system state before modifications."""
        # Detect current performance profile
        result = run_cmd([HUBOS_PERFORMANCE, "status"])
        self.previous_state["performance"] = "balanced"  # default fallback
        if result.returncode == 0 and result.stdout.strip():
            self.previous_state["performance"] = result.stdout.strip().split()[-1] \
                if result.stdout.strip() else "balanced"

    def _save_active_state(self) -> None:
        """Persist current active game state to disk."""
        state = {
            "game": self.active_game,
            "appid": self.active_appid,
            "pid": self.active_pid,
            "session_start": self.session_start.isoformat() if self.session_start else None,
            "applied": self.applied_opts,
            "timestamp": datetime.now().isoformat(),
        }
        save_json(CURRENT_STATE_FILE, state)

    def _apply_performance(self, profile: str) -> None:
        """Switch system performance profile."""
        result = run_cmd([HUBOS_PERFORMANCE, profile])
        if result.returncode == 0:
            self.applied_opts.append(f"performance:{profile}")
            log.info("Performance profile set to: %s", profile)
        else:
            log.warning("Failed to set performance profile: %s", result.stderr.strip())

    def _apply_mangohud(self, preset: str) -> None:
        """Set MangoHud configuration preset."""
        if preset == "off":
            os.environ.pop("MANGOHUD", None)
            os.environ.pop("MANGOHUD_CONFIG", None)
            self.applied_opts.append("mangohud:off")
            log.info("MangoHud disabled")
        elif preset in MANGOHUD_PRESETS:
            os.environ["MANGOHUD"] = "1"
            os.environ["MANGOHUD_CONFIG"] = MANGOHUD_PRESETS[preset]
            self.applied_opts.append(f"mangohud:{preset}")
            log.info("MangoHud preset: %s", preset)
        else:
            log.warning("Unknown MangoHud preset: %s", preset)

    def _suspend_compositor(self) -> None:
        """Suspend KWin compositor for lower latency."""
        result = run_cmd([
            "qdbus", "org.kde.KWin", "/Compositor", "suspend"
        ])
        if result.returncode == 0:
            self.applied_opts.append("compositor_suspended")
            log.info("KWin compositor suspended")
        else:
            # Try alternative method for Wayland
            result = run_cmd([
                "dbus-send", "--session", "--dest=org.kde.KWin",
                "--type=method_call", "/Compositor",
                "org.kde.kwin.Compositing.suspend"
            ])
            if result.returncode == 0:
                self.applied_opts.append("compositor_suspended")
                log.info("KWin compositor suspended (dbus-send)")
            else:
                log.debug("Compositor suspend skipped (not KWin or already suspended)")

    def _resume_compositor(self) -> None:
        """Resume KWin compositor."""
        run_cmd(["qdbus", "org.kde.KWin", "/Compositor", "resume"])
        log.info("KWin compositor resumed")

    def _pause_downloads(self) -> None:
        """Pause Steam downloads via URL handler."""
        run_cmd(["xdg-open", "steam://command/PauseDownloads"])
        self.applied_opts.append("downloads_paused")
        log.info("Steam downloads paused")

    def _resume_downloads(self) -> None:
        """Resume Steam downloads."""
        run_cmd(["xdg-open", "steam://command/ResumeDownloads"])
        log.info("Steam downloads resumed")

    def _pause_flatpak_updates(self) -> None:
        """Pause Flatpak background update services."""
        result = run_cmd(["systemctl", "--user", "list-units", "--plain",
                          "--no-legend", "flatpak-*"])
        if result.returncode == 0 and result.stdout.strip():
            units = []
            for line in result.stdout.strip().splitlines():
                parts = line.split()
                if parts:
                    units.append(parts[0])
            for unit in units:
                run_cmd(["systemctl", "--user", "stop", unit])
            if units:
                self.applied_opts.append("flatpak_paused")
                log.info("Paused %d Flatpak background units", len(units))
        else:
            log.debug("No Flatpak background services to pause")

    def _resume_flatpak_updates(self) -> None:
        """Resume Flatpak update timer."""
        run_cmd(["systemctl", "--user", "start", "flatpak-system-update.timer"])
        log.info("Flatpak updates resumed")

    def _set_priority(self, pid: int, priority: str) -> None:
        """Set process scheduling priority."""
        nice_val = {"high": -5, "normal": 0, "low": 5}.get(priority, 0)
        result = run_cmd(["renice", str(nice_val), "-p", str(pid)])
        if result.returncode == 0:
            self.applied_opts.append(f"priority:{priority}(nice={nice_val})")
            log.info("Process %d priority set to %s (nice %d)", pid, priority, nice_val)
        else:
            log.warning("Failed to renice PID %d: %s", pid, result.stderr.strip())

    def _apply_env_vars(self, env_vars: Dict[str, str], pid: Optional[int]) -> None:
        """Apply game-specific environment variables."""
        applied = []
        for key, value in env_vars.items():
            # Skip sysctl entries handled separately
            if key.startswith("vm."):
                continue
            os.environ[key] = value
            applied.append(f"{key}={value}")
        if applied:
            self.applied_opts.append(f"env:{len(applied)}_vars")
            log.info("Environment variables set: %s", ", ".join(applied))

    def _set_max_map_count(self, value: str) -> None:
        """Set vm.max_map_count (requires write access to /proc/sys)."""
        try:
            current = Path("/proc/sys/vm/max_map_count").read_text().strip()
            if int(current) < int(value):
                result = run_cmd([
                    "sudo", "-n", "sysctl", "-w", f"vm.max_map_count={value}"
                ])
                if result.returncode == 0:
                    self.applied_opts.append(f"max_map_count:{value}")
                    log.info("vm.max_map_count set to %s (was %s)", value, current)
                else:
                    # Try direct write (works if running as root or with capabilities)
                    try:
                        Path("/proc/sys/vm/max_map_count").write_text(value)
                        self.applied_opts.append(f"max_map_count:{value}")
                        log.info("vm.max_map_count set to %s (direct write)", value)
                    except PermissionError:
                        log.warning("Cannot set vm.max_map_count — needs root. "
                                    "Current: %s, needed: %s", current, value)
            else:
                log.debug("vm.max_map_count already sufficient (%s >= %s)", current, value)
        except (FileNotFoundError, ValueError) as e:
            log.warning("Failed to check/set vm.max_map_count: %s", e)

    def _log_session(self, game_name: str, duration: Optional[timedelta]) -> None:
        """Log game session to persistent history."""
        sessions = load_json(SESSION_LOG, [])
        if not isinstance(sessions, list):
            sessions = []

        session = {
            "game": game_name,
            "appid": self.active_appid,
            "start": self.session_start.isoformat() if self.session_start else None,
            "end": datetime.now().isoformat(),
            "duration_seconds": int(duration.total_seconds()) if duration else None,
            "optimizations": list(self.applied_opts),
        }
        sessions.append(session)

        # Keep last 500 sessions
        if len(sessions) > 500:
            sessions = sessions[-500:]

        save_json(SESSION_LOG, sessions)

    def _trigger_session_summary(self) -> None:
        """Call forge-session-summary for post-game report."""
        if Path(HUBOS_SESSION_SUMMARY).exists():
            run_cmd([HUBOS_SESSION_SUMMARY, "generate"], timeout=30)
            log.info("Session summary triggered")
        else:
            log.debug("forge-session-summary not found, skipping")


# ---------------------------------------------------------------------------
# Process Monitor (Game Detection)
# ---------------------------------------------------------------------------

class GameDetector:
    """Detects game launches by monitoring /proc and known paths."""

    def __init__(self):
        self.known_pids: set = set()
        self.steam_reaper_re = re.compile(r"reaper\s.*?AppId=(\d+)", re.IGNORECASE)
        self.proton_appid_re = re.compile(r"compatdata/(\d+)/")
        self._scan_existing_pids()

    def _scan_existing_pids(self) -> None:
        """Record currently running PIDs to avoid false detections on startup."""
        try:
            for entry in os.listdir("/proc"):
                if entry.isdigit():
                    self.known_pids.add(int(entry))
        except (PermissionError, FileNotFoundError):
            pass
        log.debug("Initialized with %d existing PIDs", len(self.known_pids))

    def scan(self) -> Optional[Tuple[str, str, int]]:
        """
        Scan for newly launched games.
        Returns (appid, game_name, pid) or None.
        """
        current_pids = set()
        try:
            for entry in os.listdir("/proc"):
                if entry.isdigit():
                    current_pids.add(int(entry))
        except (PermissionError, FileNotFoundError):
            return None

        new_pids = current_pids - self.known_pids
        self.known_pids = current_pids

        for pid in sorted(new_pids):
            result = self._identify_game(pid)
            if result:
                return result

        return None

    def _identify_game(self, pid: int) -> Optional[Tuple[str, str, int]]:
        """Try to identify if a PID is a game process."""
        comm = read_proc_comm(pid)
        cmdline = read_proc_cmdline(pid)

        if not comm and not cmdline:
            return None

        # --- Steam Reaper detection ---
        if "reaper" in comm or "reaper" in cmdline:
            match = self.steam_reaper_re.search(cmdline)
            if match:
                appid = match.group(1)
                rule = BUILTIN_RULES.get(appid)
                name = rule["name"] if rule else f"Steam Game {appid}"
                log.debug("Detected Steam reaper for AppID %s (PID %d)", appid, pid)
                return (appid, name, pid)

        # --- Proton/Wine detection ---
        if any(x in cmdline for x in ("proton", "wine", "wineserver", "pressure-vessel")):
            match = self.proton_appid_re.search(cmdline)
            if match:
                appid = match.group(1)
                rule = BUILTIN_RULES.get(appid)
                name = rule["name"] if rule else f"Steam Game {appid}"
                log.debug("Detected Proton game for AppID %s (PID %d)", appid, pid)
                return (appid, name, pid)

        # --- Known native binary detection ---
        basename = comm.strip()
        if basename in KNOWN_BINARIES:
            appid = KNOWN_BINARIES[basename]

            # Minecraft heuristic: only match java if cmdline contains minecraft
            if appid == "minecraft":
                if "minecraft" not in cmdline.lower():
                    return None

            rule = BUILTIN_RULES.get(appid)
            name = rule["name"] if rule else basename
            log.debug("Detected native game %s (PID %d)", basename, pid)
            return (appid, name, pid)

        # --- Lutris game detection ---
        if "lutris-wrapper" in cmdline or "lutris-wrapper" in comm:
            log.debug("Detected Lutris game launch (PID %d)", pid)
            return self._identify_lutris_game(pid, cmdline)

        # --- Heroic game detection ---
        if "heroic" in cmdline.lower() and ("wine" in cmdline or "proton" in cmdline):
            log.debug("Detected Heroic game launch (PID %d)", pid)
            return ("heroic_game", "Heroic Game", pid)

        return None

    def _identify_lutris_game(self, pid: int, cmdline: str) -> Optional[Tuple[str, str, int]]:
        """Try to identify a Lutris-launched game."""
        # Extract game name from lutris-wrapper arguments
        parts = cmdline.split()
        for i, part in enumerate(parts):
            if "lutris-wrapper" in part and i + 1 < len(parts):
                game_slug = parts[i + 1] if i + 1 < len(parts) else "unknown"
                return ("lutris_" + game_slug, f"Lutris: {game_slug}", pid)
        return ("lutris_game", "Lutris Game", pid)

    def is_game_running(self, pid: int) -> bool:
        """Check if the tracked game process is still running."""
        if not pid_exists(pid):
            return False
        # Also check that it hasn't become a zombie
        try:
            with open(f"/proc/{pid}/status") as f:
                for line in f:
                    if line.startswith("State:"):
                        return "Z" not in line  # not zombie
        except (FileNotFoundError, PermissionError):
            return False
        return True


# ---------------------------------------------------------------------------
# Daemon
# ---------------------------------------------------------------------------

class SmartLaunchDaemon:
    """Main daemon loop — monitors for games and applies optimizations."""

    def __init__(self):
        self.rules = GameRules()
        self.engine = OptimizationEngine(self.rules)
        self.detector = GameDetector()
        self.running = True
        self._setup_signals()

    def _setup_signals(self) -> None:
        """Handle graceful shutdown."""
        signal.signal(signal.SIGTERM, self._handle_signal)
        signal.signal(signal.SIGINT, self._handle_signal)
        signal.signal(signal.SIGHUP, self._handle_reload)

    def _handle_signal(self, signum: int, frame) -> None:
        """Graceful shutdown — revert all optimizations."""
        log.info("Received signal %d, shutting down gracefully...", signum)
        self.running = False

    def _handle_reload(self, signum: int, frame) -> None:
        """Reload configuration on SIGHUP."""
        log.info("Received SIGHUP, reloading rules...")
        self.rules = GameRules()
        self.engine.rules = self.rules
        log.info("Rules reloaded (%d builtin + %d overrides)",
                 len(BUILTIN_RULES), len(self.rules.overrides))

    def run(self) -> None:
        """Main daemon loop."""
        ensure_dirs()
        log.info("24HG Forge Smart Launch daemon starting (v%s)", VERSION)
        log.info("Monitoring for game launches (poll interval: %ds)", POLL_INTERVAL)
        log.info("Loaded %d builtin rules, %d user overrides",
                 len(BUILTIN_RULES), len(self.rules.overrides))

        # Recover state if daemon was restarted while a game was running
        self._recover_state()

        try:
            while self.running:
                self._tick()
                time.sleep(POLL_INTERVAL)
        except Exception as e:
            log.error("Daemon crashed: %s", e, exc_info=True)
        finally:
            # Always revert on exit
            if self.engine.active_game:
                log.info("Daemon stopping — reverting active optimizations")
                self.engine.revert()
            log.info("24HG Forge Smart Launch daemon stopped")

    def _tick(self) -> None:
        """Single monitoring cycle."""
        if self.engine.active_game:
            # A game is active — check if it's still running
            if self.engine.active_pid and not self.detector.is_game_running(self.engine.active_pid):
                log.info("Game process (PID %d) has exited", self.engine.active_pid)
                self.engine.revert()
        else:
            # No active game — scan for new launches
            detection = self.detector.scan()
            if detection:
                appid, name, pid = detection
                log.info("Game detected: %s (AppID: %s, PID: %d)", name, appid, pid)

                # Wait briefly for process tree to settle
                time.sleep(PROCESS_SETTLE_TIME)

                # Verify process is still alive after settling
                if pid_exists(pid):
                    self.engine.apply(appid, pid)
                else:
                    log.debug("Game PID %d exited during settle time, ignoring", pid)

    def _recover_state(self) -> None:
        """Recover from a daemon restart while a game was running."""
        state = load_json(CURRENT_STATE_FILE)
        if not state:
            return

        pid = state.get("pid")
        if pid and pid_exists(pid):
            log.info("Recovering active session: %s (PID %d)", state.get("game"), pid)
            self.engine.active_game = state.get("game")
            self.engine.active_pid = pid
            self.engine.active_appid = state.get("appid")
            self.engine.applied_opts = state.get("applied", [])
            start = state.get("session_start")
            if start:
                self.engine.session_start = datetime.fromisoformat(start)
            # Mark the PID as known
            self.detector.known_pids.add(pid)
        else:
            log.info("Stale state file found (PID %s no longer exists), cleaning up",
                     pid)
            CURRENT_STATE_FILE.unlink(missing_ok=True)


# ---------------------------------------------------------------------------
# CLI Commands
# ---------------------------------------------------------------------------

def cmd_daemon() -> None:
    """Run the background monitoring daemon."""
    daemon = SmartLaunchDaemon()
    daemon.run()


def cmd_apply(appid: str) -> None:
    """Manually apply optimizations for a game."""
    ensure_dirs()
    rules = GameRules()
    engine = OptimizationEngine(rules)

    rule = rules.get(appid)
    if rule:
        print(f"Applying optimizations for: {rule.get('name', appid)}")
    else:
        print(f"No specific rules for AppID {appid}, applying generic gaming profile")

    # Try to find a running process for this game
    pid = _find_game_pid(appid)
    if pid:
        print(f"Found game process: PID {pid}")
    else:
        print("No running game process found (optimizations applied without priority/env)")

    engine.apply(appid, pid)
    print("Optimizations applied. Run 'forge-smart-launch status' to verify.")


def cmd_config(appid: str, set_value: Optional[str] = None) -> None:
    """View or modify per-game configuration."""
    ensure_dirs()
    rules = GameRules()

    if set_value:
        # Parse key=value
        if "=" not in set_value:
            print(f"Error: Expected key=value format, got: {set_value}", file=sys.stderr)
            sys.exit(1)
        key, value = set_value.split("=", 1)
        rules.set_override(appid, key.strip(), value.strip())
        print(f"Override saved: {appid}.{key.strip()} = {value.strip()}")
        print(f"Stored in: {OVERRIDES_FILE}")
        return

    # View config
    rule = rules.get(appid)
    if rule is None:
        print(f"No rules found for AppID: {appid}")
        print(f"Add custom rules with: forge-smart-launch config {appid} --set key=value")
        return

    print(f"{'='*60}")
    print(f"  Game: {rule.get('name', 'Unknown')} (AppID: {appid})")
    print(f"{'='*60}")

    # Check for overrides
    overrides = rules.overrides.get(appid, {})
    has_override = bool(overrides)

    fields = [
        ("Proton", "proton", lambda v: v or "Native"),
        ("Performance", "performance", str),
        ("MangoHud", "mangohud", str),
        ("Pause Downloads", "pause_downloads", lambda v: "Yes" if v else "No"),
        ("Compositor", "compositor", str),
        ("Priority", "priority", str),
        ("Known Fixes", "known_fixes", lambda v: ", ".join(v) if v else "None"),
        ("Env Vars", "env", lambda v: json.dumps(v) if v else "None"),
        ("Launch Args", "launch_args", lambda v: v or "None"),
    ]

    for label, key, fmt in fields:
        value = rule.get(key)
        is_overridden = key in overrides
        marker = " *" if is_overridden else ""
        print(f"  {label:.<20} {fmt(value)}{marker}")

    if has_override:
        print(f"\n  * = User override (stored in {OVERRIDES_FILE})")

    print()


def cmd_status() -> None:
    """Show current optimization state."""
    ensure_dirs()

    state = load_json(CURRENT_STATE_FILE)

    print(f"{'='*60}")
    print(f"  24HG Forge Smart Launch — Status")
    print(f"{'='*60}")

    if state and state.get("game"):
        pid = state.get("pid")
        alive = pid_exists(pid) if pid else False

        print(f"  Active Game:    {state.get('game', 'Unknown')}")
        print(f"  AppID:          {state.get('appid', 'N/A')}")
        print(f"  PID:            {pid} ({'running' if alive else 'EXITED'})")
        start = state.get("session_start")
        if start:
            try:
                dt = datetime.fromisoformat(start)
                elapsed = datetime.now() - dt
                print(f"  Session Start:  {dt:%H:%M:%S}")
                print(f"  Elapsed:        {str(elapsed).split('.')[0]}")
            except ValueError:
                pass

        applied = state.get("applied", [])
        if applied:
            print(f"\n  Applied Optimizations:")
            for opt in applied:
                print(f"    - {opt}")
    else:
        print(f"  Active Game:    None")
        print(f"  Status:         Idle — waiting for game launch")

    # Daemon status
    result = run_cmd(["systemctl", "--user", "is-active", "forge-smart-launch.service"])
    daemon_status = result.stdout.strip() if result.returncode == 0 else "unknown"
    print(f"\n  Daemon Status:  {daemon_status}")

    # Performance profile
    result = run_cmd([HUBOS_PERFORMANCE, "status"])
    perf = result.stdout.strip() if result.returncode == 0 and result.stdout else "unknown"
    print(f"  Perf Profile:   {perf}")

    print(f"{'='*60}")


def cmd_rules() -> None:
    """List all built-in game rules."""
    rules = GameRules()
    all_rules = rules.all_rules()

    print(f"{'='*90}")
    print(f"  24HG Forge Smart Launch — Game Optimization Rules ({len(all_rules)} games)")
    print(f"{'='*90}")
    print(f"  {'AppID':<12} {'Game':<35} {'Perf':<10} {'HUD':<14} {'Proton':<12} {'Priority':<8}")
    print(f"  {'-'*12} {'-'*35} {'-'*10} {'-'*14} {'-'*12} {'-'*8}")

    for appid, rule in all_rules.items():
        name = rule.get("name", "Unknown")
        if len(name) > 33:
            name = name[:30] + "..."
        perf = rule.get("performance", "N/A")
        hud = rule.get("mangohud", "N/A")
        proton = rule.get("proton") or "Native"
        if len(proton) > 10:
            proton = proton[:10]
        priority = rule.get("priority", "normal")

        # Mark overridden entries
        is_custom = appid in rules.overrides
        marker = " *" if is_custom else ""

        print(f"  {appid:<12} {name:<35} {perf:<10} {hud:<14} {proton:<12} {priority:<8}{marker}")

    print(f"\n  * = Has user overrides")
    print(f"  Override file: {OVERRIDES_FILE}")
    print(f"{'='*90}")


def cmd_log(count: int = 20) -> None:
    """Show recent game launch history."""
    ensure_dirs()
    sessions = load_json(SESSION_LOG, [])

    if not sessions:
        print("No game sessions recorded yet.")
        return

    # Show most recent first
    recent = list(reversed(sessions[-count:]))

    print(f"{'='*90}")
    print(f"  24HG Forge Smart Launch — Recent Sessions (last {min(count, len(recent))})")
    print(f"{'='*90}")
    print(f"  {'Date':<12} {'Time':<8} {'Game':<30} {'Duration':<12} {'Optimizations':<20}")
    print(f"  {'-'*12} {'-'*8} {'-'*30} {'-'*12} {'-'*20}")

    for session in recent:
        try:
            start = datetime.fromisoformat(session.get("start", ""))
            date_str = start.strftime("%Y-%m-%d")
            time_str = start.strftime("%H:%M")
        except (ValueError, TypeError):
            date_str = "N/A"
            time_str = "N/A"

        game = session.get("game", "Unknown")
        if len(game) > 28:
            game = game[:25] + "..."

        dur_secs = session.get("duration_seconds")
        if dur_secs is not None:
            hours, rem = divmod(dur_secs, 3600)
            minutes, secs = divmod(rem, 60)
            if hours > 0:
                dur_str = f"{hours}h {minutes}m"
            else:
                dur_str = f"{minutes}m {secs}s"
        else:
            dur_str = "N/A"

        opts = session.get("optimizations", [])
        opt_str = f"{len(opts)} applied"

        print(f"  {date_str:<12} {time_str:<8} {game:<30} {dur_str:<12} {opt_str:<20}")

    print(f"\n  Total sessions recorded: {len(sessions)}")
    print(f"  Session log: {SESSION_LOG}")
    print(f"{'='*90}")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _find_game_pid(appid: str) -> Optional[int]:
    """Try to find a running process for the given appid."""
    try:
        for entry in os.listdir("/proc"):
            if not entry.isdigit():
                continue
            pid = int(entry)
            cmdline = read_proc_cmdline(pid)
            if not cmdline:
                continue

            # Check for Steam reaper with this appid
            if f"AppId={appid}" in cmdline:
                return pid

            # Check for proton compatdata path
            if f"compatdata/{appid}/" in cmdline:
                return pid

            # Check for known binary
            comm = read_proc_comm(pid)
            if comm in KNOWN_BINARIES and KNOWN_BINARIES[comm] == appid:
                return pid
    except (PermissionError, FileNotFoundError):
        pass
    return None


# ---------------------------------------------------------------------------
# Argument Parser and Main
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    """Build the CLI argument parser."""
    parser = argparse.ArgumentParser(
        prog="forge-smart-launch",
        description="24HG Forge Smart Game Launch — Intelligent per-game optimization daemon",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  forge-smart-launch daemon              Start background daemon\n"
            "  forge-smart-launch apply 252490         Apply Rust optimizations\n"
            "  forge-smart-launch config 730           View CS2 config\n"
            "  forge-smart-launch config 730 --set mangohud=full\n"
            "  forge-smart-launch status               Show current state\n"
            "  forge-smart-launch rules                List all game rules\n"
            "  forge-smart-launch log                  Show recent sessions\n"
        ),
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")

    sub = parser.add_subparsers(dest="command", help="Available commands")

    # daemon
    sub.add_parser("daemon", help="Run background monitoring daemon")

    # apply
    p_apply = sub.add_parser("apply", help="Manually apply optimizations for a game")
    p_apply.add_argument("appid", help="Steam AppID or game identifier")

    # config
    p_config = sub.add_parser("config", help="View or edit per-game configuration")
    p_config.add_argument("appid", help="Steam AppID or game identifier")
    p_config.add_argument("--set", dest="set_value", metavar="KEY=VALUE",
                          help="Set a config override (e.g., mangohud=competitive)")

    # status
    sub.add_parser("status", help="Show current optimization state")

    # rules
    sub.add_parser("rules", help="List all built-in game rules")

    # log
    p_log = sub.add_parser("log", help="Show recent launch history")
    p_log.add_argument("-n", "--count", type=int, default=20,
                       help="Number of recent sessions to show (default: 20)")

    return parser


def main() -> None:
    """Entry point."""
    parser = build_parser()
    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(0)

    ensure_dirs()

    commands = {
        "daemon": cmd_daemon,
        "apply": lambda: cmd_apply(args.appid),
        "config": lambda: cmd_config(args.appid, getattr(args, "set_value", None)),
        "status": cmd_status,
        "rules": cmd_rules,
        "log": lambda: cmd_log(getattr(args, "count", 20)),
    }

    handler = commands.get(args.command)
    if handler:
        handler()
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
