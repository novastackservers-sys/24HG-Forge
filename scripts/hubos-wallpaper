#!/bin/bash
# HubOS Wallpaper Manager — Time-aware wallpaper rotation for gaming desktops
# Automatically selects wallpapers that match the mood of the day, or lets
# you pick your own from the curated HubOS collection.
#
# Usage: hubos-wallpaper [rotate|set <name|path>|list|random|schedule|download]

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────

WALLPAPER_DIR="/usr/share/hubos/wallpapers"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/hubos/wallpapers"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hubos"
STATE_FILE="$CONFIG_DIR/wallpaper-state"
LOG_FILE="$CACHE_DIR/wallpaper.log"

# Time-of-day categories (filenames should contain these prefixes/tags)
declare -A TIME_CATEGORIES=(
    [morning]="morning light bright dawn sunrise"
    [afternoon]="afternoon vibrant colorful day action"
    [evening]="evening warm sunset dusk golden"
    [night]="night dark moody neon cyber midnight"
)

# ── Setup ─────────────────────────────────────────────────────────────────────

mkdir -p "$CACHE_DIR" "$CONFIG_DIR"

log() {
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$timestamp] $*" >> "$LOG_FILE" 2>/dev/null || true
}

msg() {
    echo -e "\033[1;35m❯\033[0m $*"
}

warn() {
    echo -e "\033[1;33m⚠\033[0m $*" >&2
}

err() {
    echo -e "\033[1;31m✗\033[0m $*" >&2
    exit 1
}

# ── Wallpaper Application ────────────────────────────────────────────────────

# Apply wallpaper to all KDE Plasma desktops via D-Bus
apply_wallpaper() {
    local wallpaper_path="$1"

    if [[ ! -f "$wallpaper_path" ]]; then
        err "Wallpaper not found: $wallpaper_path"
    fi

    # Resolve to absolute path
    wallpaper_path="$(realpath "$wallpaper_path")"

    log "Setting wallpaper: $wallpaper_path"

    # ── KDE Plasma desktop wallpaper ──────────────────────────────────────
    local plasma_script
    plasma_script=$(cat <<JSEOF
var allDesktops = desktops();
for (var i = 0; i < allDesktops.length; i++) {
    var d = allDesktops[i];
    d.wallpaperPlugin = "org.kde.image";
    d.currentConfigGroup = Array("Wallpaper", "org.kde.image", "General");
    d.writeConfig("Image", "file://${wallpaper_path}");
    d.writeConfig("FillMode", 1);
}
JSEOF
    )

    if qdbus org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$plasma_script" 2>/dev/null; then
        log "Desktop wallpaper set successfully"
    else
        warn "Could not set desktop wallpaper (Plasma Shell not available?)"
    fi

    # ── Lock screen wallpaper ─────────────────────────────────────────────
    kwriteconfig6 --file kscreenlockerrc \
        --group Greeter \
        --group Wallpaper \
        --group org.kde.image \
        --group General \
        --key Image "file://${wallpaper_path}" 2>/dev/null || true

    kwriteconfig6 --file kscreenlockerrc \
        --group Greeter \
        --group Wallpaper \
        --group org.kde.image \
        --group General \
        --key FillMode 1 2>/dev/null || true

    # ── SDDM login screen (requires root) ────────────────────────────────
    if [[ $EUID -eq 0 ]]; then
        local sddm_theme_conf="/etc/sddm.conf.d/hubos-wallpaper.conf"
        mkdir -p /etc/sddm.conf.d
        cat > "$sddm_theme_conf" <<SDDMEOF
[Theme]
Current=breeze
Background=${wallpaper_path}
SDDMEOF
        log "SDDM background updated"
    fi

    # ── Save state ────────────────────────────────────────────────────────
    echo "$wallpaper_path" > "$STATE_FILE"

    msg "Wallpaper set: \033[1m$(basename "$wallpaper_path")\033[0m"
}

# ── Time-of-Day Detection ────────────────────────────────────────────────────

get_time_period() {
    local hour
    hour="$(date +%H)"
    hour="${hour#0}"  # strip leading zero

    if (( hour >= 6 && hour < 12 )); then
        echo "morning"
    elif (( hour >= 12 && hour < 18 )); then
        echo "afternoon"
    elif (( hour >= 18 && hour < 22 )); then
        echo "evening"
    else
        echo "night"
    fi
}

get_period_description() {
    case "$1" in
        morning)   echo "Morning (6:00–12:00) — Light & bright gaming aesthetic" ;;
        afternoon) echo "Afternoon (12:00–18:00) — Vibrant & colorful" ;;
        evening)   echo "Evening (18:00–22:00) — Warm sunset tones" ;;
        night)     echo "Night (22:00–6:00) — Dark & moody gaming atmosphere" ;;
    esac
}

# ── Wallpaper Discovery ──────────────────────────────────────────────────────

# Categorize a wallpaper file into a time period based on filename/path
categorize_wallpaper() {
    local file="$1"
    local basename_lower
    basename_lower="$(basename "$file" | tr '[:upper:]' '[:lower:]')"
    local dir_lower
    dir_lower="$(dirname "$file" | tr '[:upper:]' '[:lower:]')"

    for period in morning afternoon evening night; do
        local keywords="${TIME_CATEGORIES[$period]}"
        for keyword in $keywords; do
            if [[ "$basename_lower" == *"$keyword"* ]] || [[ "$dir_lower" == *"/$period/"* ]] || [[ "$dir_lower" == *"/$period" ]]; then
                echo "$period"
                return
            fi
        done
    done

    # No match — assign based on image characteristics or default to "afternoon"
    echo "afternoon"
}

# Get all wallpapers for a given time period
get_wallpapers_for_period() {
    local target_period="$1"
    local results=()

    if [[ ! -d "$WALLPAPER_DIR" ]]; then
        return
    fi

    # Check subdirectories named by period first
    if [[ -d "$WALLPAPER_DIR/$target_period" ]]; then
        while IFS= read -r -d '' file; do
            results+=("$file")
        done < <(find "$WALLPAPER_DIR/$target_period" -maxdepth 1 -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' -o -name '*.webp' \) -print0 2>/dev/null)
    fi

    # Also scan root dir for tagged files
    while IFS= read -r -d '' file; do
        local cat
        cat="$(categorize_wallpaper "$file")"
        if [[ "$cat" == "$target_period" ]]; then
            results+=("$file")
        fi
    done < <(find "$WALLPAPER_DIR" -maxdepth 1 -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' -o -name '*.webp' \) -print0 2>/dev/null)

    # Also check user's cache for downloaded wallpapers
    if [[ -d "$CACHE_DIR/$target_period" ]]; then
        while IFS= read -r -d '' file; do
            results+=("$file")
        done < <(find "$CACHE_DIR/$target_period" -maxdepth 1 -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' -o -name '*.webp' \) -print0 2>/dev/null)
    fi

    # Deduplicate and print
    printf '%s\n' "${results[@]}" | sort -u
}

# Get all available wallpapers
get_all_wallpapers() {
    local dirs=("$WALLPAPER_DIR" "$CACHE_DIR")
    for dir in "${dirs[@]}"; do
        [[ -d "$dir" ]] || continue
        find "$dir" -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' -o -name '*.webp' \) 2>/dev/null
    done | sort -u
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_rotate() {
    local period
    period="$(get_time_period)"
    local description
    description="$(get_period_description "$period")"

    msg "Time period: \033[1m$description\033[0m"

    local -a candidates
    mapfile -t candidates < <(get_wallpapers_for_period "$period")

    if [[ ${#candidates[@]} -eq 0 ]]; then
        # Fallback: try any wallpaper
        mapfile -t candidates < <(get_all_wallpapers)
    fi

    if [[ ${#candidates[@]} -eq 0 ]]; then
        warn "No wallpapers found in $WALLPAPER_DIR"
        warn "Run 'hubos-wallpaper download' to get the community wallpaper pack."
        return 1
    fi

    # Pick a random one from the matching set (avoid repeating the last one)
    local last_wallpaper=""
    [[ -f "$STATE_FILE" ]] && last_wallpaper="$(cat "$STATE_FILE" 2>/dev/null || true)"

    local pick=""
    local attempts=0
    while (( attempts < 5 )); do
        pick="${candidates[RANDOM % ${#candidates[@]}]}"
        [[ "$pick" != "$last_wallpaper" || ${#candidates[@]} -eq 1 ]] && break
        (( attempts++ ))
    done

    apply_wallpaper "$pick"
    log "Rotated to $period wallpaper: $pick"
}

cmd_set() {
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        err "Usage: hubos-wallpaper set <name|path>"
    fi

    # If it's already a valid path, use it directly
    if [[ -f "$target" ]]; then
        apply_wallpaper "$target"
        return
    fi

    # Search by name in wallpaper directory
    local found=""

    # Exact filename match (with or without extension)
    for ext in "" .png .jpg .jpeg .webp; do
        local candidate="$WALLPAPER_DIR/${target}${ext}"
        if [[ -f "$candidate" ]]; then
            found="$candidate"
            break
        fi
        # Also search subdirectories
        local subdir_match
        subdir_match="$(find "$WALLPAPER_DIR" -name "${target}${ext}" -type f 2>/dev/null | head -1)"
        if [[ -n "$subdir_match" ]]; then
            found="$subdir_match"
            break
        fi
    done

    # Fuzzy match if exact didn't work
    if [[ -z "$found" ]]; then
        local fuzzy_match
        fuzzy_match="$(find "$WALLPAPER_DIR" -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' -o -name '*.webp' \) 2>/dev/null | while read -r f; do
            basename_lower="$(basename "$f" | tr '[:upper:]' '[:lower:]')"
            target_lower="$(echo "$target" | tr '[:upper:]' '[:lower:]')"
            [[ "$basename_lower" == *"$target_lower"* ]] && echo "$f"
        done | head -1)"
        [[ -n "$fuzzy_match" ]] && found="$fuzzy_match"
    fi

    if [[ -z "$found" ]]; then
        err "Wallpaper '$target' not found. Run 'hubos-wallpaper list' to see available options."
    fi

    apply_wallpaper "$found"
}

cmd_list() {
    echo ""
    msg "\033[1mHubOS Wallpaper Collection\033[0m"
    echo ""

    local total=0

    for period in morning afternoon evening night; do
        local description
        description="$(get_period_description "$period")"
        echo -e "  \033[1;36m$description\033[0m"

        local -a wallpapers
        mapfile -t wallpapers < <(get_wallpapers_for_period "$period")

        if [[ ${#wallpapers[@]} -eq 0 ]]; then
            echo -e "    \033[2m(none)\033[0m"
        else
            for wp in "${wallpapers[@]}"; do
                local name
                name="$(basename "$wp")"
                local current_marker=""
                if [[ -f "$STATE_FILE" ]] && [[ "$(cat "$STATE_FILE" 2>/dev/null)" == "$(realpath "$wp")" ]]; then
                    current_marker=" \033[1;32m◀ current\033[0m"
                fi
                echo -e "    \033[0;37m•\033[0m $name${current_marker}"
                (( total++ ))
            done
        fi
        echo ""
    done

    echo -e "  \033[2m$total wallpaper(s) available\033[0m"
    echo -e "  \033[2mWallpaper directory: $WALLPAPER_DIR\033[0m"
    echo ""
}

cmd_random() {
    local -a all_wallpapers
    mapfile -t all_wallpapers < <(get_all_wallpapers)

    if [[ ${#all_wallpapers[@]} -eq 0 ]]; then
        err "No wallpapers found. Run 'hubos-wallpaper download' to get started."
    fi

    local pick="${all_wallpapers[RANDOM % ${#all_wallpapers[@]}]}"
    apply_wallpaper "$pick"
}

cmd_schedule() {
    local action="${1:-enable}"

    case "$action" in
        enable|on)
            msg "Enabling automatic wallpaper rotation..."

            # Enable the systemd user timer
            systemctl --user daemon-reload 2>/dev/null || true
            systemctl --user enable --now hubos-wallpaper.timer 2>/dev/null

            if systemctl --user is-active hubos-wallpaper.timer &>/dev/null; then
                msg "\033[1;32mScheduled rotation active.\033[0m"
                msg "Wallpaper will change at 6:00, 12:00, 18:00, and 22:00."
                echo ""
                systemctl --user status hubos-wallpaper.timer --no-pager 2>/dev/null || true
            else
                # Fallback to cron if systemd user session isn't available
                warn "systemd user timer not available, falling back to cron..."

                local cron_entry="0 6,12,18,22 * * * /usr/bin/hubos-wallpaper rotate"
                if crontab -l 2>/dev/null | grep -qF "hubos-wallpaper rotate"; then
                    msg "Cron schedule already exists."
                else
                    (crontab -l 2>/dev/null; echo "$cron_entry") | crontab -
                    msg "\033[1;32mCron schedule installed.\033[0m"
                fi
            fi
            ;;

        disable|off)
            msg "Disabling automatic wallpaper rotation..."

            systemctl --user disable --now hubos-wallpaper.timer 2>/dev/null || true

            # Also remove cron fallback if present
            if crontab -l 2>/dev/null | grep -qF "hubos-wallpaper rotate"; then
                crontab -l 2>/dev/null | grep -vF "hubos-wallpaper rotate" | crontab -
                msg "Cron schedule removed."
            fi

            msg "Wallpaper rotation disabled."
            ;;

        status)
            echo ""
            if systemctl --user is-active hubos-wallpaper.timer &>/dev/null; then
                msg "\033[1;32mSystemd timer: active\033[0m"
                systemctl --user status hubos-wallpaper.timer --no-pager 2>/dev/null || true
            elif crontab -l 2>/dev/null | grep -qF "hubos-wallpaper rotate"; then
                msg "\033[1;32mCron schedule: active\033[0m"
                crontab -l 2>/dev/null | grep "hubos-wallpaper"
            else
                msg "\033[2mNo active schedule.\033[0m Run 'hubos-wallpaper schedule enable' to start."
            fi
            echo ""
            ;;

        *)
            err "Usage: hubos-wallpaper schedule [enable|disable|status]"
            ;;
    esac
}

cmd_download() {
    local source_url="${1:-}"
    local target_dir="$CACHE_DIR"

    echo ""
    msg "\033[1mHubOS Wallpaper Downloader\033[0m"
    echo ""

    if [[ -n "$source_url" ]]; then
        msg "Downloading from: $source_url"

        local filename
        filename="$(basename "$source_url")"
        local dest="$target_dir/$filename"

        mkdir -p "$target_dir"

        if command -v curl &>/dev/null; then
            curl -fSL --progress-bar -o "$dest" "$source_url"
        elif command -v wget &>/dev/null; then
            wget -q --show-progress -O "$dest" "$source_url"
        else
            err "Neither curl nor wget found."
        fi

        if [[ -f "$dest" ]]; then
            # If it's an archive, extract it
            case "$filename" in
                *.tar.gz|*.tgz)
                    msg "Extracting archive..."
                    tar xzf "$dest" -C "$target_dir" && rm -f "$dest"
                    ;;
                *.zip)
                    msg "Extracting archive..."
                    unzip -qo "$dest" -d "$target_dir" && rm -f "$dest"
                    ;;
                *)
                    # Sort into category
                    local cat
                    cat="$(categorize_wallpaper "$dest")"
                    mkdir -p "$target_dir/$cat"
                    mv "$dest" "$target_dir/$cat/"
                    msg "Saved to $cat/ category."
                    ;;
            esac

            local count
            count="$(get_all_wallpapers | wc -l)"
            msg "\033[1;32mDone.\033[0m $count wallpaper(s) now available."
        else
            err "Download failed."
        fi
    else
        msg "Download community wallpaper packs from the HubOS collection."
        echo ""
        echo "  Usage:"
        echo "    hubos-wallpaper download <url>"
        echo ""
        echo "  Examples:"
        echo "    hubos-wallpaper download https://hub.24hgaming.com/wallpapers/pack-v1.tar.gz"
        echo "    hubos-wallpaper download https://example.com/cool-wallpaper.png"
        echo ""
        echo -e "  \033[2mCommunity packs will be available at hub.24hgaming.com in a future update.\033[0m"
        echo ""
    fi
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<'HELP'

  hubos-wallpaper — Time-aware wallpaper management for HubOS

  Commands:
    rotate              Change wallpaper based on time of day
    set <name|path>     Set a specific wallpaper by name or file path
    list                Show all available wallpapers with categories
    random              Set a random wallpaper from the collection
    schedule [on|off]   Enable/disable automatic time-based rotation
    download [url]      Download wallpapers (or show download help)

  Time Periods:
    Morning   (06:00–12:00)  Light, bright gaming aesthetic
    Afternoon (12:00–18:00)  Vibrant, colorful scenes
    Evening   (18:00–22:00)  Warm sunset tones
    Night     (22:00–06:00)  Dark, moody gaming atmosphere

  Wallpapers are stored in /usr/share/hubos/wallpapers/ organized by
  time-of-day subdirectories. Downloaded packs go to ~/.cache/hubos/wallpapers/.

HELP
}

# ── Main ──────────────────────────────────────────────────────────────────────

ACTION="${1:-}"
shift 2>/dev/null || true

case "$ACTION" in
    rotate)             cmd_rotate ;;
    set)                cmd_set "$@" ;;
    list|ls)            cmd_list ;;
    random|rand)        cmd_random ;;
    schedule|sched)     cmd_schedule "$@" ;;
    download|dl)        cmd_download "$@" ;;
    -h|--help|help)     usage ;;
    "")
        msg "No command specified. Run \033[1mhubos-wallpaper --help\033[0m for usage."
        exit 1
        ;;
    *)
        err "Unknown command: $ACTION. Run 'hubos-wallpaper --help' for usage."
        ;;
esac
